uluscdn.com&oh=00_AYAhGJOdL_B-7hacDVjEW1dZxlFgITATJBSjPr4BoVjesg&oe=66DEF7A2"}, {"file_name": "Screenshot_6.png", "id": "1103746716896357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_1103746720229690_4764254891439105056_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_-oTz_bq7E4Q7kNvgF9Pa03&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQ3faF2TK_l-_GiqHhXnSF2p1n_Am4xz1_4VOZGsc-UA&oe=66DEDF7E"}, {"file_name": "Screenshot_2.png", "id": "2219903311518583", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974837_2219903314851916_6282926995332431501_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fNDVw1HAmJAQ7kNvgF2ouUC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBKcsy8RaEvwrg2YrGNP0uZRcOUxASrxjt_kEdmwCXGw&oe=66DEE6E7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "COVER_Landscape.png", "id": "1201511510643854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568668_1201511513977187_8294533139069675396_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VYcFtUo5oHsQ7kNvgHM9-Uu&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzVyXdRDWOck7_DLIYIjnvd2knEZRuu1JNizRh4H-x0w&oe=66DEDF94"}, "display_name": "The Great Ocean ", "keywords": [], "long_description": "In the game you explore in a high-tech ROV submarine the earth\u2019s oceans from the best diving spots in the Galapagos or in Cozumel in Mexico to the Icebergs in the Arctic and the Deep Sea and many other fascinating places around our planet's huge underwater world. In each of the levels you solve quests with your ROV's upgradeable tools based on real sunken submarines, WW2 battleship wrecks, Deep Sea creatures or Caribbean coral reefs. You will also encounter all of the giants and living wonders of the oceans from sharks, to dolphins, sea turtles and of course the blue whale and learn more about this unique, beautiful and threatened world. With your mission success you contribute to protect and save the oceans. Many hours of gameplay with a personal story, great interaction and challenging quests with a global leaderboard engage players on the exploration of the oceans and to go where no one has gone before.", "short_description": "Dive into an adventure of the earth\u2019s oceans. Explore in your high-tech submarine fascinating spots like the Galapagos or the Deep Sea and use your upgradeable tools to solve quests when you discover sunken WW2 battleships or deep sea creatures. Swim with majestic whales, sharks and sea turtles."}]}, "developer_name": null, "developer_privacy_policy_url": "https://actrio-studio.de/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actrio Studio UG", "support_website_url": null, "website_url": "https://www.actrio-studio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "767983510992950"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PENDING", "id": "409337895486603"}, {"status": "PUBLISHED", "id": "610610321006262"}, {"status": "PENDING", "id": "1260908531416319"}, {"status": "PUBLISHED", "id": "740940607190661"}, {"status": "PUBLISHED", "id": "706603804363629"}, {"status": "PENDING", "id": "799420627796973"}]}, "baseline_offer": {"id": "610610321006262"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "409337895486603"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "789246092747