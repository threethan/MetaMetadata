 stop there - now introducing multiplayer! Challenge your friends, see who can survive the longest. Are you ready to dive into a new experience? Get ready for a totally new way to play  - Blokshot VR!", "short_description": "Step into a world of heightened gaming with Blokshot VR - the fast-paced, action-packed title that combines classic arcade gameplay with a futuristic, geometric punch!  Get ready for an unbeatable, immersive game play experience. \u2013 Blokshot VR"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.player1games.com/privacy-policy", "developer_terms_of_service_url": "https://www.player1games.com/terms-of-service", "publisher_name": "player1games ", "support_website_url": "https://www.player1games.com/support", "website_url": "https://www.player1games.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "2108889222628226"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "897285338152845"}, {"status": "PUBLISHED", "id": "657390095847889"}]}, "baseline_offer": {"id": "657390095847889"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1679616000, "status": "PUBLISHED", "id": "897285338152845"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"n