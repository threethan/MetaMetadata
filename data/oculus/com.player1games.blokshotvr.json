f6J22IfFK0Q7kNvgEzGQo8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAzaFSymz1CKeu2wcKFa5Umx89FytzuWo3f5ajlNpwG_w&oe=6745BE99"}, {"file_name": "7.png", "id": "1385494998930250", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_1385495002263583_6065459306224225233_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7Jn4TIib_gQ7kNvgF6EH8D&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqfgyzTNAgxFsUkD3y1AMSyJUh4DUM3Cmbu0HlVE3mlQ&oe=6745CB1F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover landscape 2560\u04451440a.png", "id": "150893671170315", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203626_150893677836981_3219850835677365161_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sDmUZt1YLNAQ7kNvgGOHBcW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChyKFy9XqZkuG-ZQdjYrjuWS_ottH0XhXiW14ANIiJ3Q&oe=6745CC54"}, "display_name": "Blokshot VR", "keywords": [], "long_description": "Take your gaming skills to the next level with Blokshot VR! This fast-paced, action-packed shooter combines classic arcade gameplay with futuristic immersive VR gameplay, for an unbeatable experience. Compete against other Oculus players, Rack up high scores and climb to the top of the leaderboard as you blast your way through a geometric cascade of fast paced shooter action.  Put your reflexes to the test, using a range of unique weaponry to maximize your combos. The excitement doesn't stop there - prepare for, 4 player competitive multiplayer! Challenge your friends, see who can survive the longest. Are you ready blast your way into a new experience?  Blokshot VR!  A totally new way to play!", "short_description": "Step into a world of heightened gaming with Blokshot VR - the fast-paced, action-packed shooter combines classic arcade gameplay with a futuristic, geometric punch!  Get ready for an unbeatable, immersive game play experience. \u2013 Blokshot VR"}]}, "developer_name": null, "developer_privacy_policy_url"