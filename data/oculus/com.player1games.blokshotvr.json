9766822046584_943563966746048327_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zVk6da9td0UQ7kNvgEWPf0R&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkKNEtYVer1YtbxJpXn0NR5&oh=00_AYCzKvxkb4J650_6YyqnAGZXgoV6OnQyCJYTm_1JZ1koqw&oe=66F40199"}, {"file_name": "7.png", "id": "1385494998930250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_1385495002263583_6065459306224225233_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=deXH9HDAnZwQ7kNvgF6Vcqa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkKNEtYVer1YtbxJpXn0NR5&oh=00_AYC-pQfQ72mgf2gcCG8a9-HDd3vQNGRsXRaf_bOeYYDdJQ&oe=66F40E1F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover landscape 2560\u04451440a.png", "id": "150893671170315", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203626_150893677836981_3219850835677365161_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FOPDoKY4mlsQ7kNvgEnCX_O&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkKNEtYVer1YtbxJpXn0NR5&oh=00_AYCc44Jj8_yME2qTZ8rdiMSXJx3WW3v1CIU0zpgrkD4JXg&oe=66F40F54"}, "display_name": "Blokshot VR", "keywords": [], "long_description": "Take your gaming skills to the next level with Blokshot VR! This fast-paced, action-packed shooter combines classic arcade gameplay with futuristic immersive VR gameplay, for an unbeatable experience. Compete against other Oculus players, Rack up high scores and climb to the top of the leaderboard as you blast your way through a geometric cascade of fast paced shooter action.  Put your reflexes to the test, using a range of unique weaponry to maximize your combos. The excitement doesn't stop there - prepare for, 4 player competitive multiplayer! Challenge your friends, see who can survive the longest. Are you ready blast your way into a new experience?  Blokshot VR!  A totally new way to play!", "short_description": "Step into a world of heightened gaming with Blokshot VR - the fast-paced, action-packed shooter combines classic arcade gameplay with a futuristic, geometric punch!  Get ready for an unbea