scdn.com/v/t64.5771-25/39031354_393393201447291_2076182535141851136_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RqeEuElcs1gQ7kNvgHMmqtA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKIhnA86KZUxJhDuCTCsKFSv21GtEgQaNxCOy1S4Rx8g&oe=67138C46"}]}, "id": "1491875767878340", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "3460170070666631", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982576_770117963355111_396269526863314944_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=agr-WNqDhdIQ7kNvgFQleFe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCB4x7cygTA8RwjQzjfMD6HkNc86sGgGk-kqWSn9C7-PQ&oe=67138308"}, {"file_name": "migrated_image.png", "id": "3365342350149795", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_285690765435702_1574842156709838848_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWDpZZJ8zY8Q7kNvgFzX4bk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCI7ooE9jkD_mvh3fVU3x2qTGMlk_w72ESfML7bNZ3t6g&oe=6713962F"}, {"file_name": "migrated_image.png", "id": "2715717278708542", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974473_336562433866709_1194168562336399360_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0-YnrJFiH5kQ7kNvgELY6QZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgT_WV4WM32XtfHxlrW1LNI8p6LnqxWTAaybW0lFE8kQ&oe=671383DC"}, {"file_name": "migrated_image.png", "id": "2458808621099453", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982531_220086045483962_908401865325019136_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m8aVDlqB1MUQ7kNvgGsj7Fh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBN_dHQ71Q9PjSUd7C3lul1q-wozrVX1xc1ebSNBKDrQA&oe=67139FC7"}, {"file_name": "migrated_image.png", "id": "656881431741373", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982648_316758872517027_5208103800128143360_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Eyv9QFc3Zp4Q7kNvgGfPVkI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvXrkteOZKxxbiST8oj-zEF2WKNHYIhGJLZLfDAUAoHw&oe=6713AD16"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TOKYO CHRONOS -Trial Demo-", "keywords": ["Visual", "Anime", "Story", "Character", "Novel"], "long_description": "\u201cTOKYO CHRONOS\u201d is coming on March 20th, and we are getting ready to distribute the trial version! \n\n\u201cThe next Visual Novel awaits beyond the screen.\u201d\nVR Mystery Visual Novel, A story told in an immersive 360-degree world, an experience like never before\nCountless characters will come to life, right before your eyes. The story changes as you make decisions.\n\n-An empty, deserted Shibuya where time has frozen over. A mystery full of suspense, woven by 8 childhood friends trapped inside.\nA lost memory. A mysterious message, \"I am dead. Who killed me?\"\nWho is \"I\"? Why did we lose our memory? Who is the killer? \n\nFragments shattered like a broken mirror. \nWhere does the truth lie?\n\nTo kill, or not to kill \u2500 YOU decide.\n\n-Production Staff\nDirector\uff1aHaruki Kashiwakura (Motion Director of Expelled from Paradise)\nScriptwriter\uff1aKou Segawa (Mystery Writer, Konya, Kimi ni Korosareta to shitemo)\nProducer\uff1aKazuma Miki (Editor/Producer of Sword Art Online)\nCharacter Design\uff1aLAM (Illustrator)", "short_description": "\u201cTOKYO CHRONOS\u201d is coming on March 20th, and we are getting ready to distribute the trial version! \n\n\u201cThe next Visual Novel awaits beyond the screen.\u201d\nVR Mystery Visual Novel, A story told in an immersive 360-degree world. The story changes as you make decisions.\n\n-An empty, deserted Shibuya where time has frozen over. A mystery full of suspense, woven by 8 childhood friends trapped inside.\n\nA lost memory. A mysterious message, \"I am dead. Who killed me?\"\n\nTo kill, or not to kill \u2500 YOU decide."}, {"images": {"nodes": []}, "id": "837384080271987", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u6771\u4eac\u30af\u30ed\u30ce\u30b9 -\u4f53\u9a13\u7248-", "keywords": ["\u30a2\u30c9\u30d9\u30f3\u30c1\u30e3\u30fc", "ADV", "\u30a2\u30cb\u30e1", "\u30ad\u30e3\u30e9\u30af\u30bf\u30fc", "\u30b9\u30c8\u30fc\u30ea\u30fc"], "long_description": "\u3010\u6a5f\u80fd\u5236\u9650\u4ed8\u304d\u306e\u4f53\u9a13\u7248\uff01\u88fd\u54c1\u7248\u306f3/20\u30ea\u30ea\u30fc\u30b9\u4e88\u5b9a\uff01\u3011\u203bUI\u306f\u3058\u3081\u6a5f\u80fd\u3092\u4e00\u90e8\u843d\u3068\u3057\u3066\u3044\u307e\u3059\n\n\u300c\u6b21\u306e\u30a2\u30c9\u30d9\u30f3\u30c1\u30e3\u30fc\u30b2\u30fc\u30e0\u306f\u753b\u9762\u306e\u5411\u3053\u3046\u3060\u300d\n\"\u30bd\u30fc\u30c9\u30a2\u30fc\u30c8\u30fb\u30aa\u30f3\u30e9\u30a4\u30f3\" \u30d7\u30ed\u30c7\u30e5\u30fc\u30b5\u30fc\u3089\u8c6a\u83ef\u30b9\u30bf\u30c3\u30d5\u30ad\u30e3\u30b9\u30c8\u304c\u96c6\u7d50\u3002\n360\u5ea6\u306e\u5e83\u304c\u308a\u3092\u6301\u3064\u7a7a\u9593\u3067\u7d21\u304c\u308c\u308b\u3001\u672a\u4f53\u9a13\u306eVR\u30df\u30b9\u30c6\u30ea\u30fc\u30a2\u30c9\u30d9\u30f3\u30c1\u30e3\u30fc\u30b2\u30fc\u30e0\u3002\n\u76ee\u306e\u524d\u3067\u4f1a\u8a71\u3092\u7e70\u308a\u5e83\u3052\u308b\u5e7e\u591a\u306e\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u3002\u3042\u306a\u305f\u306e\u9078\u3073\u53d6\u3063\u305f\u6c7a\u65ad\u306b\u3088\u3063\u3066\u3001\u7269\u8a9e\u306f\u5909\u5316\u3059\u308b\u3002\n\n\u2015\u6642\u304c\u6b62\u307e\u3063\u305f\u8ab0\u3082\u3044\u306a\u3044\u6e0b\u8c37\u3002\u3053\u306e\u4e16\u754c\u306b\u9589\u3058\u8fbc\u3081\u3089\u308c\u305f\u306e\u306f\u5e7c\u99b4\u67d3\u3067\u3042\u308b8\u4eba\u306e\u9ad8\u6821\u751f\u305f\u3061\u3002\n\n\u5931\u308f\u308c\u305f\u8a18\u61b6\u3002\u300c\u79c1\u306f\u6b7b\u3093\u3060\u3002\u72af\u4eba\u306f\u8ab0\uff1f\u300d\u3068\u3044\u3046\u8b0e\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3002\n\u79c1\u3068\u306f\u8ab0\u306a\u306e\u304b\u3002\u4f55\u6545\u8a18\u61b6\u304c\u7121\u3044\u306e\u304b\u3002\u305d\u3057\u3066\u72af\u4eba\u306f\u8ab0\u306a\u306e\u304b\u3002\n\n\u7815\u3051\u305f\u93e1\u306e\u3088\u3046\u306b\u6563\u3089\u3070\u308b\u7121\u6570\u306e\u30ab\u30b1\u30e9\u3002\n\u3053\u306e\u4e16\u754c\u306e\u771f\u5b9f\u306f\u3069\u3053\u306b\u2500\n\n\u3042\u306a\u305f\u304c\u6c7a\u3081\u3066\u3002\u6bba\u3059\u304b\u3069\u3046\u304b\u2500\n\n\n\u25a0\u5236\u4f5c\u30b9\u30bf\u30c3\u30d5\n<\u76e3\u7763>\u67cf\u5009\u6674\u6a39(\u300c\u697d\u5712\u8ffd\u653e -Expelled from Paradise-\u300d\u30e2\u30fc\u30b7\u30e7\u30f3\u76e3\u7763)\n<\u30d7\u30ed\u30c7\u30e5\u30fc\u30b5\u30fc>\u4e09\u6728\u4e00\u99ac(\u300c\u30bd\u30fc\u30c9\u30a2\u30fc\u30c8\u30fb\u30aa\u30f3\u30e9\u30a4\u30f3\u300d\u30d7\u30ed\u30c7\u30e5\u30fc\u30b5\u30fc)\n<\u30b7\u30ca\u30ea\u30aa>\u702c\u5ddd\u30b3\u30a6(\u300c\u4eca\u591c\u3001\u541b\u306b\u6bba\u3055\u308c\u305f\u3068\u3057\u3066\u3082(\u8b1b\u8ac7\u793e\u30bf\u30a4\u30ac)\u300d\u30df\u30b9\u30c6\u30ea\u30fc\u4f5c\u5bb6)\n<\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u30c7\u30b6\u30a4\u30f3>LAM(\u30a4\u30e9\u30b9\u30c8\u30ec\u30fc\u30bf\u30fc)\n<\u6d77\u5916\u30d1\u30d6\u30ea\u30c3\u30b7\u30e3\u30fc>Sekai Project(\u300cCLANNAD\u300d\u300c\u30cd\u30b3\u3071\u3089\u300dSteam\u30d1\u30d6\u30ea\u30c3\u30b7\u30e5)\n<\u30d7\u30ed\u30e2\u30fc\u30b7\u30e7\u30f3\u30d1\u30fc\u30c8\u30ca\u30fc> Tokyo Otaku Mode Inc.\nOP\u30c6\u30fc\u30de\u66f2 : \u85cd\u4e95\u30a8\u30a4\u30eb\u300eUNLIMITED\u300f\nED\u30c6\u30fc\u30de\u66f2 :  ASCA\u300eMirage\u300f\n\n\u305d\u3057\u3066\u3001\u5236\u4f5c\u5171\u72af\u8005\u306e\u307f\u306a\u3055\u307e\u3002\n\n\u25a0\u30ad\u30e3\u30b9\u30c8\n\u6afb\u4e95\u97ff\u4ecb: cv.\u4e0a\u6751\u7950\u7fd4/ \u4e8c\u968e\u5802\u83ef\u601c: cv.\u77f3\u5ddd\u7531\u4f9d/ \u6843\u91ce\u5915: cv.\u6728\u6238\u8863\u5439/ \u6771\u56fd\u30e6\u30ea\u30a2: cv.\u67da\u6728\u5c1a\u5b50/ \u795e\u8c37\u624d: cv.\u6734\u7490\u7f8e/ \u4e21\u89d2\u611b: cv.\u685c\u3042\u305a/ \u8857\u5c0f\u8def\u98af\u592a: cv.\u690d\u7530\u572d\u8f14/ \u852d\u5c71\u54f2: cv.\u68b6\u88d5\u8cb4 / \u30ed\u30a6