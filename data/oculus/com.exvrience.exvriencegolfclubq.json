/v/t64.5771-25/38974629_1322190438186599_2427437840598176988_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CSPvvjWeEQoQ7kNvgF4-vZG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByyMKV7Pxr4-Ov9GeDLIZuxy3peVuvD93nK7_4z7t7gw&oe=674C60B2"}, {"file_name": "Clubhousepicv2.png", "id": "7250671195004946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031613_7250671198338279_2689868235985858095_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KB9Hn7RuNbYQ7kNvgGEsb1v&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOz7TTLQ8Dn-vKBKK4VVs75Txedzx8y3lCIktf505ZHQ&oe=674C3780"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscapeV9.png", "id": "1685054501684639", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982466_1685054505017972_8256876995256895557_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sp-oefK_tA8Q7kNvgGk8g-A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzvZVoJ0LXWuyWeiR_9-C2JK0NlR8nKnIgh-woe2fuSQ&oe=674C4C9E"}, "display_name": "exVRience Golf Club", "keywords": ["Golf", "Sport", "Putting"], "long_description": "Play a full 18 holes of golf on multiple themed courses, meet with friends and explore the interactive Club House.\nA truly immersive golfing experience with hazards of flowing rivers, lakes, canyons, wind and trees to make it fun and challenging.\n\nFeatures\n\u2022  Single or Online Multiplayer\n\u2022  6 full 18 hole courses including 3 Original and 3 mirrored versions\n\u2022  Play two of the courses at night\n\u2022  9 Hole Chip and Putt Challenge\n\u2022  Two tier driving range\n\u2022  Practice Green with Drill stations\n\u2022  Walk and teleport with friends around the Club House\n\u2022  Leaderboards, Hall Of Champions\n\u2022  See statistics, adjust the game to suit your swing\n\u2022  Multiple Skill levels\n\u2022  Distance, elevation and slope indicators\n\u2022  Explore feature allowing the ability to fly anywhere on the course\n\u2022  Helicopter flyovers and live satellite views\n\u2022  Save current progress feature", "short_description": "Play a full 18 holes of golf on multiple themed courses, meet with friends and explore the interactive Club House.\nA truly immersive golfing experience with hazards of flowing rivers, lakes, canyons, wind and trees to make it fun and challenging."}]}, "developer_name": null, "developer_privacy_policy_url": "https://exvrience.com/pages/privacy-policy", "developer_terms_of_service_url": "https://exvrience.com/pages/terms-and-conditions", "publisher_name": "exvrience", "support_website_url": "https://exvrience.com/pages/support", "website_url": "https://exvrience.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27941597155454414"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982568_365553091977275_5479095889733098083_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5--kfedqjZwQ7kNvgHP-LPB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZhiFW6nqco0sIzi-zN7157QazAlVpNxr70Sr2iGTCNw&oe=674C6147"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "exVRience Golf Club", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context