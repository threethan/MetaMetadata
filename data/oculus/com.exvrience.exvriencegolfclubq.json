18482729925552", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974469_218482733258885_242721205658660551_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xu1TYiQYxRcQ7kNvgGJcNXe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCukodSr0JNjI_rR5JSxyL-L_1H7Eo5I8ehlMJRyTWCgA&oe=6714D51B"}, {"file_name": "ScreenShot3.png", "id": "1088807234927165", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001699_1088807238260498_5565052483760375730_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQA6iy9XK0gQ7kNvgHu8rw0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLnaVawXifEJ3ByuGi3m98KCeNvIJ9tQg3xnW-0nj9LQ&oe=67150110"}, {"file_name": "ScreenShot5b.png", "id": "1574871236042583", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031363_1574871239375916_8466230352101111589_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ltv3xgThSpMQ7kNvgHRacRE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_0G323fHu12Hi8JIlsIP9KziFYY91dkps8q-guGfF3w&oe=6714E00F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Main2560.png", "id": "1022864634875610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974827_1022864638208943_2434641067994263392_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYoqTPDhLm0Q7kNvgGTJFXT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9KOSi9vau-LnroQmWKZx4E3K4hQN7GNPS5kuXrDowvA&oe=6714F223"}, "display_name": "exVRience Golf Club", "keywords": [], "long_description": "Play a round of Golf on the Oculus Quest using your controller as the club. \nPlay 18 holes at the custom designed Cave Lakes course, or get some swing practise in on one of the ranges. Bonus 9 hole chip challenge located on the Moon!\n \nFeatures\n\u2022  18 Hole Golf Course with rivers and lakes\n\u2022  Option to play the course mirrored\n\u2022  9 Hole Moon Chip Challenge course\n\u2022  6 Range Escapes including Beach, Space, Moon, Cliff\n\u2022  See statistics, adjust green speed and club feel\n\u202