18482729925552", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974469_218482733258885_242721205658660551_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpgVlEuwvssQ7kNvgGFKhwa&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBpGAG5tIXnko4WY90EqulYXBXaESlYydx1nnU669vJLg&oe=6710E09B"}, {"file_name": "ScreenShot3.png", "id": "1088807234927165", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001699_1088807238260498_5565052483760375730_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pYVaU5D_rvYQ7kNvgHBJCyA&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBOO3ffrk7OcetWRuv4MXhGUv2l2sNtaip3xt-8DZqEyQ&oe=67110C90"}, {"file_name": "ScreenShot5b.png", "id": "1574871236042583", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031363_1574871239375916_8466230352101111589_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7K_CIl90fBAQ7kNvgFoeCrz&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBenLDW862jEl-xiDYGAO6iNYAKfoE4gAgEun7V9sQ2yw&oe=6710EB8F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Main2560.png", "id": "1022864634875610", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974827_1022864638208943_2434641067994263392_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QcaZur8wIO8Q7kNvgFwpD_5&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD_PdPA_sOBGkyVZe0ej-hF52ExiivanQYqccPn2HbTKw&oe=6710FDA3"}, "display_name": "exVRience Golf Club", "keywords": [], "long_description": "Play a round of Golf on the Oculus Quest using your controller as the club. \nPlay 18 holes at the custom designed Cave Lakes course, or get some swing practise in on one of the ranges. Bonus 9 hole chip challenge located on the Moon!\n \nFeatures\n\u2022  18 Hole Golf Course with rivers and lakes\n\u2022  Option to play the course mirrored\n\u2022  9 Hole Moon Chip Challenge course\n\u2022  6 Range Escapes including Beach, Space, Moon, Cliff\n\u2022  See statistics, adjust green speed and club feel\n\u202