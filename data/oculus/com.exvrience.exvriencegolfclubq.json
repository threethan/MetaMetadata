LWFaK7bpW08iSaVKzBBbdjtFw&oe=6735F135"}, {"file_name": "ScreenShot1.png", "id": "218482729925552", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974469_218482733258885_242721205658660551_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=klts4ipLf5wQ7kNvgGMxp2j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxl7TbPBX8O5m9aUWvcgJHcVxKeCvhOrI8XrUW5ch5vQ&oe=6735CA9B"}, {"file_name": "ScreenShot3.png", "id": "1088807234927165", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001699_1088807238260498_5565052483760375730_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7z45e7ort8wQ7kNvgGFN7zu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCtsow5wyuqyNF1AB6c_Y8IMjXi9iP3dkkeKdo2jIdg3Q&oe=6735F690"}, {"file_name": "ScreenShot5b.png", "id": "1574871236042583", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031363_1574871239375916_8466230352101111589_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3ZIxDrvNBdEQ7kNvgEeGiIe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB28Z6sXM60MNMBGzcvoiDp_BcmtxlMbBKLWZYMDRnd-A&oe=6735D58F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Main2560.png", "id": "1022864634875610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974827_1022864638208943_2434641067994263392_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=raxGTX2aWgUQ7kNvgFfQZbq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHoy-B0x37NJdvMoM8ckkmO6BCY0_rT1xJERAVjG9s6w&oe=6735E7A3"}, "display_name": "exVRience Golf Club", "keywords": [], "long_description": "Play a round of Golf on the Oculus Quest using your controller as the club. \nPlay 18 holes at the custom designed Cave Lakes course, or get some swing practise in on one of the ranges. Bonus 9 hole chip challenge located on the Moon!\n \nFeatures\n\u2022  18 Hole Golf Course with rivers and lakes\n\u2022  Option to play the course mirrored\n\u2022  9 Hole Moon Chip Challenge course\n\u2022  6 Range Escapes including Beach, Space, Moon, Cliff\n\u2022  See statistics, adjust green speed and club feel\n\u2022  Amateur and Pro modes\n\u2022  Enhanced golf mechanics with Draw, Fade and Backspin\n\u2022  Controller distance and slope indicators\n\u2022  Explore feature allowing the ability to fly anywhere on the course\n\u2022  Helicopter Flyovers and Live Satellite views\n\u2022  Repeated bunker, putting and fairway practise\n\u2022  Save current progress feature\n\u2022  Supports two players on local headset", "short_description": "Play a round of Golf on the Oculus Quest using your controller as the club. \nPlay 18 holes at the custom designed Cave Lakes course, or get some swing practise in on one of the ranges. Bonus 9 hole chip challenge located on the Moon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://exvrience.com/pages/privacy-policy", "developer_terms_of_service_url": "https://exvrience.com/pages/terms-and-conditions", "publisher_name": "exvrience", "support_website_url": "https://exvrience.com/pages/support", "website_url": "https://exvrience.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1127266691376894"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "581812127692867"}, {"status": "PUBLISHED", "id": "1937187613453291"}, {"status": "PUBLISHED", "id": "15997933305