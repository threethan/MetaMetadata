71-25/57568674_339076337272438_4113495296300250309_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qiJXpDUwtZIQ7kNvgEHlQUu&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAg1SrolSxlYbB6QpDKSpG3CCJhVwhBvodsdT5unb1cVQ&oe=67012E98"}, {"file_name": "Oculus_VRLandscape_sc.png", "id": "320385955845299", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75339310_320385962511965_8338478632240607403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rsIwkx_Z2FMQ7kNvgFFpDvL&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB8YhEBV7VOxRzyH5SXDPCZIESy501__XpL2QRLinWX_w&oe=67012A40"}, {"file_name": "Oculus_Portrait_sc.png", "id": "319148762840245", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031334_319148766173578_3779432585996644834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L20NK5VyyokQ7kNvgE7WRPL&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA9LdVZDat-3UaW0FpvrlttqiuNAgWe7aJZG-ylxLmhFA&oe=670141B3"}]}, "id": "690696038457085", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u4e0e\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": ["\u52a8\u753b", "anime"], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its cha