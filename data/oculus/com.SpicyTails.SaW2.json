ent.oculuscdn.com&oh=00_AYC2nahrPbMIKDJx1_KxEN2IQH_0E_CeaO_9xQ8jd5WP3w&oe=66E962AF"}, {"file_name": "OculusGo_Screenshot_04.png", "id": "237826960785828", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036639_237826964119161_4418799356202695548_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WIoLj0s-M18Q7kNvgEht9SY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDT6PY42f8n3YwIiEZGAVodro38XMpejO7TidCoGMY0xQ&oe=66E978EA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SpiceandWolfVR2_PV_Oculus_En_tmb.png", "id": "376637083332832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_376637086666165_3745225190084416875_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nyVHXl8e9mEQ7kNvgF_p2LC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQJGfPNolydt9Oq43oL459QjjVxwrWJoAmFfWU6AaaJA&oe=66E95646"}, "display_name": "Spice & Wolf VR2", "keywords": ["anime", "movie", "story", "kawaii"], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Hero_sc.png", "id": "3044144615698148", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568680_3044144619031481_3023496551733235035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xn3PaZzS2QoQ7kNvgEb6tbQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZeP-JB2nNo0NRwO6WwDJiGmeBRDxt5RXMpKxMKL3Ohw&oe=66E97323"}, {"file_name": "Oculus_Square_sc.png", "id": "942634856239234", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_942634859572567_8194391438581496273_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m9mLBjrrnisQ7kNvgGhtjac&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_g5s9KT_ZTrlAu3onNmbnlA-7MiO1rd3A5DKBcTbNIw&oe=66E9670C"}, {"file_name": "Oculus_Icon_mobile.png", "id": "836460896758682", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86667275_836460900092015_2139661638604860144_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4b6inllXZ5EQ7kNvgH2xB8a&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3A-EbiPNixOYqB43TURHvyp77r1jxEEUsgJ2xu6BvpA&oe=66E97F2D"}, {"file_name": "Oculus_Landscape_sc.png", "id": "678474542743482", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348045_678474546076815_654499267490810505_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2OZQdHMaPA0Q7kNvgHLlNxF&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHsJHriXarFwZqmOmCVu6M0fKwoiriNbw5saN_5rxl9w&oe=66E96F86"}, {"file_name": "Oculus_Logo_sc.png", "id": "339076333939105", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568674_339076337272438_4113495296300250309_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=awIVLSnCOvAQ7kNvgG9mF6P&_nc_ht=scontent.oculuscdn.com&oh=00_AYCyj0MZ_62gbRL9pitTXIE8al_FRcIVOk7pkWS6UN4SuQ&oe=66E97398"}, {"file_name": "Oculus_VRLandscape_sc.png", "id": "320385955845299", "image_type": "APP_IMG_SMALL_LANDSCAPE", "