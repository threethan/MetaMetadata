=scontent.oculuscdn.com&oh=00_AYByWeY5quqI66Q7Zcy2zpcuvK_8u0y_kfLnw-o30vqfIQ&oe=66D990AF"}, {"file_name": "OculusGo_Screenshot_04.png", "id": "237826960785828", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036639_237826964119161_4418799356202695548_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bd9b9rr7a3gQ7kNvgGA-ysB&_nc_ht=scontent.oculuscdn.com&oh=00_AYD39YY7nnbVs47xq7C42EpXceUVu6gOgOeXg8koKkGPSQ&oe=66D9A6EA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SpiceandWolfVR2_PV_Oculus_En_tmb.png", "id": "376637083332832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_376637086666165_3745225190084416875_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IG8XxSmu4rMQ7kNvgG0IQJ7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwfLCcFZxN-bvuWtDp5ecuvv6z_-3JPuAN8ML-pyU9Aw&oe=66D98446"}, "display_name": "Spice & Wolf VR2", "keywords": ["anime", "movie", "story", "kawaii"], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Hero_sc.png", "id": "3044144615698148", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568680_3044144619031481_3023496551733235035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jUIJ-vq7XhIQ7kNvgEP_d1l&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZv60LGdLc53KbaQ3cCEa4vkPjp8g8dYfSnTaKaQCmnQ&oe=66D9A123"}, {"file_name": "Oculus_Square_sc.png", "id": "942634856239234", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_942634859572567_8194391438581496273_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V_FeZ5n6WwMQ7kNvgEOVoGO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZsrUMYtnVPW71qCv6RyiQzk_HgfsVlIjiuvgN8zzubw&oe=66D9950C"}, {"file_name": "Oculus_Icon_mobile.png", "id": "836460896758682", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86667275_836460900092015_2139661638604860144_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oa-ntWsyIG0Q7kNvgGbdhgr&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9-tFlBkIQIlfVb51QNAXVTuxXGxrJHlfQl_GZd5ZLAA&oe=66D9AD2D"}, {"file_name": "Oculus_Landscape_sc.png", "id": "678474542743482", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348045_678474546076815_654499267490810505_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ly9eEy41UYMQ7kNvgHeFefk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfUC2n29f8fsUJpdaKjUux1yeKGkH_8_PTglDcD8ZLmQ&oe=66D99D86"}, {"file_name": "Oculus_Logo_sc.png", "id": "339076333939105", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568674_339076337272438_4113495296300250309_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LFYoOppm8B4Q7kNvgHSCVwj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDeK2JcsIaHCEXskYqudKJxZA843FVs-wA7bEBY_2vhhg&oe=66D9A198"}, {"file_name": "Oculus_VRLandscape_sc.png", "id": "320385955845299", "image_type": "APP_IMG_SMALL_LANDSCA