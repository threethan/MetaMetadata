ent.oculuscdn.com&oh=00_AYC-9DTOdaqNVM2ZA8pec32N3Dn3sj47ZSHbiXZ9nTmKqA&oe=66FFCC2F"}, {"file_name": "OculusGo_Screenshot_04.png", "id": "237826960785828", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036639_237826964119161_4418799356202695548_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GG7SDM2JCEIQ7kNvgGw7nb5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDe63_aiF9uDVujXOox3K-DWA0cHfwpcXYVZrjoJZVAow&oe=66FFE26A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SpiceandWolfVR2_PV_Oculus_En_tmb.png", "id": "376637083332832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_376637086666165_3745225190084416875_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GmkbdiCMAK0Q7kNvgHLVMk7&_nc_ht=scontent.oculuscdn.com&oh=00_AYBmhquPzSn6umm-62Pq84-MTWrHIQg53zzOh8x4r8qe3w&oe=66FFBFC6"}, "display_name": "Spice & Wolf VR2", "keywords": ["anime", "movie", "story", "kawaii"], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Hero_sc.png", "id": "3044144615698148", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568680_3044144619031481_3023496551733235035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uIQu9B1FT2kQ7kNvgFBUiWs&_nc_ht=scontent.oculuscdn.com&oh=00_AYBiPALRdYHtKYD4L-KTfWc1GYAbNUY3kcAos1aQNuSrbw&oe=66FFDCA3"}, {"file_name": "Oculus_Square_sc.png", "id": "942634856239234", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_942634859572567_8194391438581496273_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hlwR7aoPGnkQ7kNvgE7npjb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCM2nQmkb1DVlf8O7HTJ6tXJIEL2CrYQSlMt1YrLjw9kw&oe=66FFD08C"}, {"file_name": "Oculus_Icon_mobile.png", "id": "836460896758682", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86667275_836460900092015_2139661638604860144_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9lXog4t8XkQ7kNvgEnneEx&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQgYhQoIxt2GB1a3EbDxc7nBrmZg1WZ1HSAbOpAcTocg&oe=66FFE8AD"}, {"file_name": "Oculus_Landscape_sc.png", "id": "678474542743482", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348045_678474546076815_654499267490810505_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RiEK66nkI7AQ7kNvgEeR6aT&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGErQfmETHTldrlHDMM6esvMuqU6edie19l8clcZpWtQ&oe=66FFD906"}, {"file_name": "Oculus_Logo_sc.png", "id": "339076333939105", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568674_339076337272438_4113495296300250309_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ffIxkVIw9kQ7kNvgF48ME9&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRGSyDIjbVVJtC_YglD2dY3HowKiCdxycPo9Wp6L5sdA&oe=66FFDD18"}, {"file_name": "Oculus_VRLandscape_sc.png", "id": "320385955845299", "image_type": "APP_IMG_SMALL_LANDSCAPE", "