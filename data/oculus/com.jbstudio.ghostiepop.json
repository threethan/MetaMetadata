is great for a wide range of players. Whether you're playing for a quick challenge or aiming for a high score, this exciting game will keep you coming back for more ghost-popping fun!", "short_description": "Ghostie Pop is a fun VR game where you shoot cute, dancing ghosts with umbrellas as they pop up around you. Play in passthrough mode and earn points by hitting as many ghosts as you can in this lighthearted challenge!"}]}, "developer_name": "JB Studio", "developer_privacy_policy_url": "https://sites.google.com/view/vrprivacy/home", "developer_terms_of_service_url": null, "publisher_name": "JB Studio", "support_website_url": null, "website_url": "https://jahanbihamta.com/vr-kalimba/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8397685090299483"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "511706428694662"}, {"status": "PUBLISHED", "id": "955798303235607"}]}, "baseline_offer": {"id": "511706428694662"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734789001, "status": "PUBLISHED", "id": "511706428694662"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8403838233017502", "version": "1.0.3"}, "id": "1621211961760117", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {