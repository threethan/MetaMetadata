luscdn.com/v/t64.5771-25/57574715_1071149644020784_3299312956310643785_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TdQrpcWQQg8Q7kNvgHDNuVx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmB0GLrtGlJhlHYiW3mutKvQDVJkQ4RjfJyouKDU-0eQ&oe=674B0859"}, {"file_name": "2560X1440.png", "id": "845725414297677", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031491_845725417631010_4334978492591596031_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZUfo0SwJr0sQ7kNvgHlTHzw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAD8bD9TENdxR0lW4bL0NzvPv3-BAPtkOlzz3X_IhPo6g&oe=674AFA32"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "426535033794301", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_426535037127634_4532462392567182653_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uIXHtPZd8C0Q7kNvgG5nYf5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNbMOeV7fSU2jDMjHaYHyX-9I6efNmujwTKn6kiPX94w&oe=674AFD4B"}, "display_name": "Ghostie pop", "keywords": ["casual", "hypercasual", "shooting", "arcade", "Fun"], "long_description": "Step into Ghostie Pop, a fun and easy-to-play VR game that mixes the real and virtual worlds. In passthrough mode, you\u2019ll see playful dancing ghosts appear randomly around you. \nYour goal? Aim and shoot to pop these ghosts and earn points. With its charming characters, simple controls, and fast-paced action, Ghostie Pop is great for a wide range of players. Whether you're playing for a quick challenge or aiming for a high score, this exciting game will keep you coming back for more ghost-popping fun!", "short_description": "Ghostie Pop is a fun VR game where you shoot cute, dancing ghosts with umbrellas as they pop up around you. Play in passthrough mode and earn points by hitting as many ghosts as you can in this lighthearted challenge!"}]}, "developer_name": "JB Studio", "developer_privacy_policy_url": "https://sites.google.com/view/vrprivacy/home", "deve