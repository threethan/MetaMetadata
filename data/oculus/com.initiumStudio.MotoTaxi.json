81", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036683_441092358529714_8045405257923986193_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ZNySprUK8YQ7kNvgEWiLnS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdzMMAhYGT7mf3lZK8qvrHE8mhKVnUj6m2g0X-n7gbxg&oe=67825653"}]}, "id": "461179056423300", "locale": "en_US", "screenshots": [{"file_name": "6.png", "id": "975463903801189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568684_975463907134522_3726521819271984364_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXn7R4bw5OEQ7kNvgE5BSrR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAakTzzRQqWXjNsB6hBPYdMG3JBkJ0MIbME1cO_ybVR4A&oe=67825C48"}, {"file_name": "3.png", "id": "827402679291894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974875_827402682625227_1084740394031096118_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ggk6Y3maIsQ7kNvgGGCfsh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsn5AnHW2J3rKx-tl_54SrvtgXBpsOZGKw78a5bFraoQ&oe=67826427"}, {"file_name": "4.png", "id": "1394347621959142", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542956_1394347625292475_6899015252017173603_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4bEFodto1yMQ7kNvgGKW9AE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMAoTfbQ_jOACU6cHcD_aK4hgZSEoGkt3t0ieXqbiE0Q&oe=67824DDD"}, {"file_name": "1.png", "id": "1332902114768125", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75356792_1332902118101458_2708771965368097196_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VM57U8PzqAYQ7kNvgEIdAqN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnjOUnUqEJpEEQAnTSfKAn6M8werOTQotGVyibs9w1bw&oe=6782615F"}, {"file_name": "2.png", "id": "1403391847029913", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974508_1403391850363246_4792441136444686796_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UXQE6amvH_8Q7kNvgHDUUm6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmdPYwMryXZmyPqEPgsP995tYWOGdLiWsjLqD2sQsP6g&oe=67827304"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_Logo.png", "id": "1648180182681629", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982602_1648180189348295_892454689671109805_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jQZHaXGYKuwQ7kNvgHFeEwX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAZ0ufCoytWeZwH147DzrnH4dixBabdc_vx4kuvbhEphQ&oe=67823D4B"}, "display_name": "Moto Taxi", "keywords": [], "long_description": "Get ready for an exhilarating ride like no other with VR Moto Taxi! Immerse yourself in the bustling city streets where you take on the role of a fearless moto taxi driver. Your mission? To navigate through heavy traffic, make sharp turns, and deliver your passengers to their destinations on time, all while enjoying the thrill of the ride.\n\nKey Features:\n\nRealistic City Environment: Explore a vibrant and dynamic city with stunning graphics that bring every street, alley, and landmark to life.\nImmersive VR Experience: Feel the rush of the ride with VR technology that puts you right in the driver's seat. The city feels more alive than ever as you weave through traffic and take in the sights.\nbHaptics Support: Enhance your experience with bHaptics feedback, feeling every turn, bump, and acceleration as if you were truly on the road.\nChallenging Missions: Take on various missions that test your driving skills and speed. From urgent deliveries to VIP passengers, every ride is a new challenge.\nCustomization Options: Personalize your moto taxi with different skins and upgrades to make it truly your own. Stand out in the city and show off your style.\nLeaderboards and Achievements: Compete with other players worldwide. Climb the leaderboards and unlock achievements to prove you're the best moto taxi driver around.\n", "short_description": "Moto Taxi: Thrilling Rides Through the City!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gametriclabs.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "\u0130N\u0130T\u0130UM STUD\u0130O", "support_website_url": null, "website_url": "https://gametriclabs.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7864103276967626"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "576566661480157"}, {"status": "PUBLISHED", "id": "768255465393815"}, {"status": "PUBLISHED", "id": "1652439735299086"}, {"status": "PUBLISHED", "id": "451110047522389"}]}, "baseline_offer": {"id": "768255465393815"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "576566661480157"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8935992586445351", "version": "1.0.3"}, "id": "462846982894889", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7864103250300962", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8935992586445351"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "462846982894889"}]}, "change_log