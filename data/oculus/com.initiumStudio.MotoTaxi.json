hots": [{"file_name": "6.png", "id": "975463903801189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568684_975463907134522_3726521819271984364_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4XgIX-Mq3xsQ7kNvgEZ6M8F&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNY7QpA67RgmC9BXWVUIES2LHfTGSOb23iyTs4eVDJEA&oe=6784FF48"}, {"file_name": "3.png", "id": "827402679291894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974875_827402682625227_1084740394031096118_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ggk6Y3maIsQ7kNvgE6snDD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBe7uq_VbeFwbelMOpihqnKwi6W_vDixEp8ByD7ywtKJQ&oe=67850727"}, {"file_name": "4.png", "id": "1394347621959142", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542956_1394347625292475_6899015252017173603_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1_sr200aCHYQ7kNvgGLVk08&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAkO7sQb3wnxXuntXBzOUQuaDNRx2v_DIUmsexSCK1FA&oe=6784F0DD"}, {"file_name": "1.png", "id": "1332902114768125", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75356792_1332902118101458_2708771965368097196_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LIl5Ce1LO9cQ7kNvgE9j0J9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTxM-vvUYLZJ6ySoShwW4Lg1KBakOefW_3WZpafGunxw&oe=6785045F"}, {"file_name": "2.png", "id": "1403391847029913", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974508_1403391850363246_4792441136444686796_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MOGnm4Xc9y0Q7kNvgH-iuM_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyHFSU8T_cdMtjZ7Pe-WPeduxcNSDTWHMsSypY6zxSPg&oe=67851604"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_Logo.png", "id": "1648180182681629", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982602_1648180189348295_892454689671109805_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dAaZvYxa0usQ7kNvgGrGSKt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB635F8WlXH_a7EcSloMAEEdXMahZoezRCzQmpUDgId6g&oe=6785188B"}, "display_name": "Moto Taxi", "keywords": [], "long_description": "Get ready for an exhilarating ride like no other with VR Moto Taxi! Immerse yourself in the bustling city streets where you take on the role of a fearless moto taxi driver. Your mission? To navigate through heavy traffic, make sharp turns, and deliver your passengers to their destinations on time, all while enjoying the thrill of the ride.\n\nKey Features:\n\nRealistic City Environment: Explore a vibrant and dynamic city with stunning graphics that bring every street, alley, and landmark to life.\nImmersive VR Experience: Feel the rush of the ride with VR technology that puts you right in the driver's seat. The city feels more alive than ever as you weave through traffic and take in the sights.\nbHaptics Support: Enhance your experience with bHaptics feedback, feeling every turn, bump, and acceleration as if you were truly on the road.\nChallenging Missions: Take on various missions that test your driving skills and speed. From urgent deliveries to VIP passengers, every ride is a new challenge.\nCustomization Options: Personalize your moto taxi with different skins and upgrades to make it truly your own. Stand out in the city and show off your style.\nLeaderboards and Achievements: Compete with other players worldwide. Climb the leaderboards and unlock achievements to prove you're the best moto taxi driver around.\n", "short_description": "Moto Taxi: Thrilling Rides Through the City!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gametriclabs.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "\u0130N\u0130T\u0130UM STUD\u0130O", "support_website_url": null, "website_url": "https://gametriclabs.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES