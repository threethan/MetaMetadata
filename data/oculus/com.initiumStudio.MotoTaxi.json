81", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036683_441092358529714_8045405257923986193_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pw2bJsH3iR4Q7kNvgGtM4To&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDWaw1_ibkcjxJcZ7oDExx__roZjlSKJh_Z6pny9OM80w&oe=675977D3"}]}, "id": "461179056423300", "locale": "en_US", "screenshots": [{"file_name": "6.png", "id": "975463903801189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568684_975463907134522_3726521819271984364_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzqvRXqK7b4Q7kNvgGpwGZH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZBmJLkI9aJ_BCe2syQsiUpaxTQmHcJtOV7FEr8rf44A&oe=67597DC8"}, {"file_name": "3.png", "id": "827402679291894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974875_827402682625227_1084740394031096118_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jguzrPSCQZQQ7kNvgHLhDmo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2HNKze9bVsewKr9-CB2w8TDqUrrFRXmmW4HG-riueLA&oe=675985A7"}, {"file_name": "4.png", "id": "1394347621959142", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542956_1394347625292475_6899015252017173603_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9GOP4KZpllsQ7kNvgEeO4AY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbcm_2vKmdCnj9f7u7j2AY9C1nYD-w38TgyXhgro-yTw&oe=67596F5D"}, {"file_name": "1.png", "id": "1332902114768125", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75356792_1332902118101458_2708771965368097196_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ji7ZOJAUxpkQ7kNvgF9znJt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVM2HuwLHY4zL7qswIVhZbRL3Xh09Z7gmhi73PpUI73w&oe=675982DF"}, {"file_name": "2.png", "id": "1403391847029913", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974508_1403391850363246_4792441136444686796_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rs-vX35bMjEQ7kNvgGe2yc5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRuiZnxQInLab8zPslBFAppsih3a2ow3CUXdGtmp5KPA&oe=67599484"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_Logo.png", "id": "1648180182681629", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982602_1648180189348295_892454689671109805_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=POlPP62H6kAQ7kNvgEN_Cn0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9buL3zmZGq3J8LjINuzOqm8W8RzSsh6iPZV_v8ejFKg&oe=6759970B"}, "display_name": "Moto Taxi", "keywords": [], "long_description": "Get ready for an exhilarating ride like no other with VR Moto Taxi! Immerse yourself in the bustling city streets where you take on the role of a fearless moto taxi driver. Your mission? To navigate through heavy traffic, make sharp turns, and deliver your passengers to their destinations on time, all while enjoying the thrill of the ride.\n\nKey Features:\n\nRealistic City Environment: Explore a vibrant and dynamic city with stunning graphics that bring every street, alley, and landmark to life.\nImmersive VR Experience: Feel the rush of the ride with VR technology that puts you right in the driver's seat. The city feels more alive than ever as you weave through traffic and take in the sights.\nbHaptics Support: Enhance your experience with bHaptics feedback, feeling every turn, bump, and acceleration as if you were truly on the road.\nChallenging Missions: Take on various missions that test your driving skills and speed. From urgent deliveries to VIP passengers, every ride is a new challenge.\nCustomization Options: Personalize your moto taxi with different skins and upgrades to make it truly your own. Stand out in the city and show off your style.\nLeaderboards and Achievements: Compete with other players worldwide. Climb the leaderboards and unlock achievements to prove you're the best moto taxi driver around.\n", "short_description": "Moto Taxi: Thrilling Rides Through the City!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gametriclabs.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "\u0130N\u0130T\u0130UM STUD\u0130O", "support_website_url": null, "website_url": "https://gametriclabs.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7864103276967626"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "768255465393815"}, {"status": "PUBLISHED", "id": "1652439735299086"}, {"status": "PUBLISHED", "id": "451110047522389"}]}, "baseline_offer": {"id": "768255465393815"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728334021, "status": "PUBLISHED", "id": "768255465393815"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8935992586445351", "version": "1.0.3"}, "id": "462846982894889", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7864103250300962", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8935992586445351"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "462846982894889"}]}, "change_log": null, "created_date": 1730974119, "id": "89359