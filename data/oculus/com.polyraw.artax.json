YHGOjXN_qqCG4u-YAMiHtDd8qqfSbSuEvwUVpA&oe=670A73C1"}, "display_name": "Artax", "keywords": ["magic", "fantasy", "rpg", "adventure", "toy"], "long_description": "Artax is a toy knight, you will have to guide him in a dreamlike fantasy world in search of Bulf, another warrior toy, who wanted to get out of his box to take his kingdom. Help him to face pitfalls and enemies in a strange, magical world. You are like a chessmaster playing chess, with your VR device you have the perpective from the top, like in a chess play, all your characters will follow your moves and the game respond with his moves.. but you are not locked into a chessboard, the characters will go around the castle, and there will be traps and enemy ready to attack you! So choose your right move to keep exploring the scenario and reach the end of the journey.", "short_description": "Artax is a toy knight, you will have to guide him in a dreamlike fantasy world in search of Bulf, another warrior toy, who wanted to get out of his box to take his kingdom. Help him to face pitfalls and enemies in a strange, magical world."}]}, "developer_name": "Polyraw Development", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Polyraw Development", "support_website_url": null, "website_url": "http://polyrawdevelopment.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "RPG", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4398464386921328"}}]}, "scheduled_offer