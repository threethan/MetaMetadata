04221268582504_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Eg4oBtJqeGIQ7kNvgHumCJz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA12-FJ0UCh5H_G3clNGoRvUcDrrbct0S0VF6j31i_uKg&oe=6762BB49"}, {"file_name": "\uc2a4\uc0f72.png", "id": "567895897555019", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982486_567895900888352_7787595902512532766_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_HnTnLUyo4cQ7kNvgHq70HZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAuLvTV9ZzSjL7h6FufE54O95fCyqzfXSw1xZUOdXsQVA&oe=6762B92E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\uc81c\ubaa9-\uc5c6\uc74c-1.png", "id": "811892373005891", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036682_811892376339224_4096970328336759118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zYzQp7z5jgQ7kNvgHMcmkt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLorAfz-iHxoZLTf3pYpSXq_TrzoGH2HHib1foV_CUbQ&oe=6762A1A2"}, "display_name": "Dancing Arrow : K-pop Challenge", "keywords": ["Rhythm", "KPOP", "DANCE", "IDOL", "Esport"], "long_description": "You can score points by hitting the flying arrows according to the colors, and you can enjoy the game by expressing the dance moves.\n\nDifficulty levels make the game easy to play, and more difficult levels will give you a lot of fun.\n\n\n \u25a0 Secured the best K-POP music license\n      -BTS, BLACKPINK, TWICE, PSY, ITZY, etc.\n      -3 difficulty levels: EASY, NORMAL, HARD\n\n \u25a0 Apply real dance moves to the game\n      -Apply choreography to become a key point\n\n \u25a0 Easy UI configuration and intuitive expression\n      -Comfortable design at a glance\n\n \u25a0 More than 5 new music updates every month\n      -Want new music? Apply through the community!\n\n \u25a0 Global Leaderboard\n      -Challenge the global ranking!", "short_description": "Dancing Arrow is a VR game that lets you enjoy music rhythm games with K-POP."}]}, "developer_name": null, "developer_privacy_p