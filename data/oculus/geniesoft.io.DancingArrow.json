{"data": {"node": {"__typename": "Application", "id": "3883253438405485", "organization": {"id": "103144327616604", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "5283108098470168"}]}, "id": "574587540902486"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "4898127796914678"}]}, "id": "1386558665110365"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "3883253438405485"}]}, "id": "441689083931097"}]}}, "firstRevision": {"nodes": [{"application": {"id": "3883253438405485", "release_date": 1621957281, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 2}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8979317472132364"}, "id": "483220379752270"}]}}, "binary": {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3883253438405485", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8979317472132364"}, "release_status": "RELEASED"}, "id": "8979317472132364", "version": "9.3.4", "version_code": 17, "release_status": "RELEASED", "status": "APPROVED"}, "live_binary": null, "created_date": 1733993982, "id": "8979320255465419", "is_initial_release": false, "name_with_fallback": "v6", "pdp_metadata_with_fallback": {"version": 6, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "9007643685966409"}, "release_status": "RELEASED", "id": "3883253438405485"}, "id": "9007643685966409", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3883253438405485", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "756089798372487"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "1432989698088232", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ub304\uc2f1\uc5d0\ub85c\uc6b0 : K-pop Challenge", "keywords": ["\ub9ac\ub4ec", "\ub304\uc2a4", "\uc774\uc2a4\ud3ec\uce20", "\ucf00\uc774\ud31d", "\uc544\uc774\ub3cc"], "long_description": "\ub304\uc2f1\uc5d0\ub85c\uc6b0\ub294 K-POP\uc758 \uc9dc\ub9bf\ud55c \ube44\ud2b8\uc640 \ud568\uaed8 \ucda4\uc744 \ucd94\uace0, \uc628\ubab8\uc73c\ub85c \ub9ac\ub4ec\uc744 \uc990\uae30\ub294 VR \ub9ac\ub4ec \uc561\uc158 \uac8c\uc784\uc785\ub2c8\ub2e4!\n\ub2e8\uc21c\ud55c \ub9ac\ub4ec \uac8c\uc784\uc744 \ub118\uc5b4\uc120 \ub304\uc2f1\uc758 \uc990\uac70\uc6c0\uacfc \uc2e4\uac10 \ub098\ub294 \uc561\uc158\uc744 \uacbd\ud5d8\ud574\ubcf4\uc138\uc694.\n\ub2f9\uc2e0\uc774 \ucda4\uc744 \ucd9c \ub54c, \ube44\ud2b8\ub3c4 \ud568\uaed8 \uc644\uc131\ub429\ub2c8\ub2e4!\n\n\ud83d\udd25 \uac8c\uc784\uc758 \ub9e4\ub825 \ud3ec\uc778\ud2b8\n\ud83c\udfb5 1. K-POP \ucd5c\uace0\uc758 \ud788\ud2b8\uace1 \ucd1d\uc9d1\ud569!\n\uc138\uacc4\ub97c \uc0ac\ub85c\uc7a1\uc740 K-POP \uc2a4\ud0c0\ub4e4\uc758 \uc778\uae30 \uace1\uc744 \ub9ac\ub4ec\uc5d0 \ub9de\ucdb0 \ud50c\ub808\uc774\ud558\uc138\uc694!\n* 30\uc5ec\uace1\uc758 \ub2e4\uc591\ud55c \ud2b8\ub799 \uc218\ub85d\n* 9\uc8fc\ub9c8\ub2e4 \uc0c8\ub86d\uac8c \uc5c5\ub370\uc774\ud2b8 \ub418\ub294 K-POP!\n\n\ud83c\udff9 2. \ub9ac\ub4ec\uacfc \uc561\uc158\uc758 \uc644\ubcbd\ud55c \uc870\ud654!\n\ube44\ud2b8\uc5d0 \ub9de\ucdb0 \ub0a0\uc544\uc624\ub294 \ud654\uc0b4\uc744 \uc815\ud655\ud558\uac8c \ud0c0\uaca9\ud558\uba70 \uc74c\uc545\uc758 \ud750\ub984\uc5d0 \ubab8\uc744 \ub9e1\uae30\uc138\uc694.\n* \ud654\ub824\ud55c \ube44\uc8fc\uc5bc \uc774\ud399\ud2b8\uc640 \ud0c0\uaca9\uac10\n* \ub9ac\ub4ec\uacfc \ud0c0\uc774\ubc0d\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c0\ub294 \ud37c\ud3ec\uba3c\uc2a4 \ud6a8\uacfc\n\n\ud83d\udc83 3. \ucda4\uc744 \ucd94\ub4ef \uc6c0\uc9c1\uc774\ub294 VR \ud37c\ud3ec\uba3c\uc2a4!\n\uc2e4\uc81c \uc548\ubb34\uc758 \ud575\uc2ec \ud3ec\uc778\ud2b8\ub97c \uc801\uc6a9\ud558\uc5ec, \uac8c\uc784\uc744 \ud558\uba74\uc11c \uc790\uc5f0\uc2a4\ub7fd\uac8c \ucda4\uc774 \uc644\uc131\ub429\ub2c8\ub2e4.\n* \uac8c\uc784\uacfc \ub304\uc2a4\uc758 \ud658\uc0c1\uc801\uc778 \ucf5c\ub77c\ubcf4\ub808\uc774\uc158\n* \ud50c\ub808\uc774 \ud6c4, \ub2f9\uc2e0\uc740 \uc774\ubbf8 \ubb34\ub300 \uc704 \uc8fc\uc778\uacf5!\n\n\ud83c\udfae 4. \ub204\uad6c\ub098 \uc990\uae38 \uc218 \uc788\ub294 \uc9c1\uad00\uc801\uc778 \uac8c\uc784\ud50c\ub808\uc774\n* EASY, NORMAL, HARD \ub2e4\uc591\ud55c \ub09c\uc774\ub3c4 \uc120\ud0dd\n* VR \uc785\ubb38\uc790\ub3c4 \uc27d\uac8c \uc990\uae38 \uc218 \uc788\ub294 \uac04\ub2e8\ud558\uace0 \uc9c1\uad00\uc801\uc778 \uc870\uc791\n\n\ud83c\udf0d 5. \uae00\ub85c\ubc8c \ub9ac\ub354\ubcf4\ub4dc\uc640 \ub05d\uc5c6\ub294 \ub3c4\uc804\n* \uc804 \uc138\uacc4 \uc720\uc800\ub4e4\uacfc \uc2a4\ucf54\uc5b4 \uacbd\uc7c1\n* \ucd5c\uace0\uc758 \ub9ac\ub4ec \ub9c8\uc2a4\ud130\uac00 \ub418\uc5b4 \uae00\ub85c\ubc8c \ub7ad\ud0b9\uc744 \uc815\ubcf5\ud558\uc138\uc694!", "short_description": "\ub304\uc2f1 \uc5d0\ub85c\uc6b0\ub294 \uc74c\uc545 \ub9ac\ub4ec\uac8c\uc784\uc744 K-POP\uc73c\ub85c \uc990\uae38 \uc218 \uc788\ub294 VR \uac8c\uc784\uc785\ub2c8\ub2e4.\n\ub0a0\uc544\uc624\ub294 \ud654\uc0b4\ud45c\ub97c \uceec\ub7ec\uc5d0 \ub9de\uac8c \ud0c0\uaca9\ud558\uc5ec \uc810\uc218\ub97c \uc5bb\uc744 \uc218 \uc788\uc73c\uba70, \ucda4 \ub3d9\uc791\uc744 \ud45c\ud604\ud558\uc5ec \uac8c\uc784\uc744 \uc990\uae38 \uc218 \uc788\uc5b4 \ub354\uc6b1 \uc7ac\ubbf8\uc788\uac8c \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "MainSquare.png", "id": "1914317272313479", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035412_1914317275646812_1350569248386285776_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ABWIsFYHCkQ7kNvgGKm_E8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJ4mT6n7BjB8iv5VJZqMNiFik8XJd1915_r3okfyur0w&oe=676D4CE4"}, {"file_name": "MainSquare2.png", "id": "910703074359720", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568683_910703077693053_3031650893942563794_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BW4W_eaN4uAQ7kNvgH3qeS1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCVvQnI-YnDltlCE1n9XfYItGDktpfy8zWZ0u-8aL_DQ&oe=676D3640"}, {"file_name": "ICON.png", "id": "821998805336330", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982542_821998808669663_6785008659292218609_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YkdM47twKAkQ7kNvgGySLQR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCNa_92VSfWgezXt9MoWCxZINME7TMZv1QvqtHqHjH7A&oe=676D4829"}, {"file_name": "DA_main.png", "id": "562906243163379", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569471_562906246496712_8249429224473374736_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJ_giJNoAAsQ7kNvgEkWiBe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBx69KQf0lbwTOBxbiQ4Nzl7UFEeX9Lvxi4p9JzpjK5ag&oe=676D5C19"}, {"file_name": "DA.png", "id": "489152620136426", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036706_489152623469759_550100267341502962_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bf6YvLRMVaUQ7kNvgFUvLff&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPggrxS1gENmx0iwD9nN1Py9SSesOLfcG29SzE2Z1rNQ&oe=676D3F61"}, {"file_name": "\uc81c\ubaa9-\uc5c6\uc74c-1.png", "id": "484445745893527", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568674_484445749226860_4716077246201203046_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PmwIWIpVUcMQ7kNvgEM8pdT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKAh07LOWNCOY2c5jRzOOfdxJH3moLE0GgMjmN80NhPQ&oe=676D2636"}, {"file_name": "\uc81c\ubaa9-\uc5c6\uc74c-1.png", "id": "288518742671302", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974789_288518746004635_8386170729958200457_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TLd_YyHZP4IQ7kNvgGbhkVh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDK_O8KgBdS5fld2U-w0g4JImbZChxiu21tMBTzKMAviQ&oe=676D5823"}]}, "id": "897564282446117", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "1136800050126063", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031438_1136800053459396_2326459411568869979_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oblSv_Bt9OEQ7kNvgHwP5RV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhM3N4J7rDMtCY9li3BI2gKiIU6eNBUgDf6tWtBsIYhA&oe=676D4CCC"}, {"file_name": "\uc2a4\uc0f73.png", "id": "903810803545231", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035451_903810806878564_8395426510307741718_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I-k11Xq0bs4Q7kNvgFDA1gA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCf7l81ii9tXy5MmMnaPrRlFBfk26XFvcrUxv9DCfI8gA&oe=676D2AC0"}, {"file_name": "\uc2a4\uc0f75.png", "id": "1958675957643431", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75250454_1958675960976764_4202482730125913005_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7Kt6Z9aRb8Q7kNvgE9knU8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAcnWdSKGCJinMgsaYd8Sbt7ExXrlkfFqJPoKOB1IZc7g&oe=676D57FE"}, {"file_name": "\uc2a4\uc0f74.png", "id": "387111202764218", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031467_387111206097551_6135204221268582504_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z8TMUfQOIj0Q7kNvgHAb2ZK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7kdxhk3zKIPilCrNXAT6rUGU9hq4ctLNHqopY1tV0eA&oe=676D4749"}, {"file_name": "\uc2a4\uc0f72.png", "id": "567895897555019", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982486_567895900888352_7787595902512532766_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ry7tQipyFUkQ7kNvgHEfpGq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXYuukCk1HSdbmmeDV9pyQe5SmuTcW4hBtySYFukKd3g&oe=676D452E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\uc81c\ubaa9-\uc5c6\uc74c-1.png", "id": "811892373005891", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036682_811892376339224_4096970328336759118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RzO4rGjTQC4Q7kNvgEKOIXa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChs41owAoewEhZUWgABMhIdbqRgSLZdD0JcZawmVedaA&oe=676D2DA2"}, "display_name": "Dancing Arrow : K-pop Challenge", "keywords": ["Rhythm", "KPOP", "DANCE", "IDOL", "Esport"], "long_description": "DancingArrow is a VR rhythm action game that lets you dance to the electrifying beats of K-POP and enjoy the rhythm with your whole body!\nExperience the joy of dancing and realistic action that goes beyond just a rhythm game.\nWhen you dance, the beat is complete!\n\n\ud83d\udd25 Game features\n\ud83c\udfb5 1. A collection of K-POP's biggest hits!\nPlay popular songs by K-POP stars that have captivated the world!\n* Over 30 different tracks\n* New K-POP songs updated every 9 weeks!\n\n\ud83c\udff9 2. Perfect blend of rhythm and action!\nGet in the flow of the music as you accurately hit the flying arrows in time to the beat.\n* Colorful visual effects and the feeling of hitting\n* Performance effects that depend on your rhythm and timing\n\n\ud83d\udc83 3. VR performance that moves like you're dancing!\nBy applying key points of real-life choreography, your dance will come naturally as you play the game.\n* Fantastic collaboration between game and dance\n* After playing, you are already a star on stage!\n\n\ud83c\udfae 4. Intuitive gameplay for everyone to enjoy\n* Multiple difficulty levels to choose from: EASY, NORMAL, HARD\n* Simple and intuitive controls that even VR beginners can easily enjoy\n\n\ud83c\udf0d 5. Global leaderboards and endless challenges\n* Compete your score with users around the world\n* Become the best rhythm master and conquer the global rankings!", "short_description": "Dancing Arrow is a VR game that lets you enjoy music rhythm games with K-POP."}]}, "developer_name": null, "developer_privacy_policy_url": "https://geniesoft.io/pages/portfolio/dancing_arrow/privacy_policy.php", "developer_terms_of_service_url": "https://geniesoft.io/pages/portfolio/dancing_arrow/terms_of_use.php", "publisher_name": "Geniesoft Inc", "support_website_url": null, "website_url": "https://www.geniesoft.io/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "ACTION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "9007643685966409"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035412_1914317275646812_1350569248386285776_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ABWIsFYHCkQ7kNvgGKm_E8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwVs6hUCLhxgynE6T9p01YzSVGnpF3M3jE3zwBAeeV7A&oe=676D4CE4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dancing Arrow : K-pop Challenge", "platform": "ANDROID_6DOF", "context_category": {"context_