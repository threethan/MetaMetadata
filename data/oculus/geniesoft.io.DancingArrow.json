culuscdn.com/v/t64.5771-25/39031467_387111206097551_6135204221268582504_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q0cQrAT9E2AQ7kNvgGVtbN6&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCc1OEX9VfLi9m09iTWSYYMo6KjSWTu4wRnyIP654uySQ&oe=67407449"}, {"file_name": "\uc2a4\uc0f72.png", "id": "567895897555019", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982486_567895900888352_7787595902512532766_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IGOVMjRYSkUQ7kNvgHUI9hH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCfDlWlBRCpfjT4b7L_6W5PnUrcseoACn5uSiV8HmZJwg&oe=6740722E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\uc81c\ubaa9-\uc5c6\uc74c-1.png", "id": "811892373005891", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036682_811892376339224_4096970328336759118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j5Rtl9K5sOoQ7kNvgHGDPWt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB6GTs_dd_CDPK_9w4XM6ncYyn874ABtCMg3wfSVycrFA&oe=67405AA2"}, "display_name": "Dancing Arrow", "keywords": [], "long_description": "You can score points by hitting the flying arrows according to the colors, and you can enjoy the game by expressing the dance moves.\n\nDifficulty levels make the game easy to play, and more difficult levels will give you a lot of fun.\n\n\n \u25a0 Secured the best K-POP music license\n      -BTS, BLACKPINK, TWICE, PSY, ITZY, etc.\n      -3 difficulty levels: EASY, NORMAL, HARD\n\n \u25a0 Apply real dance moves to the game\n      -Apply choreography to become a key point\n\n \u25a0 Easy UI configuration and intuitive expression\n      -Comfortable design at a glance\n\n \u25a0 More than 5 new music updates every month\n      -Want new music? Apply through the community!\n\n \u25a0 Global Leaderboard\n      -Challenge the global ranking!", "short_description": "Dancing Arrow is a VR game that lets you enjoy music rhythm games with K-POP."}]}, "developer_name": null, "developer_privacy_polic