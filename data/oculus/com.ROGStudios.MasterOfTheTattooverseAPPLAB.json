ent equipment like tattoo machines, needles, and various colors to experience being a tattoo artist in this wacky Tattooverse.\n\nUnleash your imagination, give your clients the \"ink\" they want, and prepare yourself for a one-of-a-kind adventure in Tattooverse!", "short_description": "Master of the Tattooverse is a story-driven tattoo game that allows you to create and share art pieces in a wacky universe. Enjoy the freedom of creating your own tattoos for extraordinary clients. Use templates or just do it freehand, satisfy your customers and expand your own tattoo portfolio."}]}, "developer_name": "ROG Studios", "developer_privacy_policy_url": "https://www.masterofthetattooverse.com/en/privacy-policy.aspx", "developer_terms_of_service_url": null, "publisher_name": "ROG Studios", "support_website_url": "https://rogstudios.com/", "website_url": "https://masterofthetattooverse.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "454545253155828"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1529442637576250"}]}, "baseline_offer": {"id": "1529442637576250"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1668430800, "status": "PUBLISHED", "id": "1529442637576250"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes":