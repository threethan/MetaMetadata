_name": "ss4.png", "id": "541953704350724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395590_541953711017390_3079800736664508720_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wkz337UqgzIQ7kNvgHUnLys&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9P2s4EDxvoc4NfsfFQjv9L0rpyb30wP9GL_FH4Q4kAw&oe=675966D9"}, {"file_name": "ss6.png", "id": "767470830977308", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031315_767470834310641_2664775726045902324_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=558bFkl6I8oQ7kNvgEE2s5z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAWomrmqxU-yQbB0dvwPwTyWQU7TOr7rkNhAV47Kv2MoA&oe=675977B4"}, {"file_name": "ss5.png", "id": "600124491700665", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392879_600124495033998_890761114487851083_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h81aKY3wyngQ7kNvgF2BBK4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGlvO4_iNfZHBd_2As_LOvLC3u57y10njSWu3ojlXglw&oe=67598249"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2.png", "id": "559525192530287", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974504_559525195863620_3270521811773418499_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kpYaF96bnjUQ7kNvgGAaoPU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOSrotlE02rslZQOTZGtabrM23CUAzKxtcUKWbKkHEug&oe=67597343"}, "display_name": "Master of the Tattooverse", "keywords": [], "long_description": "In a universe full of extraordinary characters and mysteries to discover, play as an apprentice tattoo artist disguised as the legendary Master. What can possibly go wrong?\n\nWell\u2026 Not to mention that you will be surrounded by some exceptional and self-absorbed clients like vampires, internet celebrities, and possessed Viking warriors that each need a unique tattoo only a Master can handle!\n\nDuring your sessions, you are armed with nothing but a mysterious mask, your tools, and your inspiration. Use and unlock different equipment like tattoo machines, needles, and various colors to experience being a tattoo artist in this wacky Tattooverse.\n\nUnleash your imagination, give your clients the \"ink\" they want, and prepare yourself for a one-of-a-kind adventure in Tattooverse!", "short_description": "Master of the Tattooverse is a story-driven tattoo game that allows you to create and share art pieces in a wacky universe. Enjoy the freedom of creating your own tattoos for extraordinary clients. Use templates or just do it freehand, satisfy your customers and expand your own tattoo portfolio."}]}, "developer_name": "ROG Studios", "developer_privacy_policy_url": "https://www.masterofthetattooverse.com/en/privacy-policy.aspx", "developer_terms_of_service_url": null, "publisher_name": "ROG Studios", "support_website_url": "https://rogstudios.com/", "website_url": "https://masterofthetattooverse.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "454545253155828"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1844488759624163"}, {"status": "PUBLISHED", "id": "1529442637576250"}]}, "baseline_offer": {"id": "1844488759624163"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733123280, "status": "PUBLISHED", "id": "1844488759624163"}]}, "liveChannel": {"nodes": [{"latest_suppo