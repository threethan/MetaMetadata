le_name": "ss6.png", "id": "767470830977308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031315_767470834310641_2664775726045902324_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EQdvR0_A2VYQ7kNvgF9xuaE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdZ1lbMY8gcZiaTNPCSYYAH&oh=00_AYDOG1jD0YUAtbti4OfTdvhH9ChVPQUnU2ul2yF57kAbYg&oe=66DEDC34"}, {"file_name": "ss5.png", "id": "600124491700665", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392879_600124495033998_890761114487851083_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AwSurMU_HQMQ7kNvgHsqhHt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdZ1lbMY8gcZiaTNPCSYYAH&oh=00_AYBd3OQhr36iBtLxJCZdACfZBd8VpRf_P_ONmIbCl9OYOA&oe=66DEE6C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2.png", "id": "559525192530287", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974504_559525195863620_3270521811773418499_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M1mtihpOlv4Q7kNvgGq52LJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdZ1lbMY8gcZiaTNPCSYYAH&oh=00_AYAdu3aqufA4n46hJnDxn9-YlFKiwf7vdlCfE6BKyl83TA&oe=66DED7C3"}, "display_name": "Master of the Tattooverse", "keywords": [], "long_description": "In a universe full of extraordinary characters and mysteries to discover, play as an apprentice tattoo artist disguised as the legendary Master. What can possibly go wrong?\n\nWell\u2026 Not to mention that you will be surrounded by some exceptional and self-absorbed clients like vampires, internet celebrities, and possessed Viking warriors that each need a unique tattoo only a Master can handle!\n\nDuring your sessions, you are armed with nothing but a mysterious mask, your tools, and your inspiration. Use and unlock different equipment like tattoo machines, needles, and various colors to experience being a tattoo artist in this wacky Tattooverse.\n\nUnleash your imagination, give your clients the \"ink\" they want, and prepare yourself for a one-of-a-kind adventure in Tattooverse!", "short_description": "Master of the Tattooverse is a story-driven tattoo game that allows you to create and share art pieces in a wacky universe. Enjoy the freedom of creating your own tattoos for extraordinary clients. Use templates or just do it freehand, satisfy your customers and expand your own tattoo portfolio."}]}, "developer_name": "ROG Studios", "developer_privacy_policy_url": "https://www.masterofthetattooverse.com/en/privacy-policy.aspx", "developer_terms_of_service_url": null, "publisher_name": "ROG Studios", "support_website_url": "https://rogstudios.com/", "website_url": "https://masterofthetattooverse.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "454545253155828"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982553_590391945915253_4549582393985895006_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ixXolz-Uax8Q7kNvgFHeZO5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdZ1lbMY8gcZiaTNPCSYYAH&oh=00_AYAJFN0BqXHb_O8ErkEledXsFIkMk6kwQcVDBwg_3szWIQ&oe=66DEC1C3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Master of the Tattooverse", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1668430800, "lastRevision": {"nodes": [{"id": "8081165371925326", "release_type": "SCH