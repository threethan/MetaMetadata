file_name": "Screen4.png", "id": "960186275874990", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982508_960186279208323_2337064947745311296_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oY4X2W7yQLcQ7kNvgH0rklq&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBRJfOSJU2EUlk_fbT_xHdF_cFa1ZcXHdO00Pd30bGnaw&oe=6710E550"}, {"file_name": "Screen5.png", "id": "27733580852907768", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031315_27733580869574433_6263553384650191409_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o4zhgqVrbtUQ7kNvgED4Esk&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA71sOpIDfFtW4PTARJQ74jYaO97z8Wb8BGGw8hsXbjzA&oe=6710DD02"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440px.png", "id": "533251622521530", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031378_533251625854863_3181000300712893273_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tTyV9y4Bq5YQ7kNvgFtz3BT&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCgz0FKNP2uW6VKyO-3aUzkyCKWAWey77ykd8B0yTXQjw&oe=6710F735"}, "display_name": "ROBOCRACY", "keywords": [], "long_description": "Disturbing signals are coming from the edges of explored space. Rebel robots have learned to cooperate and are building bases on uninhabited planets. Their new goal is to enslave all \"bags of bones,\" also known as humans, under the rule of Robocracy.\nThe Galactic Rangers are called to deal with this new threat!\n\nThey've proven that humanity can rely on them to defend against machines. But this time, the challenge is tougher than ever \u2014 you\u2019ll be up against upgraded robot models!\n\nFind and stop the Robocracy before it\u2019s too late! Defend the simple joys of human civilization: cute kittens, breakfast in bed, funny memes, and internet arguments!\n\n**Key features:**\n- Survive three hardcore acts with lots of missions in the beautiful landscapes of the explored Universe\n- Survive three hardcore acts filled with missions across the beautiful landscapes of the known Universe.\n- Arm yourself with powerful blasters, shotguns, and rocket launchers.\n- New control mechanics elevate the gameplay experience to a whole new level.\n- Tackle different difficulty levels. Use shields, slow down time, plant mines \u2014 utilize every tool to reclaim control over the Universe.\n- Fight the Robocracy solo or team up with friends to take on the soulless machines.", "short_description": "Fight against a rogue artificial intelligence and save humanity from becoming slaves to machines! Put on your VR headset, become a Galactic Ranger, and journey into deep space. Blast through waves of robots with powerful blasters, shotguns, and other crazy weapons, just like in the classic arcade games!"}]}, "developer_name": "DGMA", "developer_privacy_policy_url": "https://robocracy.dgma.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "DGMA", "support_website_url": null, "website_url": "http://dgma.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "8263558690393028"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "519384897372231"}]}, "baseline_offer": {"id": "519384897372231"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728669601, "status": "PUB