{"data": {"node": {"__typename": "Application", "id": "7690929770972540", "organization": {"id": "971494634391501", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "7690929770972540"}]}, "id": "906312801269335"}]}}, "firstRevision": {"nodes": [{"application": {"id": "7690929770972540", "release_date": 1725993540, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 1}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8299050673493777"}, "id": "416385391322609"}]}}, "binary": null, "live_binary": null, "created_date": 1726185550, "id": "8338096412922536", "is_initial_release": false, "name_with_fallback": "v3", "pdp_metadata_with_fallback": {"version": 3, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8338100226255488"}, "release_status": "RELEASED", "id": "7690929770972540"}, "id": "8338100226255488", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7690929770972540", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "498504652771745"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "1576448589890214", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica", "keywords": [], "long_description": "Experiencia inmersiva \"Sal\u00f3n ceremonial de los Pututus\". Experiencia inmersiva de realidad virtual - RV inspirada en los valores e historia social de la Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica, del \u00abSal\u00f3n Ceremonial de los Pututus\u00bb ubicado en la cima del Edificio P\u00fablico Mayor, parte alta de \u00abPe\u00f1ico, Ciudad de la Integraci\u00f3n Social\u00bb, durante el Formativo Temprano 1 (1800-1500 a. C.). Pe\u00f1ico es uno de los 25 centros urbanos identificados en el valle de Supe, hace 30 a\u00f1os, por el equipo de profesionales liderado por la arque\u00f3loga peruana doctora Ruth Shady, principal investigadora de Caral.\nEl equipo de especialistas de la Zona Arqueol\u00f3gica Caral pone a disposici\u00f3n esta experiencia inmersiva de realidad virtual - RV en la que todo cibernauta podr\u00e1 aproximarse a los principales valores de la Civilizaci\u00f3n Caral.", "short_description": "Experiencia inmersiva de realidad virtual (RV) que permite explorar el \u00abSal\u00f3n Ceremonial de los Pututus\u00bb de la Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica, destacando sus valores e historia social. Desarrollada por especialistas de la Zona Arqueol\u00f3gica Caral, esta experiencia ofrece un recorrido virtual por Pe\u00f1ico, uno de los centros urbanos del valle de Supe, investigado por el equipo de profesionales liderado por la arque\u00f3loga peruana doctora Ruth Shady, principal investigadora de Caral."}, {"images": {"nodes": [{"file_name": "Cover_Art_Portrait.png", "id": "7958297130948058", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974611_7958297134281391_2357848056663805888_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j-W47rIYKR8Q7kNvgG-Ka73&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC875e3c0kkYdKhyrKIGYeUO2pgf5SI_5fZb3l9zEpViQ&oe=672DFB2C"}, {"file_name": "Hero_Cover.png", "id": "1973422483087500", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031435_1973422486420833_915629631484001196_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R6kEKNw0lGMQ7kNvgFlsZwb&_nc_zt=3&_nc_ht=scontent-iad3-2.ocul