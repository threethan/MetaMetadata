vgH3V-ri&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBNfYGcqxQRwmp19O-SapJ6rzoRiimA5dopoPEfnr2A_w&oe=672E0E81"}, {"file_name": "Screenshot_2.png", "id": "2703245243180740", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240108_2703245246514073_7803995135664874249_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jEFBdt63WGoQ7kNvgEbnX6M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7s9b_YITOugzL1NtP4n5NMar_S2qfBwB67X00Ys9x1Q&oe=672E0963"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_image.png", "id": "500335232890455", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003255_500335236223788_5223893071272402515_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rcnRXA6b4R0Q7kNvgGgwLSk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDs6syyC7HVb5PV3cmqaT6bXB6S_KOaD8-mi2Fb60K5ow&oe=672DDFA1"}, "display_name": "Caral civilization, the oldest in America", "keywords": [], "long_description": "Immersive experience \"Pututus Ceremonial Hall\". Immersive virtual reality experience - VR inspired by the values \u200b\u200band social history of the Caral Civilization, the oldest in America, of the \u00abPututus Ceremonial Hall\u00bb located on the top of the Main Public Building, upper part of \u00abPe\u00f1ico, City of Social Integration\u00bb, during the Early Formative 1 (1800-1500 BC). Pe\u00f1ico is one of the 25 urban centers identified in the Supe Valley, 30 years ago, by the team of professionals led by the Peruvian archaeologist Dr. Ruth Shady, principal researcher of Caral.\nThe team of specialists of the Caral Archaeological Zone makes available this immersive virtual reality experience - VR in which all cybernauts will be able to approach the main values \u200b\u200bof the Caral Civilization.", "short_description": "\"Immersive virtual reality (VR) experience that allows you to explore the \u00abCeremonial Hall of the Pututus\u00bb of the Caral Civilization, the oldest in America, highlighting its values \u200b\u200band social history. Developed by specialists from the Caral Archaeological Zone, this experience offers a virtual tour of Pe\u00f1ico, one of the urban centers of the Supe Valley, investigated by the team of professionals led by Peruvian archaeologist Dr. Ruth Shady, principal investigator of Caral.\""}, {"images": {"nodes": []}, "id": "967737794687401", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica", "keywords": [], "long_description": "\"Experiencia inmersiva \"\"Sal\u00f3n ceremonial de los Pututus\"\". Experiencia inmersiva de realidad virtual - RV inspirada en los valores e historia social de la Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica, del \u00abSal\u00f3n Ceremonial de los Pututus\u00bb ubicado en la cima del Edificio P\u00fablico Mayor, parte alta de \u00abPe\u00f1ico, Ciudad de la Integraci\u00f3n Social\u00bb, durante el Formativo Temprano 1 (1800-1500 a. C.). Pe\u00f1ico es uno de los 25 centros urbanos identificados en el valle de Supe, hace 30 a\u00f1os, por el equipo de profesionales liderado por la arque\u00f3loga peruana doctora Ruth Shady, principal investigadora de Caral.\nEl equipo de especialistas de la Zona Arqueol\u00f3gica Caral pone a disposici\u00f3n esta experiencia inmersiva de realidad virtual - RV en la que todo cibernauta podr\u00e1 aproximarse a los principales valores de la Civilizaci\u00f3n Caral.\"", "short_description": "\"Experiencia inmersiva de realidad virtual (RV) que permite explorar el \u00abSal\u00f3n Ceremonial de los Pututus\u00bb de la Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica, destacando sus valores e historia social. Desarrollada por especialistas de la Zona Arqueol\u00f3gica Caral, esta experiencia ofrece un recorrido virtual por Pe\u00f1ico, uno de los centros urbanos del valle de Supe, investigado por el equipo de profesionales liderado por la arque\u00f3loga peruana doctora Ruth Shady, principal investigadora de Caral.\""}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zonacaral.gob.pe/museo/PolItica_de_privacidad.pdf", "developer_terms_of_service_url": null, "publisher_name": "Zona Arqueologica Caral", "support_website_url": null, "website_url": "https://www.gob.pe/caral", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_PE", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7690929784305872"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1925954747845916"}]}, "baseline_offer": {"id": "1925954747845916"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725993540, "status": "PUBLISHED", "id": "1925954747845916"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8299050673493777", "version": "8"}, "id": "416385391322609", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7690929770972540", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8299050673493777"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id":