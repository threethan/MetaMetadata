//scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404381_584554339812686_7320563523661474914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yqfkhHfwurQQ7kNvgFVMMCP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDP2T02RqokUQyhT_apby_m6NX_NYmoe83TUFtw8ng1Q&oe=6749A282"}, {"file_name": "screenshots_v2_09.png", "id": "1427230664447675", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974876_1427230667781008_993936481344057767_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_5mZyANgrSgQ7kNvgEMPIIe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAX1yQ0H4YZjvl2A0mGsW4_kpa8JzcQUQ5KgocZpxbgGA&oe=6749A74F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Poultry Trailer Edit (final) cover image.png", "id": "763282998234424", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974911_763283001567757_9063701743215479700_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ql6FJdokf0kQ7kNvgH2hRuu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFdEhlQuEOv9Q77wSHKTSNrE_LdMYPUB_hvk8BRcqR8A&oe=6749AEC1"}, "display_name": "Anatomy of a Chicken", "keywords": [], "long_description": "Following exploration of the anatomy of the chicken users can test their knowledge of the parts of the chicken in challenge mode. Challenge mode tests knowledge by engaging the user to extract a nominated part out of the chicken using tweezers, just like a real dissection. Feedback is provided automatically when the user places the part on the dissection tray.\nPoultry Hub Australia (PHA) is a not-for-profit organisation that focuses on challenges identified in the Australian Poultry Industry. An important aspect of PHA\u2019s activities is to build capacity in the industry. PHA commits to building capacity through resources that connect students with industry.", "short_description": "Anatomy of the chicken allows users to develop and test their knowledge of the anatomy of both a broiler and layer chicken. Users can explore different layers of the chicken including skeletal, muscular, organs and reproductive systems."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.poultryhub.org/about/privacy-2", "developer_terms_of_service_url": null, "publisher_name": "Poultry Hub Australia", "support_website_url": null, "website_url": "https://www.poultryhub.org/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "441133697802092"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974575_1075978119950865_4223737768613948011_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3sJZ7hwyk7MQ7kNvgGn5mhh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDS3InMprQNVZDMVqpQd4WceHXrUBw0ico8CXEr3_etKA&oe=6749969A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Anatomy of a Chicken", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1661959622, "lastRevision": {"nodes": [{"id": "5447969825266452", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "54479