_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HRTmW3RIkzwQ7kNvgHGB18u&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAepwdOyYpkCes60ql-Nljiu5JyyG1xsfaNrhsE9azfqg&oe=671E2102"}, {"file_name": "screenshots_v2_09.png", "id": "1427230664447675", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974876_1427230667781008_993936481344057767_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k_JIPJ3OnDMQ7kNvgFWsazW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7G5NaU74RskT1F0B8XmY3RBeGnAfUj8R8BnGBqHvNdQ&oe=671E25CF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Poultry Trailer Edit (final) cover image.png", "id": "763282998234424", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974911_763283001567757_9063701743215479700_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g0ytmKqI2zQQ7kNvgE8vdym&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfWfbJxyTQvYwydGoY-Iu90UxY3k9Nvl71kV3BQX8v8Q&oe=671E2D41"}, "display_name": "Anatomy of a Chicken", "keywords": [], "long_description": "Following exploration of the anatomy of the chicken users can test their knowledge of the parts of the chicken in challenge mode. Challenge mode tests knowledge by engaging the user to extract a nominated part out of the chicken using tweezers, just like a real dissection. Feedback is provided automatically when the user places the part on the dissection tray.\nPoultry Hub Australia (PHA) is a not-for-profit organisation that focuses on challenges identified in the Australian Poultry Industry. An important aspect of PHA\u2019s activities is to build capacity in the industry. PHA commits to building capacity through resources that connect students with industry.", "short_description": "Anatomy of the chicken allows users to develop and test their knowledge of the anatomy of both a broiler and layer chicken. Users can explore different layers of the chicken including skeletal, muscular, organs and reproductive systems."}]}, "developer_name": null, "developer_priv