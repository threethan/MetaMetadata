lQ&oe=66E2CF0A"}, {"file_name": "screenshots_v2_08.png", "id": "584554336479353", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404381_584554339812686_7320563523661474914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DcTeCficH6QQ7kNvgGnWF91&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchR9hSH_K55mfp-e081WuG&oh=00_AYCStqgPrX7sHqhuGMDsRHAgX67ERi80AhvU15gcP2FFkQ&oe=66E2CD82"}, {"file_name": "screenshots_v2_09.png", "id": "1427230664447675", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974876_1427230667781008_993936481344057767_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TWzC43KBZvEQ7kNvgGXwFDN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchR9hSH_K55mfp-e081WuG&oh=00_AYCFhfW_m4p1CoiESB21IMkHQiDoQQiPwmOKYG3Xj29SoA&oe=66E2D24F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Poultry Trailer Edit (final) cover image.png", "id": "763282998234424", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974911_763283001567757_9063701743215479700_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_fZ_EXbF47oQ7kNvgFh_RAj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchR9hSH_K55mfp-e081WuG&oh=00_AYAbA_r9GlFLqovL31JvQAwEJq15Q9NyFss3iP_MLBCNoQ&oe=66E2D9C1"}, "display_name": "Anatomy of a Chicken", "keywords": [], "long_description": "Following exploration of the anatomy of the chicken users can test their knowledge of the parts of the chicken in challenge mode. Challenge mode tests knowledge by engaging the user to extract a nominated part out of the chicken using tweezers, just like a real dissection. Feedback is provided automatically when the user places the part on the dissection tray.\nPoultry Hub Australia (PHA) is a not-for-profit organisation that focuses on challenges identified in the Australian Poultry Industry. An important aspect of PHA\u2019s activities is to build capacity in the industry. PHA commits to building capacity through resources that connect students with industry.", "short_description": "Anatomy of the chicken allows users to develop and test their knowledge of the anatomy of both a broiler and layer chicken. Users can explore different layers of the chicken including skeletal, muscular, organs and reproductive systems."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.poultryhub.org/about/privacy-2", "developer_terms_of_service_url": null, "publisher_name": "Poultry Hub Australia", "support_website_url": null, "website_url": "https://www.poultryhub.org/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "441133697802092"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974575_1075978119950865_4223737768613948011_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8IjWXfBljBUQ7kNvgGmm8IK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchR9hSH_K55mfp-e081WuG&oh=00_AYAFL-r14rpxSsGKeRm9uRXFah3nGj6s3u4zZZfazVB59w&oe=66E2C19A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Anatomy of a Chicken", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1661959622, "lastRevision": {"nodes": [{"id": "5447969825266452", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5447969805266454", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"