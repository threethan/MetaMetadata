//scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75404381_584554339812686_7320563523661474914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s1i_ocwfOcQQ7kNvgFyx2rq&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYD1syiZqUEovKMHeOCc1osjM-SrnjwJbKSRQj2RwwrjDQ&oe=67124382"}, {"file_name": "screenshots_v2_09.png", "id": "1427230664447675", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38974876_1427230667781008_993936481344057767_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S-vW04jyxugQ7kNvgEsGwAR&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYB64l-6hX_7c1vyUva2uE9miVk7Xnj3uDG_0TAFf8jMKA&oe=6712484F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Poultry Trailer Edit (final) cover image.png", "id": "763282998234424", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974911_763283001567757_9063701743215479700_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=veDNS9pbcV4Q7kNvgGI9MN6&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCo2d-Ip2fZ4iRlidqBXORUgJgI9qEdYBApUnx7Ldp0xQ&oe=67124FC1"}, "display_name": "Anatomy of a Chicken", "keywords": [], "long_description": "Following exploration of the anatomy of the chicken users can test their knowledge of the parts of the chicken in challenge mode. Challenge mode tests knowledge by engaging the user to extract a nominated part out of the chicken using tweezers, just like a real dissection. Feedback is provided automatically when the user places the part on the dissection tray.\nPoultry Hub Australia (PHA) is a not-for-profit organisation that focuses on challenges identified in the Australian Poultry Industry. An important aspect of PHA\u2019s activities is to build capacity in the industry. PHA commits to building capacity through resources that connect students with industry.", "short_description": "Anatomy of the chicken allows users to develop and test their knowledge of the anatomy of both a broiler and layer chicken. Users can explore different layers of the chicken including skeletal, muscular, organs and reproductive systems."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.poultryhub.org/about/privacy-2", "developer_terms_of_service_url": null, "publisher_name": "Poultry Hub Australia", "support_website_url": null, "website_url": "https://www.poultryhub.org/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "441133697802092"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974575_1075978119950865_4223737768613948011_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MqVh0LFSPo4Q7kNvgEkl_q8&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBKt1PNA04yXUphuUytI32kXT7pjwUKpdc2YLWgz5X6lQ&oe=6712379A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Anatomy of a Chicken", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1661959622, "lastRevision": {"nodes": [{"id": "5447969825266452", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5447969805266454", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "481161823432597"}, "iarc_email": null, "msrp": null, "translations": {"nodes"