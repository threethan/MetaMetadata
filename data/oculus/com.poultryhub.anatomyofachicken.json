=1-7&_nc_sid=6e7a0a&_nc_ohc=vke-nULkYZ8Q7kNvgHEd9vr&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw8tBaqVPedNbbZmAIEo_Ls&oh=00_AYDz4dRaK1_nudhdUDCVfzKo7EiuNub3klVrFFdGtKn4iQ&oe=66ED5B0A"}, {"file_name": "screenshots_v2_08.png", "id": "584554336479353", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404381_584554339812686_7320563523661474914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dgfchAeDmj4Q7kNvgGCGTCc&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw8tBaqVPedNbbZmAIEo_Ls&oh=00_AYCbcBVolKVZtyrjPDCNZsvL3-kue1WLdSIUs4uc2U6hYQ&oe=66ED5982"}, {"file_name": "screenshots_v2_09.png", "id": "1427230664447675", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974876_1427230667781008_993936481344057767_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pBLM_S9LKUgQ7kNvgGSDq4K&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw8tBaqVPedNbbZmAIEo_Ls&oh=00_AYALS0p1iKBPY0JsdON3U1VbldcoPIXHfdvKH4UGY2XhLA&oe=66ED5E4F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Poultry Trailer Edit (final) cover image.png", "id": "763282998234424", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974911_763283001567757_9063701743215479700_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l5XAEvMsMY0Q7kNvgG9S9rg&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw8tBaqVPedNbbZmAIEo_Ls&oh=00_AYDqQfmxQWraQGh_kVZ7nm5WT1hK37P2zQGI66_Ku6tucA&oe=66ED65C1"}, "display_name": "Anatomy of a Chicken", "keywords": [], "long_description": "Following exploration of the anatomy of the chicken users can test their knowledge of the parts of the chicken in challenge mode. Challenge mode tests knowledge by engaging the user to extract a nominated part out of the chicken using tweezers, just like a real dissection. Feedback is provided automatically when the user places the part on the dissection tray.\nPoultry Hub Australia (PHA) is a not-for-profit organisation that focuses on challenges identified in the Australian Poultry Industry. An important aspect of PHA\u2019s activities is to build capacity in the industry. PHA commits to building capacity through resources that connect students with industry.", "short_description": "Anatomy of the chicken allows users to develop and test their knowledge of the anatomy of both a broiler and layer chicken. Users can explore different layers of the chicken including skeletal, muscular, organs and reproductive systems."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.poultryhub.org/about/privacy-2", "developer_terms_of_service_url": null, "publisher_name": "Poultry Hub Australia", "support_website_url": null, "website_url": "https://www.poultryhub.org/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "441133697802092"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1107397700204482"}]}, "baseline_offer": {"id": "1107397700204482"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1661959620, "status": "PUBLISHED", "id": "1107397700204482"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5528487893881311", "version": "1.0"}, "id": "1973616159498689", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5447969805266454", "is_concept": false, "latest_released_binary": {"__t