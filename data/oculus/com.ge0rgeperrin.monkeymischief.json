135_2866867387975413122_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4n_t7kykCSUQ7kNvgHJrBTp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3-wmicKfjrTMxCfB-87QYVQWvIT5aKltS8kGFCVAfKQ&oe=671F8D0A"}, {"file_name": "ForestLava.png", "id": "443521942091770", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001728_443521945425103_2424119927321827280_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tM8tSnL3yYAQ7kNvgENxA6L&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDPOcjMsttvvGUBFW3jKqnznze_zQs8HDb7l8uhYIV4rA&oe=671F927D"}, {"file_name": "WatchingFromTrees.png", "id": "515361217959292", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982629_515361221292625_8502173092952948767_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NvXHIGF0364Q7kNvgEYk8CD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFgPBVxNRAxd5J07bs6I6avX86-69do46NGcHBXqsqxg&oe=671F76B4"}, {"file_name": "HorrorGenerator.png", "id": "506730092199699", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982570_506730095533032_1036290241158275574_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MGp_OO4H-oUQ7kNvgGjEKif&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJcBF-ZvtS9AZL9hcrGAwkjMNyropZrDlO0x-IukUsKw&oe=671F6905"}, {"file_name": "Mall.png", "id": "1096133269186763", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035304_1096133272520096_3251845521029510751_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LtB58sX2rPoQ7kNvgGshNL0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAut8iOUGCWWHAU4tCOZ4yFvdqx_x6kjPyAXyS9-5D5Pw&oe=671F6954"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LegacyTrailerCover.png", "id": "924576899550762", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75250461_924576906217428_8652467691312870474_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lhPRpJNfG2MQ7kNvgFyYLrm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxA0p-YSm5pX26b8c7rNgQIgKxU-N0Pf2MfvJ_IMVdpQ&oe=671F7852"}, "display_name": "Monkey Mischief", "keywords": ["monkey", "gorilla", "vr", "party", "mischief"], "long_description": "Welcome to Monkey Mischief. The game that has little bits of everything.\n\nThere are three game modes, with more to come in the future, that are playable in all three maps! Fly like a high speed racing car across the map with friends, climb mountains to get away from rising lava, or run from two spider-monkey twins with tentacles in a underground advanced cave system!\n\nYou can even scale multiple trees at once, do backflips on trampolines, or explore the Mischievous Mall, where more then 30 cosmetics are for sale to wear on your physical VR character!\n\nOr, you can explore the Horror maps that has three upcoming levels, all scaling higher in atmosphere, and lowering your sanity.\n \nNo matter what you do, it's ensured you will have fun!", "short_description": "Monkey Mischief is a online multiplayer VR game that is dependent on the locomotion of your hands. Run to the top of the mountains when lava is rising, fly like a racing car across the map with friends, or run from two twins with tentacles in a underground advanced cave system!"}]}, "developer_name": "GRP Games LTD", "developer_privacy_policy_url": "https://grpgames.com/monkey-mischief/privacy-policy", "developer_terms_of_service_url": "https://grpgames.com/monkey-mischief/eula", "publisher_name": "GRP Games LTD", "support_website_url": "https://grpgames.com/support", "website_url": "https://grpgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "HORROR"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "pl", "fr", "de