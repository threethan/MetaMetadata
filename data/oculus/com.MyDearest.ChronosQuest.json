303", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031477_4308564905836636_6274524008135682620_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N1RBfUZtfbUQ7kNvgHoz54N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZ8ZmaMIpqtBon12hOClBCW_F2-pqLMWBMnqRoFCMvBw&oe=672E060A"}, {"file_name": "TokyoChronos_AddScreenShot15 (1).png", "id": "268064451290987", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031467_268064454624320_6690619984376577959_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QzeaXhpEtzkQ7kNvgH_qB8h&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHXZaBPKpOw-MUel-IGylXLfuqK8-E7S61FsC8nyP3Zg&oe=672DEA88"}, {"file_name": "TokyoChronos_AddScreenShot13.png", "id": "472847610346262", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031639_472847613679595_4542425813744423185_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O_lsfgIyQocQ7kNvgEpE2Yp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCrNqVzWXOn-DFKTIQ9KypYiKGN0sbLe0XBCuvGKZNC_w&oe=672DF313"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TokyoChronos_AddScreenShot15 (1).png", "id": "1347271088998137", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75393566_1347271095664803_5387546881034672347_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bVWe7vQJ27QQ7kNvgF91vUZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgWq9vGfNHWLKPXOaIRJn9RcuH_vDzhI2JK-YgxC2E_A&oe=672DE480"}, "display_name": "TOKYO CHRONOS", "keywords": ["TOKYOCHRONOS", "CHRONOS", "VisualNovel", "adventure", "Anime"], "long_description": "Note: This game takes around 10-15 hours to complete, with new paths that unlock with multiple playthroughs. Don't stop playing after the first credits roll! \n\nTOKYO CHRONOS is the VR game that has multiple-choice decision points as well as more than one ending. It has a long story you've never experienced before with VR.\nThe game takes place in Shibuya, Tokyo, which has only eight people, including you, the protagonist, Kyosuke Sakurai. Can you solve the mystery and get out of the silent Shibuya?\n\n-Features-\n\u25cf Drastic advancement of visual novel games with VR \nThe total gameplay time reaches to 15 hours. The story has multiple-choice decision points as well as more than one ending.\n\n\u25cfMoving scenario making your HMD wet with your tears \nOne review says, \"I've purchased several games at the Oculus store, and none of them satisfied me. But TOKYO CHRONOS is no comparison. At first, you're surprised at the beautiful images. But the deep story surpasses it\".\n\n", "short_description": "TOKYO CHRONOS is the VR game that has multiple-choice decision points as well as more than one ending. It has a long story you've never experienced before with VR.\nThe game takes place in Shibuya, Tokyo, which has only eight people, including you, the protagonist, Kyosuke Sakurai. Can you solve the mystery and get out of the silent Shibuya?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tokyochronos.com/en/privacypolicy/", "developer_terms_of_service_url": "https://tokyochronos.com/en/terms/index.html", "publisher_name": "MyDearest Inc.", "support_website_url": null, "website_url": "https://tokyochronos.com/en/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "zh_CN", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4802221313188946"}, "review_messages": ["", "Sending back as the new update would make the Cover Landscape not fit thematically with the other assets. Do you have an overhaul of the assets planned?"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75643375_2502834173342169_1905876374764285425_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r7g_nq2NBBAQ7kNvgEgI0R1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsCenEfgz9rlyWmY4XV5kfiv-zOl8cL4ReatBF4qSBMg&oe=672DFB1A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TOKYO CHRONOS", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Narrative", "id": "1008279844328894"}], "release_date": 1560963600, "lastRevision": {"nodes": [{"id": "587777361633441", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2812851825399383", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1513831578761555"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "669024743868577", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u6771\u4eac\u30af\u30ed\u30ce\u30b9", "keywords": ["\u6771\u4eac\u30af\u30ed\u30ce\u30b9", "\u30af\u30ed\u30ce\u30b9", "\u30a2\u30c9\u30d9\u30f3\u30c1\u30e3\u30fc", "\u30ce\u30d9\u30eb\u30b2\u30fc\u30e0", "\u65e5\u672c"], "long_description": "\u300c\u6b21\u306e\u30a2\u30c9\u30d9\u30f3\u30c1\u30e3\u30fc\u30b2\u30fc\u30e0\u306f\u753b\u9762\u306e\u5411\u3053\u3046\u3060\u300d\n\"\u30bd\u30fc\u30c9\u30a2\u30fc\u30c8\u30fb\u30aa\u30f3\u30e9\u30a4\u30f3\" \u30d7\u30ed\u30c7\u30e5\u30fc\u30b5\u30fc\u3089\u8c6a\u83ef\u30b9\u30bf\u30c3\u30d5\u30ad\u30e3\u30b9\u30c8\u304c\u96c6\u7d50\u3002\n360\u5ea6\u306e\u5e83\u304c\u308a\u3092\u6301\u3064\u7a7a\u9593\u3067\u7d21\u304c\u308c\u308b\u3001\u672a\u4f53\u9a13\u306eVR\u30df\u30b9\u30c6\u30ea\u30fc\u30a2\u30c9\u30d9\u30f3\u30c1\u30e3\u30fc\u30b2\u30fc\u30e0\u3002\n\u76ee\u306e\u524d\u3067\u4f1a\u8a71\u3092\u7e70\u308a\u5e83\u3052\u308b\u5e7e\u591a\u306e\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u3002\u3042\u306a\u305f\u306e\u9078\u3073\u53d6\u3063\u305f\u6c7a\u65ad\u306b\u3088\u3063\u3066\u3001\u7269\u8a9e\u306f\u5909\u5316\u3059\u308b\u3002\n\n\u2015\u6642\u304c\u6b62\u307e\u3063\u305f\u8ab0\u3082\u3044\u306a\u3044\u6e0b\u8c37\u3002\u3053\u306e\u4e16\u754c\u306b\u9589\u3058\u8fbc\u3081\u3089\u308c\u305f\u306e\u306f\u5e7c\u99b4\u67d3\u3067\u3042\u308b8\u4eba\u306e\u9ad8\u6821\u751f\u305f\u3061\u3002\n\n\u5931\u308f\u308c\u305f\u8a18\u61b6\u3002\u300c\u79c1\u306f\u6b7b\u3093\u3060\u3002\u72af\u4eba\u306f\u8ab0\uff1f\u300d\u3068\u3044\u3046\u8b0e\u306e\u30e1\u30c3\u30bb\u30fc\u30b8\u3002\n\u79c1\u3068\u306f\u8ab0\u306a\u306e\u304b\u3002\u4f55\u6545\u8a18\u61b6\u304c\u7121\u3044\u306e\u304b\u3002\u305d\u3057\u3066\u72af\u4eba\u306f\u8ab0\u306a\u306e\u304b\u3002\n\n\u7815\u3051\u305f\u93e1\u306e\u3088\u3046\u306b\u6563\u3089\u3070\u308b\u7121\u6570\u306e\u30ab\u30b1\u30e9\u3002\n\u3053\u306e\u4e16\u754c\u306e\u771f\u5b9f\u306f\u3069\u3053\u306b\u2500\n\n\u3042\u306a\u305f\u304c\u6c7a\u3081\u3066\u3002\u6bba\u3059\u304b\u3069\u3046\u304b\u2500\n\n\n\u25a0\u5236\u4f5c\u30b9\u30bf\u30c3\u30d5\n\u76e3\u7763\uff1a\u67cf\u5009\u6674\u6a39(\u300c\u697d\u5712\u8ffd\u653e -Expelled from Paradise-\u300d\u30e2\u30fc\u30b7\u30e7\u30f3\u76e3\u7763)\n\u30b7\u30ca\u30ea\u30aa\uff1a\u702c\u5ddd\u30b3\u30a6(\u300c\u4eca\u591c\u3001\u541b\u306b\u6bba\u3055\u308c\u305f\u3068\u3057\u3066\u3082(\u8b1b\u8ac7\u793e\u30bf\u30a4\u30ac)\u300d\u30df\u30b9\u30c6\u30ea\u30fc\u4f5c\u5bb6)\n\u30d7\u30ed\u30c7\u30e5\u30fc\u30b5\u30fc\uff1a\u4e09\u6728\u4e00\u99ac(\u300c\u