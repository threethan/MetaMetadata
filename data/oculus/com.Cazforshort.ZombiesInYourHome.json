74874_1341930922920775_2032434531725596727_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=umLp4t7Cz14Q7kNvgEOVbvZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnrWnb4xfDKexoAeUMp5oNlFAM9SrUWtmO97wW-3H29g&oe=66D8462B"}, {"file_name": "Game4.png", "id": "483441523140842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_483441526474175_8637568278043978051_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cv4J459yT8IQ7kNvgH0tf1Z&_nc_ht=scontent.oculuscdn.com&oh=00_AYCv1IA55J2uyG59TBA5ajNRoY3bvVsJeSg4Xct1Og91Bg&oe=66D847E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "imgonline-com-ua-resize-5mxQnAdDtM8qR (5).png", "id": "307963504272287", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036704_307963510938953_12489759764553333_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kwVooR9XTSIQ7kNvgFsqmea&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmoLJwXLi-_tJgy6j5bxjfjn4bS6dRzXcJk57dsBBRmw&oe=66D846EF"}, "display_name": "Zombies in Your Home", "keywords": [], "long_description": "Zombies will chase you around and spawn randomly throughout your mapped house.\n\nGame Instructions\n\n1) Place nodes at each corner of your walls and doors with the right trigger going counter clockwise. If you put one in the wrong place, just click X on the left remote to clear them out.\n\n2) Press A on the right controller to Lock In your play area and walls. This will also start the game and dim the light.\n\n3) Press B on the right controller to turn on your flashlight. Use it to kill the enemies that are now spawning faster and faster and coming to find you. Just hold the light on them for 5 seconds.\n\n4) If the enemies get too close you will loose health and the game will stop and show your score. Restart with A on the right controller.", "short_description": "Oculus Passthrough has Zombies in your Livingroom! Kill them with your flashlight before they get you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/zombies