74874_1341930922920775_2032434531725596727_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YrARRksI4Z8Q7kNvgF86K9v&_nc_ht=scontent.oculuscdn.com&oh=00_AYDu4gW1THFt_PT3wyOQUj4RM3CGorKaTZAPSMnF8nN4Zg&oe=66CF0BAB"}, {"file_name": "Game4.png", "id": "483441523140842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_483441526474175_8637568278043978051_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MLlv4mzELjwQ7kNvgF1BZeb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSH4BXEFjqcAl0kWugaMdSDPEJ88dOJG-GXs0F56uf7w&oe=66CF0D68"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "imgonline-com-ua-resize-5mxQnAdDtM8qR (5).png", "id": "307963504272287", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036704_307963510938953_12489759764553333_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pd0t0aCbPLQQ7kNvgG7OOZ9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqDvghPFxnn8QsScea09TWRrwV6ll761DkSoI--S7ZNA&oe=66CF0C6F"}, "display_name": "Zombies in Your Home", "keywords": [], "long_description": "Zombies will chase you around and spawn randomly throughout your mapped house.\n\nGame Instructions\n\n1) Place nodes at each corner of your walls and doors with the right trigger going counter clockwise. If you put one in the wrong place, just click X on the left remote to clear them out.\n\n2) Press A on the right controller to Lock In your play area and walls. This will also start the game and dim the light.\n\n3) Press B on the right controller to turn on your flashlight. Use it to kill the enemies that are now spawning faster and faster and coming to find you. Just hold the light on them for 5 seconds.\n\n4) If the enemies get too close you will loose health and the game will stop and show your score. Restart with A on the right controller.", "short_description": "Oculus Passthrough has Zombies in your Livingroom! Kill them with your flashlight before they get you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/zombies