5_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_dQf8okh-5kQ7kNvgHI-PT9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABU4-G7F0Nq7CBvnEptSYb8&oh=00_AYAkJaNAmczNuB4AP4uTE3uAzere_ubWsi-EzLLSeH-wkw&oe=66F3FDEC"}, {"file_name": "Game3.png", "id": "1341930919587442", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974874_1341930922920775_2032434531725596727_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l5Olxe0FDxUQ7kNvgERZ8n0&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABU4-G7F0Nq7CBvnEptSYb8&oh=00_AYBMaCl_nS4WsMW-Afd0xN80sOcHm8F7UJ0GXCqyGpz7aw&oe=66F3F5AB"}, {"file_name": "Game4.png", "id": "483441523140842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_483441526474175_8637568278043978051_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mf9SxsFPnrcQ7kNvgGmzIzJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABU4-G7F0Nq7CBvnEptSYb8&oh=00_AYBpsH1T8tzYqDv0f9ajz0uSBSaq9sCA-eWUIOmp-jc5nA&oe=66F3F768"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "imgonline-com-ua-resize-5mxQnAdDtM8qR (5).png", "id": "307963504272287", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036704_307963510938953_12489759764553333_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tXglCbkA5IUQ7kNvgFzwMlC&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABU4-G7F0Nq7CBvnEptSYb8&oh=00_AYA_FXaHjUcEdTN2CdkusADZV2Qbq25LGVIPAn481UQKIQ&oe=66F3F66F"}, "display_name": "Zombies in Your Home", "keywords": [], "long_description": "Zombies will chase you around and spawn randomly throughout your mapped house.\n\nGame Instructions\n\n1) Place nodes at each corner of your walls and doors with the right trigger going counter clockwise. If you put one in the wrong place, just click X on the left remote to clear them out.\n\n2) Press A on the right controller to Lock In your play area and walls. This will also start the game and dim the light.\n\n3) Press B on the right controller to turn on your flashlight. Use it to kill the enemies that are now spawning faster and faster and coming to find you. Just hold the light on them for 5 seconds.\n\n4) If the enemies get too close you will loose health and the game will stop and show your score. Restart with A on the right controller.", "short_description": "Oculus Passthrough has Zombies in your Livingroom! Kill them with your flashlight before they get you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/zombiesprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Cazforshort", "support_website_url": null, "website_url": "https://sites.google.com/view/zombiesprivacypolicy", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SHOOTER", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5370311139648746"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982549_874257819934940_3963524846263804723_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CySEyX0PeEMQ7kNvgHFFPEB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABU4-G7F0Nq7CBvnEptSYb8&oh=00_AYAczMFAWTAbcAzKX2GlievWZK1C_5TirvfR8ZDEf-zqsA&oe=66F3E617"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Zombies in Your Home", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1647025555, "lastRevision": {"nodes": [{"id": "4724349490964661", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"ap