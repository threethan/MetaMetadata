ngroom! Kill them with your flashlight before they get you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/zombiesprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Cazforshort", "support_website_url": null, "website_url": "https://sites.google.com/view/zombiesprivacypolicy", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SHOOTER", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5370311139648746"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "5220913331287331"}]}, "baseline_offer": {"id": "5220913331287331"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1647025500, "status": "PUBLISHED", "id": "5220913331287331"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4276468232452870", "version": "0.2"}, "id": "4796007810439091", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3988684137897949", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4276468232452870"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4796007810439091"}]}, "change_log": "removed mic from manifest", "created_date