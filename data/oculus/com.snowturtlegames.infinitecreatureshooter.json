5/39035433_478466441584915_2893798964817280459_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pnkVT6pS5NYQ7kNvgFlg6U9&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjtkyx18w_gcLjO8CiLtOU_IrMUNAr4L9eEKVhtZ3bjQ&oe=66D84D68"}, "display_name": "infinite creature shooter", "keywords": ["shooter", "ation", "scifi", "endless", "infinite"], "long_description": "Infinite creature shooter is an endless loop based   action shooter VR game. This virtual reality game intends to provide its user a unique experience of characters enhanced with neon lightings.\n\nThe game has a total of 5 levels which are portrayed in a random order to the users . It is a loop based infinite runner space action game.\n\n\nThe goal to play this game is as follows :-\n\n1. Shoot down the aliens \n2. create a new high score \n3. progress through different levels\n4. enjoy this new trippy experience through a new journey \n\n\n\n{356936524139806}\n{485262154130001}\n{856784219314023}", "short_description": "Infinite creature shooter is an endless loop based   action shooter VR game. This virtual reality game intends to provide its user a unique experience of characters enhanced with neon lightings.\n\nThe game has a total of 5 levels which are portrayed in a random order to the users . It is a loop based infinite runner space action game.\n\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/145edb98-292e-4252-988b-c6832686491e", "developer_terms_of_service_url": null, "publisher_name": "aayush chaurasia", "support_website_url": null, "website_url": "https://snowturtlegames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", 