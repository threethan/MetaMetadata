584915_2893798964817280459_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sfIIoDz3VZcQ7kNvgHnn1eZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCiWOeLO76Xs4fdVpDHxu1UPW2gbWPiCVVyidJH0qXkSg&oe=67276768"}, "display_name": "infinite creature shooter", "keywords": ["shooter", "ation", "scifi", "endless", "infinite"], "long_description": "Infinite creature shooter is an endless loop based   action shooter VR game. This virtual reality game intends to provide its user a unique experience of characters enhanced with neon lightings.\n\nThe game has a total of 5 levels which are portrayed in a random order to the users . It is a loop based infinite runner space action game.\n\n\nThe goal to play this game is as follows :-\n\n1. Shoot down the aliens \n2. create a new high score \n3. progress through different levels\n4. enjoy this new trippy experience through a new journey \n\n", "short_description": "Infinite creature shooter is an endless loop based   action shooter VR game. This virtual reality game intends to provide its user a unique experience of characters enhanced with neon lightings.\n\nThe game has a total of 5 levels which are portrayed in a random order to the users . It is a loop based infinite runner space action game.\n\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/145edb98-292e-4252-988b-c6832686491e", "developer_terms_of_service_url": null, "publisher_name": "aayush chaurasia", "support_website_url": null, "website_url": "https://snowturtlegames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "