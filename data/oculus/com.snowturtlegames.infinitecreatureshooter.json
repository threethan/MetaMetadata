584915_2893798964817280459_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nbeqbq9fl7gQ7kNvgFTGdiW&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAQNUjJf4SejQAzK7SSGa3hHC0vqcSfhQ-Tiznf6ObAfg&oe=671A3868"}, "display_name": "infinite creature shooter", "keywords": ["shooter", "ation", "scifi", "endless", "infinite"], "long_description": "Infinite creature shooter is an endless loop based   action shooter VR game. This virtual reality game intends to provide its user a unique experience of characters enhanced with neon lightings.\n\nThe game has a total of 5 levels which are portrayed in a random order to the users . It is a loop based infinite runner space action game.\n\n\nThe goal to play this game is as follows :-\n\n1. Shoot down the aliens \n2. create a new high score \n3. progress through different levels\n4. enjoy this new trippy experience through a new journey \n\n", "short_description": "Infinite creature shooter is an endless loop based   action shooter VR game. This virtual reality game intends to provide its user a unique experience of characters enhanced with neon lightings.\n\nThe game has a total of 5 levels which are portrayed in a random order to the users . It is a loop based infinite runner space action game.\n\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/145edb98-292e-4252-988b-c6832686491e", "developer_terms_of_service_url": null, "publisher_name": "aayush chaurasia", "support_website_url": null, "website_url": "https://snowturtlegames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "reco