=1-7&_nc_sid=6e7a0a&_nc_ohc=RcfE2SRAQpIQ7kNvgFHhyr8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AycobGQpDkyTFFi9FFF2o1l&oh=00_AYCIIuUYbWFDyEL7cQ2gB3mfX0OHhKAAdr4gMM14vW895Q&oe=66E82613"}, {"file_name": "migrated_image.png", "id": "528742541397634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982455_454585495111800_2011777322989912064_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=28PH4rXF4QsQ7kNvgH3sxyw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AycobGQpDkyTFFi9FFF2o1l&oh=00_AYBaNowkl0Gxo7pwTgVk49Xju7cuTF893BDcgrmAo508ng&oe=66E80702"}, {"file_name": "migrated_image.png", "id": "1388515234654553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974736_2193916760911509_3324152151340482560_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-3gpMzqWs4gQ7kNvgFv_5_d&_nc_ht=scontent.oculuscdn.com&_nc_gid=AycobGQpDkyTFFi9FFF2o1l&oh=00_AYC0xIFSqiB6AUGthtFFuakDkOBK6NG-X0aQ_rQ7GaFFfw&oe=66E82F21"}, {"file_name": "migrated_image.png", "id": "1094480664267888", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974636_470699557067269_2248792073857662976_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4Kbv7oX8gfMQ7kNvgFxWee3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AycobGQpDkyTFFi9FFF2o1l&oh=00_AYBStS9Apw3Vo2rg7MljlN2DeB6sQQOMRFbHHfjzUkyNVQ&oe=66E8067C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/XnaTHm", "id": "2111964545778480", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974545_2111964549111813_2104429525730328576_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SoasbKuBHowQ7kNvgFHDaFZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AycobGQpDkyTFFi9FFF2o1l&oh=00_AYA16q5p39hCSaEbLNeCJvH0R1ULzBZ9uIJf6SICu7MLKQ&oe=66E80164"}, "display_name": "Accounting+", "keywords": ["comedy", "accounting", "job", "cartoon", "funny"], "long_description": "How long have these goggles been pressing into my flesh? What began as a small game jam between William Pugh (The Stanley Parable), Dominik Johann (Minit) and Justin Roiland (Rick and Morty) is now\u2014two years later\u2014an aberration of warped technology, weird worlds and strange, disturbing creatures. Since its debut, Accounting has tripled in size, mutated into an intricate labyrinth of forbidden virtual realities. With countless more secrets to discover if you have the stomach to brave the dangers of new characters brought to life by a cast of comedic legends (Rich Fulcher, Reggie Watts, and Justin Roiland). DANGERS - If you die in VR, you die in real life. - Do not play after midnight. - Achievements linked to unforgivable acts of human corruption. - A way better soundtrack than a VR game soundtrack has any right to be. - Subtitles and translations for 9 languages. Wow, internationally dangerous! - The vacuum of space. Yeah that dangerous. - And unfortunately: The Cops.", "short_description": "Accounting+ is a NIGHTMARE ADVENTURE COMEDY by Crows Crows Crows, designed with Squanch Games. Over double the size of the original (critically, critically acclaimed) Accounting. Experience classic reality gameplay: clean up your office, take the battery out of the cooling machine, play the skeleton xylophone, and/or summon thousands upon thousands of demons."}]}, "developer_name": "Crows Crows Crows", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://crowscrowscrows.com/privacy/", "publisher_name": "Crows Crows Crows", "support_website_url": "https://crowscrowscrows.com/", "website_url": "http://accountingpl.us/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "HORROR", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "ru", "ko", "es"], "supported_input_devices": ["OCULUS_TO