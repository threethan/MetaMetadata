_2011777322989912064_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wIUl87TnF-sQ7kNvgFVSG5E&_nc_ht=scontent.oculuscdn.com&oh=00_AYDBNOJwyO0YhQjtCBb2tT6fQaWA2URnEbVQqXeIUXfi_g&oe=66DD7B02"}, {"file_name": "migrated_image.png", "id": "1388515234654553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974736_2193916760911509_3324152151340482560_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=20gapcWdX_wQ7kNvgE-ts9P&_nc_ht=scontent.oculuscdn.com&oh=00_AYCg83_ab6OdtGj3A_ITC2afye-bPzBcJIDnTiddEFL7jA&oe=66DDA321"}, {"file_name": "migrated_image.png", "id": "1094480664267888", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974636_470699557067269_2248792073857662976_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dUBJJi7s02IQ7kNvgGQlLBZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrQqOk0S6uPaFMYSVPYI8xT8Yz-SVsdoyBv7OjzJ-oTg&oe=66DD7A7C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/XnaTHm", "id": "2111964545778480", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974545_2111964549111813_2104429525730328576_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8B1mE0p6UioQ7kNvgECubmu&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvzHy1JJjjiGG5j84JU4IlDjZkjAJ_4Q1-Xt5_mLgFXA&oe=66DD7564"}, "display_name": "Accounting+", "keywords": ["comedy", "accounting", "job", "cartoon", "funny"], "long_description": "How long have these goggles been pressing into my flesh? What began as a small game jam between William Pugh (The Stanley Parable), Dominik Johann (Minit) and Justin Roiland (Rick and Morty) is now\u2014two years later\u2014an aberration of warped technology, weird worlds and strange, disturbing creatures. Since its debut, Accounting has tripled in size, mutated into an intricate labyrinth of forbidden virtual realities. With countless more secrets to discover if you have the stomach to brave the dangers of new characters brought to life by a cast of comedic legends (Rich Fulcher, Reggie Watts, and Justin Roiland). DANGERS - If you die in VR, you die in real life. - Do not play after midnight. - Achievements linked to unforgivable acts of human corruption. - A way better soundtrack than a VR game soundtrack has any right to be. - Subtitles and translations for 9 languages. Wow, internationally dangerous! - The vacuum of space. Yeah that dangerous. - And unfortunately: The Cops.", "short_description": "Accounting+ is a NIGHTMARE ADVENTURE COMEDY by Crows Crows Crows, designed with Squanch Games. Over double the size of the original (critically, critically acclaimed) Accounting. Experience classic reality gameplay: clean up your office, take the battery out of the cooling machine, play the skeleton xylophone, and/or summon thousands upon thousands of demons."}]}, "developer_name": "Crows Crows Crows", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://crowscrowscrows.com/privacy/", "publisher_name": "Crows Crows Crows", "support_website_url": "https://crowscrowscrows.com/", "website_url": "http://accountingpl.us/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "HORROR", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "ru", "ko", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "613024753097808"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "2615963225392194"}, {"status": "PUBLISHED", "id": "383157968983728"}, {"status": "PUBLISHED", "id": "1108902573315522"}, {"status": "PUBLISHED", "id": "219770156955134"}, {"status": "PENDING", "id":