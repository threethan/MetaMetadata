7GCA9_f1QhjcjSMr9GOvBL2Q&oe=66EFF454"}, {"file_name": "Untitled (1440 x 1440 px) (3).png", "id": "368516506133069", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036608_368516509466402_8863055447355269907_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KD2oXfuuPZsQ7kNvgHEo7yz&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYDGlxqNdEmFHfLG3EA_itVZVU1BOgQagQmlDAZKwGP94A&oe=66F00E89"}]}, "id": "378896101731865", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "368767112690588", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974650_368767116023921_6274503579094904685_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A6f7EEWikbYQ7kNvgEmJnwx&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYBE0laoX9wAWd2z-782iMfeW7o-iUfDOgT_Pcjca-wXlA&oe=66EFECE6"}, {"file_name": "2.png", "id": "720731603238956", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031462_720731606572289_4976203001270237016_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xcsfZ7DI690Q7kNvgEqdY_3&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYCItYNNEm_bGNQuHpa3BJgk6naxiIWG6gV-4FUoI5mtzg&oe=66EFF807"}, {"file_name": "3.png", "id": "1625531261523675", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031399_1625531264857008_4404153950889863158_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wI2MOMYBm1QQ7kNvgG-bQmi&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYDpDcZlgbwXLIejZDcj2fmgG8rxtw-9yCEj8P3gtv4QPQ&oe=66F00CFA"}, {"file_name": "4.png", "id": "924239662705348", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86621364_924239666038681_6901919607663535899_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GrFAioQt4PQQ7kNvgEBYJOv&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYDrKvTBYokz7uatW9vtVDORTuLNBHCkFhyzIOuZjzoJHA&oe=66EFF2E7"}, {"file_name": "5.png", "id": "956382326056355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_956382329389688_8109001757266612054_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oKMf84bzpC4Q7kNvgGv5xlB&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYAgx8rmjNwX9b3LmByTVk4ZJjNHnmCM69RUPs_QXDkhXA&oe=66EFF785"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled (1440 x 1440 px) (8).png", "id": "703633211958581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371506_703633215291914_4089775545134333953_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KlMoY4lEoDIQ7kNvgGDsJUs&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYAHSLluT6qbq7PPlglI91cuCSOJdNuzxczpI7KxxaDx_A&oe=66F0141B"}, "display_name": "Maxim VR", "keywords": [], "long_description": "Welcome to Maxim VR \u2013 The Gateway to Mental Well-being for young people!\n\nKey Features:\n\ud83e\uddd8 Mindfulness and Educational Support: Immerse yourself in mindfulness exercises, guided meditation, and educational content focused on mental health awareness, coping strategies, and emotional intelligence.\n\n\ud83c\udf08 Customizable Environments: Tailor your VR experience by choosing from a variety of themes, settings, and interactive activities, ensuring a personalized space that resonates with your unique preferences (in development)\n\n\ud83c\udf1f Animated Virtual Companions: Meet our animated virtual companions, designed to provide dynamic and responsive interactions. These companions offer emotional support, guidance, and a sense of companionship, enhancing the therapeutic impact of the VR experience (in development)\n\nTherapeutic Benefits:\n\ud83c\udf0a Stress Relief: Experience a controlled and immersive space designed to relieve stress, promote relaxation, and support emotional well-being.\n\n\ud83c\udf93 Educational Enrichment: Learn about mental health in an engaging way, exploring topics that enhance your understanding of emotions, coping mechanisms, and overall mental well-being (in development)\n\n\nNote: Maxim VR Health Spaces strives for continuous improvement based on user feedback and advancements in virtual reality technology. Your well-being is our priority.\n\nV2 will launch soon!\n\n", "short_description": "Welcome to Maxim VR Health Spaces \u2013 Your Gateway to Mental Well-being! Embark on a transformative journey within our immersive virtual reality environments, meticulously designed to foster mental wellness in children and young people. Maxim VR Health Spaces are more than just virtual landscapes; they are dynamic realms where creativity, education, and therapeutic support converge to create a unique and enriching experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.maxim-vr.com/privacy-notice", "developer_terms_of_service_url": "https://www.maxim-vr.com/terms-and-conditions", "publisher_name": "Maxim VR", "support_website_url": null, "website_url": "https://www.maxim-vr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25074758515502316"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031656_773729011314473_595301407077834306_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YrO8yp4yAkIQ7kNvgGU-5iS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYA9OLrZLg5n51GXlPVkARfPVBNPtVwlhGxSCLOugRjpbg&oe=66EFF454"}, "is_concept": false, "i