": "924239662705348", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86621364_924239666038681_6901919607663535899_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dRpMKn8Ou2gQ7kNvgEo8gCr&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8dzsY0rLnFbAPdup-fIWRyH1RUPZdxgDVTf8Msu00Vw&oe=66D98967"}, {"file_name": "5.png", "id": "956382326056355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_956382329389688_8109001757266612054_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cpP04VZt3XkQ7kNvgFsdI8V&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzO6Ve7oVGIhuKm_ovL1UQDBBMrrQBTpDXNTp8Q-a04A&oe=66D98E05"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled (1440 x 1440 px) (8).png", "id": "703633211958581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371506_703633215291914_4089775545134333953_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1wMSfXkBrVAQ7kNvgHeTFC1&_nc_ht=scontent.oculuscdn.com&oh=00_AYB1L7V7Q2OKn_MqOJzI_pLyRJ5oYQqlOh5cvwuTcgnUew&oe=66D9AA9B"}, "display_name": "Maxim VR", "keywords": [], "long_description": "Welcome to Maxim VR Health Spaces \u2013 Your GenZ Gateway to Mental Well-being!\n\nKey Features:\n\ud83e\uddd8 Mindfulness and Educational Support: Immerse yourself in mindfulness exercises, guided meditation, and educational content focused on mental health awareness, coping strategies, and emotional intelligence.\n\n\ud83c\udf08 Customizable Environments: Tailor your VR experience by choosing from a variety of themes, settings, and interactive activities, ensuring a personalized space that resonates with your unique preferences.\n\n\ud83c\udf1f Animated Virtual Companions: Meet our animated virtual companions, designed to provide dynamic and responsive interactions. These companions offer emotional support, guidance, and a sense of companionship, enhancing the therapeutic impact of the VR experience (in development)\n\nTherapeutic Benefits:\n\ud83c\udf0a Stress Relief: Experience a controlled and immersive space designed to relieve stress, promote relaxation, and support emotional well-being.\n\n\ud83c\udf93 Educational Enrichment: Learn about mental health in an engaging way, exploring topics that enhance your understanding of emotions, coping mechanisms, and overall mental well-being.\n\n\ud83d\ude80 Inspiration for Coping: Use musical elements, movement, and interactive activities to discover new ways of coping with stress, anxiety, and other mental health challenges.\n\nNote: Maxim VR Health Spaces strive for continuous improvement based on user feedback and advancements in virtual reality technology. Your well-being is our priority.\n\n", "short_description": "Welcome to Maxim VR Health Spaces \u2013 Your Gateway to Mental Well-being! Embark on a transformative journey within our immersive virtual reality environments, meticulously designed to foster mental wellness in children and young people. Maxim VR Health Spaces are more than just virtual landscapes; they are dynamic realms where creativity, education, and therapeutic support converge to create a unique and enriching experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.maxim-vr.com/privacy-notice", "developer_terms_of_service_url": "https://www.maxim-vr.com/terms-and-conditions", "publisher_name": "Maxim VR", "support_website_url": null, "website_url": "https://www.maxim-vr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interact