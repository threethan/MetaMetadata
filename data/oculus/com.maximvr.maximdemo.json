o-iUfDOgT_Pcjca-wXlA&oe=66EFECE6"}, {"file_name": "2.png", "id": "720731603238956", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031462_720731606572289_4976203001270237016_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xcsfZ7DI690Q7kNvgEqdY_3&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYCItYNNEm_bGNQuHpa3BJgk6naxiIWG6gV-4FUoI5mtzg&oe=66EFF807"}, {"file_name": "3.png", "id": "1625531261523675", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031399_1625531264857008_4404153950889863158_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wI2MOMYBm1QQ7kNvgG-bQmi&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYDpDcZlgbwXLIejZDcj2fmgG8rxtw-9yCEj8P3gtv4QPQ&oe=66F00CFA"}, {"file_name": "4.png", "id": "924239662705348", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86621364_924239666038681_6901919607663535899_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GrFAioQt4PQQ7kNvgEBYJOv&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYDrKvTBYokz7uatW9vtVDORTuLNBHCkFhyzIOuZjzoJHA&oe=66EFF2E7"}, {"file_name": "5.png", "id": "956382326056355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_956382329389688_8109001757266612054_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oKMf84bzpC4Q7kNvgGv5xlB&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYAgx8rmjNwX9b3LmByTVk4ZJjNHnmCM69RUPs_QXDkhXA&oe=66EFF785"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled (1440 x 1440 px) (8).png", "id": "703633211958581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371506_703633215291914_4089775545134333953_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KlMoY4lEoDIQ7kNvgGDsJUs&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HwFGFrapvxeehUtlguvYg&oh=00_AYAHSLluT6qbq7PPlglI91cuCSOJdNuzxczpI7KxxaDx_A&oe=66F0141B"}, "display_name": "Maxim VR", "keywords": [], "long_description": "Welcome to Maxim VR Health Spaces \u2013 Your GenZ Gateway to Mental Well-being!\n\nKey Features:\n\ud83e\uddd8 Mindfulness and Educational Support: Immerse yourself in mindfulness exercises, guided meditation, and educational content focused on mental health awareness, coping strategies, and emotional intelligence.\n\n\ud83c\udf08 Customizable Environments: Tailor your VR experience by choosing from a variety of themes, settings, and interactive activities, ensuring a personalized space that resonates with your unique preferences.\n\n\ud83c\udf1f Animated Virtual Companions: Meet our animated virtual companions, designed to provide dynamic and responsive interactions. These companions offer emotional support, guidance, and a sense of companionship, enhancing the therapeutic impact of the VR experience (in development)\n\nTherapeutic Benefits:\n\ud83c\udf0a Stress Relief: Experience a controlled and immersive space designed to relieve stress, promote relaxation, and support emotional well-being.\n\n\ud83c\udf93 Educational Enrichment: Learn about mental health in an engaging way, exploring topics that enhance your understanding of emotions, coping mechanisms, and overall mental well-being.\n\n\ud83d\ude80 Inspiration for Coping: Use musical elements, movement, and interactive activities to discover new ways of coping with stress, anxiety, and other mental health challenges.\n\nNote: Maxim VR Health Spaces strive for continuous improvement based on user feedback and advancements in virtual reality technology. Your well-being is our priority.\n\n", "short_description": "Welcome to Maxim VR Health Spaces \u2013 Your Gateway to Mental Well-being! Embark on a transformative journey within our immersive virtual reality environments, meticulously designed to foster mental wellness in children and young people. Maxim VR Health Spaces are more than just virtual landscapes; they are dynamic realms where creativity, education, and therapeutic support converge to create a unique and enriching experience."}]}, "developer_name": null, "developer_priva