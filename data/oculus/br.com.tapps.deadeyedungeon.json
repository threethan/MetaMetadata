ul loot, including new and improved Arcane Guns.\n\nSTAY ON YOUR TOES\nHandle the tense atmosphere of a dangerous dark fantasy world where every corner you turn may be your last!\n\nGet ready to be immersed into this unforgettable dungeon crawling adventure!", "short_description": "Shoot monsters and discover dark secrets in a relentless new VR experience."}]}, "developer_name": null, "developer_privacy_policy_url": "http://pp.tappsgames.com.s3.amazonaws.com/GeneralPP.htm", "developer_terms_of_service_url": "http://tos.tappsgames.com.s3.amazonaws.com/GeneralTOS.htm", "publisher_name": "Tapps Games", "support_website_url": null, "website_url": "http://www.tappsgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "EXPLORATION", "RPG", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2757591844544633"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "252723111973042"}, {"status": "PUBLISHED", "id": "301393336979179"}, {"status": "PUBLISHED", "id": "1893100317385425"}]}, "baseline_offer": {"id": "301393336979179"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1528995600, "status": "PUBLISHED", "id": "252723111973042"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2143467915712795", "version": "2.1"}, "id": "1075414339257956", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary