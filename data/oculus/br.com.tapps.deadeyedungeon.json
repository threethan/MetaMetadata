ne Guns.\n\nSTAY ON YOUR TOES\nHandle the tense atmosphere of a dangerous dark fantasy world where every corner you turn may be your last!\n\nGet ready to be immersed into this unforgettable dungeon crawling adventure!", "short_description": "Shoot monsters and discover dark secrets in a relentless new VR experience."}]}, "developer_name": "Tapps VR", "developer_privacy_policy_url": "http://pp.tappsgames.com.s3.amazonaws.com/GeneralPP.htm", "developer_terms_of_service_url": "http://tos.tappsgames.com.s3.amazonaws.com/GeneralTOS.htm", "publisher_name": "Tapps Games", "support_website_url": null, "website_url": "https://www.tappsvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SHOOTER", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "712761866386452"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/11162679_1791058807876479_2112692252533850112_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xu38BOY5ztQQ7kNvgF29a9Z&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYABcSGmm87Z9WpDPsBT7KGGi79JtirZVJKCls_nAcEbtw&oe=67126034"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Deadeye Dungeon", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1496854800, "lastRevision": {"nodes": [{"id": "755643894603094", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_U