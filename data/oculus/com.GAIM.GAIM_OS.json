om/v/t64.5771-25/75411994_481234239894307_9041268923289417302_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJ_pKHGqJ60Q7kNvgEh1JHm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQ2Ef74r7v5QVlClPHM2tAJKm-iAqN2NGxyxnE_Akzww&oe=671CBC95"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "GAIM_TrailerCover.png", "id": "284549926658046", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031356_284549929991379_2954306797903590113_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J3NHf2qAh7IQ7kNvgEj2h9P&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmtvyaT7rGG3Kq8BFV4G5jVaN_ItfkjXAlH7HZ4JnBog&oe=671CD2F9"}, "display_name": "GAIM", "keywords": [], "long_description": "Improve your skills as a hunter or sports shooter with GAIM virtual training simulator. Practice shooting and hunting in the comfort of your home, and with more sophisticated tools than at the shooting range. Precise barrel tracking, correct animal anatomy and correct ballistics ensure detailed understanding of your shooting technique. Together with analysis and replay of every shot, this simulator will take your training to the next level. Practice on targets where you set the distance, speed and direction then test your skills on running game in driven hunt scenarios or a set sport shooting scenario.", "short_description": "Take your hunting and sport shooting skills to new levels with GAIM virtual training simulator. Practice your skills at home with precision tracking of your barrel movements to understand how you produce a hit with anatomically correct animal models or sport shooting environment. Get ready for reality!"}]}, "developer_name": "GAIM", "developer_privacy_policy_url": "https://gaim.com/privacy-policy", "developer_terms_of_service_url": "https://www.gaim.com/media/hypdm2hm/gaim_s-b2c-general-conditions-of-sale_eu-usa.pdf", "publisher_name": "GAIM Immersive Technology Group", "support_website_url": "https://www.gaim.com/support", "website_url": "h