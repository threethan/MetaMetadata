uc73c\uc138\uc694.\n\n\uac8c\uc784 \ud50c\ub808\uc774 Tip!\n\uc544\uc774\ud15c\uc744 \ud68d\ub4dd\ud558\uc5ec \ubd80\uc2a4\ud130 \uac8c\uc774\uc9c0\ub97c \ubaa8\uc73c\uc138\uc694. \ubd80\uc2a4\ud130\ub294 \uae30\ub85d \uac31\uc2e0\uc5d0 \ub9ce\uc740 \ub3c4\uc6c0\uc744 \uc90d\ub2c8\ub2e4.\n\n\ub9ac\ubdf0\ub97c \ub0a8\uaca8\uc8fc\uc138\uc694!\n\ucd94\uac00 \uc5c5\ub370\uc774\ud2b8\uc5d0 \ubc18\uc601\ud558\ub3c4\ub85d \ub178\ub825\ud558\uaca0\uc2b5\ub2c8\ub2e4.", "short_description": "VR A-MAN\uc774 \ub418\uc5b4 \ubcf4\uc138\uc694. \ubd88\uc2dc\ucc29\ud55c \ud589\uc131\uc5d0\uc11c \uc5ec\ub7ec\ubd84\ub4e4\uc740 \uc0b4\uc544\ub0a8\uae30 \uc704\ud574 \ub04a\uc784\uc5c6\uc774 \uc9c8\uc8fc\ud574\uc57c \ud569\ub2c8\ub2e4. \uae30\ub85d\uc744 \uc138\uc6cc \uce5c\uad6c\ub4e4\uacfc \uacbd\uc7c1\ud574 \ubcf4\uc138\uc694"}]}, "developer_name": "Developement Team", "developer_privacy_policy_url": "http://www.elrois.com/Documents/%EA%B0%9C%EC%9D%B8%EC%A0%95%EB%B3%B4%EC%B2%98%EB%A6%AC%EB%B0%A9%EC%B9%A8(A-MAN_KR).pdf", "developer_terms_of_service_url": "http://www.elrois.com/Documents/%EB%AA%A8%EB%B0%94%EC%9D%BC%EA%B2%8C%EC%9E%84%ED%91%9C%EC%A4%80%EC%95%BD%EA%B4%80(KR).pdf", "publisher_name": "Elrois inc.", "support_website_url": null, "website_url": "http://www.elrois.com/eng/main/main.php", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "314768420695297"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.c