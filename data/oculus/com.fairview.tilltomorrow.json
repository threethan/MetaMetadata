-kBsj4BGm2IjUq2tU_4YLlg&oe=67582D88"}, {"file_name": "5.png", "id": "1182625332856027", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75245823_1182625336189360_3424764054031859025_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0eR_avB_u7kQ7kNvgGIkYlR&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCb4o90JsjReWn-HNEKRCZnTmQqa_ZeEMenJfVLJqKt3g&oe=675824F7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "380862431304535", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75556794_380862434637868_4949372230755275132_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ucXXP3ntPA0Q7kNvgFhvjH-&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAeyiLaNp0wakserFNP6k2Iy3O-tzRVQC9h0lom5-PXyw&oe=67581453"}, "display_name": "Till Tomorrow", "keywords": [], "long_description": "When rescue seems impossible, were you able to thrive on the islands\uff1fThis is a sandbox survival building game with high freedom and diverse gameplay.\n\n**Highlights**\n- Exploring islands and searching for treasures\uff0cclimbing\uff0csailing\uff0crowing\uff0cswimming\n- Surviving by gathering resources, building shelter, crafting tools or feeling the sea breeze, enjoying the sunrise and sunset.\n- Hunting for food and managing encounters with aggressive wildlife\n- Planting a variety of vegetables and fruits.\n- Mixing various ingredients to cook delicious meals\n- Building and decorating your big house\n- Capturing animals for breeding and petting\n- Sharing your islands and explore new ones created by others.\n- Playing with your friends, whether it\u2019s exploring, building together or tricking each other, they are all up to you!\n- Customizing the adventures by designing your own\n\nStill there are many interesting things waiting for you to explore!\n\n## Join our *discord* (discord.gg/rU2vg7kcMv) to start the journey!", "short_description": "When rescue does not seem possible, can you survive on the island? Crafting, hunting, farming, building to thrive on islands.\n\nThe multiplay mode is available NOW! Come to build your own island and hang out with friends!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://fvworks.github.io/TillTomorrow/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Self", "support_website_url": null, "website_url": "https://fvworks.github.io/TillTomorrow/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "CASUAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7860700327381868"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75411988_1019235466274284_8716596030605421365_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_09-or1zAusQ7kNvgFOLGj1&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAWpxbSc81UMyqnd5Fu9AhlHsrwCj7RHLiroY1a1wic7A&oe=6758269F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Till Tomorrow", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sandbox", "id": "1990104051447093"}, {"topic_name": "Survival", "id": "644354873106712"}], "release_date": 1657162800, "lastRevision": {"nodes": [{"id": "910797633075013", "release_type": "SCHEDULED", "administrat