28497_3984425424958031815_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hDNawhOTHeYQ7kNvgG9c_Me&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAwGRW5N3L9i0Ppo0UnwsB_LGBHlHSu7ONsJ8H99Pd7Fw&oe=671A2E65"}, {"file_name": "3.png", "id": "2393709944099156", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75297578_2393709947432489_5007977160726967115_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SisFVRDHUUUQ7kNvgH4Vrpr&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCb63yg-6H97HcvYGgTwRhX3k0euEGkCxGogjkOOvUJhA&oe=671A4635"}, {"file_name": "4.png", "id": "477838957214204", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75262741_477838963880870_7610033215863633054_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uto-9kljIlsQ7kNvgGH7a1d&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCoG0lh6RLlULbo_48H5_o-dwwCSD55uWFrMU7VLcqVRg&oe=671A3569"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_landscape.png", "id": "474021671100140", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031629_474021674433473_3331481304428563359_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdoo5PIeP5sQ7kNvgEfcpOb&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCcCTWumqqKaejb5-qMKespQaBw8b5qIOi62jefgnJhRQ&oe=671A42AE"}, "display_name": "Till Tomorrow", "keywords": [], "long_description": "About the game\n\nAs an adventurer, you\u2019ve been thrown into a remote island by a fierce storm. You must survive on and escape from it eventually.\n\nBuild your skill set for living in the wild along the journey, no matter it is crafting your tools, forking fishes, hunting with bows, farming, or making houses! Those will definitely help to realize your goal and build up the gears needed for your next challenge.   Have great adventures to explore the 'dark forest' where you may need to fight against mystery malicious creatures and collect treasures as a reward.   No one knows what risks you'll have to resolve till tomorrow\u2026", "short_description": "When rescue does not seem possible, can you survive along with the island? Crafting, hunting, farming, building to thrive on the island."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fvworks.github.io/TillTomorrow/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Self", "support_website_url": null, "website_url": "https://fvworks.github.io/TillTomorrow/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "CASUAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1031637430756183"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "398822212941550"}, {"status": "PUBLISHED", "id": "1204104773940811"}, {"status": "PUBLISHED", "id": "792472459069798"}, {"status": "PUBLISHED", "id": "781565196727744"}, {"status": "PUBLISHED", "id": "475083431090561"}, {"status": "PUBLISHED", "id": "934707067217113"}]}, "baseline_offer": {"id": "792472459069798"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "398822212941550"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8258085460976684", "version": "0.8.0.8"}, "id": "1004118207124290", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinar