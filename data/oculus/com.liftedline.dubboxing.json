_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=INyev3SwxsUQ7kNvgGA0I3v&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB-3gfTjISq8-ysxA8D5vicknQSlY1LjK0X0CBN14C-hA&oe=6717908B"}, {"file_name": "Champion Reflex 512x512.png", "id": "493141753345969", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566688_493141756679302_4202526529522013258_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xNkIgeSGXwoQ7kNvgHAifh0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCslDdelUUAPlbFOWzZRSF0de1iT3XpyM0oqmcVjeJpgQ&oe=67178924"}]}, "id": "3715279255395248", "locale": "en_US", "screenshots": [{"file_name": "Mad Reflex Game Play Still 2.png", "id": "489249273328351", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974868_489249276661684_3624221581078752238_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=itZ_EkjNlx4Q7kNvgFvgCJf&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVFMdZfdiD8YBXiYk-_ulOA2zA63KkRqkhkSji71M4OQ&oe=6717A255"}, {"file_name": "Mad Reflex Mixed Reality Still 1.png", "id": "406499402217736", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974512_406499405551069_5110302358913969244_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cY_kVzRjOmsQ7kNvgGyu6ni&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHuf-vG6qakQMmm0BxgK9bHUoFgCV88pXA7HuykOXnCQ&oe=6717958E"}, {"file_name": "Mad Reflex Mixed Reality Still 3.png", "id": "734756302070853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974924_734756305404186_6923290934958339527_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CMSmUINjEGQQ7kNvgFyGzRG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPCyaC1wKQyhdObUSm-ljZ6crKaPQsN22FsqS7wbwGTw&oe=67177894"}, {"file_name": "Champion Reflex Still 1.png", "id": "1181292146413634", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035471_1181292149746967_5217355252292440293_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BE-7DcvQ1-8Q7kNvgENY5PF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBG8QXER9Obpzd9i_BeVnavqrdr22_BtX_ZpIV-Gj911g&oe=6717AABD"}, {"file_name": "Mad Reflex Game Play Still 3.png", "id": "533471049017236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_533471052350569_4760719742838017701_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v_UgSsu6xZEQ7kNvgG38b43&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFYqehI6C0-ngXCpvmU-9OnGWy2PPc7u9iMdMhgjEmWg&oe=671790D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Champion Reflex_2560x1440.png", "id": "1184244736025036", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569458_1184244739358369_111066120156910815_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=56HbSH7LH2sQ7kNvgEBTZWf&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASsNJS_qNGQEg3kIP6j0fNbXjQ3fHpwwEafT2yK9XU-Q&oe=67178E5C"}, "display_name": "Reflex Punk", "keywords": [], "long_description": "\ud83d\udcaa With every dodge and weave, you'll feel your reflexes sharpening while you work up a sweat and burn calories. Track your progress, challenge friends, and dominate the leaderboards as you become the ultimate reflex champion.\n\n\ud83d\udcca With real-time stat tracking and competitive leaderboards, Reflex Punk keeps you motivated to push yourself further and achieve new fitness heights.\n\n\ud83c\udfa7 Turn your workout into an intergalactic dance party with Reflex Punk, the immersive mixed reality fitness game that pits you against alien invaders while pumping upbeat music fuels your every move.  With each beat, you'll be one step closer to defeating those edgy alien thugs and achieving your fitness goals in style.\n\n\ud83e\ude93\ud83d\udd2a Dodge axes, knives, and other perilous obstacles as you immerse yourself in a heart-pounding adventure that will push your limits and leave you craving more.", "short_description": "\ud83d\udcaa Experience the adrenaline rush of Reflex Punk, the groundbreaking mixed reality fitness game designed to supercharge your reaction time while delivering an exhilarating cardio workout. Dodge axes, knives, and other perilous obstacles as you immerse yourself in a heart-pounding adventure that will push your limits and leave you craving more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/reflexpunkprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Scrimage Entertainment", "support_website_url": null, "website_url": "https://liftedline.tumblr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8010825192286313"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75303839_1019333676414537_5842002930897592845_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tBn4lmPz-yIQ7kNvgF4TTVR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrS1cPbilHMnYQsTg19gdfciTsksgc7SZtHwpJi-xmiA&oe=67177A06"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Reflex Punk", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 1655708400, "lastRevision": {"nodes": [{"id": "4990662797635916", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "e