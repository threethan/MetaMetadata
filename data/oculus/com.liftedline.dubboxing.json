5/75422369_739945504890259_164561280887661888_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sOInwrG1SRwQ7kNvgF_NykN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDOvlHaP2jHN-Yv4qOqCzdJV06suxIDBaZHfy_4XLSY3A&oe=677BC28B"}, {"file_name": "Champion Reflex 512x512.png", "id": "493141753345969", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57566688_493141756679302_4202526529522013258_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aI29WhPHPfUQ7kNvgF-cmaQ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBOpdJB3draMdZydBmVm6sulCtoRDQIfdbExHnrDfFHxw&oe=677BBB24"}]}, "id": "3715279255395248", "locale": "en_US", "screenshots": [{"file_name": "Mad Reflex Game Play Still 2.png", "id": "489249273328351", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974868_489249276661684_3624221581078752238_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_0qk8kWBJwQQ7kNvgGHYyVf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDi3mIE4COkabNbu_MjCC6gy-pS33ckkEdeUgLDyBj3-g&oe=677BD455"}, {"file_name": "Mad Reflex Mixed Reality Still 1.png", "id": "406499402217736", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974512_406499405551069_5110302358913969244_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GKxPNvurYtIQ7kNvgE90i5d&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDwTHhS6dzOAlWzLANkyePTK3Y53A_r_Qo0odopvw7RFA&oe=677BC78E"}, {"file_name": "Mad Reflex Mixed Reality Still 3.png", "id": "734756302070853", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974924_734756305404186_6923290934958339527_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LVbZsNhooDAQ7kNvgFgtG-_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCGu3-5OP8A7_iT011gIyBWAcczounXZDRYXK0laJb0Eg&oe=677BAA94"}, {"file_name": "Champion Reflex Still 1.png", "id": "1181292146413634", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035471_1181292149746967_5217355252292440293_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I6EswkWmoeoQ7kNvgHuJN4s&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDSJtoCi24NdNo80rpfWKrA8DyPUCUeplwAHk47m1zQDA&oe=677BDCBD"}, {"file_name": "Mad Reflex Game Play Still 3.png", "id": "533471049017236", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974869_533471052350569_4760719742838017701_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XPzWw--DWcwQ7kNvgG2Tq4A&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDBghnLxsZRYM5-bD16a3J6i4y3-r9OVjNc8qNtS2gzXQ&oe=677BC2D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Champion Reflex_2560x1440.png", "id": "1184244736025036", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57569458_1184244739358369_111066120156910815_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UKAAH59189sQ7kNvgHsVny8&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDSTCWEhuczMOVFEfY6s3ZTZ5AvJXLuGAMRf7LuX_LH4Q&oe=677BC05C"}, "display_name": "Reflex Punk", "keywords": [], "long_description": "\ud83d\udcaa With every dodge and weave, you'll feel your reflexes sharpening while you work up a sweat and burn calories. Track your progress, challenge friends, and dominate the leaderboards as you become the ultimate reflex champion.\n\n\ud83d\udcca With real-time stat tracking and competitive leaderboards, Reflex Punk keeps you motivated to push yourself further and achieve new fitness heights.\n\n\ud83c\udfa7 Turn your workout into an intergalactic dance party with Reflex Punk, the immersive mixed reality fitness game that pits you against alien invaders while pumping upbeat music fuels your every move.  With each beat, you'll be one step closer to defeating those edgy alien thugs and achieving your fitness goals in style.\n\n\ud83e\ude93\ud83d\udd2a Dodge axes, knives, and other perilous obstacles as you immerse yourself in a heart-pounding adventure that will push your limits and leave you craving more.", "short_description": "\ud83d\udcaa Experience the adrenaline rush of Reflex Punk, the groundbreaking mixed reality fitness game designed to supercharge your reaction time while delivering an exhilarating cardio workout. Dodge axes, knives, and other perilous obstacles as you immerse yourself in a heart-pounding adventure that will push your limits and leave you craving more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/reflexpunkprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Scrimage Entertainment", "support_website_url": null, "website_url": "https://liftedline.tumblr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8010825192286313"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75303839_1019333676414537_5842002930897592845_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7esMnOF5ANQQ7kNvgExIrlb&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDN3iEtWfDv2b55iOcHhSyGGHBy7kg9Mig2v-tqPwJjMg&oe=677BAC06"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Reflex Punk", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Sports", "id": "2776542286000603"}]