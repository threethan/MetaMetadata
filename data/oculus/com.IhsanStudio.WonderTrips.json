FD2BD"}, {"file_name": "4.png", "id": "5505988382863459", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210394_5505988386196792_2330338574410148562_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Odyfe2S5MP4Q7kNvgEHlpax&_nc_ht=scontent.oculuscdn.com&oh=00_AYDlNaBtkttCsFsODK2NSAW2vhPms3pTVPDR6vtHH1g8Ag&oe=66FFE369"}, {"file_name": "5.png", "id": "716903313279619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569471_716903316612952_3235773416454700452_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n0usFNp0RykQ7kNvgH1EzgD&_nc_ht=scontent.oculuscdn.com&oh=00_AYAr_1pxFcdHN9GjdtuEPGTE_S5HVTfS3e9DaczOkZvYyw&oe=66FFE23E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape3.png", "id": "1127878951263047", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_1127878954596380_6514816579245165761_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ueaateka6BcQ7kNvgHWitfj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCuq9_VksfwSFB5WHQ70PhkXtAoxgNaM8wV1kzCjReTIg&oe=66FFCD7A"}, "display_name": "Wonder Trips", "keywords": [], "long_description": "It's time to discover different wonderlands and enjoy your own trips.\nHave Lot Of Fun by riding, racing, para-sailing and more..\n\nWonder Trips is designed to take you into different lands to enjoy many trips and activities.\n\nYou start by a beautiful landscape view around the island; Then you get your free time to discover different monuments and parts of environment; You are lucky to participate in the racing and to be the winner.\n\nBy the end, get fun time over a para-sailing and enjoy the wonderful sunset view.\n\nNew trips are coming soon..", "short_description": "It's time to discover different wonderlands and enjoy your own trips.\nHave Lot Of Fun by riding, racing, para-sailing and more.."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wonder.sayoo.org/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "SAYOO VR Studio", "support_websit