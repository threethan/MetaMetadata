=scontent-xsp1-1.oculuscdn.com&oh=00_AYDrl6kOKVDe8NzYYZPuIwJQ4bAP3QTTeJc_dd8fLZRvMg&oe=671A4710"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ml486RWqK9QQ7kNvgGvpDmG&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYC0t7zMQmeTAeY8ic1wMAaRQqmORF7ZiX8_7HbVI9vAYg&oe=671A49D9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape_horiz_white_center_(9cw).png", "id": "2797780667125725", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031434_2797780670459058_121874044104596879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GsvCsyoQ1lgQ7kNvgGUf8qm&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAnSGUPhERT598uyxgMEOGGTjCgejE27qvhCHvpgEbIlw&oe=671A2053"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "relax"], "long_description": "**A portal to new worlds, filled with endless experiences to discover and explore. A place to connect with loved ones. Travel the world, play games, and upload videos to watch together.**\n\n- Invite your friends and family, and travel together to new places to see the world - hundreds of virtual travels to all continents: take a city tour, a hot air balloon ride, or a back-country road trip.\n\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean.\n\n- Relax and practice meditation in nature - guided, or unguided.\n\n- Listen to classical music.\n\n- Play games, share photos, upload and watch your own videos - standard, and 360, and step into them together.\n\nAlcove has something for everyone, no matter your age.", "short_description": "A portal to new worlds, a virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. World travel, casual games, media customization, adventure, and relaxation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.rendever.com/alcove/privacy-policy", "developer_terms_of_service_url": "https://www.rendever.com/terms-of-use", "publisher_name": "Rendever", "support_website_url": null, "website_url": "https://www.rendever.com/alcove", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1067126693731825"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "9450039098343757"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031311_2737585126509067_4665006917807068139_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mQ92XeKVhO4Q7kNvgEh7A_u&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCNg6gIee2es19D1K3karPyC5L7kKh61fu8LmdK3MPKJA&oe=671A4E9D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Alcove", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Relaxation & Meditation", "id": "1067126693731825"}, {"topic_name": "Travel & Exploration", "id": "726368587961803"}], "release_date": 1597942793, "lastRevision": {"nodes": [{"id": "2715016805401498", "release_type": "MANA