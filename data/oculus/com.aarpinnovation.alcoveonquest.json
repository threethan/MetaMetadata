=scontent-lhr6-1.oculuscdn.com&oh=00_AYBlf_rXLFBMBaLrIMx1Jlir0VZDkyMGMbqpU_viepiLog&oe=67125E10"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xd53CLNdYNgQ7kNvgGjaWl5&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAz73A0ts4uHMnROOnGJjS3VXaSW8zUs3eW8ji9uWBLEQ&oe=671260D9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape_horiz_white_center_(9cw).png", "id": "2797780667125725", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39031434_2797780670459058_121874044104596879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oI7ZtrXlPhIQ7kNvgEs85-w&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYB1NsMjTl80Mc0F9avLPuM2LMS-3jKScdzTwY7uNZSWdQ&oe=67123753"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "relax"], "long_description": "**A portal to new worlds, filled with endless experiences to discover and explore. A place to connect with loved ones. Travel the world, play games, and upload videos to watch together.**\n\n- Invite your friends and family, and travel together to new places to see the world - hundreds of virtual travels to all continents: take a city tour, a hot air balloon ride, or a back-country road trip.\n\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean.\n\n- Relax and practice meditation in nature - guided, or unguided.\n\n- Listen to classical music.\n\n- Play games, share photos, upload and watch your own videos - standard, and 360, and step into them together.\n\nAlcove has something for everyone, no matter your age.", "short_description": "A portal to new worlds, a virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. World travel, casual games, media customization, adventure, and relaxation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.rendever.com/alcove/privacy-policy", "developer_terms_of_service_url": "https://www.rendever.com/terms-of-use", "publisher_name": "Rendever", "support_website_url": null, "website_url": "https://www.rendever.com/alcove", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1067126693731825"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "9450039098343757"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39031311_2737585126509067_4665006917807068139_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p5_exf8-G5AQ7kNvgFNgUs_&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAXDvvh6trsoykwlh2ishLzKLpH82Spm-CzkFtrg5T-OA&oe=6712659D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Alcove", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Relaxation & Meditation", "id": "1067126693731825"}, {"topic_name": "Travel & Exploration", "id": "726368587961803"}], "release_date": 1597942793, "lastRevision": {"nodes": [{"id": "2715016805401498", "release_type": "MANA