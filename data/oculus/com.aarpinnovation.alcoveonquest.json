AFgzZR1X57Ce3bgg2Ekn1rl&oh=00_AYCvxlk2rgWribyY8m50xOH2C1473O9ssqpfdyrzeraiUQ&oe=66D6E717"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "entertainment"], "long_description": "A virtual home filled with endless experiences to discover and explore, a place to connect with loved ones. Casual games, world travel, media customization, relaxation, and adventure.\n\n- Invite your friends and family, and play games, share photos, upload and watch your own videos - standard, and 360, and step into them together\n- Travel to new places together and see the world: take a city tour, a hot air balloon ride, or a back-country road trip\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean\n- Relax on a beach practicing guided meditation\n- Listen to classical music\n- Play with your virtual pet\n- Change your perspective from ocean to green meadow, to snowy mountains\n\nAlcove has something for everyone, no matter your age. Download Alcove and start exploring today!\n\nNote: Alcove will keep growing with new immersive experiences and features. Please leave us a note to let us know what you\u2019d love to see next.", "short_description": "A virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. Casual games, world travel, media customization, relaxation, and adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aarp.org/about-aarp/privacy-policy/", "developer_terms_of_service_url": "https://www.aarp.org/about-aarp/terms-of-service/", "publisher_name": "AARP Innovation Labs", "support_website_url": null, "website_url": "https://alcovevr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": false