g?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a9oqFGnPVNUQ7kNvgEuvq-J&_nc_ht=scontent.oculuscdn.com&oh=00_AYBW1dRCknRwhpHwGzxgWRcrBgEaGhvQ8A67bh9ocxHylA&oe=66DEC454"}, {"file_name": "Wellness room from couch.png", "id": "301326734251548", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031531_301326737584881_2599110596488797645_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JQinpBc8fiUQ7kNvgGct_Us&_nc_ht=scontent.oculuscdn.com&oh=00_AYClB9j2DdNwgH55qBlJzQ9zJyx3FTPwecou51KVcP-x8Q&oe=66DED7A9"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YtLc2IAqlKsQ7kNvgFBGspr&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8kOfgiWit__tcNpQtkHYb9Savh1LoKjkxfB5l2zSqOA&oe=66DEF659"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_Final_cw27_5.png", "id": "719973655505875", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75549080_719973658839208_9047536876870375886_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oRqgr2ueoy0Q7kNvgG7f0JW&_nc_ht=scontent.oculuscdn.com&oh=00_AYCx26EmWWSZJqYZN1L01PKy6cMA6PHC4CpjQdhSlKe5tA&oe=66DED017"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "entertainment"], "long_description": "A virtual home filled with endless experiences to discover and explore, a place to connect with loved ones. Casual games, world travel, media customization, relaxation, and adventure.\n\n- Invite your friends and family, and play games, share photos, upload and watch your own videos - standard, and 360, and step into them together\n- Travel to new places together and see the world: take a city tour, a hot air balloon ride, or a back-country road trip\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean\n- Relax on a beach practicing guided meditation\n- Listen to classical music\n- Play with your virtual pet\n- Change your perspective from ocean to green meadow, to snowy mountains\n\nAlcove has something for everyone, no matter your age. Download Alcove and start exploring today!\n\nNote: Alcove will keep growing with new immersive experiences and features. Please leave us a note to let us know what you\u2019d love to see next.", "short_description": "A virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. Casual games, world travel, media customization, relaxation, and adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aarp.org/about-aarp/privacy-policy/", "developer_terms_of_service_url": "https://www.aarp.org/about-aarp/terms-of-service/", "publisher_name": "AARP Innovation Labs", "support_website_url": null, "website_url": "https://alcovevr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "2803101913326406"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "754019892058176"}]}, "baseline_offer": {"id": "754019892058176"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1597942800, "status": "PUBLISHED", "id": "754019892058176"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8608309689183373", "ve