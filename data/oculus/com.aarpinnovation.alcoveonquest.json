=scontent-fra5-1.oculuscdn.com&oh=00_AYDKt1gqhLdtoe4R2rOFXT0MnjxdOWiphH2pLl7CXqhnNA&oe=670BC690"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k18yBuYJ8soQ7kNvgHcc735&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBLvd6jJItj8hgRsnDLH4uaw6BdIcN1S44TVTLF167NVQ&oe=670BC959"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape_horiz_white_center_(9cw).png", "id": "2797780667125725", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031434_2797780670459058_121874044104596879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=563Up7XPzDoQ7kNvgFS8YMI&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDOVQCpq_I-M9r4RQrOaXOvzB1p19x_OYieICBPKWAFRQ&oe=670B9FD3"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "relax"], "long_description": "**A portal to new worlds, filled with endless experiences to discover and explore. A place to connect with loved ones. Travel the world, play games, and upload videos to watch together.**\n\n- Invite your friends and family, and travel together to new places to see the world - hundreds of virtual travels to all continents: take a city tour, a hot air balloon ride, or a back-country road trip.\n\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean.\n\n- Relax and practice meditation in nature - guided, or unguided.\n\n- Listen to classical music.\n\n- Play games, share photos, upload and watch your own videos - standard, and 360, and step into them together.\n\nAlcove has something for everyone, no matter your age.", "short_description": "A portal to new worlds, a virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. World travel, casual games, media customization, advent