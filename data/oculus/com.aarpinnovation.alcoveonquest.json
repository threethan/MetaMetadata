9489879020_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fyQ7QfN6s4wQ7kNvgF9hxe9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZ1bULR6s895ZPA0G7oZgWXhd4qRYt_zi-81k0B8Su5A&oe=675AE090"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VndmuPSGc8kQ7kNvgExN09T&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyjf_03V1WGPmOm9kFYEjXFknTRloO04Dc-0E_kBlQRA&oe=675AE359"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape_horiz_white_center_(9cw).png", "id": "2797780667125725", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031434_2797780670459058_121874044104596879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=axPO1-25WiYQ7kNvgHVIO7f&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBeTF2Co8K2NI0fzk7x67rl94X9Vq9ho54DA2ggNsHBg&oe=675AB9D3"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "relax"], "long_description": "**A portal to new worlds, filled with endless experiences to discover and explore. A place to connect with loved ones. Travel the world, play games, and upload videos to watch together.**\n\n- Invite your friends and family, and travel together to new places to see the world - hundreds of virtual travels to all continents: take a city tour, a hot air balloon ride, or a back-country road trip.\n\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean.\n\n- Relax and practice meditation in nature - guided, or unguided.\n\n- Listen to classical music.\n\n- Play games, share photos, upload and watch your own videos - standard, and 360, and step into them together.\n\nAlcove has something for everyone, no matter your age.", "short_description": "A portal to new worlds, a virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. World travel, casual games, media customization, adventure, and relaxation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.rendever.com/alcove/privacy-policy", "developer_terms_of_service_url": "https://www.rendever.com/terms-of-use", "publisher_name": "Rendever", "support_website_url": null, "website_url": "https://www.rendever.com/alcove", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "9450039098343757"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_2737585126509067_4665006917807068139_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=juMvzdMhxZ4Q7kNvgEIZ4fG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4tz1R0Sp6ViUoiC2LCqf153ke3AYZUGumknoF_8LKTQ&oe=675AE81D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Alcove", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Hangout", "id": "1023770785722696"}], "release_date": 1597942793, "lastRevision": {"nodes": [{"id": "2715016805401498", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata":