9489879020_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=StMz8XKoPkQQ7kNvgEDhrmX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBiDjNXR52prUJXaZ4d5QQJrxOWLNFFZMykSk4h3dqGTw&oe=676D5590"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C7BL6tKBDNwQ7kNvgFGnPKf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHYkL-mcM_8QKD0-AkCxgAIp0t9wdLod8uOmPmWmQ-2g&oe=676D5859"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape_horiz_white_center_(9cw).png", "id": "2797780667125725", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031434_2797780670459058_121874044104596879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RHnWnQWTSbsQ7kNvgGCgghk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYaTaF0ENSV8M7zoP4fVB6L715vDUl2U8maL4HvXSvkg&oe=676D2ED3"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "relax"], "long_description": "**A portal to new worlds, filled with endless experiences to discover and explore. A place to connect with loved ones. Travel the world, play games, and upload videos to watch together.**\n\n- Invite your friends and family, and travel together to new places to see the world - hundreds of virtual travels to all continents: take a city tour, a hot air balloon ride, or a back-country road trip.\n\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean.\n\n- Relax and practice meditation in nature - guided, or unguided.\n\n- Listen to classical music.\n\n- Play games, share photos, upload and watch your own videos - standard, and 360, and step into them together.\n\nAlcove has something for everyone, no matter your age.", "short_description": "A portal to new worlds, a virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. World travel, casual games, media customization, adventure, and relaxation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.rendever.com/alcove/privacy-policy", "developer_terms_of_service_url": "https://www.rendever.com/terms-of-use", "publisher_name": "Rendever", "support_website_url": null, "website_url": "https://www.rendever.com/alcove", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "9450039098343757"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_2737585126509067_4665006917807068139_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VPI_O8j_5YwQ7kNvgGiNF5y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHmHOb9sErnhGAdG-uyJF2ypnrg6fLynt7fDnZmFg0kg&oe=676D5D1D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Alcove", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Hangout", "id": "1023770785722696"}], "release_date": 1597942793, "lastRevision": {"nodes": [{"id": "2715016805401498", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": 