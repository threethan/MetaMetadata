.oculuscdn.com&_nc_gid=AHlbUMNSlhEGAfUrEhN-fFZ&oh=00_AYAIz5KwyM3B2X3f9YcrWw6wdJMx4wZbrijG9sesa7SNYg&oe=66EE95F6"}, {"file_name": "Environment avatars.png", "id": "1658160937667401", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223480_1658160941000734_8331008520363636101_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=Vy2yJGw6wtgQ7kNvgEKvSH3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHlbUMNSlhEGAfUrEhN-fFZ&oh=00_AYDZBx3LM4AdnV9aj5OXZjucN0DV3TxrHIAr9wPAaXD9hA&oe=66EE9AD9"}, {"file_name": "Travel Menu.png", "id": "214539386452376", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982623_214539389785709_191688213184903089_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=04IV6x66iT8Q7kNvgEn-6O7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHlbUMNSlhEGAfUrEhN-fFZ&oh=00_AYBBBQS-oh-n8IEjgpmdAjaCHFNwGNdmB-4WH0oEMaPCyQ&oe=66EE9654"}, {"file_name": "Wellness room from couch.png", "id": "301326734251548", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031531_301326737584881_2599110596488797645_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0yvXm_P9dykQ7kNvgE3IF1s&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHlbUMNSlhEGAfUrEhN-fFZ&oh=00_AYDoqJoqpV76TdED9f6T41iezrj1ouKM0CVzEUdZaLbvOg&oe=66EEA9A9"}, {"file_name": "Waving avatars.png", "id": "1170182813315251", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031649_1170182816648584_7761015419150064044_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KyFzzN0bHVkQ7kNvgFLY4pj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHlbUMNSlhEGAfUrEhN-fFZ&oh=00_AYB22cHMtoXHjfCm1QSQCbil3HMGNHzPgKKxcNHFV7SmHw&oe=66EE9019"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_Final_cw27_5.png", "id": "719973655505875", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75549080_719973658839208_9047536876870375886_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w4t2XgWA1agQ7kNvgHDA8mj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHlbUMNSlhEGAfUrEhN-fFZ&oh=00_AYAg9VHuy6TE3WATOBwnD6X56EmqvUyoQQ-OtAR3BAVyKA&oe=66EEA217"}, "display_name": "Alcove", "keywords": ["family", "travel", "health", "social", "entertainment"], "long_description": "A virtual home filled with endless experiences to discover and explore, a place to connect with loved ones. Casual games, world travel, media customization, relaxation, and adventure.\n\n- Invite your friends and family, and play games, share photos, upload and watch your own videos - standard, and 360, and step into them together\n- Travel to new places together and see the world: take a city tour, a hot air balloon ride, or a back-country road trip\n- Explore the depth of the ocean - go diving in the Great Barrier Reef of Australia, or swim with dolphins in the Pacific Ocean\n- Relax on a beach practicing guided meditation\n- Listen to classical music\n- Play with your virtual pet\n- Change your perspective from ocean to green meadow, to snowy mountains\n\nAlcove has something for everyone, no matter your age. Download Alcove and start exploring today!\n\nNote: Alcove will keep growing with new immersive experiences and features. Please leave us a note to let us know what you\u2019d love to see next.", "short_description": "A virtual home filled with endless experiences to discover and explore, a place to connect with friends and family. Casual games, world travel, media customization, relaxation, and adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aarp.org/about-aarp/privacy-policy/", "developer_terms_of_service_url": "https://www.aarp.org/about-aarp/terms-of-service/", "publisher_name": "AARP Innovation Labs", "support_website_url": null, "website_url": "https://alcovevr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "SOCIAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "2803101913326406"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "754019892058176"}]}, "baseline_offer": {"id": "754019892058176"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1597942800, "status": "PUBLISHED", "id": "754019892058176"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8608309689183373", "version": "1.300"}, "id": "255696595502083", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3895528293794893", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8608309689183373"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "255696595502083"}]}, "change_log": "Alcove 1.3\n- Added support for Quest 3, Quest Pro. Improved support for Quest 2.\n     - Sunsetting Quest 1 support. Quest 1 users will not receive this update.\n- Fixed several bugs related to controller and hand tracking.\n\n- Dozens of bug fixes and quality of life improvements.\n- Performance improvements.\n- Enabled reporting system.\n- Fixed cloud backup.\n- Fixed downloads not sticking around after restarting.\n\n- Enhanced visuals\n     - Increased resolution.\n     - Improved avatar visuals and support.\n     - Higher quality lighting and reflections.\n     - Refreshed default photo library.\n     - Improved UI visuals.\n     - New sounds too!\n\n- Staying Sharp DLC\n    - Added environment control options.\n          - Available in both paid and free games.\n\nThanks for visiting Alcove!\n\nPlease reach out to alex@rendever.com if you encounter any issues or have feedback.", "created_date": 1713565989, "id": "8608309689183373", "version": "1.300", "version_code": 1300, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3895528293794893", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8608309689183373"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1713478207, "id": "8603581222989553", "version": "1.260", "version_code": 1260, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3895528293794893", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8608309689183373"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1713397642, "id": "8599334916747517", "version": "1.250", "version_code": 1250, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3895528293794893", "is_concept": false, "latest_relea