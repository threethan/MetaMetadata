ernen: Medreality wurde bereits von Hunderten \u00c4rzten und Patienten genutzt. Die gewonnene Erkenntnisse lassen wir laufend in die App-Updates reinfliessen."}]}, "developer_name": null, "developer_privacy_policy_url": "https://more.doccheck.com/de/privacy", "developer_terms_of_service_url": null, "publisher_name": "DocCheck Agency", "support_website_url": null, "website_url": "http://medreality.de/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6400187193439017"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429292_1064532041283081_6028387581635733298_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jNr5h5xMOD4Q7kNvgHO79V_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azw1vw536ve7AKyLA5b1X0q&oh=00_AYB_HeFAKrbPxFQR8JWRa-3-LCyYfN8ZFO6LUuvbt9u1sQ&oe=66E8173A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "medreality", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Health & Fitness", "id": "619566195371476"}], "release_date": 1725604800, "lastRevision": {"nodes": [{"id": "5468677529923326", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "54686774832