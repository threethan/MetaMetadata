59_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9XWG8vaeNRcQ7kNvgHj1q2L&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkE0hRDwvqkKAV_DS_JZvomxM1XtQXARSuonfsRJ3-PQ&oe=67091235"}, {"file_name": "s1.png", "id": "208488483823190", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254870_208488487156523_2867768724179347469_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-Eb-hnbR6YQ7kNvgFyeOq9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-SxxGXMwS32Vb11cB1YNE4bPpRPNvq1yFDMgAtuRyYg&oe=67090B2A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "295952395023418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363514_295952398356751_706295565983272088_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b9NzoPKXHtUQ7kNvgFLxLEx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJnZtuky0R5YBrA0wx7fElhTvR2M7NJesR7eXvRnvaWg&oe=67091F35"}, "display_name": "Being Centered", "keywords": ["meditation", "meditate", "exercise", "calm", "mindful"], "long_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra.", "short_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra."}]}, "developer_name": "Kevin Wacknov", "developer_p