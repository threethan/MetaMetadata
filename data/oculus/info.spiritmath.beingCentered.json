59_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4GdOq37RXPcQ7kNvgEP7-0i&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUtJ-__XvJ6Lgbj2QIcg5ajpYK47kJX6xhBTU8LfZzWQ&oe=6703CC35"}, {"file_name": "s1.png", "id": "208488483823190", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254870_208488487156523_2867768724179347469_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g47-EASPyyAQ7kNvgHEuRGl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZb818C1oPDiT1j2IWEYs5PhpYgtzlwj9UtkclLCLTFQ&oe=6703C52A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "295952395023418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363514_295952398356751_706295565983272088_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EvCjrIEXju4Q7kNvgFol3Wz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsZQ4KK9hL0Ru8C5LxAw-he4IGQ8rBW3_lb75WlWlbhw&oe=6703D935"}, "display_name": "Being Centered", "keywords": ["meditation", "meditate", "exercise", "calm", "mindful"], "long_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra.", "short_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra."}]}, "developer_name": "Kevin Wacknov", "developer_p