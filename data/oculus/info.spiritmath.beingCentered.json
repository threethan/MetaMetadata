59_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x-Ulr12GWLEQ7kNvgGQkgXo&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDu4B7fqFbs4AYFAMdBAEOO7kQoHnALB9_gqm3Yz4cEjQ&oe=67139E35"}, {"file_name": "s1.png", "id": "208488483823190", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75254870_208488487156523_2867768724179347469_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7CQMrexeYRwQ7kNvgEYtVNP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcKQSABNNJ1EGbOTQy1HWku_4sQ06knQGpS_YKq0f_ig&oe=6713972A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "295952395023418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363514_295952398356751_706295565983272088_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nYWY7YVb4_oQ7kNvgELEorP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJBzGOihpmyTlbNm04lIj_I7vHu0ziXknZloxtgOzrZg&oe=6713AB35"}, "display_name": "Being Centered", "keywords": ["meditation", "meditate", "exercise", "calm", "mindful"], "long_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra.", "short_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra."}]}, "developer_name": "Kevin Wacknov", "developer_p