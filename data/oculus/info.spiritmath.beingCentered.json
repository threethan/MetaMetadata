59_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9XWG8vaeNRcQ7kNvgGJmnIh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCWmt3rVlYRXGsQuBtrQNaopYIQNrk0U9OYrVoq6chLjQ&oe=670A63B5"}, {"file_name": "s1.png", "id": "208488483823190", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254870_208488487156523_2867768724179347469_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-Eb-hnbR6YQ7kNvgHqUM4V&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZRW11UnkKrN2nXx5mm50wfu0TwN3dr1V7FZtsmGwmDw&oe=670A5CAA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "295952395023418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363514_295952398356751_706295565983272088_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ORYwgWUvNusQ7kNvgFfyRNs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAS-qtLJNu03LAo3MXGdblH9PA5kSfCH-vkVfyZ7QYAvA&oe=670A70B5"}, "display_name": "Being Centered", "keywords": ["meditation", "meditate", "exercise", "calm", "mindful"], "long_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra.", "short_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra."}]}, "developer_name": "Kevin Wacknov", "developer_p