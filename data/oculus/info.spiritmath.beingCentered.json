 chakra buttons on the right balance and align an individual chakra."}]}, "developer_name": "Kevin Wacknov", "developer_privacy_policy_url": "http://mindbodyawaregames.com/", "developer_terms_of_service_url": "http://mindbodyawaregames.com/", "publisher_name": "Mind Body Aware Games LLC", "support_website_url": "http://mindbodyawaregames.com/", "website_url": "http://mindbodyawaregames.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "365240155038782"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/75348042_761694364596737_8175718333276022367_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GE316-IUBwYQ7kNvgE9oZyn&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCElwRx9cjzQFt7v8CpDTBUfBscC3n5VklV5uMtmlrH2A&oe=677E73B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Being Centered", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1585846765, "lastRevision": {"nodes": [{"id": "142350493929962", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3582676451774250", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "615533445666878"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"