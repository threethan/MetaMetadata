59_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AnQArQMLvJUQ7kNvgGHk3It&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxVxYRP3bKsDOkbhvhs_gAn15rrYixHTXj23r8I12GMA&oe=6720CD35"}, {"file_name": "s1.png", "id": "208488483823190", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254870_208488487156523_2867768724179347469_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZZtk_FXbWV4Q7kNvgHzfYWd&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSEc-YUYmgK02l8PVlu-nUn84f6M6Z5P2gmuE4EJJ-JA&oe=6720C62A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "295952395023418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363514_295952398356751_706295565983272088_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WyGXe-k48-0Q7kNvgHn_mmy&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2rBsycQ-ztncpPzbi8OiUxBcWoGro78Wxs1yt6Y5DFQ&oe=6720DA35"}, "display_name": "Being Centered", "keywords": ["meditation", "meditate", "exercise", "calm", "mindful"], "long_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra.", "short_description": "Quick Calm lowers your energy from your crown to your tailbone.\n\nQuick Energy raises your energy from your tailbone to your crown and includes movement exercises.\n\nPrinciples are a text description of methods and ideas.\n\nChakra Sparkle actives one random chakra at a time.\n\nthe Grand Tour moves energy from tailbone to crown and has mind movement vectors.\n\nThe numbered chakra buttons on the right balance and align an individual chakra."}]}, "developer_name": "Kevin Wacknov", "developer_p