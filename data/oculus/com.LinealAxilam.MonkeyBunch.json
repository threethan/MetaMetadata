uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982685_486824710200148_3829803151650817435_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UjWVW7dAOOoQ7kNvgHf9G0o&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCS_PG6XWVLxtR5jUjwcByluXeF0ddb2f0ydj_C0ti8Sg&oe=6784E946"}, {"file_name": "Cosmetics.png", "id": "701400291538864", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75314851_701400294872197_2388943030080511339_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PfS1Lre6FCgQ7kNvgHIEyKp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBmxFc9ZwKQaYNCJ8APNEJH98LZGlPFPCEotKr3vHRlqg&oe=6785103A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wwew.png", "id": "1226636741268985", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75441579_1226636744602318_4011593143321173634_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UJg5YtWkeusQ7kNvgGbImY5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9Riz97R2j-AF_QuJg_bDW8ykNL3bmfv8jgRFTCahg4A&oe=67851815"}, "display_name": "Monkey Bunch", "keywords": [], "long_description": "Reject Humanity.\n\nRun, climb, and jump in VR using a unique locomotion method that only needs the movement of your hands and arms. No buttons, no sticks, no teleportation. Push off of surfaces to jump and squeeze them with both hands to climb.\n\nThere are many different game modes - From an fun paintball battle or horror mode, with up to 10 of your friends.\n\nRun from the other monkey, or outmaneuver the survivors to catch them. Parkour up trees and cliff faces to evade and chase monke down. Hang out in a virtual jungle with randos or group up in a private room with friends to hang out and play. The stakes are low, so feel free to just chat or make up your own games. The movement is easy to learn, and hard to master. Crossplay with the PC versions of the game, so play with anyone on any platform.\n\nThere are many different levels to explore.  Each with their own topography that form routes and obstacles to play on.\n\nVisit our store in the City, with a rotating inventory of items to buy, play with, and wear to express your true monke fashion in a unique way.\n\nBecome Monkey.", "short_description": "Run, climb, and jump in VR using a unique locomotion method that only needs the movement of your hands and arms. No buttons, no sticks, no teleportation. Push off of surfaces to jump and squeeze them with both hands to climb."}]}, "developer_name": "Lineal Axilam", "developer_privacy_policy_url": "https://docs.google.com/document/d/1PcoZDQdW9b6YKIMEh9swCtxbVRoL8ZuGsybqAtMbuks/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Noxide", "support_website_url": null, "website_url": "https://monkeybunch.weebly.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "931814968227733"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "784700303544991"}]}, "baseline_offer": {"id": "784700303544991"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723603355, "status": "PUBLISHED", "id": "784700303544991"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8899169633522032", "version": "2.0.2"}, "id": "684746146521390", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"