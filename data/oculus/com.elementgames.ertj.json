_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvgQDhx_rrJ7zNr7AiNgiOkZaUUkajNENmsBUNFbFk_w&oe=676A9D2F"}, {"file_name": "migrated_image.png", "id": "214047490007826", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12448944_190112531601635_1798384295249707008_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K_ql-LMpqhcQ7kNvgFkwf8Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbROG2FK0rpeGRnpqC0TOBubCKHFMeWQAi2aBxIHvd-w&oe=676AA1B6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Assets - Trailer Cover.png", "id": "675527765927486", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12504730_675527769260819_4026364155886829568_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a0czEQ5nxK8Q7kNvgEv2mnF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAb5xY_qRrG-jL7W4MTFa9BLMiuRQAjbfUMYeg0VCFbbw&oe=676A8870"}, "display_name": "Evil Robot Traffic Jam", "keywords": ["games", "strategy", "tower", "defense", "best"], "long_description": "You know how you'll be driving around, minding your own business, then suddenly hit bad traffic with no obvious reason why? The answer is simple: Evil Robots! They love to create traffic jams all over the world.\n\nPlay as an agent of the Evil Robot Defense Force: place powerful defense towers, activate destructive special abilities, and disrupt the robots with hacker drones. \n\nFeel like you are in the middle of a miniature battlefield!\n\nFeatures:\n\nNEW Game Mode: Cash Grab!\nMotion Controller support added!\nLeaderboard support added!\nWide variety of different enemies!\nEpic Boss battles!\nPowerful range of Defense Towers!\nMarvelous Maps!\nStunning 3D graphics!\nStrategize and Conquer!\nIntense HAVOC right in front of your eyes!\n\nTry the game and put a stop to the traffic menace before the world reaches Total Gridlock!", "short_description": "Play as an agent of the Evil Robot Defense Force: place powerful defense towers, activate destructive special abilities, and disrupt the robots with hacker drones. \n\nFeatures:\n\nNEW Game Mode: Cash Grab!\nMotion Controller support!\nLeaderboard support!\nWide variety of different enemies!\nEpic Boss battles!\nPowerful range of Defense Towers!\nMarvelous Maps!\nStunning 3D graphics!\nIntense HAVOC right in front of your eyes!\n\nPut a stop to this menace before the world reaches Total Gridlock!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.elementgamesonline.com/privacy", "developer_terms_of_service_url": "http://www.elementgamesonline.com/privacy", "publisher_name": "Element Games, LLC", "support_website_url": null, "website_url": "http://www.elementgamesonline.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "CASUAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "202042888770904"}, "review_messages": ["", "Hello,\n\nThanks for your submission.  Please reach out to your Oculus account manage regarding asset updates for GO launch.\n\n"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12139007_958820697616203_21810058677452800_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mVN2CO6M7o8Q7kNvgH6-E0k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDYhFwQLBJk-iBWZzd96xFqYmlnWGlmqGKQuenqVtnPZQ&oe=676AA8AF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Evil Robot Traffic Jam", "platform": "ANDROID", "context_category": null, "context_topics": [], "r