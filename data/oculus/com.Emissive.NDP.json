11-13-06.png", "id": "413964763942709", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031610_413964767276042_6035017567608660679_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u8VYsb6PZucQ7kNvgEOgtLd&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbo-_9EtNAzh8Ljs79Y2fefdRgW1rKoEWW0qPt2YQOKw&oe=66E42561"}, {"file_name": "NotreDameDamaged_Custom..._30.05.2022_11-58-31.png", "id": "562584938916595", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031406_562584945583261_6889953292362461242_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2QrKB8vza0Q7kNvgHVxysc&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsf2tjq3AtMcd3mJuZRRN2Zi_EqtEJF_W_64q_4KzruQ&oe=66E419CE"}, {"file_name": "MedievalExterior_Custom..._30.05.2022_11-10-33.png", "id": "701342564263632", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982454_701342567596965_3861102470685139309_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=alh6CQ-KC5AQ7kNvgFE1Wr6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpkE97JkYyP6mYeuKWbEZ3JZbGTwBvNT2LrmpxNtAsTA&oe=66E433D6"}, {"file_name": "Sketch_Custom..._30.05.2022_11-42-38.png", "id": "749552422847541", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982728_749552426180874_7718024922584410836_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6WJBNy-pakQQ7kNvgGIcDrB&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3EXvdFsSfwI9cs09exHAe0OFGFlKUm8uhJ_2OSAxc_g&oe=66E41DA5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Eternal Notre-Dame", "keywords": [], "long_description": "Orange presents \u201cEternal Notre-Dame\u201d, the first immersive Virtual Reality journey to Notre-Dame de Paris. A new and innovative experience to keep Notre-Dame alive.\n\nRelive the history of the cathedral thanks to virtual reality, discover inaccessible places and enter the History \u2026. Thanks to your headset, you will be able to explore Notre-Dame de Paris through the centuries, completely recreated digitally and thus live a real emotional journey to discover the secrets of the monument, while (re)discovering the historical events and characters who have marked its history.\n\nOrange will donate 30% of the price of this experience to the public institution for the restoration of the cathedral and to the Notre Dame Foundation to finance the program for the interior design of Notre-Dame. By taking part in this adventure, you will become a donor and contribute to the \ufb01nancing of the reconstruction work.", "short_description": "Orange presents \u201cEternal Notre-Dame\u201d, the first immersive Virtual Reality journey to Notre-Dame de Paris. A new and innovative experience to keep Notre-Dame alive.\n\nRelive the history of the cathedral thanks to virtual reality, discover inaccessible places and enter the History \u2026. Thanks to your headset, you will be able to explore Notre-Dame de Paris through the centuries, completely recreated digitally."}, {"images": {"nodes": []}, "id": "484793953557178", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Eternal Notre-Dame", "keywords": [], "long_description": "Orange presenta \u201cEternal Notre-Dame\u201d, la primera expedici\u00f3n inmersiva de realidad virtual a Notre-Dame de Par\u00eds.\n\nRevive la historia de la catedral gracias a la realidad virtual, descubre lugares inaccesibles y ad\u00e9ntrate en la historia\u2026.\n\nGracias a su casco, podr\u00e1 explorar Notre-Dame de Par\u00eds a trav\u00e9s de los siglos, totalmente recreada num\u00e9ricamente y vivir as\u00ed un verdadero viaje emocional al descubrimiento de los secretos del monumento, mientras que (re)descubriendo los acontecimientos y personajes hist\u00f3ricos que han marcado su historia.\n\nOrange dona el 30% del coste de esta experiencia al establecimiento p\u00fablico para los trabajos de restauraci\u00f3n de la catedral ya la Fundaci\u00f3n Notre Dame para la financiaci\u00f3n del programa de interiorismo de Notre-Dame.\n\nAl participar en esta aventura, te conviertes en donante y contribuyes as\u00ed a la financiaci\u00f3n de las obras de reconstrucci\u00f3n.", "short_description": "Orange presenta \u201cEternal Notre-Dame\u201d, la primera expedici\u00f3n inmersiva de realidad virtual a Notre-Dame de Par\u00eds.\n\nRevive la historia de la catedral gracias a la realidad virtual, descubre lugares inaccesibles y ad\u00e9ntrate en la historia\u2026.\n\nGracias a su casco, podr\u00e1 explorar Notre-Dame de Paris a trav\u00e9s de los siglos, totalmente recreada digitalmente."}]}, "developer_name": "Emissive", "developer_privacy_policy_url": "https://eternellenotredame.orange.com/fr/donnees-personnelles/", "developer_terms_of_service_url": "https://eternellenotredame.orange.com/fr/conditions-generales-utilisation/", "publisher_name": "Orange SA", "support_website_url": null, "website_url": "https://eternellenotredame.orange.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "1283811691952063"}, {"id": "879473995923081"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["fr", "es", "en_GB"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "466713285512386"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "595533648999599"}]}, "baseline_offer": {"id": "595533648999599"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1683057180, "status": "PUBLISHED", "id": "595533648999599"}]}, "liveCha