cdn.com/v/t64.5771-25/38982728_749552426180874_7718024922584410836_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6WJBNy-pakQQ7kNvgGIcDrB&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3EXvdFsSfwI9cs09exHAe0OFGFlKUm8uhJ_2OSAxc_g&oe=66E41DA5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NDP_trailer_cover_03_eng.png", "id": "735119098348415", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451775_735119101681748_7084703205320679418_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SsFDSoOb-wwQ7kNvgGhMqCT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgOKPSP45dyf33yqkIXtQsR_wl7D8abZYJqMCbFN4x-g&oe=66E42418"}, "display_name": "Eternal Notre-Dame", "keywords": [], "long_description": "Orange presents \u201cEternal Notre-Dame\u201d, the first immersive Virtual Reality journey to the heart of Notre-Dame de Paris.\n\nRelive the history of the cathedral thanks to virtual reality, discover inaccessible places and enter the History \u2026. \nThanks to your headset, you will be able to explore Notre-Dame de Paris through the centuries, completely recreated digitally and thus live a real emotional journey to discover the secrets of the monument, while (re)discovering the historical events and characters who have marked its history.\n\nOrange will donate 30% of the price of this experience to the public institution for the restoration of the cathedral and to the Notre Dame Foundation to finance the program for the interior design of Notre-Dame. By taking part in this adventure, you will become a donor and contribute to the \ufb01nancing of the reconstruction work.", "short_description": "Orange presents \u201cEternal Notre-Dame\u201d, the first immersive Virtual Reality journey to the heart of Notre-Dame de Paris.\n\nRelive the history of the cathedral thanks to virtual reality, discover inaccessible places and enter the History \u2026. \n\nThanks to your headset, you will be able to explore Notre-Dame de Paris through the centuries, completely recreated digitally.