033040203579986067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dfcuHSvBdhUQ7kNvgEciwZH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBObdkLVqNmfDJM3iY1rdi9xFUvNNvGuCbYry3c9NMDg&oe=672DE0D3"}, {"file_name": "scShot_4.png", "id": "776653917415609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035417_776653920748942_800252803639380126_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EgqigVIBZS8Q7kNvgE4c60Y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBbKQClhbJA6XGsLpUnA9qJVtb0y1AsOzOzjTKbRhT9PQ&oe=672E0D9E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "XRD\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_2560x1440px.png", "id": "1563629980869194", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003281_1563629984202527_7466738310881786331_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-lFQhop9WgAQ7kNvgEci6TF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNKzk21TreVFathCIf5ZnWL3VWB9WQUVl9ofTaHkFbUw&oe=672DF63A"}, "display_name": "XR Designer", "keywords": [], "long_description": "In \"XR Designer\" crafting your unique and stunning room is a breeze.\nBrowse through numerous official 3D models and wallpapers to design your space, or upload your own creations for a personalized touch.\nBorrow them from your friends and get inspired.\n(Uploads can be made through the related service at https://xrsns.com.)\n\nSave, load, and edit your designs at any time to perfect your vision.\nExplore your friends' rooms for ideas and invite them to experience your creations.\n\nUnleash your creativity and design a captivating room that is truly your own in \"XR Designer.\"\n(Detailed operating instructions can be found at https://xrsns.org.)\n\n\n\u25c6List of Functions\u25c6\nSummon models\nChange wallpapers\nSwitching windows\nChange the weather\nChange background music\nSaving a room\nLoad a room\nShare created rooms\nCheck your own data\nVolume control\nSwitch language\n\n\u25c6Controls\u25c6\nMove with the left controller stick.\nRotate with the right controller stick.\nThe upper trigger on the right controller operates the menu panel.\n\n\u25c6How to manipulate the 3D model\u25c6\nPlease do the below with the laser on the 3D model.\n\nMove: Move with the left controller stick.\nZoom in/out: Click the B button on the right controller.\nRotate: Click the A button on the right controller.\nReset rotation: Double-click the A button on the right controller.\nGravity: Click the X button on the left controller.\nDelete: Click the bottom trigger on the right controller.\n\n\u25c6Special thanks\u25c6\nBGM: (C)K.Y. (C)L-side (C)\u52b9\u679c\u97f3\u30e9\u30dc\nModel: (C)3D Shaker\nImage: (C)Pixabay", "short_description": "In \"XR Designer\" crafting your unique and stunning room is a breeze.\nBrowse through numerous official 3D models and wallpapers to design your space, or upload your own creations for a personalized touch.\nBorrow them from your friends and get inspired.\nSave, load, and edit your designs at any time to perfect your vision.\nExplore your friends' rooms for ideas and invite them to experience your creations.\nUnleash your creativity and design a captivating room that is truly your own in \"XR Designer.\""}, {"images": {"nodes": [{"file_name": "xrd\u30ed\u30b4\u80cc\u666f\u9ed2_512px.png", "id": "1663157610879996", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570305_1663157614213329_752428871586704211_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9EY4bNYqSoQ7kNvgFHBgcw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDwhfynE55-NAU9krB1iSEzE1My0_yYwIvoB-wKxo1kXw&oe=672DE536"}, {"file_name": "XRD\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_1080x360px.png", "id": "1590989611650404", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982688_1590989614983737_8848910869138619764_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Jc2XRV9iuAQ7kNvgH_iWY4&_nc_zt=3&_nc_ht=sconten