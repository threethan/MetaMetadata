4.5771-25/43931330_630122249218088_569075068671406171_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U7WQmZuGjtEQ7kNvgE4aR-1&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYChY1QTTpXnRLRtAFcDOikJzp4uqnysvPT3ruQF0n6-zw&oe=671A4985"}, {"file_name": "screenImg3.png", "id": "1225611661459693", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/57566698_1225611664793026_41401079975699600_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mjt22Gd0qEQQ7kNvgGZgQ67&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAQ7I31fgm4tUNzbsbuWKGRBvUys3zve2KmMQCeJGoroQ&oe=671A4D41"}, {"file_name": "screenImg4.png", "id": "1009519053810109", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75195904_1009519057143442_6437635823249675540_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xkcpqrfLmUIQ7kNvgH_0do4&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDNow2f6qMzytd-1LVrkVtLY2-uHj6BiLgJ31xQaoQ3RA&oe=671A1C36"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverArt_2560x1440px.png", "id": "145909078538485", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/86641450_145909081871818_1469081559402083801_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OUqvfSXM_KsQ7kNvgEJNPL6&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBOZ-GRzJxqdQEjLXMcR78SHZEqJ8aBXezJewBWm3YrAA&oe=671A3EB7"}, "display_name": "XR Designer", "keywords": [], "long_description": "XR Designer is a VR game that allows you to design and share rooms.\nYou can visit rooms created by others, or upload your own models and wallpapers for use.\n\n----Functions at a glance ----\nSummon models\nChange the texture of walls, etc.\nVisit other users' rooms\nCheck your own data\nLog in\nSwitch windows\nChange weather\nChange background music\nSave Room\nLoad Room\nVolume control\nChange language\n\n---Controls ----\nMove with the left controller stick.\nRotate with the right controller stick.\nThe upper trigger on the right controller controls the menu panel.\n\n When you open the menu panel of a model and select a model: \n You can summon & hold the model with the upper trigger on the right controller.\n Press A on the right controller to zoom in and out.\n Press B on the right controller to rotate the model.\n Delete a model with the lower trigger of the right controller.\n When you move the model while holding the model, the model will move.\n\n(More detailed explanation can be found at \"https://xrsns.org/\")\n\n---Special thanks---\nBGM: (C) K.Y., (C) L-side, (C) Sound Effect Lab\nModel: (C) MASAYOSHI, (C) Dimensiva, (C) 3D Shaker\nImage: (C) Pixabay", "short_description": "XR Designer is a VR game that allows you to design and share rooms.\nYou can visit rooms created by others, or upload your own models and wallpapers for use."}, {"images": {"nodes": []}, "id": "278878251499070", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "XR Designer", "keywords": [], "long_description": "XR Designer\u3068\u306f\u90e8\u5c4b\u3092\u30c7\u30b6\u30a4\u30f3\u3057\u305f\u308a\u5171\u6709\u3057\u3066\u904a\u3076\u3053\u3068\u306e\u3067\u304d\u308bVR\u306e\u30b2\u30fc\u30e0\u3067\u3059\n\u4ed6\u306e\u4eba\u304c\u4f5c\u3063\u305f\u90e8\u5c4b\u306b\u904a\u3073\u306b\u884c\u304f\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\u81ea\u5206\u304c\u4f5c\u3063\u305f\u30e2\u30c7\u30eb\u3084\u58c1\u7d19\u3092\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u3057\u3066\u4f7f\u7528\u3059\u308b\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\n\n---\u6a5f\u80fd\u4e00\u89a7---\n\u30e2\u30c7\u30eb\u53ec\u559a\n\u58c1\u7b49\u306e\u30c6\u30af\u30b9\u30c1\u30e3\u5f35\u66ff\n\u4ed6\u306e\u30e6\u30fc\u30b6\u30fc\u306e\u90e8\u5c4b\u3078\u904a\u3073\u306b\u884c\u304f\n\u81ea\u5206\u81ea\u8eab\u306e\u30c7\u30fc\u30bf\u78ba\u8a8d\n\u30ed\u30b0\u30a4\u30f3\n\u7a93\u306e\u5207\u66ff\n\u5929\u5019\u306e\u5909\u66f4\nBGM\u306e\u5207\u66ff\n\u90e8\u5c4b\u306e\u30bb\u30fc\u30d6\n\u90e8\u5c4b\u306e\u30ed\u30fc\u30c9\n\