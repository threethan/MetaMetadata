nt-iad3-2.oculuscdn.com/v/t64.5771-25/75485579_1024705569264292_8588475835893501076_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvv_MJNcYc4Q7kNvgGMnK2K&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAI-cy0Aa4pOSdzEVcucWkqSuvwy6dR4AImLpa8wP4ELA&oe=674EEFF1"}, {"file_name": "screen-3.png", "id": "3813784448888886", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75308617_3813784452222219_8861854153164055038_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c7EdNMZV8pQQ7kNvgH8rmyb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpYrR6ZFWx82zIyY6L-I2jyWERJLoeFpldetq-rgfqcg&oe=674EEFDA"}, {"file_name": "screen-4.png", "id": "510210628338938", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031359_510210631672271_3889054620789481961_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-G2c3dqEAxIQ7kNvgHdRwAQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXj8NaqhpTXPfQsN4Hl6gCot0NEeLmk3dMvYhF5mF6CQ&oe=674EF653"}, {"file_name": "screen-5.png", "id": "1241621836834075", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031652_1241621840167408_8711678203036836320_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LmsiDPxU6DcQ7kNvgEe8qX3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnjIsfY3WA_eBqxv8_8lbzevQD_H5rauPh_rPuiSfSqg&oe=674F0B5F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mod3_Title.png", "id": "3693715237561510", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036644_3693715240894843_8945723129178385145_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KfOhq_cc4UMQ7kNvgEMS2fS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA-cbWa56lx0UQDA234_qJPYVAFcuVhJtXUlKIlpWvYOQ&oe=674EEABE"}, "display_name": "Hololab VR - NCSG Inspection Foundation Module 3: Masonry Wood External", "keywords": [], "long_description": "**Hololab NCSG Wood Burning Freestanding Stoves VR Application**\n\nThe Hololab National Chimney Sweep Guild VR application provides users with essential skills to inspect and maintain wood-burning freestanding stoves in compliance with NCSG standards. This course features interactive slide content, desktop-based activities, realistic simulations, and detailed testing. Users are challenged to perform inspections with randomized issues in a virtual residential setting, ensuring all necessary procedures are followed.\n\n**VR Controls and PPE \u2013** Learn how to navigate the virtual environment while getting acquainted with essential personal protective equipment.\n\n**Responsibility & Worksite Hazard Assessment \u2013** Operate in a simulated environment to identify and mitigate hazards commonly encountered during inspections of wood-burning freestanding stoves.\n\n**Familiarization \u2013** Understand different types of wood-burning freestanding stoves and their common features.\n\n**Freestanding Stove Inspection \u2013** Utilize the official NCSG checklist to thoroughly inspect wood-burning freestanding stoves.\n\n**Real-World Simulation \u2013** Complete the inspection by correctly identifying issues with maximum safety awareness and forensic skills.\n\nData reports for review are saved and stored for engagement metrics and simulation performance analysis.\n\nAny off-platform monetization of content accessible in this app conforms to the Oculus Bulk IAP or Subscription Licenses app policy outlined here: https://developer.oculus.com/policy/app-policies", "short_description": "The Hololab National Chimney Sweep Guild Wood Burning Freestanding Stoves VR application provides users with essential skills to inspect and maintain wood-burning freestanding stoves in compliance with NCSG standards. This course features interactive slide content, desktop-based activities, realistic simulations, and detailed testing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ftfvr.com/privacy-app/", "developer_terms_of_service_url": null, "publisher_name": "From the Future", "support_website_url": null, "website_ur