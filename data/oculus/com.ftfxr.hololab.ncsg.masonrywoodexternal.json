_NCSG.png", "id": "509180261615781", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035335_509180264949114_5334493677490926533_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z7yurcrfploQ7kNvgFWJrz5&_nc_ht=scontent.oculuscdn.com&oh=00_AYAL-cNOHn6cNAqMGp20nRYc4C2wmW8Bc-W1YUzkAk48TQ&oe=66DEBFDD"}, {"file_name": "LOGO-1440x1440_NCSG.png", "id": "486628667322255", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269301_486628670655588_965888495349363688_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CBt2bDbVIesQ7kNvgHGtdgs&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAWlB8MSIqvE0Kw_oRUSeDNPh7OamYKlyzHUtv6u7xQg&oe=66DEC935"}, {"file_name": "COVER_LANDSCAPE-2560x1440_NCSG.png", "id": "374144505714449", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75300187_374144509047782_6040389406826937808_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S1w-3bFL2K8Q7kNvgEEk4eG&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJsBtmufQPe1Envw8nubvIpD2QTrB0cHe0Et-OrJpxTA&oe=66DECF4C"}]}, "id": "481709681455141", "locale": "en_US", "screenshots": [{"file_name": "screen-1.png", "id": "2164806320552182", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404385_2164806323885515_1331953796713699307_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HIVmzulPzu4Q7kNvgHb87Ie&_nc_ht=scontent.oculuscdn.com&oh=00_AYDP64li8WoPm3InlLJcc562z6kJ75Y5VdweteRcWrHb0A&oe=66DEC492"}, {"file_name": "screen-2.png", "id": "1024705565930959", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485579_1024705569264292_8588475835893501076_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mHX_C0KgzzMQ7kNvgGff6jL&_nc_ht=scontent.oculuscdn.com&oh=00_AYAmb0RY4SnBAVgkd9v3Z6F_BXVDO_QIMs1ex5MtFdMlpA&oe=66DEE071"}, {"file_name": "screen-3.png", "id": "3813784448888886", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75308617_3813784452222219_8861854153164055038_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rGqGepraKQcQ7kNvgGp9XJQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAv_iLbiAkVbZZHdZZ-SrVE47QwyH-AZEFvejEBzQonrw&oe=66DEE05A"}, {"file_name": "screen-4.png", "id": "510210628338938", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031359_510210631672271_3889054620789481961_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X23NijsvSjUQ7kNvgFGg9HR&_nc_ht=scontent.oculuscdn.com&oh=00_AYCWv_kxvKWcU9lzoEA4flmGSZ2ybxYJHnwykOnQbPfHpA&oe=66DEE6D3"}, {"file_name": "screen-5.png", "id": "1241621836834075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031652_1241621840167408_8711678203036836320_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r7j1hJfDaFwQ7kNvgET2t-H&_nc_ht=scontent.oculuscdn.com&oh=00_AYDTq6xQUiOc7s0-8laTWWXWF2p7lUeuSLBw_oycTu1eTQ&oe=66DEC39F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mod3_Title.png", "id": "3693715237561510", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036644_3693715240894843_8945723129178385145_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zNIOjG_N4awQ7kNvgE3ZR3f&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjwVuwNI1HIUXgvHuDnA6olUjjzwqWt9buLh2cV8duBQ&oe=66DEDB3E"}, "display_name": "Hololab VR - NCSG Inspection Foundation Module 3: Masonry Wood External", "keywords": [], "long_description": "**Hololab NCSG Wood Burning Freestanding Stoves VR Application**\n\nThe Hololab National Chimney Sweep Guild VR application provides users with essential skills to inspect and maintain wood-burning freestanding stoves in compliance with NCSG standards. This course features interactive slide content, desktop-based activities, realistic simulations, and detailed testing. Users are challenged to perform inspections with randomized issues in a virtual residential setting, ensuring all necessary procedures are followed.\n\n**VR Controls and PPE \u2013** Learn how to navigate the virtual environment while getting acquainted with essential personal protective equipment.\n\n**Responsibility & Worksite Hazard Assessment \u2013** Operate in a simulated environment to identify and mitigate hazards commonly encountered during inspections of wood-burning freestanding stoves.\n\n**Familiarization \u2013** Understand different types of wood-burning freestanding stoves and their common features.\n\n**Freestanding Stove Inspection \u2013** Utilize the official NCSG checklist to thoroughly inspect wood-burning freestanding stoves.\n\n**Real-World Simulation \u2013** Complete the inspection by correctly identifying issues with maximum safety awareness and forensic skills.\n\nData reports for review are saved and stored for engagement metrics and simulation performance analysis.\n\nAny off-platform monetization of content accessible in this app conforms to the Oculus Bulk IAP or Subscription Licenses app policy outlined here: https://developer.oculus.com/policy/app-policies", "short_description": "The Hololab National Chimney Sweep Guild Wood Burning Freestanding Stoves VR application provides users with essential skills to inspect and maintain wood-burning freestanding stoves in compliance with NCSG standards. This course features interactive slide content, desktop-based activities, realistic simulations, and detailed testing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ftfvr.com/privacy-app/", "developer_terms_of_service_url": null, "publisher_name": "From the Future", "support_website_url": null, "website_url": "https://www.ftfvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUC