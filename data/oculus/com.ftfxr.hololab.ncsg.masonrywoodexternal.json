1359_510210631672271_3889054620789481961_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iuViaUAUrVEQ7kNvgGYLC2C&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAHWHfzJon1OE-Vmo1OnVDiRtLgUxGlg4xW5U2uQiBb2A&oe=676019D3"}, {"file_name": "screen-5.png", "id": "1241621836834075", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031652_1241621840167408_8711678203036836320_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IcCMSOA7aPIQ7kNvgEd5eBQ&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCK1ovOvQ4QrJfZjoXgjcwS39RVkNZMhDn1EYBpT60rCQ&oe=67602EDF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mod3_Title.png", "id": "3693715237561510", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39036644_3693715240894843_8945723129178385145_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z2Oh-9T_ngEQ7kNvgEWoaem&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDu60HmacpYUSWUtnZW7C725cp5gOcl7ywZkebXFpN6kw&oe=67600E3E"}, "display_name": "Hololab VR - NCSG Inspection Foundation Module 3: Masonry Wood External", "keywords": [], "long_description": "**Hololab NCSG Wood Burning Freestanding Stoves VR Application**\n\nThe Hololab National Chimney Sweep Guild VR application provides users with essential skills to inspect and maintain wood-burning freestanding stoves in compliance with NCSG standards. This course features interactive slide content, desktop-based activities, realistic simulations, and detailed testing. Users are challenged to perform inspections with randomized issues in a virtual residential setting, ensuring all necessary procedures are followed.\n\n**VR Controls and PPE \u2013** Learn how to navigate the virtual environment while getting acquainted with essential personal protective equipment.\n\n**Responsibility & Worksite Hazard Assessment \u2013** Operate in a simulated environment to identify and mitigate hazards commonly encountered during inspections of wood-burning freestanding stoves.\n\n**Familiarization \u2013** Understand different types of wood-burning freestanding stoves and their common features.\n\n**Freestanding Stove Inspection \u2013** Utilize the official NCSG checklist to thoroughly inspect wood-burning freestanding stoves.\n\n**Real-World Simulation \u2013** Complete the inspection by correctly identifying issues with maximum safety awareness and forensic skills.\n\nData reports for review are saved and stored for engagement metrics and simulation performance analysis.\n\nAny off-platform monetization of content accessible in this app conforms to the Oculus Bulk IAP or Subscription Licenses app policy outlined here: https://developer.oculus.com/policy/app-policies", "short_description": "The Hololab National Chimney Sweep Guild Wood Burning Freestanding Stoves VR application provides users with essential skills to inspect and maintain wood-burning freestanding stoves in compliance with NCSG standards. This course features interactive slide content, desktop-based activities, realistic simulations, and detailed testing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ftfvr.com/privacy-app/", "developer_terms_of_service_url": null, "publisher_name": "From the Future", "support_website_url": null, "website_url": "https://www.ftfvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8192534080812009"}}]}, "scheduled_offers"