y"], "long_description": "On June 6, 2022 Horizon Venues will become part of Horizon Worlds. Download Horizon Worlds today to get ready to visit Venues there.\n\nFeel the atmosphere of a live concert and the adrenaline rush of watching a big game. Your Facebook login is an all-access pass to concerts, sports, comedy, and more.", "short_description": "On June 6, 2022 Horizon Venues will become part of Horizon Worlds. Download Horizon Worlds today to get ready to visit Venues there.\n\nFeel the atmosphere of a live concert and the adrenaline rush of watching a big game. Your Facebook login is an all-access pass to concerts, sports, comedy, and more."}]}, "developer_name": "Facebook VR", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Facebook VR", "support_website_url": null, "website_url": "https://www.oculus.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SOCIAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "471589991388290"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031582_446559783574910_2816993429607244513_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qvvKCuyspGMQ7kNvgEXKVTB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbkEpw-BPCDGGDOo3ZEIfgepQIU-DjswQ_XBalsW3izA&oe=67669BF9"}, "is_concept": false, "i