mCO0dEepaBg&oe=67011818"}, {"file_name": "Frame 2.png", "id": "1014839855643061", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75196221_1014839858976394_6593579369375425343_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rfq243EygMsQ7kNvgHWyI3N&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBoGHEPKQiynq86y2-TptXLB5cnca6jCbUt9KNoaTlYyw&oe=67011ACE"}, {"file_name": "Frame 4.png", "id": "1251729875181395", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001675_1251729878514728_136127247122211100_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7G5e1pjlGi8Q7kNvgFeOleP&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCGzG5mR2CLqbkLBTzb5Vff5a-pLMuUXJnvC1Eb4_zB3Q&oe=67010F8F"}, {"file_name": "Frame 1.png", "id": "916921798805447", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75580059_916921802138780_8958236291016190107_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CBRcmi8mXNkQ7kNvgHTSEwE&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYARj6AM5SsJ_Vho3Z0MYjKYw0d56QWDser1wWY6i3PKzg&oe=67011137"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Venues (Beta Early Access)", "keywords": ["venues"], "long_description": "Venues (Beta Early Access) is now available in a limited release!\n \nFeel the electric atmosphere of a live concert, the energy of a packed arena, and the adrenaline rush of watching a big game from the best seat in the house.\n \nYour Facebook login is your all-access pass to concerts, sports, comedy, and more. Be in the center of it all and share in this safe and social experience with thousands of people, or choose solo mode for focused viewing. Hangout with your friends and make new ones across realities.\n \nSee what\u2019s coming soon and mark your calendar so you won\u2019t miss out!\n \nNo more paying for parking and hour-long traffic jams at the end of your night. Come experience the future of entertainment and explore tomorrow\u2019s possibilities with Venues (Beta Early Access)!\n \nNote: This app is still in development and you may experience technical issues. The app and some of the events are not yet available in all regions. Have feedback? Please send to venues.support@oculus.com.", "short_description": "Venues (Beta Early Access) is now available in a limited release! Feel the atmosphere of a live concert and the adrenaline rush of watching a big game. Your Facebook login is an all-access pass to concerts, sports, comedy, and more. Share in this safe experience with thousands of people or watch in solo mode.\nNote: This app is still in development and you may experience technical issues. App and some events not yet available in all regions. Have feedback? Please send to venues.support@oculus.com"}]}, "developer_name": "Oculus", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://www.oculus.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "SPORTS", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "675261920141040"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "617630335822882"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1597345200, "status": "PUBLISHED", "id": "617630335822882"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBi