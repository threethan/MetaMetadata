/75416834_1178593325851124_5668907808360031303_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mIQovIr5BJ4Q7kNvgHdwFXi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAtCp4pvY9rlHPAyZKu1_EzjW2hucuWghAtIcS8yO9qlQ&oe=67138D18"}, {"file_name": "Frame 2.png", "id": "1014839855643061", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196221_1014839858976394_6593579369375425343_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l8ANoWitGLoQ7kNvgEgmCJJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDK7hdbTFVa3OXpTx8v8qjbYMFbfeMOMmXHPhXJFso4aA&oe=67138FCE"}, {"file_name": "Frame 4.png", "id": "1251729875181395", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001675_1251729878514728_136127247122211100_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6GkwWOArUZMQ7kNvgFiya6a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBph9kt861yNapFz5nsVoVsQlru66Y8iqb2qN0muphesQ&oe=6713848F"}, {"file_name": "Frame 1.png", "id": "916921798805447", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580059_916921802138780_8958236291016190107_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1mfi4y0Lt7EQ7kNvgF3kBxt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpP4NzQwBnfnXGb2gmLNuaLtvlfzFP-X0cT9oIxCgR9A&oe=67138637"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Venues (Beta Early Access)", "keywords": ["venues"], "long_description": "Venues (Beta Early Access) is now available in a limited release!\n \nFeel the electric atmosphere of a live concert, the energy of a packed arena, and the adrenaline rush of watching a big game from the best seat in the house.\n \nYour Facebook login is your all-access pass to concerts, sports, comedy, and more. Be in the center of it all and share in this safe and social experience with thousands of people, or choose solo mode for focused viewing. Hangout with your friends and make new ones across realities.\n \nSee what\u2019s coming soon and mark your calendar so you won\u2019t miss out!\n \nNo more paying for parking and hour-long traffic jams at the end of your night. Come experience the future of entertainment and explore tomorrow\u2019s possibilities with Venues (Beta Early Access)!\n \nNote: This app is still in development and you may experience technical issues. The app and some of the events are not yet available in all regions. Have feedback? Please send to venues.support@oculus.com.", "short_description": "Venues (Beta Early Access) is now available in a limited release! Feel the atmosphere of a live concert and the adrenaline rush of watching a big game. Your Facebook login is an all-access pass to concerts, sports, comedy, and more. Share in this safe experience with thousands of people or watch in solo mode.\nNote: This app is still in development and you may experience technical issues. App and some events not yet available in all regions. Have feedback? Please send to venues.support@oculus.com"}]}, "developer_name": "Oculus", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://www.oculus.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "SPORTS", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "675261920141040"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "61763033582288