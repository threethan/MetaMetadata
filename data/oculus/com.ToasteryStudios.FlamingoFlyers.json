"https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75210389_832061321435524_3478669676353719298_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WA-w8hZctCQQ7kNvgFs6mXw&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDoyvhjJxu0C3OxjnA3JjP4hvIVNZR52X1_-lF6ZzoQ-g&oe=6701424E"}, {"file_name": "screenshot6.png", "id": "1342867746117989", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031402_1342867749451322_3872284319872716768_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PLdhzaJkFekQ7kNvgEiD7Ck&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAgvA3KEYGyteM5QhZI4yeOmsZFCm1kyILxtiZag7njaA&oe=67013B52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumb.png", "id": "2952877285006142", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75481467_2952877291672808_4640184572027750368_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOyMc-dI9ucQ7kNvgHHFKeQ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDhp9qThDZ8VICtUI6HTm9mEP0rTIIlu0MATeZ_FPkMXg&oe=67011AE0"}, "display_name": "Flamingo Flyers", "keywords": [], "long_description": "Welcome to Flamingo Flyers! Crash down from a roller coaster into a mysterious cabin, and choose from a variety of game modes found within! \n\nGo skiing down a huge mountain, and explore deep caves full of waterfalls and glittering crystals! \n\nSurvive the forest with nothing but a flashlight in the horror mode! Invite some friends and get scared together! \n\nTake a break for a while! Relax and socialise in the main area, or head to the gun range, and empty a clip into some dummies (or into your friends)\n\nOr maybe try something closer to home, and play tag! You could even build your dream home with the sandbox building tools!\n\nCome in and join the fun!\n\n(P.s we also have a discord server! https://discord.gg/WSa5wRGdtM) ", "short_description": "Welcome to Flamingo Flyers! Crash down from a roller coaster into a mysterious cabin, and choose from a variety of game modes found within! Go skiing down a huge mountain, and explore deep caves full of shining crystals! Or maybe try something closer to home, and play tag with your friends! You could even Build your home, with advanced sandbox building tools! Come in and join the fun!\n\n(P.s we also have a discord server! The link is: https://discord.gg/WSa5wRGdtM)"}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/AtomBread/Flamingo-Flyers/main/privacypolicy.txt", "developer_terms_of_service_url": null, "publisher_name": "AtomBread", "support_website_url": null, "website_url": "https://atombread.github.io/Flamingo-Flyers/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ACTION", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "896295805113002"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001667_491733796261366_6467697470108424200_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8thfouqknTIQ7kNvgFyJa-T&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDovI89nJFkoh_1UUpabL7s1v2BbNNV1VA_-Ih8B50sQg&oe=67011EC8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Flamingo Flyers", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1673651974, "lastRevision": {"nodes": [{"id": "5613800665364860", 