67655508"}, {"file_name": "Powerwash_screenshotPlaceholder JC resize.png", "id": "3464628297126754", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340705_3464628300460087_4953141897473270102_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4-DzhS5R1a8Q7kNvgEpFP8P&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYGH34O_mdfSUhMEo6aF6TjEkSDPqM4T1O1jbUHsz_Qg&oe=67654642"}, {"file_name": "Powerwash_screenshotPlaceholder JC resize.png", "id": "1263323184293098", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036655_1263323190959764_8236388671807425299_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xrwj1UJ_pxoQ7kNvgFGaRSn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCez3qHRfTwxhS4JXtwp4M6MY-WQx309maLlsk3Z9x-JQ&oe=6765605B"}, {"file_name": "Powerwash_screenshotPlaceholder JC resize.png", "id": "585269310251872", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031631_585269313585205_4489766616379655642_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WrgirRdhe0cQ7kNvgG2wMfZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMleRHwosNTBdGVk67JQRbo6nURm5vmZXvOtfUgZsb4g&oe=676558A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "StuttG_KV_16\ua7899 (1440p).png", "id": "155941003960165", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031542_155941013960164_810089687362711791_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U919khLwl0UQ7kNvgE6VpXu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8N4kACpEST1ayuTAxt_hndCXb23m7-Ivqv-wlGHUKow&oe=67655ACF"}, "display_name": "PowerWash Simulator VR", "keywords": ["Casual", "Relaxing", "Simulation", "comfortable"], "long_description": "Grab hold of your power washer in the super-soothing simulator that has taken the world by storm. PowerWash Simulator VR is coming to Meta Quest 2! \n\nRELEASE THE PRESSURE \nWith 1:1 accuracy and control of the Quest Touch controllers, blasting away every speck of dirt and grime is a breeze. Reach up, get down and lean-in to tackle those pesky hard-to-reach spots or sit back and wash your worries away. \n\nCLEAN UP THE NEIGHBOURHOOD \nEscape to the quaint town of Muckingham, brought to life in true 360-degree immersion. The town may look wholesome but wash away the surface and not all of its residents are squeaky clean. \n\nSATISFACTION GUARANTEED \nAbsorb the relaxing atmosphere and stress-free pace as you take the pressure off and strip dirt from patios, pavements, vehicles, and public parks. \n\nPOWERWASH AND CHILL \nRelax and kick back with friends in the same shared space in online multiplayer.", "short_description": "Grab hold of your power washer, the super-soothing simulator that has taken the world by storm is coming to Meta Quest 2 in PowerWash Simulator VR.\n\nRELEASE THE PRESSURE \nWith 1:1 accuracy and control, blast away every speck of dirt and grime.\n \nSATISFACTION GUARANTEED \nStrip dirt from patios, vehicles and public parks. Absorb the simple satisfaction of making things sparkling clean.\n\nMUCKINGHAM \nThe town may look wholesome but wash away the dirt and not all its residents are squeaky clean."}]}, "developer_name": null, "developer_privacy_policy_url": "https://futurlab.co.uk/game-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "FuturLab", "support_website_url": "https://futurlab.co.uk/contact-us/", "website_url": "https://futurlab.co.uk/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "ru", "fr", "de", "es", "ja", "zh_CN", "zh_HK", "tr", "pt_BR"], "supported_input_devices"