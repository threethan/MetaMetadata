17", "locale": "en_US", "screenshots": [{"file_name": "MelbaRemake_Custom..._01.05.2024_12-08-10.png", "id": "455435840346927", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566698_455435843680260_1779163884658659311_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpSBTKPdkpgQ7kNvgGymFq_&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4w0F6-kDsjwUH_1EcAZ0oI&oh=00_AYB7rgAxgyjT8sOawTxzD1K0BtjdZI06tGZq_hImota7uA&oe=66F6A3D1"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-11-08.png", "id": "965002751881509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569423_965002755214842_5171569897886592499_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FM04qhw2xusQ7kNvgH-tPVx&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4w0F6-kDsjwUH_1EcAZ0oI&oh=00_AYA0ikHrhTuxcr71PPa2qZFJikH32HYuqF58S_0ngHSO5A&oe=66F693D9"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-10-21.png", "id": "2930950953719069", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982712_2930950957052402_6865657057301331391_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EAsWPSy2RDkQ7kNvgG6w4NI&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4w0F6-kDsjwUH_1EcAZ0oI&oh=00_AYBgI-w1dQ4y18Da9Veiw2TgAbWvkkpEVGPo2-_BO4KUKw&oe=66F6B3B7"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-10-37.png", "id": "963981601606192", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982549_963981604939525_7048254565176153513_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IxnQicbM7fgQ7kNvgGvvciB&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4w0F6-kDsjwUH_1EcAZ0oI&oh=00_AYBH92Mzwgnd9oaIz3QXeENqXhPQbZKQmEsqTx1vrac5xw&oe=66F69907"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-10-48.png", "id": "811609293664091", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223481_811609300330757_4274023099672643865_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dlnULWY2o-4Q7kNvgHUHrRJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4w0F6-kDsjwUH_1EcAZ0oI&oh=00_AYACNfm8d1X4yMvsPHhCP1MXMKIMG9ea0BGv0dGWBUFj5g&oe=66F6B00C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MelbaRemake_Custom..._01.05.2024_12-08-10.png", "id": "956839295933600", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974619_956839299266933_4410619895062726047_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMrKsW6lx_UQ7kNvgGXJFcd&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4w0F6-kDsjwUH_1EcAZ0oI&oh=00_AYDL05Uucatzz-9xV11zvPu0EPvirRFl1X-P7AMFaOfWew&oe=66F69FC7"}, "display_name": "MelbaVR Remake", "keywords": [], "long_description": "Welcome to Melba VR!\n\n\nBut beware, as the jungle holds its fair share of challenges and dangers. From treacherous terrain to cunning predators, players must use their wits and agility to overcome obstacles and outsmart their foes. Along the way, they'll uncover hidden treasures, solve puzzles, and forge unlikely friendships with the creatures they encounter.\n\n\nWith stunning graphics, immersive gameplay, and endless customization options, 'Melba: Monkey VR Adventure' is not just a game\u2014it's an unforgettable journey into a world of fun, excitement, and endless possibilities. So grab your VR headset, don your favourite accessories, and get ready to swing into action with Melba!\"", "short_description": "Experience the jungle like never before in MelbaVR! Swing through trees, customize your monkey with endless cosmetic options, and embark on an unforgettable journey filled with danger and discovery. Get ready to unleash your inner primate in this immersive VR experience!"}]}, "developer_name": "mmo0nVR", "developer_privacy_policy_url": "https://sites.google.com/view/melbavrprivacy/home", "developer_terms_of_service_url": null, "publisher_name": "mmo0nVR", "support_website_url": null, "website_url": "https://sites.google.com/view/melbavrmain/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "394813