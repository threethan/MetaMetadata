7&_nc_sid=6e7a0a&_nc_ohc=PYXmw8WLtnAQ7kNvgFuMG9K&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0YsRDBW3B2kVI7LPmqKq7aXuUE60TH1khCRTysuq4vQ&oe=66D6FFD1"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-11-08.png", "id": "965002751881509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569423_965002755214842_5171569897886592499_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kexu63FHx4QQ7kNvgGflYLp&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxiKXejoXIZq1q3Qdc-CWfOH2zf5scB0RtymTZ-sKdcg&oe=66D6EFD9"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-10-21.png", "id": "2930950953719069", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982712_2930950957052402_6865657057301331391_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZX_beIdKitEQ7kNvgFcdyqL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHC2hNMayJPN2OvidfilHLcMDZspJCASlNBQm-7QrWag&oe=66D6D777"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-10-37.png", "id": "963981601606192", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982549_963981604939525_7048254565176153513_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pjDZS_f7vB0Q7kNvgF7f9o2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnAcccQMTpq5bSJxsGxuEhbWdrLfYcl7v0KnJ-gKFKBA&oe=66D6F507"}, {"file_name": "MelbaRemake_Custom..._01.05.2024_12-10-48.png", "id": "811609293664091", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223481_811609300330757_4274023099672643865_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5YP-u-5NEWUQ7kNvgFrTmMk&_nc_ht=scontent.oculuscdn.com&oh=00_AYCac74MOp1uKx28duf13THR-KX-8e9o8j3x4da-9u1D2w&oe=66D70C0C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MelbaRemake_Custom..._01.05.2024_12-08-10.png", "id": "956839295933600", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974619_956839299266933_4410619895062726047_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aVkiOcYExoAQ7kNvgFAXQU8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvOT9ShoA7QVgCCv5FpgC01S6LrxCGKnS8AEVIN5MjFA&oe=66D6FBC7"}, "display_name": "MelbaVR Remake", "keywords": [], "long_description": "Welcome to Melba VR!\n\n\nBut beware, as the jungle holds its fair share of challenges and dangers. From treacherous terrain to cunning predators, players must use their wits and agility to overcome obstacles and outsmart their foes. Along the way, they'll uncover hidden treasures, solve puzzles, and forge unlikely friendships with the creatures they encounter.\n\n\nWith stunning graphics, immersive gameplay, and endless customization options, 'Melba: Monkey VR Adventure' is not just a game\u2014it's an unforgettable journey into a world of fun, excitement, and endless possibilities. So grab your VR headset, don your favourite accessories, and get ready to swing into action with Melba!\"", "short_description": "Experience the jungle like never before in MelbaVR! Swing through trees, customize your monkey with endless cosmetic options, and embark on an unforgettable journey filled with danger and discovery. Get ready to unleash your inner primate in this immersive VR experience!"}]}, "developer_name": "mmo0nVR", "developer_privacy_policy_url": "https://sites.google.com/view/melbavrprivacy/home", "developer_terms_of_service_url": null, "publisher_name": "mmo0nVR", "support_website_url": null, "website_url": "https://sites.google.com/view/melbavrmain/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interacti