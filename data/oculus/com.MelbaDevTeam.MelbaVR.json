iler": null, "video_trailer_thumbnail": {"file_name": "MelbaRemake_Custom..._01.05.2024_12-08-10.png", "id": "956839295933600", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974619_956839299266933_4410619895062726047_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QV8o9j8qRCMQ7kNvgEodJnn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBBM9zItrwIOp42ixAJNpSwmoNVlZ52HdVKxwOv2_03tw&oe=677BC747"}, "display_name": "MelbaVR Remake", "keywords": [], "long_description": "Welcome to Melba VR!\n\n\nBut beware, as the jungle holds its fair share of challenges and dangers. From treacherous terrain to cunning predators, players must use their wits and agility to overcome obstacles and outsmart their foes. Along the way, they'll uncover hidden treasures, solve puzzles, and forge unlikely friendships with the creatures they encounter.\n\n\nWith stunning graphics, immersive gameplay, and endless customization options, 'Melba: Monkey VR Adventure' is not just a game\u2014it's an unforgettable journey into a world of fun, excitement, and endless possibilities. So grab your VR headset, don your favourite accessories, and get ready to swing into action with Melba!\"", "short_description": "Experience the jungle like never before in MelbaVR! Swing through trees, customize your monkey with endless cosmetic options, and embark on an unforgettable journey filled with danger and discovery. Get ready to unleash your inner primate in this immersive VR experience!"}]}, "developer_name": "mmo0nVR", "developer_privacy_policy_url": "https://sites.google.com/view/melbavrprivacy/home", "developer_terms_of_service_url": null, "publisher_name": "mmo0nVR", "support_website_url": null, "website_url": "https://sites.google.com/view/melbavrmain/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "6443548731067