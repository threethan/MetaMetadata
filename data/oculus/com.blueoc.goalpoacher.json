humbnail": {"file_name": "screenshot_202404230023340038.png", "id": "401395172659930", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974783_401395175993263_3027170000623439756_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gWQCTP7E82kQ7kNvgEll5dQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYACOcnZr3CjJJCuNiJ2eHUL5Q3WTZRQlYmus3vggewUlQ&oe=672E004E"}, "display_name": "Goal Poacher: Soccer Header Simulator", "keywords": [], "long_description": "Become a pro football striker going up against challenging real-life defenders and goalkeepers to score header goals. \n\nCHALLENGING DEFENDERS AI\nThe defenders and goalkeepers in this game will try their best to stop you from scoring. You have to quickly assert their positions and decide where to put the ball to maximize scoring chance (as in real life).\n\nREAL-LIFE GOAL SCORING SCENARIO\nWe put together over 30 levels inspired by real-life goals that will test your header skills. Can you score like your favorite striker?\n\nREAL-LIFE ACCURATE BALL HEADING PHYSICS\nWe developed our projectile physics to correctly simulate the ball projectile with drag, Magnus effect, and collision check with your head to ensure a realistic heading experience.\n\n\n\n ", "short_description": "Become a pro football striker going up against challenging real-life defenders and goalkeepers to score header goals. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://blueoc.tech/en/case-study/goal-poacher/policy", "developer_terms_of_service_url": null, "publisher_name": "BlueOC studio", "support_website_url": null, "website_url": "https://blueoc.tech/en/case-study/goal-poacher", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUI