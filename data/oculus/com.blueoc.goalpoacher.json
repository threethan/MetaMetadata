110000573570332_6542911169550544387_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j5zokKQTZMMQ7kNvgGiKe5t&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSlyovpAyrum-bmSO13aUjgwPw3WBy3nFkYhpBZALW-g&oe=673DE20C"}, {"file_name": "screenshot_202404230030019617.png", "id": "1849705048835900", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_1849705052169233_4130962020149518409_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0WwThN3TLIQQ7kNvgEHF6dC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDAYyIylxk4mPq9Lg5F7__oRjc2xeM2A3awylQiUGYbg&oe=673DD336"}, {"file_name": "screenshot_202404230029444203.png", "id": "965052701736421", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035405_965052705069754_3779205855369532648_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xtT5nF8qcH8Q7kNvgEODfkV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBaaUpUWgB4DipbkaiLOYA7i8tZl5XgHKPICBiKVkOCg&oe=673DBBDD"}, {"file_name": "screenshot_202404230033274107.png", "id": "1111784780045415", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984440_1111784783378748_6963712676489512728_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5w1ruG-P_xIQ7kNvgHcuUGs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDjYwcAl8cxzayr3J4Oprnkix3pIqtvY6tg6M3rGbAXcA&oe=673DD836"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot_202404230023340038.png", "id": "401395172659930", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974783_401395175993263_3027170000623439756_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IS-_n64n4zkQ7kNvgHmcUmQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHeNiB-fqghShJ4wh4LLYnt5kKhVShEP5MOTh9jmk_Uw&oe=673DD24E"}, "display_name": "Goal Poacher: Soccer Header Simulator", "keywords": [], "long_description": "Become a pro football striker going up against challenging real-life defenders and goalkeepers to score header goals. \n\nCHALLENGING DEFENDERS AI\nThe defenders and goalkeepers in this game will try their best to stop you from scoring. You have to quickly assert their positions and decide where to put the ball to maximize scoring chance (as in real life).\n\nREAL-LIFE GOAL SCORING SCENARIO\nWe put together over 30 levels inspired by real-life goals that will test your header skills. Can you score like your favorite striker?\n\nREAL-LIFE ACCURATE BALL HEADING PHYSICS\nWe developed our projectile physics to correctly simulate the ball projectile with drag, Magnus effect, and collision check with your head to ensure a realistic heading experience.\n\n\n\n ", "short_description": "Become a pro football striker going up against challenging real-life defenders and goalkeepers to score header goals. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://blueoc.tech/en/case-study/goal-poacher/policy", "developer_terms_of_service_url": null, "publisher_name": "BlueOC studio", "support_website_url": null, "website_url": "https://blueoc.tech/en/case-study/goal-poacher", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7279132668874361"}}]}, "scheduled_offers": {"count": 8, "nodes": [{"status": "PUBLISHED", "id": "578730664721535"}, {"status": "PUBLISHED", "id": "523410713401199"}, {"status": "PUBLISHED", "id": "1738205490252930"}, {"status": "CANCELLED", "id": "1302972147353418"}, {"sta