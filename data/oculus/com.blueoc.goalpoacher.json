ent-iad3-1.oculuscdn.com&oh=00_AYAbir1J3t6iIiRQdoIgy0c_iVuuUtqFICYhyif0XHUvog&oe=672E01D4"}, {"file_name": "2kScreenshot2.png", "id": "727419716078337", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974750_727419719411670_2881611740445070994_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c0KTyPZgkgkQ7kNvgF4F4la&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD__bs5P_vCBMeGn4tENpxC9znCa6EmJ-Nu8XWcoKuhdQ&oe=672DE6E4"}, {"file_name": "2kScreenshot3.png", "id": "989857625739179", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65396053_989857629072512_3842690398633909823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ffKiwYSUSkQ7kNvgFnJhNI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvqgGYzIAlB9p6bZas3uW0LUZcT2aOLkr2U7esZts2kg&oe=672DE261"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "505722265152179", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974740_505722268485512_3381212373758678608_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=re0JQBAHOxsQ7kNvgFKzPyh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBf3XTykANNo_lr6QxfzwjRoEgvni8dHfnNkspjMfNNKg&oe=672E0E9C"}, "display_name": "Football: Goal Poacher (Soccer)", "keywords": ["football", "soccer", "header", "goal"], "long_description": "This is a football header simulator (soccer).\nBecome a pro striker who scores headers from corner kicks and free-kicks in a football simulator.\n\n# REAL-LIFE GOAL SCORING SCENARIO\nWe put together over 50 levels inspired by real-life goals that will test your header skills. \n{502323015590182}\n{1586323765481518}\n\n# CHALLENGING DEFENDERS AI\n\n{761851352778564}\nThe defenders and goalkeepers in this game will try their best to stop you from scoring. You have to quickly assert their positions and decide where to put the ball to maximize scoring chance (as in real life).\n\n# REALISTIC BALL HEADING PHYSICS\nWe developed our projectile physics to correctly simulate the ball projectile with drag, Magnus effect, and collision check with your head to ensure a realistic heading experience.\n\n{384127804168848}\n\n# NEVER PLAYED FOOTBALL IRL? WE GOT YOU COVERED!\n\nWe have slow-motion options so heading becomes easy for new players! We have also prepared a tutorial section to teach you the technique in our training facility!\n\n{2259209314422819}\n\n\n# REALISTIC GOAL-NET PHYSICS\n\n{3587114328265836}\n\n\n\nThe game is in Early Access and we would love to hear your feedback! Join us on Discord now https://discord.gg/Xyp2SyyKXv\n\n\n\n", "short_description": "This is a football header simulator (soccer).\nBecome a pro striker who scores headers from corner kicks and free-kicks in a football simulator. With accurate physics, detailed graphics, and challenging opponent AI, you can immersively experience the thrill of scoring goals as a pro in a big stadium with thousands of fans screaming and bringing victory to our country's team."}]}, "developer_name": null, "developer_privacy_policy_url": "https://goalpoachervr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "BlueOC studio", "support_website_url": null, "website_url": "https://goalpoachervr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "84410451326831