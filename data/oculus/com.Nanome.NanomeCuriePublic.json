7073532301475840_n.png", "id": "276878813865129", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974864_276878817198462_2194890393792401770_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8VOXdkJcDMwQ7kNvgEOTpdv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCcK4RXQryfcsQUseB_wogKAKFc1FHFFNVIYXb-M5DmDQ&oe=67178E57"}, {"file_name": "38974505_254799885401780_413407507231277056_n.png", "id": "858208675013264", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031391_858208678346597_8610615376986062604_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3cm5b4iVK6kQ7kNvgFscR4O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBi60x_WHWRbbWABOWWAVViiEwwUS9GnLTc_-6izhV9zg&oe=67178519"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_thumbnail.png", "id": "431449088107326", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001687_431449091440659_5707369122895378827_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0MuL75NTNIMQ7kNvgEs6NO5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsdd5Ra5wX_ruiioR6rdrFbIbLzcRshcU1WqQp4LwcHQ&oe=671775DB"}, "display_name": "Nanome AppLab", "keywords": [], "long_description": "Nanome - Your Home for Nanoscale Design\nImagine a future where chemistry and the molecules are no longer difficult to understand. Nanome enables you to build your own molecular structures or explore the intricacies of a DNA strand or understand what medicine looks like at the molecular level. \nFeatures:\n\u2022Import molecular structures from RCSB Protein Databank, Pubchem and Drugbank.\n\u2022Manipulate molecular structures by literally reaching out and grabbing, rotating, or enlarging your molecule.\n\u2022See Atoms, Residues, Chains, or Proteins as Stick, Wire, Ball & Stick, or Van der Waals.\n\u2022Measure distance and angles between atoms.\n\u2022Mutate amino acids and cycle through rotamer conformations.\n\u2022Build with any element from the periodic table.\n\u2022Minimization simulations.\n\u2022Duplicate or Split any selected area of your structure to modify or export independently.\n\u2022Private & public multi-user support including 2D mode\nIn-app camera to capture and export images.", "short_description": "Manipulate chemicals and proteins with your hands, explore chemistry and molecules from a whole new perspective, collaborate with others, learn and create like never before.\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://nanome.ai/downloads/Nanome-Privacy.pdf", "developer_terms_of_service_url": "https://nanome.ai/terms", "publisher_name": "Nanome Inc.", "support_website_url": "https://nanome.ai/", "website_url": "https://nanome.ai/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}, {"id": "393222478507326"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "6464101413693277"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982640_523760319665111_3584164198869309747_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A8E8C1xPjIIQ7kNvgH8PzLf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNtD7ugDbYgf3q2DZkvmvtafUKE-WKGY0Al_jNe5sQ5Q&oe=671792F6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Nanome AppLab", "platform": "ANDROI