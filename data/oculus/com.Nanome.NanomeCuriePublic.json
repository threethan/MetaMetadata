ng your molecule.\n\u2022See Atoms, Residues, Chains, or Proteins as Stick, Wire, Ball & Stick, or Van der Waals.\n\u2022Measure distance and angles between atoms.\n\u2022Mutate amino acids and cycle through rotamer conformations.\n\u2022Build with any element from the periodic table.\n\u2022Minimization simulations.\n\u2022Duplicate or Split any selected area of your structure to modify or export independently.\n\u2022Private & public multi-user support including 2D mode\nIn-app camera to capture and export images.", "short_description": "Manipulate chemicals and proteins with your hands, explore chemistry and molecules from a whole new perspective, collaborate with others, learn and create like never before.\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://nanome.ai/terms", "developer_terms_of_service_url": "https://nanome.ai/terms", "publisher_name": "Nanome Inc.", "support_website_url": "https://nanome.ai/", "website_url": "https://nanome.ai/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "4496188257159872"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "344866180186039"}]}, "baseline_offer": {"id": "344866180186039"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1615490460, "status": "PUBLISHED", "id": "344866180186039"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typen