a&_nc_ohc=u9JubJX_R8oQ7kNvgFqUfLj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC9FwgExIhY7oVH1SUQa8kO&oh=00_AYCQgE2nTrBGSMYZ1t60fYAMcpoZMBFaoePq_mtNBnlyDw&oe=66F544C3"}, {"file_name": "Fire.png", "id": "969792831266656", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334063_969792834599989_9133593109480239972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hS1FnMK-3psQ7kNvgFsacQk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC9FwgExIhY7oVH1SUQa8kO&oh=00_AYBbr62espuvWy_WXtsNMHLE7_8A440YO0HNeLk8fBeWmw&oe=66F550D0"}, {"file_name": "tREEscreen.png", "id": "2118877995134865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035430_2118877998468198_6702883681695695660_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tjGAi65WD-AQ7kNvgGKlIcS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC9FwgExIhY7oVH1SUQa8kO&oh=00_AYA7Qo1FXLoAwE1T4FNeTa5YpotnFYvglqgIHiDlIvGsHA&oe=66F53914"}, {"file_name": "Vent.png", "id": "2209082372768911", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982621_2209082376102244_961038042765605839_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L6fslrOTCNEQ7kNvgF-cDpS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC9FwgExIhY7oVH1SUQa8kO&oh=00_AYA6xsZRHQ-iTG_nBS1DP2fKQnKZFm3fHtIcWo_H7Hn1Uw&oe=66F55ABB"}, {"file_name": "Shop.png", "id": "1470316070224894", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974767_1470316073558227_6929871350646489347_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dG2Edae4sWwQ7kNvgHLEBTu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC9FwgExIhY7oVH1SUQa8kO&oh=00_AYBcwRPwyyPnK5qSK8Wg4MfefQazyEPyE8aylYXFYo4aYA&oe=66F5508D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2024_05_06_0s9_Kleki.png", "id": "2132132347160920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_2132132350494253_1200221396818654202_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aHLbOLf6FLMQ7kNvgGwcol4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC9FwgExIhY7oVH1SUQa8kO&oh=00_AYBKzE3GmBcPqTVa9S6j2aCJiCaRUASf9dGjiyezLNltEA&oe=66F53CA3"}, "display_name": "MonkeSprinters", "keywords": [], "long_description": "Welcome to \"Monke Sprinters\" \u2013 an electrifying VR experience where you and friends become agile primates racing through lush jungle. Use your hands to sprint, climb, and leap, feeling the rush of wind as you bound from branch to branch. Discover hidden treasures unlocking new cosmetics. Express your unique style with accessories from feathered headdresses to woven bracelets. With endless customization options, the jungle becomes your canvas for self-expression. Join friends for intense races, playful games, or tranquil hangs in the virtual jungle. But beware of rival monkes and cunning predators lurking in the shadows. \"Monke Sprinters\" is a high-octane adventure where speed, style, and socializing collide. So grab your headset, rally your friends, and prepare to sprint, climb, and leap your way to glory in the ultimate jungle showdown. The race is on \u2013 are you ready to embrace your inner monke?\n\n\n\n\n\n\n", "short_description": "A remake of the game Monke Sprinters.\nIn this game you can set a name, move with your hands, get cosmetics and so much more! "}]}, "developer_name": "Gloomy", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/de95c913-1546-467e-bd73-d7a41037269f", "developer_terms_of_service_url": null, "publisher_name": "Gloomy", "support_website_url": null, "website_url": "https://sites.google.com/view/monkesprinter/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"]