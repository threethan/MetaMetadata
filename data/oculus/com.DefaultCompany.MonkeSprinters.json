0xWJzkPvzGAW1Dig&oe=67372FC3"}, {"file_name": "Fire.png", "id": "969792831266656", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75334063_969792834599989_9133593109480239972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O0uUN_VM4sIQ7kNvgECnx1T&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBGpDMWU0KwZ3FF7f4AaVCs7l7waB8WudJ4qyaHJeDEDg&oe=67373BD0"}, {"file_name": "tREEscreen.png", "id": "2118877995134865", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035430_2118877998468198_6702883681695695660_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-YtKCdhpaLgQ7kNvgHjYmk7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIYXe0hOMxXuPi3zoj5-junVhudX_Zfehs7B8jwh7g1g&oe=67372414"}, {"file_name": "Vent.png", "id": "2209082372768911", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982621_2209082376102244_961038042765605839_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LGg_vfGf-BcQ7kNvgFaslVM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXi5Y5mDy5lJygSyaRhcrCCz2PgdbHoVpUbDSKbG6EEA&oe=673745BB"}, {"file_name": "Shop.png", "id": "1470316070224894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974767_1470316073558227_6929871350646489347_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k2gajv7OgLgQ7kNvgGCMUmB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB68APqgN098sma0ofLMt-yhJyuF68Zn_vcPmRYedGKEQ&oe=67373B8D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2024_05_06_0s9_Kleki.png", "id": "2132132347160920", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001663_2132132350494253_1200221396818654202_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7NSD-aGjNHwQ7kNvgH4qtrG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1MZqw1oGLZq8xUnp5PFnE6PfrO-8NXwviAZztfH6Dow&oe=673727A3"}, "display_name": "MonkeSprinters", "keywords": [], "long_description": "Welcome to \"Monke Sprinters\" \u2013 an electrifying VR experience where you and friends become agile primates racing through lush jungle. Use your hands to sprint, climb, and leap, feeling the rush of wind as you bound from branch to branch. Discover hidden treasures unlocking new cosmetics. Express your unique style with accessories from feathered headdresses to woven bracelets. With endless customization options, the jungle becomes your canvas for self-expression. Join friends for intense races, playful games, or tranquil hangs in the virtual jungle. But beware of rival monkes and cunning predators lurking in the shadows. \"Monke Sprinters\" is a high-octane adventure where speed, style, and socializing collide. So grab your headset, rally your friends, and prepare to sprint, climb, and leap your way to glory in the ultimate jungle showdown. The race is on \u2013 are you ready to embrace your inner monke?\n\n\n\n\n\n\n", "short_description": "A remake of the game Monke Sprinters.\nIn this game you can set a name, move with your hands, get cosmetics and so much more! "}]}, "developer_name": "Gloomy", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/de95c913-1546-467e-bd73-d7a41037269f", "developer_terms_of_service_url": null, "publisher_name": "Gloomy", "support_website_url": null, "website_url": "https://sites.google.com/view/monkesprinter/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7170217123107713"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUB