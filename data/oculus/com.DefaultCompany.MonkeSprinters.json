2834599989_9133593109480239972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYMI27e070MQ7kNvgFvljaO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDOw42OXi3Ll9_gvpT6LHQmk495jwiYDGKnXxTggNLoNA&oe=66D84FD0"}, {"file_name": "tREEscreen.png", "id": "2118877995134865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035430_2118877998468198_6702883681695695660_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=42hbvZ6-9dkQ7kNvgEzCmWT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQNNAv-Gv4g6a3M9eSMOPmNUufOhKX6EzJ4Mc1RHBwHg&oe=66D83814"}, {"file_name": "Vent.png", "id": "2209082372768911", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982621_2209082376102244_961038042765605839_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SWbeB9FoeWEQ7kNvgG11rHI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBotCe1VWBwoWny4VLVrpR94j_eKYXHBsYwRUqguV8nSg&oe=66D859BB"}, {"file_name": "Shop.png", "id": "1470316070224894", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974767_1470316073558227_6929871350646489347_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DOZHjDol6FsQ7kNvgGBDZ1k&_nc_ht=scontent.oculuscdn.com&oh=00_AYB2W4QRd1Z0BcsTCg_OpRf150Ly8dfWuQxaV1Hn40w_rg&oe=66D84F8D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2024_05_06_0s9_Kleki.png", "id": "2132132347160920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_2132132350494253_1200221396818654202_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q0XRyTsKYloQ7kNvgFYxVaQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAY8W9Bl8CSF2TAqdSzWAJ-hMKBgeLPUlvOdrxIwdGMZw&oe=66D83BA3"}, "display_name": "MonkeSprinters", "keywords": [], "long_description": "Welcome to \"Monke Sprinters\" \u2013 an electrifying VR experience where you and friends become agile primates racing through lush jungle. Use your hands to sprint, climb, and leap, feeling the rush of wind as you bound from branch to branch. Discover hidden treasures unlocking new cosmetics. Express your unique style with accessories from feathered headdresses to woven bracelets. With endless customization options, the jungle becomes your canvas for self-expression. Join friends for intense races, playful games, or tranquil hangs in the virtual jungle. But beware of rival monkes and cunning predators lurking in the shadows. \"Monke Sprinters\" is a high-octane adventure where speed, style, and socializing collide. So grab your headset, rally your friends, and prepare to sprint, climb, and leap your way to glory in the ultimate jungle showdown. The race is on \u2013 are you ready to embrace your inner monke?\n\n\n\n\n\n\n", "short_description": "A remake of the game Monke Sprinters.\nIn this game you can set a name, move with your hands, get cosmetics and so much more! "}]}, "developer_name": "Gloomy", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/de95c913-1546-467e-bd73-d7a41037269f", "developer_terms_of_service_url": null, "publisher_name": "Gloomy", "support_website_url": null, "website_url": "https://sites.google.com/view/monkesprinter/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7170217123107713"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "466499416053233"}]}, "baseline_offer": {"id": "466499416053233"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715186700, "status": "PUBLISHED", "id": "466499416053233"}]}, "liveChannel": {"nodes": [{"late