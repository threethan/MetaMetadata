 Kheelee, and even face Vel Selysian - the mysterious prophet-like leader of the Dominion."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zerofun.games/antiprism-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zero Fun Ltd", "support_website_url": null, "website_url": "https://zerofun.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "523884858862162"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "525441425357078"}]}, "baseline_offer": {"id": "525441425357078"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1628115480, "status": "PUBLISHED", "id": "525441425357078"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4180701485349043", "version": "1.04"}, "id": "1164267717426351", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4079780642107795", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4180701485349043"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1164267717426351"}]}, "change_log": null, "created_date":