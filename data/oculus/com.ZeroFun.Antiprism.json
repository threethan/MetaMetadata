et in order to reach the end of our pilots' journey.\nTest your aim and dodging abilities against elite enemies, unique bosses and environmental hazards, as you uncover the secrets of the Antiprism and its connection to the extinct civilization of Arn.", "short_description": "Fight your way through bands of space pirates, armies of the Selysian Dominion, swarms of insect-like Kheelee, and even face Vel Selysian - the mysterious prophet-like leader of the Dominion."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zerofun.games/antiprism-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zero Fun Ltd", "support_website_url": null, "website_url": "https://zerofun.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "523884858862162"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "525441425357078"}]}, "baseline_offer": {"id": "525441425357078"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1628115480, "status": "PUBLISHED", "id": "525441425357078"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4180701485349043", "version": "1.04"}, "id": "1164267717426351", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary"