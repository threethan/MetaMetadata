 bosses and environmental hazards, as you uncover the secrets of the Antiprism and its connection to the extinct civilization of Arn.", "short_description": "Fight your way through bands of space pirates, armies of the Selysian Dominion, swarms of insect-like Kheelee, and even face Vel Selysian - the mysterious prophet-like leader of the Dominion."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zerofun.games/antiprism-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zero Fun Ltd", "support_website_url": null, "website_url": "https://zerofun.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "523884858862162"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_687957388722115_4328917200252961276_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=217qeZZnhJsQ7kNvgHHw9vm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArrcen3z0kcgacz8fvQYBvjM9oZQ9kFANogK3td6p8Qw&oe=674992C9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Antiprism", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1628115531, "lastRevi