2.oculuscdn.com/v/t64.5771-25/38974635_513403304625008_3934172412346721816_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CPuxA2Bw8EoQ7kNvgFOrGC6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDaMKUOYzBfRjiRbLcVuf069QUEGhuWDMP5DO3oAMLwDQ&oe=676BE757"}, {"file_name": "2.png", "id": "403814366088965", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031533_403814369422298_3652931090691213258_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Mwk0h-Sl0MQ7kNvgFReKkK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVBE15IUaERfdLD44xQK568MqNebkvyqJrWverm4_yBA&oe=676BFD62"}, {"file_name": "3.png", "id": "2255129008188560", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974812_2255129011521893_5568475357922827256_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GFPQlFzkG3YQ7kNvgEYG3XD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-oQ1S9DqWrLsbqO7Tb4REQ4f9QNTVYmKpe8nl7Wykvg&oe=676BEA21"}, {"file_name": "0.png", "id": "2311328955882136", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036657_2311328962548802_8183369815991323783_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QOPDHBl7s5cQ7kNvgE96wfM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCruvAsFDpyfINDVLV6F40GXfkYot7iXBZ9JQiZW8cdlQ&oe=676BF151"}, {"file_name": "1.png", "id": "1062674858571716", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240106_1062674861905049_448257407803339299_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pGJZlmX-nYkQ7kNvgE4yrZt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDl2pratrVfEKni7Yz-5Bft7LIlfZHoOzlmK1nLS_M45g&oe=676C0661"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Echo Eyes", "keywords": ["blind", "impaired", "obstacle", "echoeyes", "ai"], "long_description": "# EchoEyes: Your AI-Powered Companion for Visual Understanding\n\n# \ud83d\udc41\ufe0f See the World Through AI\n\nWelcome to EchoEyes, an innovative AI-powered app designed to empower individuals with visual impairments. Using cutting-edge technology and intuitive hand gestures, EchoEyes helps you understand your surroundings and navigate the world with confidence.\n\n{541757971654618}\n\n# \ud83c\udfaf Key Features\n- **Gesture-Based Interface**: Simple hand movements control the app, ensuring ease of use.\n- **Real-Time Environment Description**: Get instant audio descriptions of your surroundings.\n- **Obstacle Detection**: Receive timely alerts about potential hazards in your path.\n\n{840249464553769}\n\n# \u270b How It Works\n- Activate EchoEyes with a simple gesture.\n- Explore your environment using intuitive hand movements.\n- Listen to clear, concise audio descriptions and alerts.\n\n# \ud83d\udc8e Benefits\n\n- **Enhanced Independence**: Navigate unfamiliar spaces with greater confidence.\n- **Improved Safety**: Stay aware of potential dangers in your surroundings.\n- **Expanded Access**: Interact with visual information previously out of reach.\n- **Seamless Integration**: Fits naturally into your daily routine.\n\n# \ud83c\udf1f Perfect For\n\n- Individuals with visual impairments\n- Those experiencing gradual vision loss\n- Anyone seeking an extra layer of environmental awareness", "short_description": "Welcome to EchoEyes, an AI-powered app designed for the blind. With just simple hand gestures, it helps you understand your surroundings."}]}, "developer_name": null, "developer_privacy_policy_url": "https://bbape.com/privacypolicy_echoeyes.html", "developer_terms_of_service_url": null, "publisher_name": "BBAPE", "support_website_url": null, "website_url": "https://bbape.com/privacypolicy_echoeyes.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "reco