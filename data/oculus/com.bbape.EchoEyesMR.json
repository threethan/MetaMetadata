BD7D7"}, {"file_name": "2.png", "id": "403814366088965", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031533_403814369422298_3652931090691213258_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=psm1hpSsNoIQ7kNvgH5UpGK&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgk7D2RO5E8bZhlbu4xXsBbiDd5p34MDXvFQwLilbJdQ&oe=66FBEDE2"}, {"file_name": "3.png", "id": "2255129008188560", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974812_2255129011521893_5568475357922827256_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vXiNANQaF6sQ7kNvgEY1rkF&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhd9eiI68W6UIWRpAAPt8kjYYBxgY8ZgfP5cVO3JqTUw&oe=66FBDAA1"}, {"file_name": "0.png", "id": "2311328955882136", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_2311328962548802_8183369815991323783_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d93AtJL_sKsQ7kNvgFy5IsW&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1b7odPG29_5w9gTSlAT6NK6Xbk_PLgUw9Je0iJt8FCQ&oe=66FBE1D1"}, {"file_name": "1.png", "id": "1062674858571716", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240106_1062674861905049_448257407803339299_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2FB5xgsD-LgQ7kNvgG1pcBK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdLDWkgKbyKTkgv37I3r5cqMdACVLqPpxr_wH8o5jsgw&oe=66FBF6E1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Echo Eyes", "keywords": ["blind", "impaired", "obstacle", "echoeyes", "ai"], "long_description": "# EchoEyes: Your AI-Powered Companion for Visual Understanding\n\n# \ud83d\udc41\ufe0f See the World Through AI\n\nWelcome to EchoEyes, an innovative AI-powered app designed to empower individuals with visual impairments. Using cutting-edge technology and intuitive hand gestures, EchoEyes helps you understand your surroundings and navigate the world with confidence.\n\n{541757971654618}\n\n# \ud83c\udfaf Key Features\n- **Gesture-Based Interface**: Simple hand movements control the app, ensuring ease of use.\n- **Real-Time Environment Description**: Get instant audio descriptions of your surroundings.\n- **Obstacle Detection**: Receive timely alerts about potential hazards in your path.\n\n{840249464553769}\n\n# \u270b How It Works\n- Activate EchoEyes with a simple gesture.\n- Explore your environment using intuitive hand movements.\n- Listen to clear, concise audio descriptions and alerts.\n\n# \ud83d\udc8e Benefits\n\n- **Enhanced Independence**: Navigate unfamiliar spaces with greater confidence.\n- **Improved Safety**: Stay aware of potential dangers in your surroundings.\n- **Expanded Access**: Interact with visual information previously out of reach.\n- **Seamless Integration**: Fits naturally into your daily routine.\n\n# \ud83c\udf1f Perfect For\n\n- Individuals with visual impairments\n- Those experiencing gradual vision loss\n- Anyone seeking an extra layer of environmental awareness", "short_description": "Welcome to EchoEyes, an AI-powered app designed for the blind. With just simple hand gestures, it helps you understand your surroundings."}]}, "developer_name": null, "developer_privacy_policy_url": "https://bbape.com/privacypolicy_echoeyes.html", "developer_terms_of_service_url": null, "publisher_name": "BBAPE", "support_website_url": null, "website_url": "https://bbape.com/privacypolicy_echoeyes.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id":