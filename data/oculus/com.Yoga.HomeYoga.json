our Quest headset. Professional Yoga teachers who had 8+ years teaching experiences, both from beginer to higher level."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cqplanb.com/ccc/Home_Yoga_VR.txt", "developer_terms_of_service_url": null, "publisher_name": "jijia", "support_website_url": null, "website_url": "http://www.cqplanb.com/ccc/Home_Yoga_info.txt", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2776542286000603"}, {"id": "879473995923081"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "EDUCATIONAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1289984098279593"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572927_1060361764717464_6403930155310147726_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MZRqzwcfTqMQ7kNvgES_cig&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ay5ttcyjdJrpheTB-StVaYM&oh=00_AYBcsa1oYYClz_EhxhHspYtQx62AbJOBTcoeoZg34eEEfQ&oe=66E96B53"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Home Yoga", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Education", "id": "879473995923081"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1635192132, "lastRevision": {"nodes": 