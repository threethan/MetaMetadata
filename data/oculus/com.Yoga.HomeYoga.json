52454379_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1fy1RPhQsdEQ7kNvgEWmWja&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpVuFZi9yc7FEBINndTsLOvITdvufjrvBg_9xUTRZcag&oe=671508F0"}, {"file_name": "2560 1440 1.png", "id": "240961151316723", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974711_240961154650056_7897661354730702399_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iQfidsMsh4sQ7kNvgGxOHlb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmM-ZTwZ1PHfDe97v2o2K-zoszZCq4hKH_808NxbqKrg&oe=6714D573"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 1440 1.png", "id": "601445537814753", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974873_601445541148086_5828305710488420632_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QgL2-j6Nec0Q7kNvgF9e64E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAgl1hA1FjESKRZaKn5enKveAws7i77dcOnc4XzH6S-6Q&oe=67150594"}, "display_name": "Home Yoga", "keywords": [], "long_description": "1. Suggest you use Quest2 headset. Quest still can work. \n2. Make sure you are in a place with no objects close to you!  It requires a playspace of at least 6'6''x4'11'' (2x1.5m).\n3. We have teachers team who teach people Yoga for almost 8+ years. Our courses we\u2019ve built is suitable for everyone, both beginners and those already on the yoga path.\n4. Everyone is busy.Getting motivated to go to the gym was always hard for most people. Compare to the long way drive to gym and back,and also bring a lot of things,only 10mins everyday in your spare time, you can finish.\n5. Now there are 101 Yoga workouts in it. Update time and time with new courses.You can use it for a long time.\n6.Please e-mail us if you have any suggestion or cooperation idea. \ne-mail: 408077086@qq.com\n\nUpdated 2023/04/05\n", "short_description": "Do Yoga at anywhere,any time with your Quest headset. Professional Yoga teachers who had 8+ years teaching experiences, both from beginer to higher leve