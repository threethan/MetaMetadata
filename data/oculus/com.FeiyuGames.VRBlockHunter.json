d=6e7a0a&_nc_ohc=ug1NQudyMsgQ7kNvgGBU0cK&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYC6-seetwGXsoeSerqi8SFGMmMTwN3pWsRSrhdusV2peA&oe=677E688A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1111.png", "id": "642215117835898", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031523_642215121169231_1253359253477954172_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bz9Mbk5te7cQ7kNvgEDfLd1&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDh1BEtg6UTCnymKiOCoXuf38umtnedBuWR_0fdVdc4Sw&oe=677E66D3"}, "display_name": "Block Hunter", "keywords": [], "long_description": "\"Block Hunter is a music rhythm game that combines party game, online competitions, and maybe rogue lite genes,and one more thing...\"\n\"Give me the mic,mic-check,1,2,3...\n Okay,listen up,folks:\nAs everyone knows,the BLOCK Galaxy is the motherlode of Block storage in the Cosmos. But it's also a hot zone for the Block Pirates who love causing chaos and looting.\nThat's why we got a bunch of Block Hunter volunteers going to take down those infamous Block pirates. The pirate cargo ships are filled with piles of loot and powerful weapons, Although each hunt is both dangerous and thrilling, the rich reward and glorious leaderboard make everyone want to take their chance for themselves, um... I mean,of course\uff0cAll for the glory of the BLOCK Galaxy. \n\n- Endless hunting experience \uff08you'd stick it out\uff09\n- Groovy beats\uff08More and more updates in the future\uff09\n- Mystery perks \uff08You deserve it\uff09\n- Ranking competition\uff08Not vanity\uff09\n- Local multi-user login \uff08compete your family or Friends\uff09", "short_description": "Block Hunter is a music rhythm game that combines party game, online and local competitions, and maybe rogue-lite genes.hope you guys enjoy it!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://privacy.737.com/protocol/30379-2.html", "developer_terms_of_service_url": null, "publisher_name":