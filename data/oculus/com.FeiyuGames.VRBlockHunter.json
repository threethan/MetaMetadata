a0a&_nc_ohc=uAgo2zXzmA4Q7kNvgFAG1ZK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHKmIcdWinoerLUb7znFXhCY__H9ovwAOovFxhg4Hnyw&oe=676D450A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1111.png", "id": "642215117835898", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031523_642215121169231_1253359253477954172_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TZbhki0usu0Q7kNvgEyt_L_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAppru157rb68860rjRm6ydN7xOMCztnijzLQf8ujnw-Q&oe=676D4353"}, "display_name": "Block Hunter", "keywords": [], "long_description": "\"Block Hunter is a music rhythm game that combines party game, online competitions, and maybe rogue lite genes,and one more thing...\"\n\"Give me the mic,mic-check,1,2,3...\n Okay,listen up,folks:\nAs everyone knows,the BLOCK Galaxy is the motherlode of Block storage in the Cosmos. But it's also a hot zone for the Block Pirates who love causing chaos and looting.\nThat's why we got a bunch of Block Hunter volunteers going to take down those infamous Block pirates. The pirate cargo ships are filled with piles of loot and powerful weapons, Although each hunt is both dangerous and thrilling, the rich reward and glorious leaderboard make everyone want to take their chance for themselves, um... I mean,of course\uff0cAll for the glory of the BLOCK Galaxy. \n\n- Endless hunting experience \uff08you'd stick it out\uff09\n- Groovy beats\uff08More and more updates in the future\uff09\n- Mystery perks \uff08You deserve it\uff09\n- Ranking competition\uff08Not vanity\uff09\n- Local multi-user login \uff08compete your family or Friends\uff09", "short_description": "Block Hunter is a music rhythm game that combines party game, online and local competitions, and maybe rogue-lite genes.hope you guys enjoy it!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://privacy.737.com/protocol/30379-2.html", "developer_terms_of_service_url": null, "publisher_name": "FEIYU TECHNOLOGY HONGKONG LIMITED ", "support_website_url": null, "website_url": "https://bh.feiyu.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1700921480735423"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7776042092457109"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974900_251018940894412_2822056221580308406_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zV9slrJo10IQ7kNvgGaZED5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4jnBFuZV-ZPZMjDmZlVvFPy2Zo8xfjHKlAc9Wdiwuxg&oe=676D2815"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Block Hunter", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Rhythm", "id": "1672577396871977"}, {"topic_name": "Party Game", "id": "1700921480735423"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1697509800, "lastRevision": {"nodes": [{"id": "6367516189976380", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6367516176643048", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1315667102631035"}, "iarc_email": null, "msrp": null,