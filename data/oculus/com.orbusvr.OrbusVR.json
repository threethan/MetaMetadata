06_6828830509800357888_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C7qG02OGzqEQ7kNvgFmPnPh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDGyHY9L2en72aix7fAJRIuiFJzuFV_MH8M0WVg3se1FA&oe=66F950F3"}]}, "id": "347222100814945", "locale": "en_US", "screenshots": [{"file_name": "oculus new highsteppe (1).png", "id": "227499459425949", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031549_227499462759282_2851333166620211535_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PNiy9hiT53AQ7kNvgHvwBc6&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-VWELCW1Er-x5lxxSZuqr2UALShpBYE6B2qJeBV-_tg&oe=66F92761"}, {"file_name": "Oculus Screenshot Hulthines.png", "id": "335988614777987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974796_335988618111320_1647239326005047475_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=boAdmGlb1KcQ7kNvgGZtp4Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVULUqkavSdtovY63tv2yH6fo2MiXXqkn-q5fITn7Rww&oe=66F92CA0"}, {"file_name": "migrated_image.png", "id": "857756697984598", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974491_189606425825822_2068162010134085632_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NMJPuV7_PYsQ7kNvgFMmvIR&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_qf3R_KC6ZWkvBISMLp6ejVDvxt5jtyEm3Ddp2DUGDw&oe=66F93D2D"}, {"file_name": "migrated_image.png", "id": "258679631790134", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035398_3409676112392928_7944265801840721920_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3nwkkc4SadgQ7kNvgHwNuN6&_nc_ht=scontent.oculuscdn.com&oh=00_AYCeESXtzex0qmy8lkj8GKszCdSUFKwcilcP13lHQRVhEg&oe=66F94370"}, {"file_name": "migrated_image.png", "id": "494442034530735", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4sUfPWeKa6IQ7kNvgEnm4aM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjCGAs90luLt907RYrOFFuh_Fj7RlTYK3p0DeoV8keag&oe=66F92F28"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus trailer cover image 2021.png", "id": "827417904817135", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_827417908150468_5632650648744685154_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D_iagO5eHh8Q7kNvgE1fNte&_nc_ht=scontent.oculuscdn.com&oh=00_AYD6DAF3FGE32cal_EnycbftFv1gbCq0Bzp3--sXYuQxiw&oe=66F93604"}, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy", "multiplayer", "social"], "long_description": "With more than 100+ hours of unique content and a strong in-game community, Orbus is a VR experience like no other!\n\nBattle monsters, race dragons, brew a potion, or kick back at the Highsteppe Tavern and catch up with your favorite adventurers. In OrbusVR, you\u2019ll find everything you love about an MMORPG, including:\n\n\u2022 8 playable classes\n\u2022 Fishing, crafting & artificing\n\u2022 Opt-in World PvP & Battlegrounds\n\u2022 5-player dungeons & 10-player raids\n\u2022 Dungeon queue, group finder & other social features\n\u2022 Frequent free updates with new content\n\u2022 Pet dragons, player trading and more!\n\nThe first MMORPG designed exclusively for room-scale virtual reality, Orbus offers a way for every player to enjoy the game on their terms, whether you prefer group play or flying solo, combat or exploration.\n\nImmerse yourself in a world of discovery. Join the OrbusVR community and start exploring today!", "short_description": "With more than 100+ hours of unique content and a strong in-game community, Orbus is a VR experience like no other!\n\nIn OrbusVR, you\u2019ll find everything you love about an MMORPG, including:\n\n\u2022 8 playable classes\n\u2022 Fishing, crafting & artificing\n\u2022 Opt-in World PvP & Battlegrounds\n\u2022 5-player dungeons & 10-player raids\n\u2022 Dungeon queue, group finder & other social features\n\u2022 Pet dragons, player trading and more!\n\nImmerse yourself in a world of discovery. Join the OrbusVR community today!"}]}, "developer_name": null, "developer_privacy_