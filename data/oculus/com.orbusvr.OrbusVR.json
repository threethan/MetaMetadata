.5771-25/38982618_452716225467712_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AO6bQhGGOxoQ7kNvgG3dNsB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrcHdnge072j_b3mdlSXYceC-9GzEGIpwZvBpJByY3IA&oe=67373AD0"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HY2jT6HO3nMQ7kNvgFFf1b2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtgeXVtH-fdwOwXNz94RDWWnRfYI2zYbTY5SdPhABxYA&oe=673744CF"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RxAyqPwzqcQQ7kNvgGnD5a7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUUTHPn4AEOEMhRSUXKPsXKkbgWPgFXcu6gBmMC3Hs2w&oe=673725A8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "short_descripti