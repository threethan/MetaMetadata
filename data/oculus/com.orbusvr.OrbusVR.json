n.com/v/t64.5771-25/38982618_452716225467712_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0zBkG0-9hLMQ7kNvgHaVEhW&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYDmWvwyJK0OChstTaZUsYqh30t2AvVPjM7-AFR1Y1giOw&oe=677E6BD0"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7UPRjrKhtNUQ7kNvgEPcz6r&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDeS8WhlnUFE2eb7fP9MCmYsw0coWq_9Hpq2pwvbJryug&oe=677E75CF"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9L3W8pDiCgAQ7kNvgHe0CaZ&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBPlKyOy0j0dj0v7_7vcARTpa2zcwdqHjlUB-wznaBz5Q&oe=677E56A8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "sh