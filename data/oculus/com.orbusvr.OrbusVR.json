scdn.com/v/t64.5771-25/39031403_401605603726667_996092281326927872_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qItLQP2GVA8Q7kNvgESyPMW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYBGF7A2Pqe2v1tjD8UrkFH5QVuZdafIUlQNSbT5ZywDJQ&oe=66F14AFE"}, {"file_name": "migrated_image.png", "id": "947262619023614", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_452716225467712_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZV2GHOub-9YQ7kNvgGOr5ad&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYCFvxe6TRntxlhBec2mMgNuVxuFt5Z7PJDH2mRt3d5sEQ&oe=66F15B50"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M1We-2paJHIQ7kNvgFGgfTs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYBJs0lZo9nUQpMzZzSjQLnGBS8CSLN1V2LXtPQFq2SmCQ&oe=66F1654F"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=muzq-KNUkEEQ7kNvgGpXsS-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYCfxa3fJfexxNm4bOE1Xyt2PwPPb4d8mWQKVLfmkNsTwA&oe=66F14628"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "short_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://orbusvr.com/account/terms", "developer_terms_of_service_url": "https://orbusvr.com/account/terms", "publisher_name": "Orbus Online LLC", "support_website_url": null, "website_url": "http://orbusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "RPG", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "489736062496330"}}]}, "scheduled_offers": {"count": 35, "nodes": [{"status": "PUBLISHED", "id": "1582053885921957"}, {"status": "PUBLISHED", "id": "368228468014353"}, {"status": "PUBLISHED", "id": "399483258487776"}, {"status": "PUBLISHED", "id": "707823223106641"}, {"status": "PUBLISHED", "id": "847024076969466"}, {"status": "PUB