.oculuscdn.com/v/t64.5771-25/39031403_401605603726667_996092281326927872_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CcdQs4QeF0UQ7kNvgEqUE9p&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjZnUhWwtOGP9v9XbsGuN7n&oh=00_AYApRdlJnr3qGxVZH-TzEigQviLaO-_m1OXig69qAyxFFA&oe=66D449FE"}, {"file_name": "migrated_image.png", "id": "947262619023614", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_452716225467712_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3LGxCqP4SdMQ7kNvgFt33NE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjZnUhWwtOGP9v9XbsGuN7n&oh=00_AYB4-u86NdCQiD_R2JDz44jHRt1wwMpQYslm6hdkeD-IIA&oe=66D45A50"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lH5b_08vTiUQ7kNvgEsbWYo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjZnUhWwtOGP9v9XbsGuN7n&oh=00_AYB8gPFbO6F2yaKCictYOxa-r3dNEg6EEL0COtDggOKctQ&oe=66D4644F"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B2qwv8lC-jAQ7kNvgEPEeKm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjZnUhWwtOGP9v9XbsGuN7n&oh=00_AYDUZIrQKELjwrfZuBoiG6tltLIjsDQLoXoGpdWouuJ6HA&oe=66D44528"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n