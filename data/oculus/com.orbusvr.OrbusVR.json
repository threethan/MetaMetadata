e.png", "id": "214408899675212", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974671_328546094638106_6828830509800357888_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GBumvItr9HMQ7kNvgFx29Fq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5dJ_zNxbnm5A2qI-KDH6Fi4-QJk_cWNSdkYZg6MOunQ&oe=67850FF3"}]}, "id": "347222100814945", "locale": "en_US", "screenshots": [{"file_name": "oculus new highsteppe (1).png", "id": "227499459425949", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031549_227499462759282_2851333166620211535_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LVi9BxWpXqIQ7kNvgGP5S-q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeMHJzJWjzLiJlWro-vQUEv90jJJ_oCfRujqdTVYsT6A&oe=6784E661"}, {"file_name": "Oculus Screenshot Hulthines.png", "id": "335988614777987", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974796_335988618111320_1647239326005047475_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ClBH3QmtLskQ7kNvgHvJ0aX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJNKWafTp_YD6nF0IWam9QPqT5emM_FP46TuEQKgSbIg&oe=6784EBA0"}, {"file_name": "migrated_image.png", "id": "857756697984598", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974491_189606425825822_2068162010134085632_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vbw5G7RX0PEQ7kNvgHsZXd4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArONk5yKX_6OOWIbKGfnPFuIl0i4up6mAW9iWmafccbw&oe=6784FC2D"}, {"file_name": "migrated_image.png", "id": "258679631790134", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035398_3409676112392928_7944265801840721920_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hn-tstUUkMAQ7kNvgEU6EpK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmo5fMbV8MtTcjLQHB0bDTi2cqfilv8KkW4kDLPKuZ1g&oe=67850270"}, {"file_name": "migrated_image.png", "id": "494442034530735", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQBr9AYvUgoQ7kNvgEgtJPp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLny2PcX8JG9qLVYPKiEz1MLiyF91xW5DY-sgmiibQQg&oe=6784EE28"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus trailer cover image 2021.png", "id": "827417904817135", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974493_827417908150468_5632650648744685154_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pJdxDTaX9IwQ7kNvgH1tgVn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaFLB3AAvqMXke_eVe-9mymvcBno1bZlBM1PHTcf09gw&oe=6784F504"}, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy", "multiplayer", "social"], "long_description": "With more than 100+ hours of unique content and a strong in-game community, Orbus is a VR experience like no other!\n\nBattle monsters, race dragons, brew a potion, or kick back at the Highsteppe Tavern and catch up with your favorite adventurers. In OrbusVR, you\u2019ll find everything you love about an MMORPG, including:\n\n\u2022 8 playable classes\n\u2022 Fishing, crafting & artificing\n\u2022 Opt-in World PvP & Battlegrounds\n\u2022 5-player dungeons & 10-player raids\n\u2022 Dungeon queue, group finder & other social features\n\u2022 Frequent free updates with new content\n\u2022 Pet dragons, player trading and more!\n\nThe first MMORPG designed exclusively for room-scale virtual reality, Orbus offers a way for every player to enjoy the game on their terms, whether you prefer group play or flying solo, combat or exploration.\n\nImmerse yourself in a world of discovery. Join the OrbusVR community and start exploring today!", "short_description": "With more than 100+ hours of unique content and a strong in-game community, Orbus is a VR experience like no other!\n\nIn OrbusVR, you\u2019ll find everything you love about an MMORPG, including:\n\n\u2022 8 playable classes\n\u2022 Fishing, crafting & artificing\n\u2022 Opt-in World PvP & Battlegrounds\n\u2022 5-player dungeons & 10-player raids\n\u2022 Dungeon queue, group finder & other social features\n\u2022 Pet dragons, player trading and more!\n\nImmerse yourself in a world of discovery. Join the OrbusVR community today!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://orbusvr.com/account/terms", "developer_terms_of_service_url": "https://orbusvr.com/account/terms", "publisher_name": "Orbus Online LLC", "support_website_url": "https://community.orbusvr.com/", "website_url": "http://orbusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "RPG", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "499903211931603"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974748_385600976853807_8118256512423586150_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mbDp_UgAg5kQ7kNvgGEiLDT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7mHcG_is_mEBrESjHcC_dvxhgUnD_YmQXTVxpMyMzKw&oe=67850624"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "OrbusVR: Reborn", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Role Playing", "id": "821934236779161"}], "release_date": 1558458000, "lastRevision": {"nodes": [{"id": "5678659369