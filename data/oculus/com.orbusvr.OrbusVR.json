2_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZeGuH3t3SnEQ7kNvgF7XhER&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYA04YitWPB40nHT6ql914HPbitgcCarAXTybVetfdND1Q&oe=671250D0"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9DHbO-wKRjgQ7kNvgHcK5At&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYDF3SBNqvUWOJgSXngeMJKlW913GYayIMvuZgPbviRq5w&oe=67125ACF"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7XI4wLKJvr4Q7kNvgFm2-f-&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDcHdnpPzHk1LalhUwnbWoGg-exbOoJ5H6iojDBcplItQ&oe=67123BA8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "short_description": "OrbusVR: Reborn is the first expansion to OrbusVR, th