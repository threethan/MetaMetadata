42034530735", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=muzq-KNUkEEQ7kNvgGpXsS-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYCfxa3fJfexxNm4bOE1Xyt2PwPPb4d8mWQKVLfmkNsTwA&oe=66F14628"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus trailer cover image 2021.png", "id": "827417904817135", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_827417908150468_5632650648744685154_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=30KIiVtTRgUQ7kNvgGImVsK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYC9lpfs8In7eo7_aBWtjP-g_gP0RfCWcwV-KO2kIsAOWw&oe=66F14D04"}, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy", "multiplayer", "social"], "long_description": "With more than 100+ hours of unique content and a strong in-game community, Orbus is a VR experience like no other!\n\nBattle monsters, race dragons, brew a potion, or kick back at the Highsteppe Tavern and catch up with your favorite adventurers. In OrbusVR, you\u2019ll find everything you love about an MMORPG, including:\n\n\u2022 8 playable classes\n\u2022 Fishing, crafting & artificing\n\u2022 Opt-in World PvP & Battlegrounds\n\u2022 5-player dungeons & 10-player raids\n\u2022 Dungeon queue, group finder & other social features\n\u2022 Frequent free updates with new content\n\u2022 Pet dragons, player trading and more!\n\nThe first MMORPG designed exclusively for room-scale virtual reality, Orbus offers a way for every player to enjoy the game on their terms, whether you prefer group play or flying solo, combat or exploration.\n\nImmerse yourself in a world of discovery. Join the OrbusVR community and start exploring today!", "short_description": "With more than 100+ hours of unique content and a strong in-game community, Orbus is a VR experience like no other!\n\nIn OrbusVR, you\u2019ll find everything you love about an MMORPG, including:\n\n\u2022 8 playable classes\n\u2022 Fishing, crafting & artificing\n\u2022 Opt-in World PvP & Battlegrounds\n\u2022 5-player dungeons & 10-player raids\n\u2022 Dungeon queue, group finder & other social features\n\u2022 Pet dragons, player trading and more!\n\nImmerse yourself in a world of discovery. Join the OrbusVR community today!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://orbusvr.com/account/terms", "developer_terms_of_service_url": "https://orbusvr.com/account/terms", "publisher_name": "Orbus Online LLC", "support_website_url": "https://community.orbusvr.com/", "website_url": "http://orbusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "961172191044986"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "RPG", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "499903211931603"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974748_385600976853807_8118256512423586150_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RGe0Gwz_Y7IQ7kNvgHzfeHh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHf1ciKYBjKRklsWSi4IN9G&oh=00_AYCsQNb6w7O40Ml84tw2xwZ1yD7hLtSbzIYfwBKbWmNhBg&oe=66F15E24"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "OrbusVR: Reborn", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GA