scdn.com/v/t64.5771-25/39031403_401605603726667_996092281326927872_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L3HxDjSMfpkQ7kNvgHZXRJa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlrqxqyvQP3qZhaUoTQcTHv&oh=00_AYAHK4M4F_JsjoUTFXpZBtc0uZ_I0ralzPs_eALlF0sz2A&oe=66F53F7E"}, {"file_name": "migrated_image.png", "id": "947262619023614", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_452716225467712_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DA3Yr72qm5sQ7kNvgHTll7C&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlrqxqyvQP3qZhaUoTQcTHv&oh=00_AYDFmXEu5oDB4CVjXS9GYQSLz6CSwm_sTs_fYzGYKLkJTg&oe=66F54FD0"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R1VkuNvSC2kQ7kNvgFG63ZJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlrqxqyvQP3qZhaUoTQcTHv&oh=00_AYBC7_rULMk5RlFUVWFrudh5biMk6gAkkCVx22p8VraXdw&oe=66F559CF"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OvMzY-qKc5oQ7kNvgFT3I-B&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlrqxqyvQP3qZhaUoTQcTHv&oh=00_AYB2wZIqps5usux4H3YQVZQXSVXFjBBkYrFCdyZkNfLJdg&oe=66F53AA8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "short_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://orbusvr.com/account/terms", "developer_terms_of_service_url": "https://orbusvr.com/account/terms", "publisher_name": "Orbus Online LLC", "support_website_url": null, "website_url": "http://orbusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "RPG", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "489736062496330"}}]}, "scheduled_offers": {"count": 35, "nodes": [{"status": "PUBLISHED", "id": "1582053885921957"}, {"status": "PUBLISHED", "id": "368228468014353"}, {"status": "PUBLISHED", "id": "399483258487776"}, {"status": "PUBLISHED", "id": "707823223106641"}, {"status": "PUBLISHED", "id": "847024076969466"}, {"status": "PUB