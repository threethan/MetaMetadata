.5771-25/38982618_452716225467712_3332829677495517184_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ts1h7v5wQc8Q7kNvgF48ZyM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBhVCsKb2b8mLsuoy8hzGkgai7Tr_DT7hY22h92ms4n5Q&oe=67261750"}, {"file_name": "migrated_image.png", "id": "662078737929034", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984471_637132083379735_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MBnlYSjv_usQ7kNvgGdxaos&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYADn5abi0xZRVjMwkchiWiqETlBDIhTUlCNJbgbxsGN2Q&oe=6726214F"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J-HK4vPiWQYQ7kNvgGcfSBq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA-2XwC5dB11L4DN8WApVK9nUxf4xdXlmt75d_OYbQ1Og&oe=67260228"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "short_descripti