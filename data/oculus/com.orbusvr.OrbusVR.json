35_4454674611224707072_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lbg3Go6V4Q8Q7kNvgFRkcYm&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-Qfiv_WqlNRVnjGB88TsuXwsXqN9ep3RoKsynoRC2qQ&oe=66F94E4F"}, {"file_name": "migrated_image.png", "id": "1039857279719465", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_340080463310202_5791885663490015232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4sUfPWeKa6IQ7kNvgEnm4aM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjCGAs90luLt907RYrOFFuh_Fj7RlTYK3p0DeoV8keag&oe=66F92F28"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "OrbusVR: Reborn", "keywords": ["mmorpg", "mmo", "fantasy"], "long_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more! A ground-up re-imagining of the original game, Reborn features gorgeous hand-painted visuals, improved performance and stability, and a host of new features, including: \n\u2022 4 NEW playable classes \n\u2022 Opt-in World PvP & Battlegrounds \n\u2022 Honor Ranks and Title System \n\u2022 NEW enemies, featuring improved monster AI \n\u2022 NEW activities, including airship adventures, pet dragon racing, public events and more \n\u2022 100+ hours of content, including weekly missions Immerse yourself in a world of discovery. \n\nJoin the OrbusVR community today.", "short_description": "OrbusVR: Reborn is the first expansion to OrbusVR, the only MMORPG designed exclusively for room-scale virtual reality. It features everything you love about an MMO: a huge open world, hundreds of hours of quests, dragon pets, five-player group dungeons, ten-player Raids, voice chat, player trading, and more!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://orbusvr.com/account/terms", "develop