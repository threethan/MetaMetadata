dYIP3&oh=00_AYAdLmoEGFXL_y4z3oloLSuQA55OfE9ztnnYIIPTvihp8w&oe=66F55189"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AEVR Thumbnail 1440.png", "id": "577468500991687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222946_577468504325020_3404596672138950381_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TMbHyOi2WzAQ7kNvgF-WIrV&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJBdPVKaXaH1oydNpdYIP3&oh=00_AYBwN_PVzoOx6PRdIxfzD9pzODevJjzkhqs4DuOFeU5LYw&oe=66F537BE"}, "display_name": "Amid Evil", "keywords": ["retro", "shooter", "adventure", "magic", "fantasy"], "long_description": "A retro FPS for the ages! Completely rebuilt from the ground up for VR! Once branded a HERETIC. Now YOU have been chosen as our champion! Reclaim our sacred weapons. Take back our ancient lands. If you can stand... AMID EVIL.\n\nSEVEN distinct episodes each featuring a completely different setting and enemies\n\nLUDICROUS magical weaponry that can be overcharged with the souls of the dead and used in either hand\n\nBRUTAL and adaptive enemy AI that will hunt you down on land, sea and air\n\nSPRAWLING non-linear levels filled with secrets and ancient lore\n\nMULTITUDES of in-game options + cheat codes for a truly golden PC age experience\n\nEPIC original & dynamic soundtrack composed by Andrew Hulshult\n\nBUILT in Unreal Engine 4 for cutting edge visuals (even if they are a bit retro)\n", "short_description": "A retro FPS for the ages! Completely rebuilt from the ground up for VR! \n\nOnce branded a HERETIC. Now YOU have been chosen as our champion! Reclaim our sacred weapons. Take back our ancient lands. If you can stand... AMID EVIL."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.generateprivacypolicy.com/live.php?token=LC4UIkFE7ZzKHqTYo4kRhS9Y1vPqFyt9", "developer_terms_of_service_url": null, "publisher_name": "New Blood Interactive", "support_website_url": null, "website_url": "http://NewBlood.games/", "category": null, "comfort_rating": "