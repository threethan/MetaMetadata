 LIFE!!!44! is a climbing game, where you have to earn the top of the towers. If you want to get to the top of the towers, you have to overcome obstacles, and have to be fast, because something is coming from the bottom what kills you.\n\nIf you want to beat your friends' or other oculus users' time, you can do that if you are fast enough, because all of the towers have Leaderboard. So conquer all the towers! Show that you are the fastest tower climber!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.facebook.com/bandnclimbgame/posts/263625351840411", "developer_terms_of_service_url": null, "publisher_name": "B&N", "support_website_url": null, "website_url": "https://www.facebook.com/bandnclimbgame/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SPORTS", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "747842682982680"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451778_895145221235517_4324801935935577433_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FWlMyyOz0VQQ7kNvgG1cD9r&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8HHlyNJOS-Sw3GumHe5gXZT7PlYm4sIIzaiuB5WVmXg&oe=67051A05"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CLIMB FOR YOUR LIFE!!!44!", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1657570238, "lastR