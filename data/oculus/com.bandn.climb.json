2faM2tow&oe=67261B8E"}, "display_name": "CLIMB FOR YOUR LIFE!!!44!", "keywords": [], "long_description": "CLIMB FOR YOUR LIFE!!!44! is a climbing game, where you have to earn the top of the towers. If you want to get to the top of the towers, you have to overcome obstacles, and have to be fast, because something is coming from the bottom what kills you.\n\nIf you want to beat your friends' or other oculus users' time, you can do that if you are fast enough, because all of the towers have Leaderboard. So conquer all the towers! Show that you are the fastest tower climber!\n\nFuture plans:\n- more towers in every patch\n- multiplayer climbing(climb in same tower in same time with your friend)", "short_description": "CLIMB FOR YOUR LIFE!!!44! is a climbing game, where you have to earn the top of the towers. If you want to get to the top of the towers, you have to overcome obstacles, and have to be fast, because something is coming from the bottom what kills you.\n\nIf you want to beat your friends' or other oculus users' time, you can do that if you are fast enough, because all of the towers have Leaderboard. So conquer all the towers! Show that you are the fastest tower climber!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.facebook.com/bandnclimbgame/posts/263625351840411", "developer_terms_of_service_url": null, "publisher_name": "B&N", "support_website_url": null, "website_url": "https://www.facebook.com/bandnclimbgame/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SPORTS", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devi