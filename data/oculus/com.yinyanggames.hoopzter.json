74672_959851465006143_7734013650343168798_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wqPkAvJA5VEQ7kNvgE7q2Ci&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6I1ARZp5heUS-id0eqdoSw&oh=00_AYDWTtTzSOyRVHb_-MAw20bG2QR2bAYnuu_SuXwCEcyMnQ&oe=66CD9D70"}, {"file_name": "Shooting.png", "id": "182631081203983", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982460_182631084537316_1848639894827762231_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SbDygbFtjYUQ7kNvgFIT4cf&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6I1ARZp5heUS-id0eqdoSw&oh=00_AYDbrbYQJaCuYLk2hOfv2NGI9vB56Wsm758Nme65fCRICg&oe=66CD9DD4"}, {"file_name": "ScoreOnOpponent.png", "id": "173079792228840", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982492_173079795562173_1707894542075726949_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hm3C5OYvCr0Q7kNvgHYoPWn&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6I1ARZp5heUS-id0eqdoSw&oh=00_AYBmYg9uzYPxEZ_QckYkIbctQuqmzDA49xZVB5EjNo6AXg&oe=66CDB4CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thubmail.png", "id": "170432322496758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404379_170432325830091_7462892159789990450_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PFYEX0z2A3oQ7kNvgGzc3fI&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6I1ARZp5heUS-id0eqdoSw&oh=00_AYDo23S1BCMv6_DKftEKbRIh8K5L_5ae1SvX0WBuBO-Tpg&oe=66CDC0A6"}, "display_name": "Hoopzter", "keywords": [], "long_description": "Hone your skills and experience basketball like never before with VR Hoopzter! Choose from a variety of courts, including indoor arenas, outdoor stadiums, and street courts, to compete in 1v1, 2v2, and 3v3 modes. Whether you're a seasoned veteran or a beginner, our intuitive controls make it easy to learn and play.\n\nSelect your favorite ball from over 10 unique options to fit your style and play with confidence. With voice chat, you can communicate with your teammates in real-time, making the game even more immersive. If you're looking for a unique challenge, try our popular \"horse\" mode, where you can test your creativity and skill by taking difficult shots.\n\nVR Hoopzter is perfect for basketball fans and gamers alike. With customizable meta avatars and exciting game modes, you'll never run out of fun and challenges. Experience the thrill of basketball like never before with VR Hoopzter!", "short_description": "Experience basketball like never before with Hoopzter! \nPlay 1v1, 2v2, or 3v3 modes and use precision to shoot, dunk, block, and score three-pointers. \nPlay with your meta avatars and choose from a variety of more than 10 balls to use, each with its unique style. \nEnjoy intuitive controls suitable for all ages and skill levels, and engage with our VR technology to feel like you're on the court. \nGet VR Hoopzter today!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/982a8b6e-42f3-4ff0-8814-941862321cc7", "developer_terms_of_service_url": null, "publisher_name": "Ying Yang Games", "support_website_url": null, "website_url": "http://hoopzter.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1854267444951444"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "512678304449182"}, {"status": "PUBLISHED", "id": "769422711438386"}]}, "baseline_offer": {"id": "769422711438386"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time