84_4851829360922148825_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ah5E9E2vAqQQ7kNvgGgnjId&_nc_ht=scontent.oculuscdn.com&oh=00_AYCivP3fBLmhyfmjOnc7zZwAodvX6mom0msViz5INZYhng&oe=66E2D101"}, {"file_name": "38982693_823121502585453_4016638522269531593_n.png", "id": "992798165813213", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974549_992798172479879_1075127351998908857_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dRt4WURI_fEQ7kNvgGbJ32k&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnT5zw1UpaLgNp5ZCEGSMQqxwprMbW9f9eDSxiworN0g&oe=66E2E6B5"}, {"file_name": "38974821_798556975587001_3718101858904573018_n.png", "id": "1021897726156704", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974695_1021897729490037_8637593546140586569_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iCZLdoBPakAQ7kNvgElIepG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAkvFX-R-2E0iovn6SAnlbubDQIdw5aUKZZXmuQZdAwnw&oe=66E2E20C"}, {"file_name": "38974695_3811050085808370_5417121639385648853_n.png", "id": "2016230285496520", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210390_2016230288829853_7647887637724098147_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AD0J3V1WZ5wQ7kNvgFwEe_3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDN2j7rR34RsvPyWdCaOQbv7Exylkzgh0XLJyc28cbBpg&oe=66E2DD23"}, {"file_name": "image_2024-07-26_114011891.png", "id": "512211704669651", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035445_512211708002984_1040454059113550023_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h175ndTo4NcQ7kNvgH46UQy&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGloBjNW0LWjXCs9xvncPKwMGFGZULXistL_3Pb3R9jA&oe=66E2C05D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_2024-08-22_011057453.png", "id": "508718514902566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367587_508718521569232_1225849325549550734_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RxMLNSBX2cQ7kNvgGxVB8A&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCWEv4IYnWlTUSCpE5REMOkmCrZJPAcXRSA3LGGXF25g&oe=66E2C5E9"}, "display_name": "Project Ape", "keywords": [], "long_description": "Embark on a thrilling adventure with Project Ape, an Action game that unfolds in a captivating canyon environment. Monkeys, known for their unique hand-based movement, are pursued by infected lava monkeys aiming to tag and eliminate them. As the chase intensifies, the game offers diverse settings like a Jungle-like Forest, a City with quirky hats, and a spooky Cave with lurking ghosts. Each environment presents unique challenges and experiences, enhancing the excitement and strategy of the game. Monkey Runners tag isn't just a game; it's an immersive journey into a world of action and suspense, where players must outwit their foes to emerge victorious.", "short_description": "Project Ape is a fun action game set in a Canyon environment where monkeys who move with their hands are chased by infected lava monkeys which try to tag the normal monkeys until there is none left. There is alternative environments like a jungle-like forest, a city map with hats and a cave with a scary mine where ghosts lurk."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/project-ape/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/project-ape/terms-of-service", "publisher_name": "MitrixStudios", "support_website_url": null, "website_url": "https://sites.google.com/view/project-ape", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH