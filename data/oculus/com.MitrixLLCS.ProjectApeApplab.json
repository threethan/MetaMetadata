moR1Qseq96fVR8ABQqeTw&oe=66E957DD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_2024-08-22_011057453.png", "id": "508718514902566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367587_508718521569232_1225849325549550734_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=85qOOLf2fp8Q7kNvgFIXWhP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP7VKGBvBEJ8erBzTh7An0Q&oh=00_AYBzqj8krarpM3XkhudsahLCsb2BBFqVeHGGyMGK5EpPlg&oe=66E95D69"}, "display_name": "Project Ape", "keywords": [], "long_description": "Embark on a thrilling adventure with Project Ape, an Action game that unfolds in a captivating canyon environment. Monkeys, known for their unique hand-based movement, are pursued by infected lava monkeys aiming to tag and eliminate them. As the chase intensifies, the game offers diverse settings like a Jungle-like Forest, a City with quirky hats, and a spooky Cave with lurking ghosts. Each environment presents unique challenges and experiences, enhancing the excitement and strategy of the game. Monkey Runners tag isn't just a game; it's an immersive journey into a world of action and suspense, where players must outwit their foes to emerge victorious.", "short_description": "Project Ape is a fun action game set in a Canyon environment where monkeys who move with their hands are chased by infected lava monkeys which try to tag the normal monkeys until there is none left. There is alternative environments like a jungle-like forest, a city map with hats and a cave with a scary mine where ghosts lurk."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/project-ape/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/project-ape/terms-of-service", "publisher_name": "MitrixStudios", "support_website_url": null, "website_url": "https://sites.google.com/view/project-ape", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "conte