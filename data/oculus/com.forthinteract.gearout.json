1440.png", "id": "679080253601432", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001703_679080256934765_5244425530880622471_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w9oNbVdHNu8Q7kNvgFmo6u3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD0924LrkLn2lCrJ8bbjhK94k3o3k9mIVJLm3QTc-oZPw&oe=6776987E"}, {"file_name": "gearOut_skeleton_in_coffin_2560x1440.png", "id": "657440632790719", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75303837_657440636124052_7175170353512171189_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rgadFh2mzfEQ7kNvgGpO3gT&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBgxD0iuxpv3Z457x1Oz68cDm5RTCh3JoslSPb7smZ5NA&oe=67768A30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_2560_1440.png", "id": "573593934780293", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974744_573593938113626_499325477876599777_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gWFMFZUktewQ7kNvgEvIutb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYClRltaKGkiMoE_U4H7BqoPwu1SykKVF85dch3GMLPQig&oe=67766A0F"}, "display_name": "Gear Out", "keywords": [], "long_description": "Explore the underground caves, find the gears and solve the puzzles to escape. \nGear Out is a tense and immersive interactive puzzle game set underground. You must search for gears, interact with obstacles and arrange the gears on spindles to open the door to the next level. But beware, you\u2019re not always in there alone.\nThere are 13 levels of increasing difficulty. Some have time limits, some have additional challenges. Each level can be randomized to produce up to 9,999 variants of the puzzle for extended play time.\nPlayable from seated, standing or room scale environments. Also playable with either one or both controllers.\n", "short_description": "Explore the underground caves, find the gears and solve the puzzles to escape. But beware, you\u2019re not always in there alone."}]}, "developer_name": null, "de