t=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bvOHQzDvp8EQ7kNvgHEVt0T&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACS88PgHUzA_lEgV2Tlh_1d&oh=00_AYDyh5UGYA79nmEWTYX2D8wFISsQHdPUUblJ7S5J2NiS5A&oe=66ED4D01"}, "display_name": "Gear Out", "keywords": [], "long_description": "# Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game.\nExplore the creepy environments and solve challenging puzzles to escape to the next level. But watch out - you're not always in there alone!\n\n{793570542745458}\n\nNavigate through 26 different environments, solving problems and interacting with obstacles to locate gears. Arrange the gears on the final puzzles to open the door and escape to the next level.  \n\n{1137153677435027}\n\nEach level can be randomised to generate up to **9,999** puzzle variations for extended game play. Explore caves, tunnels, underwater, basements, drains, industrial areas and offices. Interact with doors, wheels, cranes, levers, buttons, hatches, drawers, lockers, wall-bashing hammers and more. The scale of each level varies from single rooms to expansive complexes and mazes.\n\n{1795887044254758}\n\nControls are fully customizable to your specific preference. Play seated, standing or room-scale with one or both controllers.\n\n# To succeed at Gear Out, you need to be smart and brave. Ready to put yourself to the test?  Install Gear Out now.", "short_description": "Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http://forwardthinkinginteractive.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Forward Thinking Interactive", "support_website_url": "http://forwardthinkinginteractive.com/contact", "website_url": "http://forwardthinkinginteractive.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context