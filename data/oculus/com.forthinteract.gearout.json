18928253", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036639_763694222261586_5683049531970248567_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q3xHSWKs5AsQ7kNvgFt-5zQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAjh7ZfkAuQ2vKLLeUXV25YZirmmZLY5gK73M5-b7qgA&oe=66FD17E0"}, {"file_name": "hatches_2560_1440.png", "id": "748705700454894", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297582_748705703788227_1181917996033779433_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VOj8pWiwrpEQ7kNvgHQ70sw&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaPntEYiYg5p7l0M_Ctg8kp5ECM-cJ8RtR_xPKjMu20w&oe=66FD298A"}, {"file_name": "metalGearPlace_2560_1440.png", "id": "682450700437153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031363_682450703770486_3475114188374750327_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PZ_cmaRT7UoQ7kNvgHrtBhr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtaRNxWJ_hmHWkMhLGZhmPkzj2YC7EkKCNXpQIOIcd7w&oe=66FD49AB"}, {"file_name": "coffinSkeleton_2560_1440.png", "id": "357715490193772", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_357715496860438_3229979792850571367_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KouzS6W54ykQ7kNvgHcYGoz&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCDKIho8tCDl3o74EHse0hdIPF_dLQzExYgqMoco_Hcw&oe=66FD2098"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_2560_1440_v2.png", "id": "1533784720732743", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75355156_1533784727399409_5559420013389731690_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tuQFbgNaFkMQ7kNvgE5sGbA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBG2qgDIfpPIWbjAJ6hVxY3A8zpDbWR1MYuTXNsYBZCfQ&oe=66FD1F01"}, "display_name": "Gear Out", "keywords": ["puzzle", "puzzles", "escape", "room", "creepy"], "long_description": "# Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game.\nExplore the creepy environments and solve challenging puzzles to escape to the next level. But watch out - you're not always in there alone!\n\n{793570542745458}\n\nNavigate through 26 different environments, solving problems and interacting with obstacles to locate gears. Arrange the gears on the final puzzles to open the door and escape to the next level.  \n\n{1137153677435027}\n\nEach level can be randomised to generate up to **9,999** puzzle variations for extended game play. Explore caves, tunnels, underwater, basements, drains, industrial areas and offices. Interact with doors, wheels, cranes, levers, buttons, hatches, drawers, lockers, wall-bashing hammers and more. The scale of each level varies from single rooms to expansive complexes and mazes.\n\n{1795887044254758}\n\nControls are fully customizable to your specific preference. Play seated, standing or room-scale with one or both controllers.\n\n# To succeed at Gear Out, you need to be smart and brave. Ready to put yourself to the test?  Install Gear Out now.", "short_description": "Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http://forwardthinkinginteractive.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Forward Thinking Interactive", "support_website_url": "http://forwardthinkinginteractive.com/contact", "website_url": "http://forwardthinkinginteractive.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "es", "ko", "cy"], "supported_input_devices": ["OCULUS_TOUCH"], "support