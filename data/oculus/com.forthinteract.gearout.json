18928253", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036639_763694222261586_5683049531970248567_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wmjOYzi9QQIQ7kNvgF_Lt8V&_nc_ht=scontent.oculuscdn.com&oh=00_AYBl6XJRehleDE-5oRnertmCPG3PyDzhH0Vwwke9LqKKPQ&oe=66E95160"}, {"file_name": "hatches_2560_1440.png", "id": "748705700454894", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297582_748705703788227_1181917996033779433_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q0yZDNZTsdQQ7kNvgEJg9I9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnttF1GEY--EOmLksMWAzI__OqAh85NJ3rKgJIEjSlNA&oe=66E9630A"}, {"file_name": "metalGearPlace_2560_1440.png", "id": "682450700437153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031363_682450703770486_3475114188374750327_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=57iMqdtdQT4Q7kNvgGs7X2n&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEv4Mxs63RRtSWF07pf-Nt2lJjREjfh57bLvp9WH5nOg&oe=66E9832B"}, {"file_name": "coffinSkeleton_2560_1440.png", "id": "357715490193772", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_357715496860438_3229979792850571367_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8aj1x8WZzaIQ7kNvgFUdZRY&_nc_ht=scontent.oculuscdn.com&oh=00_AYAG7ufZrXLqOZdSd1RMdxJNS8lfgTcOLK75B8zSjHrkKA&oe=66E95A18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_2560_1440_v2.png", "id": "1533784720732743", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75355156_1533784727399409_5559420013389731690_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-FJ7d9sdvegQ7kNvgESc87q&_nc_ht=scontent.oculuscdn.com&oh=00_AYB1xnrNDm0MCTcn2o8F4mZ9FTqu8FibMeyJs1-pmzUANg&oe=66E95881"}, "display_name": "Gear Out", "keywords": [], "long_description": "# Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game.\nExplore the creepy environments and solve challenging puzzles to escape to the next level. But watch out - you're not always in there alone!\n\n{793570542745458}\n\nNavigate through 26 different environments, solving problems and interacting with obstacles to locate gears. Arrange the gears on the final puzzles to open the door and escape to the next level.  \n\n{1137153677435027}\n\nEach level can be randomised to generate up to **9,999** puzzle variations for extended game play. Explore caves, tunnels, underwater, basements, drains, industrial areas and offices. Interact with doors, wheels, cranes, levers, buttons, hatches, drawers, lockers, wall-bashing hammers and more. The scale of each level varies from single rooms to expansive complexes and mazes.\n\n{1795887044254758}\n\nControls are fully customizable to your specific preference. Play seated, standing or room-scale with one or both controllers.\n\n# To succeed at Gear Out, you need to be smart and brave. Ready to put yourself to the test?  Install Gear Out now.", "short_description": "Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http://forwardthinkinginteractive.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Forward Thinking Interactive", "support_website_url": "http://forwardthinkinginteractive.com/contact", "website_url": "http://forwardthinkinginteractive.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "es", "ko", "cy"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27102853095972452"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001704_357378243353775_5175380407402905139_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bJd90S2_BuUQ7kNvgFRzhAd&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpQJCAt_EJU53Mnv0-3j-ZfBDEBJkMIsnb49fQOrjHAw&oe=66E973B2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gear Out", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1674172800, "lastRevision": {"nodes": [{"id": "8766954853322222", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8766954653322242", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "6500922859958364"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Meta_2560_1440.png", "id": "5879389988785426", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974681_5879389995452092_1461923416627946944_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=07AQxadxDAYQ7kNvgF_BDAB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDG_u8ejCkHfXCz4CrUo4BA-Cxt5R-tunrEsZSfElgqEw&oe=66E95D28"}, {"file_name": "Meta_icon_512_512.png", "id": "3010465522594923", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974798_3010465525928256_400137434428356198_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UhGuF31h2B4Q7kNvgHF0qCV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJBeYkHwhLqG0SYozezqm1ayG7m