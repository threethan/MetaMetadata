80256934765_5244425530880622471_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vfIMlMSw-C0Q7kNvgHvs7pG&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACS88PgHUzA_lEgV2Tlh_1d&oh=00_AYB7AYG5Mee05wdzpLtqlLi2GV7liwVpgDhGaVCQO5tXuA&oe=66ED443E"}, {"file_name": "gearOut_skeleton_in_coffin_2560x1440.png", "id": "657440632790719", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75303837_657440636124052_7175170353512171189_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uYQIfjhRc5sQ7kNvgE0ew3n&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACS88PgHUzA_lEgV2Tlh_1d&oh=00_AYCxPoT1cpNtgbC7hlggRLDCzVolkTE6kLIG8-WM8DeGeA&oe=66ED6E30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_2560_1440.png", "id": "573593934780293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974744_573593938113626_499325477876599777_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=legY0rLWM00Q7kNvgGFB3-1&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACS88PgHUzA_lEgV2Tlh_1d&oh=00_AYCLL942oI9uwGZIB0U-V0E_A7HieZeoCPwyQigSaUu9Cw&oe=66ED4E0F"}, "display_name": "Gear Out", "keywords": [], "long_description": "Explore the underground caves, find the gears and solve the puzzles to escape. \nGear Out is a tense and immersive interactive puzzle game set underground. You must search for gears, interact with obstacles and arrange the gears on spindles to open the door to the next level. But beware, you\u2019re not always in there alone.\nThere are 13 levels of increasing difficulty. Some have time limits, some have additional challenges. Each level can be randomized to produce up to 9,999 variants of the puzzle for extended play time.\nPlayable from seated, standing or room scale environments. Also playable with either one or both controllers.\n", "short_description": "Explore the underground caves, find the gears and solve the puzzles to escape. But beware, you\u2019re not always in there alone."}]}, "developer_name": null, "developer_privacy_policy_url": "http://forwardthinkinginteractive.com/privacy