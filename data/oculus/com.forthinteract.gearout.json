46373776562963_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HpbIOFzSDSAQ7kNvgGQm9ZC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3nIUt6oLz_pD7h7NHZZSTBaunPmV37QmhGgmnc1Ekmg&oe=672DEA84"}, {"file_name": "mummy_2560_1440.png", "id": "763694218928253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036639_763694222261586_5683049531970248567_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B1-a59lhWFsQ7kNvgG8wR97&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhCUFRPogz2hdEyM752GhAaWj_ZWf4LC8Qp4hDsc-yRg&oe=672DDF60"}, {"file_name": "hatches_2560_1440.png", "id": "748705700454894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297582_748705703788227_1181917996033779433_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LzleQ-5md64Q7kNvgHEcIko&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtrCTZsq3uFVF-9zOcq2mb50oEWhkIjqdspi-fccam2g&oe=672DF10A"}, {"file_name": "metalGearPlace_2560_1440.png", "id": "682450700437153", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031363_682450703770486_3475114188374750327_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4WU8Yh9ibmsQ7kNvgFXGxfe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGOFFPzKjHP-qoUPlsAbvNgREglJK3TbA7ZpB-ZIwqLA&oe=672E112B"}, {"file_name": "coffinSkeleton_2560_1440.png", "id": "357715490193772", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982548_357715496860438_3229979792850571367_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PseEWWlW1IMQ7kNvgGE71DD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9FVs4vwO9dIOqHg1vSm_UCL7RI5R-rSjEKId5Uh_Ihw&oe=672DE818"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_2560_1440_v2.png", "id": "1533784720732743", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75355156_1533784727399409_5559420013389731690_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WWiyg4doElQQ7kNvgE120NG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCfk_IF-aqjFVXerkwctr90vrFl5eExN02ei-Zzks6Ddw&oe=672DE681"}, "display_name": "Gear Out", "keywords": ["puzzle", "puzzles", "escape", "room", "creepy"], "long_description": "# Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game.\nExplore the creepy environments and solve challenging puzzles to escape to the next level. But watch out - you're not always in there alone!\n\n{793570542745458}\n\nNavigate through 26 different environments, solving problems and interacting with obstacles to locate gears. Arrange the gears on the final puzzles to open the door and escape to the next level.  \n\n{1137153677435027}\n\nEach level can be randomised to generate up to **9,999** puzzle variations for extended game play. Explore caves, tunnels, underwater, basements, drains, industrial areas and offices. Interact with doors, wheels, cranes, levers, buttons, hatches, drawers, lockers, wall-bashing hammers and more. The scale of each level varies from single rooms to expansive complexes and mazes.\n\n{1795887044254758}\n\nControls are fully customizable to your specific preference. Play seated, standing or room-scale with one or both controllers.\n\n# To succeed at Gear Out, you need to be smart and brave. Ready to put yourself to the test?  Install Gear Out now.", "short_description": "Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http://forwardthinkinginteractive.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Forward Thinking Interactive", "support_website_url": "http://forwardthinkinginteractive.com/contact", "website_url": "http://forwardthinkinginteractive.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [