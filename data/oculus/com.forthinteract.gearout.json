46373776562963_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ary2Ah_MePsQ7kNvgHOpQnu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBFWJgXpuR6KpxUHOQOBEE--0o0_f3C6SfCMdewa8Si9Q&oe=67693E04"}, {"file_name": "mummy_2560_1440.png", "id": "763694218928253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036639_763694222261586_5683049531970248567_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1bWP-7N29M4Q7kNvgFnI0dv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ-D5cgoOLJW981GA4cvT6HWEKtnurdaCbMv8tkePWLQ&oe=676932E0"}, {"file_name": "hatches_2560_1440.png", "id": "748705700454894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297582_748705703788227_1181917996033779433_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e-KH3whTrbcQ7kNvgEUdHEi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHRyHSVQI6XTriUjuKOwrAfD-ndxKFg0zfoF_WbQdFVg&oe=6769448A"}, {"file_name": "metalGearPlace_2560_1440.png", "id": "682450700437153", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031363_682450703770486_3475114188374750327_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vq1iSn1OonIQ7kNvgHYVTke&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAuEo7KTuMz5kRQTmlD-sq3lqVQLs-hrNaiUUkk1pGqQQ&oe=676964AB"}, {"file_name": "coffinSkeleton_2560_1440.png", "id": "357715490193772", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982548_357715496860438_3229979792850571367_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DoHIlL6tsUMQ7kNvgF0FHl7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCmdoKnK8EuKhSgaLK4bnjPp1JYL3diDb1D5vGuNOSWQ&oe=67693B98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_2560_1440_v2.png", "id": "1533784720732743", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75355156_1533784727399409_5559420013389731690_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2qQ0_oVqGesQ7kNvgF8JZr2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQPJH1anqr5wBA6bqbI6VWiEoLBP1rLV-wkKoQ5YEfAQ&oe=67693A01"}, "display_name": "Gear Out", "keywords": ["puzzle", "puzzles", "escape", "room", "creepy"], "long_description": "# Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game.\nExplore the creepy environments and solve challenging puzzles to escape to the next level. But watch out - you're not always in there alone!\n\n{793570542745458}\n\nNavigate through 26 different environments, solving problems and interacting with obstacles to locate gears. Arrange the gears on the final puzzles to open the door and escape to the next level.  \n\n{1137153677435027}\n\nEach level can be randomised to generate up to **9,999** puzzle variations for extended game play. Explore caves, tunnels, underwater, basements, drains, industrial areas and offices. Interact with doors, wheels, cranes, levers, buttons, hatches, drawers, lockers, wall-bashing hammers and more. The scale of each level varies from single rooms to expansive complexes and mazes.\n\n{1795887044254758}\n\nControls are fully customizable to your specific preference. Play seated, standing or room-scale with one or both controllers.\n\n# To succeed at Gear Out, you need to be smart and brave. Ready to put yourself to the test?  Install Gear Out now.", "short_description": "Gear Out is a unique, tense and completely immersive interactive escape-room puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http://forwardthinkinginteractive.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Forward Thinking Interactive", "support_website_url": "http://forwardthinkinginteractive.com/contact", "website_url": "http://forwardthinkinginteractive.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [