e love in LOVE ON!\n\n\nMiyuki CV(JP) : Monaca Morino\n\nMiyuki CV(KO) : Jimin\n\n\u24d2Songasonga / Novelpia Ltd.", "short_description": "Become the main character in a romantic comedy game.\nSet against the backdrop of a fresh summer, the beautiful love story between two people begins now."}]}, "developer_name": null, "developer_privacy_policy_url": "https://looksten.com/privacy-policy-loveon-first/", "developer_terms_of_service_url": null, "publisher_name": "Looksten Inc.", "support_website_url": null, "website_url": "https://looksten.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7872434239529125"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569433_1211579219989650_3646736908661937800_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Syh5QKMNUDsQ7kNvgHh1PC_&_nc_ht=scontent.oculuscdn.com&_nc_gid=A99gYGu8IDrhqipph3sYzHQ&oh=00_AYAre5lOz8Ef7y6xDH89IcAAY-HhxVsDqXmI7PZ_EvXZAQ&oe=66F6A219"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "LOVE ON: First Story", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Interactive Story", "id": "3771364559549515"}, {"topic_name": "Adventure"