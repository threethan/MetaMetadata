ZkV-4n8Ny88LGg&oe=6771333B"}, {"file_name": "Morels_Homestead_Screenshot_3.png", "id": "275659134453967", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_275659137787300_7521744792157286392_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1fFKObdmnq0Q7kNvgGh_Nt9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsHTj7Hd7hsJHkSJkVLppcEJ93RZEX_Ii7-3NKChnl5Q&oe=6771357E"}, {"file_name": "Morels_Homestead_Screenshot_4.png", "id": "666302984339092", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982515_666302987672425_5867527957476389758_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rGfLTuTCRr4Q7kNvgGIaG-X&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFKphN2RSpV3qLiY9q3AvoAD5DkODPjM4RzIjKOWdeOg&oe=67714F17"}, {"file_name": "Morels_Homestead_Screenshot_5.png", "id": "3065132823815532", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003231_3065132827148865_2057858496466835875_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GDrW-Xl9JdQQ7kNvgGj3aOH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWmSPplerHBlXPHyb2Z3DnL5fTrZnXYGH7x-ax8XKZEw&oe=67712EA3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Morels_Homestead_Artwork.png", "id": "274802414530877", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75322605_274802417864210_6655069468533852729_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qbe3JVXpHoMQ7kNvgHL-BkB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEQA8ADVW5vmDr_VMdaQ6RBQjkMu5kBMrD6fGKG6KMZg&oe=67713AAC"}, "display_name": "Morels: Homestead", "keywords": ["Sandbox", "Farming", "Exploration", "Adventure", "Nature"], "long_description": "In this sandbox VR adventure you'll start with a blank canvas of empty land.  Explore levels from many environments and find hundreds of unique items to keep for yourself or trade to grow your homestead into whatever you wish.  Grow and harvest crops, hunt for the elusive Morel mushroom, and find rarities to give you valuable commodities for trade.  Use your metal detector and trusty shovel to find and secure many different treasures.  Let out your inner nature enthusiast and photograph beautiful and sometimes rare animals.  The path you take is yours to choose.  Every homestead will be unique.  What will you create?", "short_description": "Build your very own homestead in this sandbox VR adventure.  Grow and harvest crops, explore and dig up treasure, trade and sell your way to glory as you grow your homestead into the something amazing."}]}, "developer_name": null, "developer_privacy_policy_url": "http://morelshomestead.com/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Abrams Studios LLC", "support_website_url": "http://forum.morelshomestead.com/", "website_url": "http://www.morelshomestead.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "fr", "ko", "es_AR"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3078519945695804"}}]}, "scheduled_offers": {"count": 15, "nodes": [{"status": "PUBLISHED", "id": "1110367897136586"}, {"status": "PUBLISHED", "id": "1012056280716461"}, {"status": "PUBLISHED", "id": "1602208483689194"}, {"status": "PUBLISHED", "id": "751232833526766"}, {"status": "PUBLISHED", "id": "242741591096194"}, {"status": "CANCELLED", "id": "393752200322701"}, {"status": "PENDING", "id": "589203923144