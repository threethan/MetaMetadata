nc_ohc=4GJ0EqsdOGsQ7kNvgEN-rbP&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkn-Ng931-fYGt7FQyA6PM9XkmvuAxuXVQiLz7cZ-iLA&oe=66D1A57C"}]}, "id": "762354612172790", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_01_2560X1440.png", "id": "118627084507952", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422379_118627087841285_6569284289591822443_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RPCkjbeZEwEQ7kNvgEm3dWb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIzPIu-JkAe9BA1iorYd7g8e2hZEEkfqb47xhuLdWXaA&oe=66D1BD93"}, {"file_name": "Screenshot_02_2560X1440.png", "id": "246796514370095", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476597_246796517703428_6670063398055006652_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AjZGXUSewsoQ7kNvgHWB94K&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBW1z5nDsS2NcFo40EPFR3_8c4soOVSUGJEKBKu5djfA&oe=66D1C48E"}, {"file_name": "Screenshot_03_2560X1440.png", "id": "1491932784677073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031346_1491932788010406_577406407159841891_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QgdCqD5nLLcQ7kNvgEffUGt&_nc_ht=scontent.oculuscdn.com&oh=00_AYCp8L_BovcHMQhNBj0jdV7txZJmKFY36BZJsvbok1bfNQ&oe=66D19891"}, {"file_name": "Screenshot_04_2560X1440.png", "id": "170550285385662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031643_170550288718995_4159135805628350243_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aWCQpuWc1HIQ7kNvgG1Dljw&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKf4n57Wprv-wr0TDJWKZQWmuuGnpzqKLjU5OuULnQWA&oe=66D19E27"}, {"file_name": "Screenshot_05_2560X1440.png", "id": "757567075939504", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234365_757567079272837_1193157604052138362_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1wcXZyDhEzEQ7kNvgG3frhL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbqGaNgbtNC4CuCOiQxlAXa0S4eIMk8BlUoS1FnOunaQ&oe=66D1C4F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_02_2560X1440.png", "id": "1414523469084831", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974859_1414523472418164_250160287908959841_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tX34zgiFMkYQ7kNvgHAnGSU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCn7Eb3YBLjD4oFWlDUs5xv76608vOIwaiZ8ETp4O422Q&oe=66D1BEE0"}, "display_name": "VR SUP", "keywords": [], "long_description": "The Virtual Reality Stand Up Paddleboard (SUP) simulation provides a safe environment where anyone can succeed, from the first-time user to the most seasoned paddler. VR SUP brings the watercraft experience to your headset as you paddle across a calm lake. Birds soar above as you explore your surroundings on a clear and warm day. Practice paddling forward and backwards while steering your SUP to the left and right, safely passing ducks and other watercraft along the way. Haptic feedback in each controller reminds you that your virtual paddle has interacted with the water, maximizing each stroke. This experience is ideal for anyone who loves paddleboarding or wants to try it for the first time. It also benefits anyone with phobias looking to face fears and build confidence in a safe, dry, controlled environment. \n\nDon\u2019t forget your personal floatation device (PFD)! \n\nBenefits include: \n\u2022  Realistic watercraft, equipment and environments \n\u2022  Stabilization across the simulation, reducing kayak and wave motion to avoid motion sickness \n\u2022  Paddling skills that can be transferred to real-world SUP ", "short_description": "The Virtual Reality Stand Up Paddleboard (SUP) simulation provides a safe environment where anyone can succeed, from the first-time user to the most seasoned paddler. VR SUP brings the watercraft experience to your headset as you paddle across a calm lake."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://ww