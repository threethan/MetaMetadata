": "757567075939504", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234365_757567079272837_1193157604052138362_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1wcXZyDhEzEQ7kNvgG3frhL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbqGaNgbtNC4CuCOiQxlAXa0S4eIMk8BlUoS1FnOunaQ&oe=66D1C4F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_02_2560X1440.png", "id": "1414523469084831", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974859_1414523472418164_250160287908959841_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tX34zgiFMkYQ7kNvgHAnGSU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCn7Eb3YBLjD4oFWlDUs5xv76608vOIwaiZ8ETp4O422Q&oe=66D1BEE0"}, "display_name": "VR SUP", "keywords": [], "long_description": "The Virtual Reality Stand Up Paddleboard (SUP) simulation provides a safe environment where anyone can succeed, from the first-time user to the most seasoned paddler. VR SUP brings the watercraft experience to your headset as you paddle across a calm lake. Birds soar above as you explore your surroundings on a clear and warm day. Practice paddling forward and backwards while steering your SUP to the left and right, safely passing ducks and other watercraft along the way. Haptic feedback in each controller reminds you that your virtual paddle has interacted with the water, maximizing each stroke. This experience is ideal for anyone who loves paddleboarding or wants to try it for the first time. It also benefits anyone with phobias looking to face fears and build confidence in a safe, dry, controlled environment. \n\nDon\u2019t forget your personal floatation device (PFD)! \n\nBenefits include: \n\u2022  Realistic watercraft, equipment and environments \n\u2022  Stabilization across the simulation, reducing kayak and wave motion to avoid motion sickness \n\u2022  Paddling skills that can be transferred to real-world SUP ", "short_description": "The Virtual Reality Stand Up Paddleboard (SUP) simulation provides a safe environment where anyone can succeed, from the first-time user to the most seasoned paddler. VR SUP brings the watercraft experience to your headset as you paddle across a calm lake."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "726368587961803"}, {"id": "619566195371476"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6237176903001698"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "745729427248603"}]}, "baseline_offer": {"id": "745729427248603"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1681821000, "status": "PUBLISHED", "id": "745729427248603"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6200245210059850", "version": "2.1"}, "id": "3289076801406864", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6044376368980069", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6200245210059850"}, "release_status": "RELEASED"}, "binary_release_channels": {"