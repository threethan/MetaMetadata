c_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmX_Pa4bBhPG9B9xOESaikZGDB4ZXd7EbHLMCCDM0YkQ&oe=674C596B"}, {"file_name": "migrated_image.png", "id": "211110806632045", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974765_1163656613803088_7423218034690490368_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vZo0CdqvyfUQ7kNvgGlveWS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzlq2z1pRFuXNi8LLOyKH0IvCOtI7svnReTbmZoQYWlw&oe=674C5633"}, {"file_name": "migrated_image.png", "id": "210573596712862", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974780_471491136923512_1332548899625238528_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zs4lXXGMzm0Q7kNvgGayiao&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_TTmabAlFa4Xbb5JqdHu02VHfTDEHL786frcO4ylUWA&oe=674C3BAF"}, {"file_name": "migrated_image.png", "id": "313730622923359", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974837_1114440005388601_5831688267883347968_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXNicXWO2wsQ7kNvgH5hPky&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_cf3nvES5y0EZ2J49562jOc5_AWj-3OXWig3LOY0TUg&oe=674C6254"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/NGpzGp", "id": "2085418911749654", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974442_2085418915082987_4306258653352034304_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MPGXbnqPOa8Q7kNvgFlj0Eo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDo4JvsUKpXUj63G08hC-20G3PTNmFRZnskZfBx86pzJw&oe=674C51AC"}, "display_name": "SKYBOX VR Video Player", "keywords": ["Player", "Movie", "Video", "Tool", "VR"], "long_description": "SKYBOX is an ultimate local VR video player which supports video playback from local storage and network shared servers. \n\nAny Feedback is highly appreciated: \nBug Report & Join Beta Testing to support@SKYBOX.xyz \nDiscussions: https://forum.SKYBOX.xyz \nFAQ: https://SKYBOX.xyz/en/support/ \n\nWith SKYBOX, enjoy videos from your UPnP/DLNA media server or SMB share in the same Wi-Fi. A easy-to-set-up PC Client is available to support streaming from PC = Save your Storage! \nNo need to manually set the stereo mode such as 180\u00b0 or 3D side-by-side; SKYBOX would recognize the correct format for you = Save your Life! \n\nFeatures include: \n1. Automatically recognize video stereo mode ( 180\u00b0 / 360\u00b0 / 2D / 3D ). \n2. AirScreen: stream videos to multiple headsets (download here: https://SKYBOX.xyz/en/download/)\n3. Support DLNA media servers and SMB (1.0 & 2.0) shares. \n4. 5K local and streaming playback. \n5. Simple and intuitive UI; Spectacular VR environment. \n\nRelax and enjoy SKYBOX :)", "short_description": "SKYBOX is an ultimate local VR video player which supports video playback from local storage and network shared servers. \n\nWith SKYBOX, enjoy videos from your UPnP/DLNA media server or SMB share in the same Wi-Fi. A easy-to-set-up PC Client is available to support streaming from PC = Save your Storage! \n\nNo need to manually set the stereo mode such as 180\u00b0 or 3D side-by-side; SKYBOX would recognize the correct format for you = Save your Life!"}]}, "developer_name": "SKYBOX STUDIO", "developer_privacy_policy_url": "https://skybox.xyz/en/privacy-policy/", "developer_terms_of_service_url": "https://skybox.xyz/en/terms-of-use/", "publisher_name": "SKYBOX STUDIO", "support_website_url": null, "website_url": "https://SKYBOX.XYZ/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "MEDIA_PLAYER", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh