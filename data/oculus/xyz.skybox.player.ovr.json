c_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAazPNliCXmah00qfwm-xoxSv3anUpmQrWTzUTGmCXEPA&oe=6749B66B"}, {"file_name": "migrated_image.png", "id": "211110806632045", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974765_1163656613803088_7423218034690490368_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vZo0CdqvyfUQ7kNvgEOzd9t&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAil7y--Z4zO1Lz340K-xS283V0XzAlIwzL1BoFcMRFHg&oe=6749B333"}, {"file_name": "migrated_image.png", "id": "210573596712862", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974780_471491136923512_1332548899625238528_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l7_0ChgoEQsQ7kNvgF-fU1r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmRrJeTz85_nqzQ3PyO9KEvZQep8kg3iNnLRau1Zo0oA&oe=674998AF"}, {"file_name": "migrated_image.png", "id": "313730622923359", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974837_1114440005388601_5831688267883347968_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXNicXWO2wsQ7kNvgGrA4G9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRARkx4jYcHxVF91EkjEu4l9qu0uhwM4pCJasQhOay2A&oe=6749BF54"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/NGpzGp", "id": "2085418911749654", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974442_2085418915082987_4306258653352034304_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uPMGMqp2Me4Q7kNvgG2h0_e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfCifSPl5rgdCJqhP6ZLblbYX2hP7VpCP61zGLOqIDZg&oe=6749AEAC"}, "display_name": "SKYBOX VR Video Player", "keywords": ["Player", "Movie", "Video", "Tool", "VR"], "long_description": "SKYBOX is an ultimate local VR video player which supports video playback from local storage and network shared servers. \n\nAny Feedback is highly appreciated: \nBug Report & Join Beta Testing to support@SKYBOX.xyz \nDiscussions: https://forum.SKYBOX.xyz \nFAQ: https://SKYBOX.xyz/en/support/ \n\nWith SKYBOX, enjoy videos from your UPnP/DLNA media server or SMB share in the same Wi-Fi. A easy-to-set-up PC Client is available to support streaming from PC = Save your Storage! \nNo need to manually set the stereo mode such as 180\u00b0 or 3D side-by-side; SKYBOX would recognize the correct format for you = Save your Life! \n\nFeatures include: \n1. Automatically recognize video stereo mode ( 180\u00b0 / 360\u00b0 / 2D / 3D ). \n2. AirScreen: stream videos to multiple headsets (download here: https://SKYBOX.xyz/en/download/)\n3. Support DLNA media servers and SMB (1.0 & 2.0) shares. \n4. 5K local and streaming playback. \n5. Simple and intuitive UI; Spectacular VR environment. \n\nRelax and enjoy SKYBOX :)", "short_description": "SKYBOX is an ultimate local VR video player which supports video playback from local storage and network shared servers. \n\nWith SKYBOX, enjoy videos from your UPnP/DLNA media server or SMB share in the same Wi-Fi. A easy-to-set-up PC Client is available to support streaming from PC = Save your Storage! \n\nNo need to manually set the stereo mode such as 180\u00b0 or 3D side-by-side; SKYBOX would recognize the correct format for you = Save your Life!"}]}, "developer_name": "SKYBOX STUDIO", "developer_privacy_policy_url": "https://skybox.xyz/en/privacy-policy/", "developer_terms_of_service_url": "https://skybox.xyz/en/terms-of-use/", "publisher_name": "SKYBOX STUDIO", "support_website_url": null, "website_url": "https://SKYBOX.XYZ/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "MEDIA_PLAYER", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh