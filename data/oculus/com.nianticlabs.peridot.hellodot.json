-1.oculuscdn.com/v/t64.5771-25/38984443_1376996899655589_7080611007580992188_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CPZUhKivr_sQ7kNvgH1R7D3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBul_RGGebPr4Oq6PUOEtLcT5JXv_vkzAij3kjQp4ZoBA&oe=671E253F"}, {"file_name": "Hello Dot_2.png", "id": "830908182211865", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031356_830908185545198_2556931366129501020_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N1vO17WUBh4Q7kNvgG2V_Q1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSRjx6QKKcfzTdJz10W72fY5eFJEuCbp9iCNRMhYQOtg&oe=671E2B91"}, {"file_name": "Hello Dot_3v2.png", "id": "341814095190633", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003252_341814098523966_7628510584701864277_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YebDKM6lyEAQ7kNvgHjNjlL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDV73WuwHpddEvvZmy8eELPFPg_GyJf_vX1JSX7WwP7CQ&oe=671E0E5C"}, {"file_name": "Hello Dot_4.png", "id": "372490671802075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974867_372490675135408_4825715607005268583_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Oki44sOoIc8Q7kNvgFiwcK1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAOhJBzQdHazqjFhWqnhWufpN2B65hVdAefW-oIQ5INWA&oe=671E3F91"}, {"file_name": "Hello Dot_5.png", "id": "2645936498919699", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974819_2645936502253032_1075822578038513285_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aZcEfqmQ9eMQ7kNvgG4bvr2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBp9wRR6ndF2HPYgBUX9LydquTAkbsyGGbOUH66tt2ztQ&oe=671E3AC3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hello, Dot", "keywords": [], "long_description": "Hello, Dot, takes the best parts of caring for an adorable creature (a Peridot) and brings them to life through the magic of mixed reality. \n\nIn this immersive experience, you\u2019ll be able to admire just how visually stunning your Dots are up close, and develop a special bond with them as you play together. Imagine being able to hook your hands under your Dot\u2019s arms and pick them up \u2013 and then toss them up and and let them float back down into your embrace. Or perhaps your favorite song is playing in the background and you want to have a little dance party with your Dot. Or maybe you want to just relax on the couch snuggled up against your Dot. The possibilities are endless and the joy you\u2019ll feel is REAL.", "short_description": "Hello, Dot is a mixed reality experience from the Peridot franchise where you can interact with adorable magical creatures in your real-world environment. Feel just how real these creatures are by picking them up, petting them, and playing with them."}]}, "developer_name": null, "developer_privacy_policy_url": "https://nianticlabs.com/privacy", "developer_terms_of_service_url": "https://nianticlabs.com/terms", "publisher_name": "Niantic, Inc.", "support_website_url": "https://niantic.helpshift.com/a/peridot/", "website_url": "https://playperidot.com/hello-dot", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25825290020403701"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "759324036332806"}]}, "baseline_offer": {"id": "759324036332806"}, "is_approved": true, "firstOffer": 