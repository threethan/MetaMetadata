eenshots": [{"file_name": "1.png", "id": "2220667858274398", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269597_2220667864941064_2105509202232334427_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oTuLvLR_y8cQ7kNvgFKKhD8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZY4MPVG2fv80C8e0NFyhRTIK1mD2Pyhz2AmpR_JGfTw&oe=67693AA9"}, {"file_name": "4.png", "id": "1174758907064567", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036699_1174758910397900_1718051782348004191_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n8LCAA81Lx8Q7kNvgHl0keB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyXO5B4uy-mwMS-Fqm444FKhOE7WG3sKg7sbBTdSm-Bw&oe=67694220"}, {"file_name": "3.png", "id": "457457597035268", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982618_457457600368601_3188675145621070132_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0VvPIHiZ5pEQ7kNvgFjr9Bs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9w298ADlzY6bkGo16N7eAoc9DIhA03TNLBeC7D8Z_jQ&oe=6769535B"}, {"file_name": "5.png", "id": "996534591863687", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572927_996534595197020_5398134876768491404_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cHB6gyygfdUQ7kNvgFVTwVB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDFSKP9isFtQt5Cy9uuhGOnFo1XRFmdLEGRCSHjtcmttQ&oe=676961DE"}, {"file_name": "6.png", "id": "1011659503768096", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982699_1011659507101429_7519951062421030461_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zNAEkTcM46gQ7kNvgG1Hw7y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCTO1Bt6ed669M_IvCrn0lTLrRp4XgEEQ2TPX4qnxwmvg&oe=67693CC5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "987837626121564", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974695_987837632788230_1015870060816177121_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_f1RylzDYSwQ7kNvgH2PYzu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcUjym4MjxG0n_5HBTS-liCs2u0arefeJrQhVFMxQDJw&oe=676958B3"}, "display_name": "VR Kart 360", "keywords": [], "long_description": "Strap into your VR headsets for VR Kart 360 !\n\nExperience the adrenaline of immersive kart racing like never before. Dive into thrilling tracks, compete globally, and fine-tune your kart to dominate. Feel every turn and bump in VR's fully immersive world.\n{2749921605164381}\n\n{1010189834052785}\n- Immersive VR Experience: Feel the excitement of kart racing with realistic sensations.\n- Thrilling Tracks: Test your skills on challenging tracks designed for strategy and precision.\n- Global Competition: Compete worldwide, climb leaderboards, and become the ultimate champion.\n- Customizable Karts: Personalize your kart with upgrades for better performance and appearance.\n- Intense Head-to-Head Races: Compete against AI and real players in adrenaline-pumping races.\n- Skill Mastery: Hone reflexes and focus to navigate sharp corners and lead the pack.\n- VR Enhancements: Heightened realism and immersion elevate your kart racing experience.\n\n{348264668061132}\n\nWhy Choose Kart 360 VR:\nEmbark on an exhilarating journey where each race is a challenge and victory makes you a legend. With stunning visuals and a true-to-life VR environment, Kart 360 VR is the definitive choice for racing enthusiasts and VR gamers alike.\n\n{797696912453103}", "short_description": "Strap into your VR headsets and dive into the adrenaline-pumping world of Kart 360 VR! Get ready for an unparalleled immersive kart racing experience where speed meets skill, and legends are forged in the heat of intense virtual competition."}]}, "developer_name": null, "developer_privacy_policy_url": "https://geniegaming.com/vr-policy", "developer_terms_of_service_url": null, "publisher_name": "Genie Gaming Ltd", "support_website_url": null, "website_url": "https://geniegaming.com/", "category": null, "comfort_rating": n