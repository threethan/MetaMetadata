1064_2105509202232334427_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IxmYaOOJGJsQ7kNvgHos3-J&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCb988R5WKV8nINQak3kUGcJY7UEQNM0ouV0ZgEFjehoQ&oe=670BA029"}, {"file_name": "4.png", "id": "1174758907064567", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39036699_1174758910397900_1718051782348004191_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OuGJ1vUiuXEQ7kNvgG1aj8e&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYC-7dS_g9A0OSTJZOU9vTWxAm9TZ9h9DYr-bSfVkqzmXA&oe=670BA7A0"}, {"file_name": "3.png", "id": "457457597035268", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982618_457457600368601_3188675145621070132_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bYnRoy87QHYQ7kNvgG3F8xU&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDzu0FeWH4w-8URw_0OAlQ_Zd-0NH23k9lTbhw-3-PwZg&oe=670BB8DB"}, {"file_name": "5.png", "id": "996534591863687", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/57572927_996534595197020_5398134876768491404_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMPvhFz1zVMQ7kNvgFWX9kb&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDXFRmMtQyS_CBBfO5rea4SX2IT7BCWzjui4pbpK8l6yA&oe=670BC75E"}, {"file_name": "6.png", "id": "1011659503768096", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982699_1011659507101429_7519951062421030461_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ag_L7VE5VAQ7kNvgEOI2E8&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCu3u1NWoScwLbjv5IdXwuwuucoXAA1qGCgkACBL0Uhag&oe=670BA245"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "987837626121564", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974695_987837632788230_1015870060816177121_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kTNlkZfD9nQQ7kNvgFjzX5Z&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYA-dhuUjCkLcpRzX3EFq0crFnyCK2r1hiNeFNRRJoa-lQ&oe=670BBE33"}, "display_name": "VR Kart 360", "keywords": [], "long_description": "Strap into your VR headsets for VR Kart 360 !\n\nExperience the adrenaline of immersive kart racing like never before. Dive into thrilling tracks, compete globally, and fine-tune your kart to dominate. Feel every turn and bump in VR's fully immersive world.\n{2749921605164381}\n\n{1010189834052785}\n- Immersive VR Experience: Feel the excitement of kart racing with realistic sensations.\n- Thrilling Tracks: Test your skills on challenging tracks designed for strategy and precision.\n- Global Competition: Compete worldwide, climb leaderboards, and become the ultimate champion.\n- Customizable Karts: Personalize your kart with upgrades for better performance and appearance.\n- Intense Head-to-Head Races: Compete against AI and real players in adrenaline-pumping races.\n- Skill Mastery: Hone reflexes and focus to navigate sharp corners and lead the pack.\n- VR Enhancements: Heightened realism and immersion elevate your kart racing experience.\n\n{348264668061132}\n\nWhy Choose Kart 360 VR:\nEmbark on an exhilarating journey where each race is a challenge and victory makes you a legend. With stunning visuals and a true-to-life VR environment, Kart 360 VR is the definitive choice for racing enthusiasts and VR gamers alike.\n\n{797696912453103}", "short_description": "Strap into your VR headsets and dive into the adrenaline-pumping world of Kart 360 VR! Get ready for an unparalleled immersive kart racing experience where speed meets skill, and legends are forged in the heat of intense virtual competition."}]}, "developer_name": null, "developer_privacy_policy_url": "https://geniegaming.com/vr-policy", "developer_terms_of_service_url": null, "publisher_name": "Genie Gaming Ltd", "support_website_url": null, "website_url": "https://geniegaming.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscripti