eenshots": [{"file_name": "1.png", "id": "2220667858274398", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75269597_2220667864941064_2105509202232334427_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwojcA4304MQ7kNvgGZP9Ao&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAzyGA9oMQObVweH5GDzzhaKrlN3ES8taq_w2bw2lj2kQ&oe=67727529"}, {"file_name": "4.png", "id": "1174758907064567", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036699_1174758910397900_1718051782348004191_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TeGMa1QLSrgQ7kNvgFv5Uh3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCd_2CJBp8qjJd2mTO_jqpTAE3_crTHOAu0Qw_iJX4_fw&oe=67727CA0"}, {"file_name": "3.png", "id": "457457597035268", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982618_457457600368601_3188675145621070132_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J7-BKDbysR8Q7kNvgGp314F&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCEIq72pCkBxSuV8qeOl29R-2Lw_J9QehHQ9ZIBBASrEw&oe=67728DDB"}, {"file_name": "5.png", "id": "996534591863687", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57572927_996534595197020_5398134876768491404_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jF_Jpf8FKqgQ7kNvgHLgvI3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBwO3hwPF4WG6_4WnUEcYd80_yY2NzBF0H6smkXGK13JA&oe=67729C5E"}, {"file_name": "6.png", "id": "1011659503768096", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982699_1011659507101429_7519951062421030461_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=el0BDfY4UQIQ7kNvgEAgOT2&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAiBybJMtEtX0LPyElvSWI4Qf_FWB6TVwd78DFh7f9tVg&oe=67727745"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "987837626121564", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974695_987837632788230_1015870060816177121_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wJH359xzq8kQ7kNvgHVS9iG&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBfTkCeyEXmfTXBI97EyPBzBA4W0g39IrtWQp9elXcqwA&oe=67729333"}, "display_name": "VR Kart 360", "keywords": [], "long_description": "Strap into your VR headsets for VR Kart 360 !\n\nExperience the adrenaline of immersive kart racing like never before. Dive into thrilling tracks, compete globally, and fine-tune your kart to dominate. Feel every turn and bump in VR's fully immersive world.\n{2749921605164381}\n\n{1010189834052785}\n- Immersive VR Experience: Feel the excitement of kart racing with realistic sensations.\n- Thrilling Tracks: Test your skills on challenging tracks designed for strategy and precision.\n- Global Competition: Compete worldwide, climb leaderboards, and become the ultimate champion.\n- Customizable Karts: Personalize your kart with upgrades for better performance and appearance.\n- Intense Head-to-Head Races: Compete against AI and real players in adrenaline-pumping races.\n- Skill Mastery: Hone reflexes and focus to navigate sharp corners and lead the pack.\n- VR Enhancements: Heightened realism and immersion elevate your kart racing experience.\n\n{348264668061132}\n\nWhy Choose Kart 360 VR:\nEmbark on an exhilarating journey where each race is a challenge and victory makes you a legend. With stunning visuals and a true-to-life VR environment, Kart 360 VR is the definitive choice for racing enthusiasts and VR gamers alike.\n\n{797696912453103}", "short_description": "Strap into your VR headsets and dive into the adrenaline-pumping world of Kart 360 VR! Get ready for an unparalleled immersive kart racing experience where speed meets skill, and legends are forged in the heat of intense virtual competition."}]}, "developer_name": null, "developer_privacy_policy_url": "https://geniegaming.com/vr-policy", "developer_terms_of_service_url": null, "publisher_name": "Genie Gaming Ltd", "support_website_url": null, "website_url": "https://geniegaming.com/", "category": null, "comfort_rating": n