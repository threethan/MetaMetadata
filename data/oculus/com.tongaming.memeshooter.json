47", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974698_878419267178980_2806247721943973764_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vT6XYYSGizwQ7kNvgHHK7ms&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAyQf41GCnn5uduuugRUH3NFgo-6Yp4lMXpPYYL2ziFog&oe=677E61AE"}, {"file_name": "screenshot_2560x1440_2024-08-23_15-23-38.png", "id": "1734595504043011", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/39031421_1734595510709677_8212401149062966555_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7RX_Ay0ueWAQ7kNvgF4MBM6&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYCHBZTLsBSk_-kmvxryClO3HDQJkKlZCabUxmwTUZOk2Q&oe=677E7BFD"}, {"file_name": "screenshot_2560x1440_2024-08-23_15-25-21.png", "id": "1724730194939285", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38974528_1724730198272618_638226287506297458_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WivbfJVG0W0Q7kNvgGJVbZ1&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYCh9E5cDLkPbrQrwDzidIy3MZq9g3Olhp4x1dO8AgTNzQ&oe=677E613F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot_2560x1440_2024-08-23_15-23-38.png", "id": "1218787809435739", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/227814956_1218787812769072_2751227772506974541_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kViCSzj0UFYQ7kNvgEbxcjf&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBGmKDVVRd_ZEOaeYawyTD4I5v8I1ihAMlhEcjUR136jw&oe=677E58A6"}, "display_name": "Meme Shooter VR", "keywords": ["vr", "memeshooter", "singleplay", "casual", "fps"], "long_description": "Step into Meme Shooter VR, the ultimate virtual reality meme-shooting experience! Grab your shotgun and blast flying memes in a race against time. From classic memes to the latest viral hits, your goal is simple: shoot as many as you can to rack up points before the clock runs out. Compete for high scores, challenge friends, and become the top meme-slayer in this fast-paced, hilarious VR game. Are you ready to take aim at internet culture?\n\n{734670615471617}\n{3819407981663212}\n{1167698934291321}\n{1667700940468076}", "short_description": "Immerse yourself as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "TNG Company", "support_website_url": null, "website_url": "https://tongaming.github.io/Meme-Shooter/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27240026622278105"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38974835_444215377967720_3008110378344298257_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQFWfFQs81YQ7kNvgEVg3c1&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYATOk43EIh9XhGn0HLEJ0BNGQokO0C6eQ5nOZ3SfXdB6w&oe=677E5C9C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meme Shooter VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date":