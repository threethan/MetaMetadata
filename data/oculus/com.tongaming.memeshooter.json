5504043011", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031421_1734595510709677_8212401149062966555_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A0TMISSulSkQ7kNvgG7UKU4&_nc_ht=scontent.oculuscdn.com&oh=00_AYDL2r9NMtfceOkNUtctgJTdqRWCxekOmUTZqIsiQpE1zg&oe=66FFEBFD"}, {"file_name": "screenshot_2560x1440_2024-08-23_15-25-21.png", "id": "1724730194939285", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_1724730198272618_638226287506297458_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bpJfcb_aU7gQ7kNvgFU_7fU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTviqYHa6aAtae0NcYXRY_fwuXdSQVyL1BAc4uyVJ42w&oe=66FFD13F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot_2560x1440_2024-08-23_15-23-38.png", "id": "1218787809435739", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227814956_1218787812769072_2751227772506974541_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G3oq3kKZql0Q7kNvgEcMJDD&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXRQPtFquWh_VWKdKTv9YrxemG2V8Iowj8PqiKjZBkgg&oe=66FFC8A6"}, "display_name": "Meme Shooter VR", "keywords": ["vr", "memeshooter", "singleplay", "casual", "fps"], "long_description": "Step into Meme Shooter VR, the ultimate virtual reality meme-shooting experience! Grab your shotgun and blast flying memes in a race against time. From classic memes to the latest viral hits, your goal is simple: shoot as many as you can to rack up points before the clock runs out. Compete for high scores, challenge friends, and become the top meme-slayer in this fast-paced, hilarious VR game. Are you ready to take aim at internet culture?\n\n{734670615471617}\n{3819407981663212}\n{1167698934291321}\n{1667700940468076}", "short_description": "Immerse yourself as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url