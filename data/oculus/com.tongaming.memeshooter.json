p&oh=00_AYCkfrOYF96QsqPgKMSdz9bVJzPP4aUAk-5P2cJB37tjHg&oe=66F14AE1"}, {"file_name": "Casting_Screenshot_1726023689478.png", "id": "3596606207151155", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_3596606210484488_5195701684628437712_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=czvU9RAxDXAQ7kNvgE8582P&_nc_ht=scontent.oculuscdn.com&_nc_gid=AarqFBM7XxZSoaLJmQz1lqp&oh=00_AYAK2ggtN7UYU5nujPIM1dQJlDSM--c9l4J6Z-gaI5oYuw&oe=66F16ABB"}, {"file_name": "Casting_Screenshot_1726023719110.png", "id": "3916598401955073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982456_3916598405288406_4166344391557905771_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tEPF35VDGKIQ7kNvgFf4ftR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AarqFBM7XxZSoaLJmQz1lqp&oh=00_AYDvuE3wTLgYxptFXKj2T6CqhvrvvTZlrmUMkdUn0D-Xiw&oe=66F16859"}, {"file_name": "Casting_Screenshot_1726023698958.png", "id": "995355245674393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974700_995355249007726_3630741285579051550_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l6YJBaBngiQQ7kNvgHOI3Ob&_nc_ht=scontent.oculuscdn.com&_nc_gid=AarqFBM7XxZSoaLJmQz1lqp&oh=00_AYDdmTjCdF1ecf5e2k1It7looeK8aplplhXle5UdRxIdDQ&oe=66F159B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnails.png", "id": "1054822019642417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_1054822022975750_8298974446033483292_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rXoBZYI-CJMQ7kNvgE8jJ9O&_nc_ht=scontent.oculuscdn.com&_nc_gid=AarqFBM7XxZSoaLJmQz1lqp&oh=00_AYBLdv7AubU7yP9h4C8lMYMABLmPasAyOEys0YpGJxYbNw&oe=66F154AB"}, "display_name": "Meme Shooter VR", "keywords": ["vr", "memeshooter", "singleplay", "casual", "fps"], "long_description": "Step into Meme Shooter VR, the ultimate virtual reality meme-shooting experience! Grab your shotgun and blast flying memes in a race against time. From classic memes to the latest viral hits, your goal is simple: shoot as many as you can to rack up points before the clock runs out. Compete for high scores, challenge friends, and become the top meme-slayer in this fast-paced, hilarious VR game. Are you ready to take aim at internet culture?\n\n{734670615471617}\n{3819407981663212}\n{1167698934291321}\n{1667700940468076}", "short_description": "Immerse yourself as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "TNG Company", "support_website_url": null, "website_url": "https://tongaming.github.io/Meme-Shooter/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27097937053153730"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974835_444215377967720_3008110378344298257_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3376g90dJE0Q7kNvgF1PZwj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AarqFBM7XxZSoaLJmQz1lqp&oh=00_AYBr3P7b8sLbzWpumyVDT2xxRWNy46njAkLWxbmDLh64NA&oe=66F14C1C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meme Shooter VR", "platform": "ANDROID_6DOF", "context_category": {"con