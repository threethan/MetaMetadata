p&oh=00_AYABdNVzh_FeAjPsBKK1cG30QwnbQSleoibaoV54_KD0fg&oe=66F29C61"}, {"file_name": "Casting_Screenshot_1726023689478.png", "id": "3596606207151155", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_3596606210484488_5195701684628437712_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=czvU9RAxDXAQ7kNvgFA_pkK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqrmJyVL3BwUVChUU1cmWbp&oh=00_AYDgb0yvvWZXhSYXvnrCjA_WcAKAxu1L0l9aAj7VvAPeBQ&oe=66F2BC3B"}, {"file_name": "Casting_Screenshot_1726023719110.png", "id": "3916598401955073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982456_3916598405288406_4166344391557905771_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rC4i86KVy6AQ7kNvgEMgItM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqrmJyVL3BwUVChUU1cmWbp&oh=00_AYDXLruS_HdM3DX6sG9Fl7ajfYvri-HW6knQHjoJAH0n2A&oe=66F2B9D9"}, {"file_name": "Casting_Screenshot_1726023698958.png", "id": "995355245674393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974700_995355249007726_3630741285579051550_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l6YJBaBngiQQ7kNvgGXtgTU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqrmJyVL3BwUVChUU1cmWbp&oh=00_AYBHYZqsM2PZANA1IvVYk1W6vCnDIdGUn7To8W-mJ9vmdg&oe=66F2AB30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnails.png", "id": "1054822019642417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_1054822022975750_8298974446033483292_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rXoBZYI-CJMQ7kNvgF8iSQ9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqrmJyVL3BwUVChUU1cmWbp&oh=00_AYB157ZWE9aflpmdZcT-iMc97j3nkHnCSiULHz661FMqyQ&oe=66F2A62B"}, "display_name": "Meme Shooter VR", "keywords": ["vr", "memeshooter", "singleplay", "casual", "fps"], "long_description": "Step into Meme Shooter VR, the ultimate virtual reality meme-shooting experience! Grab your shotgun and blast flying memes in a race against time. From classic memes to the latest viral hits, your goal is simple: shoot as many as you can to rack up points before the clock runs out. Compete for high scores, challenge friends, and become the top meme-slayer in this fast-paced, hilarious VR game. Are you ready to take aim at internet culture?\n\n{734670615471617}\n{3819407981663212}\n{1167698934291321}\n{1667700940468076}", "short_description": "Immerse yourself as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "TNG Company", "support_website_url": null, "website_url": "https://tongaming.github.io/Meme-Shooter/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27097937053153730"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974835_444215377967720_3008110378344298257_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3376g90dJE0Q7kNvgGURdSb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqrmJyVL3BwUVChUU1cmWbp&oh=00_AYDskADaGnqgGV7h3ZFQHGGnV3_AVU9xSg8-DJV0GlV8Xw&oe=66F29D9C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meme Shooter VR", "platform": "ANDROID_6DOF", "context_category": {"con