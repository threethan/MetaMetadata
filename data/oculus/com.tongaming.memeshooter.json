oal is simple: shoot as many as you can to rack up points before the clock runs out. Compete for high scores, challenge friends, and become the top meme-slayer in this fast-paced, hilarious VR game. Are you ready to take aim at internet culture?\n\n{734670615471617}\n{3819407981663212}\n{1167698934291321}\n{1667700940468076}", "short_description": "Immerse yourself as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "TNG Company", "support_website_url": null, "website_url": "https://tongaming.github.io/Meme-Shooter/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27097937053153730"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "524939550001262"}]}, "baseline_offer": {"id": "524939550001262"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726193640, "status": "PUBLISHED", "id": "524939550001262"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27241132915500809", "version": "46"}, "id": "1649198615859799", "channel_name": "LIVE"}]}, "is_for