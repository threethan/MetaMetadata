"3916598401955073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982456_3916598405288406_4166344391557905771_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8q9RRAa93pUQ7kNvgG6soPg&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5bP29ty5DO6qBA5v5psY_8T5tnVbKodqjVg7jceqLQA&oe=66F6AE59"}, {"file_name": "Casting_Screenshot_1726023698958.png", "id": "995355245674393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974700_995355249007726_3630741285579051550_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VT2bSwJ_VFoQ7kNvgGzwPIZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtFvGRaxqvNcn1ACYLWGHSvFgHmjiWTO4lSS85poiX6w&oe=66F69FB0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnails.png", "id": "1054822019642417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_1054822022975750_8298974446033483292_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5I86OEC39YAQ7kNvgHaBY7P&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQdCmgI2cwT_fcNnY3vSZMDau5LLSmDk_1yBVxsoo19g&oe=66F69AAB"}, "display_name": "Meme Shooter VR", "keywords": ["vr", "memeshooter", "singleplay", "casual", "fps"], "long_description": "Step into Meme Shooter VR, the ultimate virtual reality meme-shooting experience! Grab your shotgun and blast flying memes in a race against time. From classic memes to the latest viral hits, your goal is simple: shoot as many as you can to rack up points before the clock runs out. Compete for high scores, challenge friends, and become the top meme-slayer in this fast-paced, hilarious VR game. Are you ready to take aim at internet culture?\n\n{734670615471617}\n{3819407981663212}\n{1167698934291321}\n{1667700940468076}", "short_description": "Immerse yourself as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "TNG C