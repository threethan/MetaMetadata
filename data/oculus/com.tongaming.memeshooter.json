elf as a meme-hunter, grab your trusty shotgun and try to eliminate as many memes as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tatustudio.blogspot.com/2024/08/vr-meme-shooter-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "TNG Company", "support_website_url": null, "website_url": "https://tongaming.github.io/Meme-Shooter/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27240026622278105"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974835_444215377967720_3008110378344298257_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qh-JLFDvVMwQ7kNvgHYE5MT&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAMov-iF3TvShK_RRGil1WvGr0Sxv0l8CxBfMvjPIopBA&oe=67026F9C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meme Shooter VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1726193640, "lastRevision": {"nodes": [{"id": "26865218763092228", "release_type": "SCHEDULED", "admini