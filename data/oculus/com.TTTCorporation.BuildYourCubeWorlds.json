9&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qemCw7sugecQ7kNvgF6Oh8l&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA27Vqh7tOSuG2wQTuZ2CYXjHPyZ35GdP6d1-POBdshOQ&oe=670F952D"}, {"file_name": "2560x1440 (3).png", "id": "850727383357661", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75469624_850727386690994_2922255316032264070_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gRifawxfNwgQ7kNvgG39Cio&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA-q5q7YHfgqT_IbGUznTuarei2hzRXuaT6HnYyD8-s5w&oe=670FAAA0"}, {"file_name": "2560x1440 (2).png", "id": "1038560117240491", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974679_1038560120573824_1785670509674239552_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IIujo-_GBPAQ7kNvgEa-2_J&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBx-0LyddUQumDEVau-sbG6nqVJPq-SmMdbGm5dOysM5g&oe=670FB5A2"}, {"file_name": "2560x1440 (1).png", "id": "1012736317153137", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982511_1012736320486470_1876558519849823907_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UKrkaS53br8Q7kNvgF3J2PM&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCoQebrTC1IuByWK7DircMtEwMb0O1EdMNyp13gVHeNuw&oe=670F8F3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (6).png", "id": "888879133107993", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974915_888879136441326_6893320149738884912_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nZ44QIGJlLkQ7kNvgFF8NBQ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB4dnHl2QxXRXuPVF0ZCodUh5Ctmm5elvg3hmh9C-r2Hw&oe=670F95B9"}, "display_name": "Build Your Cube Worlds", "keywords": [], "long_description": "In this immersive virtual reality experience, you become the architect of a universe where everything can connect. Build Your Cube Worlds\ncombines the simplicity of interlocking pieces with the boundless possibilities of VR technology, offering a completely new creative playground.\nBuild Your Cube Worlds isn't just a game; it's a gateway to your infinite creative world. Whether you're recreating wonders of the world, designing complex machinery, or simply relaxing by connecting pieces, this app offers joy and satisfaction in building.\nDownload Build Your Cube Worlds today and start your creative journey in VR! Get ready to see your boldest ideas come to life through the power of connection. From simple architectural structures to intricate machines, anything is possible in the world of Build Your Cube Worlds!", "short_description": "Build Your Cube Worlds: Build Your Wondrous World Through Connection\nStep into a world of limitless creativity with Build Your Cube Worlds\n - the unique VR application that lets you build and explore through the power of connection!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bmatterstudio.site/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "BMatter Studio", "support_website_url": null, "website_url": "https://bmatterstudio.site/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084534611625696"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8180803995332090", "version": "0.4"}, "id": "1053987532963