SYgBwA&oe=66FBCEAD"}, {"file_name": "2560x1440 (3).png", "id": "850727383357661", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469624_850727386690994_2922255316032264070_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=axe2SRRllNcQ7kNvgHSwQnU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjwxnyc6bKBo0RVqFjeUV-AyG7AUwkSULgM4yW570y1Q&oe=66FBE420"}, {"file_name": "2560x1440 (2).png", "id": "1038560117240491", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974679_1038560120573824_1785670509674239552_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QNmLwUzafe8Q7kNvgGECygp&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQK4Indy7SLNKdn-OeMIZ76nsYE9XjXWdNE9EyOHLo7w&oe=66FBEF22"}, {"file_name": "2560x1440 (1).png", "id": "1012736317153137", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982511_1012736320486470_1876558519849823907_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u9_15fVWk-oQ7kNvgHBgGli&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrU5jRKCy2-pHjHvVhkKaFiPQnDHOL5wU_CjkG6YnjPA&oe=66FBC8BF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (6).png", "id": "888879133107993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974915_888879136441326_6893320149738884912_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=30ussFSsCmYQ7kNvgHJt89o&_nc_ht=scontent.oculuscdn.com&oh=00_AYCP3rFQbCjh3MYf4Jm57GSIb85mbCMOIav7dQwG5jowBw&oe=66FBCF39"}, "display_name": "Build Your Cube Worlds", "keywords": [], "long_description": "In this immersive virtual reality experience, you become the architect of a universe where everything can connect. Build Your Cube Worlds\ncombines the simplicity of interlocking pieces with the boundless possibilities of VR technology, offering a completely new creative playground.\nBuild Your Cube Worlds isn't just a game; it's a gateway to your infinite creative world. Whether you're recreating wonders of the world, designing complex machinery, or simply relaxing by connecting pieces, this app offers joy and satisfaction in building.\nDownload Build Your Cube Worlds today and start your creative journey in VR! Get ready to see your boldest ideas come to life through the power of connection. From simple architectural structures to intricate machines, anything is possible in the world of Build Your Cube Worlds!", "short_description": "Build Your Cube Worlds: Build Your Wondrous World Through Connection\nStep into a world of limitless creativity with Build Your Cube Worlds\n - the unique VR application that lets you build and explore through the power of connection!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bmatterstudio.site/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "BMatter Studio", "support_website_url": null, "website_url": "https://bmatterstudio.site/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084534611625696"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8180803995332090", "version": "0.4"}, "id": "1053987532963810", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typena