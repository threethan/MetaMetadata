iZHbWJA&oe=66E80A5A"}, {"file_name": "oculus screenshot 6.png", "id": "173579598860712", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974914_173579602194045_2043299477488637509_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJLXvX9RpnEQ7kNvgHJqR4f&_nc_ht=scontent.oculuscdn.com&_nc_gid=A235aPxh9qGggJS5cwdiYQm&oh=00_AYCruaBL8ff5-a8PkfTk2csccGu7Pgc4x48Lq9C-wKgiYw&oe=66E81C5B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover art.png", "id": "782998756902491", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982502_782998763569157_2262920780424065717_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X4tOT5Lxx2IQ7kNvgEwNmpE&_nc_ht=scontent.oculuscdn.com&_nc_gid=A235aPxh9qGggJS5cwdiYQm&oh=00_AYBL0jtXob3q04wkQAxcqFd6ddP8cAOlO7KriacTt__IZw&oe=66E81859"}, "display_name": "Blockworks", "keywords": [], "long_description": "Blockworks is a creative VR sandbox. Express your full creativity and build anything your mind can imagine!\n\nClassic Mode\nFollow instructions and build from built-in sets and hundreds of workshop submissions. Build one page at the time.\n\nSandbox Mode\nThe only limit is your imagination. All blocks and all materials are at your disposal. You can save your block creations in the library or share them on the game workshop.\n\nEndless Mode\nNo longer limited by table size, you have an infinite area to build on. Place the blocks on the studs in the ground.\n\nContent\n\u25cf 100s of block types\n\u25cf 30 materials\n\u25cf 5 build-in sets\n\u25cf 4 environments\n\u25cf 100s of workshop builds\n\nGameplay\n- use you virtual hands to grab and manipulate blocks. When blocks are close enough each other a blue preview will show up. Dropped block will instantly connect to the other block. Help blocks are highlighted, when the disconnect button is hit, the highlighted block is separated from the rest of the group. The game features lot of buttons and gizmos that have good feeling feedback. There is no UI in the game.\n\nJoin our official Discord for more fun outside the game!", "short_description": "Blockworks is unique VR sandbox game. Use your imagination to build anything you want."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.elasticsea.com/blockworksprivacy", "developer_terms_of_service_url": null, "publisher_name": "Elastic Sea", "support_website_url": null, "website_url": "https://www.elasticsea.com/blockworks", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8176522535770207"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982593_1359039028359265_5144098816852753749_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uvh3uhx228QQ7kNvgGS3yTM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A235aPxh9qGggJS5cwdiYQm&oh=00_AYCBU2wvCH-uqv2Arg87s1vIESmP4GrickT-edPchXjX5A&oe=66E83119"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Blockworks", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1671123600, "lastRevision": {"nodes": [{"id": "626901122079341", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US"