=1-7&_nc_sid=6e7a0a&_nc_ohc=vQK5UVeG6Z8Q7kNvgHGyHDY&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDoZ2yaQim-Wn195bHTeJoaTfLVildP3vi1QDOMN7yIew&oe=670FA56C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440 (1).png", "id": "1149947469195227", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974751_1149947475861893_3742548628872915671_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xZ7XzwkbSq0Q7kNvgEYTrVL&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB_SK0Xr2yDu82La2W5P3AEtsInOowY6Y5YVjTKFun0_g&oe=670FA5F6"}, "display_name": "ALTAIR BREAKER", "keywords": ["SAO", "melee", "blade", "saber", "fighting"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://altair-breaker.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "305013941658811"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "3626372831012964"}, {"status": "PUBLISHED", "id": "1719912118457190"}, {"status": "PENDING", "id": "3465456147031592"}, {"status": "PENDING", "id": "851226276455900"}, {"status": "PUBLISHED", "id": "5318635608255893"}]}, "baseline_offer": {"id": "5318635608255893"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718902800, "status": "PUBLISHED", "id": "3626372831012964"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7841124815919080", "version": "2.0.1"}, "id": "168803138388503", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4599090550122539"