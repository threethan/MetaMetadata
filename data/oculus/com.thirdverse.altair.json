.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EZXAexyaPqcQ7kNvgEfw5Ry&_nc_ht=scontent.oculuscdn.com&oh=00_AYDDGBePzaQSCZ_oFqrKCviBQciLwIyjA92gbYHAqs2nKg&oe=66DD957C"}]}, "id": "1522600324832840", "locale": "en_US", "screenshots": [{"file_name": "2.0_store.png", "id": "945938106793365", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974751_945938110126698_5049168628009870684_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yr9voK9GnuAQ7kNvgHzluvU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFi6n9P4xPKt4Z1Ol8pcyXX37OuyFAFvy5nLi998ubUg&oe=66DD90DA"}, {"file_name": "store_1.png", "id": "3255746144654203", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65227368_3255746151320869_6996041940704008745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q7gl7EXqS7oQ7kNvgH9P_uM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdSLl06woDjSATI7e--_xZt7Z6nsaJYO7pSpQabTR4VQ&oe=66DD8DA9"}, {"file_name": "store_2.png", "id": "462974492240045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982699_462974495573378_1034767390867189488_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qIWyQt1bvoMQ7kNvgFBpRkj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbJ-iFwAHN5_reOH8ujRhSi6Wbiua9HwV49-_egekD1g&oe=66DD8032"}, {"file_name": "store_3.png", "id": "422836609754517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974524_422836613087850_4080946146330262927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7qH-BkWzDeAQ7kNvgEb5tvo&_nc_ht=scontent.oculuscdn.com&oh=00_AYClODiIKk-l7YHTNL_vtOsYpwJeAIScbJ4kjEz5DQKKlQ&oe=66DD9825"}, {"file_name": "store_4.png", "id": "5075395275903256", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974714_5075395279236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Xsg-uqFZocQ7kNvgFxvWvx&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHzSk6u81xsDTrkRtLCw5Z4t9I_v5ZEGTCpPnTOa1SGA&oe=66DD7D00"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440.png32.png", "id": "618447913408864", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_618447916742197_5974117523784124568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SHUzzUlBRcAQ7kNvgHObMzR&_nc_ht=scontent.oculuscdn.com&oh=00_AYCqum719_n52qTADoz_GUdxAHf4WLpfxq07ALISL-DCrQ&oe=66DDA2A3"}, "display_name": "ALTAIR BREAKER", "keywords": ["melee", "blade", "saber", "fighting", "action"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html"