", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974774_392957699629687_6911195933165272446_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BYAaBVEljwwQ7kNvgHv5pD5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAvQ4urOKJ1BvCWsPuRR4mKX7CaCzD4msGHrGSf2m6W_w&oe=6714F47C"}]}, "id": "1522600324832840", "locale": "en_US", "screenshots": [{"file_name": "2.0_store.png", "id": "945938106793365", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974751_945938110126698_5049168628009870684_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UNhlkwt2-cQQ7kNvgE902ok&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBH1o22zzcvcwXJO22fOVmntn_V8Nm1cKI26DansRebJw&oe=6714EFDA"}, {"file_name": "store_1.png", "id": "3255746144654203", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65227368_3255746151320869_6996041940704008745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s8l8UFoMbJQQ7kNvgHoZXnm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRe_nO3Rya8TNx_BZmRSjK--4sWpwfBYpjq9p5Z7LPIA&oe=6714ECA9"}, {"file_name": "store_2.png", "id": "462974492240045", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982699_462974495573378_1034767390867189488_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X2ZcvukqZ8EQ7kNvgE0WUwJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQSHIMFGvnxL0rQm-_3-A04Z0OZebxCQjoBubJ6deK0w&oe=6714DF32"}, {"file_name": "store_3.png", "id": "422836609754517", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974524_422836613087850_4080946146330262927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ajcoy41KXgcQ7kNvgGlFyQK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2heYAw7iqEhq-A1559mIxpCXRF6nOq7zwAMQVfE5B4w&oe=6714F725"}, {"file_name": "store_4.png", "id": "5075395275903256", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974714_5075395279236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BKjQQlq8hjEQ7kNvgEtmzq0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWIaz1UhpEJfYi0gxYeWDzVuBfJ-oQo-Y5Cid5pHzpVQ&oe=6714DC00"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440.png32.png", "id": "618447913408864", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974817_618447916742197_5974117523784124568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B-systOqB7wQ7kNvgEzT4Eg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkm4-3eKJxOcBVCr8Vq4xCnNkZDCogXXh0irphyZ9yQg&oe=671501A3"}, "display_name": "ALTAIR BREAKER", "keywords": ["melee", "blade", "saber", "fighting", "action"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://altair-breaker.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ko", "en", "fr", "fr_CA", "zh_TW", "zh_HK", "ja", "es_MX", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "520430169752218"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974716_1872160179795779_3060844840965007231_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AOH-PxScThkQ7kNvgHlu7Zv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBdiq-LJFexfPxUyWe1TUmqDrIA1bb2rjUXWr3GxvHNw&oe=6714EC16"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ALTAIR BREAKER", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1660841994, "lastRevision": {"nodes": [{"id": "4424369774246619", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_local