.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zrkan98Did4Q7kNvgETHOdJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBUzvxjdi6g9AbYnIIl1KTOLK5XYiQI3U9u4-x4rvGqRA&oe=66D84F7C"}]}, "id": "1522600324832840", "locale": "en_US", "screenshots": [{"file_name": "2.0_store.png", "id": "945938106793365", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974751_945938110126698_5049168628009870684_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IBgCUb_gr04Q7kNvgE_6NXU&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-M8bqnj8Wijcbpo4-GbJJ15p-sN59fW9JV4UavJPn5A&oe=66D84ADA"}, {"file_name": "store_1.png", "id": "3255746144654203", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65227368_3255746151320869_6996041940704008745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BvW_DWY4fVYQ7kNvgHU3toF&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXQVGmX6HxD5OPf0LXju0QVIZ4p_Db7n9Rb9wntpdQkw&oe=66D847A9"}, {"file_name": "store_2.png", "id": "462974492240045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982699_462974495573378_1034767390867189488_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AD2LTPXFFPgQ7kNvgGHObl5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLxw5HmI4--v-9WOJB7y-UpHHHQXPgr4PYMbeZKD0tZw&oe=66D83A32"}, {"file_name": "store_3.png", "id": "422836609754517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974524_422836613087850_4080946146330262927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_J_35JEmEtgQ7kNvgFXyFz9&_nc_ht=scontent.oculuscdn.com&oh=00_AYA2J445272Y3CQx7FmQ8MwxgPFYqGwQ37fJvcRC_595Og&oe=66D85225"}, {"file_name": "store_4.png", "id": "5075395275903256", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974714_5075395279236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SrS2DSZU8fgQ7kNvgFe2vj6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDH6x70aBgYUQyewdTD6ekHd3if0QCsBoiB2DzJ7pxOaQ&oe=66D83700"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440.png32.png", "id": "618447913408864", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_618447916742197_5974117523784124568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JqlJUvvm-QwQ7kNvgFCIG6s&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHnyB9BLz5PMnB1-vC2l4fxcjgRbAF6H0CrClJgPzoIw&oe=66D85CA3"}, "display_name": "ALTAIR BREAKER", "keywords": ["melee", "blade", "saber", "fighting", "action"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html"