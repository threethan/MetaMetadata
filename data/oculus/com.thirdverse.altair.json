.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rT9CJ4YQJIwQ7kNvgFIKYwJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6TD_wo6NRJ3WQCheGZPrDqDahmtMzvdV2q3EjlP_vOg&oe=66E57E7C"}]}, "id": "1522600324832840", "locale": "en_US", "screenshots": [{"file_name": "2.0_store.png", "id": "945938106793365", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974751_945938110126698_5049168628009870684_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jylQnxX_4ZIQ7kNvgE2d6XW&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDLtrF9pm1VxG5ZHIa1x4tmvkuORCnMEd4rJA8cxjcag&oe=66E579DA"}, {"file_name": "store_1.png", "id": "3255746144654203", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65227368_3255746151320869_6996041940704008745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dzr-UnZe2O8Q7kNvgGBkxfh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaIs4Mh3aQiYhFJjLRpusMAPEXLF544EzyN4ulg73S9Q&oe=66E576A9"}, {"file_name": "store_2.png", "id": "462974492240045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982699_462974495573378_1034767390867189488_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-9-F8Kqt8cYQ7kNvgHRT6y4&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5NSfiX1kIVA7IfzzJ_MWVReca1lkRT9f_THBy5gm7Fg&oe=66E56932"}, {"file_name": "store_3.png", "id": "422836609754517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974524_422836613087850_4080946146330262927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VKzfxO6kz1YQ7kNvgFa2SV2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBUI8RjXSPIcsCNxGKIY2_WXSxqsMKgCrBeA0MPe20gJw&oe=66E58125"}, {"file_name": "store_4.png", "id": "5075395275903256", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974714_5075395279236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-CQwNU2Cpt8Q7kNvgHJJ-7n&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOvtp854LUXJn14GYuB60o-q-oioyltcjg6SkhCW-gYQ&oe=66E56600"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440.png32.png", "id": "618447913408864", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_618447916742197_5974117523784124568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vW5DoUjgyW8Q7kNvgHzrHLc&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbSe6tbx4xtX1b1uM_yFrX_jCdt2D0aogTVq-T-OAJYw&oe=66E58BA3"}, "display_name": "ALTAIR BREAKER", "keywords": ["melee", "blade", "saber", "fighting", "action"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html"