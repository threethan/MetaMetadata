ent-sea1-1.oculuscdn.com/v/t64.5771-25/38974774_392957699629687_6911195933165272446_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pVRq0PhcsnYQ7kNvgE4I0yI&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBOvaeCcKkPhP88i9mok-bccMTfPs31hL1XGEia-3lSuA&oe=670FAE7C"}]}, "id": "1522600324832840", "locale": "en_US", "screenshots": [{"file_name": "2.0_store.png", "id": "945938106793365", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974751_945938110126698_5049168628009870684_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vx8h5Mvn_w8Q7kNvgGu5IS7&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB0zRWuWV3ipM5oxD0FdRVFPO9ENdCKNStvQ_jE316Viw&oe=670FA9DA"}, {"file_name": "store_1.png", "id": "3255746144654203", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/65227368_3255746151320869_6996041940704008745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pn1-tq69GIYQ7kNvgGrOwof&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDrbeaDrzOR45i19JcrTOkz4V7l_C3FLxLpZ8RCPiNPIA&oe=670FA6A9"}, {"file_name": "store_2.png", "id": "462974492240045", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982699_462974495573378_1034767390867189488_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wzx858YArmwQ7kNvgHMzrwz&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAXFJltcL1eo1j2bj_rUEuRRAXpQkGCIEvyqfKqOKyxEA&oe=670F9932"}, {"file_name": "store_3.png", "id": "422836609754517", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974524_422836613087850_4080946146330262927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IMThaZa2aSgQ7kNvgG8Si5d&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCABYgQIyd5JR8QQFGJ7FqpE9d5sIwf79QhpQZq7gWOyA&oe=670FB125"}, {"file_name": "store_4.png", "id": "5075395275903256", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974714_5075395279236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0kKOWYRBIKEQ7kNvgHS3GQO&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDAo7YElu8dkubJv17rhH5y_R_QVjC6tXhAuCxjH59_HQ&oe=670F9600"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440.png32.png", "id": "618447913408864", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974817_618447916742197_5974117523784124568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i2O4jfUrn9kQ7kNvgFvhvBN&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDudPXiXxFFM3MALcsPm1DNPKZ0L5qywUq-7aGIM_4Pag&oe=670FBBA3"}, "display_name": "ALTAIR BREAKER", "keywords": ["melee", "blade", "saber", "fighting", "action"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": 