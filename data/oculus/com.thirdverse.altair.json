content-lga3-2.oculuscdn.com&oh=00_AYCgHIOIfTJnyExt3WEB5guvykaY0q2NW45GIlJDY4msNA&oe=67601CA5"}, {"file_name": "store_4.png", "id": "5075395275903256", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974714_5075395279236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VpAr8k7cCdIQ7kNvgHCB26e&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYD3LK-hJw_azcU0v7OhLen_YjeAG-LssWigma2sFrisig&oe=67600180"}, {"file_name": "store_5.png", "id": "808510233851899", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39001698_808510237185232_4332461869180106686_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9oXGBaK9oEgQ7kNvgGjxR5b&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAt3XYTN8UrFhMGa8qBzuqdT13cKz0x38mUUxSqEiWU5g&oe=676010EC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440 (1).png", "id": "1149947469195227", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974751_1149947475861893_3742548628872915671_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TqIXCKPBYcsQ7kNvgF33ifb&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBKj5JiDxJs7FcFMUggySdgD1jcrGNtjZBuRerEDVc77w&oe=67601176"}, "display_name": "ALTAIR BREAKER", "keywords": ["SAO", "melee", "blade", "saber", "fighting"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://altair-breaker.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "305013941658811"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1272091057464629"}, {"status": "PUBLISHED", "id": "3626372831012964"}, {"status": "PUBLISHED", "id": 