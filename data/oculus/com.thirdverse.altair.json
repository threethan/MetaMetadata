79236589_4641673077474597517_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UmRMnGY62YcQ7kNvgGF6I_a&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afm8sgdhhF_u9srhISNnKa1&oh=00_AYDTu9agiKvarqzS0w5wD5OvwdQwoeIg94eJF4gwTNAcSw&oe=66F68980"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus LandscapeW2560xH1440.png32.png", "id": "618447913408864", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_618447916742197_5974117523784124568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qVHYp0i7p2AQ7kNvgFrd9yg&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afm8sgdhhF_u9srhISNnKa1&oh=00_AYAhobiN8raGH1Kk8zKfQI5egA13QZwD4OMKwF3wuwbnDQ&oe=66F6AF23"}, "display_name": "ALTAIR BREAKER", "keywords": ["melee", "blade", "saber", "fighting", "action"], "long_description": "THE WORLD OF ALTAIR\nSet on the floating island of Vastus Isle, once a magic workshop now in ruins and exploited to run AI experiments. Take on battles to push back the army of LAWS (Lethal Autonomous Weapons Systems) that are roaming around and help Stella, the humanoid AI left in charge of ALTAIR, to maintain peace.\n\nBATTLE SYSTEM\nMove from map to map while enjoying the feeling of transcendent sword fighting.\nTake advantage of your surroundings by climbing and gliding to easily take on enemies. \nExperience a wide range of attacks only possible in the VR world, like Shockwaves and Surge Mode.\n\nUSER-FRIENDLY UI\nA simplified and intuitive UI was developed to increase the sense of VR and not interrupt the game flow.\nThe Tablet will be your main hub to change equipment, check your status and more.\n\nCO-OP MULTIPLAYER\nTeam up with other 3 players from around the world and take on enemies together.\nThe game supports crossplay between Quest 2 and PCVR and features a native voice chat system.", "short_description": "Enter the world of ALTAIR and battle against the LAWS, an army of corrupted AI left behind roaming the floating Vastus Isle. Team up with friends and experience the feeling of transcendent VR sword fighting in this map-based multiplayer adventure. Climb, glide, and slice your way through beautifully-crafted levels and collect resources to upgrade your character while playing with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/ja/privacy-policy.html", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service.html", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://altair-breaker.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ko", "en", "fr", "fr_CA", "zh_TW", "zh_HK", "ja", "es_MX", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "520430169752218"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974716_1872160179795779_3060844840965007231_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VN6_QCjY2UEQ7kNvgFgmvE5&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afm8sgdhhF_u9srhISNnKa1&oh=00_AYAPo1Hq_bg58yQ5VsAczAzhLnx0PklLSvV2gFxljx6Fvg&oe=66F69996"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ALTAIR BREAKER", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1660841994, "lastRevision": {"nodes": [{"id": "4424