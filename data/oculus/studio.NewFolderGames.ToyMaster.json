a&_nc_ohc=pI9eLayA6I0Q7kNvgHuHs8_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPcTTYc0SKSi70WlhfgZn8Wn7e9faAySnrnMd4pUyXDw&oe=676563B6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 toy master.png", "id": "1447150539209590", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031588_1447150542542923_306021620979646302_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VyFfsGYsqy0Q7kNvgFSVIgF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoUMNSRo0BHNhEMmiJ_u97lfbKZ8Fy0T62hw9eL34nEA&oe=6765412C"}, "display_name": "Toy Master", "keywords": [], "long_description": "Welcome to Toy Master, the ultimate construction simulator that lets you enjoy the thrill of opening and putting together new toys and delightful eggs. Dive into a world of excitement with interesting game features and a laid-back atmosphere. Simply unwrap the package, crack open the chocolate egg, and discover the special toy hidden inside. This fantastic stress-relief game is like reliving the joy of your favorite childhood treats.\n\nExplore the fun of opening various eggs, each filled with unique toys that you can customize with stickers. We offer a wide variety of toys and eggs, each with its own special features. Use different tools to enhance your enjoyment during the assembly process.\n\nImmerse yourself in the pure joy of unwrapping and putting together toys in Toy Master!", "short_description": "Unpack and play, Toy Master's way, assembling joy, day by day."}]}, "developer_name": null, "developer_privacy_policy_url": "https://newfolderstudio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NEW FOLDER GAMES LTD", "support_website_url": null, "website_url": "https://newfolderstudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_R