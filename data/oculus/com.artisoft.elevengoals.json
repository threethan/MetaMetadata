t-iad3-2.oculuscdn.com/v/t64.5771-25/38982499_6325799374178073_8933801958820894606_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ice4whpnoXUQ7kNvgGOyTEi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQuaDg6VsUitrfEYlVe89u0DEcAvM7oH6RkhhfY6VADA&oe=674EFB92"}, {"file_name": "sc2.png", "id": "814342443353557", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031606_814342450020223_646134755387049443_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u5qWPh6-WxgQ7kNvgFv-JUo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBMdmmQTVNv5_B4fGtFJ7ztAYQwFXqM_Jae3eVGNSrlWg&oe=674EF039"}, {"file_name": "sc6.png", "id": "819781943005946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003228_819781946339279_8313737698820743009_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cgSO16QNt_QQ7kNvgErmeaT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMm1b2Bhk2sLbV2qJW7VZ1IHSKr6KHAp0bF7mpKqU1Kw&oe=674EDFCB"}, {"file_name": "sc3.png", "id": "237404199186857", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262745_237404202520190_7269246516171065302_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p_cVS6F8L2QQ7kNvgFgz9SW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCTAolxIXUuT-P-7DTGxH8Wl_oKb2Tiua6sA7DJB9wurA&oe=674EF502"}, {"file_name": "sc5.png", "id": "952024302762284", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031636_952024306095617_8441863511266288354_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uv-DP29_-Z0Q7kNvgEd3rgd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARchP5-sgVisAtnd21Bv26bGKyZwRxLrrz5KU8pNjXKg&oe=674EFECA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_1.png", "id": "960043135211891", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974811_960043145211890_8988895673906674259_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=poz6oPDHf5gQ7kNvgGMcOBR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAO6YMA2pN1FPv9VMifD8A5g4xcofKFP_3ZOUEi5lYEjw&oe=674EDAB7"}, "display_name": "Eleven goals", "keywords": [], "long_description": "Use your foot - that's not a joke. Due to a specific mount of a left controller, you can actually kick ball with your foot like real football (or soccer) player. \n\nYou can select to practice:\n- Penalties\n- Free kicks\n- Curved shots\n\nFive levels of goalkeeper difficulty. \nIf you prefer, you can use targets instead of goalkeeper.\nAnd during free kicks you can have a wall blocking clear shot.\nYou can also tune the shoe, so it will fit better as well as changing the power level.\n\nNo need for additional equipment. All you need is two 1.5m/60\" strips of fabric, preferably elastic.\n\nWatch video on how to securely mount the controller to the feet. In few words:\n- Take the left controller\n- Mount strips on both sides of plastic ring\n- Choose leg and attach the default security fastening to it\n- Put shoe on or not - up to you\n- Use strips to secure controller on the foot so it will stay still\n- In game use shoe tune if needed\n\nWARNING. Always use the security fastening from Oculus Quest controller.\nRemember to have some space around you.", "short_description": "Use your foot - that's not a joke. Due to a specific mount of a left controller, you can actually kick ball with your foot like real football (or soccer) player. \n\nYou can select to practice:\n- Penalties\n- Free kicks\n- Curved shots\n\nFive levels of goalkeeper difficulty. \nIf you prefer, you can use targets instead of goalkeeper.\nAnd during free kicks you can have a wall blocking clear shot.\n\nNo need for additional equipment. All you need is two 1.5m/60\" strips of fabric, preferably elastic."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artisoft.pl/policies/eg_v1.html", "developer_terms_of_service_url": null, "publisher_name": "Artisoft", "support_website_url": null, "website_url": "https://eg.artisoft.pl/", "category": null, "comfort_rating": "NOT_RATED", "com