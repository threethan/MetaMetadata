7&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vFomnwyrsT8Q7kNvgF-nd0C&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYByzhQvOlmxGcceTCEKfAxgA8hHHgQwWq1oykLZOnK2LQ&oe=677E4C01"}, {"file_name": "migrated_image.png", "id": "660724478086394", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982540_2871895256369844_8396520841587720192_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QG1Ejh6RMsUQ7kNvgHg9LW0&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCd-As5foj6slFOUodueXGJMde-G56D9bhnUKO8kS76JA&oe=677E743C"}, {"file_name": "migrated_image.png", "id": "2278132129159311", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/38974453_2817730581784427_8336486686372397056_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nIFnD_f01lgQ7kNvgFJ2Dfk&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYDWxC9DsHKtyfmgaskOJ8NA22-YDT9bH-VzDLlwVAmlkw&oe=677E7204"}, {"file_name": "migrated_image.png", "id": "610775142806089", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974501_444896586081961_7025688832573964288_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7GOs1hyZDh8Q7kNvgHgpqf7&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAke1_okCNaiLV0l0Q_jblV14jyqZZ5vftVAmVXd4gWaw&oe=677E59C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/cKnxwW", "id": "452154672212602", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39003278_452154675545935_1677441104275832832_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2HVvnYqezh0Q7kNvgG5NFNw&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYAyDQ_RumD2Pl2m9b-388Ybbi7bOp9XRSQTd1NSSoaPvA&oe=677E6777"}, "display_name": "BOXVR", "keywords": ["sports", "boxing", "exercise", "rhythm", "dance"], "long_description": "\u201cBest VR Fitness Game of the Year\u201d - VR Fitness Insider\n\n\u201cA game for everyone that wants to get ripped\u201d - Discovery Channel\n\nBOXVR brings music enhanced, boxing inspired workouts to Virtual Reality.\n\nWorkout Classes by fitness experts\nLeading fitness instructors help us produce a variety of boxing workouts, specifically designed to destroy calories in the most entertaining way ever devised! From short 3 minute warm ups to 60+ minute endurance workouts, we\u2019ve got everything you need to give you a fantastic cardio workout!\n\nTrack your progress\nEvery workout is recorded so you can see how many calories you've burned. Set your own goals and see your progress day by day to stay motivated.\n\nWorkout Music Variety\nFrom Rock to Pop, Dance to Hip Hop, we\u2019ve got the music that will get you boxing to your favourite beat!\n\nMake your own playlists!\nWith over 100 different music tracks you can create your own workouts with varying levels of intensity.", "short_description": "BOXVR brings music enhanced, boxing inspired workouts to Virtual Reality gaming.\n\nWorkout Classes by fitness experts\nBeginner to Expert Classes\nEffective cardio exercise\nSet goals and track your progress\nOver 100 different music tracks\nMake your own Workouts"}]}, "developer_name": "FitXR", "developer_privacy_policy_url": "https://fitxr.com/privacy", "developer_terms_of_service_url": "https://fitxr.com/eula", "publisher_name": "FitXR", "support_website_url": "https://fitxr.zendesk.com/hc/en-gb", "website_url": "http://www.fitxr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "ACTION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "fr", "de", "es", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_inter