7559098", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031629_279469697559097_8584576383001980473_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vp5wtziNhd0Q7kNvgGGSDTx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsBT6drTcjojcVJWio2ZrLspaPN5U2CPua2h6X6erLhQ&oe=670D01A3"}, {"file_name": "Shot4.png", "id": "273800928137307", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207234_273800931470640_2603566706085727327_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wlDof0g0xxMQ7kNvgHiVseX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGoLd2e3NPd_pWI7Es8iE3KhA9SiF4YRHz87wefYhY9Q&oe=670D052D"}, {"file_name": "Shot5.png", "id": "213141630982328", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439593_213141637648994_3188695562402402270_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CiDcDHRsB80Q7kNvgGQAcbE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD58BRT0Q7xmFUCVlLPFWSjsvavwXnGzG2HRijjLWzBDw&oe=670D0967"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OUAS_Landscape.png", "id": "235496792032420", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572957_235496795365753_4287613132046459954_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pXz9C1wqvSsQ7kNvgF5w4Fw&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAdXMgFiQDRFJh9pcm2Fs5k6y3me8Ya7Qf4O6TuoZKiLw&oe=670D1659"}, "display_name": "Once Upon a Sea - Shimon Shukron - The Last Man Standing", "keywords": [], "long_description": "For 50 years, Shimon Shukron worked as a beach ranger at Ein Gedi Beach and lived in a hut at the foot of the sea. Following the appearance of a huge sinkhole and the closure of the busy Route 90, the beach was also closed, and overnight Shimon's home became a ghost area. People stopped coming to the area and after the council finished dismantling the beach and parking lot from its amenities, Simon was left alone, refusing to leave his home and the orchard he had been cultivating all his life. Even at the cost of risking his life", "short_description": "So what happened . Humans Happened. Water politics paralyze the region while issues remain unresolved, the sea\u2019s water levels continue to disappear rapidly, 35 meters in 35 years. As this ecological disaster leaves in its wake a fragile landscape, it also dramatically reshapes people\u2019s lives."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vTB9QkEglEoGWqRiiejtmGluAKDptYFAgijYU1fjypF3J8n1QQQVWJ1R5-_1hUzRkqSCDwaxKOhSJew/pub", "developer_terms_of_service_url": null, "publisher_name": "Blimey TV", "support_website_url": null, "website_url": "http://blimey.tv/blog/welcome-to-our-blog-but-what-is-it", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "476233047407103"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "402282731665713"}]}, "baseline_offer": {"id": "402282731665713"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1644619680, "status": "PUBLISHED", "id": "402282731665713"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5108938222451789", "version": "2"}, "id": "285089196906333", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinar