682050", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75462961_828897662015383_3747885686094884541_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iS5zvpz3eg4Q7kNvgFDjOw3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAGAsXw-rkRnyDIbyZqh0-my9LrTfF-hwcQsCuvyGuepw&oe=6762C6E6"}, {"file_name": "Blood Pressure Check Simulator_Screenshot_06.png", "id": "411851528398966", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_411851531732299_2693507955641970078_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mm_5jiqD0dQQ7kNvgECZStb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDx2sSLlXJxFAc9TiSjgo3yJeWqr7j1j3g56xKbkcn5_g&oe=6762CD18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "301541419690023", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_301541423023356_4938514156357818911_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QU2K11n5d9wQ7kNvgEqX6UU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAAG0AkYxXl7Op1SMdz-EMVNxY13mR-lnflfkoiIXLMZQ&oe=6762D0D4"}, "display_name": "Blood Pressure Check Simulator", "keywords": [], "long_description": "The Blood Pressure Check Simulator app immerses participants in a realistic virtual environment where they can practice and refine their skills in measuring and interpreting blood pressure readings. This application guides users through the proper selection and use of a blood pressure cuff, the correct procedure for taking a reading, and the interpretation of the results.\n\n# Learning Objectives:\n- Remembering the steps of the procedure\n- Understanding the significance of systolic and diastolic values\n- Applying the correct technique in a virtual scenario\n- Analyzing the accuracy of readings\n- Evaluating the results against normal ranges \n- Creating a plan for patient follow-up based on the readings obtained\n\nThis comprehensive simulation ensures that certified nursing assistant's or anyone interested in the h