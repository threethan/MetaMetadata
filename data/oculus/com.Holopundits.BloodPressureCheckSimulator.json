"}]}, "id": "926434449218967", "locale": "en_US", "screenshots": [{"file_name": "Blood Pressure Check Simulator_Screenshot_01.png", "id": "544810938533024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75641342_544810945199690_4470805562282520344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4sxymKTCzkMQ7kNvgH6fxdX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUGFe8Fy171DGP41EZZNf306CrWAzQb0wmz4bRbduWZQ&oe=6773F390"}, {"file_name": "Blood Pressure Check Simulator_Screenshot_02.png", "id": "1669850440231996", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75308616_1669850443565329_6680430181113513362_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IFyjpQT2fTwQ7kNvgEZGVUx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtiYDoPQVsraVMY_ZR35b7hMXQgB028v2r8aQamjCeqg&oe=6773CC78"}, {"file_name": "Blood Pressure Check Simulator_Screenshot_03.png", "id": "557282607222132", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974589_557282610555465_8054978692493683166_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-bZDkPzjyZcQ7kNvgGvoHKw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEC8bVFrmk63V4I1opVGkzP_8eA02Qew2iOdxtzDrYZA&oe=6773F0CB"}, {"file_name": "Blood Pressure Check Simulator_Screenshot_04.png", "id": "2634128040120476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982452_2634128043453809_1270987149800978371_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xtnSwHViGE8Q7kNvgHVD0pY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_vvGxe0WEQlRfEEkhaqNcnOSU_6mQxpjdnUUYmqS3Yg&oe=6773CA53"}, {"file_name": "Blood Pressure Check Simulator_Screenshot_05.png", "id": "613542804438356", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974915_613542807771689_6093729675850183217_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nkjm4reffkUQ7kNvgFO41Ft&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDVW0Fh93k--uB_GrMoXXiOAZLn392_B4o9a60pPCOJJQ&oe=6773C712"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Blood Pressure Check Simulator_Screenshot_03.png", "id": "933691004936744", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031437_933691008270077_921704919857808857_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jf9VH3m0fYwQ7kNvgGBhOLl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrH705078itCmOZVU93g7YFL6QkjGiodFcK9bjysPFGg&oe=6773D526"}, "display_name": "Blood Pressure Check Simulator", "keywords": ["cna", "nurse", "nursing", "BP", "Healthcare"], "long_description": "The Blood Pressure Check Simulator app immerses participants in a realistic virtual environment where they can practice and refine their skills in measuring and interpreting blood pressure readings. This application guides users through the proper selection and use of a blood pressure cuff, the correct procedure for taking a reading, and the interpretation of the results.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features\n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives:\n- Remembering the steps of the procedure\n- Understanding the significance of systolic and diastolic values\n- Applying the correct technique in a virtual scenario\n- Analyzing the accuracy of readings\n- Evaluating the results against normal ranges \n- Creating a plan for patient follow-up based on the readings obtained\n\nThis comprehensive simulation ensures that certified nursing assistant's or anyone interested in the healthcare field are well-prepared to perform blood pressure measurements accurately and confidently in real-world clinical settings.", "short_description": "Designed to train CNAs in accurately measuring and interpreting patient blood pressure using an interactive, hands-on virtual scenario with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27776850205295810"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974788_544350578364689_3596253973155763826_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zM3BFXCZTX0Q7kNvgGb7Wfh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeopRU4JuvjbZyQeOApA3kmPIRKbIj_ijn8vJaarS-qw&oe=6773DA13"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Blood Pressure Check Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_nam