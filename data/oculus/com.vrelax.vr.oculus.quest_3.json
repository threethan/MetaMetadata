dn.com&oh=00_AYBBsBMQCv9innVjpFty20va6LFWDcHCn2zNpoab9OJ86A&oe=675597B7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VRelax - Quest 3", "keywords": [], "long_description": "Many people suffer from stress, such as burn-out, depression or anxiety. This results in a lot of personal suffering and high medical costs (CBS, 2019).Reducing stress and learning to relax is an important pillar of good mental health. But that is easier said than done. That\u2019s why VRelax was created because we have experienced that Virtual Reality has a very fast and strong effect on body and mind.", "short_description": "VRelax is a virtual reality app that helps people to reduce their stress level and improve their mood. Scientific research has shown that VRelax is effective. It is a relaxation tool to reduce stress, burnout, anxiety and depression. VRelax can also be used as a distraction tool for pain management, physical discomfort and medical procedures. From mild stress to severe health complications, VRelax can provide relief at any time and place for any kind of stress."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrelax.com/en/privacy-statement/", "developer_terms_of_service_url": "https://vrelax.com/wp-content/uploads/2022/06/VRelax_Algemene-Voorwaarden_NL-C00421-1679622868-61-002_ver.-WeFact.pdf", "publisher_name": "VRelax B.V.", "support_website_url": "https://vrelax.com/en/support", "website_url": "https://vrelax.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl"], "supported_input_devices": ["OCULU