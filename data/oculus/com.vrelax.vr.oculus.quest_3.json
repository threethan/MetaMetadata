F3E5EA"}, {"file_name": "75462965_601876351583554_5297430548521710064_n.png", "id": "806686838073768", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569432_806686841407101_7724895919713055786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZTX-EwSsAJoQ7kNvgFq99AR&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6Ou2UE9B-EyeYjKbvJjjzJ&oh=00_AYBBxTtQoI3QplTbl0x_9eRh6hCf2DlE7ieXnrWir8OIHQ&oe=66F408B7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VRelax - Quest 3", "keywords": [], "long_description": "Many people suffer from stress, such as burn-out, depression or anxiety. This results in a lot of personal suffering and high medical costs (CBS, 2019).Reducing stress and learning to relax is an important pillar of good mental health. But that is easier said than done. That\u2019s why VRelax was created because we have experienced that Virtual Reality has a very fast and strong effect on body and mind.", "short_description": "VRelax is a virtual reality app that helps people to reduce their stress level and improve their mood. Scientific research has shown that VRelax is effective. It is a relaxation tool to reduce stress, burnout, anxiety and depression. VRelax can also be used as a distraction tool for pain management, physical discomfort and medical procedures. From mild stress to severe health complications, VRelax can provide relief at any time and place for any kind of stress."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrelax.com/en/privacy-statement/", "developer_terms_of_service_url": "https://vrelax.com/wp-content/uploads/2022/06/VRelax_Algemene-Voorwaarden_NL-C00421-1679622868-61-002_ver.-WeFact.pdf", "publisher_name": "VRelax B.V.", "support_website_url": "https://vrelax.com/en/support", "website_url": "https://vrelax.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}