c=K-Pt8vxVOwYQ7kNvgEZ3G3r&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_flguglAA7D8hvcXQrUrMSP1qR7df3Q6KFz9A3SaWpA&oe=66D99363"}, {"file_name": "38974824_794088151589027_2974708319604114360_n.png", "id": "2436058656577502", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003247_2436058659910835_7614286475388164355_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ssslOXRI34Q7kNvgGm7lQO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmsYZNzQAXfUdxMz5aw-NmvjuYCd8roQWxVH9aKbJk7A&oe=66D97F90"}, {"file_name": "75307246_455278679856687_864923497991710047_n.png", "id": "3331614370472722", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974608_3331614377139388_4805779949039153496_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iZ4v5LW66lQQ7kNvgG6CHXb&_nc_ht=scontent.oculuscdn.com&oh=00_AYBht7uMyuyenn2Ex2HuNNELJaYF8o2xBrMS8FxlQDTydA&oe=66D9B174"}, {"file_name": "75210891_5441969079214514_5020506565144759968_n.png", "id": "1115576252886566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86627649_1115576256219899_2284973846805312015_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CIa3KkggJLYQ7kNvgE77NBI&_nc_ht=scontent.oculuscdn.com&oh=00_AYDzRm7ZpEslVXwCK78JgD-dI7qhYFLJoW6pGJvyBTmQ9A&oe=66D987EA"}, {"file_name": "75462965_601876351583554_5297430548521710064_n.png", "id": "806686838073768", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569432_806686841407101_7724895919713055786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_issKlMYSsoQ7kNvgHcSkB4&_nc_ht=scontent.oculuscdn.com&oh=00_AYD4JwfGfzN5pK9vj48euLibaJcvQLySz00A_WukNduybw&oe=66D9AAB7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VRelax - Quest 3", "keywords": [], "long_description": "Many people suffer from stress, such as burn-out, depression or anxiety. This results in a lot of personal suffering and high medical costs (CBS, 2019).Reducing stress and learning to relax is an important pillar of good mental health. But that is easier said than done. That\u2019s why VRelax was created because we have experienced that Virtual Reality has a very fast and strong effect on body and mind.", "short_description": "VRelax is a virtual reality app that helps people to reduce their stress level and improve their mood. Scientific research has shown that VRelax is effective. It is a relaxation tool to reduce stress, burnout, anxiety and depression. VRelax can also be used as a distraction tool for pain management, physical discomfort and medical procedures. From mild stress to severe health complications, VRelax can provide relief at any time and place for any kind of stress."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrelax.com/en/privacy-statement/", "developer_terms_of_service_url": "https://vrelax.com/wp-content/uploads/2022/06/VRelax_Algemene-Voorwaarden_NL-C00421-1679622868-61-002_ver.-WeFact.pdf", "publisher_name": "VRelax B.V.", "support_website_url": "https://vrelax.com/en/support", "website_url": "https://vrelax.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7811059505609195"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1016878043103727"}]}, "baseline_offer": {"id": "1016878043103727"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1717008120, "status": "PUBLISHED", "id": "1016878043103727"}]}, "liveChannel": {"nodes": [{"latest_