8679856687_864923497991710047_n.png", "id": "3331614370472722", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974608_3331614377139388_4805779949039153496_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=20WTQ1Sd9z0Q7kNvgFtbmVA&_nc_ht=scontent.oculuscdn.com&oh=00_AYAogTlaGjMvW4iD7guP7eu2VWCtsBMhkgiImoRB_1OdJg&oe=66E831F4"}, {"file_name": "75210891_5441969079214514_5020506565144759968_n.png", "id": "1115576252886566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86627649_1115576256219899_2284973846805312015_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=carv8d5L0vQQ7kNvgF95VaV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJHxc0pf4aPH73YNwNYl0bXm4lOxJba_KQP5SJRnPN1Q&oe=66E8086A"}, {"file_name": "38974824_794088151589027_2974708319604114360_n.png", "id": "2436058656577502", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003247_2436058659910835_7614286475388164355_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fNsyIoeL8dkQ7kNvgFISa4X&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9AGYnvF4I-1X5oIOM7OcPqFTflsi8uvOpl-Nb-ChBPQ&oe=66E80010"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus-cover-landscape.png", "id": "1158136038734740", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984447_1158136042068073_7659915589654357513_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DkcfHtXmuZIQ7kNvgFEeS9P&_nc_ht=scontent.oculuscdn.com&oh=00_AYBYmKEPUDBtb0Y1zLs4FfXhNxg7_wlG4vblt4nboKG4tg&oe=66E82E81"}, "display_name": "VRelax - Quest 3", "keywords": [], "long_description": "**A valid VRelax license is required in order to use this App. Please refer to the VRelax website for more information**\n\nHundreds of hospitals and mental healthcare providers worldwide use VRelax to help patients manage stress-related symptoms such as insomnia, anxiety, and depression.\n\nUsers can fully immerse themselves in virtual reality for a short session as they are taken into a photorealistic VR environment created to help you relax. Participate in breathing exercises, listen to relaxing tones of the nature around you or simply enjoy the view. \n\nAt VRelax, we're committed to providing affordable, accessible, and validated VR e-health treatments. Join us in embracing the future of relaxation.", "short_description": "Immerse yourself in relaxation with VRelax. Trusted by hundreds of healthcare organisations worldwide, our VR app offers a scientifically validated solution for managing stress symptoms. \n\nEngage in breathing exercises, listen to soothing nature sounds, and enjoy photorealistic environments. \n\nWe aim to provide society with affordable, accessible and validated VR e-health treatment. Join us in embracing the future of relaxation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrelax.com/en/privacy-statement/", "developer_terms_of_service_url": "https://vrelax.com/en/algemene-voorwaarden-en-condities/", "publisher_name": "VRelax B.V.", "support_website_url": "https://vrelax.com/en/support", "website_url": "https://vrelax.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8038654459516364"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75603734_982588653259098_5575451316012754595_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WTjNl8wwVlcQ7kNvgErDs_Q&_nc_ht=scontent.oculus