 null, "video_trailer_thumbnail": null, "display_name": "Escape From Bunker 14", "keywords": ["escape", "adventure", "puzzle", "game"], "long_description": "You begin with no memory of who you are, or where you are. You seem to be in some sort of military bunker... but why?\n\nAs you descend through the levels of the bunker, you begin to work out what happened in this place and why you're here. In the end it becomes a race against time, with high stakes and difficult challenges.\n\nThis is an adventure-style game, all about exploration and problem-solving. There are no zombies, no \"jump scares\" and nothing is trying to kill you. It's just you against the bunker, as you try to find your way out.\nNote -- this is a small game, with an estimated play-through time of about half an hour.", "short_description": "This is a short adventure-style game, all about exploration and problem-solving. There are no zombies, no \"jump scares\" and nothing is trying to kill you. It's just you against the bunker, as you try to find your way out."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tiriam.com/#%21bunker14%2Fcs7r3", "developer_terms_of_service_url": "http://www.tiriam.com/#%21bunker14%2Fcs7r3", "publisher_name": "Tiriam Immersive Media", "support_website_url": null, "website_url": "http://www.tiriam.com/#%21bunker14%2Fcs7r3", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EXPLORATION", "ADVENTURE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "323154106528627"}, "review_messages": [""]}]}, "cove