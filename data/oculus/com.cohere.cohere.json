872145257315952_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SisFRsPVbMkQ7kNvgESfSWA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgDjC7Uho6hBMDK69NnA3OGwYhDXH2V8sIGl3c_7ZZsg&oe=676BD9D4"}, {"file_name": "181862453_456891438732663_6570000156002538162_n 2.png", "id": "370686698041304", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974779_370686701374637_8946645015137559248_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h4dfDy9SDiEQ7kNvgF9xKrv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHyKaqXt301LN0YwC4Ls374OHFW5TaNZTmtqG5bHEqsA&oe=676BDB3B"}, {"file_name": "23.png", "id": "1006052623560181", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974909_1006052630226847_7999381520604970027_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vDmIzIXQqZMQ7kNvgGgPVP1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBF7R62_-HGT9U79BSpI8EfwKQddzSZaKTFI61P3zMtHg&oe=676BDA76"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cohere", "keywords": [], "long_description": "Regain creative vitality with virtual reality!\nWorkshops have helped teams go faster for ages. Get on the same page and build momentum with new ideas. That\u2019s the gist.\n\nThen we went remote, and now workshops suck. They slow us down. Some old technophobe is hogging the microphone with complaints, trying to find the zoom-button. It turns out sitting on our butts all day isn\u2019t very inspiring, and we feel our creative juices flowing freely down the drain.\n\nSo we got off our asses and now we\u2019re making Cohere. It\u2019s a virtual reality platform for workshops, that\u2019s actually easy to use. Even for those pesky boomers.", "short_description": "We make remote workshops brilliant with VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cohere.fun/brukervilkaar/", "developer_terms_of_service_url": null, "publisher_name": "Cohere XR", "support_website_url": "https://cohereapp.typeform.com/to/s