], "long_description": "Shelley\u2019s Creation is an immersive theater that presents Mary Shelley\u2019s inspirations to create the famous sci-fi gothic novel - Frankenstein, or The Modern Prometheus.\n\nPut on your headset to attend this multiplayer exploration. You are traveling as a ghost to the year 1816 when Mary Shelley started her novel - Frankenstein. You found yourself inside part of the story of Mary Shelley\u2019s Frankenstein, Lord Byron and Percy Shelley\u2019s poems in the romanticism era, and John Milton\u2019s Paradise Lost.\n\nWhich ways will you choose? The paths to paradise or hell?", "short_description": "Inspired by Sleep-No-More and The Under Presents: Tempest. We attempt to build an immersive theater related to Mary Shelley\u2019s inspirations that led her to create the famous sci-fi gothic novel - Frankenstein, or The Modern Prometheus."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sciencevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.sciencevr.com/terms-of-use", "publisher_name": "ScienceVR, Inc.", "support_website_url": "https://sciencevr.com/support", "website_url": "https://sciencevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "2019569808224187"}, "review_messages": ["", "Please provide valid links and 