.com/wifi-direct"}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersed.com/privacy", "developer_terms_of_service_url": "https://immersed.com/terms", "publisher_name": "Immersed Inc.", "support_website_url": "https://immersed.com/community", "website_url": "https://immersed.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1055187466124150"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "UTILITY", "MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD_VIA_TOUCH", "OCULUS_TOUCH", "HAND_TRACKING", "TRACKED_KEYBOARD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "23985784567734768"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031613_2505329773000109_2805114907440426918_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=Ptrz8pweYOoQ7kNvgFeMJrr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbTUMP4XB99K0Kzr_QTpdlPOZ4IvrlxtulPJl3YkFmDg&oe=67277C46"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Immersed", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Computer Link", "id": "1055187466124150"}, {"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 1595523587, "lastRevision": {"nodes": [{"id": "2274675929464458", "release_type": "MANAGED", "administration_st