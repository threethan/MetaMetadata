aDP8A&oe=66DEEB41"}, {"file_name": "p4.png", "id": "1630108077828522", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974865_1630108081161855_1443105396158647867_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T-l5MWVH77UQ7kNvgEBpuhP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqDNUNtyxPypktR9OimWnT8&oh=00_AYCoHkRI4z1pyGDXE7sMo1bfZKfkUGuQ8MA51_lPF9AEGQ&oe=66DEF6F0"}, {"file_name": "d4.png", "id": "421856310661911", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75411995_421856313995244_299677034213495421_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nao1ocjJsDgQ7kNvgGlcyLg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqDNUNtyxPypktR9OimWnT8&oh=00_AYDO7QWroQqmkJVl9GSiOnkKKJ623zv3p01_CRnbB0x0JQ&oe=66DEE20B"}, {"file_name": "v1.png", "id": "984429956747844", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982621_984429960081177_5366525785618080994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-vD9cCsue2AQ7kNvgGvIUms&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqDNUNtyxPypktR9OimWnT8&oh=00_AYCMvOyFaflsm8CwDw_rfgcTq2STZmnRNTesDlUZynZZCw&oe=66DEDD20"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverH.png", "id": "1487750508524096", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520119_1487750511857429_7861293774588014887_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mj2TiXgerCwQ7kNvgF_r5Gd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqDNUNtyxPypktR9OimWnT8&oh=00_AYAfBj2uK1m78GkiZDu_jTyS9fTI1tztbIRhB8E_8lsE_Q&oe=66DEED21"}, "display_name": "Magical Doodle", "keywords": [], "long_description": "Turn Your Room into a Canvas, Your Space into a Studio! Experience a New Dimension of Art with Just a Finger Touch.\nDive into the magical world of VR drawing! Unleash your creativity and cross the boundaries between reality and virtual art.\n\nKey Features:\nCanvas Selection: Choose from AR mode, where your real room becomes the canvas, or VR mode, where you can draw in stunning virtual environments like starry skies, outer space, or underwater worlds.\nDraw with Fingertips: Create art with simple hand gestures. Just move your fingers in the air to draw\u2014it's like magic! Experience intuitive and free expression.\nVariety of Pens: Enjoy colorful art with 13 special pens, including stars, flames, hearts, and snowflakes.\nAnimation Effects: Watch your drawings appear and disappear like magic with 10 types of animations, offering amazing expressive power.\nSave and Load Your Work: Save your precious artwork and load it anytime to continue creating from where you left off.\nSharing Features: Use Quest's recording feature to share and showcase your animated artwork as videos.\n\nUse the Quest recording feature to share and showcase your animated masterpieces in videos!\nDownload now and transform your room or virtual space into a canvas to explore infinite possibilities!\n\nThis app is planned to become a paid service.\n\nSound Design & Sound Programing by AT-Music", "short_description": "Experience VR drawing and unleash your creativity by blending reality with virtual art.\n\nKey Features:\nCanvas Selection: AR mode to turn your room into a canvas or VR mode for virtual environments.\nFingertip Drawing: Draw with simple hand gestures for intuitive and free expression.\nVariety of Pens: Use 13 special pens.\nAnimation Effects: Enjoy 10 animations to make your drawings appear and disappear like magic.\nSave and Load: Save your artwork and continue creating anytime."}, {"images": {"nodes": []}, "id": "1036664594487317", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Magical Doodle", "keywords": [], "long_description": "\u90e8\u5c4b\u304c\u30ad\u30e3\u30f3\u30d0\u30b9\u3001\u7a7a\u9593\u304c\u30b9\u30bf\u30b8\u30aa\uff01 \u6307\u5148\u3067\u63cf\u304d\u3001\u64cd\u308b\u65b0\u611f\u899a\u306e\u30a2\u30fc\u30c8\u4f53\u9a13\u3002\nVR\u3067\u9b54\u6cd5\u306e\u3088\u3046\u306b\u304a\u7d75\u63cf\u304d\u3092\u697d\u3057\u3082\u3046\uff01 \u60f3\u50cf\u529b\u3092\u89e3\u304d\u653e\u3061\u3001\u73fe\u5b9f\u3068\u4eee\u60f3\u306e\u5883\u754c\u3092\u8d8a\u3048\u305f\u30a2\u30fc\u30c8\u306e\u4e16\u754c\u306b\u98db\u3073\u8fbc\u3082\u3046\uff01\n\n\u4e3b\u306a\u6a5f\u80fd\uff1a\n\u30ad\u30e3\u30f3\u30d0\u30b9\u9078\u629e\uff1a\u73fe\u5b9f\u4e16\u754c\u306e\u90e8\u5c4b\u3092\u30ad\u30e3\u30f3\u30d0\u30b9\u306b\u3059\u308bAR\u30e2\u30fc\u30c9\u3001\u661f\u7a7a\u3084\u5b87\u5b99\u3001\u6d77\u4e2d\u306a\u3069\u306e\u7f8e\u3057\u3044\u4eee\u60f3\u7a7a\u9593\u3067\u63cf\u3051\u308bVR\u30e2\u30fc\u30c9\u3092\u642d\u8f09\u3002\n\u6307\u5148\u3067\u63cf\u304f\uff1a\u7a7a\u4e2d\u306b\u6307\u3092\u52d5\u304b\u3059\u3060\u3051\u3067\u7d75\u3092\u63cf\u3051\u308b\u3001\u9b54\u6cd5\u306e\u3088\u3046\u306a\u30cf\u30f3\u30c9\u30b8\u30a7\u30b9\u30c1\u30e3\u30fc\u64cd\u4f5c\u3002\u76f4\u611f\u7684\u3067\u81ea\u7531\u306a\u8868\u73fe\u304c\u53ef\u80fd\u3067\u3059\u3002\n\u591a\u5f69\u306a\u30da\u30f3\uff1a\u661f\u3001\u708e\u3001\u30cf\u30fc\u30c8\u3001\u96ea\u306e\u7d50\u6676\u3001\u97f3\u7b26\u306a\u3069\u300113\u7a2e\u985e\u306e\u7279\u5225\u306a\u30da\u30f3\u3067\u30ab\u30e9\u30d5\u30eb\u306a\u30a2\u30fc\u30c8\u3092\u697d\u3057\u3081\u307e\u3059\u3002\n\u30a2\u30cb\u30e1\u30fc\u30b7\u30e7\u30f3\u52b9\u679c\uff1a\u63cf\u3044\u305f\u7d75\u304c\u9b54\u6cd5\u306e\u3088\u3046\u306b\u73fe\u308c\u305f\u308a\u6d88\u3048\u305f\u308a\u3059\u308b\u300110\u7a2e\u985e\u306e\u30a2\u30cb\u30e1\u30fc\u30b7\u30e7\u30f3\u3067\u9a5a\u304d\u306e\u8868\u73fe\u529b\u3002\n\u4f5c\u54c1\u306e\u4fdd\u5b58\u3068\u8aad\u307f\u8fbc\u307f\uff1a\u5927\u5207\u306a\u4f5c\u54c1\u3092\u4fdd\u5b58\u3057\u3001\u3044\u3064\u3067\u3082\u8aad\u307f\u8fbc\u3093\u3067\u7d9a\u304d\u304b\u3089\u63cf\u3051\u307e\u3059\u3002\n\nQuest\u306e\u9332\u753b\u6a5f\u80fd\u3067\u3001\u30a2\u30cb\u30e1\u30fc\u30b7\u30e7\u30f3\u4f5c\u54c1\u3092\u52d5\u753b\u3067\u5171\u6709\u30fb\u516c\u958b\u3057\u3088\u3046\uff01\n\u4eca\u3059\u3050\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3057\u3066\u3001\u