ive is simple yet challenging: control your balls, follow the lines, roads, and reach the destination.", "short_description": "Welcome to Ball Lines, an innovative and immersive VR game that challenges your precision, reflexes, and strategic thinking. Dive into a futuristic world where you control dynamic spheres, navigating them through intricate tracks and lines. Your goal is to guide these spheres to their destination while overcoming various obstacles and challenges."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/sneakandsteal/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "CCAA Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/sneakandsteal", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7955466384522140"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "1987008405109782"}, {"status": "PUBLISHED", "id": "1154654502259921"}]}, "baseline_offer": {"id": "1154654502259921"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1987008405109782"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7955857537816358", "version": "1.0"}, "id": "464132323013228", "channel_name": "LIVE"}]}, "is_for_oc