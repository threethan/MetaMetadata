6848_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QpgT1SkaXmIQ7kNvgFPM1wT&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBXBjetH_GfZXMPcRzSWeF_xlISEzi1DkeBSFV3G5cjPQ&oe=6780ED45"}, {"file_name": "ss2.png", "id": "474273005196713", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035405_474273008530046_5703622255577249167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UYJB4kpv3DQQ7kNvgEUmKNG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCqhkRUSDjMCW2IqbZc9zEtdq-F7Ifuv0dC52p-F9DE3Q&oe=6780FCBD"}, {"file_name": "ss3.png", "id": "826237469464919", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572934_826237472798252_8499873791658789455_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jp3oKdD7l3EQ7kNvgGXO9P2&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD9wKU_24jn-yM6ivUvfICCrBePkDFBP92Xu56YQPBfig&oe=67811A9F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1017351233357847", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031478_1017351236691180_2383292809881305642_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iXRv4u__zUAQ7kNvgE1yqJ7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDj8dFN06HWP8gNGba27AK3CQ5UNY17Vd6tw3LET5M6jQ&oe=67810F0D"}, "display_name": "Sneak and Steal", "keywords": [], "long_description": "Welcome to Ball Lines, an innovative and immersive VR game that challenges your precision, reflexes, and strategic thinking. Dive into a futuristic world where you control dynamic spheres, navigating them through intricate tracks and lines. Your goal is to guide these spheres to their destination while overcoming various obstacles and challenges.\nGameplay\n\nBall Lines offers a unique and engaging gameplay experience, utilizing VR technology to create a sense of presence and immersion like never before. Players will find themselves in a mesmerizing environment filled with vibrant colors, futuristic designs, and intricate paths. The primary objective is simple yet challenging: control your balls, follow the lines, roads, and reach the destination.", "short_description": "Welcome to Ball Lines, an innovative and immersive VR game that challenges your precision, reflexes, and strategic thinking. Dive into a futuristic world where you control dynamic spheres, navigating them through intricate tracks and lines. Your goal is to guide these spheres to their destination while overcoming various obstacles and challenges."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/sneakandsteal/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "CCAA Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/sneakandsteal", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7955466384522140"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "1987008405109782"}, {"status": "PUBLISHED", "id": "1154654502259921"}]}, "baseline_offer": {"id": "1154654502259921"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1987008405109782"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7955857537816358", "version": "1.0"}, "id": "464132323013228", "channel_name": "LIVE"}]}, "is_for_oc