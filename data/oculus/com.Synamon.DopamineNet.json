n.com&_nc_gid=Au14Mty68T9C82vKyQskOkJ&oh=00_AYAXYI94bsdCah3eeAA0MVFfBTwz5iC1AlYDRMdwgpVZsA&oe=66DD92FA"}, {"file_name": "migrated_image.png", "id": "260279541634855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12727794_328832057456154_1909041952_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6BOkpnrbeoQ7kNvgG-aHgb&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au14Mty68T9C82vKyQskOkJ&oh=00_AYDbCskuh9yz2v08CyztzKpNkoSMqOnlz0sEnO0Bq5TMeg&oe=66DD91EB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DOPAMINE", "keywords": ["shooting", "action", "dopamin", "Unity", "VR"], "long_description": "DOPAMINE is a competitive high-speed action shooter in VR. \nFly and boost-dash through space, fire your beams and homing lasers, and go head-to-head against your opponents!\n\nTwo game modes are available: Single Play for just you, and an Online Play mode to compete against other players.\n\nSet your username and character from the settings, and learn the basics by playing the tutorial mode. You can use Key Config to rearrange the button mappings as you like.\n\nPractice makes perfect. Improve your skills to reach for the top spot in the rankings!", "short_description": "DOPAMINE is a competitive high-speed action shooter in VR. Fly, boost-dash, and use your beams and homing lasers to rack up your points!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://synamon.jp/dopamine_term-of-use", "developer_terms_of_service_url": "http://synamon.jp/dopamine_term-of-use", "publisher_name": "Synamon Inc.", "support_website_url": null, "website_url": "http://synamon.jp/DOPAMINE_manual.pdf", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "SHOOTER", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommend