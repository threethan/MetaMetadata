0a&_nc_ohc=Zw-ogO8dpHoQ7kNvgE6qK6-&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCbV4MIy13gY6qQO2mydKVs6lNfnldh3cfybVa53jl5aQ&oe=67518A77"}, {"file_name": "Battles---New-Card.png", "id": "1254739841808321", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982709_1254739848474987_5086793005295979524_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G2lbDnP8bQEQ7kNvgHqU77p&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAT-Dk6fej3h6RFwjt_TKNnKIpF5o084Uzn_yB7s7poyw&oe=67518621"}, {"file_name": "Battles---Overview2.png", "id": "1210464476321351", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031355_1210464479654684_311058227055271208_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NM56XfJS8QIQ7kNvgHig9JD&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYANxUkz_EIpBCW-iK0DP5GixQjg959ZSQnSoDHo0hHluA&oe=67517D5F"}, {"file_name": "Battles---Place-units2.png", "id": "789704312284193", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39031355_789704315617526_2792818596407696198_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7n8hPgHNg7YQ7kNvgFRTibB&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYD2x3xI791b6m-Pd093dHLHIzqsIEnore0BOvOTSLEhjw&oe=67518D34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DemeoBattles_Thumbnail.png", "id": "637664445068835", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75557069_637664448402168_1933084965014661694_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g-KAFP03_G0Q7kNvgF9ynTj&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDAJV8Pi01TYv4__vy1ZwidrG8-0s3OnVrWGzvD3IkLUw&oe=67519CA5"}, "display_name": "Demeo Battles", "keywords": [], "long_description": "Welcome to the arena! Demeo Battles is a competitive turn-based strategy game for 1-4 players, featuring\u2026\n\n\u2022 Turn-based Tactics - Battle your opponents in dungeons, forests and more as you square off against your opponents in grid-based action combat\n\n\u2022 Monstrous Minions - Assemble an army of chaotic critters to fight alongside you \u2014 from rats and goblins to cave trolls to giant slimes, all with a mind of their own! \n\n\u2022 Teamwork FTW - Bring two champions to the battle in every match and leverage their synergies; control both heroes directly or partner up with another player to defeat competitors  cooperatively  \n\n\u2022 Classic Classes - Choose a champion that matches your favorite fantasy play style to unleash magic, melee mayhem and more\n\n\u2022 Bespoke Builds - Spend your coins wisely when you enter the arena to build a unique loadout in every game, choosing from a randomized selection of action cards and monsters\n\n\u2022 Speedy Strategy - Challenge yourself to battle after battle with average matches lasting just under 20 minutes  \n\nComing later this year, Demeo Battles is the next game for the Demeo Action Role Playing System. Wishlist today!\n", "short_description": "Demeo Battles is a competitive turn-based strategy game for 1-4 players. Choose your champion, assemble an army of monstrous minions, and team up with another champion in your quest for turn-based glory!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.resolutiongames.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Resolution Games", "support_website_url": null, "website_url": "http://demeobattles.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_playe