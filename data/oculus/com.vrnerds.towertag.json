 strategy are also essential.", "short_description": "Tower Tag is a hyper-dynamic futuristic paintball like PVP shooter with a grappling hook locomotion method that becomes second nature instantly. Without any motion sickness!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrnerds.de/tower-tag-quest-privacy/", "developer_terms_of_service_url": null, "publisher_name": "VR Nerds Studios", "support_website_url": null, "website_url": "https://vrnerds.biz/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "397796155661957"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1573234809923703"}, {"status": "PUBLISHED", "id": "717738715976301"}, {"status": "PUBLISHED", "id": "596516659230704"}]}, "baseline_offer": {"id": "1573234809923703"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724225460, "status": "PUBLISHED", "id": "1573234809923703"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7791426937583545", "version": "openxr_2.0.21"}, "id": "419413445992170", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3812563858803226", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "i