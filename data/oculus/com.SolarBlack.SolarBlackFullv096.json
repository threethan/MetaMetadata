t=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D5inxfLK-GwQ7kNvgGeq9DT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOcbXFYJpaq9E2VlYrmM7HukjRayfdIm0AHVVEn8navQ&oe=6720BD63"}, {"file_name": "SolarBlack Mata Portrait new final.png", "id": "507133395440969", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974741_507133398774302_1883834077931045741_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5eX6iY0MJ5oQ7kNvgEonmOi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2AzJGtct1QySy-qg7cTCAkicN4o9sk2w19e9MKA6fww&oe=6720DCEC"}]}, "id": "561680449671231", "locale": "en_US", "screenshots": [{"file_name": "1_SolarBlackQuest_Screenshot.png", "id": "443122548051574", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75303840_443122551384907_5003313074114795250_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X5kMKDxboUcQ7kNvgHuD547&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFTzUhPGIObqu9W2U9bJiWT8ff7uHYyvGC-4zRphgQkw&oe=6720BD83"}, {"file_name": "4_SolarBlackQuest_Screenshot.png", "id": "1116821736228525", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221324_1116821739561858_4157269610778622314_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_fO596DE4OEQ7kNvgEoiVBm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC--5HXdEHERQrt8leezlIwtijSfQ9y2K8JrWc80gM07Q&oe=6720B405"}, {"file_name": "2_SolarBlackQuest_Screenshot.png", "id": "368572792710893", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86613167_368572796044226_5809498655111946243_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X8c3j8VOxc4Q7kNvgGgQvjN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClwUAlkSlj7WnjJoMh4nJh12B19MEcLyKY20jUxAkQWA&oe=6720C7DE"}, {"file_name": "4_1440p.png", "id": "632183495447001", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974633_632183498780334_8801135400521344320_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MebuTLU7kF8Q7kNvgE-vm3W&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgcriODRJ0Rgsv7umUJxI-7B-0qxEfJJI0uRC85_NX8Q&oe=6720BCB8"}, {"file_name": "3_1440p.png", "id": "250550250694660", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974709_250550254027993_6885754610064091669_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vNDYEwiZeL0Q7kNvgE8PoFJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAilMzBKN8ztW3j-IACpthFupZf_dMLvHQOxuzSf_m-rg&oe=6720E544"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SB_Cybersymphony_CoverLandscape.png", "id": "3593637784247199", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031604_3593637790913865_3587406416698179347_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VIbXxUmfi1EQ7kNvgGqP8iW&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8TDhKfVdU60SB8q0upXX2VzE2kEdQr3TCNZ211Tfw1Q&oe=6720E6ED"}, "display_name": "SolarBlack", "keywords": ["dance", "rhythm", "music", "beat", "action"], "long_description": "SolarBlack is an action-rhythm game made exclusively for VR where you slice and shoot to the beat to defeat an other-worldly threat. Immerse yourself in new worlds as you train your body and mind in time to handcrafted soundtracks. Control the tempo of the battle as you see fit with **Flextime** and seek to unravel the secrets of the universe on your journey to becoming the ultimate legend of sound and space.\n- 5 different difficulties for every legend or legend-in-training\n- Over 31 environments, some of which might look familiar to you\n- Achievements & collectables\n\n# Saber Guns\n{890920122977244}\nThis is the first VR game that weaves **two awesome fighting styles** together in a single pulse-pounding, unstoppable rhythmic action. Featuring a soundtrack specially composed to accompany incredible graphics and atmospheric worlds that pulses to the beat. \n\n# Flextime\n{3666338663677854}\nWant that extra **\"Matrix\" flair** while you decimate everything in your path? Activate Flextime to slow down every single enemy and target, and carefully plan your next move.\n\n# Fitness\n{463808249399988}\n\nGet fit with SolarBlack! Looking to add another game to your VR fitness game library? Take advantage of our Fitness Mode and throw those hard punches at incoming targets! Not only does it grant you max score, it's also **guaranteed to make you sweat**.\n\n", "short_description": "SolarBlack is an action-rhythm game made exclusively for VR where you slice and shoot to the beat to defeat an other-worldly threat. Immerse yourself in new worlds and experience the music in every pulsating atom. Control the tempo of the battle as you see fit with Flextime and strategically plan each victory on your journey to becoming the ultimate hero of sound and space."}]}, "developer_name": "SolarBlack", "developer_privacy_policy_url": "https://solarblack.net/docs/EULA_Privacypolicy.txt", "developer_terms_of_service_url": "https://solarblack.net/docs/EULA_Privacypolicy.txt", "publisher_name": "Andromeda Entertainment", "support_website_url": "https://solarblack.net/", "website_url": "https://solarblack.net/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "ko", "pt", "en", "it", "fr", "es", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27351364324511708"}, "review_messages": ["", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75469631_6948563241919552_6253940446158435861_n.png?stp=dst-png_s360x360&_nc_cat=103&cc