INLINE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031435_518793870863422_4541274484298186509_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RbbLkkygz3cQ7kNvgET-oNz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPYtx7bQ7mDwUKcL1CYUrGQMIe-V7am3T8sbtwsLUCsw&oe=672754E3"}, {"file_name": "SolarBlack Mata Portrait new final.png", "id": "507133395440969", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974741_507133398774302_1883834077931045741_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KFuszeXf3EQQ7kNvgHRDKQj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDc6oOFuf4GUmxgX0IPGTSwezcuqs1iusxZKqlps_hFuQ&oe=6727746C"}]}, "id": "561680449671231", "locale": "en_US", "screenshots": [{"file_name": "1_SolarBlackQuest_Screenshot.png", "id": "443122548051574", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75303840_443122551384907_5003313074114795250_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z7eFdAWSW-YQ7kNvgE4TpcL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAir--MfhjetpMMfXt7VLqP44lI4iYGF_DqTbT9C_wxqg&oe=67275503"}, {"file_name": "4_SolarBlackQuest_Screenshot.png", "id": "1116821736228525", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221324_1116821739561858_4157269610778622314_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHs9zupVxeEQ7kNvgG0-mmb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxtHpQxPsJCfbAHtNTdLqhYIKVVS_PjqXJc3T5pEoNRQ&oe=67274B85"}, {"file_name": "2_SolarBlackQuest_Screenshot.png", "id": "368572792710893", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86613167_368572796044226_5809498655111946243_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n6lKrQRgA4cQ7kNvgGEFljz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXDjU4P1Xm5ghEXc6fUkCykWSlGqekmoXJJdINiKHqyQ&oe=67275F5E"}, {"file_name": "4_1440p.png", "id": "632183495447001", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974633_632183498780334_8801135400521344320_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w9PD4mxjS2IQ7kNvgFl3kQA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5xORxtQMMdS0URpdRuJ16iPI7zLPGC9KjgZJY62q6Sw&oe=67275438"}, {"file_name": "3_1440p.png", "id": "250550250694660", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974709_250550254027993_6885754610064091669_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YiTNNVS2jPMQ7kNvgFmTc4L&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlT2fCCjOaM-D0uGVLsis7EsX1lBZLVj4vFQZP2SPHsA&oe=67277CC4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SB_Cybersymphony_CoverLandscape.png", "id": "3593637784247199", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031604_3593637790913865_3587406416698179347_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-6p24gFb4QkQ7kNvgEl7PHq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwNSILGoqfPW-mnTcrTY6PdIH6dpHYNX8OrZkCivQNdA&oe=6727462D"}, "display_name": "SolarBlack", "keywords": ["dance", "rhythm", "music", "beat", "action"], "long_description": "SolarBlack is an action-rhythm game made exclusively for VR where you slice and shoot to the beat to defeat an other-worldly threat. Immerse yourself in new worlds as you train your body and mind in time to handcrafted soundtracks. Control the tempo of the battle as you see fit with **Flextime** and seek to unravel the secrets of the universe on your journey to becoming the ultimate legend of sound and space.\n- 5 different difficulties for every legend or legend-in-training\n- Over 31 environments, some of which might look familiar to you\n- Achievements & collectables\n\n# Saber Guns\n{890920122977244}\nThis is the first VR game that weaves **two awesome fighting styles** together in a single pulse-pounding, unstoppable rhythmic action. Featuring a soundtrack specially composed to accompany incredible graphics and atmospheric worlds that pulses to the beat. \n\n# Flextime\n{3666338663677854}\nWant that extra **\"Matrix\" flair** while you decimate everything in your path? Activate Flextime to slow down every single enemy and target, and carefully plan your next move.\n\n# Fitness\n{463808249399988}\n\nGet fit with SolarBlack! Looking to add another game to your VR fitness game library? Take advantage of our Fitness Mode and throw those hard punches at incoming targets! Not only does it grant you max score, it's also **guaranteed to make you sweat**.\n\n", "short_description": "SolarBlack is an action-rhythm game made exclusively for VR where you slice and shoot to the beat to defeat an other-worldly threat. Immerse yourself in new worlds and experience the music in every pulsating atom. Control the tempo of the battle as you see fit with Flextime and strategically plan each victory on your journey to becoming the ultimate hero of sound and space."}]}, "developer_name": "SolarBlack", "developer_privacy_policy_url": "https://solarblack.net/docs/EULA_Privacypolicy.txt", "developer_terms_of_service_url": "https://solarblack.net/docs/EULA_Privacypolicy.txt", "publisher_name": "Andromeda Entertainment", "support_website_url": "https://solarblack.net/", "website_url": "https://solarblack.net/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "ko", "pt", "en", "it", "fr", "es", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27351364324511708"}, "review_messages