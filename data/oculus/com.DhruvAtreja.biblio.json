 "keywords": [], "long_description": "Turn off your controllers and just use your hands :)\n\nBiblio has been made for the pleasure of reading in VR. Now you can:\n1. Read in peace and isolation, without distractions\n2. Read while lying down or any other position you're comfortable in\n3. Sift through pages by just swiping.\n4. Choose the environment you want to read in.\n5. Upload any book you want to read\n6. Choose from 25 free comic books to read, and add more\n7. Drag and resize your reader with your hands", "short_description": "Turn off your controllers and just use your hands :)\n\nBiblio has been made for the pleasure of reading in VR. Now you can:\n1. Read in peace and isolation, without distractions\n2. Read while lying down or any other position you're comfortable in\n3. Sift through pages by just swiping.\n4. Choose the environment you want to read in.\n5. Upload any book you want to read\n6. Choose from 25 free comic books to read, and add more\n7. Drag and resize your reader with your hands"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1m1Z9W-3vAL0fVlY_m5Kbez-wTn6mxyCmrLx-LSAkDtU/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Dhruv Atreja", "support_website_url": null, "website_url": "https://dhruvatreja.my.canva.site/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2676136442603296"}, {"id": "879473995923081"}, {"id": "541611600222565"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_mod