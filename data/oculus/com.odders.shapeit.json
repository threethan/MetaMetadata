2435842468_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BiuvffGiwpEQ7kNvgFozAPL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTewdAsqTWp2DlUNBobqxKaER6O22vxJ3W4Fvg38kNrw&oe=673C7019"}, "display_name": "LES MILLS BODYCOMBAT", "keywords": ["fitness", "gym", "boxing", "combat", "fit"], "long_description": "We\u2019re on a mission to create a fitter planet. Join us.\n\nWork out at home with a premium fitness app. LES MILLS, the world's leading fitness company, brings the BODYCOMBAT experience to your VR headset with an extensive workout portfolio, top-quality coaching, innovative mechanics, and different intensities.\n\n\ud83c\udfc6 BODYCOMBAT STYLE\nMixing martial arts and fitness, get an all-access to all types of workouts. New punch moves and knee strikes.\n\n\ud83c\udfcb\ufe0f\u200d\u2640\ufe0f FOR EVERYONE\nBeginner to advanced: 30 workout plans to help you achieve your goals.\n\n\ud83d\udd25 GET THE RESULTS YOU WANT\nAll workouts are scientifically designed to get the best results.\n\n\ud83d\udc68\u200d\ud83c\udfeb FIRST CLASS COACHES\nInstructors Dan Cohen & Rachael Newsham will motivate and push you through every workout.\n\n\ud83c\udfb5 AMAZING MUSIC\nThe best soundtrack to motivate you with songs from artist like Noam Dee, Fas Fash, & more.\n\n\u26f0\ufe0f BREATHTAKING ENVIRONMENTS\n5 dreamlike environments for your fitness journey: Mars, Neo City, Rome, Japan, and Tundra, with more to come!", "short_description": "We\u2019re on a mission to create a fitter planet. Join us.\n\nWorkout at home with the best fitness app on Quest. Bodycombat brings to VR all the expertise of Les Mills, a leading company in the training sector with unique ideas and innovative mechanics that bring a new dimension to the world of home workouts.\n\n\ud83c\udfc6 BODYCOMBAT & MORE\n\ud83c\udfcb\ufe0f\u200d\u2640\ufe0f FOR EVERYONE\n\ud83d\udd25 BURN THOSE CALORIES\n\ud83d\udc68\u200d\ud83c\udfeb FIRST CLASS COACHES\n\ud83c\udfb5 AMAZING MUSIC\n\u26f0\ufe0f BREATHTAKING ENVIRONMENTS"}]}, "developer_name": "Odders", "developer_privacy_policy_url": "https://odderslab.com/bodycombat/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Odders", "support_website_url": null, "website_url": "https://www.lesmills.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SPORTS", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "522144938945152"}}]}, "scheduled_offers": {"count": 47, "nodes": [{"status": "PUBLISHED", "id": "1712170702681567"}, {"status": "PUBLISHED", "id": "1902580890254383"}, {"status": "PUBLISHED", "id": "835146554602938"}, {"status": "PENDING", "id": "368256638966821"}, {"status": "PUBLISHED", "id": "983193655914041"}, {"status": "PENDING", "id": "3414551102096984"}, {"status": "PENDING", "id": "690865923117373"}, {"status": "PENDING", "id": "152907957740035"}, {"status": "PUBLISHED", "id": "643698614608998"}, {"status": "PENDING", "id": "1111409650256773"}, {"status": "PENDING", "id": "1305985493460977"}, {"status": "PENDING", "id": "1315588542430321"}, {"status": "PUBLISHED", "id": "1154564828734276"}, {"status": "PUBLISHED", "id": "324471813591248"}, {"status": "PENDING", "id": "571719105161781"}, {"status": "PENDING", "id": "723329282499501"}, {"status": "PENDING", "id": "721637909519568"}, {"status": "PUBLISHED", "id": "7501245929917987"}, {"status": "PUBLISHED", "id": "3061688837462755"}, {"status": "PENDING", "id": "626540638924