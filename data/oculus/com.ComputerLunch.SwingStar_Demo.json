189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12727894_1244349155685243_631799352918016000_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=38vWWAptlPcQ7kNvgGxtpao&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_WZrLPRdZHlpKXCffrPgfjk0aqdUCDR00zIMH9t77EA&oe=670E7130"}, {"file_name": "migrated_image.png", "id": "227997191679005", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12533900_175818146265566_5173549375187582976_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gPrlrRsvAigQ7kNvgF8Jf8A&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClLpAGwpGnx9ml6H8DZO4M9pPH2_cjRc52jcGspfSE1g&oe=670E6430"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "SwingStar Demo", "keywords": ["platformer", "puzzle", "rope", "swinging", "spiderman"], "long_description": "SwingStar is a wacky third-person physics puzzler set in a colorful universe. Your goal is to find and swing on a mysterious bell using a giant sticky hand attached to your head.\n\n- Touch Controller supported.\n- Explore all 30 colorful cartoon levels by swinging through enchanted deserts, bright forests, steep canyons, and many more bizarre and beautiful worlds.\n- Epic Boss Battle.\n- Unlock mysterious doors that unlock secret levels\n- Wacky power up items change the gameplay. Turbo Yo-yos swing you around, Air Cannons blast you high in the air, and The Grappling Jelly will suck you to it's gooey surface.\n- Brilliantly dreamy soundtrack.\n- Master each level to receive a perfect 3 Star rank.\n- Get all 84 stars to unlock the mysterious inter-dimensional zone.", "short_description": "SwingStar is a wacky third-person physics puzzler set in a colorful universe. Your goal is to find and swing on a mysterious bell using a giant sticky hand attached to your head.\n\n- Touch Controller supported.\n- In this demo Explore 30 colorful cartoon levels by swinging through enchanted deserts, bright forests, steep canyons, and many more bizarre and beautiful worlds.\n- Epic Boss Battle! \n- Unlock mysterious doors that unlock secret levels\n- Wacky power up items."}]}, "developer_name": null, "developer_privacy_policy_url": "http://games.computerlunch.com/privacy-policy-terms-of-service/", "developer_terms_of_service_url": "http://games.computerlunch.com/privacy-policy-terms-of-service/", "publisher_name": "Computer Lunch", "support_website_url": null, "website_url": "http://games.computerlunch.com/swing-star/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "PUZZLE", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1157642614771859"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12727726_236298520112896_4343828622075756544_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jq3XnZV2J08Q7kNvgFGipot&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgFBC4hbmoWOn1HrlXv0sz_3bYwssZQNVINCb-9BDa2g&oe=670E46F4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SwingStar Demo", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1485936000, "lastRevision": {"nodes": [{"id": "1239220452835854", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1506227612735591", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "218745115255273"}, "iarc