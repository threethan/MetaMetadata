RL87RJ4DWJ8e7_328jLbUV8YVoNJzsx2kxC64AgVWw&oe=6745BA1B"}, {"file_name": "migrated_image.png", "id": "139256180829144", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12727894_1244349155685243_631799352918016000_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O2UwQ9PbfdoQ7kNvgE1yb-V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAj5xPGnwsXyn5w92CsWHundSnZMuSaxQ4Yw0D0rUR56w&oe=6745D030"}, {"file_name": "migrated_image.png", "id": "2844871422261886", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12331072_1249128018528323_5885355310176010240_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y3MUaHEWxK0Q7kNvgEuoWFD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_2x3P-T1kw7Cj2Bpdf8Dtu0nQ8ACCuPZ8DOgG0rdDJw&oe=6745BAE5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "12138848_188442018286999_8666111583660802048_n.png", "id": "1815281048689008", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12727931_1815281052022341_2238148303084584960_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bSWKj6MlD3wQ7kNvgEenBdX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAskQRkNcQePEIwxofilTMhlaoGe7cI0vyub8DzXPC12Q&oe=6745B688"}, "display_name": "SwingStar Demo", "keywords": ["swing", "puzzle", "rope", "swinging", "spiderman"], "long_description": "SwingStar VR allows players to swing around a virtual reality world using a giant sticky hand attached to their head. The game is a third-person swinging physics puzzler that puts players through a wild ride, accelerating the player as they swing. It's wacky and super fun.\n\nA disaster has mutated physics, you must save your home multiverse by ringing all the mysterious bells. A colossus robot stand between you and the final bell.\n\n- Explore all 30 colorful cartoon levels by swinging through enchanted deserts, bright forests, steep canyons, and many more bizarre and beautiful worlds.\n- Epic Boss Battle.\n- Unlock mysterious doors that unlock secret levels\n- Wacky power up items change the gameplay. Turbo Yo-yos swing you around, Air Cannons blast you high in the air, and The Grappling Jelly will suck you to it's gooey surface.\n- Brilliantly dreamy soundtrack.\n- Master each level to receive a perfect 3 Star rank.\n- Get all 84 stars to unlock the mysterious inter-dimensional zone.", "short_description": "SwingStar VR allows players to swing around a virtual reality world using a giant sticky hand attached to their head. The game is a third-person swinging physics puzzler that puts players through a wild ride, accelerating the player as they swing.\n\n- Explore all 30 colorful cartoon levels by swinging through enchanted deserts, bright forests, steep canyons, and many more bizarre and beautiful worlds.\n- Epic Boss Battle! \n- Unlock mysterious doors that unlock secret levels\n- Wacky power up items."}]}, "developer_name": null, "developer_privacy_policy_url": "http://games.computerlunch.com/privacy-policy-terms-of-service/", "developer_terms_of_service_url": "http://games.computerlunch.com/privacy-policy-terms-of-service/", "publisher_name": "Computer Lunch", "support_website_url": null, "website_url": "http://games.computerlunch.com/swing-star/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5043382275725454"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"