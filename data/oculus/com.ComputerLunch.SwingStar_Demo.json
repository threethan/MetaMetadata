1799352918016000_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9U8_zUEiQXAQ7kNvgHDBotA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTSp8Gr7LFlsFGOTlVprOal-ogGTpP15DXRZkMQsGAJw&oe=67064FF0"}, {"file_name": "migrated_image.png", "id": "2844871422261886", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12331072_1249128018528323_5885355310176010240_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GNuge04Dn-wQ7kNvgHSQyTp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4r_vfWEtBqOqpWB32nOGNwu22rxfB7F8wZ7ucJIgDTA&oe=670672E5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "12138848_188442018286999_8666111583660802048_n.png", "id": "1815281048689008", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12727931_1815281052022341_2238148303084584960_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_C3AqSdZVxQQ7kNvgHOJ6_k&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOsN_Y_B0ZZrLc20nEiZWga7qgGsVD3EMyyQ8UFmDtag&oe=67066E88"}, "display_name": "SwingStar Demo", "keywords": ["swing", "puzzle", "rope", "swinging", "spiderman"], "long_description": "SwingStar VR allows players to swing around a virtual reality world using a giant sticky hand attached to their head. The game is a third-person swinging physics puzzler that puts players through a wild ride, accelerating the player as they swing. It's wacky and super fun.\n\nA disaster has mutated physics, you must save your home multiverse by ringing all the mysterious bells. A colossus robot stand between you and the final bell.\n\n- Explore all 30 colorful cartoon levels by swinging through enchanted deserts, bright forests, steep canyons, and many more bizarre and beautiful worlds.\n- Epic Boss Battle.\n- Unlock mysterious doors that unlock secret levels\n- Wacky power up items change the gameplay. Turbo Yo-yos swing you around, Air Cannons blast you high in the air, and The Grappling Jelly will suck you to it's gooey surface.\n- Brilliantly dreamy soundtrack.\n- Master each level to receive a perfect 3 Star rank.\n- Get all 84 stars to unlock the mysterious inter-dimensional zone.", "short_description": "SwingStar VR allows players to swing around a virtual reality world using a giant sticky hand attached to their head. The game is a third-person swinging physics puzzler that puts players through a wild ride, accelerating the player as they swing.\n\n- Explore all 30 colorful cartoon levels by swinging through enchanted deserts, bright forests, steep canyons, and many more bizarre and beautiful worlds.\n- Epic Boss Battle! \n- Unlock mysterious doors that unlock secret levels\n- Wacky power up items."}]}, "developer_name": null, "developer_privacy_policy_url": "http://games.computerlunch.com/privacy-policy-terms-of-service/", "developer_terms_of_service_url": "http://games.computerlunch.com/privacy-policy-terms-of-service/", "publisher_name": "Computer Lunch", "support_website_url": null, "website_url": "http://games.computerlunch.com/swing-star/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5043382275725454"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1668564703168547", "version": "1.685"}, "id": "367670680283515", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"