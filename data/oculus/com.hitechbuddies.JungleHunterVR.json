lay_name": "Jungle Hunter VR", "keywords": ["Jungle", "Hunter", "shooting", "Adventure", "Action"], "long_description": "Jungle Hunter VR, allows players to hunt realistic animals such as male deer, rabbits, ibex, goats, wolves, brown bears, boars, and golems. Players can use both hands to handle a pistol, remove and replace magazines, and pull the slider to reload. The game features health points in the jungle for players to heal after taking damage, and both the animals and the gun are designed to be realistic in a stylized forest setting.", "short_description": "Jungle Hunter VR allows players to hunt realistic animals such as deer, rabbits, wolves, and bears. Players can handle a pistol, manage magazines, and reload using both hands. The game features health points in the jungle for recovery, with realistic animals and weapons set in a stylized forest."}]}, "developer_name": null, "developer_privacy_policy_url": "https://hitechbuddies.com/privacy_policy", "developer_terms_of_service_url": "https://hitechbuddies.com/terms-and-conditions", "publisher_name": "HiTech Buddies", "support_website_url": null, "website_url": "https://hitechbuddies.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27301944422787246"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035428_169406540472