yfish.png", "id": "2323094407851588", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036614_2323094411184921_2721918908720316856_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vxL4AEHvVDEQ7kNvgHuqv10&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBjueH5UJJpyIz_6z-u04Kd1YrCLSFXVlny9tN8ROnyWw&oe=67713A8D"}, {"file_name": "Screenshot_store.png", "id": "1358580958234940", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568679_1358580961568273_5356701231646317168_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiEzCKhisSYQ7kNvgEsfdUu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhTgYAQZjgyxtbMuDpWBM3237JqyFUhUrVuqiyBucb7Q&oe=67711DDE"}, {"file_name": "Screendshot_fireplace.png", "id": "600646275228081", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035413_600646278561414_642703241753859784_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=psmbqwEb5OMQ7kNvgGe2zKe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdWtxv3aCmOFSY78eTsfiR1a0gbHxaYaeMhxsiRipO4Q&oe=67712EA3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "567635975249006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003243_567635978582339_385010080011966976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qQTSakBGjKsQ7kNvgGtl8w7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB4grhWrSVviVekeOUf31sdJP14iQc5IuO6_rD-cNURSg&oe=677127D2"}, "display_name": "Little Planet: Escape to a new life", "keywords": [], "long_description": "Welcome to Little Planet! With the roar of the spaceship, you landed at a lovely planet\u2014\u2014\nYou can escape into a fantasy, ever-growing and a whole new life. Explore and decorate your own little planet, which is full of  excitement, fun items, creatures, and scenery. \n\nMissions? Rather some reminders:\n- The backpack fills up quickly? You need to learn to manage your inventory strategically.\n- Complete terrain editing independently, making a maze is also a great choice!\n- Find a way to get gifts floating in the air.\n- Pay off your debts! Otherwise, you will be sent back to Earth! (Just kidding :) )\n- Fishing? Try to master casting the rod first.\n- Build your beautiful garden from scratch!\n- Look for scattered easter eggs.\n- Never drop items by the sea or else...\n- Make a room that is more aesthetic than the sample room.\n- Be kind to everyone, whether it's a player or an NPC (No animal cruelty!)\netc...\n \nNot available here: hustle and bustle,tedious, academic pressure, tests, cat's paw, endless competition. \nIt's your show time to demonstrate your extraordinary wisdom, aesthetics planning ability, strategic thinking and a beautiful mind looking forward to a better life.", "short_description": "Little Planet lets you escape into a fantasy, ever-growing and a whole new life. You can explore and decorate your own little planet, which is full of  excitement, fun items, creatures, and scenery. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.littleplanet.world/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRWOOD virtual reality technology", "support_website_url": null, "website_url": "https://www.littleplanet.world/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "74