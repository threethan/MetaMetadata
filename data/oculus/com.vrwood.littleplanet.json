t64.5771-25/39036614_2323094411184921_2721918908720316856_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ndLwytROOOYQ7kNvgFHrCPd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3Whw74Y1M_9Vqs8hIK9V8IrO0k8sjLg1Wh08eLX_q9A&oe=671F7D8D"}, {"file_name": "Screenshot_store.png", "id": "1358580958234940", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568679_1358580961568273_5356701231646317168_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VDP6bWVB7b8Q7kNvgEX3-qq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsWz2juw1XSappkgHCi-z0Jr0JAFXJK9Fi7wdokKyfzg&oe=671F60DE"}, {"file_name": "Screendshot_fireplace.png", "id": "600646275228081", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035413_600646278561414_642703241753859784_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YsDZu18BTHkQ7kNvgFqjAmz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBs_2u8UhcvZ56Kv7XVLIiaP3Nmb0U5G3kC9a7LEBVUdg&oe=671F71A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "567635975249006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003243_567635978582339_385010080011966976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ui6khTpLHlUQ7kNvgHbZdSV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC1SbZk52Ogf0aSRe9ZBPlFQcwrzLiF55tietey17JQIg&oe=671F6AD2"}, "display_name": "Little Planet: Escape to a new life", "keywords": [], "long_description": "Welcome to Little Planet! With the roar of the spaceship, you landed at a lovely planet\u2014\u2014\nYou can escape into a fantasy, ever-growing and a whole new life. Explore and decorate your own little planet, which is full of  excitement, fun items, creatures, and scenery. \n\nMissions? Rather some reminders:\n- The backpack fills up quickly? You need to learn to manage your inventory strategically.\n- Complete terrain editing independently, making a maze is also a great choice!\n- Find a way to get gifts floating in the air.\n- Pay off your debts! Otherwise, you will be sent back to Earth! (Just kidding :) )\n- Fishing? Try to master casting the rod first.\n- Build your beautiful garden from scratch!\n- Look for scattered easter eggs.\n- Never drop items by the sea or else...\n- Make a room that is more aesthetic than the sample room.\n- Be kind to everyone, whether it's a player or an NPC (No animal cruelty!)\netc...\n \nNot available here: hustle and bustle,tedious, academic pressure, tests, cat's paw, endless competition. \nIt's your show time to demonstrate your extraordinary wisdom, aesthetics planning ability, strategic thinking and a beautiful mind looking forward to a better life.", "short_description": "Little Planet lets you escape into a fantasy, ever-growing and a whole new life. You can explore and decorate your own little planet, which is full of  excitement, fun items, creatures, and scenery. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.littleplanet.world/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRWOOD virtual reality technology", "support_website_url": null, "website_url": "https://www.littleplanet.world/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "743332207302685"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "617060860383421"}, {"status":