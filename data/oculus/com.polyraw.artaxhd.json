r through a dreamlike world in search of Bulf, a character who has escaped from his box. Explore a fascinating miniature world with incredible details, an engaging atmosphere, and innovative gameplay. Help Artax overcome obstacles and enemies to return Bulf to his world and restore order to their magical universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.polyrawdevelopment.com/PR_ArtaxPrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Polyraw Development", "support_website_url": null, "website_url": "https://www.polyrawdevelopment.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26100408082940492"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "927410362743950"}, {"status": "PUBLISHED", "id": "1460537467950784"}]}, "baseline_offer": {"id": "1460537467950784"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "927410362743950"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26178535695127730", "version": "1.4"}, "id": "1257915598919406", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_appl