131818924124256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i33-YvfC3eUQ7kNvgGGHuI7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDeJc_T4KCVvIQZs1wEcdjDaX6OMTqrx4kCYr8_C4-XfA&oe=6718E11E"}, {"file_name": "Screenshot02.png", "id": "1008481184020716", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982577_1008481187354049_23600633797903052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hS_3aHozjQAQ7kNvgH9XjLt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8oeRwMhZC5qcu_8SiqvjUYaDtQbMNU895G5uUaS9Tow&oe=6718F445"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_per_video.png", "id": "840494258075006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031409_840494261408339_2720833867148154916_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zv6sGJHZr2YQ7kNvgGIDeEb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCk45S_qUdiPxaYdVVtXbuZhX_SuDaT6ff1q3GztuNUfA&oe=6718D6A3"}, "display_name": "Artax", "keywords": ["artax", "knight", "diorama", "castle", "toy"], "long_description": "Artax immerses you in an extraordinary adventure. You play as a toy soldier who must face obstacles and enemies in a fantastical world in search of Bulf, a larger and villainous soldier who has escaped from his box. Guide Artax through a miniature world characterized by finely crafted details for an immersive and thrilling experience. The high-quality graphics contribute to a captivating visual experience, while the innovative gameplay offers unique and engaging challenges. Get ready to embark on an unforgettable adventure in a magical world.", "short_description": "In Artax, you guide a toy soldier through a dreamlike world in search of Bulf, a character who has escaped from his box. Explore a fascinating miniature world with incredible details, an engaging atmosphere, and innovative gameplay. Help Artax overcome obstacles and enemies to return Bulf to his world and restore order to their magical universe."}]}, "develop