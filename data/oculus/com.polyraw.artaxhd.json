hot05.png", "id": "415936007507283", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974888_415936010840616_3496078935878250826_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sa_XJmBy50YQ7kNvgF8gRWw&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDgHqXYfaQKWFAqt83d3LH3g-oQJgUS7Yy-4S8Hn9vRZQ&oe=67348385"}, {"file_name": "Screenshot03.png", "id": "1026259675517039", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75371503_1026259678850372_7429131818924124256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lm4IUzhfMaEQ7kNvgHs9Zyi&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDI5vqS7oUZ-Xw2LagyrdaqwBhLKE2-yC9Jui4d-ogabA&oe=6734909E"}, {"file_name": "Screenshot02.png", "id": "1008481184020716", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982577_1008481187354049_23600633797903052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B2NJpOlcXE8Q7kNvgExb45F&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAvGJoPvSqOwArzR0k1-exNcLcb4J1qKOAAxQ4a55B_XQ&oe=6734A3C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_per_video.png", "id": "840494258075006", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031409_840494261408339_2720833867148154916_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FpNBag0JNhEQ7kNvgHmduzG&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAeZgjgW7FQCJqTtrw5dBbxV99en9nWwt6YGVwrKyuVnQ&oe=67348623"}, "display_name": "ArtaxHD", "keywords": [], "long_description": "Artax immerses you in an extraordinary adventure. You play as a toy soldier who must face obstacles and enemies in a fantastical world in search of Bulf, a larger and villainous soldier who has escaped from his box. Guide Artax through a miniature world characterized by finely crafted details for an immersive and thrilling experience. The high-quality graphics contribute to a captivating visual experience, while the innovative gameplay offers unique and engaging challenges. Get ready to embark on an unforgettable adventure in a magical world.", "short_description": "In Artax, you guide a toy soldier through a dreamlike world in search of Bulf, a character who has escaped from his box. Explore a fascinating miniature world with incredible details, an engaging atmosphere, and innovative gameplay. Help Artax overcome obstacles and enemies to return Bulf to his world and restore order to their magical universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.polyrawdevelopment.com/PR_ArtaxPrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Polyraw Development", "support_website_url": null, "website_url": "https://www.polyrawdevelopment.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26100408082940492"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "927410362743950"}, {"status": "PUBLISHED", "id": "1460537467950784"}]}, "baseline_offer": {"id": "1460537467950784"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "927410362743950"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26178535695127730", "version": "1.4"}, "id": "1257915598919406", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes"