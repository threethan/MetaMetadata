here, and innovative gameplay. Help Artax overcome obstacles and enemies to return Bulf to his world and restore order to their magical universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.polyrawdevelopment.com/PR_ArtaxPrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Polyraw Development", "support_website_url": null, "website_url": "https://www.polyrawdevelopment.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26302260479421917"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982645_836291145295767_6995692700050752075_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MM_WJggZ4b4Q7kNvgFE4fK9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AS1Cr0Sxd0fNVCt_ao47D2l&oh=00_AYAjPR7Uf5R4xfTmtyO0ldz4tXFwfendMthUQ7DonT5YWg&oe=66E6C7ED"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Artax", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1723494790, "lastRevision": {"nodes": [{"id": "26100408126273821", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata":