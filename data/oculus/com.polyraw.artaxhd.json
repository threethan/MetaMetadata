49_23600633797903052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZN_TsblOAqIQ7kNvgFbkhQF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgRG-a3ZtiLVb7HOWDaI5Cepf4zrYNvtcO_DKKo0IJrg&oe=66DEF245"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_per_video.png", "id": "840494258075006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031409_840494261408339_2720833867148154916_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=459U4FM82b4Q7kNvgGcxZo4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoW9QhQQGPdxiwDQP8Cuh45WECUrZ2vpe-XBTYmhZyUg&oe=66DED4A3"}, "display_name": "Artax", "keywords": ["artax", "knight", "diorama", "castle", "toy"], "long_description": "Artax immerses you in an extraordinary adventure. You play as a toy soldier who must face obstacles and enemies in a fantastical world in search of Bulf, a larger and villainous soldier who has escaped from his box. Guide Artax through a miniature world characterized by finely crafted details for an immersive and thrilling experience. The high-quality graphics contribute to a captivating visual experience, while the innovative gameplay offers unique and engaging challenges. Get ready to embark on an unforgettable adventure in a magical world.", "short_description": "In Artax, you guide a toy soldier through a dreamlike world in search of Bulf, a character who has escaped from his box. Explore a fascinating miniature world with incredible details, an engaging atmosphere, and innovative gameplay. Help Artax overcome obstacles and enemies to return Bulf to his world and restore order to their magical universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.polyrawdevelopment.com/PR_ArtaxPrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Polyraw Development", "support_website_url": null, "website_url": "https://www.polyrawdevelopment.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "