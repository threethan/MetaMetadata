1-25/38974888_415936010840616_3496078935878250826_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I5gVvDC8IB0Q7kNvgFssgv1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA8ow4-aPkQbFgzEn5X1BaWR56m8jtRLEQJs0ilTcB_IQ&oe=6720BD05"}, {"file_name": "Screenshot03.png", "id": "1026259675517039", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75371503_1026259678850372_7429131818924124256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Iu7CRL7_BOIQ7kNvgEAS6mj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlL_37aYpZnWxl5jWFGJhFNrA848efP0f50PWRAFBRow&oe=6720CA1E"}, {"file_name": "Screenshot02.png", "id": "1008481184020716", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982577_1008481187354049_23600633797903052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-fu3bendawsQ7kNvgGfkv0w&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHXAvV5r7muvFg69GElDAw7_-mpuav7KdTAOnMSMOlFg&oe=6720DD45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_per_video.png", "id": "840494258075006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031409_840494261408339_2720833867148154916_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_vmu-VZReEwQ7kNvgE3ucC8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCA-hnaiUs9bJzqMX948oa7fuakWXAirPe878IYLQWYlQ&oe=6720BFA3"}, "display_name": "Artax", "keywords": ["artax", "knight", "diorama", "castle", "toy"], "long_description": "Artax immerses you in an extraordinary adventure. You play as a toy knight who must face obstacles and enemies in a fantastical world in search of Bulf, a larger and villainous soldier who has escaped from his box. Guide Artax through a miniature world characterized by finely crafted details for an immersive and thrilling experience. The high-quality graphics contribute to a captivating visual experience, while the innovative gameplay offers unique and engaging challenges. Get ready to embark on an unforgettable adventure in a magical world.", "short_description": "In Artax, you guide a toy soldier through a dreamlike world in search of Bulf, a character who has escaped from his box. Explore a fascinating miniature world with incredible details, an engaging atmosphere, and innovative gameplay. Help Artax overcome obstacles and enemies to return Bulf to his world and restore order to their magical universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.polyrawdevelopment.com/PR_ArtaxPrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Polyraw Development", "support_website_url": null, "website_url": "https://www.polyrawdevelopment.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27211837785130844"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982645_836291145295767_6995692700050752075_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UfnO8acot-QQ7kNvgGOe72C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnH4xDt3SLg82Sm7MThVwX0VVOsqVEV3emUugFjUZ1-A&oe=6720C9ED"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Artax", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"