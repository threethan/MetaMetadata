id": "151125910111949", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974631_151125913445282_6332619446427452796_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vivbbTObN78Q7kNvgFyHGgp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDANBX_viDH9xcNJbbiltn1oiIQ0IGzJOgC3b875-YAGw&oe=671F6C6A"}, {"file_name": "ss_1a684e4a42e443590bfbd8e08b49202c42657f71.png", "id": "438468744051002", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974631_438468750717668_4846225290144339407_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uDzGKK5U2goQ7kNvgHD2JMU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClS6U6XM6pEbf4mX3e1FQb2aA2X6a0HKMseuCPL3GV4A&oe=671F5EAB"}, {"file_name": "ss_2123eb5198ecf4fa7946d83d08a1fa4115b1b918.png", "id": "3449755711796477", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_3449755715129810_8962456890771049314_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ltYDeEKX0YcQ7kNvgEIS8v-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9y6Gk_82F0f_oR8ASluXtcC76MG9TaFeC2GeyZhIjGw&oe=671F6FC9"}, {"file_name": "ss_7d605c705b1866aebbc188b821d7d02dbae011b4.png", "id": "255660282708475", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_255660286041808_3913103671746758460_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EVf33pVcX0cQ7kNvgEgoNJo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDwNwcGfEwUWgQ7MyMkyObpn422Htjez-RzldV15cf-2A&oe=671F8E94"}, {"file_name": "ss_90cf4fcdb702bf75528946a5022afacac8e7fea9.png", "id": "461579864992075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974557_461579868325408_1578445223530056449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q48CGaGS0PIQ7kNvgExtixf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpAVeAJX7yTabdiRzL6_pCmH8NSnNbzvS3Yswe27lcSw&oe=671F5ED2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss_1a684e4a42e443590bfbd8e08b49202c42657f71.png", "id": "901011737349559", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982479_901011740682892_675919200486557106_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vkUwn8ktugMQ7kNvgGTYlCj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAzzhFiuLmMJV3_GF2O5ZMNvpdSvWthC5CPxYl5LlpF2g&oe=671F8448"}, "display_name": "Dissection Simulator: Pig Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual reality pig dissection software is a hands-on dissection opportunity experienced through the power of VR. This true-to-life, hour-and-a-half practice thoroughly covers each step of the science procedure that students would take if dissecting a fetal pig specimen in their classroom.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications. Schools save on expensive and rising annual costs of animal specimens. Additionally, acquisitions are reliable and not dependent on animal procurement.", "short_description": "VictoryXR\u2019s virtual reality pig dissection software is a hands-on dissection opportunity experienced through the power of VR. This true-to-life, hour-and-a-half practice thoroughly covers each step of the science procedure that students would take if dissecting a fetal pig specimen in their classroom."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category":