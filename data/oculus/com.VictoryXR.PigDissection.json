urcQ7kNvgHtqFQh&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCys9nzzr_HMuOkvVOuz6A0VzL5IwAO4yhtRPXNeka7kw&oe=670119EA"}, {"file_name": "ss_1a684e4a42e443590bfbd8e08b49202c42657f71.png", "id": "438468744051002", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974631_438468750717668_4846225290144339407_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ApCngysooBQQ7kNvgHq15ri&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAKjFaQoJvmpCoTcLvZQ2mKOYfXu_I3Ep8n9Zdn-8W2Zw&oe=67010C2B"}, {"file_name": "ss_2123eb5198ecf4fa7946d83d08a1fa4115b1b918.png", "id": "3449755711796477", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982601_3449755715129810_8962456890771049314_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G9WoWJ8Q1hoQ7kNvgElokFr&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD4bw4IjFbda-glPH_bD0FiyAQzs29YEHA2jffHa5H1jw&oe=67011D49"}, {"file_name": "ss_7d605c705b1866aebbc188b821d7d02dbae011b4.png", "id": "255660282708475", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982601_255660286041808_3913103671746758460_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2WswjfHZmUQ7kNvgFptkpG&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB1-tu51BzMFq3gE-_T2APPkx4rPYmM6UclgW5JYh_v4A&oe=67013C14"}, {"file_name": "ss_90cf4fcdb702bf75528946a5022afacac8e7fea9.png", "id": "461579864992075", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974557_461579868325408_1578445223530056449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sLOmzyCGZbsQ7kNvgFl19Va&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDSUnaLUAw3zpGEe5OqnW2AQG67I0aH1UybgOP0XrwUmA&oe=67010C52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss_1a684e4a42e443590bfbd8e08b49202c42657f71.png", "id": "901011737349559", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982479_901011740682892_675919200486557106_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U5KPnMWrR4AQ7kNvgF-wJL7&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBhqVT1DCrHiHHi4B0FjHOJnoChRApXhp9JoAFWLdUNsQ&oe=670131C8"}, "display_name": "Dissection Simulator: Pig Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual reality pig dissection software is a hands-on dissection opportunity experienced through the power of VR. This true-to-life, hour-and-a-half practice thoroughly covers each step of the science procedure that students would take if dissecting a fetal pig specimen in their classroom.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications. Schools save on expensive and rising annual costs of animal specimens. Additionally, acquisitions are reliable and not dependent on animal procurement.", "short_description": "VictoryXR\u2019s virtual reality pig dissection software is a hands-on dissection opportunity experienced through the power of VR. This true-to-life, hour-and-a-half practice thoroughly covers each step of the science procedure that students would take if dissecting a fetal pig specimen in their classroom."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area"