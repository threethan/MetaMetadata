19446427452796_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UQtojeA5KHEQ7kNvgFEAbKi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBE5SC3By4_Hb6HD5F4rqIf2y3MD33xLQvqMT0MLd7Rgw&oe=6717836A"}, {"file_name": "ss_1a684e4a42e443590bfbd8e08b49202c42657f71.png", "id": "438468744051002", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974631_438468750717668_4846225290144339407_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YwA1ZkmQd2cQ7kNvgHEwqQ3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkDgwgbHb9XHFhwf8SMALVYIsyS2b_Q3Ogf4uCYEZkOg&oe=671775AB"}, {"file_name": "ss_2123eb5198ecf4fa7946d83d08a1fa4115b1b918.png", "id": "3449755711796477", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_3449755715129810_8962456890771049314_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=luk0XrZpwQwQ7kNvgFS-Dqx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDC9za-swZ7bi0MmsB1QGEVwG3KdqOobrIXdfk2dXJhUg&oe=671786C9"}, {"file_name": "ss_7d605c705b1866aebbc188b821d7d02dbae011b4.png", "id": "255660282708475", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_255660286041808_3913103671746758460_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a92jAedtFdMQ7kNvgG79IXn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsVqhx9c7jk89sruoyJFHDQ1Io8wHJYuNDSOQvYlCXSA&oe=6717A594"}, {"file_name": "ss_90cf4fcdb702bf75528946a5022afacac8e7fea9.png", "id": "461579864992075", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974557_461579868325408_1578445223530056449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RUUX9HUQHlkQ7kNvgGhCfh4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrF6RpNcS0X9kR5ecmN8IM3CB4nKenWG8cp3Fm8rmMZA&oe=671775D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss_1a684e4a42e443590bfbd8e08b49202c42657f71.png", "id": "901011737349559", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982479_901011740682892_675919200486557106_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bivQUrsT1j8Q7kNvgEGaCaj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAHd_mWWZ7gOd3zXSfP_5tXJUAmQm3JBDywZIyT4_7gUA&oe=67179B48"}, "display_name": "Dissection Simulator: Pig Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual reality pig dissection software is a hands-on dissection opportunity experienced through the power of VR. This true-to-life, hour-and-a-half practice thoroughly covers each step of the science procedure that students would take if dissecting a fetal pig specimen in their classroom.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications. Schools save on expensive and rising annual costs of animal specimens. Additionally, acquisitions are reliable and not dependent on animal procurement.", "short_description": "VictoryXR\u2019s virtual reality pig dissection software is a hands-on dissection opportunity experienced through the power of VR. This true-to-life, hour-and-a-half practice thoroughly covers each step of the science procedure that students would take if dissecting a fetal pig specimen in their classroom."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_R