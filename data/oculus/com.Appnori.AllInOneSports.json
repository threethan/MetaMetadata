-25/38982459_540880140566551_5741259350524531130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KHuyRutVzL0Q7kNvgEOBgDt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQjXZgpqAU-7eDE18QRFy-thgU6qgIV14L3PCKY5coZw&oe=67178521"}, {"file_name": "Badminton25601440.png", "id": "2596279404014935", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001678_2596279407348268_4547254064845674337_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VnjpWodkg10Q7kNvgH2a7RA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHkIpJvV5d5H_8aGtMw45T9YFrKUQ4QbIdJOyMzVsNXQ&oe=67177971"}, {"file_name": "Pinpong25601440.png", "id": "888830421845285", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031544_888830425178618_1422020724842662413_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Or_8snMEvYQ7kNvgFfE-f3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4-3c6nOBPgSv_LSgks4mJ-Gn-EOohCC7HcOW3qqHlqg&oe=67179A13"}, {"file_name": "Baseball25601440.png", "id": "910141746231003", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035371_910141749564336_5914863698586160063_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KziL-54G-EAQ7kNvgGcBFe8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUmg0Ciw7LeHOcyhetr6fpo6gY0KVBc0e58tyEXQgq9w&oe=67177FAD"}, {"file_name": "Billiards25601440.png", "id": "1322403814822820", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974493_1322403818156153_5567142707346549959_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WaOUW6KaGUEQ7kNvgELBzZj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBCR05I-5Xf9C0c11WIjGwEPYRiH1RfPSRrhn0O8Ft9GA&oe=67178B59"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "270133684909239", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974630_270133688242572_777489658576802972_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BsVedoJHoC4Q7kNvgHRv_a2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-duDhkc90GP3lj-rYNYdO7Rxp0RuOK6LRaRHKVwIqkw&oe=67177F2F"}, "display_name": "All-In-One Sports VR", "keywords": [], "long_description": "\u25a0 A variety of sports titles experiences\n- Baseball, Archery, Ping Pong, Basketball, Bowling, Badminton, Golf, Dart, Billiard, Boxing\n\n\u25a0 Real time PvP by multiplay\n- boxing, baseball and table tennis are not yet supported\n\n\u25a0 Realistic virtual sports experiences by advanced physics\n\n\u25a0 Player customization\n\n\u25a0 Simple UI and easy control can help anyone to play\n\n\u25a0 5 different difficulties from beginner to professional\n\n* The game format is the same as the official Olympic rules, so you can learn sports training and rules.\n* Suitable for virtual reality sports classrooms that must be conducted indoors due to physical education facilities and weather conditions.", "short_description": "10 Sports in 1 Game ! What type of sports acitivities will be safer during the pandemic era? All in One sports VR offers the most safe way to keep you healthy for both physically and mentally with zero contact."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.appnori.com/policy", "developer_terms_of_service_url": null, "publisher_name": "Appnori Inc.", "support_website_url": null, "website_url": "https://www.appnori.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SPORTS", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "532887294520410"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1158316938569345"}, {"status": "PUBLISHED", "id": "233812431790262"}, {"status": "PUBLISHED", "id": "1143665819476489"}]}, "baseline_offer": {"id": "1143665819476489"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1158316938569345"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8413819745402383", "version": "1.4.2"}, "id": "1117155452121376", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3840611616056575", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8413819745402383"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1729129368, "id": "8458896760894681", "version": "1.4.2", "version_code": 75, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3840611616056575", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8413819745402383"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1117155452121376"}]}, "change_log": "V1.4.2 Update Announcement\n\nHello, players! The V1.4.2 update has been released! In this update, we have added various new features, optimizations, and bug fixes. Please see the details below.\n\nLobby\n- Added UI for event tournament announcements\n\nBowling\n- Fixed an issue where the game would not proceed after a strike in the 10th frame\n\nBasketball\n- Optimized the stadium\n\nBadminton\n- Optimized the stadium\n- Changed the stadium and added UI elements to the scoreboard\n\nDarts\n- Fixed a bug where the opponent's hand in multiplayer did not receive light properly\n\nTable Tennis\n- Changed the stadium and added UI elements to the scoreboard\n\nBoxing\n- Changed the fire glove effect\n- Changed the stadium and added UI elements to the scoreboard\n- Fixed an issue where character shadows appeared incorrectly in single-player mode\n- Fixed an issue where the player direction was incorrect when a new round started in multiplayer mode\n- Performance optimization\n\nBaseball\n- Changed the fireball and fire bat effects\n\nTennis\n- Changed the fireball effect\n\nVolleyball\n- Changed the stadium and added UI elements to the scoreboard\n\nSquash\n- Changed the fireball and fire racket effects\n- Optimized the effects for better performance\n\nSoccer\n- Added spectator mode\n- Fixed an issue where the game would not proceed when the goalkeeper caught the ball in multiplayer\n- Optimized the map for spectator mode\n- Removed draws in penalty shootouts to align with official rules\n\nFoot Hockey\n- Added spectator mode\n\nKung Fu\n- Added spectator mode\n- Fixed an issue where the wrong icon appeared when switching tracker modes in the tutorial\n- Performance optimization across all martial arts\n\n\n-We hope this update will provide an even better gaming experience. We always value your feedback and are committed to making a better game. Enjoy your gaming!", "created_date": 1728562167, "id": "8413819745402383", "version": "1.4.2", "version_code": 74, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3840611616056575", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8413819745402383"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1117155452121376"}]}, "change_log": null, "created_date": 1727423666, "id": "8286127621504930", "version": "1.4.1", "version_code": 73, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3840611616056575", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8413819745402383"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1117155452121376"}]}, "change_log": "Announcement: Latest Update Complete\n\nDear players,\n\nWe have resolved the issue where the game did not progress correctly after scoring a strike in the 10th round. You can now play the game without any problems.\n\nThank you for your patience as we worked on this fix, and we will continue to strive for a better gaming experience.\n\nSincerely,\nAppnori", "created_date": 1727154057, "id": "8256127817838244", "version": "1.4.1", "version_code": 72, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3840611616056575", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8413819745402383"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1117155452121376"}]}, "change_log": "Get Ready for the Ultimate VR Sports Experience!\nWe\u2019re thrilled to announce the release of three brand-new sports in the latest DLC for All In One Sports VR!\nThis DLC brings a whole new level of excitement to All In One Sports VR.\nWhether you crave the intense discipline of combat sports or the adrenaline rush of team-based play, we\u2019ve got you covered!\nEach of these new sports will challenge you in unique ways, offering fresh, immersive experiences designed to push your skills and keep the adrenaline pumping.\nThis isn\u2019t just an update\u2014it\u2019s a major expansion that adds even more excitement and variety to your favorite VR sports game.\n1. KungFu\nUnleash your inner martial artist!\nEngage in intense sparring sessions, using real Kung Fu movements to block, deflect, and counter your opponent's attacks.\nFeel the precision and agility required as you train like a true master.\n2. Hockey\nChallenge yourself to a fast-paced air hockey game.\nUse the VR controller to control your paddle with pinpoint accuracy to block, attack, and dominate your opponents.\nThe winning dash is just one puck away!\n3. Soccer\nStep into the ultimate VR soccer experience!\nWhether you're dribbling past defenders, making that perfect pass, or shooting for goal, this mode brings the thrill of the pitch right to your living room with ultra-realistic physics and immersive gameplay.", "created_date": 1726030538, "id": "8142560092528351", "version": "1.4.1", "version_code": 71, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}