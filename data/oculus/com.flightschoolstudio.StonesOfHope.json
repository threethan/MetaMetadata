scdn.com/v/t64.5771-25/43931338_1894909554187819_1925674753099679481_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7h4SkbBEZp8Q7kNvgHVraV9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB854l0-a-jfibedrpwNBgAb2jKFC8Igzcb4rSk96kchg&oe=67499453"}, {"file_name": "NITT_Screenshot_5.png", "id": "665083618492483", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974716_665083625159149_1064865793251564261_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=50ivBu5Kaa8Q7kNvgHeTkyZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoM-MllbTZPSDDZvtOiAQlaTUHVdcWun9OSBl2Nc0BgQ&oe=6749A7DF"}, {"file_name": "NITT_Screenshot_4.png", "id": "1849346928758200", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036672_1849346932091533_7796005936924380429_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4N0eAWcP6ckQ7kNvgGXVV7U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxKCpBztGjIRQ3XQMO4DGu5Xqdqy7snN-LYxyTgocwJw&oe=6749B4D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NITT_DigitalAssets_v05_HDvideo_1920x1080.png", "id": "942459706719818", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035433_942459710053151_7882200148446536338_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=52WAdSa3pTQQ7kNvgGJVqem&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8EE6uBZOPm7p2yIXYzZXTTk9BQnv4gRezAjEGCv4bPg&oe=6749AB45"}, "display_name": "MLK: Now is the Time", "keywords": ["civil", "rights", "dream"], "long_description": "It\u2019s been sixty years since Dr. Martin Luther King delivered his iconic \"I Have a Dream\" speech, but the messages from that speech resonate today.  \n \n\u201cMLK: Now is the Time\u201d is an immersive journey that explores key themes of Dr. King's speech and highlights systemic inequities that persist in our society. Through first-person stories and interactions, \u201cMLK: Now is the Time\u201d drops you into a thoroughly modern interpretation of a contemporary March on Washington that will inform and inspire a new generation of activists. ", "short_description": "Dr. Martin Luther King's iconic \"I Have a Dream\" speech contains messages that still resonate today, sixty years later.  \n \n\u201cMLK: Now is the Time\u201d is an immersive journey that explores key themes of Dr. King's speech and highlights systemic inequities that persist in our society. Through first-person stories and interactions, \u201cMLK: Now is the Time\u201d drops you into a thoroughly modern interpretation of a contemporary March on Washington that will inform and inspire a new generation of activists."}]}, "developer_name": "Flight School Studio", "developer_privacy_policy_url": "http://time.com/nowisthetime/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "TIME Immersive", "support_website_url": null, "website_url": "http://time.com/nowisthetime/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "496618139167721"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "575852274419335"}]}, "baseline_offer": {"id": "575852274419335"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1673532060, "status": "PUBLISHED", "id": "575852274419335"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typen