665083625159149_1064865793251564261_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZmcvpCau6YkQ7kNvgHHKmLp&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYATN5RfycjGs-trn8TcRSiuvMPxsdnWZZ-qgmjuUVQgIA&oe=671248DF"}, {"file_name": "NITT_Screenshot_4.png", "id": "1849346928758200", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39036672_1849346932091533_7796005936924380429_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G3qqUATzQA0Q7kNvgGkNsoP&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAru1pUFqz0CG3ppQaMPLOJl-mneoMcjykDeQ-Dxtts7w&oe=671255D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NITT_DigitalAssets_v05_HDvideo_1920x1080.png", "id": "942459706719818", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39035433_942459710053151_7882200148446536338_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gN95WjiPyVcQ7kNvgE6b2pH&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDPO7_bk2dFg5viJjlOFUQ6JDm5p8M7Fx95ncUAgxzHJQ&oe=67124C45"}, "display_name": "MLK: Now is the Time", "keywords": ["civil", "rights", "dream"], "long_description": "It\u2019s been sixty years since Dr. Martin Luther King delivered his iconic \"I Have a Dream\" speech, but the messages from that speech resonate today.  \n \n\u201cMLK: Now is the Time\u201d is an immersive journey that explores key themes of Dr. King's speech and highlights systemic inequities that persist in our society. Through first-person stories and interactions, \u201cMLK: Now is the Time\u201d drops you into a thoroughly modern interpretation of a contemporary March on Washington that will inform and inspire a new generation of activists. ", "short_description": "Dr. Martin Luther King's iconic \"I Have a Dream\" speech contains messages that still resonate today, sixty years later.  \n \n\u201cMLK: Now is the Time\u201d is an immersive journey that explores key themes of Dr. King's speech and highlights systemic inequities that persist in our society. Through first-person stories and interactions, \u201cMLK: Now is the Time\u201d drops you into a thoroughly modern interpretation of a contemporary March on Washington that will inform and inspire a new generation of activists."}]}, "developer_name": "Flight School Studio", "developer_privacy_policy_url": "http://time.com/nowisthetime/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "TIME Immersive", "support_website_url": null, "website_url": "http://time.com/nowisthetime/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1283811691952063"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "496618139167721"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "575852274419335"}]}, "baseline_offer": {"id": "575852274419335"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1673532060, "status": "PUBLISHED", "id": "575852274419335"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6227997767290011", "version": "1.0.1-670645-1"}, "id": "629698568241830", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4790561384366997", "is_concep