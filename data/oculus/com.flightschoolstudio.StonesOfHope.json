4380429_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zkONaFMDeYQ7kNvgFLvMZY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwSRfVoRGDzW-wxDriEL4DN&oh=00_AYDZf0dUVx7pVQquDK6sGIrZ57xFpqu-EVSCT4ZyrHoz2A&oe=66F16051"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NITT_DigitalAssets_v05_HDvideo_1920x1080.png", "id": "942459706719818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035433_942459710053151_7882200148446536338_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KmAmjGK_cCkQ7kNvgH0WUWH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwSRfVoRGDzW-wxDriEL4DN&oh=00_AYC-K7eO8CzFN7a_Z3yy-xFD_ootzIll4HbPhu2TpWGppA&oe=66F156C5"}, "display_name": "MLK: Now is the Time", "keywords": ["civil", "rights", "dream"], "long_description": "** WINNER: Audience Award: 2023 SXSW XR Experience Spotlight \n** NOMINEE: Emmy: 2023 Outstanding Emerging Media Program\n** NOMINEE: Social Impact Award: 2023 AIXR VR Awards\n\nIt\u2019s been sixty years since Dr. Martin Luther King delivered his iconic \"I Have a Dream\" speech, but the messages from that speech resonate today.  \n \n\u201cMLK: Now is the Time\u201d is an immersive journey that explores key themes of Dr. King's speech and highlights systemic inequities that persist in our society. Through first-person stories and interactions, \u201cMLK: Now is the Time\u201d drops you into a thoroughly modern interpretation of a contemporary March on Washington that will inform and inspire a new generation of activists. ", "short_description": "Dr. Martin Luther King's iconic \"I Have a Dream\" speech contains messages that still resonate today, sixty years later.  \n \n\u201cMLK: Now is the Time\u201d is an immersive journey that explores key themes of Dr. King's speech and highlights systemic inequities that persist in our society. Through first-person stories and interactions, \u201cMLK: Now is the Time\u201d drops you into a thoroughly modern interpretation of a contemporary March on Washington that will inform and inspire a new generation of activists."}]}, "developer_name": "Flight School Studio", "developer_privacy_policy_url": "https://nowisthetime.time.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TIME Immersive", "support_website_url": null, "website_url": "http://time.com/nowisthetime/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1283811691952063"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6719561131467003"}, "review_messages": ["I've approved this submission, please note that the Hero Image has text that is going below the safe zone and into the bleed area - please fix for your next submission otherwise it may be rejected. "]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223477_6076997912344657_4165052289897781929_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yyCR-LyOJ68Q7kNvgFVMl5v&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwSRfVoRGDzW-wxDriEL4DN&oh=00_AYAAlq32r8ZNfupqTk8N4V0xuW2938m7WXJ_gLzQ0xNVkQ&oe=66F16BDD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MLK: Now is the Time", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Documentary", "id": "1283811691952063"}, {"topic_name": 