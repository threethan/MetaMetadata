2445264294_n.png", "id": "3488573521406645", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982634_3488573524739978_1058832383216682676_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z1fHqcd06lYQ7kNvgGBdAsr&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDpYwYSnd65n70Eel0kjhxPEXGwKlDCZhn2ESP2KZ0xfA&oe=671A2A63"}, {"file_name": "Dragons Fit.png", "id": "2686524794831341", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974571_2686524801498007_1837795891791832642_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GaD1aW1VvLoQ7kNvgFF0FtG&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAIYYfOx98dAQdrk5PTdLryFoOU-8cYZmkIg1LyMOFRAA&oe=671A2EDB"}, {"file_name": "Battle Fit.png", "id": "1033211114593372", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/86794643_1033211117926705_3117466909561812951_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aeVMN6fLBk0Q7kNvgGeY9yA&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYA9RanqCuBymmxFEs1miNHK7HztrWMVRY921ldpGrHXkQ&oe=671A3811"}, {"file_name": "Scales Fit.png", "id": "1274722773218037", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031479_1274722776551370_198509303584703668_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=adnAv4u9I2kQ7kNvgHwY52e&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYC__Bn2HpKNGVjLjj9EFY8wWB7rsOKvyhey4gVKRAcxdg&oe=671A4F8F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Thumb.png", "id": "1514058476107369", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974584_1514058479440702_2118685885866131343_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JzyuYXZu-kAQ7kNvgElOsF_&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBsQdP9fg8vPNVhrev2kqrO-L7TNl99W7VZ9U7wVNmovQ&oe=671A4AFA"}, "display_name": "Dragon Front Rising", "keywords": ["MixedReality", "Fantasy", "Dragons", "CCG", "Strategy"], "long_description": "Challenge players online or solo with Conquest mode in this immersive collectible card-battler. Dragon Front Rising mixes high fantasy with World War II on a 4x4 grid battlefield that is alive with rampaging giants, intimidating war-machines, and soaring projectiles.\n\n* Meta Quest 3 and Meta Quest Pro users can enjoy Dragon Front Rising in cutting edge Mixed Reality (MR)\n\n* Online Multiplayer \u2013 Challenge your friends, or online armies, and climb through the competitive ranks for rewards.\n\n* 7 Thematically Diverse Factions \u2013 Each army is equipped with unique powers, traits and strategies, and powerful Champions. \n\n* Collectible Cards \u2013 Construct your 30 card deck from over 500 battle-hardened soldiers, fortifications that evolve the battlefield, and a wide array of spells.\n\n* Champion System \u2013 Legendary champions helm your army to ensure an epic come-back in the late minutes of every game.\n\n* Test your decks in Conquest Mode, playing against a relentless AI campaign to take control of the realm.", "short_description": "Challenge players online or solo with Conquest mode in this immersive collectible card-battler. Dragon Front Rising mixes high fantasy with World War II on a 4x4 grid battlefield that is alive with rampaging giants, intimidating war-machines, and soaring projectiles."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.high-voltage.com/privacy/", "developer_terms_of_service_url": "https://www.high-voltage.com/end-user-license-agreement/", "publisher_name": "Meta", "support_website_url": "https://www.high-voltage.com/contact-us/", "website_url": "https://www.dragonfrontrising.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memo