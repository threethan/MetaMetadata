2445264294_n.png", "id": "3488573521406645", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982634_3488573524739978_1058832383216682676_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YsXe-VozuPoQ7kNvgGSjaxA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDseZ-uaAyNijWZHmSh_rmqAX1gLPbAUIKeDms6yLVXhw&oe=671E1EE3"}, {"file_name": "Dragons Fit.png", "id": "2686524794831341", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974571_2686524801498007_1837795891791832642_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNU3sJ8xwXcQ7kNvgEgtDo0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDo-qpAY8EiyQ7b6kRA4_6CBwj-QgPw-b-82DXY8oLO9w&oe=671E235B"}, {"file_name": "Battle Fit.png", "id": "1033211114593372", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86794643_1033211117926705_3117466909561812951_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KjWXN8EYs3cQ7kNvgFMYkkQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDPlunN1uTdAQEUF-56-8qv3WpuqdfBG1UatSaTLjvCA&oe=671E2C91"}, {"file_name": "Scales Fit.png", "id": "1274722773218037", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031479_1274722776551370_198509303584703668_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C82_R2szJCEQ7kNvgGhYp3l&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRgVo6P2rqd_oscK-GOGETi9zNHApAeHFqxcndN8uphQ&oe=671E0BCF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Thumb.png", "id": "1514058476107369", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974584_1514058479440702_2118685885866131343_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h10rPNbZxmMQ7kNvgH9vV9r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCWva6fmZn2PZHArzRC8uF87ka4zSBOBjR9dYBioTrLjA&oe=671E3F7A"}, "display_name": "Dragon Front Rising", "keywords": ["MixedReality", "Fantasy", "Dragons", "CCG", "Strategy"], "long_description": "Challenge players online or solo with Conquest mode in this immersive collectible card-battler. Dragon Front Rising mixes high fantasy with World War II on a 4x4 grid battlefield that is alive with rampaging giants, intimidating war-machines, and soaring projectiles.\n\n* Meta Quest 3 and Meta Quest Pro users can enjoy Dragon Front Rising in cutting edge Mixed Reality (MR)\n\n* Online Multiplayer \u2013 Challenge your friends, or online armies, and climb through the competitive ranks for rewards.\n\n* 7 Thematically Diverse Factions \u2013 Each army is equipped with unique powers, traits and strategies, and powerful Champions. \n\n* Collectible Cards \u2013 Construct your 30 card deck from over 500 battle-hardened soldiers, fortifications that evolve the battlefield, and a wide array of spells.\n\n* Champion System \u2013 Legendary champions helm your army to ensure an epic come-back in the late minutes of every game.\n\n* Test your decks in Conquest Mode, playing against a relentless AI campaign to take control of the realm.", "short_description": "Challenge players online or solo with Conquest mode in this immersive collectible card-battler. Dragon Front Rising mixes high fantasy with World War II on a 4x4 grid battlefield that is alive with rampaging giants, intimidating war-machines, and soaring projectiles."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.high-voltage.com/privacy/", "developer_terms_of_service_url": "https://www.high-voltage.com/end-user-license-agreement/", "publisher_name": "Meta", "support_website_url": "https://www.high-voltage.com/contact-us/", "website_url": "https://www.dragonfrontrising.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memo