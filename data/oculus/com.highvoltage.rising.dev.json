8573524739978_1058832383216682676_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WRjmSImHHVYQ7kNvgGN19b-&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBenrcuwe21YKXrPRsJaZEvCMM7hyQ4tTxGL6dVCv7Dcw&oe=670BA9E3"}, {"file_name": "Dragons Fit.png", "id": "2686524794831341", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974571_2686524801498007_1837795891791832642_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s0twftFlAVAQ7kNvgHOO2bt&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCeL8CjDjl5QGK3xW57L3zc6I9sHYYcNmfu3fcDWx-GEQ&oe=670BAE5B"}, {"file_name": "Battle Fit.png", "id": "1033211114593372", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/86794643_1033211117926705_3117466909561812951_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3mSRX5cEJc8Q7kNvgHaZc-X&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD-8ZahmOUqNlhz2knE3HNXG_j7xK6tnOnxBUd2EB_9_g&oe=670BB791"}, {"file_name": "Scales Fit.png", "id": "1274722773218037", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031479_1274722776551370_198509303584703668_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DCT4j1fMkdkQ7kNvgHbwrio&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDDQow9UcfzURVojUU0_7B2TMyOal_bdr8gKLw3qR1OZg&oe=670B96CF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Thumb.png", "id": "1514058476107369", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974584_1514058479440702_2118685885866131343_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7OlnwAN20qUQ7kNvgHlzqd-&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBJxP6Q6Z8QjQk67KXxZj1a8VOoFAd2xtllC-cZBB5CZw&oe=670BCA7A"}, "display_name": "Dragon Front Rising", "keywords": ["MixedReality", "Fantasy", "Dragons", "CCG", "Strategy"], "long_description": "Challenge players online or solo with Conquest mode in this immersive collectible card-battler. Dragon Front Rising mixes high fantasy with World War II on a 4x4 grid battlefield that is alive with rampaging giants, intimidating war-machines, and soaring projectiles.\n\n* Meta Quest 3 and Meta Quest Pro users can enjoy Dragon Front Rising in cutting edge Mixed Reality (MR)\n\n* Online Multiplayer \u2013 Challenge your friends, or online armies, and climb through the competitive ranks for rewards.\n\n* 7 Thematically Diverse Factions \u2013 Each army is equipped with unique powers, traits and strategies, and powerful Champions. \n\n* Collectible Cards \u2013 Construct your 30 card deck from over 500 battle-hardened soldiers, fortifications that evolve the battlefield, and a wide array of spells.\n\n* Champion System \u2013 Legendary champions helm your army to ensure an epic come-back in the late minutes of every game.\n\n* Test your decks in Conquest Mode, playing against a relentless AI campaign to take control of the realm.", "short_description": "Challenge players online or solo with Conquest mode in this immersive collectible card-battler. Dragon Front Rising mixes high fantasy with World War II on a 4x4 grid battlefield that is alive with rampaging giants, intimidating war-machines, and soaring projectiles."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.high-voltage.com/privacy/", "developer_terms_of_service_url": "https://www.high-voltage.com/end-user-license-agreement/", "publisher_name": "Meta", "support_website_url": "https://www.high-voltage.com/contact-us/", "website_url": "https://www.dragonfrontrising.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_MX", "fr", "de", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"]