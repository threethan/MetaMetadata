275_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yj4PF1AUF_MQ7kNvgE7ZMgN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDR2v8ots-Xf7-SDHo-4KjTAUeIF9PeAaQUp8gTTXSdDg&oe=67275552"}]}, "id": "1279525003225101", "locale": "en_US", "screenshots": [{"file_name": "rainmaker-store.png", "id": "3304930936489329", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031516_3304930939822662_3024577294544462636_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wnvjcw30MG8Q7kNvgFVzlwe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCF6xF0ly9eNfv5axb9lCoKRqztrGx4iYdfT-bGTIDdhA&oe=672747CB"}, {"file_name": "PatchWorld_Screenshot_03.png", "id": "774888243787021", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75340713_774888247120354_3853613240663211124_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q6UsV-DvGL4Q7kNvgGhzLAa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASSdwPiYlBBj3lPlBx17_Mlvca8s-5mJLFo84FpTLB-w&oe=67277161"}, {"file_name": "EP2-store.png", "id": "1093564108188171", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982647_1093564111521504_1443822054915238278_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWY19Dpu428Q7kNvgH0EAER&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLA_PoMmeFjRCq6jl4VuksTri0IUc4FhHG6V6LM7MYQA&oe=67276BCF"}, {"file_name": "deviceandmrbouncy-store.png", "id": "813540293118698", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/54809987_813540296452031_3683609199160633668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XR3wzbfz0BUQ7kNvgHy60FZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJ7rNW6TJDyOLMHdzEb-Gv6BZ8sBQeG2RfMFhkvYL-6g&oe=67275443"}, {"file_name": "MR snapshot.png", "id": "504004651285098", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974458_504004654618431_6635035311508794289_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TynZDTjXhQoQ7kNvgHVxqSL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2zLIWUS4ucTHfPklC4PQz-0Uf-9A2gtjQXqU0CqpABg&oe=67275676"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Frame 5.png", "id": "494940995740872", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982466_494940999074205_2689054535717780810_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cbAkQnLsCO0Q7kNvgH0me8l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgaAt2JhuQJx-DRR6f8t71WH6IFHM215WmPoSx26BrCQ&oe=672767BA"}, "display_name": "PatchWorld - Multiplayer Music Maker", "keywords": ["create", "music", "DJ", "multiplayer", "social"], "long_description": "PatchWorld is more than a music app; it's a mixed reality studio where your creations come to life, perfect for sharing on social media:\n\n* Dive into a universe of infinite worlds, each a canvas for your imagination. \n\n* Ideal for content creators, musicians, and VR enthusiasts.\n\n* Collaborate with musicians and creators in real-time jams and world-building.\n\n* Amass an unlimited collection of sounds and instruments for your studio.\n\n* Seamlessly record and share your VR performances and creations.\n\n*  Explore and contribute to a library of over 40 pre-built worlds.\n\n* Exclusive to Meta Quest 3 and Meta Quest Pro: Craft and share cinematic mixed reality content and films.\n\n* Enjoy unparalleled mixed reality features with Meta Quest 3 and Meta Quest Pro's advanced capabilities.\n\n* Experience the richness of 3D spatial audio and a high-quality VR audio engine.\n\n* Connect with Ableton Live for comprehensive cross-reality studio integration. \n\n\nNew features and improvements:\n\n* Support for Ready Player Me avatars\n\n* Portal Blocks\n\n* Community page, world suggestions, and improved search for worlds and other players.\n\n* Patch Worlds from the community, with weekly events, Venues for jam sessions, how-to content, and featured user art and instruments\n\n* Fixes to multiplayer sync and joining sessions\n\n\nJoin our dynamic Discord community for exclusive access to the PatchMaker beta and begin your journey in crafting and sharing immersive mixed-reality content.", "short_description": "Discover the ultimate VR playground in PatchWorld! Create and explore boundless worlds, build your dream music studio, and connect with friends globally. Now bring your Ready Player Me avatars. Unique to Meta Quest 3 and Meta Quest Pro: Capture your mixed reality adventures and musical creations and share on social media. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://wiki.patchxr.com/privacy-policy-201", "developer_terms_of_service_url": "https://patchxr.com/license/", "publisher_name": "PatchXR", "support_website_url": null, "website_url": "https://patchxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7914366651964330"}, "review_messages": ["Please schedule release."]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974907_7778294172208916_3632987520609288523_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_knMn79Wr4wQ7kNvgHaS8jr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApW173SP3-idplwcAacxRrdYmU99qpX0E0sIGQmjBDDA&oe=672755D9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PatchWorld - Multiplayer Music Maker", "platfo