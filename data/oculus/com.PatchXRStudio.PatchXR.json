m/v/t64.5771-25/39031634_415254350489386_8633858151340321297_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QafcZTLdgu8Q7kNvgFmiWQg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdDUpsje21i8bZPfMIKfpaFxJ0Lqx_27Na7Wo7r4eitg&oe=6784EAB7"}, {"file_name": "Rainmaker.png", "id": "406285344740675", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031453_406285348074008_876362344507952341_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxZslQG90sMQ7kNvgEqIN5y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTEjxuf56YvMoSbAq7FG3gdxVUxtaY-xs-nuiRMO8Uuw&oe=6785063B"}, {"file_name": "Frame 7.png", "id": "345864101013118", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982552_345864104346451_3235740934879403403_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MeO3QDPtLDsQ7kNvgGe_Ylb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2exYF0UD1cxMvTsomlY7lJadaXWVTGDCReVY8Z4E9fw&oe=6784FE05"}, {"file_name": "Frame 6.png", "id": "716253483129159", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982449_716253486462492_1631874179459413443_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xJoSC1YoL7kQ7kNvgFc6g-e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByGvMe1vmuKNzj2BJVXOvmtCxPnQ0EZz8vPPMoA_uvxQ&oe=6784E69C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Frame 5.png", "id": "494940995740872", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982466_494940999074205_2689054535717780810_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zMZAub73prcQ7kNvgEF0vZu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVZYuKLEAovyQkKQkxkuiigd6GrqwPQeoRGAvLYwd1Fw&oe=6785023A"}, "display_name": "PatchWorld", "keywords": ["create", "music", "DJ", "sandbox", "world"], "long_description": "Unleash your creativity in the marvellous musicverse of PatchWorld! Explore an ever-expanding library of tools, toys, and wild instruments you can use to make your own music in VR. Join an underwater reggae jam, blast some hard techno beats, or make polyrhythms out of rainfall. Build your own reactive stage and musical inventions \u2013 fully immersed, natively on your headset!\n\nEXPLORE a growing number of experiences, shows, virtual studios, and instruments created by artists around the globe.\n\nCREATE your own musical worlds and instruments, design your avatar, and record yourself performing, for musicverse music videos and shows.\n\nSHARE your creations with the world in a series of updates coming soon. Publish your works to PatchWorld and in the coming months, multiplayer support will allow you to explore, build, and jam in real-time with friends.\n\n*Join our Discord channel to access our community and register for the PatchMaker beta for early access to even more powerful creative feature*", "short_description": "Unleash your creativity in the marvelous musicverse of PatchWorld!\n\nEXPLORE a growing number of experiences, shows, virtual studios, and instruments created by artists around the globe.\n\nCREATE your own musical worlds and instruments, design your avatar, and record yourself performing shows.\n\nSHARE creations with the world with updates coming soon. Publish your works to PatchWorld and in the coming months, multiplayer support will allow you to explore, build, and jam in real-time with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://coda.io/@patch-world-build-guide/patchxr-wiki/privacy-policy-201", "developer_terms_of_service_url": "https://patchxr.com/license/", "publisher_name": "PatchXR", "support_website_url": null, "website_url": "https://www.patchxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "REQU