=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TKuDzVF_MYYQ7kNvgEv5S2A&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYfEHbO0W3xQMs3tN7_oi7m&oh=00_AYDJynH1t_icwxPc1d3LrhxOaKooe6bgCbZ1eOUWV9NiLQ&oe=66F154E8"}, {"file_name": "1.png", "id": "679058940374349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982676_679058943707682_9004057607941484755_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vy3NalNPKKcQ7kNvgFRcWk4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYfEHbO0W3xQMs3tN7_oi7m&oh=00_AYCblXT0EtFk4PlKFHrfIyuEMW2W_BlnOc7Pq8AsAJ5tQw&oe=66F142B5"}, {"file_name": "5.png", "id": "6592664140794052", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982696_6592664147460718_1415334430303956780_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7bGOoq3KrSkQ7kNvgHi61wY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYfEHbO0W3xQMs3tN7_oi7m&oh=00_AYAwjBuTe29ybAbmUT6_299Uhj-5oWrxO6QXW6-KlLB-Xg&oe=66F16A25"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WAG-COVER-IMAGE.png", "id": "228390826836793", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469631_228390830170126_6775051472029311939_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5VSbVYN5RBcQ7kNvgF-UTF9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYfEHbO0W3xQMs3tN7_oi7m&oh=00_AYD82Hb8h4w2OSHiioHqtrYWHM-zee-3gEAOJCEeR6XAYA&oe=66F143E5"}, "display_name": "Wallace & Gromit in The Grand Getaway", "keywords": ["wallace", "gromit", "space", "mars", "fun"], "long_description": "Wallace and Gromit are preparing for a well-earned golfing getaway. They've even created a new Auto-Caddy contraption to join them!\n\nBut Wallace soon discovers he has his dates mixed up, and they need a quick solution to make up time! There\u2019s only one option...they\u2019ll have to take the Rocket and hope nothing goes wrong along the way\u2026 \ud83d\ude80! \n\nBefore long, mishaps and mayhem send the team hurtling into deep space on an epic new adventure.\n\nWill this be a holiday to remember? Or one they'd rather forget...\n\nStep into their world and play your part to find out!\n\n\nFEATURES\n\n\ud83d\ude80Blast off on an epic story-led adventure.\n\n\ud83d\udc3ePlay from the perspective of Wallace, Gromit and their brand new contraption Auto-Caddy!\n\n\ud83d\udd79\ufe0fEnjoy re-playable mini-games along the way.\n\n\ud83c\udfa5 Explore some of their most iconic environments and new ones in a story chock full of the heart and humour of a classic Aardman film.\n\n\ud83e\ude90Discover strange worlds, encounter new life forms, and, well, eat cheese and crackers!\n\n\ud83d\udc6a A fun-tastical mix of story and game for all the family.\n\n\u270bPlayable with Hand-Tracking or Controllers.\n\n\ud83c\udfc6 From the multi-award-winning independent animation studio Aardman (Wallace & Gromit, Chicken Run, Shaun the Sheep) and immersive storytelling experts Atlas V (Madrid Noir, Gloomy Eyes, Battlescar).", "short_description": "Now is your chance to wishlist Wallace & Gromit\u2019s first-ever VR experience!\n\nThe Grand Getaway will take old-time fans and newcomers on an exciting and immersive VR adventure with much-loved characters Wallace and Gromit.\n\nStep into the shoes (and paws) of the legendary duo as they blast off on a cracking new adventure that takes the team from the familiar sights of West Wallaby Street to the strange surroundings of deep space. \nAll in glorious VR-O-Rama!\n"}]}, "developer_name": "Aardman, Atlas V, NoGhost, Albyon", "developer_privacy_policy_url": "https://astreaimmersive.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://wallacegromitvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2777382702530830"}, {"id": "2691890164460465"}, {"id": "447840929525167"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_