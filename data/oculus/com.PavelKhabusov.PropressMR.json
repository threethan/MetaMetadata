432\u0430\u043d\u0438\u044f \u2014 \u0441\u0434\u0435\u043b\u0430\u043d\u043e \u0432 Clipchamp (6) - frame at 3m1s.png", "id": "622651520057962", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43931328_622651523391295_8517572701458591240_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-dsQI9-h5U4Q7kNvgF8No4_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBN3mkA6L-1VNfcW7lZfVHhWSqBIEQu_J9WCsG7ePP-0w&oe=6739EE13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u0412\u0438\u0434\u0435\u043e \u0431\u0435\u0437 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u044f \u2014 \u0441\u0434\u0435\u043b\u0430\u043d\u043e \u0432 Clipchamp (6) - frame at 3m51s.png", "id": "1636133830467825", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974458_1636133837134491_3079484974793979767_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rG4FUC1hXOwQ7kNvgGX0D3o&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUqEVrvRWtYdV_ekzeWODQS7FWl7QLKep_hENY3Am-RQ&oe=6739EDE7"}, "display_name": "Kartoteka", "keywords": [], "long_description": "\ud83c\udf1f Welcome to the world of innovation and convenience for designers and private customers! Our unique application allows you to virtually try on paving slabs, bricks, granite, wallpaper, parquet and more with the help of Meta Quest 3 glasses.\n\n\ud83c\udfa8 Products from a variety of companies are available to you to create the perfect combination for any project. Choose a color that harmonizes with the surroundings and choose a shape that will emphasize the uniqueness of each corner.\n\n\ud83d\udca1 Our application will help you visualize the project, saving time and resources on physical examples. Save your energy and focus on the most important thing - turning your idea into reality.\n\n\ud83d\udd27 Ease of use, high-quality visualization and a huge selection of colors and shapes make our application an ideal tool for anyone who appreciates innovation and professionalism in landscape design.\n\n\u2728 Don't miss the chance to improve the design process with our Meta Quest 3 glasses app!", "short_description": "Virtually try on paving slabs, bricks, porcelain stoneware, wallpaper, parquet and more from a variety of companies simply and quickly! A great tool for designers and anyone who wants to see future design in real time. Immerse yourself in the world of colors and shapes to create a stylish and harmonious design of the space! \u2728 \ud83c\udfa8"}]}, "developer_name": "Pavel Khabusov", "developer_privacy_policy_url": "https://propress.ru/customer/politika-konfidencialnosti-kartoteka/", "developer_terms_of_service_url": null, "publisher_name": "Pavel Khabusov", "support_website_url": null, "website_url": "https://propress.ru/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ru"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8241942065823010"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "805493144751699"}]}, "baseline_offer": {"id": "805493144751699"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1713295560, "status": "PUBLISHED", "id": "805493144751699"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8632442233439656", "version": "3.6.3"}, "id": "1062067868422804", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [