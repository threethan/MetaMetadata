=6e7a0a&_nc_ohc=Ccyg6tQPASQQ7kNvgGE2XGA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkEaAXvazYvfY6kpxuVDzrjpjfCVqVA3W4K3lC4IaJJQ&oe=66DC3ABE"}, {"file_name": "Oculus_Logo_sc.png", "id": "471620827192922", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_471620830526255_4534585783299574611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ePF7ItcNnt0Q7kNvgEFrd6Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbVMQ3gKmIizbT6T-bz1cwV1Ga61KXUdswKYfO6yaSYA&oe=66DC4759"}, {"file_name": "Oculus_Hero_tc.png", "id": "424594388610036", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485579_424594391943369_7165260809346619121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xRqPc-SIcfIQ7kNvgGY-IOA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBndmzpkWkoGC7g1F7eHOZ7P0hsb-eFnPIgFcYCIizW3A&oe=66DC3BEA"}]}, "id": "435274941083731", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u4e0e\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "4977285745675565", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974887_4977285749008898_4482133498831970937_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V8e4ddiMS9YQ7kNvgE_iIrj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLhroqHJTB5F-DBxCoKCkDwgkY-wWPC7K-vuahujhLWA&oe=66DC4DFB"}, {"file_name": "Oculus_Portrait_en.png", "id": "1115593388914444", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031366_1115593392247777_1108929082473903627_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kbb--Cq7iPwQ7kNvgHnaElz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHo92Svm-RK81qHh5mftn8C48Ckclrdsv_CSQQLb077w&oe=66DC2404"}, {"file_name": "Oculus_Hero_en.png", "id": "871157030095923", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982668_871157033429256_6789488157395094913_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ea2o_2ZSZUQ7kNvgFWoUbm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBk4I3zAg6uZYloLBxfD6fh_DQLoK1MHXbadoOa-9SqJg&oe=66DC47D0"}, {"file_name": "Oculus_Square_en.png", "id": "477446693254143", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_477446696587476_4659881486425096962_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_4L5jG3ZZjUQ7kNvgHR5_ea&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCEFOB7jCzBR1pFGbbwN0I62g39ZSgO0KMcUL1ZwkOWg&oe=66DC3849"}, {"file_name": "Oculus_Landscape_en.png", "id": "427087448520662", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984459_427087451853995_4215533920751611972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hencspSWrpUQ7kNvgENEIsE&_nc_ht=scontent.oculuscdn.com&oh=00_