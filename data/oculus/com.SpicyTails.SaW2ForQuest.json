2653_514961039895486_7808674029667119029_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4uAW8Z4c-wsQ7kNvgF8Z33M&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2kdxh1_v5-ixHTDqb-L5bhGhWV-VjmiRz2iJk0K-59A&oe=6714E341"}, {"file_name": "Oculus_VRLandscape_tc.png", "id": "495203051865619", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75530717_495203055198952_2833762408757760645_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uQsqTOwsK4IQ7kNvgHasF7Q&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwjx86JrCTo9An8o12zVYnr1lg9LRlRET7y8zOm3BHCQ&oe=6714E5A7"}, {"file_name": "Oculus_Hero_tc.png", "id": "493992588655970", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974841_493992591989303_6448678946023260907_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qvpa00AI5McQ7kNvgF2VVXG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9IPDts0cvudpPUpG2CTpQPBgIRsz9YLzUpZU_T1eOFg&oe=6714E7A2"}, {"file_name": "Oculus_Landscape_tc.png", "id": "436327121017163", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75299157_436327124350496_1480866125900628976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1D9TRJcB5FIQ7kNvgEK7Y9g&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5cyju_2y4I6kS0ByhjuJ_OrvjxlLbQhpK3Gtg4PUsxw&oe=6714EEFE"}]}, "id": "1482939075228787", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u8207\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "1064913614018317", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375083_1064913617351650_8414523728123351065_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aYIeJ69na4kQ7kNvgH-Vp0b&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARQE9HNYy9AKj5wRugh8HSxxAvifdxZQTC9yFfZJAOhg&oe=6714DF51"}, {"file_name": "Oculus_Landscape.png", "id": "888092388709773", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221313_888092392043106_3388339122400482554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZlGiZ_swtKAQ7kNvgF95GmI&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB51DvMRnR4GGRV4UOBkb3L8l3kMNz2imwzcyBVTvOmHw&oe=67150288"}, {"file_name": "Oculus_VRLandscape.png", "id": "723262801706006", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982668_723262805039339_6616665206780105350_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sRJAWV89XWwQ7kNvgHhBXhk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDyjsnbd6fXzYhJWUg7wN_YVjPhMNjamx_lSFA7e8DbjA&oe=6714D9A5"}, {"file_name": "Oculus_Hero.png", "id": "714465152559029", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.ocul