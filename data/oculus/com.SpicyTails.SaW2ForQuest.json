=6e7a0a&_nc_ohc=d55PAM6d7QUQ7kNvgGM8wFF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjKe6o0WlkzKv2cojW_j9IQ3_QOnHiTQOPhreLFLF2mA&oe=66D8463E"}, {"file_name": "Oculus_Logo_sc.png", "id": "471620827192922", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_471620830526255_4534585783299574611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1GaFSiB3mPcQ7kNvgGbVN83&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsQ7ztrV57LK4CTMTfGXDySGf-Yfa8OBlAhhEcVjOzOA&oe=66D852D9"}, {"file_name": "Oculus_Hero_tc.png", "id": "424594388610036", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485579_424594391943369_7165260809346619121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=omaF-fh0v5cQ7kNvgFbdst_&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8TgFwtE3-vHmjrmg9TUvAkf8mB44xggjSlMtAI7Xatg&oe=66D8476A"}]}, "id": "435274941083731", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u4e0e\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "4977285745675565", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974887_4977285749008898_4482133498831970937_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e3dUGsWOIKAQ7kNvgGrDCJW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwRFGeTwEl2DqyyJvRSJRTsBs9OeuWJMESeXHQZJa2tg&oe=66D8597B"}, {"file_name": "Oculus_Portrait_en.png", "id": "1115593388914444", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031366_1115593392247777_1108929082473903627_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LJOBjd9wETEQ7kNvgEK9RYb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJWWkEZLaEqHEXWpXUpS6BXsXKg8-iuj5yJKhk8AQBSA&oe=66D82F84"}, {"file_name": "Oculus_Hero_en.png", "id": "871157030095923", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982668_871157033429256_6789488157395094913_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4I7Zk5bdEN4Q7kNvgGy7wLu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoeBWx-UiXbQWukkFIEosOZkNdvbb2NrOFgPCf1EASRw&oe=66D85350"}, {"file_name": "Oculus_Square_en.png", "id": "477446693254143", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_477446696587476_4659881486425096962_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xDht3xLsJzYQ7kNvgERBb-n&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjGwdPAZGHh5y9n9KPH76uCC9r-3A9oGiXoAbMKr8uvw&oe=66D843C9"}, {"file_name": "Oculus_Landscape_en.png", "id": "427087448520662", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984459_427087451853995_4215533920751611972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JksSxNyLX2cQ7kNvgGVFmn7&_nc_ht=scontent.oculuscdn.com&oh=00_