png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Che0qg39GlsQ7kNvgHfnLMU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDaVgHaPduPgxCI_ZQobJ1hiKtXQy6YGpQ2Km3ejhWhw&oe=66D83E41"}, {"file_name": "Oculus_VRLandscape_tc.png", "id": "495203051865619", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75530717_495203055198952_2833762408757760645_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vgSC-K8_uxcQ7kNvgH5XOMg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAcI-8omF7-sAZy3LmGUtW61TmhiyoqJ-nqjA8m5fOo9A&oe=66D840A7"}, {"file_name": "Oculus_Hero_tc.png", "id": "493992588655970", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_493992591989303_6448678946023260907_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vdULvf0GS1UQ7kNvgFww0wj&_nc_ht=scontent.oculuscdn.com&oh=00_AYB99492LYy1Eav5FyzZ_RbN9Oay8chVn7MdrF7DEK1JCQ&oe=66D842A2"}, {"file_name": "Oculus_Landscape_tc.png", "id": "436327121017163", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299157_436327124350496_1480866125900628976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0XfPbNbvZrUQ7kNvgFJc1GT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgZYQAj0p1dfbs7OyYPoeiLJKEDQ0a-0UIaFZUdIDP7g&oe=66D849FE"}]}, "id": "1482939075228787", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u8207\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "1064913614018317", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375083_1064913617351650_8414523728123351065_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8MMaBDJVEe8Q7kNvgFMqWTw&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-HrmpM-Pdlsl6GoVyi9Hxx_svLR-kvlF8Ylrz6DKYlA&oe=66D83A51"}, {"file_name": "Oculus_Landscape.png", "id": "888092388709773", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221313_888092392043106_3388339122400482554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W12ShMWAtuAQ7kNvgGsxtUR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWeuStQzJEQRGI2pxtwhF4wIUswczRCq1I0FdMsmnT8g&oe=66D85D88"}, {"file_name": "Oculus_VRLandscape.png", "id": "723262801706006", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982668_723262805039339_6616665206780105350_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1i5xEWc01ewQ7kNvgEjWOeg&_nc_ht=scontent.oculuscdn.com&oh=00_AYALKTfHm069JWcK70-lz2aY2S9g77ViUtF6_bs-04wc1A&oe=66D834A5"}, {"file_name": "Oculus_Hero.png", "id": "714465152559029", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367592_714465155892362_8370308211571510202_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nNzAbm0eP_kQ7kNvgG5K_wv