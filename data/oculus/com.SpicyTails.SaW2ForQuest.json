2653_514961039895486_7808674029667119029_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_6s08AhKDPcQ7kNvgEHorzu&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYA5yvzr9Pv_UcILMWASLSHqi2JHEzlh1EkE582D4pnyGg&oe=67124041"}, {"file_name": "Oculus_VRLandscape_tc.png", "id": "495203051865619", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75530717_495203055198952_2833762408757760645_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l1ZgBvrEpdIQ7kNvgHcFXsB&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCLcMof-cpDQDcZMmmr6iX2Vb9aVGCjjEZGUOoIIFZSrw&oe=671242A7"}, {"file_name": "Oculus_Hero_tc.png", "id": "493992588655970", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974841_493992591989303_6448678946023260907_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nY8l61rCYPMQ7kNvgH6VqFp&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCfnNrvGXV6eicUop8fgKsBsRRy3CtT8wXOQNx-UaaOeQ&oe=671244A2"}, {"file_name": "Oculus_Landscape_tc.png", "id": "436327121017163", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75299157_436327124350496_1480866125900628976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1D9TRJcB5FIQ7kNvgH4l_v2&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAitYEEuDfgo5i_IDJEs0GPixnDhteYfuyD9Shz-CbChg&oe=67124BFE"}]}, "id": "1482939075228787", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u8207\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "1064913614018317", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75375083_1064913617351650_8414523728123351065_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hlsnEcnrWRgQ7kNvgHy-sPV&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBSmrYyOjWmuQaMMvm64W6QEyRl7LdexxemNqKqtXTl5g&oe=67123C51"}, {"file_name": "Oculus_Landscape.png", "id": "888092388709773", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75221313_888092392043106_3388339122400482554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YTBfA9YckM4Q7kNvgHjLlsc&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDKXFJgszBnF8da5FceVbC_zQ1dTQDDxu5unsmt8Nwn-g&oe=67125F88"}, {"file_name": "Oculus_VRLandscape.png", "id": "723262801706006", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982668_723262805039339_6616665206780105350_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4mlimkaFntEQ7kNvgGkd5KZ&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDBQGzeLJpfvnGzIihB_W2dasBkZ8YCfBnf87sRvxl8yw&oe=671236A5"}, {"file_name": "Oculus_Hero.png", "id": "714465152559029", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lhr6-1.ocul