=6e7a0a&_nc_ohc=7w0B5gCYVHgQ7kNvgE2t1Vf&_nc_ht=scontent.oculuscdn.com&oh=00_AYCQKjP1-gI77otsnMNIQWLR-humSDJv1r013OB7v_8Afg&oe=66CC68BE"}, {"file_name": "Oculus_Logo_sc.png", "id": "471620827192922", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_471620830526255_4534585783299574611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yaAQQ8iKxEAQ7kNvgFIAC40&_nc_ht=scontent.oculuscdn.com&oh=00_AYApKIDbG3-Dczs0NRf7jbTQydSVD8a6cqhUtKnthPzuww&oe=66CC7559"}, {"file_name": "Oculus_Hero_tc.png", "id": "424594388610036", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485579_424594391943369_7165260809346619121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9rYSnR9bzzgQ7kNvgHktuZJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTeVmpaIvt0xmW14wFiHbAJyVkkkxVXqScHnqNli_bvg&oe=66CC69EA"}]}, "id": "435274941083731", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u4e0e\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "4977285745675565", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974887_4977285749008898_4482133498831970937_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=erB5KCG7VwcQ7kNvgEcuDWY&_nc_ht=scontent.oculuscdn.com&oh=00_AYAwFAsN5uwHk0LNYfL6bFVUK294FNDbB3t26GgMk97XeA&oe=66CC7BFB"}, {"file_name": "Oculus_Portrait_en.png", "id": "1115593388914444", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031366_1115593392247777_1108929082473903627_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MHGSFtoVRAcQ7kNvgEmK-jO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDA4OPz8XsNjhWXCQuFYHQY92BG4erfrfFII9tJff3LQ&oe=66CC5204"}, {"file_name": "Oculus_Hero_en.png", "id": "871157030095923", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982668_871157033429256_6789488157395094913_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TOoKUKZp2OAQ7kNvgHVh-zC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnLsJTlEcS3FVcDc-6hVcA4CkszumA63gMceOD1lzA3g&oe=66CC75D0"}, {"file_name": "Oculus_Square_en.png", "id": "477446693254143", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_477446696587476_4659881486425096962_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i6F898SJc_0Q7kNvgETcYpq&_nc_ht=scontent.oculuscdn.com&oh=00_AYATU6yUYUVcVfdaYzYX490Xz0C2qCX-dtjL3VlKsDZphw&oe=66CC6649"}, {"file_name": "Oculus_Landscape_en.png", "id": "427087448520662", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984459_427087451853995_4215533920751611972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Lh8cbVZ8QwQ7kNvgFJPgTv&_nc_ht=scontent.oculuscdn.com&oh=00_