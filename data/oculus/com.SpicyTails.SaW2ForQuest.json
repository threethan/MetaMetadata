AHiZpFnQ&oe=6714D9C6"}, {"file_name": "Oculus_Portrait_sc.png", "id": "494727051932433", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974769_494727055265766_7172328752200092164_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a7mGo-4HpikQ7kNvgGkSGaD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC3LlyfAAFjBOjEyT_Ck4qYvS_BY6GHkY08XjjD8q80qQ&oe=6714EB3E"}, {"file_name": "Oculus_Logo_sc.png", "id": "471620827192922", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031545_471620830526255_4534585783299574611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yffp3oX2wkYQ7kNvgFyv6A_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBzBXwDPXuXilAHxC_siWwcz6gOeBj7eVPN0VE284OxuA&oe=6714F7D9"}, {"file_name": "Oculus_Hero_tc.png", "id": "424594388610036", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75485579_424594391943369_7165260809346619121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TYCp_K60eScQ7kNvgFAZNSD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEghyg3KV7WaA8VnXzr7TkSR_GE5wG2_7Yfg6adGgIXg&oe=6714EC6A"}]}, "id": "435274941083731", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u4e0e\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "4977285745675565", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974887_4977285749008898_4482133498831970937_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LWni38TAXzoQ7kNvgFwe7qC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC2nSm3eMyD-S_N2s4m0ZdcKD8Xvp9B0WPaZyrMRU7uJw&oe=6714FE7B"}, {"file_name": "Oculus_Portrait_en.png", "id": "1115593388914444", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031366_1115593392247777_1108929082473903627_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hZQEz2xmMWcQ7kNvgH-FlYg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4gwqxGnoBSQZkGQMESLUFfI_dL73XU6O3yaj3BDRVsQ&oe=6714D484"}, {"file_name": "Oculus_Hero_en.png", "id": "871157030095923", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982668_871157033429256_6789488157395094913_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mfO0tuDWkiMQ7kNvgEMLf3c&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDW4zsL_AG3RiHrOSLZxlwEru_nlvrwXPD25ku2SZxvyg&oe=6714F850"}, {"file_name": "Oculus_Square_en.png", "id": "477446693254143", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974841_477446696587476_4659881486425096962_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AEJeAEyBWMEQ7kNvgFLXTG9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSqZMnqX5EU8zD2D