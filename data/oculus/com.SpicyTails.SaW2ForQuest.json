png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i8gyVG1SOeoQ7kNvgFerSoI&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUGI8TReqYz-aomnt1_7R-r5TxC2T3yP4ChPvhrCrDlg&oe=66DC32C1"}, {"file_name": "Oculus_VRLandscape_tc.png", "id": "495203051865619", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75530717_495203055198952_2833762408757760645_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_sFV42Iv1oUQ7kNvgEd3Axy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkQ8Q5j_fyVNjSWJDOKMOl0r_k1bq3Ga4sFURNVQMnEQ&oe=66DC3527"}, {"file_name": "Oculus_Hero_tc.png", "id": "493992588655970", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_493992591989303_6448678946023260907_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oU83lLFM9Z0Q7kNvgE0_tH_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMIBmf26yagudNIaK3ARhY1M4QaQe_3yRB6AVGUpdRAw&oe=66DC3722"}, {"file_name": "Oculus_Landscape_tc.png", "id": "436327121017163", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299157_436327124350496_1480866125900628976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z58vvEjarsAQ7kNvgF0qx7b&_nc_ht=scontent.oculuscdn.com&oh=00_AYDzmf78qk3QQ31t8xMaa5cfYydAxdR7nwdSAhwVZnLwxA&oe=66DC3E7E"}]}, "id": "1482939075228787", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u8207\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original series has gotten together to bring you into the world of Spice and Wolf again for a second installment of VR animation! \nAnimation has evolved from \"watching\" to \"experiencing.\""}, {"images": {"nodes": [{"file_name": "Oculus_Icon_mobile.png", "id": "1064913614018317", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375083_1064913617351650_8414523728123351065_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CzxxYmdZMroQ7kNvgGePc_g&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoHmo2mpJXot3QJJ5wIYR5JRpZdbdaa99_T7JNzANq9g&oe=66DC2ED1"}, {"file_name": "Oculus_Landscape.png", "id": "888092388709773", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221313_888092392043106_3388339122400482554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yjC7AO4XCPcQ7kNvgH6xS9J&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGTOvPBnb3Ms_qxHb8W6672b8KFSWPz6mP0dAYBHVEZg&oe=66DC5208"}, {"file_name": "Oculus_VRLandscape.png", "id": "723262801706006", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982668_723262805039339_6616665206780105350_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PECGdm8EpfoQ7kNvgFkMkeZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCyC8JUqF3WvK3nK-iFX4JtgeaoPw7lot4uW0iFHeZaHg&oe=66DC2925"}, {"file_name": "Oculus_Hero.png", "id": "714465152559029", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367592_714465155892362_8370308211571510202_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sxt0OBAIk2cQ7kNvgEUIKRC&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8a_l54pC3HtwfN7iLAKTHSixKC8mqgHR9tmDUeRMQOQ&oe=66DC4A3D"}, {"file_name": "Oculus_Logo.png", "id": "430308521578157", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984462_430308524911490_8076409021473746060_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aL3lf84cMX4Q7kNvgH0IJIX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfvlO7NeXi3JSOk5Va1WwfJhIXLNyA1y0PGPXW-C3qrQ&oe=66DC3349"}, {"file_name": "Oculus_Square.png", "id": "352729222510361", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75488375_352729225843694_7453560219647756054_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dF6xJOxBhawQ7kNvgF0XIPt&_nc_ht=scontent.oculuscdn.com&oh=00_AYDp7l1ld_OTVjeFoI7a5yaGwI-TRf9FZL10JW5KPzQwdg&oe=66DC3846"}, {"file_name": "Oculus_Portrait.png", "id": "276501360504524", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196225_276501367171190_4751659361454104137_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0DtpfaBfPKkQ7kNvgEHltv6&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXG-WgWQ-rRr8MnSQdXzuqlUZxnICp0PlD7gCl66ogLA&oe=66DC41D3"}]}, "id": "1188574034893345", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SpiceandWolfVR2_PV_Oculus_Ja_tmb.png", "id": "470374587295640", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404374_470374590628973_6207792904719178023_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_lSuWW6GiNoQ7kNvgFwZUvC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmD31GqEemDBzGMVpbVlJxLLBxvF3kmwodo2ha7z912A&oe=66DC210A"}, "display_name": "\u72fc\u3068\u9999\u8f9b\u6599VR2", "keywords": [], "long_description": "\u72fc\u306e\u5316\u8eab\u3067\u3042\u308b\u5c11\u5973\u30db\u30ed\u3068\u51fa\u4f1a\u3063\u305f\u5143\u884c\u5546\u4eba\u306e\u30ed\u30ec\u30f3\u30b9\u306f\u3001\u65c5\u8def\u306e\u679c\u3066\u306b\u30db\u30ed\u3068\u7d50\u3070\u308c\u3001