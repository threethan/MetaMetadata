a&_nc_ohc=cMAiWfwZjCEQ7kNvgH8rWPT&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtwOlftUjT8Ce21wfRF_9AcCMGUhlsq3ufb54c8PcIGg&oe=66EC0CBE"}, {"file_name": "Oculus_Logo_sc.png", "id": "471620827192922", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_471620830526255_4534585783299574611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tEbr6IMYogQ7kNvgHNGpGe&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCWCuc4x4hVH2a1iF99jjk9X-yco1p3A5WCCttN3S29Q&oe=66EC1959"}, {"file_name": "Oculus_Hero_tc.png", "id": "424594388610036", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485579_424594391943369_7165260809346619121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YOGMaJHF3YgQ7kNvgHV8dgI&_nc_ht=scontent.oculuscdn.com&oh=00_AYChF5XvXkFJP9F_nF3UwGigoUbcoUUy28P6PCo62EnIHw&oe=66EC0DEA"}]}, "id": "435274941083731", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u72fc\u4e0e\u8f9b\u9999\u6599\uff36\uff32\uff12", "keywords": [], "long_description": "At the end of his journey with the wolf goddess Holo, former traveling merchant Lawrence settled down with her and opened a bathhouse.\nThe couple was blessed with an adorable daughter and an idyllic life.\nHowever, the beautiful wolves have a weakness for delicious meals and their food expenses are a source of headaches for Lawrence.\nOne day, as Lawrence is going about his fur side business to further fill the family's coffers, a slight incident occurs.\nTo further complicate things, Holo saunters in with quite the feast.\n\nThis is a VR Animation of Spice and Wolf: Spring Log, sequel to the original Spice and Wolf VR animation.\nThe game has a 30 minute story and a game mode where you can watch part of the anime alongside its characters in the style of Japanese paper street theater.\nA peaceful life in the bathhouse with wolfgirls awaits.\n", "short_description": "The team behind the original s