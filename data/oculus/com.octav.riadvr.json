2012_404346689300369_1924994508341083515_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_QAA8Z-3k6gQ7kNvgFIFGRv&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYDlHOp1715JgEaBLhYcyWft57sRoWwk_TFya7nBkef5_Q&oe=671A2F70"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Landscape (1).png", "id": "1450814318971629", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974448_1450814325638295_2703974088119855249_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=liM_9hIuucAQ7kNvgEnvYK6&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAOfIBcxMcz5SCAO_7gd74gVhWxj2D3VeGDy5p4H-Oung&oe=671A33F1"}, "display_name": "Riad VR", "keywords": ["immersive", "experience", "traditional", "visit", "Travel"], "long_description": "Travel to the enchanting world of a traditional Moroccan Riad with Riad VR! Step through the virtual doors and immerse yourself in the beauty and tranquility of this architectural masterpiece.\nDiscover the hidden details:\nExplore every corner: Wander through the riad's courtyards, admire the tilework and carvings, and soak in the peaceful atmosphere.\nUncover the secrets of design: Learn about the fascinating history and cultural significance of Moroccan architecture and design.\nExperience the ambiance: Feel the serenity of the riad's central fountain and the gentle sounds of traditional music.\n\nDownload Riad VR today and join on a virtual journey to the heart of Morocco!\n", "short_description": "Travel to the tranquility of a traditional Moroccan Riad in VR. Explore its intricate architecture, admire the beautiful tilework, and uncover the secrets of its design. A peaceful virtual journey to the heart of Morocco. \n"}]}, "developer_name": "Octav Studio", "developer_privacy_policy_url": "https://octav.studio/Privacy%20Policy%20for%20RiadVR.html", "developer_terms_of_service_url": null, "publisher_name": "Octav Studio", "support_website_url": null, "website_url": "https://octav.studio/", "category": null, "comfort_rating": "COMFORTABL