": "RVR_SS_4.png", "id": "404346685967036", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75622012_404346689300369_1924994508341083515_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PWU9MbKdcPcQ7kNvgFcdf4D&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAojEh1Kp4xcOLp52TLNesOl_oGAv6GJbD3TpaxrqCiWg&oe=67597770"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Landscape (1).png", "id": "1450814318971629", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974448_1450814325638295_2703974088119855249_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6egSL_x9fjUQ7kNvgHqPkYs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDd3RE6aM4FKmtSNYqjTrCJ9F78zfi_Ly0C_7E3luXtiA&oe=67597BF1"}, "display_name": "Riad VR", "keywords": ["immersive", "experience", "traditional", "visit", "Travel"], "long_description": "Travel to the enchanting world of a traditional Moroccan Riad with Riad VR! Step through the virtual doors and immerse yourself in the beauty and tranquility of this architectural masterpiece.\nDiscover the hidden details:\nExplore every corner: Wander through the riad's courtyards, admire the tilework and carvings, and soak in the peaceful atmosphere.\nUncover the secrets of design: Learn about the fascinating history and cultural significance of Moroccan architecture and design.\nExperience the ambiance: Feel the serenity of the riad's central fountain and the gentle sounds of traditional music.\n\nDownload Riad VR today and join on a virtual journey to the heart of Morocco!\n", "short_description": "Travel to the tranquility of a traditional Moroccan Riad in VR. Explore its intricate architecture, admire the beautiful tilework, and uncover the secrets of its design. A peaceful virtual journey to the heart of Morocco. \n"}]}, "developer_name": "Octav Studio", "developer_privacy_policy_url": "https://octav.studio/Privacy%20Policy%20for%20RiadVR.html", "developer_terms_of_service_url": null, "publisher_name": "Octav Studio", "support_website_url": null, "website_url": "https://octav.studio/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8750843311639674"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982508_2345965692405818_140923489887763068_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QIoaWTKtPtEQ7kNvgFpljWi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAhs1a4VhRc5cYg9v0ON9JIq2okRm5I3b0lWzVPTkBjRg&oe=6759961E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Riad VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Travel & Exploration", "id": "726368587961803"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1723104399, "lastRevision": {"nodes": [{"id": "8059969874060358", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8059969844060361", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "765294312204699"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "RVR_Hero.png", "id": 