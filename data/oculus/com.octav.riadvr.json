g", "id": "404346685967036", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/75622012_404346689300369_1924994508341083515_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_QAA8Z-3k6gQ7kNvgFIFGRv&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYDlHOp1715JgEaBLhYcyWft57sRoWwk_TFya7nBkef5_Q&oe=671A2F70"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art.png", "id": "435808435771867", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38982637_435808439105200_5495729857779919215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pzZUYHflk0YQ7kNvgG1dmo_&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDUzURizBMjFwKGydsEMopI-woUrIHVoU0Us_dw7AgzPA&oe=671A4692"}, "display_name": "Riad VR", "keywords": [], "long_description": "Experience the grandeur of a traditional Moroccan Riad in breathtaking virtual reality. Every element, from the intricate Zellij tilework to the detailed Nekch carvings, has been meticulously recreated to immerse you in Morocco's rich cultural heritage.\n \nExplore the winding corridors and uncover the secrets of traditional Moroccan design, where Islamic geometry beautifully intersects with Moorish elegance. Our immersive experience makes you feel as if you are truly standing in a Moroccan Riad.", "short_description": "Experience the grandeur of a traditional Moroccan Riad in breathtaking virtual reality. Every element, from the intricate Zellij tilework to the detailed Nekch carvings, has been meticulously recreated to immerse you in Morocco's rich cultural heritage."}]}, "developer_name": "Octav Studio", "developer_privacy_policy_url": "https://octav.studio/Privacy%20Policy%20for%20RiadVR.html", "developer_terms_of_service_url": null, "publisher_name": "Octav Studio", "support_website_url": null, "website_url": "https://octav.studio/game-studio", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362