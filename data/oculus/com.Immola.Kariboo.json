UoC4-LsP_YdcxOl88mil3ltiXkg&oe=66EFF8EA"}, {"file_name": "product_shot_3.png", "id": "408457942088705", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982556_408457945422038_746277000303009735_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a2be4fspHKMQ7kNvgFyUN3A&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATcxA7bn6o1cyInPXUejU41&oh=00_AYAnomYBRCYcVT6rQNW4I_q0Z3qsWX4-xWEwllBBlytN_A&oe=66EFE745"}, {"file_name": "product_shot_4.png", "id": "850662573759295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031624_850662577092628_5871337959828837092_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KdPw-9Q7YhoQ7kNvgG7fMxU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATcxA7bn6o1cyInPXUejU41&oh=00_AYB8byybafXyWqffkbudd6AehiqWvhse9MHs7jsY86V5jw&oe=66F0142C"}, {"file_name": "product_shot_5.png", "id": "1520316178545982", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_1520316181879315_8647811834743136746_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OGBss7q4imQQ7kNvgE2WyoN&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATcxA7bn6o1cyInPXUejU41&oh=00_AYDA6scO4KGysCt0fNNT7N7rlg_SXZUOApldSHEx2wDi9g&oe=66EFF47F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Kariboo_logo_simple.png", "id": "1574847693362664", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250459_1574847700029330_8693848230127420379_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o1SSzlbGAJUQ7kNvgG7Mmny&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATcxA7bn6o1cyInPXUejU41&oh=00_AYBLMZQu_2hxHBBdf1KMi4qa5djn6WKHhA7NwjJRmBmdkA&oe=66EFFEC9"}, "display_name": "Kariboo", "keywords": [], "long_description": "Dive into the world of Kariboo, the ultimate XR movie streaming app that brings the magic of cinema right into your living room\u2014or wherever you might be! With Kariboo, you're not just watching; you're experiencing movies in a way you never thought possible. From heart-pounding action scenes that unfold all around you to breathtaking landscapes that stretch as far as the eye can see, Kariboo takes you on a cinematic journey like no other.\n\nOur ever-exanding library is filled with a diverse selection of content that caters to all tastes. Whether you're a fan of spine-tingling horror, heart-pounding adventures, or thought-provoking independent cinema, Kariboo has something to captivate your senses and ignite your imagination.\n\nEasy to navigate and endlessly entertaining, Kariboo is your passport to an extraordinary virtual reality experience. Join us, and step into a world where stories come alive in the most immersive way possible. Welcome to Kariboo\u2014where every movie night is an adventure.", "short_description": "Dive into Kariboo, the movie streaming app that turns your living room into a cinema! \ud83c\udfa5\u2728Kariboo is your ticket to extraordinary entertainment with an ever-expanding movie library of independent films that ensures the adventure never ends. Easy to navigate and endlessly entertaining, Kariboo is your passport to an extraordinary XR experience. \ud83d\ude80\ud83c\udf7f"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kari.boo/privacy-policy", "developer_terms_of_service_url": "https://www.kari.boo/terms-of-service", "publisher_name": "Immola LLC", "support_website_url": null, "website_url": "https://www.kari.boo/", "category": "ENTERTAINMENT", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2777382702530830"}, {"id": "337573230800174"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "u