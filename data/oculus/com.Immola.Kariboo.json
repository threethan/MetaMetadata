3eov2QzMl5qip7Cf3ghBMfnpczg&oe=66EEA76A"}, {"file_name": "product_shot_3.png", "id": "408457942088705", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982556_408457945422038_746277000303009735_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a2be4fspHKMQ7kNvgEdW9-6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiREEUDgVaQ3za70zG7TKD9&oh=00_AYCjNXd3SaL4FjdJRPUpIWQ2cn5V3sp2MkEjI84DafZeIg&oe=66EE95C5"}, {"file_name": "product_shot_4.png", "id": "850662573759295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031624_850662577092628_5871337959828837092_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KdPw-9Q7YhoQ7kNvgEIPiU_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiREEUDgVaQ3za70zG7TKD9&oh=00_AYAsWu3WlrVjqsGY7FhZ7WAwBtAJeXqiRLTRuEX6_UORJw&oe=66EEC2AC"}, {"file_name": "product_shot_5.png", "id": "1520316178545982", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_1520316181879315_8647811834743136746_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9dyIOZIl7qMQ7kNvgF7e1js&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiREEUDgVaQ3za70zG7TKD9&oh=00_AYDXlOXpbf2T4JetIGQNBvZ1JjYULtiSyGO8FSYby3HtZg&oe=66EEA2FF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Kariboo_logo_simple.png", "id": "1574847693362664", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250459_1574847700029330_8693848230127420379_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-kWHaEz0EA4Q7kNvgH_VqNl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiREEUDgVaQ3za70zG7TKD9&oh=00_AYArBqFNmaucnqWPRAql4eEbBXMtDrJ5n7nbFByBj5c0Xw&oe=66EEAD49"}, "display_name": "Kariboo", "keywords": [], "long_description": "Dive into the world of Kariboo, the ultimate XR movie streaming app that brings the magic of cinema right into your living room\u2014or wherever you might be! With Kariboo, you're not just watching; you're experiencing movies in a way you never thought possible. From heart-pounding action scenes that unfold all around you to breathtaking landscapes that stretch as far as the eye can see, Kariboo takes you on a cinematic journey like no other.\n\nOur ever-exanding library is filled with a diverse selection of content that caters to all tastes. Whether you're a fan of spine-tingling horror, heart-pounding adventures, or thought-provoking independent cinema, Kariboo has something to captivate your senses and ignite your imagination.\n\nEasy to navigate and endlessly entertaining, Kariboo is your passport to an extraordinary virtual reality experience. Join us, and step into a world where stories come alive in the most immersive way possible. Welcome to Kariboo\u2014where every movie night is an adventure.", "short_description": "Dive into Kariboo, the movie streaming app that turns your living room into a cinema! \ud83c\udfa5\u2728Kariboo is your ticket to extraordinary entertainment with an ever-expanding movie library of independent films that ensures the adventure never ends. Easy to navigate and endlessly entertaining, Kariboo is your passport to an extraordinary XR experience. \ud83d\ude80\ud83c\udf7f"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kari.boo/privacy-policy", "developer_terms_of_service_url": "https://www.kari.boo/terms-of-service", "publisher_name": "Immola LLC", "support_website_url": null, "website_url": "https://www.kari.boo/", "category": "ENTERTAINMENT", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2777382702530830"}, {"id": "337573230800174"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "u