=KKZnxIQKkyQQ7kNvgEj7dXn&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYA9uXl3nNSJPU5QTLtgX3DZjcP_VXeQVX-_OeYN2Zc2tw&oe=677E77D6"}, {"file_name": "FS_meta-store_Screenshot-2.png", "id": "511716677124584", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974742_511716680457917_8742739686212066711_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=30v4vFHFjksQ7kNvgG5_uBq&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAnsA2sBFXDOtRSLT0rIDK8K_QU8PhPx_RjasNtym82dA&oe=677E79F9"}, {"file_name": "FS_meta-store_Screenshot-5.png", "id": "489417783071679", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974462_489417786405012_4060843803796523374_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XxDjVbwb3wIQ7kNvgGaaQsw&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYA0FB6c-sD1r6Z_AihzjyIb8-EfB8otxlCwGbLL6Ww98Q&oe=677E7768"}, {"file_name": "FS_meta-store_Screenshot-3.png", "id": "416597883986416", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38974742_416597887319749_2922306019326442412_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T0ayyD9EAa0Q7kNvgFqV8DO&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYD1F1do2EAXQcnDQ41asLP9Dg-buDd6E8vbeHPWtSWSug&oe=677E69A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FS_meta-store_Trailer-Cover-Image.png", "id": "6477503358931451", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/75222937_6477503362264784_6203451220098661937_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E4Xm2pe7ABAQ7kNvgGo-z0V&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCbagBjFTU39RISsLkrWLHiYj1HBbaJvO8xAY3OPjH7yg&oe=677E66F1"}, "display_name": "Flipside Studio", "keywords": ["animation", "mocap", "recording", "cartoon", "streaming"], "long_description": "Turn any room into a stage with Flipside Studio!\n\nPacked with features, Flipside Studio is a virtual production studio that allows creators to use VR to make real-time animated shows for Twitch, YouTube, TikTok, and more.\n\nShare your live-streamed or recorded adventure, comedy, family entertainment or talk show series\u2026Your only limit is your imagination!\n- Choose from pre-loaded characters, sets, and 100's of props\n- Create characters in-app using Ready Player Me\n- Use show tools like cameras, teleprompters, monitors, slideshows, and more\n- Capture actor and prop movement as full spatial motion capture recordings that can be seen from any angle\n- Create on your own or collaborate remotely in-real time with folks world-wide\n- Stream online, on social, Zoom, and more with the free Flipside Broadcaster (PC) companion app\n- Customize characters, sets, props and effects with the free Unity plug-in, Flipside Creator Tools\n\nDownload Flipside Studio today. Visit www.flipsidexr.com for free tools and tips.\n", "short_description": "Turn any room into a stage with Flipside Studio!\n\nPacked with features, Flipside Studio allows creators to use VR to make real-time animated shows for Twitch, TikTok, YouTube and more.\n\n- Work solo or remote with others in real-time\n- Choose from pre-loaded characters, sets and 100's of props\n- Customize characters with Ready Player Me\n- Use show tools like cameras, teleprompters, monitors, slideshows and more\n\nDownload Flipside Studio today. Visit www.flipsidexr.com for free tools and tips."}]}, "developer_name": "Flipside XR", "developer_privacy_policy_url": "https://www.flipsidexr.com/privacy", "developer_terms_of_service_url": "https://www.flipsidexr.com/terms", "publisher_name": "Flipside XR", "support_website_url": "https://www.flipsidexr.com/support", "website_url": "https://www.flipsidexr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "PRODUCTIVITY"], "has_in_app_ads": null, "intern