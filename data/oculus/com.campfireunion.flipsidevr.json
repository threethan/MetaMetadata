ttps://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974742_511716680457917_8742739686212066711_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wQSUi4qzqX0Q7kNvgHuwA3u&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDGOIDjExEmzj-5eb5iXU_AuNP3-d1Y0_712ATlz5EGuQ&oe=67559B79"}, {"file_name": "FS_meta-store_Screenshot-5.png", "id": "489417783071679", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974462_489417786405012_4060843803796523374_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Do2d0VguwdEQ7kNvgHF8IRy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5ehsYnz4PNL1xHYq_6BtSk_zRh62q-LOuF0yHwSCE2g&oe=675598E8"}, {"file_name": "FS_meta-store_Screenshot-3.png", "id": "416597883986416", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974742_416597887319749_2922306019326442412_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NNVPLx3_1S8Q7kNvgFc7iy6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAekX-Y5DJ0IfVbI5P3lUNX3eKOeIxrBVcIRsqL9kUsDQ&oe=67558B24"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FS_meta-store_Trailer-Cover-Image.png", "id": "6477503358931451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222937_6477503362264784_6203451220098661937_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u7Tz7zaFHl4Q7kNvgHWyiHr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB305a1EZ4oX3Y82jhAjSSCIRsiJCYFpX-zGrOLmV22tQ&oe=67558871"}, "display_name": "Flipside Studio", "keywords": ["animation", "mocap", "recording", "cartoon", "streaming"], "long_description": "Turn any room into a stage with Flipside Studio!\n\nPacked with features, Flipside Studio is a virtual production studio that allows creators to use VR to make real-time animated shows for Twitch, YouTube, TikTok, and more.\n\nShare your live-streamed or recorded adventure, comedy, family entertainment or talk show series\u2026Your only limit is your imagination!\n- Choose from pre-loaded characters, sets, and 100's of props\n- Create characters in-app using Ready Player Me\n- Use show tools like cameras, teleprompters, monitors, slideshows, and more\n- Capture actor and prop movement as full spatial motion capture recordings that can be seen from any angle\n- Create on your own or collaborate remotely in-real time with folks world-wide\n- Stream online, on social, Zoom, and more with the free Flipside Broadcaster (PC) companion app\n- Customize characters, sets, props and effects with the free Unity plug-in, Flipside Creator Tools\n\nDownload Flipside Studio today. Visit www.flipsidexr.com for free tools and tips.\n", "short_description": "Turn any room into a stage with Flipside Studio!\n\nPacked with features, Flipside Studio allows creators to use VR to make real-time animated shows for Twitch, TikTok, YouTube and more.\n\n- Work solo or remote with others in real-time\n- Choose from pre-loaded characters, sets and 100's of props\n- Customize characters with Ready Player Me\n- Use show tools like cameras, teleprompters, monitors, slideshows and more\n\nDownload Flipside Studio today. Visit www.flipsidexr.com for free tools and tips."}]}, "developer_name": "Flipside XR", "developer_privacy_policy_url": "https://www.flipsidexr.com/privacy", "developer_terms_of_service_url": "https://www.flipsidexr.com/terms", "publisher_name": "Flipside XR", "support_website_url": "https://www.flipsidexr.com/support", "website_url": "https://www.flipsidexr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH