c_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDkGgChax7Qd6u7t6XqAl_82tcELhm-Aa-mzChp_t8ilw&oe=676178D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FS_Cover-Landscape.png", "id": "948055656716612", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001731_948055660049945_3697445677810051434_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=007VR1WMbBoQ7kNvgFJtkm7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABcSM0uqn2YSSQlQlqGiyn_720KbVaGZk41tiYB8j72g&oe=67614D24"}, "display_name": "Flipside", "keywords": ["animation", "mocap", "recording", "metaverse", "social"], "long_description": "Flipside is the metaverse social media platform for next-gen creators and their fans.\n\nWatch a steady stream of spatial content, which you can like, subscribe, share, and even remix. Connect with friends over multiplayer and watch together!\n\nNext-gen creators make spatial recordings using Flipside\u2019s built-in virtual TV studio, then share them to your channel and build a fanbase of subscribers.\n\n# Highlights:\n\n- Browse, watch, like, share and subscribe to other Flipside creators\n- Remix other creators' posts, where you can replace characters with yourself\n- Send direct messages to connect with your friends and share content\n- Record full 3D spatial recordings, including motion capture, voice, props, music and more\n- An ever-growing catalog of built-in characters, props and sets\n- Generate custom characters with built-in Ready Player Me integration\n- Generate teleprompter scripts and custom sets using AI tools\n- Show tools including cameras, camera switcher, teleprompters, slideshow, and more\n- Audio controller to add music and special effects, including a built-in audio library or import your own\n- Use our companion Flipside Broadcaster app for PC to capture 2D content for other social platforms\n- Use our Flipside Creator Tools plugin for Unity to import your own custom characters, props, and sets\n- And too many features to list them all\n\nDownload Flipside today!", "short_description": "Flipside is the metaverse social media platform for next-gen creators and their fans.\n\nWatch a steady stream of spatial content, which you can like, subscribe, share, and even remix. Connect with friends over multiplayer and watch together!\n\nNext-gen creators make spatial recordings using Flipside\u2019s built-in virtual TV studio, then share them to your channel and build a fanbase of subscribers.\n\nDownload Flipside today!"}]}, "developer_name": "Flipside XR", "developer_privacy_policy_url": "https://www.flipsidexr.com/privacy", "developer_terms_of_service_url": "https://www.flipsidexr.com/terms", "publisher_name": "Flipside XR", "support_website_url": "https://www.flipsidexr.com/support", "website_url": "https://www.flipsidexr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}, {"id": "1819021644882647"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "PRODUCTIVITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "6915404768583911"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031407_537194542532532_6599176511050037141_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TZDpaWT98gcQ7kNvgF6FrMX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjsPFOVewP_Gl0x7_78kQbGOIyJk8oHyYkFlgZSMD_tQ&oe=67617DBE"}, "is_conc