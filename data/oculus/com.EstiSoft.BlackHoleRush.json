SbJ7eV8Q5OYTyqOWQ&oe=67126340"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Ekran g\u00f6r\u00fcnt\u00fcs\u00fc 2024-09-28 035432.png", "id": "1127929185363924", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75462204_1127929188697257_605028384963660461_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QwDvL48-DHkQ7kNvgFxq37Q&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBzJQckpq1s8HAE6IVMYflxRF_9auczZ3CZM37-CQ4Z8Q&oe=67123AD2"}, "display_name": "Black Hole Rush", "keywords": ["HyperCasual", "Casual", "Comfort", "Satisfy", "Enemy"], "long_description": "In Black Hole Rush, the universe is on the brink of collapse as relentless waves of enemies seek to destroy everything in their path. Your mission is to stop them by harnessing the immense power of a black hole. Using VR controls, players grab, throw, and launch enemies into the ever-hungry void, banishing them from existence. The game combines intense action with strategic positioning as players must manage increasing enemy numbers and more powerful foes in later stages. With immersive VR gameplay, players feel the gravity of each decision, using their environment and quick thinking to manipulate the battlefield. Black holes are not only your weapon but also your greatest ally. However, beware, as one wrong move could send you spiraling into the abyss as well. Each level introduces new enemy types, abilities, and environmental challenges, making for a constantly evolving experience that keeps players on edge. Will you have what it takes to master the power of the black hole and save the galaxy from total annihilation?", "short_description": "Black Hole Rush is a thrilling VR game where you must defend the universe from waves of enemies by sending them spiraling into a massive black hole. Utilize your skills and strategies to grab, push, or launch enemies into the void, all while avoiding their attacks. As the levels progress, the challenges become more intense, and only the quickest reactions can save the galaxy from destruction. Dive into the immersive chaos and control the power of the black hole!"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/black-hole-rush", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8539843939407405"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "880344260351215"}]}, "baseline_offer": {"id": "880344260351215"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727702941, "status": "PUBLISHED", "id": "880344260351215"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8539887972736335", "version": "1"}, "id": "539458378825110", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8539843916074074", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8539887972736335"}, "rel