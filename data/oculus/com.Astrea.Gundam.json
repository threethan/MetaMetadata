0035_494010240909278079_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WhbHzCtiX4cQ7kNvgH00lvR&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBascmOTZRTCyf5HLBeA7B5PlqIC4arBcm0FHR0JzXyRg&oe=6756DBE4"}, {"file_name": "GVR_Screenshot5.png", "id": "768536385222242", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75375761_768536388555575_7786747098689683368_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uMYkl65ObUUQ7kNvgFLAYkb&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC3yil8kkT7fm3jwrKnzxwQ-Q3_mURjd9BWDHqPvB9LYQ&oe=6756D7E3"}, {"file_name": "GVR_Screenshot3.png", "id": "725761182717798", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974869_725761186051131_5440165161738549431_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GJtcjpohJAAQ7kNvgHesuWb&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC3L-cbnfj6jwidk-9j2scaKVG05upx_VHpIAFXgB9EbQ&oe=6756C411"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "1125893658680348", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974764_1125893662013681_3309252748776832022_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CtaUxuoLwBIQ7kNvgFwDPf8&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCYZOCWUAUyi2hL0ZdXFNaP_LHk-Gc8PDM-obesZ1f_yQ&oe=6756D557"}, "display_name": "Mobile Suit Gundam: Silver Phantom", "keywords": ["mecha", "anime", "movie", "robot", "space"], "long_description": "Embark on an epic adventure with \"Mobile Suit Gundam: Silver Phantom,\" a groundbreaking VR experience soon available on the Meta Quest Store. \n\n{425371483731297}\n\n# THE FIRST-EVER INTERACTIVE & CINEMATIC ANIME\n\n{988448559389026}\n\nThis feature-length interactive cinematic story tailored for Gundam enthusiasts, anime fans, and VR lovers alike, will offer a unique opportunity to dive deep into the heart of one of Japan's most iconic anime universes. \n\n{2109721869409581}\n\nSet in the Universal Century, this immersive journey places you at the center of an interactive cinematic experience like no other. As the main character of your own story, you'll be able to explore the universe of Mobile Suit Gundam like never before.\n\n{758897363079117}\n\n# ADD-ONS: TWO EXCLUSIVE MIXED REALITY FEATURES\n\n**Battle mode** - Grab your Gundam and unleash its powers to defeat your enemies through multiple levels. Dodge enemies, defend yourself, shoot missiles and master your Gundam\u2019s Beam Saber! \n\n{472590441922879}\n\n**Gallery mode** - Explore a wide variety of life-sized Mobile Suits and discover them from every angle, as if they were there in real life for the first time. \n\n{425912543734933}\n\nWishlist today and prepare to discover what it truly means to be a hero in the Universal Century. Your Gundam awaits!", "short_description": "Embark on an epic adventure with \"Mobile Suit Gundam: Silver Phantom,\" a groundbreaking VR experience soon available on the Meta Quest Store. \n\nThis feature-length interactive cinematic story tailored for Gundam enthusiasts, anime fans, and VR lovers alike, will offer a unique opportunity to dive deep into the heart of one of Japan's most iconic anime universes. \n\nWishlist today and prepare to discover what it truly means to be a hero in the Universal Century. Your Gundam awaits!"}]}, "developer_name": "Bandai Namco Filmworks, Atlas V, Albyon", "developer_privacy_policy_url": "https://astreaimmersive.io/mobile-suit-gundam-silver-phantom-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://www.gundamvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEM