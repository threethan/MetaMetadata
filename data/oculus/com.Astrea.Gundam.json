7475_3138251809528337775_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10k2bGGDFX8Q7kNvgHrbvHo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDm2tvNDnlmm5khJQrjkPUow7ZBeyYUZ70uaIYssb7-wA&oe=6714F525"}, {"file_name": "GVR_Screenshot3.png", "id": "725761182717798", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_725761186051131_5440165161738549431_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9EXQU8a7bXQQ7kNvgFok_-U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDT2_cCrlFBPlYO2ANNRZgXmQY26SEGkeqLcW_ResP91w&oe=6714D911"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "1125893658680348", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974764_1125893662013681_3309252748776832022_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YXptgdToHeMQ7kNvgFMhp7e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3Jdg8RN2rEV1I2xHF8O9ZRGNLauQj_k0qQk9O5_dVig&oe=6714EA57"}, "display_name": "Mobile Suit Gundam: Silver Phantom", "keywords": ["mecha", "anime", "movie", "robot", "space"], "long_description": "Embark on an epic adventure with \"Mobile Suit Gundam: Silver Phantom,\" a groundbreaking VR experience now available on the Meta Quest Store. \n\n# THE FIRST-EVER INTERACTIVE & CINEMATIC ANIME\n\nThis feature-length interactive cinematic story tailored for Gundam enthusiasts, anime fans, and VR lovers alike, will offer a unique opportunity to dive deep into the heart of one of Japan's most iconic anime universes. \n\n{988448559389026}\n\nSet in the Universal Century, this immersive journey places you at the center of an interactive cinematic experience like no other. As the main character of your own story, you'll be able to explore the universe of Mobile Suit Gundam like never before.\n\n{758897363079117}\n\n# ADD-ONS: TWO EXCLUSIVE MIXED REALITY FEATURES\n\n**Battle mode** - Grab your Gundam and unleash its powers to defeat your enemies through multiple levels. Dodge enemies, defend yourself, shoot missiles and master your Gundam\u2019s Beam Saber! \n\n{472590441922879}\n\n**Gallery mode** - Explore a wide variety of life-sized Mobile Suits and discover them from every angle, as if they were there in real life for the first time. \n\n{425912543734933}\n\nGet it today and prepare to discover what it truly means to be a hero in the Universal Century. Your Gundam awaits!", "short_description": "Embark on an epic adventure with \"Mobile Suit Gundam: Silver Phantom,\" a groundbreaking VR experience now available on the Meta Quest Store. \n\nThis feature-length interactive cinematic story tailored for Gundam enthusiasts, anime fans, and VR lovers alike, will offer a unique opportunity to dive deep into the heart of one of Japan's most iconic anime universes. \n\nGet it today and prepare to discover what it truly means to be a hero in the Universal Century. Your Gundam awaits!"}]}, "developer_name": "Bandai Namco Filmworks, Atlas V, Albyon", "developer_privacy_policy_url": "https://astreaimmersive.io/mobile-suit-gundam-silver-phantom-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://www.gundamvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2777382702530830"}, {"id": "842287169851443"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "83861632247