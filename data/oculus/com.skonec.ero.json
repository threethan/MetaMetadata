58\uc758 \uc758\uacac\uc744 \uae30\ub2e4\ub9ac\uaca0\uc2b5\ub2c8\ub2e4.\n\ub354 \ub9ce\uc740 \uc5d0\ud53c\uc18c\ub4dc\ub4e4\uc774 \uc5ec\ub7ec\ubd84\uc744 \ucc3e\uc544\uac08 \uac83\uc785\ub2c8\ub2e4.", "short_description": "\uacf5\ud3ec \ubc29\ud0c8\ucd9cVR \uac8c\uc784 (\uc815\uc2dd\ubc84\uc804\uc744 \uc704\ud55c \ud2f0\uc800)\n-\ud63c\uc790\uc11c \ud50c\ub808\uc774 \ud558\uac70\ub098 \uce5c\uad6c\ub97c \ucd08\ub300\ud558\uc5ec \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4"}, {"images": {"nodes": [{"file_name": "Portrait.png", "id": "3403127939936935", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974527_3403127943270268_5982631016592496092_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L2M6xFIwgy0Q7kNvgGjBr3C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCd7qJupkmbJSe56mrjqElcqXJFBoYmuULEoLV5BonyTg&oe=67486078"}, {"file_name": "Landscape.png", "id": "927076248559542", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974773_927076251892875_8940624378489886719_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nYvcg7h-2zUQ7kNvgHCutAg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAPeXdLcLig563r62zQy_EiPcKxmczDUaVKqwtXmWGqaA&oe=67486BDF"}, {"file_name": "Icon.png", "id": "790868906088752", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974859_790868909422085_8366478809179753009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EQprRw6qOyAQ7kNvgE4xvlT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClimiNAU1PeItCh-bHKqfIdn_nS7CSbUQ3EfuUxg4-sA&oe=6748714C"}, {"file_name": "Logo_Escape Room Online.png", "id": "559850699513050", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982516_559850702846383_9221648333595865513_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3uxs85WvXXAQ7kNvgH3KTeY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAB