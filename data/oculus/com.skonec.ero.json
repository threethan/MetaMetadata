1-25/38974809_283136717528089_4812108343838447054_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RSiwql_s798Q7kNvgE08QnU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRGE1QnCDG1QMc0bCF5U9TtB3y2M2jzSaOwtEvGuXXDg&oe=66F690AC"}]}, "id": "1004370233906261", "locale": "en_US", "screenshots": [{"file_name": "screenshot_03.png", "id": "6109183169165445", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974826_6109183172498778_1980131108077743951_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R9jPAjLVfcQQ7kNvgHnAiQv&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMnpT9ReaFOISP14iD9PwcTUw2CJPzhaQG98p99UDepg&oe=66F68D71"}, {"file_name": "screenshot_01.png", "id": "1642138399571507", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035301_1642138402904840_6244483486417544388_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W0v5beb9qVAQ7kNvgHIbpyM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKAw6Nvy9fw62dz1t5QrYeqdveg5g6qNS0MqJzKqef6w&oe=66F68D61"}, {"file_name": "screenshot_05.png", "id": "1575484332961851", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974624_1575484336295184_3731873507937996818_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ILcQ1VGsOP0Q7kNvgE-UOun&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBa_PtCVSVgY15dwzVKSGM3CDjvREwT_k6cp1h_TUo-Q&oe=66F6A1DC"}, {"file_name": "screenshot_04.png", "id": "1386469365541116", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974891_1386469368874449_2457219569148898534_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jfvwlpwOHWwQ7kNvgGkcXuW&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_JcR6tQ_15B1LbsLKTY-IN07OV5O9tcihlZO6pVB71Q&oe=66F69F8F"}, {"file_name": "screenshot_02.png", "id": "1305994510334499", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974852_1305994513667832_1553642627453722891_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CknUp8tGXFoQ7kNvgH3InWm&_nc_ht=scontent.oculuscdn.com&oh=00_AYClFth4A_2QuJJYTXGksVW8eJ0Dj3fq30KhO_r0czPMBQ&oe=66F69E1D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_image.png", "id": "974260513607698", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031561_974260520274364_8095202081499740686_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J3OMM0Reo04Q7kNvgFa0402&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfy4-6SB_0z5P4IExaRjdG8w4PyfPQXSPRikq4ZLR2og&oe=66F68208"}, "display_name": "Escape Room Online", "keywords": [], "long_description": "There is only one purpose, Open the door and escape!\n\nThe cursed doll's room.\nEverything in the room is a hint.\nLike a tightly closed  child's heart,\nthis room is locked by itself and cannot be opened anymore.\n\n - How can I enjoy the game more fun?\nIt's fun alone, but if you don't like the game being difficult or scary, invite a friend.\nEven difficult puzzles are overcome together by sharing each other's thoughts and putting their heads together through voice chat.\nWork with up to 4 people to find and solve hints!\n\n - I want to play a game with my friend!\nFirst of all, I am contacting a friend who will play with me after a long time. \nIf the relationship is awkward, try [Buy for a friend].\n\nPlease tell your friend [room code] who bought the game after making the room.\nFriends who are invited as guests simply enter the room code and prepare.\nDone! Play the game [start] and enjoy room escape with your friends.\n\n - I want to play with my friends who live in other countries.\nIt has been updated so that you can play with friends from other countries. Please enjoy!\n\nWe look forward to your feedback.\nWe will gradually improve our functions by collecting various opinions, and in the official version, we will visit you with more episodes.", "short_description": "Horror Room Escape VR Game (Teaser for full game)\n - You can play alone or invite friends to enjoy it"}, {"images": {"nodes": [{"file_name": "mini_Landscape.png", "id": "1600719224081286", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_1600719227414619_8259530618883852021_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LKB5ceB29nAQ7kNvgFAwyj9&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmdFnofqSYvLlPKFV54Guk-czNXvTcfaQw7uhcoke4KQ&oe=66F6922B"}, {"file_name": "HeroCover.png", "id": "1381759549053127", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003238_1381759552386460_2151333439904320506_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MjnVYPKwL2AQ7kNvgFAfBYt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCw6R5Z7BXJGGiVr6CfjED2vgPA25_D7pLGygrPlMpmg&oe=66F6A9F8"}, {"file_name": "Icon.png", "id": "1311298769465608", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230040_1311298772798941_2168339518688400017_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=exWGqP2haLMQ7kNvgHTqzKY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbIt6ozOkTOpLGTy_8ytP2Vj3a-1VBrVbyAQ6JZ_HKuQ&oe=66F6B4D7"}, {"file_name": "Logo_Escape Room Online.png", "id": "1267524437205605", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982516_1267524440538938_3734239516573941978_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d2vLMxI9fxMQ7kNvgFGpz2z&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsw_fVriydNmPdhZiRclHCA0CK2tHrgOprXrpmw9Z8Dg&oe=66F6A488"}, {"file_name": "Cover_image.png", "id": "807892697398123", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974624_807892700731456_5090504890972949280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9VGSuYgUnMQ7kNvgEuqqip&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyHaDa6kcHGhlXVnKgX5iNtpYo8oAQjSehOHce2bGWGQ&oe=66F6852F"}, {"file_name": "Portrait.png", "id": "801263777992104", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982565_801263784658770_4111985462776797695_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z6bzLJYz7hcQ7kNvgGf1yNe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZtj-eFzxQtvyDCo__S-T5obrw_YbBeRrL2tt2XeE-pA&oe=66F695E3"}, {"file_name": "Square.png", "id": "643976364424839", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566698_643976367758172_2883169784107415272_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFSGGa7L50kQ7kNvgHJpJwi&_nc_ht=scontent.oculuscdn.com&oh=00_AYCcK6AeLHWQeI77hO0ZHFXgNWyn50euftzN9FKlVkUz0g&oe=66F69623"}]}, "id": "998250691206500", "locale": "ko_KR", "screenshots": [{"file_name": "screenshot_03.png", "id": "1643980849397822", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334054_1643980852731155_1801451258457195245_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jdtOxHaMtVEQ7kNvgEKBwYI&_nc_ht=scontent.oculuscdn.com&oh=00_AYAe-XewSn3C_OCUCX8mCv_HuLuGiGvYUzcXu4HxonlFYQ&oe=66F68B45"}, {"file_name": "screenshot_04.png", "id": "1013451249637989", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974661_1013451252971322_7149821529924810793_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qAjauIx0xrcQ7kNvgGxQWRC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqCgSvOZmfHfz02PgdoGbMp3N8JUpYScvpCeO6wbrp0A&oe=66F6865B"}, {"file_name": "screenshot_05.png", "id": "918954582739694", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982716_918954586073027_3066611866280301347_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bVPcZ90aM_MQ7kNvgGV2Xpy&_nc_ht=scontent.oculuscdn.com&oh=00_AYB67GEP1ScavX3c7RuUy6rRoY0SVw6OrYe9KwTLyixTLw&oe=66F69C7C"}, {"file_name": "screenshot_01.png", "id": "624075745984417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974732_624075749317750_3104111007046430173_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dvmv-ZbsmI0Q7kNvgHW4ho_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAp1CSgUjhyYcO3QF2PZRpdOF38YSJJ5tDYys1faPlkng&oe=66F697A8"}, {"file_name": "screenshot_02.png", "id": "255320403658184", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974852_255320406991517_7897575683643396095_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FuppUt3rLpUQ7kNvgFYH5YH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJr-rVK3NXXnvWI4Ldy_G8OUUgf14D1JB5raE5jW5H8A&oe=66F6A8B4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_image.png", "id": "835637507428998", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_835637510762331_6004386185149400704_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h61_jXPMtQoQ7kNvgExdeSZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCL9bHhp7xgZDTv5snJfns13AqZOOR5ZI9jBsiy7-8Qgw&oe=66F68A28"}, "display_name": "Escape Room Online", "keywords": [], "long_description": "\ub2e8 \ud558\ub098\uc758 \ubaa9\uc801, \ubb38\uc744 \uc5f4\uace0 \ud0c8\ucd9c\ud558\ub77c! \n\n\uc800\uc8fc\ubc1b\uc740 \uc778\ud615\uc758 \ubc29. \n\ubc29 \uc548\uc5d0 \ubaa8\ub4e0 \uac83\uc774 \ub2e8\uc11c\uac00 \ub41c\ub2e4. \n\uc2dc\uac04 \ub0b4\uc5d0 \ud0c8\ucd9c\ud558\uc9c0 \ubabb\ud558\uba74 \ub2eb\ud600\ubc84\ub9b0 \uc544\uc774\uc758 \ub9c8\uc74c\ucc98\ub7fc \uc774 \ubc29\ub3c4 \uc2a4\uc2a4\ub85c \uad73\uac8c \uc7a0\uaca8\ubc84\ub824 \ub354 \uc774\uc0c1 \uc5f4\ub9ac\uc9c0 \uc54a\ub294\ub2e4. \n\n - \uac8c\uc784\uc744 \ub354\uc6b1 \uc7ac\ubbf8\uc788\uac8c \uc990\uae30\ub824\uba74?\n\n\ud63c\uc790\uc11c\ub3c4 \uc990\uac81\uc9c0\ub9cc \uac8c\uc784\uc774 \uc5b4\ub835\uac70\ub098 \ubb34\uc11c\uc6b4 \uac83\uc774 \uc2eb\ub2e4\uba74 \uce5c\uad6c\ub97c \ucd08\ub300\ud574 \ubcf4\uc138\uc694.\n\uc5b4\ub824\uc6b4 \ud37c\uc990\ub3c4 \ubcf4\uc774\uc2a4 \ucc57\uc744 \ud1b5\ud574 \uc11c\ub85c\uc758 \uc0dd\uac01\uc744 \uacf5\uc720\ud558\uace0 \uba38\ub9ac\ub97c \ub9de\ub300\uc5b4 \ud568\uaed8 \uadf9\ubcf5\ud569\ub2c8\ub2e4.\n\ucd5c\ub300 4\uc778\uae4c\uc9c0 \ud611\ub825\ud558\uc5ec \ud78c\ud2b8\ub97c \ucc3e\uc544 \ud574\uacb0\ud574 \ubcf4\uc138\uc694!\n\n - \uce5c\uad6c\uc640 \ud568\uaed8 \uac8c\uc784\uc744 \ud558\uace0 \uc2f6\uc5b4\uc694!\n\n\uc6b0\uc120 \ud50c\ub808\uc774\ub97c \ud568\uaed8 \ud560 \uce5c\uad6c\uc5d0\uac8c \uc624\ub79c\ub9cc\uc5d0 \uc5f0\ub77d\ud569\ub2c8\ub2e4. \n\uad00\uacc4\uac00 \uc5b4\uc0c9\ud558\ub2e4\uba74 [\uce5c\uad6c\uc5d0\uac8c \uc120\ubb3c\ud558\uae30]\ub97c \ud574\ubcf4\uc138\uc694.\n\n\uac8c\uc784\uc744 \uad6c\uc785\ud55c \uce5c\uad6c\uc5d0\uac8c \ubc29\uc744 \ub9cc\ub4e0 \ud6c4\uc5d0 [\ubc29 \ucf54\ub4dc]\ub97c \uc54c\ub824\uc8fc\uc138\uc694.\n\uac8c\uc2a4\ud2b8\ub85c \ucd08\ub300\ub41c \uce5c\uad6c\ub294 [\ubc29 \ucf54\ub4dc]\ub97c \uc785\ub825\ud558\uc5ec [\uc900\ube44]\ub9cc \ud558\uba74 \ub429\ub2c8\ub2e4.\n\ub05d\ub0ac\uc2b5\ub2c8\ub2e4! \uac8c\uc784\uc744 [\uc2dc\uc791]\ud558\uc5ec \uce5c\uad6c\uc640 \ud568\uaed8 \ubc29\ud0c8\ucd9c\uc744 \uc990\uae30\uc138\uc694.\n\n - \ub2e4\ub978 \ub098\ub77c\uc758 \uce5c\uad6c\ub4e4\uacfc\ub3c4 \ud568\uaed8 \ud50c\ub808\uc774\ud558\uace0 \uc2f6\uc5b4\uc694.\n\n\ub2e4\ub978 \ub098\ub77c\uc758 \uce5c\uad6c\ub4e4\uacfc\ub3c4 \uac19\uc774 \ud50c\ub808\uc774\ud560 \uc218 \uc788\ub3c4\ub85d \uc5c5\ub370\uc774\ud2b8\ub418\uc5c8\uc2b5\ub2c8\ub2e4. \ud568\uaed8 \uc990\uaca8\uc8fc\uc138\uc694!\n\n\uadc0\ud558\uc758 \uc758\uacac\uc744 \uae30\ub2e4\ub9ac\uaca0\uc2b5\ub2c8\ub2e4. \n\ub2e4\uc591\ud55c \uc758\uacac\uc744 \uc218\ub834\ud574 \uc810\ucc28 \uae30\ub2a5\uc744 \uac1c\uc120\ud574 \ub098\uac08 \uc608\uc815\uc774\uba70, \uc815\uc2dd \ubc84\uc804\uc5d0\uc11c\ub294 \ub354 \ub9ce\uc740 \uc5d0\ud53c\uc18c\ub4dc\ub85c \uc5ec\ub7ec\ubd84\uc744 \ucc3e\uc544\ubd59\uaca0\uc2b5\ub2c8\ub2e4.", "short_description": "\uacf5\ud3ec \ubc29\ud0c8\ucd9cVR \uac8c\uc784 (\uc815\uc2dd\ubc84\uc804\uc744 \uc704\ud55c \ud2f0\uc800)\n-\ud63c\uc790\uc11c \ud50c\ub808\uc774 \ud558\uac70\ub098 \uce5c\uad6c\ub97c \ucd08\ub300\ud558\uc5ec \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4"}]}, "developer_name": "Skonec Entertainment", "developer_privacy_policy_url": "https://vrsquare.skonec.com/privacy%20policy%20Skonec_01.htm", "developer_terms_of_service_url": null, "publisher_name": "Skonec Entertainment", "support_website_url": null, "website_url": "http://www.skonec.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "