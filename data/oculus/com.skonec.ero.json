2739694", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982716_918954586073027_3066611866280301347_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LphReBQo1z4Q7kNvgEshyG8&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDHrtMRzcxLN0kAr_1fpVmb71Lfflp6XMdjt-H59G02gA&oe=675193FC"}, {"file_name": "screenshot_01.png", "id": "624075745984417", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974732_624075749317750_3104111007046430173_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ohf6vXvo38Q7kNvgF7tP20&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDkF0QSNUU_URKdlmFxD233VhbYebMl6SvGUghe1Un5kA&oe=67518F28"}, {"file_name": "screenshot_02.png", "id": "255320403658184", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974852_255320406991517_7897575683643396095_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gycRqPxJVSAQ7kNvgFpv_VK&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCc1iL850EL7MssFN6hzuPIXeCI3AR2Be5Fvvi-3aQafw&oe=6751A034"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_image.png", "id": "168984949461724", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982719_168984952795057_2362559546396233548_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pxB79I8AM98Q7kNvgGGZa4w&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYA6wuGdz-Y8igMJ0vaUqS2SdzkunMMpiGEYGDLTSPYrfw&oe=67518A70"}, "display_name": "Escape Room Online", "keywords": [], "long_description": "\ub2e8 \ud558\ub098\uc758 \ubaa9\uc801, \ubb38\uc744 \uc5f4\uace0 \ud0c8\ucd9c\ud558\ub77c!\n\n\uc800\uc8fc \ubc1b\uc740 \uc778\ud615\uc758 \ubc29.\n\ubc29 \uc548\uc5d0 \ubaa8\ub4e0 \uac83\uc774 \ub2e8\uc11c\uac00 \ub41c\ub2e4.\n\uc2dc\uac04 \ub0b4\uc5d0 \ud0c8\ucd9c\ud558\uc9c0 \ubabb\ud558\uba74 \ub2eb\ud600\ubc84\ub9b0 \uc544\uc774\uc758 \ub9c8\uc74c\ucc98\ub7fc\n\uc774 \ubc29\ub3c4 \uc2a4\uc2a4\ub85c \uad73\uac8c \uc7a0\uaca8\ubc84\ub824 \ub354\uc774\uc0c1 \uc5f4\ub9ac\uc9c0 \uc54a\ub294\ub2e4.\n\n-\uadc0\ud558\uc758 \uc758\uacac\uc744 \uae30\ub2e4\ub9ac\uaca0\uc2b5\ub2c8\ub2e4.\n\ub354 \ub9ce\uc740 \uc5d0\ud53c\uc18c\ub4dc\ub4e4\uc774 \uc5ec\ub7ec\ubd84\uc744 \ucc3e\uc544\uac08 \uac83\uc785\ub2c8\ub2e4.", "short_description": "\uacf5\ud3ec \ubc29\ud0c8\ucd9cVR \uac8c\uc784 (\uc815\uc2dd\ubc84\uc804\uc744 \uc704\ud55c \ud2f0\uc800)\n-\ud63c\uc790\uc11c \ud50c\ub808\uc774 \ud558\uac70\ub098 \uce5c\uad6c\ub97c \ucd08\ub300\ud558\uc5ec \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4"}, {"images": {"nodes": [{"file_name": "Portrait.png", "id": "3403127939936935", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974527_3403127943270268_5982631016592496092_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JY0C49SWkA0Q7kNvgGNeLpG&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAI6TpAjsbOQ2wM3eeAFy-q-BiSRxr56Vjt6YHg6AAYbA&oe=67519AF8"}, {"file_name": "Landscape.png", "id": "927076248559542", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974773_927076251892875_8940624378489886719_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eS9aEnwVAZ0Q7kNvgGE6ZTj&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDUms_GQx5hldHfBR4L4BhFFvuvuyL6GsXh8qLEx4vT-Q&oe=6751A65F"}, {"file_name": "Icon.png", "id": "790868906088752", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974859_790868909422085_8366478809179753009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FqyB5TpQRfkQ7kNvgGAjYSi&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYApEJ3B3-PZx5yAjoC23VrI2kXCY-ko3cYMatT8mgqeNA&oe=6751ABCC"}, {"file_name": "Logo_Escape Room Online.png", "id": "559850699513050", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982516_559850702846383_9221648333595865513_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0pwpB9QWgdwQ7kNvgEEd0RZ&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBt