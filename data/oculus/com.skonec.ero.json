2739694", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982716_918954586073027_3066611866280301347_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UxKwN9NqcCEQ7kNvgEj_lDW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbodEoxrzX0yodisjYHk0-mAC2ZNZNjkoi5SWQ3OqhIQ&oe=6720CC7C"}, {"file_name": "screenshot_01.png", "id": "624075745984417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974732_624075749317750_3104111007046430173_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vA2WK7akzjAQ7kNvgHD8QL0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAe3qUNaj_OObXFrYYFO1pSM_kySA3hAYC-FvRb4e_1Cg&oe=6720C7A8"}, {"file_name": "screenshot_02.png", "id": "255320403658184", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974852_255320406991517_7897575683643396095_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k0rxr8Jp9TsQ7kNvgEJhtB7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxPYjze823fNB1sKF4acxxV01XzCfL-6D0q7_R6KdNpw&oe=6720D8B4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_image.png", "id": "168984949461724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982719_168984952795057_2362559546396233548_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ozxOTPRnG64Q7kNvgG-6F5Y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVKpbiO35apn8RpC5Kh1D2_ThAFAfCT6HnlFmw0dQU9Q&oe=6720C2F0"}, "display_name": "Escape Room Online", "keywords": [], "long_description": "\ub2e8 \ud558\ub098\uc758 \ubaa9\uc801, \ubb38\uc744 \uc5f4\uace0 \ud0c8\ucd9c\ud558\ub77c!\n\n\uc800\uc8fc \ubc1b\uc740 \uc778\ud615\uc758 \ubc29.\n\ubc29 \uc548\uc5d0 \ubaa8\ub4e0 \uac83\uc774 \ub2e8\uc11c\uac00 \ub41c\ub2e4.\n\uc2dc\uac04 \ub0b4\uc5d0 \ud0c8\ucd9c\ud558\uc9c0 \ubabb\ud558\uba74 \ub2eb\ud600\ubc84\ub9b0 \uc544\uc774\uc758 \ub9c8\uc74c\ucc98\ub7fc\n\uc774 \ubc29\ub3c4 \uc2a4\uc2a4\ub85c \uad73\uac8c \uc7a0\uaca8\ubc84\ub824 \ub354\uc774\uc0c1 \uc5f4\ub9ac\uc9c0 \uc54a\ub294\ub2e4.\n\n-\uadc0\ud558\uc758 \uc758\uacac\uc744 \uae30\ub2e4\ub9ac\uaca0\uc2b5\ub2c8\ub2e4.\n\ub354 \ub9ce\uc740 \uc5d0\ud53c\uc18c\ub4dc\ub4e4\uc774 \uc5ec\ub7ec\ubd84\uc744 \ucc3e\uc544\uac08 \uac83\uc785\ub2c8\ub2e4.", "short_description": "\uacf5\ud3ec \ubc29\ud0c8\ucd9cVR \uac8c\uc784 (\uc815\uc2dd\ubc84\uc804\uc744 \uc704\ud55c \ud2f0\uc800)\n-\ud63c\uc790\uc11c \ud50c\ub808\uc774 \ud558\uac70\ub098 \uce5c\uad6c\ub97c \ucd08\ub300\ud558\uc5ec \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4"}, {"images": {"nodes": [{"file_name": "Portrait.png", "id": "3403127939936935", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974527_3403127943270268_5982631016592496092_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qrS5KyeqWfwQ7kNvgHsvGCo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrQS8Se5_dcUozoKHAY3HaQ7bgQDsx0TqCeUWGvm1A_g&oe=6720D378"}, {"file_name": "Landscape.png", "id": "927076248559542", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974773_927076251892875_8940624378489886719_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BeC9s5UeFhYQ7kNvgHhfwxa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyOtWGjXbY6nAtFhYFqSD1EKkudZzL7TlhjH3A9kslbQ&oe=6720DEDF"}, {"file_name": "Icon.png", "id": "790868906088752", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974859_790868909422085_8366478809179753009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mOk6pFtRvTAQ7kNvgG-XpL7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfcA3yNs7Q3ywnLqX2hiOfDj6Xahd51A6vYF6GZ5yr0g&oe=6720E44C"}, {"file_name": "Logo_Escape Room Online.png", "id": "559850699513050", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982516_559850702846383_9221648333595865513_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FbM8DOsCKU0Q7kNvgGn4GGw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBI