e_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031540_579501121042958_2698044250665010196_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JPARDtIVpUoQ7kNvgFqt07w&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqj_WcSsbdVVefxa3Db5CE_VfJzGJPgpqHmg7LnnnZSw&oe=6762AC43"}]}, "id": "621722373487787", "locale": "en_US", "screenshots": [{"file_name": "Avatar_Customization.png", "id": "822309619395893", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984447_822309622729226_1197202532857370675_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MnHcHYvOAQ0Q7kNvgF1qKA1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYClbxIejDDfh0IsuubY0a8oNJ0L-HdO6ncHVMlew3LfOg&oe=6762A401"}, {"file_name": "Force_Multiplayer_pro.png", "id": "350839654066724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203622_350839657400057_620305802896038405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cT2Hmxs_1owQ7kNvgG7D48t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDcUZkS6kGQtoPOTw0t5HJn3REvQBPyX04ROiCdbw0QXQ&oe=6762A345"}, {"file_name": "Grenades_Multiplayer.png", "id": "1011830126697909", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974856_1011830130031242_878552109109056314_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UtWN9-el_ikQ7kNvgHmI7Q5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCX1YJOfW3psSU2oe0lDxXCX3AHj_OrSKofoG0EgqA0fA&oe=6762C67F"}, {"file_name": "Chomp_MR_pro.png", "id": "281127768043232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982623_281127771376565_7107781871141056162_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KHEm0RG8uAsQ7kNvgGDtlrY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwADbDc3dWO_HH0qYA8f6JTDk4nBvuMGdi3XBUDslqGg&oe=6762ADD8"}, {"file_name": "Claws_Out.png", "id": "688878106453158", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451775_688878109786491_189506205815762548_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tQldIqe9mWYQ7kNvgGBymuv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALjzLgE063q3IOquA6EOjSN5b9Sb8FTzFeaO4a2V6dAQ&oe=6762B6EA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Grokit - Early Access", "keywords": [], "long_description": "Grokit is designed to be easy to learn and quick to play, with lots of opportunity to engage with a variety of interactions and types of gameplay. \n\nEasy and Accessible Fun: Grokit is a great way to unwind and have fun without the need for complex controls or extensive gaming experience. With simple gameplay mechanics and intuitive controls, anyone can pick up and play Grokit, making it the perfect choice for those looking for a quick and easy way to play with friends.\n\nBite-sized Entertainment: Grokit is designed to be played in short bursts, making it perfect for people who don't have a lot of time to spare. Whether you're waiting for a package or taking a break from work, you can easily fit in a quick game or two, making it a great way to pass the time.\n\nSocial Gaming: Grokit is designed to be played with others, making it a great way to connect with friends and family. Whether you're playing together in the same house or competing against each other online, Grokit is a great way to socialize and have fun with others.\n\nEngaging and Replayable: Grokit is easy to pick up and play, and also incredibly engaging and replayable. With simple yet challenging gameplay, players can easily become hooked on XR gaming, making it a great way to keep people coming back for more. Whether you're looking to kill time or challenge yourself, Grokit has something for everyone.", "short_description": "Grok: To understand something intuitively or by empathy. \n\nA multiplayer mixed reality game aimed at rapid fire interactions.\n\nPlayers are dropped into bizarre situations where they must evaluate and act in a short amount of time. Learn a variety of gesture based mechanics and practice using them without needing a lot of guidance. Play against your friends and beat their score by any means necessary!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://3lbgames.com/privacy-policy/", "developer_terms_of_service_url": "https://3lbgames.com/terms-of-service/", "publisher_name": "3lbGames Inc.", "support_website_url": "https://3lbgames.com/contact/", "website_url": "https://3lbgames.com/grokit/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "4938240286300261"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1179850373110667"}, {"status": "PUBLISHED", "id": "823077926653196"}, {"status": "PUBLISHED", "id": "605770368435138"}]}, "baseline_offer": {"id": "605770368435138"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1179850373110667"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6945365255587744", "version": "24.11.29"}, "id": "3145234072412483", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3388893331234972", "is_concept": false, "latest_released_binary": {"