ps://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982694_1190178372378521_4303966440156152832_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vHEuSYivxwYQ7kNvgFXgy6C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7qDpnMzktZNhla1amzAYwkjLatHVl3VC3J2WMVAtj3A&oe=6762A8DF"}, {"file_name": "Grokit_Icon2.png", "id": "863583401889063", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974748_863583405222396_5833752640983298593_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iNqqVC1BSOUQ7kNvgH5OSfA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIiFQEQcOgh1ABFTZn7IALhoKmgbwng5SNMScZfmdmaA&oe=6762C8C4"}, {"file_name": "Grokit_Portrait.png", "id": "579501117709625", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031540_579501121042958_2698044250665010196_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JPARDtIVpUoQ7kNvgFqt07w&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqj_WcSsbdVVefxa3Db5CE_VfJzGJPgpqHmg7LnnnZSw&oe=6762AC43"}]}, "id": "976158727685793", "locale": "en_US", "screenshots": [{"file_name": "Avatar_Customization.png", "id": "822309619395893", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984447_822309622729226_1197202532857370675_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MnHcHYvOAQ0Q7kNvgF1qKA1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYClbxIejDDfh0IsuubY0a8oNJ0L-HdO6ncHVMlew3LfOg&oe=6762A401"}, {"file_name": "Force_Multiplayer_pro.png", "id": "350839654066724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203622_350839657400057_620305802896038405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cT2Hmxs_1owQ7kNvgG7D48t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDcUZkS6kGQtoPOTw0t5HJn3REvQBPyX04ROiCdbw0QXQ&oe=6762A345"}, {"file_name": "Grenades_Multiplayer.png", "id": "1011830126697909", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974856_1011830130031242_878552109109056314_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UtWN9-el_ikQ7kNvgHmI7Q5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCX1YJOfW3psSU2oe0lDxXCX3AHj_OrSKofoG0EgqA0fA&oe=6762C67F"}, {"file_name": "Chomp_MR_pro.png", "id": "281127768043232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982623_281127771376565_7107781871141056162_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KHEm0RG8uAsQ7kNvgGDtlrY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwADbDc3dWO_HH0qYA8f6JTDk4nBvuMGdi3XBUDslqGg&oe=6762ADD8"}, {"file_name": "Claws_Out.png", "id": "688878106453158", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451775_688878109786491_189506205815762548_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tQldIqe9mWYQ7kNvgGBymuv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALjzLgE063q3IOquA6EOjSN5b9Sb8FTzFeaO4a2V6dAQ&oe=6762B6EA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "2727762307362704", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566682_2727762310696037_5898926899262939185_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7WxOQ3i60jcQ7kNvgEk72-0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAo2jPQgPCp8faRyY35f255TTAT2AXEzATyWMsNu6Xq8w&oe=6762A8E1"}, "display_name": "Grokit", "keywords": ["Party", "Fun", "Fast", "Friends", "Easy"], "long_description": "Grok: To understand something intuitively or by empathy. \n\nGrokit is a hand tracking multiplayer mixed reality game aimed at rapid fire interactions.  Inspired by the party games of old, players are dropped into bizarre situations where they must evaluate their environment and act in a short amount of time. \n\nPlay in your own room with mixed reality passthrough or in traditional virtual reality in a variety of handcrafted environments. \n\nGrokit is built from the ground up to leverage more of what the new hardware can do. See what\u2019s possible with scene understanding, with game objects interacting with your and your friends\u2019 rooms and furniture. Fast and smooth hand tracking means no more dealing with controllers.\n\nPlay your way, with multiple character customization options available for avatars, hats, and watches, as well as a selection of environments and music. \n\nGrokit is also an excellent way to introduce your friends to VR and MR because it\u2019s easy to pick up, or grok, and the engaging challenges can be enjoyed in short play sessions. Perfect for family gatherings!\n\nThis is just the beginning of our Grokit journey. Future updates will include additional micro-levels, longer content mini-levels, more customization options, holiday and other special events, mobile asymmetrical play, and more, oh my!\n\nGrokit is a work in progress, with much more content coming, buy now to help support development!", "short_description": "Grok: To understand something intuitively or by empathy. \n\nGrokit is a hand tracking multiplayer mixed reality game aimed at rapid fire interactions.  Inspired by the party games of old, players are dropped into bizarre situations where they must evaluate their environment and act in a short amount of time. \n\nGrokit is a work in progress, with much more content coming, buy now to help support development!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://3lbgames.com/privacy-policy/", "developer_terms_of_service_url": "https://3lbgames.com/terms-of-service/", "publisher_name": "3lbGames Inc.", "support_website_url": "https://3lbgames.com/contact/", "website_url": "https://3lbgames.com/grokit/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_