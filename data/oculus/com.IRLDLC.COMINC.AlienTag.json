cdn.com&oh=00_AYAEy5AxjO3w-PvzTr8A6yijbJ_unjK4HCVui6bu8XvRIg&oe=67387FFF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (1).png", "id": "359451397002424", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974848_359451400335757_4290193130037986948_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NFnjdl7HkLEQ7kNvgEIaUOS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRTz_a3tVHObs1yQDc8VJY4dAWFM0K4Fh8TlyNXZLwVQ&oe=67387C27"}, "display_name": "Alien Tag", "keywords": [], "long_description": "Alien Tag is a NEW, FREE VR Game that includes built-in mods & built-in custom maps! Join the Discord at https://discord.gg/alientag \ud83d\udc7d Check out the built-in mods at  https://alientagvr.com. Alien Tag puts you in the shoes of an extraterrestrial trying to tag other aliens! Use your long, flexible alien arms to swing swiftly across psychedelic alien worlds. See if you can master the art of alien locomotion and become the top tagger in the galaxy. With Mods & Custom Maps natively integrated, no two games of Alien Tag are ever the same. Challenge your friends to out-swing and out-tag one another in intense, fast-paced rounds. Transport yourself to new worlds and catch some alien vibes today!", "short_description": "Reject Monke, Become Alien. Discord.gg/AlienTag. AlienTagVR.com."}]}, "developer_name": "IRLDLC.COM INC", "developer_privacy_policy_url": "https://alientagvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "IRLDLC.COM INC", "support_website_url": "https://alientagvr.com/", "website_url": "https://alientagvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT