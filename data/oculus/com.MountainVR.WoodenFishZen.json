/scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974691_1769304390202926_4857717662441570091_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lcxqk5I_bC4Q7kNvgH8jO8o&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpkVGq17b4URHkU34_equtbQeouGqkV-2n_4CTFzSu3w&oe=6718EC8F"}, {"file_name": "2023-12-30 18_41_45.png", "id": "1078950889907975", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974688_1078950893241308_1374981864668893190_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mQQwk0K4cugQ7kNvgGD6Nh3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1UPvZMpKGi-EcWeEmB0Kt_2lrykqGsIZCHiJVUaPggA&oe=6718E170"}, {"file_name": "passthrough.png", "id": "910258337370743", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982510_910258340704076_8779057242099034012_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5ie89x2_6YAQ7kNvgHg4Lt-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTsYyFee9w0SmOdSYigSDKCr_s-Z5xLuPaRJOUXIW50w&oe=6718CD81"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u5c01\u9762.png", "id": "745951794088262", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43997711_745951797421595_3871520485959633568_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-SoR7Zz7oYQ7kNvgF1Jxmg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCO3ASmszVxmVJNsZBbuWJ-wJ7agFRX7Dh1lQ3tlsNWoA&oe=6718DF83"}, "display_name": "Wooden Fish Zen", "keywords": [], "long_description": "The wooden fish, a venerable and mystical wood instrument originating in East Asia, is frequently employed by Buddhist clergy for recitation and ceremonies. \n\"Wooden Fish Zen\" is an application that allows you to experience knocking wooden fish in virtual reality, with real physical interaction effects. You can choose to use mixed reality mode to place the wooden fish on your own table, or choose different atmospheric scenes, such as temple, waterfall, space, rainy day, etc. This app hopes to allow you to have an immersive wooden fish zen experience, put aside distracting thoughts, and gain a feeling of decompression, healing, and concentration.\nVirtues++, troubles--.\nFind a simple and effective way to relax in your busy life, and feel a sense of peace and depth in the rhythm of tapping the wooden fish.", "short_description": "An immersive wooden fish zen experience for stress relief and healing"}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/wooden-fish-zen-privacy-policy/23e3581f-db88-4230-9aa1-0f39fc92880c/privacy", "developer_terms_of_service_url": null, "publisher_name": "MountainVR Studio", "support_website_url": null, "website_url": "https://www.facebook.com/profile.php?id=100023151198467", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7006926306011701"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7015411048496560", "version": "1.5"}, "id": "710677384498141", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6986819501355715", "is_concept": false, "latest_released_binary": {"__typ