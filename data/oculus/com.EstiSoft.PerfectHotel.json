, "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75508956_431678453255968_8819951904550143283_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ClwZw38jVO4Q7kNvgFfF_zh&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYCu6AUo_9iSWBNhCeewcFJ1M9wQiRly6jUoJAXiyyZylg&oe=66F3D9E1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "398430959653299", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003231_398430962986632_1209891275704058482_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DIjtn0boZQ8Q7kNvgFveaIj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYBeAKDst6NWlmCcw188rlfZfrXlY1aOu69WNZOlmltDIw&oe=66F3DD4F"}, "display_name": "Perfect Hotel", "keywords": ["arcadeidle", "idle", "casual", "fun", "Upgrade"], "long_description": "My Perfect Hotel is an engaging idle-clicker game that allows players to build and manage their own hotel empire. Starting with a small, basic hotel, players take on the role of a hotel manager, where their primary tasks are checking in guests, managing rooms, and ensuring that customers are happy. As you earn money from satisfied guests, you can reinvest that income into upgrading your hotel.\n\nYou start small, managing tasks like cleaning rooms, checking in guests, and collecting payments. As you accumulate cash, you can expand the hotel by adding more rooms and improving the services offered. Over time, the game allows you to automate these tasks by hiring staff, including receptionists and cleaners, who handle day-to-day operations. This allows you to focus more on strategic decisions, such as further expansions and unlocking new areas of the hotel.\n\nThe game\u2019s progression system keeps things interesting by rewarding players with stars and cash for achieving goals and providing excellent service. These resources are then used to unlock upgrades, new features, and further customization options for the hotel. As you level up, the hotel becomes more luxurious, and you must balance between expansion and maintaining customer satisfaction.", "short_description": "My Perfect Hotel is a fun idle-clicker game where players manage and expand their own hotel. Starting with a small reception, you handle guests, collect earnings, and use the money to improve your hotel. The goal is to unlock more rooms, hire staff to automate tasks, and upgrade facilities for better guest satisfaction. As the hotel grows, so do the challenges, making strategic decisions crucial to maintaining smooth operations. Over time, the game introduces new areas, expanding the hotel's cap"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/perfect-hotel", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8449307688467800"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1072430237817839"}]}, "baseline_offer": {"id": "1072430237817839"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726083121, "status": "PUBLISHED", "id": "1072430237817839"}]}, "liveChannel": {"nodes": [{"late