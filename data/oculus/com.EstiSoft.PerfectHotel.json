_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYColQk9fTplp6R8y3Qb5M8TVGJtytpOZcHznaOkpE0L3Q&oe=66F3FFBB"}, {"file_name": "2.png", "id": "1527483267892470", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572954_1527483271225803_854646925359131130_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=leuVouI-w0IQ7kNvgG3-hKP&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYAHjL2JiA_gRs1ucRhb04VmtffZKQGBWmzXK73Juogc3A&oe=66F3FCB2"}, {"file_name": "4.png", "id": "841009844851840", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422395_841009848185173_5821487651596049167_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VecQgJQi3nMQ7kNvgE_Soh-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYA6ar6wTS7egsjnqwb0Ik3oQGvUSJYgOzz0iIcwIoAX9w&oe=66F40A23"}, {"file_name": "3.png", "id": "3809594535980098", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422393_3809594539313431_1509731187905384527_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1txWr1VrgSUQ7kNvgEz3dAi&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYAp3FScuafh6qPso9PVbtU85sZmxXmDZZcHXt-KPFGyBA&oe=66F3EA54"}, {"file_name": "1.png", "id": "431678449922635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75508956_431678453255968_8819951904550143283_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ClwZw38jVO4Q7kNvgFfF_zh&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYCu6AUo_9iSWBNhCeewcFJ1M9wQiRly6jUoJAXiyyZylg&oe=66F3D9E1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "398430959653299", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003231_398430962986632_1209891275704058482_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DIjtn0boZQ8Q7kNvgFveaIj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3XPU664rZQqf4FWiexQkd9&oh=00_AYBeAKDst6NWlmCcw188rlfZfrXlY1aOu69WNZOlmltDIw&oe=66F3DD4F"}, "display_name": "Perfect Hotel", "keywords": ["arcadeidle", "idle", "casual", "fun", "Upgrade"], "long_description": "My Perfect Hotel is an engaging idle-clicker game that allows players to build and manage their own hotel empire. Starting with a small, basic hotel, players take on the role of a hotel manager, where their primary tasks are checking in guests, managing rooms, and ensuring that customers are happy. As you earn money from satisfied guests, you can reinvest that income into upgrading your hotel.\n\nYou start small, managing tasks like cleaning rooms, checking in guests, and collecting payments. As you accumulate cash, you can expand the hotel by adding more rooms and improving the services offered. Over time, the game allows you to automate these tasks by hiring staff, including receptionists and cleaners, who handle day-to-day operations. This allows you to focus more on strategic decisions, such as further expansions and unlocking new areas of the hotel.\n\nThe game\u2019s progression system keeps things interesting by rewarding players with stars and cash for achieving goals and providing excellent service. These resources are then used to unlock upgrades, new features, and further customization options for the hotel. As you level up, the hotel becomes more luxurious, and you must balance between expansion and maintaining customer satisfaction.", "short_description": "My Perfect Hotel is a fun idle-clicker game where players manage and expand their own hotel. Starting with a small reception, you handle guests, collect earnings, and use the money to improve your hotel. The goal is to unlock more rooms, hire staff to automate tasks, and upgrade facilities for better guest satisfaction. As the hotel grows, so do the challenges, making strategic decisions crucial to maintaining smooth operations. Over time, the game introduces new areas, expanding the hotel's cap"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "