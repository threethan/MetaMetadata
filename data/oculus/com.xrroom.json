mV4iIu0Z-lnhYqqp4PLETZDjFlICVOHgprlw&oe=675437FA"}, {"file_name": "screenImg4.png", "id": "207578008766424", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75294239_207578012099757_7643644066453232291_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H7LD0IM78VwQ7kNvgF1iqCu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGRDX7C6dYxqKCw0HjlnZeU8oD2lxoWl_zuKV_QmwwBQ&oe=675447AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverArt_2560x1440px.png", "id": "1272843143464404", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035377_1272843146797737_8383428287429128361_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YwEvk3bMePoQ7kNvgGIEQRI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4_xOdRe29IrlX9AJTyg3Hb4Ou-IlitLEy79sKJIiJ8A&oe=67541C9D"}, "display_name": "XR Designer old", "keywords": [], "long_description": "XR Designer is a VR game that allows you to design and share rooms.\nYou can visit rooms created by others, or upload your own models and wallpapers for use.\n\n----Functions at a glance ----\nSummon models\nChange the texture of walls, etc.\nVisit other users' rooms\nCheck your own data\nLog in\nSwitch windows\nChange weather\nChange background music\nSave Room\nLoad Room\nVolume control\nChange language\n\n---Controls ----\nMove with the left controller stick.\nRotate with the right controller stick.\nThe upper trigger on the right controller controls the menu panel.\n\n When you open the menu panel of a model and select a model: \n You can summon & hold the model with the upper trigger on the right controller.\n Press A on the right controller to zoom in and out.\n Press B on the right controller to rotate the model.\n Delete a model with the lower trigger of the right controller.\n When you move the model while holding the model, the model will move.\n (More detailed explanation can be found at \"https://xrsns.org/\")\n\n---Special thanks---\nBGM: (C) K.Y., (C) L-side, (C) Sound Effect Lab\nModel: (C) MASAYOSHI, (C) Dimensiva, (C) 3D Shaker\nImage: (C) Pixabay\n", "short_description": "XR Designer is a VR game that allows you to design and share rooms.\nYou can visit rooms created by others, or upload your own models and wallpapers for use."}, {"images": {"nodes": [{"file_name": "coverArt_1080x360px.png", "id": "9546402602098530", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240095_9546402608765196_4519594928395556476_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UDfFu0KoXZUQ7kNvgGbv2GS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUuY6URbq-ysN6SmXEQKFC0pmaeaM5xbrD4mhXQ4XgEg&oe=67543021"}, {"file_name": "coverArt_1008x1440px.png", "id": "6317703311616142", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003237_6317703314949475_8763368581178911583_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4K4LMjyRUDYQ7kNvgHVd9kt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDf6LCrzZ8qbacFigGl_PJDwlFN3esC9Z957kIS8sGhCA&oe=67542277"}, {"file_name": "xrsnsReiB0(\u80cc\u666f\u900f\u904e)_512x512.png", "id": "814221223654109", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031446_814221226987442_9156478809795113856_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RrNyY9yeIRMQ7kNvgFmcyfk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDuK7dbXzDz1DgFm3Wcs8A4JGpXszImTw9Sc75HEsYeuw&oe=6754492A"}, {"file_name": "coverArt_2560x1440px.png", "id": "788414566352221", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974702_788414569685554_3777497240444806861_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ebGJSO9LjUQ7kNvgEVB3LR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAylS4Hoy4UnYG45WS6YP7LCRCm5GahA155cWuaUmv58g&oe=675426DA"}, {"file_name": "xrsnsReiB0_512x512.png", "id": "562562755958489", "image_type": "APP_IMG_ICON", "