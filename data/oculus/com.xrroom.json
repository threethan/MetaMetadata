_4251591238434379218_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aBkE4GD0TWkQ7kNvgEmAMhP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDx3booKc0vbAwbMgun8mQkYVYkhIbxNPApJNkk0-XlbQ&oe=675431E1"}, {"file_name": "screenImg1.png", "id": "1196291771061356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031318_1196291774394689_2455308442893831945_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pXEJMhclYl0Q7kNvgF7DOon&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDdW_rVnuS1GCsbEoui3b4UfxkqvAtma-THTKrnZvDNUA&oe=67544FE8"}, {"file_name": "screenImg2.png", "id": "1680973372360168", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982529_1680973375693501_4330847431798606563_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QpSOT8DiM3AQ7kNvgFaAeYE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAW2ovGXA9NZC4yJ0JOnJpfdEMK_1Nth5uSKk8xnHFwog&oe=67543BA2"}, {"file_name": "screenImg3.png", "id": "578064184315048", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574726_578064187648381_7566851642217159551_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YXkk9PTLSU4Q7kNvgHym91A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCXwyMlgumV4iIu0Z-lnhYqqp4PLETZDjFlICVOHgprlw&oe=675437FA"}, {"file_name": "screenImg4.png", "id": "207578008766424", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75294239_207578012099757_7643644066453232291_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H7LD0IM78VwQ7kNvgF1iqCu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGRDX7C6dYxqKCw0HjlnZeU8oD2lxoWl_zuKV_QmwwBQ&oe=675447AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverArt_2560x1440px.png", "id": "1272843143464404", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035377_1272843146797737_8383428287429128361_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YwEvk3bMePoQ7kNvgGIEQRI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4_xOdRe29IrlX9AJTyg3Hb4Ou-IlitLEy79sKJIiJ8A&oe=67541C9D"}, "display_name": "XR Designer", "keywords": [], "long_description": "XR Designer is a VR game that allows you to design and share rooms.\nYou can visit rooms created by others, or upload your own models and wallpapers for use.\n\n----Functions at a glance ----\nSummon models\nChange the texture of walls, etc.\nVisit other users' rooms\nCheck your own data\nLog in\nSwitch windows\nChange weather\nChange background music\nSave Room\nLoad Room\nVolume control\nChange language\n\n---Controls ----\nMove with the left controller stick.\nRotate with the right controller stick.\nThe upper trigger on the right controller controls the menu panel.\n\n When you open the menu panel of a model and select a model: \n You can summon & hold the model with the upper trigger on the right controller.\n Press A on the right controller to zoom in and out.\n Press B on the right controller to rotate the model.\n Delete a model with the lower trigger of the right controller.\n When you move the model while holding the model, the model will move.\n (More detailed explanation can be found at \"https://xrsns.org/\")\n\n---Special thanks---\nBGM: (C) K.Y., (C) L-side, (C) Sound Effect Lab\nModel: (C) MASAYOSHI, (C) Dimensiva, (C) 3D Shaker\nImage: (C) Pixabay\n", "short_description": "XR Designer is a VR game that allows you to design and share rooms.\nYou can visit rooms created by others, or upload your own models and wallpapers for use."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xrsns.com/j/policy/privacy/", "developer_terms_of_service_url": "https://xrsns.com/j/policy/term/", "publisher_name": "https://xrsns.com/", "support_website_url": null, "website_url": "https://xrsns.org/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}, {"id": "1990104051447093"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "1014324473307962"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "661916505531123"}, {"status": "PUBLISHED", "id": "221554830634314"}]}, "baseline_offer": {"id": "661916505531123"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1690835732, "status": "PUBLISHED", "id": "661916505531123"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6365099873527875", "version": "4.0.4"}, "id": "238867605490542", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6057482550956277", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6365099873527875"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "238867605490542"}]}, "change_log": "\"XR Designer\" has been re-released with a new version in a separate application. Please change to the new \"XR Designer\".\nSearch for \"XR Designer\" in the Meta Quest Store and press the \"View App\" button in the App Lab below.\nThe new app has several times the number of models per room and capacity limit, respectively.\nThis older version limits some functions.\nWe apologize for releasing this app in a separate app due to the fundamental changes.\n\u300cXR Designer\u300d\u306f\u65b0\u30d0\u30fc\u30b8\u30e7\u30f3\u3092\u5225\