454159940165941823_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k0fzrHmR9zoQ7kNvgGG8c4h&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDIGbghoZ3WE-5LYDQ9tLxZwXRJBUTTEVCmqu2nbI37Tw&oe=6718D305"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "383881107219597", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974905_383881110552930_2764998636448943466_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1sz7U13BziIQ7kNvgEBwlbK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAApiueAKMsGhsV_p3h1GpJ0hT5gZE7u60vhhBkjTvrDA&oe=6718E573"}, "display_name": "Ethereal Land Meditation", "keywords": [], "long_description": "Ethereal Land is a spiritual sanctuary for those huddled masses yearning to breathe free who want to escape the day's demands, zone out from reality and find their inner peace.\n\nOur soothing immersive stories might touch a chord with you, or it would bring a whole new perspective on your piece of mind, a refreshing experience. With a customizable weather system, you could project your feeling and mindset to an environment you see fit.\n\nWe hope you can escape the day's demand and find your inner peace here.", "short_description": "Have you ever felt you want to escape the day's demands, zone out from reality and find your inner peace? For those huddled masses yearning to breathe free, the lost and wounded souls, may you find sanctuary in Ethereal Land."}]}, "developer_name": "SFS Studio", "developer_privacy_policy_url": "https://shufeishu.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "SFS Studio", "support_website_url": null, "website_url": "https://shufeishu.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "CASUAL", "TRAVEL"], "has_in_app_ads": f