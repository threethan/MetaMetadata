7626375700", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031504_521867629709033_7454159940165941823_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y9O897t6N5oQ7kNvgES0doX&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ala3haNR4NON9jOyZYYgBAM&oh=00_AYB89y8Zf7-Gt84zFarEx6T0ICv2K3gDdNEsDGNskvARow&oe=66F3E905"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "383881107219597", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974905_383881110552930_2764998636448943466_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cqJy5AaVcNQQ7kNvgF1U_gA&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ala3haNR4NON9jOyZYYgBAM&oh=00_AYBVrQRp1fEFEVQAr-2hI8TE3Zp_G0PehknS3ZJh7_Fyqw&oe=66F3FB73"}, "display_name": "Ethereal Land Meditation", "keywords": [], "long_description": "Ethereal Land is a spiritual sanctuary for those huddled masses yearning to breathe free who want to escape the day's demands, zone out from reality and find their inner peace.\n\nOur soothing immersive stories might touch a chord with you, or it would bring a whole new perspective on your piece of mind, a refreshing experience. With a customizable weather system, you could project your feeling and mindset to an environment you see fit.\n\nWe hope you can escape the day's demand and find your inner peace here.", "short_description": "Have you ever felt you want to escape the day's demands, zone out from reality and find your inner peace? For those huddled masses yearning to breathe free, the lost and wounded souls, may you find sanctuary in Ethereal Land."}]}, "developer_name": "SFS Studio", "developer_privacy_policy_url": "https://shufeishu.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "SFS Studio", "support_website_url": null, "website_url": "https://shufeishu.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "exte