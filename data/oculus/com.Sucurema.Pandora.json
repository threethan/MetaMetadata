s for upgrades and to unleash your most powerful attacks! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://sucurema.com/en/privacy-policy-pandora-vr", "developer_terms_of_service_url": null, "publisher_name": "Sucurema GmbH", "support_website_url": null, "website_url": "https://sucurema.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SHOOTER", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "227213863169768"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974874_276118730968912_5378438765737285589_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c7GGXUY6GvEQ7kNvgHjxYzX&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3vFJe74mz3MMi6if4wKqPL&oh=00_AYBKiYoGZKG_AZk39zxpAWl0y6CMtctggTmXeT3hZ-bY7w&oe=66EFF4F1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pandora", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1635546322, "lastRevision": {"nodes": [{"id": "103677175260531", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_m