YX4ngg&oe=67728867"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image.png", "id": "4146366052093130", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982526_4146366055426463_1932917196235881614_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VI4wcnHairoQ7kNvgGeJlAR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDs2Nih-Si0phO1ErdUjcobo8KPf1NUKBR5SSRd1XRY1g&oe=67726FBE"}, "display_name": "Phases of the Moon", "keywords": [], "long_description": "Phases of the Moon is a three-dimensional poem that you fly through in order to read. It is not an ordinary text, but a place that you visit and quickly get lost in. \n\nThe narrative revolves around a toxic love story told through 60 chapters or 'phases', which intertwine in a cloud of text strings. As the reader and protagonist move closer to the center and ending of the text, its poetic statements crisscross and fuse into a chaotic conclusion.\n\nThe full journey is 20 minutes.\n\nINSTRUCTIONS:\n\u2022 Hold the trigger buttons to fly\n\u2022 Control the speed by bending and stretching your arms\n\u2022 You can fly with just a single controller - or both for maximum speed\n\u2022 In the menu you can access the chapter index, switch the color and more\n", "short_description": "Experience a unique form of literature: a three-dimensional poem that you fly through in order to read. Get lost in the landscape of a toxic love story."}]}, "developer_name": "Simon Theis Hansen", "developer_privacy_policy_url": "https://sites.google.com/view/phasesofthemoon-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Simon Theis Hansen", "support_website_url": null, "website_url": "https://sites.google.com/view/phasesofthemoon-privacypolicy", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_