ohc=Y6GS0Aqy0-8Q7kNvgEiZqDE&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrXNvliGcwsEobnkxlH0nHbkQvBAjiEbEaeOpIL414qw&oe=66D43BBE"}, "display_name": "Phases of the Moon", "keywords": [], "long_description": "Phases of the Moon is a three-dimensional poem that you fly through in order to read. It is not an ordinary text, but a place that you visit and quickly get lost in. \n\nThe narrative revolves around a toxic love story told through 60 chapters or 'phases', which intertwine in a cloud of text strings. As the reader and protagonist move closer to the center and ending of the text, its poetic statements crisscross and fuse into a chaotic conclusion.\n\nThe full journey is 20 minutes.\n\nINSTRUCTIONS:\n\u2022 Hold the trigger buttons to fly\n\u2022 Control the speed by bending and stretching your arms\n\u2022 You can fly with just a single controller - or both for maximum speed\n\u2022 In the menu you can access the chapter index, switch the color and more\n", "short_description": "Experience a unique form of literature: a three-dimensional poem that you fly through in order to read. Get lost in the landscape of a toxic love story."}]}, "developer_name": "Simon Theis Hansen", "developer_privacy_policy_url": "https://sites.google.com/view/phasesofthemoon-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Simon Theis Hansen", "support_website_url": null, "website_url": "https://sites.google.com/view/phasesofthemoon-privacypolicy", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "NARRATIVE", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "da"], "sup