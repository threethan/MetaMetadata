3-2.oculuscdn.com&oh=00_AYCHjtra7L81Ka4Ixj0f_Ey-tK079qoMpU6nbE2rSq6n0w&oe=672F6508"}, {"file_name": "loopspace (3).png", "id": "3033787206850176", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974444_3033787210183509_941028689153976760_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=46LWw8XDe8cQ7kNvgGSVzl7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1wzx0Yf6ox0ZJ0oNcjevw8zKlSdp6HUolTxzfvQSsSQ&oe=672F33F2"}, {"file_name": "loopspace (4).png", "id": "457365612046090", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974809_457365615379423_1757397775368796576_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Osr9tIsnDOgQ7kNvgH_EhnL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIh2FaOVJNPxcxDdOFXtVg5BxL6EVTYcS_OVEHs2VWfg&oe=672F4640"}, {"file_name": "loopspace (5).png", "id": "1092993334536107", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974689_1092993337869440_2386251358080699200_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Amb9Envn-14Q7kNvgHqLrRf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCnhuR3i3qhEW9zFa8jhNeHT7CRFH0Owt8xUVNqK5sTUg&oe=672F6150"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS2560_1440.png", "id": "447356696573503", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974608_447356699906836_2817233385959890817_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YBW9wyBp3egQ7kNvgFCCQiP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyKY0bwJA2-5-oIzvU0NXlA9Y8NISJK9D9gImk85Obqg&oe=672F3194"}, "display_name": "LoopSpace", "keywords": [], "long_description": "Players all over the world are transported to the cyber space outer space with a large amount of mysterious energy distributed in different spaces. To become a superstar in the cyberspace, you need to swing your body and use the energy rackets to collect energy. In the meanwhile you can stimulate sports potential of your body and even get a higher ranking.\n\nGame features:\n\u25c6 Dynamic electronic music with Tron-style art style, players can easily get started and immerse themselves in a different world\n\u25c6 Stretch your hands and body through rhythmic movement, and exercise at the same time to get higher scores\n\u25c6 Six well-designed levels with three different difficulties to choose\n\u25c6 Various interactables, dodging, tapping and breaking experience make the game more challenging\n\u25c6 Compete with all players on the global leaderboard\n\u25c6 Long-term play makes exercise no more boring and also achieve the goal of weight loss at the same time", "short_description": "LoopSpace is a VR music action game with a strong sense of rhythm, allowing players to deeply feel color dynamic effects and fierce percussion."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesstar.com/privacyen", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "http://www.chesstar.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "364392501778145"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451775_501460244195401_3618603644501890191_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g2Dxk83YAQoQ7kNvgGD3um6&_nc_zt=3&_nc_ht=scontent-iad3-1.ocul