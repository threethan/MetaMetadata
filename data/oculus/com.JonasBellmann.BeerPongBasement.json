310_8890218944084981034_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y5sUQ2vxF84Q7kNvgH-Zc24&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqPkT3MeIfF6vByaK8svq8GzIRaRk9s_p-9mfwX9Zc5Q&oe=671E2960"}, {"file_name": "vlcsnap2.png", "id": "1200590684219579", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_1200590687552912_2207682141123999554_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UH4d81I6W9UQ7kNvgEsU0GW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAwe-cXgUeuavkGdbYNRZneRNyVLHDn3fVztovYnymBQ&oe=671E0F39"}, {"file_name": "vlcsnap-2023-01-05-14h52m02s728.png", "id": "985685649058290", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_985685652391623_907988519699543384_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oQbhkwef-IwQ7kNvgF5HgiL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8vnSexBM3XEtLChaXOn_cNTNzbms9frl4_ydkCobYOA&oe=671E2CE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BPB_Trailer_CoverImage.png", "id": "1332822014148386", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982553_1332822017481719_1348058048902923884_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kKtAlue3m28Q7kNvgFEbzXK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmFzvr-erCcs-rDvtg_hzQSb9s5d3AtXA-VWeA0tCTnQ&oe=671E3EBE"}, "display_name": "Beer Pong Basement", "keywords": [], "long_description": "Experience the classic party game of beer pong in virtual reality! Challenge a friend or practice your skills against a training robot. Play regular beer pong or add some excitement and change things up with an arrangement of items and power-ups. Watch the entire Youtube library, either by yourself or together with friends. Beer Pong Basement has more to offer than beer pong though. Try your luck at the slot machine or the Flappy Cuppy arcade machine to earn credits. Or try to unlock the many different ping pong balls this game has to offer. Bring the party to your headset with Beer Pong Basement!", "short_description": "Play the classic party game of beer pong in virtual reality! Invite a friend to play or challenge a training robot. Choose regular beer pong or spice things up with power-ups. Take a break and watch YouTube videos, or try your luck at the slot machine or arcade game to earn credits. Try to unlock the many different ping pong balls as you play. Get ready to bring the party to your headset with Beer Pong Basement!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://jonasbellmann.wixsite.com/beerpongbasement/terms", "developer_terms_of_service_url": null, "publisher_name": "Jonas Bellmann", "support_website_url": null, "website_url": "https://sidequestvr.com/app/5185/beer-pong-basement", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "492920262759560"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1129246181089397"}, {"status": "PUBLISHED", "id": "1022935012471827"}]}, "baseline_offer": {"id": "1022935012471827"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674255600, "status": "PUBLISHED", "id": "1129246181089397"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26087184564261078", "version": "0.9.5.9.1"},