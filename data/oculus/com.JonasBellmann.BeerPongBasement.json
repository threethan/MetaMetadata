Gb4JMN&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOkc8fERVgBdz8XWVwsMQ7ZcNqsFK3Txsalv-sDBN_mQ&oe=6707BFE0"}, {"file_name": "vlcsnap2.png", "id": "1200590684219579", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_1200590687552912_2207682141123999554_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dRhgJuQ9Xr8Q7kNvgGbBfMs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQ86Bqj9iJsW7Po4Yktl6jegm2M-alU6sV66zaUNMNOw&oe=6707A5B9"}, {"file_name": "vlcsnap-2023-01-05-14h52m02s728.png", "id": "985685649058290", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_985685652391623_907988519699543384_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IjfY0YdAzEAQ7kNvgFBt11v&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATKMknsWrx68ei9FuIukKS4qSep6lmR2vKehdDWe1P0A&oe=6707C363"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BPB_Trailer_CoverImage.png", "id": "1332822014148386", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982553_1332822017481719_1348058048902923884_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DvxQCDxHFtQQ7kNvgFjP8aE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjdXHQnTd6KU_JRXYkcPAtqAg1LTHlHOQJQu5_34e3jQ&oe=6707D53E"}, "display_name": "Beer Pong Basement", "keywords": [], "long_description": "Experience the classic party game of beer pong in virtual reality! Challenge a friend or practice your skills against a training robot. Play regular beer pong or add some excitement and change things up with an arrangement of items and power-ups. Watch the entire Youtube library, either by yourself or together with friends. Beer Pong Basement has more to offer than beer pong though. Try your luck at the slot machine or the Flappy Cuppy arcade machine to earn credits. Or try to unlock the many different ping pong balls this game has to offer. Bring the party to your headset with Beer Pong Basement!", "short_description": "Play the classic party game of beer pong in virtual reality! Invite a friend to play or challenge a training robot. Choose regular beer pong or spice things up with power-ups. Take a break and watch YouTube videos, or try your luck at the slot machine or arcade game to earn credits. Try to unlock the many different ping pong balls as you play. Get ready to bring the party to your headset with Beer Pong Basement!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://jonasbellmann.wixsite.com/beerpongbasement/terms", "developer_terms_of_service_url": null, "publisher_name": "Jonas Bellmann", "support_website_url": null, "website_url": "https://sidequestvr.com/app/5185/beer-pong-basement", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "492920262759560"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1129246181089397"}, {"status": "PUBLISHED", "id": "1022935012471827"}]}, "baseline_offer": {"id": "1022935012471827"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674255600, "status": "PUBLISHED", "id": "1129246181089397"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26087184564261078", "version": "0.9.5.9.1"}, "id": "502174585107194", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__type