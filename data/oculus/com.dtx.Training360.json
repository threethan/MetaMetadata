00_335267421510210_30679035490231993_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3VIBtCdqDo8Q7kNvgGKcK2X&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHB1LUYWL9QZOqDhy3_DkeubkWHhplhQ-mUvZNJxCtLQ&oe=66FD4970"}]}, "id": "6744363662347211", "locale": "en_US", "screenshots": [{"file_name": "01_Hazwoper.png", "id": "279876680543502", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974769_279876683876835_2377688235017197857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HWqCplHHpq4Q7kNvgF5HdfK&_nc_ht=scontent.oculuscdn.com&oh=00_AYCePmAtnIxPGiABPFrZDcgzXQLyphtTJgGy0zQA_kTKrQ&oe=66FD19EF"}, {"file_name": "02_Warehouse.png", "id": "803638397219662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974786_803638400552995_1041481918515541659_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zrn6r-IHtYoQ7kNvgEYlCji&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvnZR0BziSQEHw8EXweUpaYy8iVe8L591PCmpMAr9nUg&oe=66FD3190"}, {"file_name": "03_Construction.png", "id": "174246537923802", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982456_174246541257135_8298177170510331942_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=35YftxVUOwEQ7kNvgFKZ0Wu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDDcrqWb8PfMir8EycMPXFpu-l-mqnEMkfrDF2p9JXMcg&oe=66FD1D19"}, {"file_name": "04_Manufacturing.png", "id": "485039189609153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974866_485039192942486_8983657717342528058_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9jg4mxOvrhQQ7kNvgHKsgmZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlWUHWGWLWMBsxUtlFfwCKCAip7MpXJ2rAEOj7bd0PSw&oe=66FD1D33"}, {"file_name": "05_Scaffolding.png", "id": "306583724364500", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001707_306583727697833_5477069484724668049_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kL-Ie1CPWW8Q7kNvgG-W6O6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHkYzjnFepgjVL6EkJoxnbSP9Mz9a-TeFNtEEyN9Q9Fg&oe=66FD303D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape - 2560 x 1440.png", "id": "1233589303798531", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982500_1233589307131864_891965906717263628_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZKicqkqoKEkQ7kNvgFwonZr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpnGYdtSMR8PRNGKJjT3igZy43l-hq2lJEwZ_DNxCOXg&oe=66FD3CBC"}, "display_name": "Train 360", "keywords": [], "long_description": "The Train360 app was developed by a passionate group of tech enthusiasts, storytellers, and innovators committed to creating immersive training solutions that help save lives.  VR sims help learners move beyond basic safety compliance skills to develop: \n\nVisual literacy & hazard recognition skills: Allow learners the opportunity to develop identification, see past normal working conditions, and then bring that fresh perspective back into their workplace.\n\nSelf-awareness & confidence skills:  Each training simulation is developed to support Total Worker Safety\u2122. Learners that are self-aware, empowered, and skilled in recognizing potential hazards are foundational elements to building a strong company culture.\n\nThe Train360 app is a FREE download. The VR simulations that accompany the Train360 app can only be accessed by entering a 4-6 digit Learning Code associated with the My Virtual Safety Trainer (MVST) eLearning courses. For a FREE TRIAL, go to https://www.360immersive.com/mvst/", "short_description": "The Train 360 app is developed by a team of software nerds, creative geniuses, and safety geeks passionate about eliminating serious injuries and fatalities in the workplace. Traditional safety training is boring and lacks engagement. Try this app in your next safety training class, see how much fun it is to explore your surroundings in VR, and practice what you have learned in the My Virtual Safety Trainer (MVST) courses. To learn more about MVST, visit 360immersive.com/mvst and try it FREE"}]}, "developer_name": null, "developer_privacy_policy_url": "https://360immersive.s3.am