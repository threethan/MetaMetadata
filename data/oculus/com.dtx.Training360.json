dscape - 2560 x 1440.png", "id": "1233589303798531", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982500_1233589307131864_891965906717263628_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aO97vm0x7voQ7kNvgElxhs6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBw_vctTAv9HcBVkUAeZXf_1k_11D3d8y_RytH8ePw0WQ&oe=66DC473C"}, "display_name": "Train 360", "keywords": [], "long_description": "The Train360 app was developed by a passionate group of tech enthusiasts, storytellers, and innovators committed to creating immersive training solutions that help save lives.  VR sims help learners move beyond basic safety compliance skills to develop: \n\nVisual literacy & hazard recognition skills: Allow learners the opportunity to develop identification, see past normal working conditions, and then bring that fresh perspective back into their workplace.\n\nSelf-awareness & confidence skills:  Each training simulation is developed to support Total Worker Safety\u2122. Learners that are self-aware, empowered, and skilled in recognizing potential hazards are foundational elements to building a strong company culture.\n\nThe Train360 app is a FREE download. The VR simulations that accompany the Train360 app can only be accessed by entering a 4-6 digit Learning Code associated with the My Virtual Safety Trainer (MVST) eLearning courses. For a FREE TRIAL, go to https://www.360immersive.com/mvst/", "short_description": "The Train 360 app is developed by a team of software nerds, creative geniuses, and safety geeks passionate about eliminating serious injuries and fatalities in the workplace. Traditional safety training is boring and lacks engagement. Try this app in your next safety training class, see how much fun it is to explore your surroundings in VR, and practice what you have learned in the My Virtual Safety Trainer (MVST) courses. To learn more about MVST, visit 360immersive.com/mvst and try it FREE"}]}, "developer_name": null, "developer_privacy_policy_url": "https://360immersive.s3.amazonaws.com/NewLibrarySystemTest/2021_Train%20360%20Privacy%20Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "360 Immersive", "support_website_url": null, "website_url": "https://www.360immersive.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}, {"id": "393222478507326"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24080894118224195"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974738_1035532993965700_3345668575970593875_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hTQK6tIwiVsQ7kNvgGzXPI2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJt8OkzjziMULeEJQkC3ssEDHoBi2oZqK4N2W4jTFJJQ&oe=66DC2772"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Train 360", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Business", "id": "421923165850360"}, {"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 1640135055, "lastRevision": {"nodes": [{"id": "3892798617441278", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5466472450092977", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": 