00_335267421510210_30679035490231993_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jA1BND9zpLcQ7kNvgER8zI4&_nc_ht=scontent.oculuscdn.com&oh=00_AYD72w0BcB9T6WqvmHtcmuD8I9t5OB6a8Qa5mfTc7sxbzw&oe=66F80370"}]}, "id": "6744363662347211", "locale": "en_US", "screenshots": [{"file_name": "01_Hazwoper.png", "id": "279876680543502", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974769_279876683876835_2377688235017197857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3QU6P-7fJhMQ7kNvgFXZzSe&_nc_ht=scontent.oculuscdn.com&oh=00_AYB1rKWQaTZCPEngK6aN-6JgkdOiMDMubcHOeo3J91X0kg&oe=66F7D3EF"}, {"file_name": "02_Warehouse.png", "id": "803638397219662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974786_803638400552995_1041481918515541659_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mHZ90OsVzx0Q7kNvgFcBxvb&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0I2SlfCWP7VbWqQT0nQykdULZtPoR90Gv4SXfhypWAA&oe=66F7EB90"}, {"file_name": "03_Construction.png", "id": "174246537923802", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982456_174246541257135_8298177170510331942_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EFIJRO6YXZkQ7kNvgH8C3QD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKtBerCbQeLQxGgXsY3XLkoq2eDwHtnh1kOM6keT50fQ&oe=66F7D719"}, {"file_name": "04_Manufacturing.png", "id": "485039189609153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974866_485039192942486_8983657717342528058_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kc2SmlaY76sQ7kNvgGChzmo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvCH0oKSjh6_vG4IqTIRxxyIIA7SoclOHKOqEt1444CQ&oe=66F7D733"}, {"file_name": "05_Scaffolding.png", "id": "306583724364500", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001707_306583727697833_5477069484724668049_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4negm5f1hrAQ7kNvgHw9p21&_nc_ht=scontent.oculuscdn.com&oh=00_AYDczpc6Us8hQoXDNTf4fMSVpzWPxttNTAvGx6DLC13aHQ&oe=66F7EA3D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape - 2560 x 1440.png", "id": "1233589303798531", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982500_1233589307131864_891965906717263628_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RxmSFnppKA8Q7kNvgGkwnhn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAddlUCsK-PUC33HCeiaQy4nT5rKLL8-N_7OnPDobgHWg&oe=66F7F6BC"}, "display_name": "Train 360", "keywords": [], "long_description": "The Train360 app was developed by a passionate group of tech enthusiasts, storytellers, and innovators committed to creating immersive training solutions that help save lives.  VR sims help learners move beyond basic safety compliance skills to develop: \n\nVisual literacy & hazard recognition skills: Allow learners the opportunity to develop identification, see past normal working conditions, and then bring that fresh perspective back into their workplace.\n\nSelf-awareness & confidence skills:  Each training simulation is developed to support Total Worker Safety\u2122. Learners that are self-aware, empowered, and skilled in recognizing potential hazards are foundational elements to building a strong company culture.\n\nThe Train360 app is a FREE download. The VR simulations that accompany the Train360 app can only be accessed by entering a 4-6 digit Learning Code associated with the My Virtual Safety Trainer (MVST) eLearning courses. For a FREE TRIAL, go to https://www.360immersive.com/mvst/", "short_description": "The Train 360 app is developed by a team of software nerds, creative geniuses, and safety geeks passionate about eliminating serious injuries and fatalities in the workplace. Traditional safety training is boring and lacks engagement. Try this app in your next safety training class, see how much fun it is to explore your surroundings in VR, and practice what you have learned in the My Virtual Safety Trainer (MVST) courses. To learn more about MVST, visit 360immersive.com/mvst and try it FREE"}]}, "developer_name": null, "developer_privacy_policy_url": "https://360immersive.s3.am