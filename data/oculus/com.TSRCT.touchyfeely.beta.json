wJ4JqCDiWtDH3y5ri5fUkXiQ&oe=6752FD29"}, {"file_name": "Art-08.png", "id": "1891902310961288", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196225_1891902314294621_2238078460830108184_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1LsHHmSVkBoQ7kNvgGYl1Q1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4_QQR_upqbnASDNzwL2K5zp--2EBrozAg-RnGHtE5HQ&oe=6752CA87"}, {"file_name": "Art-08.png", "id": "782210065728523", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974769_782210069061856_6175752411345744086_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=miFWwcwDM4UQ7kNvgHcDWm6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBSokw0clwxk8pr7_gz7xaReDiMGQ5oXvC3MyqrogDEFw&oe=6752CD78"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Art-08.png", "id": "423398472215020", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_423398475548353_5249155989052516159_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KnKuVdNE3i0Q7kNvgHHGaLG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJ3LEQHNP-fYYnVSow75eJK4IpDsgaa0JnnIKaIoGnOg&oe=6752CFC6"}, "display_name": "Touchy Feely", "keywords": [], "long_description": "This is the first draft of a system I want to use to build experiences with hand tracking, it features\n\n - touch response, this is colour and sound for temperature and pressure\n - custom shader, I'm learning shader graph and want to make a battered comic book style\n\nWhat I hope to do\n\n - create a small short story in this space, about someone packing down the apartment of a loved one that has passed away.\n - polish the grab and feedback mechanics based on some feedback\n - add teleport and explore hand based teleport\n - work on more natural engaging interactions\n\nI'm making this public to get a read on the grabbing and the art style, I still want to add audio and polish the mechanics. My goal is also to create technical and creative experiments and share them. I want to publish often and develop in public! You can see all my development work at https://www.twitch.tv/samueltates and develop with me on Saturday mornings!!!", "short_description": "a hand tracking playspace, testing out grabbing and visual / audio feedback\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.samueltate.com/", "developer_terms_of_service_url": null, "publisher_name": "Sam!", "support_website_url": null, "website_url": "https://www.samueltate.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "NARRATIVE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "432045602041361"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1895319367289152"}]}, "baseline_offer": {"id": "1895319367289152"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1618858680, "status": "PUBLISHED", "id": "1895319367289152"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3480630195371946", "version": "0.1.10"}, "id": "175748643949580", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3253774778057490", "is_concept": false, "latest_released_binary": {"__typename": "Android