10961288", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196225_1891902314294621_2238078460830108184_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jqoA9pBNy9sQ7kNvgFWXAMe&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ayb_FjgUrkVwVwi9nNEJvq_&oh=00_AYCmd63lcFs4a-GhVkKRZtsTNOSUfj1Gykj1hHJcY4IdUQ&oe=66F68187"}, {"file_name": "Art-08.png", "id": "782210065728523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974769_782210069061856_6175752411345744086_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rNJIEqe1FRoQ7kNvgGy28N7&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ayb_FjgUrkVwVwi9nNEJvq_&oh=00_AYAQx4z8IToARKFOjOw4u_ztDU884ReeQtKPSGVojg-2_A&oe=66F68478"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Art-08.png", "id": "423398472215020", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974891_423398475548353_5249155989052516159_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mZn2yastfHYQ7kNvgGQf5Ti&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ayb_FjgUrkVwVwi9nNEJvq_&oh=00_AYC1skwq6gQ9E4kocevEmXjfqI11LQNn7wA5qzj88ZWSjA&oe=66F686C6"}, "display_name": "Touchy Feely", "keywords": [], "long_description": "This is the first draft of a system I want to use to build experiences with hand tracking, it features\n\n - touch response, this is colour and sound for temperature and pressure\n - custom shader, I'm learning shader graph and want to make a battered comic book style\n\nWhat I hope to do\n\n - create a small short story in this space, about someone packing down the apartment of a loved one that has passed away.\n - polish the grab and feedback mechanics based on some feedback\n - add teleport and explore hand based teleport\n - work on more natural engaging interactions\n\nI'm making this public to get a read on the grabbing and the art style, I still want to add audio and polish the mechanics. My goal is also to create technical and creative experiments and share them. I want to publish often and develop in public! You can see all my development work at https://www.twitch.tv/samueltates and develop with me on Saturday mornings!!!", "short_description": "a hand tracking playspace, testing out grabbing and visual / audio feedback\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.samueltate.com/", "developer_terms_of_service_url": null, "publisher_name": "Sam!", "support_website_url": null, "website_url": "https://www.samueltate.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "NARRATIVE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "432045602041361"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001711_256135626003028_8526661205509639251_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5xZendDGJsoQ7kNvgGbzwNA&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ayb_FjgUrkVwVwi9nNEJvq_&oh=00_AYBOIYCMCyXtnvrGTx86KIGmg7K76PSs39Ug2xcG_Guv1w&oe=66F698F5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Touchy Feely", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1618858666, "lastRevision": {"nodes": [{"id": "3934250179939584", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3253774778057490", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "A