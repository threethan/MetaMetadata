79_820075531924216_8453958641523072547_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KwV3WupYh1EQ7kNvgFHwiED&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDObcH28WbAfACMhYuZgO42mIQFwHfN-BRYi0moShk7Ow&oe=6752F7F8"}, {"file_name": "vAejyi.png", "id": "257539862748470", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001692_257539866081803_1027820747145021085_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fZGF_0jqyvgQ7kNvgEynwJC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDcaYrs4Lxdf4j4uKMVApmPbSs3VLKqjPVPFH-sCdEdJw&oe=6752FDB1"}, {"file_name": "ZdBcfS.png", "id": "497083544621025", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031540_497083547954358_1005228314153522449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c2H7mOLhu1oQ7kNvgFpH7mS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAKflcj4xFxLtXD4OuqFwo4o9mcXz5kGmf7L7dZSLGqug&oe=6752FA56"}, {"file_name": "Ur83NR.png", "id": "151842380128785", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974787_151842383462118_6791558993792951922_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huA4JKrJLb4Q7kNvgFYNNZK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxAapMz6oR3w6bwwlXhaqpXuW5WItH8IMbwLaXb_L4vw&oe=6752D3AD"}, {"file_name": "hv6XsP.png", "id": "924820468059132", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974702_924820471392465_7561884887428129009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HgVYG98AWl8Q7kNvgG98SK8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAP_EhXW6_GwRObUumP9q5VHgQ4agMSqYp4gHeiZabpwA&oe=6752DBAA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4BR6zK.png", "id": "3067317450154600", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031468_3067317456821266_5989603035678189572_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRAyTvE2Oo4Q7kNvgGxs_IU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDillQN-GcQWh62obW-QPqDUXyBF6jvdcCa24ia2T0vMQ&oe=6752F785"}, "display_name": "Dissection Simulator: Invertebrate Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "pl