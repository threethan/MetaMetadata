t64.5771-25/39001692_257539866081803_1027820747145021085_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-IppixftNGkQ7kNvgFZ279_&_nc_ht=scontent.oculuscdn.com&oh=00_AYARrnp3hcd9hKbRPx08lQhn1UgHaUDyRbazhGzLRY1R_A&oe=66FBFAB1"}, {"file_name": "ZdBcfS.png", "id": "497083544621025", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031540_497083547954358_1005228314153522449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YVpj5pWo32oQ7kNvgHhC597&_nc_ht=scontent.oculuscdn.com&oh=00_AYAO6P0TGclvtYgUKYnQ_9VCzbAQV3JUnPA2rarkDaeH8A&oe=66FBF756"}, {"file_name": "Ur83NR.png", "id": "151842380128785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974787_151842383462118_6791558993792951922_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VTztsNGyDusQ7kNvgG7mzb3&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUeavyaBb1DhiZfjCOMiACnnoUQpO5--gm2c66ljiwnw&oe=66FBD0AD"}, {"file_name": "hv6XsP.png", "id": "924820468059132", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974702_924820471392465_7561884887428129009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fTZj5KNM12YQ7kNvgHx1Dtx&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7gGzxKeWWylniyOJX2YDYSwWYuoh4HhmlqgLPsM4abg&oe=66FBD8AA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4BR6zK.png", "id": "3067317450154600", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031468_3067317456821266_5989603035678189572_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I7FtTOHsAjAQ7kNvgHA_dF8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSG7Hcf7BH7rs0pUKnYqkwvuYIryAGT6XbHMcNYKviuQ&oe=66FBF485"}, "display_name": "Dissection Simulator: Invertebrate Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "498545464965340"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "486153270701245"}, {"s