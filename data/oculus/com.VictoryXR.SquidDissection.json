_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L9F1mnbvV4sQ7kNvgFP1sH1&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8dQ76z6ptBzkTu39wJ5LPt&oh=00_AYBCCB4EU-iTJpUCTRKgRPGax5BXR1ivRd3eQSF2ZSKVNA&oe=66E97FF8"}, {"file_name": "vAejyi.png", "id": "257539862748470", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001692_257539866081803_1027820747145021085_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=80mZTsED7E8Q7kNvgG9iOsq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8dQ76z6ptBzkTu39wJ5LPt&oh=00_AYBslJYpeoV-uHxuFgm966KxD1-Sa_98MeMRTePBh6h47Q&oe=66E94D71"}, {"file_name": "ZdBcfS.png", "id": "497083544621025", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031540_497083547954358_1005228314153522449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PAE_fHrXS_gQ7kNvgHUTBk2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8dQ76z6ptBzkTu39wJ5LPt&oh=00_AYDHJigFt98_7Y4g3n7_94oig6wEL5_8IlSxCpswJ2W7Bw&oe=66E98256"}, {"file_name": "Ur83NR.png", "id": "151842380128785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974787_151842383462118_6791558993792951922_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1tSTJtYigmYQ7kNvgFV4pjh&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8dQ76z6ptBzkTu39wJ5LPt&oh=00_AYAAw1JrU74P2S_lQPvdsXoiGGGyrXuJcTpwAImVcI9GtA&oe=66E95BAD"}, {"file_name": "hv6XsP.png", "id": "924820468059132", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974702_924820471392465_7561884887428129009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VBd-XSetALEQ7kNvgG5Guvo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8dQ76z6ptBzkTu39wJ5LPt&oh=00_AYCXsUv4VT-QQY-RRmb75Kp8XIc325Gtg6WMJGpbLjCf1w&oe=66E963AA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4BR6zK.png", "id": "3067317450154600", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031468_3067317456821266_5989603035678189572_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xc5NAJ-EqTUQ7kNvgGonG_E&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8dQ76z6ptBzkTu39wJ5LPt&oh=00_AYCxih3UrsF8bzetvKRAawLjGPsnhpyeGQ0I4iMkqf-RRw&oe=66E97F85"}, "display_name": "Dissection Simulator: Invertebrate Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommen