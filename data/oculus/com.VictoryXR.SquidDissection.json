_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PbS-fLdQwK0Q7kNvgHrENOW&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9W4m-fZ_iec0jl4PLDr20z&oh=00_AYArqR5YdP1Nqu03Rzj99Z7fdH5z5JV3Ec1p-WzKlnT7kw&oe=66F40BF8"}, {"file_name": "vAejyi.png", "id": "257539862748470", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001692_257539866081803_1027820747145021085_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vQQqwiO9MfgQ7kNvgGNvHnb&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9W4m-fZ_iec0jl4PLDr20z&oh=00_AYA2t0WKteU-q1NqpuvXCc5DT5ovyRVfRtTbqZThBlTxsQ&oe=66F3D971"}, {"file_name": "ZdBcfS.png", "id": "497083544621025", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031540_497083547954358_1005228314153522449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=76wohm10mTMQ7kNvgFr2qo4&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9W4m-fZ_iec0jl4PLDr20z&oh=00_AYBauki74Ii4YMnqWIROLuGK7MIjMqqrJWicg2ea8Eq3Uw&oe=66F40E56"}, {"file_name": "Ur83NR.png", "id": "151842380128785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974787_151842383462118_6791558993792951922_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRvx3VqEgcIQ7kNvgHIZLzL&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9W4m-fZ_iec0jl4PLDr20z&oh=00_AYBk0JpIob687eW3eGZH4Sn0KI8GbjPo9zLcgP3eGWm8Ew&oe=66F3E7AD"}, {"file_name": "hv6XsP.png", "id": "924820468059132", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974702_924820471392465_7561884887428129009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xp62TezT0pgQ7kNvgFpOOvo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9W4m-fZ_iec0jl4PLDr20z&oh=00_AYB5MseoC3LqiM0MG2yhbMeENjAoPcZOlgJ5eGz9Vu-JLw&oe=66F3EFAA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4BR6zK.png", "id": "3067317450154600", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031468_3067317456821266_5989603035678189572_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y9pesygdknoQ7kNvgFw7KrR&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9W4m-fZ_iec0jl4PLDr20z&oh=00_AYAks-0N51bYKmDXf0oxl_VuTvq9rIjTNOlWXNMSwWI7Jw&oe=66F40B85"}, "display_name": "Dissection Simulator: Invertebrate Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "M