79_820075531924216_8453958641523072547_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bCIXHgWUr8MQ7kNvgEknesi&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAZBlv2Dz02UVkl3hyyGMcEohbyz5QZqXCk2gs8wvsQOg&oe=6756EC78"}, {"file_name": "vAejyi.png", "id": "257539862748470", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001692_257539866081803_1027820747145021085_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YSj6fTwF27kQ7kNvgGHE0CG&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDgBkcGfwl2xIvEN4cpElHSUOwPFobsayWs6xG66ywTGQ&oe=6756F231"}, {"file_name": "ZdBcfS.png", "id": "497083544621025", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031540_497083547954358_1005228314153522449_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VGEmKtuYFjYQ7kNvgEjxeeK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDF2PJV9D_-KDXSzDl5_n9pWA8_vdHVZWNtlpKnhqMkYg&oe=6756EED6"}, {"file_name": "Ur83NR.png", "id": "151842380128785", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974787_151842383462118_6791558993792951922_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XaZQR21u44oQ7kNvgGUoneM&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC9TFxWSxG1JMw2UOMB2eQl54rwbCwOq965UqbW9WGkBA&oe=6756C82D"}, {"file_name": "hv6XsP.png", "id": "924820468059132", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974702_924820471392465_7561884887428129009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Re6HRwWcITsQ7kNvgG-TkYt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBibSBjpbK0qtGf-6nm07YzTdZVX8lPQPlTPtlUZLB3HQ&oe=6756D02A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4BR6zK.png", "id": "3067317450154600", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031468_3067317456821266_5989603035678189572_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X6lKUN3r5RMQ7kNvgFPN6d4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCd4c8mkGy81ERTY1vUJXU0BVE5WxLni64uABO2bUzmEA&oe=6756EC05"}, "display_name": "Dissection Simulator: Invertebrate Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality dissection. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "pl