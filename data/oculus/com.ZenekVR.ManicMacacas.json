6997172_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FbSi1oPMSQIQ7kNvgGI6UqX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQom009eFXs-1wiNmt9TJO9&oh=00_AYDz1zfuaUIG0P-Ftejtw6ACo_Mnq43zU_fuG-qMv_Q2pA&oe=66DD8903"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Manic Macacas", "keywords": [], "long_description": "Welcome to Manic Macacas! This is a fun, well made gorilla tag fangame! \nMe, as the creator, put my heart and soul into making sure this is the funnest, best game possible! We have multiple developers from hit games like: Rat Party, CatosVR: Multiplayer Horror, and Bad Tag!!\n\nGo out there and explore your environment, you chill in a cave but the elevator will take you some place new! Put on all kinds of cosmetics to look your monkey best! And don't be a bad Macaca, we punish those! Now have fun!", "short_description": "Welcome to Manic Macacas! This is a fun, well made gorilla tag fangame! \nMe, as the creator, put my heart and soul into making sure this is the funnest, best game possible! We have multiple developers from hit games like: Rat Party, CatosVR: Multiplayer Horror, and Bad Tag!!\n\nGo out there and explore your environment, you chill in a cave but the elevator will take you some place new! Put on all kinds of cosmetics to look your monkey best! And don't be a bad Macaca, we punish those! Now have fun!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1Kx9ClIAKKxIyFgAdipbJpOgAii7uFH6Jz-0CtyDdgtY/edit", "developer_terms_of_service_url": null, "publisher_name": "ZenekVR", "support_website_url": null, "website_url": "https://linktr.ee/zenekvr", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "inte