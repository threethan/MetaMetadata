dn.com/v/t64.5771-25/57569484_787425692781867_5118839749073408355_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a-YLZLSjMuQQ7kNvgFkwLLe&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtsrjBKkGvb5EzTW030oPmzHBuf_XMvubvK7MgZLSBEA&oe=670E4568"}, {"file_name": "screenshot4.png", "id": "3640084426209329", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974746_3640084432875995_5248446006496999654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L25iUb4KIeIQ7kNvgHQp1ii&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBaSwUVLoWt3oEvbZk7im8pclFrMcpRIaZ5kWtMIzbZpA&oe=670E5749"}, {"file_name": "screenshot5.png", "id": "399916539442236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982574_399916542775569_8496828432910334725_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yp2iZLBFdCYQ7kNvgE311mq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3IvKmC9pRetSFiZzuUOAm4MbgCRNHhtgzFM-b3iusVg&oe=670E4E16"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Human Brain Time", "keywords": [], "long_description": "The Human Brain Time app is an interactive and informative way to learn about the human brain. It works great as a study tool for students! Play with the model and see the different regions of the brain. See how they are positioned in relation to other brain structures. Break apart the brain and try to put it back together! Quiz yourself and play the Brain Structure Position Game.", "short_description": "Experience the human brain in an interactive and interesting way. Grab a piece of the brain, look at it all angles, see detailed areas highlighted and labeled, throw it around the room, or leave it hovering in place for reference later!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/61cc6cfe-5e89-4e80-9e37-1718e1b47c0b", "developer_terms_of_service_url": null, "publisher_name": "HAE Studios", "support_website_url": null, "website_url": "https://virtualrealityforeducation.com/human-brain-time/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25667887062856063"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "909235457665911"}]}, "baseline_offer": {"id": "909235457665911"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1716568020, "status": "PUBLISHED", "id": "909235457665911"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27099561376355284", "version": "0.4"}, "id": "737280788377690", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25009713832006726", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27099561376355284"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "737280788377690"}]}, "change_log": "Version 4 updates: Fixed some small bugs, added helpful information for brain parts, improved Walk-through brain.", "created_date": 1727898809, "id": "27099561376355284", "version": "0.4", "version_code": 9, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug