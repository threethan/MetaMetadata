ohc=29_SLnT1qAQQ7kNvgH10F1F&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAn-Z4qF0Xx15qUL9UCFVcmFoODbqu2U6KaUubGqblhog&oe=670278C3"}, {"file_name": "HighresScreenshot00011.png", "id": "942024050632437", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75608441_942024053965770_2573322626234875085_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A3mj6DDO2RoQ7kNvgEIUOCs&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC-wMPr4Hio4deOGa7PsXY3FoFzVTsVDgNXJZvneM0yQQ&oe=670278A3"}, {"file_name": "NEEDS RESHOT_HighresScreenshot00329.png", "id": "201412409338606", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75287555_201412412671939_7969595189370676777_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gcectGekCFoQ7kNvgGv4VJa&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYALAFbIrTRCtvI1G8LJfXRzZrLFuidbNoym2tK5oq5fTA&oe=67026240"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OH_Landscape2560x1440.png", "id": "634765978662394", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974819_634765985329060_5170579330524035117_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1Km0SgksucQ7kNvgGJ5blk&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBXkemFdlMvYLiJ0MI-zzvlbIlPh9DeeXYuBYR-lfmsfA&oe=67028CBC"}, "display_name": "Outta Hand", "keywords": ["platforming", "adventure", "platformer", "action", "story"], "long_description": "Outta Hand is a high-energy platforming adventure that lets you embody one of the Hand-People, wide-eyed, hop-happy lab experiments with the power to jump great heights, leap impossible lengths, and shake hands from\u2026 really, really far away. Like a whole big dining room away.\n\nDue to not being dumb enough, loveable as you are, Dr. Vendelvom has selected you for immediate termination. Not like fired gone, more like dead gone. \n\nTo save yourself and your brethren, you must platform, jump, bounce, and punch your way through the evil doctor\u2019s laboratory with your\u2026 uh\u2026 very long arms, to take down him and all his baddies. With multiple levels and boss fights along with an endless mode, things might get, shall we say, a little bit \u201cout of hand?\u201d Get it?! No? Fine\u2026\n\nOutta Hand:\n\u2747\ufe0f Is an arm-swinging platformer with an exhilarating movement mechanic paired with a humorous light narrative.\n\u2747\ufe0f Let's you explore 4 chapters with 37 levels to traverse and several mega-bosses to punch!\n\u2747\ufe0f An endless run mode in two flavors for infinite hours of fun!\n\u2747\ufe0f Gives you plenty of movement comfort settings to fit your playstyle.\n\n\nPlease note that while the game does support seated gameplay, we recommend standing up and ensuring you have plenty of room to swing your arms!", "short_description": "Outta Hand is a high-energy platforming adventure that lets you embody one of the Hand-People, wide-eyed, hop-happy lab experiments with the power to jump great heights, leap impossible lengths, and shake hands from\u2026 really, really far away.\n\nOutta Hand:\n\u2747\ufe0f Is an arm-swinging platformer with an exhilarating movement mechanic and a humorous narrative.\n\u2747\ufe0f Let's you explore 4 chapters with 37 levels to traverse and several mega-bosses to punch!\n\u2747\ufe0f An endless run mode for hours of fun!"}]}, "developer_name": "Capricia Productions", "developer_privacy_policy_url": "https://beyondframes.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Beyond Frames Entertainment", "support_website_url": null, "website_url": "https://outtahandvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memor