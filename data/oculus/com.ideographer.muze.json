&oe=66DC28F7"}, {"file_name": "Stone-Cold.png", "id": "1431900517412903", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974655_1431900520746236_5815815504011693572_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MhLIDAlvluUQ7kNvgH-riDO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAup2Zqi_4QvaGFOHhqgUga65xjQfHCqK7AuLYk6ePskw&oe=66DC48A0"}, {"file_name": "Theater.png", "id": "311661385262711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375751_311661388596044_3528530548461404427_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OZF2Gn8U_jYQ7kNvgG-NdPm&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3UTaw45maeYFU9j_ZUs_WOK7CU9CrYT2yPLs8fodVew&oe=66DC51F1"}, {"file_name": "MacPaint.png", "id": "416000154326499", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031498_416000157659832_2324387629214690962_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RPsdAb0etMEQ7kNvgFJ9uW4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrXUEiIIvWNjODJkfwJX144ubupLpDTSyL68CrgaGnfQ&oe=66DC3D7F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video-Cover.png", "id": "739682444559509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_739682454559508_5028058827951312842_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WeDKLSoIT0IQ7kNvgGPikhi&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpbkVkPuNFNsL1791k50odk1-sP3KjBeVaTf8xRzcx8w&oe=66DC40BA"}, "display_name": "Muze XR", "keywords": [], "long_description": "Ready to immerse yourself in sophisticated spaces and discover beautiful things with people from around the world? Welcome to Muze XR. Experience tech, gaming, and art like never before with stunning graphics.\n\nOur specifically designed spaces and interactions cater to exhibitions, galleries, and technological encounters. Interact with 80s computing tech, explore vintage arcade games, see world art, and join special events while staying connected with fellow visitors and enthusiasts. Create your own avatar and catch some YouTube videos or presentations in private rooms.\n\nMuze XR is currently in the early access stage, with more features to be added soon. In the future, users will be able to create their own spaces. If you have any questions or suggestions, feel free to let us know.", "short_description": "Ready to immerse yourself in sophisticated spaces and discover beautiful things with people from around the world? Welcome to Muze XR. Experience tech, gaming, and art like never before with stunning graphics. Our specifically designed spaces and interactions cater to exhibitions, galleries, and technological encounters. Interact with 80s computing tech, explore vintage arcade games, see world art, and join special events while staying connected with fellow visitors and enthusiasts."}]}, "developer_name": null, "developer_privacy_policy_url": "https://muzexr.com/privacy-policy-muze.html", "developer_terms_of_service_url": null, "publisher_name": "Ideographer", "support_website_url": "https://muzexr.com/support.html", "website_url": "https://muzexr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "879473995923081"}, {"id": "726368587961803"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5556914971099461"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "465732769144710"}]}, "baseline_offer": {"id": "465732769144710"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1710794280, "status": "PUBLISHED", "