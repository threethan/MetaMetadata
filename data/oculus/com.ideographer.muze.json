?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MzZemf9IgBUQ7kNvgGFOETf&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCfz6jvYUp2Q6pVlaqwPH4a8VfFNgy5tg3AsDb7Y4L0FQ&oe=677BAE77"}, {"file_name": "Stone-Cold.png", "id": "1431900517412903", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974655_1431900520746236_5815815504011693572_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q9sjAJQUnKEQ7kNvgEKUUVB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBLhlP6Jo8HMIWLvK2eHTsd2BHb9zByF83HncMi43WMNw&oe=677BCE20"}, {"file_name": "Theater.png", "id": "311661385262711", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75375751_311661388596044_3528530548461404427_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=__-HzJ1NaTsQ7kNvgEcAdi2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCOr6mZOpxT7B_j1zQ0BmBXxgcumDhc0UMzdKZ9mtE3eg&oe=677BD771"}, {"file_name": "MacPaint.png", "id": "416000154326499", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031498_416000157659832_2324387629214690962_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0F3KxiE9mcwQ7kNvgHxUtDc&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCSwD1C_3666Ona3wgBy-RdM4qk4pCpZE56SQS1c3CjUQ&oe=677BC2FF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video-Cover.png", "id": "739682444559509", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974528_739682454559508_5028058827951312842_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uw9qngCiWsUQ7kNvgG_kyl4&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCeh8NM0MTFEsfdFhZDYt04ew18Umkmd6EWPYBNCcPCmw&oe=677BC63A"}, "display_name": "Muze XR", "keywords": [], "long_description": "Ready to immerse yourself in sophisticated spaces and discover beautiful things with people from around the world? Welcome to Muze XR. Experience tech, gaming, and art like never before with stunning graphics.\n\nOur specifically designed spaces and interactions cater to exhibitions, galleries, and technological encounters. Interact with 80s computing tech, explore vintage arcade games, see world art, and join special events while staying connected with fellow visitors and enthusiasts. Create your own avatar and catch some YouTube videos or presentations in private rooms.\n\nMuze XR is currently in the early access stage, with more features to be added soon. In the future, users will be able to create their own spaces. If you have any questions or suggestions, feel free to let us know.", "short_description": "Ready to immerse yourself in sophisticated spaces and discover beautiful things with people from around the world? Welcome to Muze XR. Experience tech, gaming, and art like never before with stunning graphics. Our specifically designed spaces and interactions cater to exhibitions, galleries, and technological encounters. Interact with 80s computing tech, explore vintage arcade games, see world art, and join special events while staying connected with fellow visitors and enthusiasts."}]}, "developer_name": null, "developer_privacy_policy_url": "https://muzexr.com/privacy-policy-muze.html", "developer_terms_of_service_url": null, "publisher_name": "Ideographer", "support_website_url": "https://muzexr.com/support.html", "website_url": "https://muzexr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "2687655338230691"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5556914971099461"}}]}, "scheduled_offer