 review and commenting on what could be better!\ud83d\ude0a", "short_description": "Monkey Havoc is a 'Gorilla Tag' and 'Capuchin' fan game, made so that you and your friends can freely explore the world around you. \nHave Fun!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/monke-jumpers-website/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/monke-jumpers-website/terms-of-service", "publisher_name": "KrakinProductioms", "support_website_url": null, "website_url": "https://sites.google.com/view/monke-jumpers-website/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "394813081514456"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8673020899385590"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1722975131867680"}]}, "baseline_offer": {"id": "1722975131867680"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729184640, "status": "PUBLISHED", "id": "1722975131867680"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8696643180356695", "version": "1.3"}, "id": "987648196449303", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typ