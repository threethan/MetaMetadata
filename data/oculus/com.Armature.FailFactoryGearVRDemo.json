ohc=Losl8rS-P-8Q7kNvgH3QBIo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-s_XTAK0GTVycDv4Ib7iAW&oh=00_AYAFnDUWuR6kX6e_mWwbtW58tFMt4uRa50cdtzm9bcyVBQ&oe=66EBFE5F"}, {"file_name": "migrated_image.png", "id": "913276845770000", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162716_309301642809703_3634431536675160064_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7e5ybe8xQjgQ7kNvgFgxWlW&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-s_XTAK0GTVycDv4Ib7iAW&oh=00_AYAepSu2371xsHTxx_HxvQq6Uvs9g1MPQbbUtkt80n9-Tg&oe=66EBF39E"}, {"file_name": "migrated_image.png", "id": "220267052508465", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386286_322834038196860_322204868838162432_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q4JaJEI91U4Q7kNvgEfpZ2Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-s_XTAK0GTVycDv4Ib7iAW&oh=00_AYAOBnq9g3wr91q020TJ1ptdBeUM-lGQEpqEWIWUh64krw&oe=66EC01BE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "75262744_592055948252052_3174710684126543872_n.png", "id": "2273427452851341", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363516_2273427456184674_5101230653467287889_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LD49YwtrJJIQ7kNvgEvgOmf&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-s_XTAK0GTVycDv4Ib7iAW&oh=00_AYCqqxVSL-yHls7a9ed8XzMP2fUaeQ7UCfNkD0qBBzlT2Q&oe=66EC2472"}, "display_name": "Fail Factory! Demo", "keywords": ["Puzzle", "Casual", "Arcade", "Physics", "Demo"], "long_description": "Immerse yourself in a whimsical robot factory while climbing your way up the corporate ladder from lowly intern to esteemed star employee. In a wacky spectacle of increasing chaos, strive to keep up with the escalating comedy of errors as you operate various assembly lines in a myriad of mini-games. Entrenched in a physics-based, no consequences playground, experience three main types of mini-game stations, all with the goal to help the factory build robots on a massive scale. \n \nWorking in assembly stations, sorting stations and quality assurance protocol (QAP), where you\u2019ll control unfathomably large robots, you\u2019ll hone your skills in a factory that feels reactive and alive, allowing for a fully immersive experience. Designed with approachability in mind, ridiculous failure is inevitable as you work your way to the top in this vibrant, witty and comedic stress-inducing Fail Factory!.", "short_description": "Immerse yourself in a whimsical robot factory while climbing your way up the corporate ladder from lowly intern to esteemed star employee. In a wacky spectacle of increasing chaos, strive to keep up with the escalating comedy of errors as you operate various assembly lines in a myriad of mini-games. Entrenched in a physics-based, no consequences playground, experience three main types of mini-game stations, all with the goal to help the factory build robots on a massive scale."}]}, "developer_name": "Armature Studio", "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.meta.com/legal/quest/games-terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "http://www.armature.com/games/failfactory", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en_US"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7093413164012358"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.ocul