20_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QiI2YMMahYUQ7kNvgHJ4v_1&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYBuix6rcOzgfasRuNxhaRuDWMzybxJtOlmt3dtSD2kONQ&oe=677E6988"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gtag.png", "id": "1454151685459352", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38982501_1454151688792685_7717428527590049642_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oj7UKLQYXoUQ7kNvgHStZ8V&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYD9-qKDsPw0oARWOU00Gri29-qXpqwc0gzBEzcUqbNlNw&oe=677E7CDD"}, "display_name": "Bad Tag", "keywords": [], "long_description": "Welcome to Bad Tag VR!\n\nBad Tag is Hand-Based locomotion game with no true objective other than be a true monkey! Explore the different maps, try out the gamemodes, join a lobby with strangers or hop into a private lobby with your friends, get lost in the poolrooms, or customize your monkey with different cosmetics!\n\nBy using one or two controllers, maybe even no controllers at all, explore and have fun in Bad Tag!", "short_description": "Bad Tag VR is a Hand-Based locomotion game with various maps and gamemodes."}]}, "developer_name": "coz", "developer_privacy_policy_url": "https://sites.google.com/view/badtagvr/privacy-policy?authuser=0", "developer_terms_of_service_url": null, "publisher_name": "coz", "support_website_url": null, "website_url": "https://sites.google.com/view/badtagvr/home?authuser=0", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH