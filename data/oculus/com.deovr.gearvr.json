kNvgGKBPvO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAr8kHcnMxJ-iLcfAHIM6YOKrPz3A4qLVMY7CmZ6BAxXg&oe=674F0A60"}, {"file_name": "migrated_image.png", "id": "3144199535612210", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982700_2570953252929262_5129614608528572416_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kxsngf7PbR4Q7kNvgGwU0jZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAeftxOEaJ9BiLxIVVPfGlQokZegVzamhtvN9xut14JlA&oe=674EFB90"}, {"file_name": "migrated_image.png", "id": "2628530487425067", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_457331451499870_3199554445708886016_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l-N4e3aqrQ8Q7kNvgEyZTbl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCm2V6VA6MT7tFS_enyNHr-kOGUISdm5nMh11ze3M9ezw&oe=674ED99F"}, {"file_name": "migrated_image.png", "id": "563928967551082", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982656_2480206575364368_5307941586233982976_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gz8gIS26U5IQ7kNvgEMnOcy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBt1uNCCFkvkQGIkazcecqR3v950hN3lrmVsPWrABfASA&oe=674EE6DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/RlMNPV", "id": "430021804447533", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974760_430021814447532_1107669858025209856_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=buFbF_h-wa8Q7kNvgHS8YmR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkwAom8tK0iC2dHhXD9a25Audc1rjIS7Z_ES5g_3Zvpg&oe=674ED725"}, "display_name": "DeoVR Video Player", "keywords": ["vrplayer", "360player", "videoplayer", "vrvideo", "movies"], "long_description": "DeoVR is a straight-forward, high performance video player for 2D, 3D, flat, 180\u00b0and 360\u00b0 videos that has been labeled the \u201cKing of the Hill of VR Video Players\" by VRCircle. \n\nDeo has a clean, intuitive UI and includes a wide variety of features and video adjustment options such as:\n- Stereo Offset (IPD adjustment)\n- Zoom\n- Tilt\n- Height\n- Playback Speed\n- Brightness\n- Contrast\n- Saturation\n- Force monoscopic view\n- Fisheye support\n- Subtitle support\n- Support for multiple audio tracks\n- Clean and intuitive UI\n- SuperSampling and AntiAliasing settings\n- Streaming video support (just paste the video URL)\n\nFilename Conventions:\nInclude those markers in filenames to enjoy autosettings for your favourite videos:\nSide by Side: \"SBS\" or \"_LR\"\nOver Under: \"OverUnder\" or \"_TB\"\n180: \"180\"\n360: \"360\" (270\u00ba is technically 360\u00ba)\nGive your video a filename like VideoTitle_SBS_180.mp4 and you are good to go. It Doesn't matter what order the markers are in.", "short_description": "DeoVR is a straight-forward, high performance video player for 2D, 3D, flat, 180\u00b0and 360\u00b0 videos that has been labeled the \u201cKing of the Hill of VR Video Players\" by VRCircle. \n\nDeo has a clean, intuitive UI and includes a wide variety of features and video adjustment options including brightness/contrast/saturation, IPD Offset/Zoom/Height/Tilt, playback speed, streaming video support, subtitle support and more."}]}, "developer_name": "VRFavs.com", "developer_privacy_policy_url": "https://deovr.com/pages/privacy", "developer_terms_of_service_url": "https://deovr.com/pages/privacy", "publisher_name": "VRFavs.com", "support_website_url": null, "website_url": "http://deovr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "UTILITY", "MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_A