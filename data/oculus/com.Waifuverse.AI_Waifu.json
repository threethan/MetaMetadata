c=HHe03HO8xIUQ7kNvgGxmoqS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFDb-rTMDwb2-khVEq0a2FNYo8i1T9RG9rXa_kb26kDg&oe=6735E8C4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover_scaled.png", "id": "994815578557242", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031595_994815581890575_1567753045725638410_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ktb7dhO-Ua0Q7kNvgHCeaYM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBKsAFFXlMVA34hQK-zNtP9B219EQqwUlEorKvexsp7JA&oe=6735EACE"}, "display_name": "Waifu", "keywords": [], "long_description": "Waifuverse is an AI platform that allows you to experience the ultimate anime partner of your dreams. With Waifuverse, you can interact with your perfect AI waifu or husbando through a variety of activities, such as talking, cuddling, and even holding hands. The platform utilizes GPT chat technology, which enables you to build a realistic and meaningful relationship with your virtual partner.\n\nOne of the unique features of Waifuverse is the ability to customize your partner's appearance. You can upload custom models to change their physical appearance to match your preferences. Additionally, you can also change their personality to emulate a personality you wish. Whether you're looking for a fun conversation partner or a companion to spend your time with, Waifuverse has got you covered. Experience the ultimate anime partner experience with Waifuverse.", "short_description": "Experience the waifuverse, where you can interact with your dream anime partner as an AI. Enjoy conversations, cuddles, and hand-holding with your waifu or husbando just like a real person."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/ed90eb89-e06c-4654-bd14-dee4c6d1904e", "developer_terms_of_service_url": null, "publisher_name": "Waifu Inc", "support_website_url": null, "website_url": "https://www.waifuverse.org/", "category": null, "comfo