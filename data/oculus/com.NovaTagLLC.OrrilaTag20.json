_3306249409599055033_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z8yBiaW65u0Q7kNvgGBGIvX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG5exAmvU_S-XH4VS2clIEp&oh=00_AYC1HgDzLwFcrXIU7X18mqT8lo0Ili5Le5hz30pcGCd0rg&oe=66E7FC50"}, {"file_name": "3b40ae7684b149fbb96d848db2005bb8.png", "id": "1635697093874501", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035410_1635697097207834_4552685891763476608_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-PHYe_JRjQMQ7kNvgF2JQY8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG5exAmvU_S-XH4VS2clIEp&oh=00_AYBJge0ivFjYvW7IS54C4mkvhtFC4eQtjLug805Au6YRSg&oe=66E82E01"}, {"file_name": "e883e6555be742a0a563d511de271832.png", "id": "409358985489732", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240097_409358988823065_8167669319934299430_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NqaNC25L50QQ7kNvgGPy1jc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG5exAmvU_S-XH4VS2clIEp&oh=00_AYBiYEYblpnob2iO2iDdplPDzawZm7dtqsnEmj7sWCwB9w&oe=66E82D6E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BADEBAFB-2961-4DDA-9266-F897D5841C4C (7).png", "id": "518695467162533", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_518695470495866_347057906579158690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-acfu7FX6uIQ7kNvgG0Qzsl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG5exAmvU_S-XH4VS2clIEp&oh=00_AYDXberL5ZWN_UlcmriPxBZrayV_6R162jqhrqWk8HKxtQ&oe=66E80A72"}, "display_name": "Orrila Tag 2.0", "keywords": [], "long_description": "Orrila Tag 2.0 by LSG\n\nStep into the thrilling world of Orrila Tag 2.0, the ultimate multiplayer VR experience where agility, strategy, and quick reflexes are your keys to victory. Remade and constantly evolving with frequent updates, this game by LSG invites you to immerse yourself in a vibrant, dynamic environment where you play as a nimble gorilla.\n\nChallenge your friends or other players in fast-paced, adrenaline-pumping matches. Scale walls, leap across treetops, and outmaneuver your opponents to avoid being tagged or to become the ultimate tagger. With new features, maps, and game modes added regularly, Orrila Tag 2.0 keeps the excitement fresh and the competition fierce. Are you ready to dominate the jungle? Join the fun and experience the next level of VR gameplay with Orrila Tag 2.0!", "short_description": "Orrila Tag 2.0 by LSG\n\nDive into the action with Orrila Tag 2.0 the ultimate VR gorilla tag experience! Remade and frequently updated, this game challenges you to leap, climb, and outmaneuver opponents in a vibrant, ever-evolving jungle. Whether you're tagging or evading, every match promises fast-paced excitement and fresh challenges. Are you ready to prove your skills and dominate the jungle? Join the fun in Orrila Tag 2.0!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://nyandiekashayen9.wixsite.com/orrilatag/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "daddylsg", "support_website_url": null, "website_url": "https://nyandiekashayen9.wixsite.com/orrilatag", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8046672628753498"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451785_865106342181945_5821831244070049906_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oxI3Xt9V