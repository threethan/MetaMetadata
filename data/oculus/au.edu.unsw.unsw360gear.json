/11162763_1974970069442238_2892469021393813504_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xYaEl-9u5QUQ7kNvgFlibPf&_nc_ht=scontent.oculuscdn.com&oh=00_AYAU6fvHSho4Ig6P6-lyubNqD4uHF8ZtaEm3ikZMsxLNwQ&oe=66CC5C81"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "UNSW 360 VR Campus Tour", "keywords": ["Sydney", "University", "Australia", "Campus", "Education"], "long_description": "Welcome to UNSW Sydney in 360!\n\nExplore our beautiful campus and see your future at UNSW. \n\nCheck out your future campus and Sydney Harbour before you arrive. Meet some of our friendly students as they take you on a guided tour, and get access to information about our world-class Faculties, research labs, library and modern facilities. \n\nChoose your own way of exploring our campuses and Sydney Harbour in 360. Take the guided tour or jump to your favourite locations using the scene finder.\n\nTake the guided route starting with our famous University Mall. At the beginning of each location, one of our students will give you an introduction. Click on the icons to watch videos, find out more about our Faculties, read about buildings and who is inside. When you\u2019re ready to move on, click \u2018Next\u2019 to go to the next location. \n\nImagining yourself at UNSW has never been easier. Let\u2019s go!", "short_description": "Explore our beautiful campus in VR and see your future at UNSW."}]}, "developer_name": "Paper Moose", "developer_privacy_policy_url": "https://www.unsw.edu.au/privacy", "developer_terms_of_service_url": "http://www.international.unsw.edu.au/terms-and-conditions", "publisher_name": "UNSW Sydney", "support_website_url": null, "website_url": "http://www.360tour.unsw.edu.au/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "CASUAL", "EXPLORATION", "SOCIAL", "UTILITY"], "has_in_app_ads": false, "int