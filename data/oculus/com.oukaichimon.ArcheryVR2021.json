963258927449200_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MCk_lS2i9DsQ7kNvgGlzgnO&_nc_ht=scontent.oculuscdn.com&_nc_gid=A05zFI-KjyZgyKSbjqeQ0Dk&oh=00_AYBPGbhiRkT6flRIGQfJmGegKBWgsXy2beYGOKev3kX2Ng&oe=66E5841E"}, {"file_name": "ScreenShot00.png", "id": "374672787296456", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031656_374672790629789_3465339864124643415_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BLz-H2Gjk3UQ7kNvgFsxUN5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A05zFI-KjyZgyKSbjqeQ0Dk&oh=00_AYBKepW3RmzEyzAful_a0VFAxUDT5929QtfDTZ_6ag1Ljg&oe=66E56673"}, {"file_name": "CoverLandscape.png", "id": "785904978982544", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572941_785904982315877_8537425924808949631_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NlBJABByOi8Q7kNvgGesp9Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=A05zFI-KjyZgyKSbjqeQ0Dk&oh=00_AYDIxodEfcYzJVslwM2bg7_x23C7MewTEUV9qRJsXosqwg&oe=66E58997"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30e0\u30fc\u30d3\u30fc\u306e\u30b5\u30e0\u30cd.png", "id": "897552224139259", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75435282_897552227472592_4859223191107329569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xyOi4KAGuGUQ7kNvgEgwDU6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A05zFI-KjyZgyKSbjqeQ0Dk&oh=00_AYDCsfR0F9al2zS7kcA4WnzJh1rD5Ip5a1Zu_Jn_pHNQxA&oe=66E56AA3"}, "display_name": "ModernArcheryVR", "keywords": [], "long_description": "An old Chinese poet said,. Ideas come up when you're riding a horse, sleeping, or defecating.\nGood ideas come when you're focused on something else. Also, it's better to think in a large space than in a small room.\n\nHere is a VR game where you shoot an arrow at a target in a big space.\nWould you like to try this game to come up with a good idea?\n\nAlso, all the sales of this game will be the cost of the designer of the next VR game we are preparing.\nPlease buy it for our next game.", "short_description": "I'm not sure if the Tokyo Olympics will be held, but if not, why don't we just do archery in VR?"}, {"images": {"nodes": []}, "id": "323383242507839", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "ModernArcheryVR", "keywords": [], "long_description": "\u6614\u306e\u4e2d\u56fd\u306e\u8a69\u4eba\u304c\u8a00\u3044\u307e\u3057\u305f\u3002\u30a2\u30a4\u30c7\u30a2\u304c\u6d6e\u3076\u5834\u6240\u306f\u99ac\u306b\u4e57\u3063\u3066\u3044\u308b\u6642\u3001\u5bdd\u3066\u3044\u308b\u6642\u3001\u6392\u6cc4\u3057\u3066\u3044\u308b\u6642\u3060\u3068\u3002\n\u826f\u3044\u30a2\u30a4\u30c7\u30a2\u306f\u4ed6\u306e\u3053\u3068\u306b\u96c6\u4e2d\u3057\u3066\u3044\u308b\u6642\u306e\u65b9\u304c\u51fa\u308b\u305d\u3046\u3067\u3059\u3002\u307e\u305f\u5e83\u3044\u7a7a\u9593\u3067\u8003\u3048\u305f\u65b9\u304c\u3001\u72ed\u3044\u90e8\u5c4b\u3067\u8003\u3048\u308b\u3088\u308a\u3082\u826f\u3044\u305d\u3046\u3067\u3059\u3002\n\n\u3053\u3053\u306b\u5e83\u3044\u7a7a\u9593\u3067\u4e00\u5fc3\u4e0d\u4e71\u306b\u7684\u306b\u77e2\u3092\u6253\u3064VR\u30b2\u30fc\u30e0\u304c\u3042\u308a\u307e\u3059\u3002\n\u826f\u3044\u30a2\u30a4\u30c7\u30a2\u3092\u51fa\u3059\u305f\u3081\u306b\u3001\u3042\u306a\u305f\u306f\u3053\u306e\u30b2\u30fc\u30e0\u3092\u8a66\u3057\u3066\u307f\u307e\u305b\u3093\u304b\uff1f\n\n\u3042\u3068\u3053\u306e\u30b2\u30fc\u30e0\u306e\u58f2\u4e0a\u306e\u5168\u3066\u306f\u3001\u6b21\u306b\u6e96\u5099\u3057\u3066\u3044\u308bVR\u30b2\u30fc\u30e0\u306e\u30c7\u30b6\u30a4\u30ca\u30fc\u8cbb\u306b\u306a\u308a\u307e\u3059\u3002\n\u79c1\u9054\u306e\u6b21\u306e\u30b2\u30fc\u30e0\u306e\u305f\u3081\u306b\u3082\u305c\u3072\u8cb7\u3063\u3066\u304f\u3060\u3055\u3044\u3002", "short_description": "\u6771\u4eac\u30aa\u30ea\u30f3\u30d4\u30c3\u30af\u306f\u958b\u50ac\u3055\u308c\u308b\u304b\u3069\u3046\u304b\u308f\u304b\u308a\u307e\u305b\u3093\u304c\u3001\u3082\u3057\u958b\u50ac\u3055\u308c\u306a\u304b\u3063\u305f\u3089\u30a2\u30fc\u30c1\u30a7\u30ea\u30fc\u3060\u3051\u306fV