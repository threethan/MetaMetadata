1-25/39001717_343374847126368_2497999834148640937_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zXqUI51Go1kQ7kNvgGTHaMv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDkb1hSoinznw2gGDkNbqiCL_4B5UBYVhi0PJ7NnpsX5w&oe=6741B3F2"}, {"file_name": "Tennis-League-VR-03.png", "id": "4284916688259040", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982541_4284916691592373_9146724376901987960_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9mx1UYeEeJoQ7kNvgFOIOch&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5J1Q1RHuNV_f6_beXtJDEiNiIOQH-sfYBlK4oAw5GoQ&oe=6741D784"}, {"file_name": "Tennis-League-VR-04.png", "id": "773366416668978", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982604_773366423335644_6358419333340780748_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KgOpqp-MQtgQ7kNvgHhWSSf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDT80nsD0NccCOfOMQMOEdu0PtKU5LiAKh6YSeKDE4qYQ&oe=6741CBB0"}, {"file_name": "Tennis-League-VR-05.png", "id": "493866851896730", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982535_493866855230063_711765005910350392_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ORxOFcF-aMQ7kNvgGDuop6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATaASN3LVDqmvrfQ5KzZb5Uj_TlP0c1LC2vR_LN4EDIw&oe=6741B835"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_Tennis-League-VR-2560x1440_03.png", "id": "406263917292750", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254878_406263927292749_605698455396388518_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RXC_Hyafx6YQ7kNvgG7jshL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6UUAJs4RpI53yY3NQE1TnPT4yZWPTReCUcl0wKeEAvA&oe=6741D16F"}, "display_name": "Tennis League VR - Early access demo", "keywords": [], "long_description": "Tennis League VR is a realistic tennis simulator for Oculus Quest and Quest 2 where you can casually play alone or with other people online, and also properly learn tennis techniques and train them.\n\nThis Early Access alpha features a small slice of the final game, coming on Oculus Quest and Oculus Quest 2 this Fall!\n\nFeatures:\n- Spins: the game understands shots and movements to reproduce also top spins, slices, and lobs.\n- Training mode: learn basic techniques and practice with timed exercises and targeted areas of the court\n- Custom mode: train using the ball cannon at different speeds, or challenge the CPU in an exhibition\n- Multiplayer mode: play a rally with an online friend \n- Different settings and court surfaces (urban and synthetic currently available)\n\nFeel like a real tennis champion!", "short_description": "Tennis League VR is a realistic tennis simulator for Oculus Quest and Quest 2 where you can casually play alone or with other people online, and also properly learn tennis techniques and train them.\n\nThis Early Access alpha features a small slice of the final game, coming on Oculus Quest and Oculus Quest 2 this Fall!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.anothereality.io/tennis-league-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HIP", "support_website_url": null, "website_url": "https://www.anothereality.io/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1818730618321692"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "861522804489080"}]}, "baseline_offer": {"id": "861522804489080"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1627334400, "status": "PUBLISHED", "id": "861522804489080"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27911262585186808", "version": "1.1.3.0"}, "id": "1118498168626167", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5873456359394080", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27911262585186808"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1118498168626167"}]}, "change_log": "Tennis League VR Free Edition 1.1.3.0 release notes\n\n\n- Localization: game now available in French, German, Spanish (LATAM), Korean, Japanese, Chinese (Simplified)\n\n\n- Introduced all control options from the full game\n\n\n- Temporarily reintroduced multiplayer (with full cross-play) for a limited time\n\n\n- Minor bugfixes and QoL improvements", "created_date": 1731433986, "id": "27911262585186808", "version": "1.1.3.0", "version_code": 36, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5873456359394080", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27911262585186808"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1118498168626167"}]}, "change_log": "- Sound effects improvements\n- Many bugfixes across the whole game\n\nTennis League VR is OUT NOW on Meta Quest Store! \nClick the button on the blackboard (in the home environment) to go directly to the store page!", "created_date": 1681911313, "id": "9500319413374405", "version": "1.0.0.0", "version_code": 22, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5873456359394080", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27911262585186808"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1118498168626167"}]}, "change_log": "~ New movement control option, thumbsticks ~\n You can now move freely around the court using the analog stick of either of your Quest controllers. Please note that the default movement is still teleport - if you wish to play using analog sticks, you can activate the option from the settings menu\n\n ~ Improved physics and swing control ~\n Your shots are now more precise than ever\n\n ~ Other UI/UX improvements ~", "created_date": 1666624415, "id": "8584372241635798", "version": "0.7.0.8", "version_code": 16, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5873456359394080", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27911262585186808"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id":