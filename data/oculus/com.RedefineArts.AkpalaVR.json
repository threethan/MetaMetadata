RlO4Q7kNvgGQ9ya_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQmWvuzjM4zkkLVrcZtvwpTeC6b9F97ktr-ZE3S9ClsQ&oe=673C6B33"}]}, "id": "3048694771979115", "locale": "en_US", "screenshots": [{"file_name": "Cast-Meta.png", "id": "512569518024237", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75322595_512569521357570_7588731477569819728_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mnMW4wNPXsMQ7kNvgGfHHpB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbyfQMfosvIWPuQUVWocp8nueEOOnIzyyy2ud62RNpkQ&oe=673C829D"}, {"file_name": "Pose-Meta.png", "id": "1086710686428505", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974446_1086710689761838_1353733103899770758_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K184dVf3ot8Q7kNvgEACFVc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAj7HO7q2P4sI8JW9r_zazkmT-VdKMSAX-WPcJSmYTwNw&oe=673C6398"}, {"file_name": "Choose-Meta.png", "id": "1864891524005976", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031640_1864891530672642_7458095216083688746_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OhWNXlHu0I0Q7kNvgEThNOp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDN49I1lKGI5vZvupqCpvISAoaU04VUVkjp4fFIIgK9mg&oe=673C6561"}, {"file_name": "Chat-Meta.png", "id": "1255998218729711", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974809_1255998228729710_1443845334787229163_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mXe84UagbvUQ7kNvgHct7dN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDtpg7KlV4QMfYxpRS__2GYt_zU8hkgkmDfN-bloecsA&oe=673C87D3"}, {"file_name": "DLC-Meta.png", "id": "857787409341125", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003273_857787412674458_5290447081960292166_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kZasI6WQO7AQ7kNvgGMiryI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9t2LULH0Htuf52wC5CQJGJMHtEFifrf5GEP5carZ2Bg&oe=673C90F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "f2p-meta.png", "id": "3169578119839724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974809_3169578123173057_2079444359238908647_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qofMInSyepsQ7kNvgHEEM_I&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFfP4SZXstnkMGNBWnDY7UTa5nA1GCNl7RtWlhVhgVrA&oe=673C86FA"}, "display_name": "Akpala", "keywords": ["PvP", "Free", "Magic", "Anime", "Voice"], "long_description": "*Free to play for a limited time! (Ends: 31st October 2024)\n\n# VOICE MAGIC ACTIVATION\n\nCast spells by chanting, and striking heroic poses for enhanced magic effects. Learn and perform different spells according to the needs of the battle. Movement, strategic thinking and resource management are crucial in every duel! Be sure that you use every tool in your arsenal.\n\n{1176736497103531}\n\n\n# AI CHARACTER CONVERSATIONS\n\nEngage in voice-based communication with 3D AI characters! During the tutorial stages, you will not only be able to learn everything about the game but also 'chit-chat' with the character that is guiding you with AI-generated conversations. Be sure that you don't get captivated by Lukia and actually finish the tutorial!\n\n{912634733949310}\n\n# GAME HIGHLIGHTS\n\nSupports up to four players in multiplayer mode with 1v1 or 2v2 team battles and battle royales. Grab your partner or join solo with our matchmaking feature and get to play with other Wizards from all around the world.\n\n{1450985992470893}\n\nIn multiplayer, strategically create and place blocks on the stage to build advantageous positions or snipe from above. These blocks can make a huge difference in different scenarios. Need to go higher? Build a ladder! Plain battleground? Create some cover!\n\n{1484220565855393}\n\nTake advantage of different perks and jumping-pads to move through the battlefield. Collect black orbs that yield random outcomes and mana orbs to keep casting your spells.  Flex your wits, move your body, and chant magic loudly on the battlefield!\n\n{465384995949128}\n", "short_description": "Participate in VR Magic battles where you will need to chant to cast spells and strike poses to enhance your power. Fight 1v1 or 2v2 in a variety of scenarios. Master different spells and defeat your opponents to become a master duelist in Akpala."}, {"images": {"nodes": []}, "id": "1938996723284903", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AkpalaPV_1.png", "id": "7690176081065379", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974456_7690176084398712_3727308418691568002_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YaUSuc7PhzsQ7kNvgGV33pH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAE8mCnPrm8Q5p0yeRI3Zs7wPbnBInVnit6gtKzH3Mh7w&oe=673C6A27"}, "display_name": "Akpala", "keywords": [], "long_description": "\n# \u97f3\u58f0\u3092\u4f7f\u3063\u305f\u30ea\u30a2\u30eb\u306a\u9b54\u6cd5\u4f53\u9a13\n\u3053\u306e\u30b2\u30fc\u30e0\u3067\u306f\u3001\u5b9f\u969b\u306b\u58f0\u306b\u51fa\u3057\u3066\u546a\u6587\u3092\u5531\u3048\u3001\u6c7a\u3081\u30dd\u30fc\u30ba\u3092\u3068\u308b\u3053\u3068\u3067\u9b54\u6cd5\u306e\u52b9\u679c\u3092\u5f37\u5316\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u72b6\u6cc1\u306b\u5fdc\u3058\u3066\u3001\u3055\u307e\u3056\u307e\u306a\u546a\u6587\u3092\u4f7f\u3063\u3066\u30d0\u30c8\u30eb\u306b\u52dd\u5229\u3057\u307e\u3057\u3087\u3046\u3002\n\n#  AI \u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u3068\u306e\u5bfe\u8a71\n3D AI\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u3068\u306e\u97f3\u58f0\u306b\u3088\u308b\u4f1a\u8a71\u3092\u697d\u3057\u307f\u307e\u3057\u3087\u3046\uff01\n\u3053\u306e\u30b2\u30fc\u30e0\u306e\u30c1\u30e5\u30fc\u30c8\u30ea\u30a2\u30eb\u3067\u306f\u3001\u30b2\u30fc\u30e0\u306b\u3064\u3044\u3066\u3092\u5b66\u3076\u3060\u3051\u3067\u306a\u304f\u3001Akpala\u306b\u3064\u3044\u3066\u30ac\u30a4\u30c9\u3057\u3066\u304f\u308c\u308b\u3001AI\u6280\u8853\u3092\u6d3b\u7528\u3057\u305f\u30ad\u30e