8_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L1I19d19euEQ7kNvgEK5bin&_nc_ht=scontent.oculuscdn.com&oh=00_AYCcmlBjrMXin-y6Q-hREMScR1VBTQjgSFXKy4reka76gw&oe=66CF15F2"}, {"file_name": "4 akpala-screenshots.png", "id": "300523432971899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035411_300523436305232_9048662689807847515_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TTVrUZFo0n4Q7kNvgFLwX-W&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSwuwqYM9cd99YMNrqPosDEWikpg_b_FsoBZ0vNn74bw&oe=66CF2298"}, {"file_name": "2 akpala-screenshots.png", "id": "871536691642396", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974671_871536698309062_8519694922450412299_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_J-xU7cdzlsQ7kNvgFHiUaf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJvkrnzInVE4Ekt_MraJuczns_F2x_98qub2xHFTfk3w&oe=66CF0A0A"}, {"file_name": "1 akpala-screenshots.png", "id": "1860918744341108", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982603_1860918747674441_837857210029328855_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ut5G_-gVVhIQ7kNvgEH0ooK&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUxflRg2iMa1s1XKRA4tXoIlWZucuZQUDyFmig6WKW7g&oe=66CF1969"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AkpalaPV_1.png", "id": "344506461906490", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982706_344506465239823_8632136906973913159_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mbw6Cbka1IwQ7kNvgE6p3sl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAylzpWLlPl36LTVTiuMwSVwg3ZWYP9tkSdgQtdqRL-fQ&oe=66CEF3D4"}, "display_name": "Akpala", "keywords": [], "long_description": "\n\n# VOICE MAGIC ACTIVATION\n\nCast spells by chanting, and striking heroic poses for enhanced magic effects. Learn and perform different spells according to the needs of the battle. Movement, strategic thinking and resource management are crucial in every duel! Be sure that you use every tool in your arsenal.\n\n{1176736497103531}\n\n\n# AI CHARACTER CONVERSATIONS\n\nEngage in voice-based communication with 3D AI characters! During the tutorial stages, you will not only be able to learn everything about the game but also 'chit-chat' with the character that is guiding you with AI-generated conversations. Be sure that you don't get captivated by Lukia and actually finish the tutorial!\n\n{912634733949310}\n\n# GAME HIGHLIGHTS\n\nSupports up to four players in multiplayer mode with 1v1 or 2v2 team battles and battle royales. Grab your partner or join solo with our matchmaking feature and get to play with other Wizards from all around the world.\n\n{1450985992470893}\n\nIn multiplayer, strategically create and place blocks on the stage to build advantageous positions or snipe from above. These blocks can make a huge difference in different scenarios. Need to go higher? Build a ladder! Plain battleground? Create some cover!\n\n{1484220565855393}\n\nTake advantage of different perks and jumping-pads to move through the battlefield. Collect black orbs that yield random outcomes and mana orbs to keep casting your spells.  Flex your wits, move your body, and chant magic loudly on the battlefield!\n\n{465384995949128}\n", "short_description": "Don't you want to play a magical battle, chanting magic with your voice in VR space? A thrilling action game that offers three new experiences like never before has arrived! Multiplayer VR game for up to 4 players, featuring 2v2 team battles and a battle royale mode."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xpraize.com/index.php/terms-of-use/", "developer_terms_of_service_url": null, "publisher_name": "https://twitter.com/AkpalaVR_en", "support_website_url": null, "website_url": "https://www.akpala-vr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7834275969988498"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_671544121602270_8073429376038631190_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u0Ob9AjGSV0Q7kNvgGX1G4T&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFVjSyUllSw57-QWmB3rMFwA7PRkpBz5EdefR_f6K2pw&oe=66CF1FC4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Akpala", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Battle Royale", "id": "889588098232891"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1695985200, "lastRevision": {"nodes": [{"id": "5926605347422246", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5926605344088913", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "7366311503391186"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "874415630317026", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Akpala", "keywords": [], "long_description": "\u30a4\u30f3\u30c7\u30a3\u30fc\u30ba\u30b2\u30fc\u30e0\u4f1a\u793eRedefineArts\u304c\u958b\u767a\u3057\u305fVR\u30b2\u30fc\u30e0\u300eAkpala\u300f\u306f\u9b54\u6cd5\u8a60