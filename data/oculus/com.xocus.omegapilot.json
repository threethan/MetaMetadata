om/v/t64.5771-25/39031330_500252738288021_6504378647134435343_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yZggHMM4Z4EQ7kNvgH0_h3B&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQmZGuDXYrFUTfJfv6zpHotLiwr2cfeVspGNvJN2TKew&oe=66CDAAA0"}, {"file_name": "S2.png", "id": "401309358333608", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974504_401309368333607_3140522348943701099_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kBW14H6pM08Q7kNvgHUx7dH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGZ8cp6I2mhGe-BK7XNgob2D6lc3nLNi6XGiR_UBd9rQ&oe=66CDC3E7"}, {"file_name": "S4.png", "id": "3219237551732021", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982553_3219237555065354_2848504715724959393_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xZEVdBNHeFIQ7kNvgHEHuiB&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGDxhbOudIDhtZTbyEQwM3aDIdwGyvTTFIeVQPXFCUug&oe=66CDB601"}, {"file_name": "S3.png", "id": "335910751866869", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_335910755200202_8416459498474949487_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3cyUH-ElmugQ7kNvgGIB3QH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzqx1yopyldftSjNZ_AbmvGe0RUVYftg3MIJ9Y0f4C_g&oe=66CDD0D3"}, {"file_name": "S5.png", "id": "3130597270595060", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031372_3130597280595059_3037881579099271786_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mNZsBN6CsI0Q7kNvgFOhKjW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDa5M6C-XlpqxNtLRa86nTPCQfpgVftGgwdmXnIfxwPJQ&oe=66CDBB64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover.png", "id": "1127578171115224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035365_1127578174448557_300400251191567525_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xxJ2Rl79_k8Q7kNvgH36Iw-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCI7nFnqejFaTvO9ZG7RRm5y7W9clwmxIT0Jw6wLMTipg&oe=66CDA941"}, "display_name": "Omega Pilot", "keywords": [], "long_description": "Know thyself, & live on the edge!\n\nBecome the best - become an Omega Pilot! Do you like first-person racing? If so, then this virtual world is for you.\n\n- Compete for in-ring races with other pilots in asynchronous multiplayer, which will identify the best among equals.\nHone your skills and reach maximum speed. Don't miss the chance to surpass yourself and improve your time on the track. Become the fastest.\n\n- Stand out not only by the results but also by the unique customization of your \"Air Bollid\".\n\n- Enjoy the view from the cockpit and its interior, as you immerse yourself in advanced polygonal graphics.\n\n- Participate in regular events with prizes, and get ready for constant content updates.\n\nJoin the league. Become an Omega pilot!", "short_description": "Omega Pilot is an exciting first-person VR racing game with realistic physics and control mechanics. Compete for in-ring races with other pilots in asynchronous multiplayer and enjoy the view from the cockpit at high speed!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xocus.co/privacy-policy-eng", "developer_terms_of_service_url": null, "publisher_name": "XOCUS", "support_website_url": null, "website_url": "https://xocus.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "RACING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "992137828349307"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "443165170908881"}]}, "baseline_offer": {"id": "443165170908881"}, "is_approved": true, "firstOffer": {"nodes