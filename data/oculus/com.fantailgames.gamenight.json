ontent-ams4-1.oculuscdn.com&oh=00_AYCUrxtXbEgYJr_bsgdEqswdyUBR2nohFXCSjWkLiIaGMQ&oe=675D6294"}, {"file_name": "Screenshot1.png", "id": "1095471751421767", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974879_1095471754755100_4139716018714587894_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_S-p4ljCO6IQ7kNvgHrOcNK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBZMCpFoC0abprnVMrKrBVv3qqCZsfbkN5R2GH8pRFxag&oe=675D74DC"}, {"file_name": "Screenshot2.png", "id": "1269718507781466", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001727_1269718511114799_4049486010738995088_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzMMjr1ULuUQ7kNvgENv_tA&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAESEYqScbXKTd2xdo6KYsZdJuXZRhG90GZYcxlqCPUlg&oe=675D6FB2"}, {"file_name": "Screenshot3.png", "id": "502703552730574", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974463_502703556063907_7418726509708352419_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O6w-YMTYsFIQ7kNvgFI7M_m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDdWX_SFeOpPhrXX21GC5ruOmy7JIaGnPm6OEbami0vrA&oe=675D7CF8"}, {"file_name": "Screenshot4.png", "id": "459311616671184", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031447_459311620004517_7580658906980873012_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BCJZJ7GFApQQ7kNvgHgKYEc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCcYNjMAjMlOG3a78XO7OES2XZRWLSlAV3OyJ3oQqwfYQ&oe=675D7C9C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Game Night", "keywords": ["party", "family", "multiplayer", "MR", "minigame"], "long_description": "# Local Multiplayer Mayhem\nInvite your friends and family to bring their Quest to yours for the ultimate party experience! **Play together** in person with **up to four players**. With **competitive and cooperative** play it suits everyone from teens to grandparents. It'll bring any event to life from birthday parties to team building exercises.\n\n**Online multiplayer is not supported** as everyone's rooms are different sizes and shapes. Plus there\u2019s just no substitute for playing together in person!\n\n\n# Single Player Mastery\nOnly have one headset? No worries, **perfect your skills in single player**. Each minigame has **hidden strategies** to learn. Beat your personal best and give yourself the edge for the next party.\n\n\n# Get Physical\n**Move fast** comfortably and safely (no more standing on the cat or punching the wall)! **Your body is the controller!** Use your hands, head, body and even your voice to interact with the game and your friends. Play hard and feel the burn.\n\n\n# No motion sickness\nIn MR, you\u2019re moving, not the world so your body doesn\u2019t get confused. With the Quest 3, **even the most prone can play** without risk of feeling rough. If they don\u2019t believe you, say I said it\u2019ll be ok.\n\n\n# Join the community\nJoin our discord to share your ideas or to find other players in your community.\nhttps://discord.com/invite/mDWR7yjXy4 \n\n\nAvailable on Quest 3, Quest 3S, Quest Pro, and Quest 2.", "short_description": "Run around your lounge together playing your favorite party games imagined to life around you in Mixed Reality.\n\nMaster minigames solo, or invite friends and family around for the ultimate party! Combining the best that board games and sports have to offer you\u2019ll test your mind and body. With cooperative and competitive play there is something for everyone from teens to grandparents. \n\nJoin us on our Early Access journey. Together we will make Game Night the best MR game on Meta Quest!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fantailgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fantail Games", "support_website_url": null, "website_url": "http://www.fantailgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [],