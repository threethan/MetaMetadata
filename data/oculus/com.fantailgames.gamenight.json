aKRXhclmUQ7kNvgGhAX-J&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBbJZgwCYjPBrZ7EK9X5u5z3hujJwTcQ6W_0qkXE3guDw&oe=675D607D"}]}, "id": "3973470942886152", "locale": "en_US", "screenshots": [{"file_name": "Screenshot5.png", "id": "907177008020445", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75299164_907177011353778_5280054790589429898_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ov9hzxILzYMQ7kNvgHWY8ik&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCUrxtXbEgYJr_bsgdEqswdyUBR2nohFXCSjWkLiIaGMQ&oe=675D6294"}, {"file_name": "Screen_019.png", "id": "1070783707576508", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003279_1070783710909841_199959542905015444_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PIluXB9tY3kQ7kNvgGAQHuP&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBYNv2gVvpJqk1BcSupFbHXKznAhWv2JgMQlDFL6_DgLg&oe=675D6E36"}, {"file_name": "Screenshot2.png", "id": "1269718507781466", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001727_1269718511114799_4049486010738995088_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzMMjr1ULuUQ7kNvgENv_tA&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAESEYqScbXKTd2xdo6KYsZdJuXZRhG90GZYcxlqCPUlg&oe=675D6FB2"}, {"file_name": "Screenshot4.png", "id": "459311616671184", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031447_459311620004517_7580658906980873012_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BCJZJ7GFApQQ7kNvgHgKYEc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCcYNjMAjMlOG3a78XO7OES2XZRWLSlAV3OyJ3oQqwfYQ&oe=675D7C9C"}, {"file_name": "Screen_021.png", "id": "580523744668650", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003279_580523748001983_1218228659238312840_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oH7wmDuzzRYQ7kNvgFz56Ip&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBtKQ9nlg_BtQ5rZiV-xHtJMlOSBl8B5SpaF4G8SfZq6g&oe=675D64FD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "GameNight_TrailerCover.png", "id": "500771792959754", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974827_500771796293087_8338939001463420116_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNEqPSHCQukQ7kNvgHKuMMR&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAQ8NfSkAEpK9yYd0ICn50gbc2-70F_aBscYTqvSV77Kw&oe=675D79F7"}, "display_name": "Game Night", "keywords": ["party", "family", "multiplayer", "MR", "fishing"], "long_description": "Perfect your skills in single player or invite your friends and family around for the ultimate party experience. Run around your room playing a range of quirky party games imagined to life in Mixed Reality.\n\u200e\n\n{1290463558797181}\n# Get Physical\n**Move fast** comfortably and safely (no more standing on the cat or punching the wall)! **Your body is the controller!** Use your hands, head, body and even your voice to interact with the game and your friends. Play hard and feel the burn.\n\n\n\u200e{1401523864418127}\u200e  \n# No motion sickness\nMixed Reality is the solution to motion sickness as your body is used to moving in the real world (not virtual ones).\n\n\n# Single Player Mastery\nOnly have one headset? No worries, **perfect your skills in single player**. Each minigame has **hidden strategies** to discover. Beat your personal best and get the edge for your next party.\n\n\n{1310998346926070}\n# Local Multiplayer Mayhem\nInvite your friends and family to bring their Quest to yours for the ultimate party experience! **Play together** in person with **up to four players**. With **competitive and cooperative** play it suits everyone from teens to grandparents. It'll bring any event to life from birthday parties to team building exercises.\n\n**Online multiplayer is not supported** as everyone's rooms are different sizes and shapes. Plus, there\u2019s no substitute for playing together in person!\n\u200e\n\n# Join the community\nJoin our discord to share your ideas or to find other players in your community\nhttps://discord.com/invite/mDWR7yjXy4 \n\u200e\n\nAvailable on Quest 3, Quest 3S, Quest Pro, and Quest 2", "short_description": "Perfect your skills in single player or invite your friends and family around for the ultimate party experience. Run around your room playing a range of quirky party games imagined to life in Mixed Reality!\n\nCombining the best of board games and sports, you\u2019ll test your mind and body. With cooperative and competitive play there's something for everyone from teens to grandparents. \n\nJoin us on our Early Access journey. Together let's make Game Night the best MR game on Meta Quest!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fantailgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fantail Games", "support_website_url": null, "website_url": "http://www.fantailgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8764128450288999"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035325_2266427097049610_4386362131965964202_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9eYpVnyOhcoQ7kNvgE3R3s8&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAHUGfWOLSF8KduUyqX-LKXv4k9VsqSdJs6k3GvI