_1170244933827814_4656475279881341835_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aAaO8XWPl44Q7kNvgE7hEdv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCv4xi3RaQFJAzGt6Tx5OdHroBFEFa3yJ8BAW9tMKo5XQ&oe=674D97A0"}, {"file_name": "4.png", "id": "2201844739983391", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974901_2201844749983390_9196565263099690180_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pH_bIWcvJY8Q7kNvgGV23f6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDW_YBUnpWgC1LsMRJ4YJ3QjS-CU6BMbnK19gjcrbWTEQ&oe=674DB4F5"}, {"file_name": "1.png", "id": "331212599075763", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974892_331212602409096_6698097928821038148_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vdnuLWbYecYQ7kNvgEFW4FY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB4xO8J0vWZx4dJD2gnbNxtePF_3zGz5faKyXyCQ-vXzg&oe=674D8919"}, {"file_name": "2.png", "id": "373910241510506", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_373910244843839_7165825484083273138_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EP-H-HVkgh4Q7kNvgFVa0bS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCG1ykvgDHQcEXaC9W54HfxGBNoFEFGAqPJQsZyPsPHxA&oe=674DB94D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Thunder Gladiator - Fighting Game", "keywords": [], "long_description": "In this game you can play with the best clans of gladiators.\nGo to the armory and take your sword with a sharp blade. Put your sandals on and step in where your adventure begins in the best fighting and strategy game.\nThis is the unique strategy game where you can show your skills to all gladiator clans.\nUse tactically adventitious war strategy to beat your enemies. Some of them could be iron strong Apply stealth to defeat them. Level-up your characteristics and evolve into the best warrior.\n", "short_description": "It\u2019s time to attack! Become the master of the Thunder Gladiator."}]}, "deve