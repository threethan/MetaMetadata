[], "long_description": "You can practice with different weapons like Bow/Arrow, Spear, Sword and Shield etc. Once you are ready to fight, take a direct one vs one challenge to fight a gladiator or enter the Arena where you fight a wave of different kind of fighters.\n\nThe game is still in development and we are continuously improving the fighting AI and graphics. So stay in touch and look for our frequent updates.\n\nThe story mode in the games lets you find your way in an underground tunnel to find and rescue the king and while fighting the enemies, lead the king back to his throne.\n\n", "short_description": "Fight one to one by a Sword and a shield or take the challenge to defend yourself in an Arena or save the king in story mode with different weapons and types of enemy."}]}, "developer_name": "XZ Solutions", "developer_privacy_policy_url": "https://skippyapps.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Skippy Apps PTY LTD.", "support_website_url": null, "website_url": "https://skippyapps.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26691173510531018"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422395_762223355821106_5199826812587160372_n.png?stp=dst-png_s360x360&_nc_cat