jrLNMP6D&oh=00_AYBLb-agh1asFNSBzTQbpNwlO_162u1D1TMRZY96VAF6Jg&oe=66F3E2EC"}, {"file_name": "9.png", "id": "1024907445979964", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221317_1024907449313297_2012196129282985897_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JFDf55tJBaEQ7kNvgE76Aj7&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1kERHT_NznHdwjrLNMP6D&oh=00_AYD5eICqfKgyr0r06m9qpPBT-1yIi-EIjk2OvjteHTq3nA&oe=66F3F257"}, {"file_name": "3.png", "id": "504245975671448", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001673_504245979004781_7628018720807492137_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bryFCGiQ2CEQ7kNvgH0SZaV&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1kERHT_NznHdwjrLNMP6D&oh=00_AYB7QkOPVlC0jvz6GNlez55s_VpqIUviebdjbxZnLSYolw&oe=66F3F27A"}, {"file_name": "2.png", "id": "1050493172698463", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974508_1050493179365129_2688386042649854639_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sO5WGIXXP0kQ7kNvgFim0XO&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1kERHT_NznHdwjrLNMP6D&oh=00_AYDR8Hhx_FrzCSp0Tmad3yWiN0RxAPejXg3u-qJzMEXA8w&oe=66F3EFDE"}, {"file_name": "1.png", "id": "893186809331037", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75439594_893186812664370_3406911142599199308_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q7Nvodnb-LwQ7kNvgGwiQsE&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1kERHT_NznHdwjrLNMP6D&oh=00_AYCTG-LSqLCYkCiDHSScxAMOZwfGxJ2Ib2t-b5mxc2PABw&oe=66F3F545"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Thunder Gladiator - Sword Fighting Game", "keywords": ["sword", "fighting", "gladiator", "action", "horror"], "long_description": "You can practice with different weapons like Bow/Arrow, Spear, Sword and Shield etc. Once you are ready to fight, take a direct one vs one challenge to fight a gladiator or enter the Arena where you fight a wave of different kind of fighters.\n\nThe game is still in development and we are continuously improving the fighting AI and graphics. So stay in touch and look for our frequent updates.\n\nThe story mode in the games lets you find your way in an underground tunnel to find and rescue the king and while fighting the enemies, lead the king back to his throne.\n\n", "short_description": "Fight one to one by a Sword and a shield or take the challenge to defend yourself in an Arena or save the king in story mode with different weapons and types of enemy."}]}, "developer_name": "XZ Solutions", "developer_privacy_policy_url": "https://skippyapps.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Skippy Apps PTY LTD.", "support_website_url": null, "website_url": "https://skippyapps.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26816909607957407"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422395_762223355821106_5199826812587160372_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C6T0hnbkvMAQ7kNvgG14QuJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1kERHT_NznHdwjrLNMP6D&oh=00_AYBYzEie8TPsv1c_fenh5VZ4A_yKBR6cOtZdFm9cawz8lg&oe=66F3E59C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Thunder Gladiator - Sword Fighting Game", "platform": "ANDROID_6DO