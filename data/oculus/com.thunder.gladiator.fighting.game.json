_1170244933827814_4656475279881341835_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K5bg9aI_uIoQ7kNvgE5JK_p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhqKfaVsvOzww6e401T6twbVQOW3BN2C-gJsB-G6348g&oe=6749A320"}, {"file_name": "4.png", "id": "2201844739983391", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974901_2201844749983390_9196565263099690180_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5R1kepb_uY8Q7kNvgGP5dxf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4a2auQ8_FuJSV8J5nLf0RDsIf0x38O4lQQcBwcGYIag&oe=6749C075"}, {"file_name": "1.png", "id": "331212599075763", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974892_331212602409096_6698097928821038148_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OQRYjZK34-0Q7kNvgGuJc_p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2gwIJRNMuKy_C-TFd1DkLeyglycFm_yfSXoytHk_oLw&oe=67499499"}, {"file_name": "2.png", "id": "373910241510506", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_373910244843839_7165825484083273138_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=49HQ3Eo2ey0Q7kNvgGIh-wd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDX0KzJEo25aO9GebrEHBI4JykLTK6yjUQN-P8Swg30FA&oe=6749C4CD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Thunder Gladiator - Fighting Game", "keywords": [], "long_description": "In this game you can play with the best clans of gladiators.\nGo to the armory and take your sword with a sharp blade. Put your sandals on and step in where your adventure begins in the best fighting and strategy game.\nThis is the unique strategy game where you can show your skills to all gladiator clans.\nUse tactically adventitious war strategy to beat your enemies. Some of them could be iron strong Apply stealth to defeat them. Level-up your characteristics and evolve into the best warrior.\n", "short_description": "It\u2019s time to attack! Become the master of the Thunder Gladiator."}]}, "deve