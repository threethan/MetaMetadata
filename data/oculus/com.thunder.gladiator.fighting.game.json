vIQ7kNvgFQpLur&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAt0w7Gb_0bCK7iYOT9CB4D7REyBMdZbdUGGDoillE1Iw&oe=673087EC"}, {"file_name": "9.png", "id": "1024907445979964", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75221317_1024907449313297_2012196129282985897_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=12iQWYattzMQ7kNvgEkMivK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB45lNwvCoW0W2QDVGVrfl0YoTluGtt0ryLSRcS3j2M0g&oe=67309757"}, {"file_name": "3.png", "id": "504245975671448", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001673_504245979004781_7628018720807492137_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3pWftuUq_OgQ7kNvgHl-ZL3&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA9oSFbjtuuYvfkI0tv9iiCOscJBmJTfNoiMCiKzIDdZg&oe=6730977A"}, {"file_name": "2.png", "id": "1050493172698463", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974508_1050493179365129_2688386042649854639_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_HAWXnqwdu4Q7kNvgEZdQM6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCIM7ZcVmgncORZBr2lhyf2YnyTOUpXq2Fjdv2SM30_Yw&oe=673094DE"}, {"file_name": "1.png", "id": "893186809331037", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75439594_893186812664370_3406911142599199308_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SLF1rKoaxqgQ7kNvgH7jnr6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCzvsUMlCYgaD6A9TX38EYgijVRPJPu4f8K8b3E1GLG9Q&oe=67309A45"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Thunder Gladiator - Sword Fighting Game", "keywords": ["sword", "fighting", "gladiator", "action", "horror"], "long_description": "You can practice with different weapons like Bow/Arrow, Spear, Sword and Shield etc. Once you are ready to fight, take a direct one vs one challenge to fight a gladiator or enter the Arena where you fight a wave of different kind of fighters.\n\nThe game is still in development and we are continuously improving the fighting AI and graphics. So stay in touch and look for our frequent updates.\n\nThe story mode in the games lets you find your way in an underground tunnel to find and rescue the king and while fighting the enemies, lead the king back to his throne.\n\n", "short_description": "Fight one to one by a Sword and a shield or take the challenge to defend yourself in an Arena or save the king in story mode with different weapons and types of enemy."}]}, "developer_name": "XZ Solutions", "developer_privacy_policy_url": "https://skippyapps.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Skippy Apps PTY LTD.", "support_website_url": null, "website_url": "https://skippyapps.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26816909607957407"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75422395_762223355821106_5199826812587160372_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_4rPkEwGeuMQ7kNvgGvpVDp&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBsoU6833bYHaAaOKuuPwEA2-svAKVhpMo0gJjlwd0bKA&oe=67308A9C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Thunder Gladiator - Sword Fighting Game", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GA