ideo_trailer_thumbnail": {"file_name": "VIDEOCOVER.png", "id": "910405713797165", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982613_910405717130498_7165191762179409940_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yRawLJiEbDAQ7kNvgHDM5Za&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbEh6EssOygSRCKYz8CP-trWfLmy_VM-XNnZKaU2NRqg&oe=6749B735"}, "display_name": "Egg VR", "keywords": [], "long_description": "As you travel through oversized air ducts and sprawling kitchen landscapes, the ordinary becomes extraordinary. Each room is a playground, and every object a potential obstacle or hiding spot. Playing with friends becomes a thrilling chase; run from fellow egg adventurers or become the hunter, using your wits and agility to outsmart your friends. Experience the thrill of movement in a magnified world as you navigate through obstacles and climb steep cabinets in Egg VR.\nHowever, Egg VR is not merely a game of pursuit. This game offers more than just entertainment; it's a social platform where you can interact with players from around the world. Join a virtual kitchen turned jungle or create a private room to play with friends. Whether you are looking for excitement or just want to relax and chat, this game is designed to help you make connections and create lasting memories.", "short_description": "Embark on a wild multiplayer adventure in Egg VR! Crawl through oversized air ducts as an egg and explore giant kitchen landscapes with your friends. Dodge high obstacles and customize your character with unique cosmetics in this egg-exciting social playground. Where will your tiny adventures take you?"}]}, "developer_name": "IRONHEAD Games", "developer_privacy_policy_url": "https://futureofvr.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "FutureOfVR", "support_website_url": null, "website_url": "https://futureofvr.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_categor