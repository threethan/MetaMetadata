 [{"file_name": "1.png", "id": "782933057236472", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75223483_782933060569805_5887700456127224365_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=43UWi4VSOSgQ7kNvgFXzotu&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBUMIQvQg4DeU7IiG_xhM97bYsRGwZCz-yE46Z0-B6C1A&oe=677BB9A9"}, {"file_name": "2.png", "id": "1216657149555384", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974792_1216657152888717_2424814744076244782_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rDyMEHYfeQYQ7kNvgFiu0dx&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBQrHbkNwaQ8GDibBFVOzp-HboL8oBlBUHMGRYB0ghZSA&oe=677BBB41"}, {"file_name": "3.png", "id": "861918439420852", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75630188_861918446087518_6434351243388159362_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=76z1WdtVxOAQ7kNvgFsvcoa&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA-VxqhCCNHPFoH0EOmTaMWQBNp1VbR8T1lIYIoB6e30w&oe=677BD33B"}, {"file_name": "4.png", "id": "1713875726046304", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75422373_1713875729379637_8482830925162593121_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LyIqG9kGaqkQ7kNvgEMDx0n&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCW2cT-F1KDWN64OBgEk-OO0_1zH7BFYhT6XDtFivV0OA&oe=677BA741"}, {"file_name": "5.png", "id": "1708342893256093", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001725_1708342896589426_2665100175518478568_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B6tZ4HzRvqQQ7kNvgHtrwun&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCWS8_BRcQ0Tm-iQEN3tSoqd12GxvuiBNz19h6W-T8J2Q&oe=677BB44B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Copy of Cover Landscape (1).png", "id": "855052066699068", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75395591_855052073365734_7729926575953612792_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w23ePHfynx4Q7kNvgEQPosZ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDZNlXo2Ubi9iZRhCwpJYMVoqoKRqk2XlMLlzFmmW2rsQ&oe=677BD951"}, "display_name": "Egg VR", "keywords": ["gorilla", "fangame", "monkey", "eggvr", "egg"], "long_description": "Reject Reality and Become an Egg!\n\nRun, climb, and jump in VR using a unique locomotion method inspired by Gorilla Tag. This method only requires the movement of your hands and arms. No buttons, no sticks, no teleportation. Push off surfaces to jump and squeeze them with both hands to climb.\n\nCurrently, there is one game mode called Smash mode where one egg has to reach other eggs, but soon, there will also be shooter mode, hunt mode, infection mode, casual mode, and horror mode.\n\nUsing the Smash mode, you can play different mini-games such as:\n\n- Hide and Seek\n- Sharks and Minnows\n- Ghost in the Graveyard\n- Monkey on the Shelf\n\nRun from the other eggs or outmaneuver the survivors to catch them. Parkour up kitchen objects and cliff cupboards to evade and chase down eggs. The movement is easy to learn but hard to master.\n\nCurrently, there are 3 maps to explore: Kitchen, Horror, and Speedrun!\n\nVisit the Egg Store in the kitchen, where you can buy, play with, and wear to express your true nature.\n\nBecome an Egg!", "short_description": "Reject Reality and Become an Egg!"}]}, "developer_name": "IRONHEAD Games", "developer_privacy_policy_url": "https://futureofvr.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "FutureOfVR", "support_website_url": null, "website_url": "https://futureofvr.games/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": nu