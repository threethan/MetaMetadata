3158050_6148223050477784806_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SxUk_7yAOpEQ7kNvgHUFge9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQi9J2DJ2mfyP-aQx3qsfnMkugA2hv5H3P9W8y-focBg&oe=6741C161"}, {"file_name": "SCR1.png", "id": "2032042583863286", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86610714_2032042587196619_6781272509647889245_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X5c44VnnITIQ7kNvgGYOYzj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFzS56HQHlthGj7P6raYfC5PYleU6Br5PUf2kvbrs6bQ&oe=6741CB5D"}, {"file_name": "SCR5.png", "id": "911001180553401", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75223482_911001183886734_8320042508041395063_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EWBT3B5ayMYQ7kNvgE2FYm4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwdLvb4CxsCyHiMqalbEbsSk_1RX8iOsITZBBG4_cyAw&oe=6741B341"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VIDEOCOVER.png", "id": "910405713797165", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982613_910405717130498_7165191762179409940_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q8q0tUFbF6AQ7kNvgEbVAUe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJpNNXevbd4FIBT8AtLR-NBiESlS3X40hNL6RpUKFz3A&oe=6741CE35"}, "display_name": "Egg VR", "keywords": [], "long_description": "As you travel through oversized air ducts and sprawling kitchen landscapes, the ordinary becomes extraordinary. Each room is a playground, and every object a potential obstacle or hiding spot. Playing with friends becomes a thrilling chase; run from fellow egg adventurers or become the hunter, using your wits and agility to outsmart your friends. Experience the thrill of movement in a magnified world as you navigate through obstacles and climb steep cabinets in Egg VR.\nHowever, Egg VR is not merely a game of pursuit. This game offers more than just entertainment; it's a social platform where you can interact with players from around the world. Join a virtual kitchen turned jungle or create a private room to play with friends. Whether you are looking for excitement or just want to relax and chat, this game is designed to help you make connections and create lasting memories.", "short_description": "Embark on a wild multiplayer adventure in Egg VR! Crawl through oversized air ducts as an egg and explore giant kitchen landscapes with your friends. Dodge high obstacles and customize your character with unique cosmetics in this egg-exciting social playground. Where will your tiny adventures take you?"}]}, "developer_name": "IRONHEAD Games", "developer_privacy_policy_url": "https://futureofvr.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "FutureOfVR", "support_website_url": null, "website_url": "https://futureofvr.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7275543395800660"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "363429549830841"}]}, "baseline_offer": {"id": "363429549830841"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1707930360, "status": "PUBLISHED", "id": "363429549830841"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8897314983623485", "version": "0.0.6.05.25"}, "id": "771445231