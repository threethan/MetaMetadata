F05JaOKoMhpX3YlNY_zfCT3drw&oe=671B6DBA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d4wPsYjstwIQ7kNvgGP7bbB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBno9o36pqKinXSpG19rl-UJfD1EOPxnrfXYevS4QyiZA&oe=671B849A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "We can't save the world alone, the OSA needs you soldier - enlist NOW by wishlisting Zero Caliber 2 in the Meta Quest store! \n\n### THE SEQUEL ###\n\nYour favorite all-in-one VR FPS made infinitely better! Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter! \n\nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign (taking place after the events of the prequel), PvP, native mod support, zombies, airstrikes, more explosions and a VR experience you'll never forget! \n\nComing to your Meta Quest in 2024.\n\n### COMMUNITY ###\n\nTo participate in future playtests, catch sneak peeks and behind the scenes, join our awesome community on Discord: \n-> discord.gg/xrealgames <- \n\nAnd follow us on: \n- Facebook: https://www.facebook.com/XREALGamesVR\n- X: https://twitter.com/ZeroCaliber2\n- YouTube: https://www.youtube.com/@XREALGamesVR\n- TikTok: https://www.tiktok.com/@xrealgames ", "short_description": "Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to the critically acclaimed Zero Caliber: Reloaded military shooter! \nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign, PvP, airstrikes, more explosions and a VR experience you'll never forget! Coming in 2024."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "6870927629610029"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PUBLISHED", "id": "2480558915447893"}, {"status": "PUBLISHED", "id": "3759425570937326"}, {"status": "CANCELLED", "id": "1154828208959434"}, {"status": "CANCELLED", "id": "1886402775170665"}, {"status": "PUBLISHED", "id": "327678677059354"}, {"status": "PUBLISHED", "id": "887973006433190"}, {"status": "PUBLISHED", "id": "471795258715892"}, {"status": "PUBLISHED", "id": "1573074710181700"}, {"status": "PUBLISHED", "id": "295941446563126"}]}, "baseline_offer": {"id": "327678677059354"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729364400, "status": "PUBLISHED", "id": "2480558915447893"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8293420300694081", "version": "ZC2-1.1-926"}, "id": "789743115693153", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBina