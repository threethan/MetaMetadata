vgFnXfwh&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAHjcjY0F3TTlQ4FBLm41fW0uWpnw_SqnG8xYkhn8NwTQ&oe=6728CCBA"}, {"file_name": "ZeroCaliber2_Screenshot02.png", "id": "2097802907236337", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974505_2097802910569670_2985437567014530766_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=owpWhyvooucQ7kNvgFQAsJq&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAspvId4ZHWR_LBNx3u2Z7pJewh0afdq32M4xykEBIfhQ&oe=6728A268"}, {"file_name": "ZeroCaliber2_Screenshot03.png", "id": "195746533533355", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/38974919_195746536866688_6980383296141980473_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yqG-HT3FpRwQ7kNvgHKzT0s&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYCq2A8L-rvecO1Q8aAS05B_NS-KIz75mrlZIxq8qc0pbQ&oe=67289A18"}, {"file_name": "ZeroCaliber2_Screenshot04.png", "id": "798871275584847", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974614_798871278918180_1423763732982701246_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VEv65b5qMtAQ7kNvgH5wnoQ&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBleM1dpi1UyOSr0J54B47zGVkqJaYRZB008t74qFI9uQ&oe=6728C26B"}, {"file_name": "ZeroCaliber2_Screenshot05.png", "id": "239766985659915", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/75334066_239766988993248_484809953301683563_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ErsHAt5IwnkQ7kNvgFMOXa6&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDbrI9yutTjmq9oSjmIzih8KIJ8UlJQEgdYGCzxJQwv5A&oe=67289CBA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lMloI4RNXnMQ7kNvgGG-AYT&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCeIIIyV3Uw1wS9IuYY8yWRimJM1iV1XXYiLlbbLAmXVw&oe=6728B39A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "We can't save the world alone, the OSA needs you soldier - enlist NOW by wishlisting Zero Caliber 2 in the Meta Quest store! \n\n### THE SEQUEL ###\n\nYour favorite all-in-one VR FPS made infinitely better! Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter! \n\nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign (taking place after the events of the prequel), PvP, native mod support, zombies, airstrikes, more explosions and a VR experience you'll never forget! \n\nComing to your Meta Quest in 2024.\n\n### COMMUNITY ###\n\nTo participate in future playtests, catch sneak peeks and behind the scenes, join our awesome community on Discord: \n-> discord.gg/xrealgames <- \n\nAnd follow us on: \n- Facebook: https://www.facebook.com/XREALGamesVR\n- X: https://twitter.com/ZeroCaliber2\n- YouTube: https://www.youtube.com/@XREALGamesVR\n- TikTok: https://www.tiktok.com/@xrealgames ", "short_description": "Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to the critically acclaimed Zero Caliber: Reloaded military shooter! \nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign, PvP, airstrikes, more explosions and a VR experience you'll never forget! Coming in 2024."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "45978