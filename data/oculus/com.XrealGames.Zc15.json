80249003_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Miu-reLIRgIQ7kNvgFKSDAR&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB7jCJTPQV8qXWUY9hnm6_jzwXsUjWBWZ6RN3V0_ImepA&oe=6756F13A"}, {"file_name": "ZeroCaliber2_Screenshot02.png", "id": "2097802907236337", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974505_2097802910569670_2985437567014530766_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7n0uC223WWAQ7kNvgG7YOwG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBfD7omAKHG7A_D8CFAmstfSf5IibDor64PiIwtMMX3sA&oe=6756C6E8"}, {"file_name": "ZeroCaliber2_Screenshot03.png", "id": "195746533533355", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974919_195746536866688_6980383296141980473_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=stLspnIrLM8Q7kNvgGGWtyB&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBEFyI-MrJJcXqN8UJaKyMudlZIlDwFf9kaWqjoej_cJQ&oe=6756BE98"}, {"file_name": "ZeroCaliber2_Screenshot04.png", "id": "798871275584847", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974614_798871278918180_1423763732982701246_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P-shQqvg_MEQ7kNvgHY-gge&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBgfpRHvr0D-Igymy_dh5A0YTzYCeOWb1w9lvqqa1g0lQ&oe=6756E6EB"}, {"file_name": "ZeroCaliber2_Screenshot05.png", "id": "239766985659915", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75334066_239766988993248_484809953301683563_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j47lsW_9n7oQ7kNvgFc7cYJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDa-qCcltGfxejaMr77tSPUHGfrHqhOTkTi5hXnldNWHw&oe=6756C13A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N7MWyKoXcdIQ7kNvgEoq9KI&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCsUfL4oHtTbNMvMR6-lqvadxGveQ33MEV4fxQAZEiZWA&oe=6756D81A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "We can't save the world alone, the OSA needs you soldier - enlist NOW by wishlisting Zero Caliber 2 in the Meta Quest store! \n\n### THE SEQUEL ###\n\nYour favorite all-in-one VR FPS made infinitely better! Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter! \n\nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign (taking place after the events of the prequel), PvP, native mod support, zombies, airstrikes, more explosions and a VR experience you'll never forget! \n\nComing to your Meta Quest in 2024.\n\n### COMMUNITY ###\n\nTo participate in future playtests, catch sneak peeks and behind the scenes, join our awesome community on Discord: \n-> discord.gg/xrealgames <- \n\nAnd follow us on: \n- Facebook: https://www.facebook.com/XREALGamesVR\n- X: https://twitter.com/ZeroCaliber2\n- YouTube: https://www.youtube.com/@XREALGamesVR\n- TikTok: https://www.tiktok.com/@xrealgames ", "short_description": "Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to the critically acclaimed Zero Caliber: Reloaded military shooter! \nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign, PvP, airstrikes, more explosions and a VR experience you'll never forget! Coming in 2024."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category":