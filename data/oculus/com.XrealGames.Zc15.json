80249003_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PczCDzDxZKoQ7kNvgHj0kY_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDR-qWSKr0443my-0pEqenCcuDL4iqfWwKIlGByTrxUdg&oe=67617D3A"}, {"file_name": "ZeroCaliber2_Screenshot02.png", "id": "2097802907236337", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974505_2097802910569670_2985437567014530766_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OJVU7qx7LdUQ7kNvgGMIfkN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkokqmasr679vB_BIitxg38JTxQcCYOjBYVXhLWfOgZg&oe=676152E8"}, {"file_name": "ZeroCaliber2_Screenshot03.png", "id": "195746533533355", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974919_195746536866688_6980383296141980473_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N9w4Mw2-QZIQ7kNvgEWd5yV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-YtQ10Y5t9HTmjbarZQS6KHeCdnHy0RdKzGJW8DdA9g&oe=67614A98"}, {"file_name": "ZeroCaliber2_Screenshot04.png", "id": "798871275584847", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974614_798871278918180_1423763732982701246_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9yvNk8KD7RUQ7kNvgH_MJtH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOibvZwG9wS1xY_xmmADNhSjrF1tXlz5veTuiTfHzw-Q&oe=676172EB"}, {"file_name": "ZeroCaliber2_Screenshot05.png", "id": "239766985659915", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75334066_239766988993248_484809953301683563_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wi-_oPB81mwQ7kNvgGe-Vyg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQlHp9RGcLg1cnzme7COmFQuFUL1fl_tz5sBFEvS5T0w&oe=67614D3A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCLdcmLQQxwQ7kNvgGMg3_3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVjflI7kxYiJlWZ-GOOTBC5SL7DbKJ-Pe8CakE0GyfPg&oe=6761641A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "We can't save the world alone, the OSA needs you soldier - enlist NOW by wishlisting Zero Caliber 2 in the Meta Quest store! \n\n### THE SEQUEL ###\n\nYour favorite all-in-one VR FPS made infinitely better! Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter! \n\nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign (taking place after the events of the prequel), PvP, native mod support, zombies, airstrikes, more explosions and a VR experience you'll never forget! \n\nComing to your Meta Quest in 2024.\n\n### COMMUNITY ###\n\nTo participate in future playtests, catch sneak peeks and behind the scenes, join our awesome community on Discord: \n-> discord.gg/xrealgames <- \n\nAnd follow us on: \n- Facebook: https://www.facebook.com/XREALGamesVR\n- X: https://twitter.com/ZeroCaliber2\n- YouTube: https://www.youtube.com/@XREALGamesVR\n- TikTok: https://www.tiktok.com/@xrealgames ", "short_description": "Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to the critically acclaimed Zero Caliber: Reloaded military shooter! \nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign, PvP, airstrikes, more explosions and a VR experience you'll never forget! Coming in 2024."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category":