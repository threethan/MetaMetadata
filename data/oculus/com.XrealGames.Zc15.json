yjwMKE-_gveP0Rv9ZzGGXSFNM0Ii99C-g&oe=671F8309"}, {"file_name": "ZeroCaliber2_Screenshot_05_2560x1440.png", "id": "2579849238870307", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031400_2579849242203640_4717901026076490611_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3czMWC3cw6IQ7kNvgE6Oa4p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCeF2qmblf5mEbB7MlxwyshqWdwmOP3fqF_4IrddpsBng&oe=671F6224"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=El1iVo0D_sUQ7kNvgHXwwZj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDGtCrY02hS3_WOvPx0KTKFVn6i-TXoMl3IhbzHnmOJbQ&oe=671F791A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "\u2b07\ufe0f **Zero Caliber 2 is out NOW!** \u2b07\ufe0f\n\nWe can't save the world alone, the OSA needs your help soldier - enlist **NOW** by jumping into the game right away!\n\n{888829013066754}\n\n# \ud83d\udd11 KEY FEATURES\n\nZero Caliber 2 is THE ultimate VR shooter package:\n\n- 8+ hour **single player campaign** fully playable in **Co-op** (up to 4 players)\n\n- Classic **multiplayer game modes** with up to 10 players\n\n- Native **mod support** with modding tools - visit our Discord for more info (discord.gg/xrealgames)\n\n- More than 60 unlockable weapons, skins, and attachments\n\n- Gripping story full of cinematic action = immersion you haven't experienced in a VR shooter yet!\n\n# \ud83d\udcd6 THE STORY\n\nIn a world where water is scarce, a ruthless dictator, Barak, and his fanatic followers threaten the fragile peace of the OSA. Their brutal invasion aims to control the vital WELL water supplies, putting millions at risk.\n\n{1153668505934186}\n\nAs a **skilled operative**, your task is to navigate a war-torn landscape and undertake high-stakes missions to reclaim the stolen WELL supplies. **Fight** through cities and remote villages, face ruthless enemies, and uncover a web of betrayal and chaos. **The fate of the OSA is in your hands** - fight to end Barak\u2019s reign of terror and secure humanity\u2019s future!\n\n{689968696629104}\n\n# \ud83d\udd2e WHAT'S NEXT?\n\nZero Caliber 2's release is only the beginning - help us shape the future of the Zero Caliber IP by joining our community and sharing your feedback/suggestions!\n\n\ud83d\udc49 discord.gg/xrealgames \ud83d\udc48\n\nFor technical issues: support@xrealgames.com\n\n\u23af\u23af\u23af\u23af\u23af\n\nThanks for playing, catch you on the battlefield!\n- **The XREAL Games Crew**", "short_description": "8+ hour single player/Co-op campaign, cinematic action, explosions, 59+ weapons and skins to unlock, PvP, mods, airstrikes, all in one single package - this is Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter. See you on the virtual battlefields! o7"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_US