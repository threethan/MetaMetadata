name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "We can't save the world alone, the OSA needs you soldier - enlist NOW by wishlisting Zero Caliber 2 in the Meta Quest store! \n\n### THE SEQUEL ###\n\nYour favorite all-in-one VR FPS made infinitely better! Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter! \n\nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign (taking place after the events of the prequel), PvP, native mod support, zombies, airstrikes, more explosions and a VR experience you'll never forget! \n\nComing to your Meta Quest in 2024.\n\n### COMMUNITY ###\n\nTo participate in future playtests, catch sneak peeks and behind the scenes, join our awesome community on Discord: \n-> discord.gg/xrealgames <- \n\nAnd follow us on: \n- Facebook: https://www.facebook.com/XREALGamesVR\n- X: https://twitter.com/ZeroCaliber2\n- YouTube: https://www.youtube.com/@XREALGamesVR\n- TikTok: https://www.tiktok.com/@xrealgames ", "short_description": "Get ready to experience the thrill of your virtual life in Zero Caliber 2, the sequel to the critically acclaimed Zero Caliber: Reloaded military shooter! \nCinematic action, explosions, tons of weapons to unlock, a full-blown single player/Co-op campaign, PvP, airstrikes, more explosions and a VR experience you'll never forget! Coming in 2024."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "extern