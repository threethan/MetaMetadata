ntent-fra5-2.oculuscdn.com&oh=00_AYAH8j9MGC1XQ9BSwGquc2FWy4H-fOVb4_AvnrlkotncJQ&oe=675185BB"}]}, "id": "3979772852347719", "locale": "en_US", "screenshots": [{"file_name": "ZeroCaliber2_Screenshot_01_2560x1440.png", "id": "868642695304284", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75314848_868642698637617_6703783183999619475_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-q_GRhipOwAQ7kNvgEl3JD_&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDMsXVSeSxYJTxsdNzoV5rhtxdaurJ0J58Vz7IJm2xKcg&oe=6751AEF8"}, {"file_name": "ZeroCaliber2_Screenshot_02_2560x1440.png", "id": "8684035601610863", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974621_8684035621610861_4150297349049920714_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-b7DWrMQKWYQ7kNvgFRVUCm&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAekLHiOuKMOdjLc0Yn8jMbponzBd9VNL8PQ01nsWO_xQ&oe=6751A275"}, {"file_name": "ZeroCaliber2_Screenshot_03_2560x1440.png", "id": "688981123354563", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974507_688981126687896_6736655473577228057_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t6d4YXEU73AQ7kNvgFuc4Nu&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAyaCvhiIKDkxn8gigIMuKQFqtOO8qn3sT_kurtVSGFOQ&oe=67518C96"}, {"file_name": "ZeroCaliber2_Screenshot_04_2560x1440.png", "id": "780519374202336", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39001680_780519377535669_5621174576393243075_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_qzRDcFEtHUQ7kNvgGCIf_D&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDzn1UVB7KHj6tePdFIZQXUYAYz0IvkNYb1jyUt3aMQ3g&oe=67519C09"}, {"file_name": "ZeroCaliber2_Screenshot_05_2560x1440.png", "id": "2579849238870307", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031400_2579849242203640_4717901026076490611_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aPY3gysUsVEQ7kNvgEwlC6q&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAZyJezCGlVqoM-R6J5JHW_NjdmZ7XLW6sPbWlnHGLzeA&oe=67517B24"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9U8V_di7HxwQ7kNvgFT6oV6&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCDeRhEiUU2dK4EQXcqvmwOcAorki0UfKUaa0yHfZFOYA&oe=6751921A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "\u2b07\ufe0f **Zero Caliber 2's 1st content update is LIVE!** \u2b07\ufe0f\n\nA brand new 'Defense' game mode with 2 new maps, 5 new weapons, 3 jaw-dropping Halloween-themed weapon skins and a sp\ud83c\udf83\ud83c\udf83ky grenade, 2 new PvP maps, completely reworked endgame and much more! \n\n{888829013066754}\n\n# \ud83d\udd11 KEY FEATURES\n\nZero Caliber 2 is THE ultimate VR shooter package:\n\n- 8+ hour **solo campaign** fully playable in **Co-op** (up to 4 players)\n\n- Classic **multiplayer game modes** (up to 10 players)\n\n- Native **mod support**\n\n- 60+ unlockable weapons, skins, and attachments\n\n- Gripping story full of cinematic action reminescent of classic FPS games\n\n# \ud83d\udcd6 THE STORY\n\nIn a world where water is scarce, a ruthless dictator, Barak, and his fanatic followers threaten the fragile peace of the OSA. Their brutal invasion aims to control the vital WELL water supplies, putting millions at risk.\n\n{1153668505934186}\n\nAs a **skilled operative**, your task is to navigate a war-torn landscape and undertake high-stakes missions to reclaim the stolen WELL supplies. **Fight** through cities and remote villages, face ruthless enemies, and uncover a web of betrayal and chaos. **The fate of the OSA is in your hands** - fight to end Barak\u2019s reign of terror and secure humanity\u2019s future!\n\n{689968696629104}\n\n# \ud83d\udd2e WHAT'S NEXT?\n\nZero Caliber 2's release is only the beginning - help us shape the future of the Zero Caliber IP by joining our community and sharing your feedback/suggestions!\n\n\ud83d\udc49 discord.gg/xrealgames \ud83d\udc48\n\nFor technical issues: support@xrealgames.com\n\n\u23af\u23af\u23af\u23af\u23af\n\nThanks for playing, catch you on the battlefield!\n- **The XREAL Games Crew**", "short_description": "8+ hour single player/Co-op campaign, cinematic action, explosions, 59+ weapons and skins to unlock, PvP, mods, airstrikes, all in one single package - this is Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter. See you on the virtual battlefields! o7"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8482313331804776"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982535_8393681517376555_2617709658481534055_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O9scZweFc3sQ7kNvgF6l5qY&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYC1-zNHKBL0uBRmnzLZp7ss360p0l7HxvvlUx