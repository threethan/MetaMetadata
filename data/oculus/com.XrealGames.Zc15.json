roCaliber2_CoverArt_Landscape_2560x1440.png", "id": "377486044700026", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75411995_377486048033359_910554351192204151_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PasU8xsb6_AQ7kNvgF5ZFBn&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCZIpDv_-7c_79Ptn2T-pE-sUfal4h6H8gB1wnY1SBb4A&oe=6711024A"}]}, "id": "1239919793660074", "locale": "en_US", "screenshots": [{"file_name": "ZeroCaliber2_Screenshot_01_2560x1440.png", "id": "868642695304284", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75314848_868642698637617_6703783183999619475_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvF9NImssqwQ7kNvgGiJg95&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB4pp9glUT_1XfPDwvGS44JH73H6kdgzVCeHonBwnrfUA&oe=6710DD38"}, {"file_name": "ZeroCaliber2_Screenshot_02_2560x1440.png", "id": "8684035601610863", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974621_8684035621610861_4150297349049920714_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yg1qkN2iTJsQ7kNvgEtinVF&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBHdnHEG5rmipxNwT7rMcnHKBmt_OTGyk0jxBkRsGc4Fg&oe=671108F5"}, {"file_name": "ZeroCaliber2_Screenshot_03_2560x1440.png", "id": "688981123354563", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974507_688981126687896_6736655473577228057_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BbDi5cq6aL8Q7kNvgEX8E01&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDVKUUXxhydPB3u1FG1VjrCVDrGA5a9fdio5_FwNbqHQg&oe=6710F316"}, {"file_name": "ZeroCaliber2_Screenshot_04_2560x1440.png", "id": "780519374202336", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001680_780519377535669_5621174576393243075_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PIrA81SMcGwQ7kNvgF-x0La&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB7JuYAVfhGP_wNLZc6uTAM1Yc4FHcrD3h2Mj5kcgWQJg&oe=67110289"}, {"file_name": "ZeroCaliber2_Screenshot_05_2560x1440.png", "id": "2579849238870307", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031400_2579849242203640_4717901026076490611_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nZnmJztoHB8Q7kNvgHCH04U&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYApqEY_OjjBT-xnX-hZrjkz61_7u4smaMyXFXA6Z2rkjQ&oe=6710E1A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZeroCaliber2_CoverArt_Landscape_2560x1440.png", "id": "219203984540676", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38984447_219203987874009_6483626324491434520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MM7uhMf2jVEQ7kNvgHVdSyM&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA7sGS6cCb-_lCcg1T2054XMl-Ye9FFiVhaCJhoh6N-0A&oe=6710F89A"}, "display_name": "Zero Caliber 2", "keywords": ["coop", "shooter", "story", "military", "campaign"], "long_description": "\u2b07\ufe0f **Zero Caliber 2 is out NOW!** \u2b07\ufe0f\n\nWe can't save the world alone, the OSA needs your help soldier - enlist **NOW** by jumping into the game right away!\n\n{888829013066754}\n\n# \ud83d\udd11 KEY FEATURES\n\nZero Caliber 2 is THE ultimate VR shooter package:\n\n- 8+ hour **single player campaign** fully playable in **Co-op** (up to 4 players)\n\n- Classic **multiplayer game modes** with up to 10 players\n\n- Native **mod support** with modding tools - visit our Discord for more info (discord.gg/xrealgames)\n\n- More than 60 unlockable weapons, skins, and attachments\n\n- Gripping story full of cinematic action = immersion you haven't experienced in a VR shooter yet!\n\n# \ud83d\udcd6 THE STORY\n\nIn a world where water is scarce, a ruthless dictator, Barak, and his fanatic followers threaten the fragile peace of the OSA. Their brutal invasion aims to control the vital WELL water supplies, putting millions at risk.\n\n{1153668505934186}\n\nAs a **skilled operative**, your task is to navigate a war-torn landscape and undertake high-stakes missions to reclaim the stolen WELL supplies. **Fight** through cities and remote villages, face ruthless enemies, and uncover a web of betrayal and chaos. **The fate of the OSA is in your hands** - fight to end Barak\u2019s reign of terror and secure humanity\u2019s future!\n\n{689968696629104}\n\n# \ud83d\udd2e WHAT'S NEXT?\n\nZero Caliber 2's release is only the beginning - help us shape the future of the Zero Caliber IP by joining our community and sharing your feedback/suggestions!\n\n\ud83d\udc49 discord.gg/xrealgames \ud83d\udc48\n\nFor technical issues: support@xrealgames.com\n\n\u23af\u23af\u23af\u23af\u23af\n\nThanks for playing, catch you on the battlefield!\n- **The XREAL Games Crew**", "short_description": "8+ hour single player/Co-op campaign, cinematic action, explosions, 59+ weapons and skins to unlock, PvP, mods, airstrikes, all in one single package - this is Zero Caliber 2, the sequel to our critically acclaimed Zero Caliber: Reloaded military shooter. See you on the virtual battlefields! o7"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrealgames.com/pp/", "developer_terms_of_service_url": null, "publisher_name": "XREAL Games", "support_website_url": null, "website_url": "https://www.xrealgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7623345777701540"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "h