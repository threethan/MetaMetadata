scontent-lhr8-2.oculuscdn.com&oh=00_AYDaoO6O_UYExewOh1HffHKh5JfIzI-0JVr-gPtAuX9TvA&oe=672A18AD"}, {"file_name": "migrated_image.png", "id": "192935268673230", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/12449015_1539227286381422_2089509622_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bjwQleIj0MYQ7kNvgFhiqM9&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAuExLltQJ3I628WmalRLn68bORvQMgNx2brPL4ScxE5A&oe=6729EF43"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "escaperoomvr_2_2560x1440.png", "id": "1445401442244390", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/12386304_1445401445577723_4444863205113593856_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=51vLxrprX-gQ7kNvgGzuH3t&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYC6yoT36bvAJgTtgiM6JVKZBroUUthJFQLTr5WgMx5y_g&oe=672A067F"}, "display_name": "Escape Room VR", "keywords": ["Escape", "Room", "Riddle", "Puzzle", "adventure"], "long_description": "We are happy to announce that four rooms are now available! You can purchase the newest story for 1,99$. \n\nTry your mental strength in four different predicaments. In the beginning, you have \"Crazy Kidnapper\" where you woke up in a closed room with no memories of how you got there. Then \"Dirty Money\" challenged your quick thinking in order to avoid getting caught by the police. We all remember those special parties after which you wake up with only a couple questions in your mind. Where am I? How did I get here? This ultimate challenge adds one more to the collection... How do I get out? You can look for answers to those in \"Knowledge & Order\".\n\nAnd now we're adding an extra challenge, a fourth story! As a disrespectful customer, you're being punished by the store employees who left you alone in the closed shop. You have 15 minutes before the alarm goes off and you get in more trouble... Test your wits in \"Salesclerk Revenge\"!\n\nGood luck!", "short_description": "Four rooms are now available! You can now try your mental strength in four different predicaments. In the beginning you have \"Crazy Kidnapper\" where you woke up in a closed room with no memories of how you got there. Then \"Dirty Money\" challenged your quick thinking in order to avoid getting caught by the police. Next there is the party hangover in \"Knowledge & Order\" and finally the newest story in which you find yourself abandoned in the closed store."}]}, "developer_name": null, "developer_privacy_policy_url": "http://escroomvr.com/privacy/", "developer_terms_of_service_url": "http://escroomvr.com/privacy/", "publisher_name": "EvilPort", "support_website_url": null, "website_url": "http://www.escroomvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EXPLORATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "268985855253582"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/11162737_2117681958459347_5170651650947284992_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K66OsWal-rAQ7kNvgHFfLk0&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYARx8D1hT2UJPajmge4p9RjGhVz6GI1N0ygMsKSvWfsiQ&oe=6729FEBA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Escape Room VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1456300800, "lastRevision": {"nodes": [{"id": "1018914911493969", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pd