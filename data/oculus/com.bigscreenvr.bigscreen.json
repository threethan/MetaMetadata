enshots": [{"file_name": "1.png", "id": "1951607111931711", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035387_1951607115265044_8189110939372331230_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Gq_SNSxpZwQ7kNvgGvcygO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2bSg4GJ9VfIbbPDzqc3_5VLTaID-AMg94mGehCJhGTg&oe=6731ED27"}, {"file_name": "2.png", "id": "543027144899467", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031450_543027151566133_2144991127496339035_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NnzJ3XIBjTsQ7kNvgFU179N&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCSwJwCh33n2F8eRJZqX9CKwBzmqp1wnGrksHpAXxG-JA&oe=6731D904"}, {"file_name": "4.png", "id": "500799449210696", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_500799452544029_175856897157497237_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A5Uap66ebSoQ7kNvgEywopH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1q-dmalJkrs7hil8VeQxtw_-DYloUmLHAVKaaUY7HTA&oe=6731EC6B"}, {"file_name": "3.png", "id": "1203658137636536", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_1203658140969869_2662628457889990118_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YWy5sKkKpBUQ7kNvgFKtHYm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzLfbdCfVhzxryDy77b4SmWh3CIT_9i1vUhzZ8qcrkbg&oe=6731DCEC"}, {"file_name": "5.png", "id": "1157565888650874", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974677_1157565891984207_3280651599364342289_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VTq9i0EkRIEQ7kNvgGjTf6n&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDpq6lFWcMhXzGsi153kGjAPXDLeb_BCSY69qsS0CpFw&oe=6732024E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "6.png", "id": "396708406467677", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035354_396708409801010_1199767793945276199_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QtsD1yZ2GlMQ7kNvgESR9VQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCa7tp3k4UhCkVhwHBKC1Wt55GnnR_jvjEtzRNdwNf2Hw&oe=6731ED5C"}, "display_name": "Bigscreen Beta", "keywords": ["bigscreen", "bigscreenbeta", "bigscreentv"], "long_description": "Bigscreen is your VR movie theater.\n\nWATCH 3D movies with friends in a virtual theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms.\n\n--- Features ---\nYOUTUBE: watch YouTube with friends!\n\nVIDEO PLAYER: play local video files stored on your VR headset. Supports 3D MOVIES in Side-by-Side 3D or Over-Under 3D.\n\nREMOTE DESKTOP STREAMING: stream your Windows PC's screen into your VR headset. Wirelessly play your favorite PC games. Play a movie or video on your PC and watch it wirelessly in your VR headset in a virtual movie theater.\n\nTV Channels: watch movies, sports, and comedy channels for free 24/7.\n\nCROSS PLATFORM VR headset support!\n\nPublic and Private social VR CHAT ROOMS with up to 12 people.\n\nChoose from a variety of environments like campfires and movie theaters.", "short_description": "WATCH movies with friends in a virtual movie theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms."}]}, "developer_name": "Bigscreen, Inc.", "developer_privacy_policy_url": "https://www.bigscreenvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.bigscreenvr.com/termsofservice", "publisher_name": "Bigscreen, Inc.", "support_website_url": "https://bigscreenvr.com/discord", "website_url": "http://bigscreenvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}, {"id": "1055187466124150"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "26804578225856583"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982499_392916103550708_1524871341119685681_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UqYb3ZvWSKYQ7kNvgEASEjY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDYvkc3Se6FSBr8RWioD_mYsJJBwoHYhWmAcNRSvazZQ&oe=6731F130"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bigscreen Beta", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Media", "id": "434961926215971"}, {"topic_name": "Computer Link", "id": "1055187466124150"}, {"topic_name": "Community", "id": "1228796255027646"}], "release_date": 1558458000, "lastRevision": {"nodes": [{"id": "2543588199047509", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2497738113633933", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "347067685680577"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2632956313616477", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001707_274956693453863_2954972611005644800_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0IG_Jshyt7EQ7kNvgF7pUaB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZKcU87KbKG3Ftqhcz3ppkutm32c-DfigfaqRmkcRZ3A&oe=6731E328"}, {"file_