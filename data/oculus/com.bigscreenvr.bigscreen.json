, "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974545_1055735231284141_2540786202865303552_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5a0dCJEAJw4Q7kNvgEeZLzh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCWMs6AWaps0u6G8qNrvGiePP5dqg-buuxCKt78ZY6aQw&oe=6707AC18"}, "display_name": "Bigscreen Beta", "keywords": ["bigscreen", "virtualdesktop", "vrdesktop", "netflix", "movie"], "long_description": "Bigscreen is your VR movie theater.\n\nWATCH movies with friends in a virtual movie theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms.\nEVENTS like weekly 3D Movie Nights and VR LAN parties!\n\n--- Features ---\n\nREMOTE DESKTOP STREAMING: stream your PC's screen into your VR headset. Wirelessly play your favorite PC games. Play a movie or video on your PC and watch it wirelessly in your VR headset in a virtual movie theater.\n\nSupports 3D MOVIES in Side-by-Side 3D or Over-Under 3D.\n\nCROSS PLATFORM VR headset support!\n\nPublic and Private social VR CHAT ROOMS with up to 12 people.\n\nChoose from a variety of environments like campfires and movie theaters.\n\n--- Coming Soon ---\n\nVIDEO PLAYER: play local video files stored on your VR headset, or stream from a video server.", "short_description": "WATCH movies with friends in a virtual movie theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms.\nEVENTS like weekly 3D Movie Nights and VR LAN parties!"}]}, "developer_name": "Bigscreen, Inc.", "developer_privacy_policy_url": "http://bigscreenvr.com/privacypolicy.txt", "developer_terms_of_service_url": "http://bigscreenvr.com/termsofservice.txt", "publisher_name": "Bigscreen, Inc.", "support_website_url": null, "website_url": "http://bigscreenvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_R