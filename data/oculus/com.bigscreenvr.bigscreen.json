enshots": [{"file_name": "1.png", "id": "1951607111931711", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035387_1951607115265044_8189110939372331230_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ox3kNc3ieuMQ7kNvgFo5t7b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTuiXu6s-XyJlAs-WPapjlsM-VsAQ7dBWJz8VBPFG-9A&oe=675585A7"}, {"file_name": "2.png", "id": "543027144899467", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031450_543027151566133_2144991127496339035_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YthE7EMuOK4Q7kNvgFFc8SS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChONPAaWj9PbcSqPpQTkGitzSvWaswWD-797sKz1OQzQ&oe=67557184"}, {"file_name": "4.png", "id": "500799449210696", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_500799452544029_175856897157497237_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pl58IwGQkfoQ7kNvgFwI-e_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPN22IknT3Y1Hu9Se1RMg6swMlMeY-EEth5f6aatJ5Jg&oe=675584EB"}, {"file_name": "3.png", "id": "1203658137636536", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_1203658140969869_2662628457889990118_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fuF_nyoUciMQ7kNvgF0GkEB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUR9I0h5C2Dl6Kp7etEaUs6aizj0QcGLAq1jkTB6jbhQ&oe=6755756C"}, {"file_name": "5.png", "id": "1157565888650874", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974677_1157565891984207_3280651599364342289_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MrPwiN_AtIcQ7kNvgGw64Vz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCnol5GR4HRVQsqSDtpKiM1BEtMDzK9de5-I8ZLvZrfZw&oe=67559ACE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "6.png", "id": "396708406467677", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035354_396708409801010_1199767793945276199_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4wXlk2TIpQEQ7kNvgHWTUvf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFhNZvKTOA4aocjcULUlG2ufQ5ZQGUIXbXeWc1oE9OeQ&oe=675585DC"}, "display_name": "Bigscreen Beta", "keywords": ["bigscreen", "bigscreenbeta", "bigscreentv"], "long_description": "Bigscreen is your VR movie theater.\n\nWATCH 3D movies with friends in a virtual theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms.\n\n--- Features ---\nYOUTUBE: watch YouTube with friends!\n\nVIDEO PLAYER: play local video files stored on your VR headset. Supports 3D MOVIES in Side-by-Side 3D or Over-Under 3D.\n\nREMOTE DESKTOP STREAMING: stream your Windows PC's screen into your VR headset. Wirelessly play your favorite PC games. Play a movie or video on your PC and watch it wirelessly in your VR headset in a virtual movie theater.\n\nTV Channels: watch movies, sports, and comedy channels for free 24/7.\n\nCROSS PLATFORM VR headset support!\n\nPublic and Private social VR CHAT ROOMS with up to 12 people.\n\nChoose from a variety of environments like campfires and movie theaters.", "short_description": "WATCH movies with friends in a virtual movie theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms."}]}, "developer_name": "Bigscreen, Inc.", "developer_privacy_policy_url": "https://www.bigscreenvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.bigscreenvr.com/termsofservice", "publisher_name": "Bigscreen, Inc.", "support_website_url": "https://bigscreenvr.com/discord", "website_url": "http://bigscreenvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}, {"id": "1055187466124150"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_M