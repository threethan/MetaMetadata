_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRmZAb2BEnOd1ry0fwheNNibqNCiP5VZ4VsgBs2B6_tA&oe=6762B4DC"}, "display_name": "Bigscreen Beta", "keywords": ["bigscreen", "bigscreenbeta", "bigscreentv"], "long_description": "Bigscreen is your VR movie theater.\n\nWATCH 3D movies with friends in a virtual theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms.\n\n--- Features ---\nYOUTUBE: watch YouTube with friends!\n\nVIDEO PLAYER: play local video files stored on your VR headset. Supports 3D MOVIES in Side-by-Side 3D or Over-Under 3D.\n\nREMOTE DESKTOP STREAMING: stream your Windows PC's screen into your VR headset. Wirelessly play your favorite PC games. Play a movie or video on your PC and watch it wirelessly in your VR headset in a virtual movie theater.\n\nTV Channels: watch movies, sports, and comedy channels for free 24/7.\n\nCROSS PLATFORM VR headset support!\n\nPublic and Private social VR CHAT ROOMS with up to 12 people.\n\nChoose from a variety of environments like campfires and movie theaters.", "short_description": "WATCH movies with friends in a virtual movie theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms."}]}, "developer_name": "Bigscreen, Inc.", "developer_privacy_policy_url": "https://www.bigscreenvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.bigscreenvr.com/termsofservice", "publisher_name": "Bigscreen, Inc.", "support_website_url": "https://bigscreenvr.com/discord", "website_url": "http://bigscreenvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}, {"id": "1055187466124150"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVE