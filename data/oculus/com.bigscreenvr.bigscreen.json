enshots": [{"file_name": "1.png", "id": "1951607111931711", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035387_1951607115265044_8189110939372331230_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kOFPfOAHzFYQ7kNvgGJY0M_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDkTuj68XIcg2aNyO_xHMFcpkRTy7Nj3CAQNOrv5aKRwQ&oe=67694C27"}, {"file_name": "2.png", "id": "543027144899467", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031450_543027151566133_2144991127496339035_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MMMoWhju6NYQ7kNvgH8BqZp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCkK-Q42Z3DnrHqxwLImIRLWAzZAmaVTVqYbVYEQUA-w&oe=67693804"}, {"file_name": "4.png", "id": "500799449210696", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_500799452544029_175856897157497237_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nTdMHtkIr34Q7kNvgEvxfH0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEhGswb-zh2ULJ1K0lyaWHOF2Ps4HKrshwPisHBX2pRA&oe=67694B6B"}, {"file_name": "3.png", "id": "1203658137636536", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_1203658140969869_2662628457889990118_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kMyDknDihWIQ7kNvgFUQlg5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUNxV5UnTYnDnEpHO-g3PfUKB8gKxbnWVEngA77ak5tA&oe=67693BEC"}, {"file_name": "5.png", "id": "1157565888650874", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974677_1157565891984207_3280651599364342289_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cwqWFIsVzvQQ7kNvgEWC-xC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWUHVbG8Nn6kMjZqjIsgvCdlZ8nYdTmTIXczE-3n6swA&oe=6769614E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "6.png", "id": "396708406467677", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035354_396708409801010_1199767793945276199_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GqX_6vXyvcQQ7kNvgE1kxA0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqlW7Fh6eSBKzg0pop5w_Mt9Ztu3yS3HqtspszE3yPLQ&oe=67694C5C"}, "display_name": "Bigscreen Beta", "keywords": ["bigscreen", "bigscreenbeta", "bigscreentv"], "long_description": "Bigscreen is your VR movie theater.\n\nWATCH 3D movies with friends in a virtual theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms.\n\n--- Features ---\nYOUTUBE: watch YouTube with friends!\n\nVIDEO PLAYER: play local video files stored on your VR headset. Supports 3D MOVIES in Side-by-Side 3D or Over-Under 3D.\n\nREMOTE DESKTOP STREAMING: stream your Windows PC's screen into your VR headset. Wirelessly play your favorite PC games. Play a movie or video on your PC and watch it wirelessly in your VR headset in a virtual movie theater.\n\nTV Channels: watch movies, sports, and comedy channels for free 24/7.\n\nCROSS PLATFORM VR headset support!\n\nPublic and Private social VR CHAT ROOMS with up to 12 people.\n\nChoose from a variety of environments like campfires and movie theaters.", "short_description": "WATCH movies with friends in a virtual movie theater. \nPLAY your favorite PC video games on a huge screen. \nHANG OUT in social VR chat rooms."}]}, "developer_name": "Bigscreen, Inc.", "developer_privacy_policy_url": "https://www.bigscreenvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.bigscreenvr.com/termsofservice", "publisher_name": "Bigscreen, Inc.", "support_website_url": "https://bigscreenvr.com/discord", "website_url": "http://bigscreenvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}, {"id": "1055187466124150"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "26804578225856583"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982499_392916103550708_1524871341119685681_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b65ORkcmcyQQ7kNvgEoflEW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJ_tbPPY3WxciggSBdytZt9WOuwMjGjpS8Uv35pRR0BA&oe=67695030"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bigscreen Beta", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Media", "id": "434961926215971"}, {"topic_name": "Computer Link", "id": "1055187466124150"}, {"topic_name": "Community", "id": "1228796255027646"}], "release_date": 1558458000, "lastRevision": {"nodes": [{"id": "2543588199047509", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2497738113633933", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "347067685680577"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2632956313616477", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001707_274956693453863_2954972611005644800_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0DRvfh0d86kQ7kNvgFoKVDC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlphpW_hhox7iBJaFD7RycDv0zcLM0oszCd1Mmn-_Nzw&oe=67694228"}, {"file_n