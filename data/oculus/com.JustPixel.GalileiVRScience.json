487521407_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KGClQimOQ6kQ7kNvgGyuoiS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDK08zSGcOThH9uHZRYdNIvROa9dW8ypkQH-LiA1izgrQ&oe=66E41646"}, {"file_name": "Artboard 3.png", "id": "912383657378781", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031432_912383660712114_2572436446715478623_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1PLHB81BmfUQ7kNvgFwegKw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnOUikLd6IfID062nr3O8a_7gOsro6QlQz7WZznHDr-g&oe=66E4357A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "3748813912049179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031311_3748813915382512_2166423531006939259_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JCyKO_nOLNEQ7kNvgHBsVIJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYB_qb109_9YRjzWcdrfCbTE7eGok8gi957b1lfrXSPC1w&oe=66E411CD"}, "display_name": "Cellular Safari", "keywords": [], "long_description": "**Safari Cellular** is an innovative virtual reality app that turns learning about **cellular biology** into an exciting adventure. Designed for **students, educators and science enthusiasts**, this app allows you to explore an **animal cell in 3D** like never before. Through an immersive interface, you can navigate through different cell structures, such as **the nucleus, mitochondria, and endoplasmic reticulum**, discovering their functions and importance.\n\nEach component of the cell is represented in stunning detail, allowing you to observe and understand complex biological processes in a visually engaging way. **Integrated artificial intelligence** is at your disposal to answer any questions you may have while exploring, providing clear and detailed explanations.\n\nCellular Safari is not just a passive educational experience; it includes a series of **mini interactive games** designed to consolidate your knowledge in a fun and engaging way. Through **challenges and quizzes**, you can test your understanding of biological concepts, making learning an active and stimulating process.\n\nPerfect for use in education or as a self-study tool, Cellular Safari offers a new and innovative way to explore the microscopic world of the animal cell. With **high-quality graphics** and an **intuitive user experience**, this app turns the study of biology into an unforgettable adventure.", "short_description": "Discover the fascinating world of the animal cell with Cell Safari, the educational VR app that lets you explore cellular structures in 3D. Through interactive mini-games and advanced artificial intelligence, learn scientific concepts while having fun. Ideal for students and biology enthusiasts, this immersive experience makes learning an exciting adventure."}]}, "developer_name": "Just Ware", "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/93783224", "developer_terms_of_service_url": "https://www.iubenda.com/terms-and-conditions/93783224", "publisher_name": "Just Ware", "support_website_url": "https://justware.it/supporto/", "website_url": "https://justware.it/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8020087248080681"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_49309406345