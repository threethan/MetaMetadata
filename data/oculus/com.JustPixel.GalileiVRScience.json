ms2-1.oculuscdn.com&oh=00_AYBx2RaVkkV79DnwSXWHRBpK02Mva9_CMzsnR0-vhoXJ5A&oe=67406190"}, {"file_name": "Artboard 3.png", "id": "3889565187981667", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031547_3889565191315000_5528783709779854295_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2GwlbF0tzcQ7kNvgH-Rd2-&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBEIG3eNhrj7_0aW9IGM2WFb_UJX8xOZ3guuL8i2Mi9cA&oe=67406124"}, {"file_name": "Artboard 1.png", "id": "867384681933118", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003244_867384685266451_2340853765823917163_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JR3oMWD0lmoQ7kNvgG1kE8e&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCrxsyVUaVXS02tpNrxQU8EeZ3h3rfJMjAw-HAviopznQ&oe=67406545"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "999991165259980", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75476756_999991168593313_5483195490028886346_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XGG6eJxfTKoQ7kNvgG3wU8H&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAGfnGoZyBXTD64e8EvyeJIUkcEkeokVREl-ML_2Bnx9w&oe=674072B1"}, "display_name": "Safari Cellulare", "keywords": [], "long_description": "**Safari Cellulare** \u00e8 un'applicazione di realt\u00e0 virtuale innovativa che trasforma l'apprendimento della **biologia cellulare** in un'avventura emozionante. Progettata per **studenti, educatori e appassionati di scienza**, questa app ti permette di esplorare una **cellula animale in 3D** come mai prima d'ora. Attraverso un'interfaccia immersiva, puoi navigare tra le diverse strutture cellulari, come **il nucleo, i mitocondri e il reticolo endoplasmatico**, scoprendone le funzioni e l'importanza.\n\nOgni componente della cellula \u00e8 rappresentato con dettagli straordinari, permettendoti di osservare e comprendere i processi biologici complessi in modo visivamente accattivante. **L'intelligenza artificiale integrata** \u00e8 a tua disposizione per rispondere a qualsiasi domanda tu possa avere durante l'esplorazione, fornendo spiegazioni chiare e dettagliate.\n\nSafari Cellulare non \u00e8 solo un'esperienza educativa passiva; include una serie di **mini giochi interattivi** progettati per consolidare le tue conoscenze in modo divertente e coinvolgente. Attraverso **sfide e quiz**, puoi mettere alla prova la tua comprensione dei concetti biologici, rendendo l'apprendimento un processo attivo e stimolante.\n\nPerfetta per l'uso in ambito educativo o come strumento di autoapprendimento, Safari Cellulare offre un modo nuovo e innovativo per esplorare il mondo microscopico della cellula animale. Con **grafica di alta qualit\u00e0** e un'**esperienza utente intuitiva**, questa app trasforma lo studio della biologia in un'avventura indimenticabile.", "short_description": "Scopri l'affascinante mondo della cellula animale con Safari Cellulare, l'app VR educativa che ti permette di esplorare le strutture cellulari in 3D. Attraverso mini giochi interattivi e un'intelligenza artificiale avanzata, apprendi concetti scientifici divertendoti. Ideale per studenti e appassionati di biologia, questa esperienza immersiva rende l'apprendimento un'avventura entusiasmante."}, {"images": {"nodes": [{"file_name": "Logo.png", "id": "7830788620364802", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974477_7830788637031467_2492816240902607915_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0FNsGcdFWAoQ7kNvgEVd-rm&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDcwgfsAZwBIcU6f78aUBvgG83Jv2vcxKYH_u_1gsBRbw&oe=6740782C"}, {"file_name": "Landscape Portrait.png", "id": "1994643360958356", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75462955_1994643364291689_8067620305322327621_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XSL_dy_xz7cQ7kNvgHBu4Ix&_nc_zt=