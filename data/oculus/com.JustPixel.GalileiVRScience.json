.oculuscdn.com/v/t64.5771-25/39036623_2759662720860180_2489395151907338724_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LZS3uHSb9A0Q7kNvgGZSKPE&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfn4_tDNt76gRSsGnt8ol9e7Bwz-jrK-bJUeGcpfCXQg&oe=66FE9872"}, {"file_name": "Artboard 4.png", "id": "2251639125188099", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_2251639131854765_8396477208328520911_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AyfIpCR5a1wQ7kNvgEvTLL-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDK9hcQ0QNeVDhlcXKFINjxcUbKfYQstxLfpTviozmdVw&oe=66FE85A9"}, {"file_name": "Artboard 2.png", "id": "473243412277688", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984439_473243418944354_2938823070153890993_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ghhWhwtEVwsQ7kNvgHNMQTG&_nc_ht=scontent.oculuscdn.com&oh=00_AYBx8RdHIIT4gSW9cw_mUTLkk78HzMX55fXqx26qbonapA&oe=66FE6E37"}, {"file_name": "Artboard 1.png", "id": "1543351499921825", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974887_1543351503255158_348442130487521407_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OaLUgTMDcYoQ7kNvgGlmrRE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqKy6_QLuHd3_dg4ocSmMFdptPYJkUBRvgKouqqH8ZnA&oe=66FE7446"}, {"file_name": "Artboard 3.png", "id": "912383657378781", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031432_912383660712114_2572436446715478623_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3_7xQnQXFmEQ7kNvgH-OgAK&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7Je8Sqe35HKvWNg0Z-lazGszPdRz5EZyzcv5WHvQUQw&oe=66FE937A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "3748813912049179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031311_3748813915382512_2166423531006939259_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gxA6OADvxmYQ7kNvgGQuqpc&_nc_ht=scontent.oculuscdn.com&oh=00_AYAggmy1SkBLXvXJlOeEnNXI1U80d4xbmdJ-upIxSQ8lKQ&oe=66FE6FCD"}, "display_name": "Cellular Safari", "keywords": [], "long_description": "**Safari Cellular** is an innovative virtual reality app that turns learning about **cellular biology** into an exciting adventure. Designed for **students, educators and science enthusiasts**, this app allows you to explore an **animal cell in 3D** like never before. Through an immersive interface, you can navigate through different cell structures, such as **the nucleus, mitochondria, and endoplasmic reticulum**, discovering their functions and importance.\n\nEach component of the cell is represented in stunning detail, allowing you to observe and understand complex biological processes in a visually engaging way. **Integrated artificial intelligence** is at your disposal to answer any questions you may have while exploring, providing clear and detailed explanations.\n\nCellular Safari is not just a passive educational experience; it includes a series of **mini interactive games** designed to consolidate your knowledge in a fun and engaging way. Through **challenges and quizzes**, you can test your understanding of biological concepts, making learning an active and stimulating process.\n\nPerfect for use in education or as a self-study tool, Cellular Safari offers a new and innovative way to explore the microscopic world of the animal cell. With **high-quality graphics** and an **intuitive user experience**, this app turns the study of biology into an unforgettable adventure.", "short_description": "Discover the fascinating world of the animal cell with Cell Safari, the educational VR app that lets you explore cellular structures in 3D. Through interactive mini-games and advanced artificial intelligence, learn scientific concepts while having fun. Ideal for students and biology enthusiasts, this immersive experience makes learning an exciting adventure."}, {"images": {"nodes": [{"file_name": "Landscape Mini.png", "id": "7934545376658361", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.