031317_1429133904452550_6409544868446892523_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MZVbcfd5CDcQ7kNvgGm0_Sd&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlD0tu87ZGDDMYjK9nVylC9s6u3TOU0P0JsQ013nOTEg&oe=66E42B4D"}, {"file_name": "Artboard 1.png", "id": "1021011425999827", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_1021011429333160_4176289926510597494_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nov89fmhmpYQ7kNvgHSNGMX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDieAwN0Jnu3pm3bZv30ITTfyAaABnmY96Z57N0S3w6xA&oe=66E420E1"}, {"file_name": "Artboard 4.png", "id": "524012790104112", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001669_524012793437445_4891316513078544414_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kViEaSHDZz0Q7kNvgG7fJeX&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8F3dpFBvai1SqSL585vMzMJJWDXKDInYHP5Kl77RDOA&oe=66E4355A"}, {"file_name": "Artboard 3.png", "id": "1187574142495669", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031470_1187574145829002_8495108821353233334_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mnk_e4NMLoYQ7kNvgEC2hhB&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6wO9x-wgzzCQUyPgnj_OjHX1qEMrwC0k3bBTILBSCtg&oe=66E427F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "529809686395654", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476759_529809689728987_2021663405477506286_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ocVs2Jt9-sMQ7kNvgHY949h&_nc_ht=scontent.oculuscdn.com&oh=00_AYDO22j55lAI_mB-nv6SeaAL8HkbYpo3W6wZ4Ia1GlC79w&oe=66E419FF"}, "display_name": "Cellular Safari", "keywords": [], "long_description": "**Safari Cellular** is an innovative virtual reality app that turns learning about **cellular biology** into an exciting adventure. Designed for **students, educators and science enthusiasts**, this app allows you to explore an **animal cell in 3D** like never before. Through an immersive interface, you can navigate through different cell structures, such as **the nucleus, mitochondria, and endoplasmic reticulum**, discovering their functions and importance.\n\nEach component of the cell is represented in stunning detail, allowing you to observe and understand complex biological processes in a visually engaging way. **Integrated artificial intelligence** is at your disposal to answer any questions you may have while exploring, providing clear and detailed explanations.\n\nCellular Safari is not just a passive educational experience; it includes a series of **mini interactive games** designed to consolidate your knowledge in a fun and engaging way. Through **challenges and quizzes**, you can test your understanding of biological concepts, making learning an active and stimulating process.\n\nPerfect for use in education or as a self-study tool, Cellular Safari offers a new and innovative way to explore the microscopic world of the animal cell. With **high-quality graphics** and an **intuitive user experience**, this app turns the study of biology into an unforgettable adventure.", "short_description": "Discover the fascinating world of the animal cell with Cell Safari, the educational VR app that allows you to explore cell structures in 3D. Through interactive mini-games and advanced artificial intelligence, learn scientific concepts while having fun. Ideal for students and biology enthusiasts, this immersive experience makes learning an exciting adventure."}, {"images": {"nodes": [{"file_name": "Landscape Mini.png", "id": "2930927027073306", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974477_2930927030406639_1033799740283778117_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hkBR29sGF6oQ7kNvgEeFCEs&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwYPPlnBaqSBdVJCOb3NaobhedruXaGHB-y23gazIN3w&oe=66E4138E"}, {"file_name": "Hero Cover.png", "id": "1897915367381648", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75207242_1897915370714981_6546028005331927603_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sgCu7Q_Q3-gQ7kNvgH5aB6l&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPEpqkFJZudJ4HymMwUEJZ4jsVjpcm60I72rfwYV4PqA&oe=66E40ACD"}, {"file_name": "Logo.png", "id": "1156101178831306", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982713_1156101182164639_3284781712281521597_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FNSpptvHgHoQ7kNvgFmH5-P&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuUedHQ5nHo9IZvauBd-441k1Eys4pwpWmDVl7UsgPQQ&oe=66E410CF"}, {"file_name": "Landscape.png", "id": "1035480321561334", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982526_1035480328228000_568917300582159945_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tn5v3GUQXEkQ7kNvgGbQrWo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwmiSFtx1aX-HF84iP6mu2skQLqmlT-7f7IC-Y1JsjXA&oe=66E43338"}, {"file_name": "Landscape Portrait.png", "id": "840716281119571", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574720_840716291119570_6338633741422904364_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6HHJQgnwvVIQ7kNvgG9a6GF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsIGqDfARhAZ267Hl2DS_ZswM1fC1GLtuN6jJzb-FnKg&oe=66E40DDB"}, {"file_name": "Icon.png", "id": "488412717275961", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974525_488412720609294_7458364120634917665_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vji4UcOHfJ0Q7kNvgEb93KC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBM6B_A2mHDBSTUa2uFdR9-QQ4VqYH9mEWrRwv8yrdsdw&oe=66E43751"}, {"file_name": "Landscape Square.png", "id": "427144199756021", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223486_427144203089354_4369279694658394896_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kFtkK-gmJTQQ7kNvgF2jM11&_nc_ht=scontent.oculuscdn.com&oh=00_AYBM5mqT-ROsVvdzim85YgQVS6MIKR8ypSS8QLMWE7Bq1w&oe=66E4160F"}]}, "id": "520469743690183", "locale": "it_IT", "screenshots": [{"file_name": "Artboard 5.png", "id": "422140790868918", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_422140794202251_1640211663921085746_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=saDcNPvGt3YQ7kNvgHhtcN7&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFt8cSZv7puui9As7XIBNYyhUKluIPHefYXqq_uHesTg&oe=66E41E2A"}, {"file_name": "Artboard 2.png", "id": "468838062692515", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984464_468838066025848_9209980070403449565_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lsw_lAlc0vIQ7kNvgFttnf0&_nc_ht=scontent.oculuscdn.com&oh=00_AYADHUQqCtfjdfVEWi5umVh2sZsa8EP22gbu-W_6jECsuw&oe=66E41A0C"}, {"file_name": "Artboard 4.png", "id": "481654227990009", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031353_481654234656675_3114596455803752280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8sHSm7jXggEQ7kNvgFpHqBc&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgBkTPqmGPVb9Ekis6PbxDA4OpEeWjWzHukDQ2gXadFw&oe=66E41890"}, {"file_name": "Artboard 3.png", "id": "3889565187981667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_3889565191315000_5528783709779854295_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dp1EAY7wUmUQ7kNvgGYS9u7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoLlVIX3yvu78ql4RN9nH8sdT7hu4kGrkP084Zb_rsCg&oe=66E41824"}, {"file_name": "Artboard 1.png", "id": "867384681933118", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_867384685266451_2340853765823917163_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PHZX0AtgiioQ7kNvgGxFF4I&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUtHqx50a_lzQO8-Qrl-wtuSjXi1vH4htxYmGsikE1WA&oe=66E41C45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "999991165259980", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476756_999991168593313_5483195490028886346_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FQzPRk7DK6sQ7kNvgHlQ0FT&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnAXOJ-7RsrCwthtyX_xIsgejLgnCVkYqiTlECJnm07A&oe=66E429B1"}, "display_name": "Safari Cellulare", "keywords": [], "long_description": "**Safari Cellulare** \u00e8 un'applicazione di realt\u00e0 virtuale innovativa che trasforma l'apprendimento della **biologia cellulare** in un'avventura emozionante. Progettata per **studenti, educatori e appassionati di scienza**, questa app ti permette di esplorare una **cellula animale in 3D** come mai prima d'ora. Attraverso un'interfaccia immersiva, puoi navigare tra le diverse strutture cellulari, come **il nucleo, i mitocondri e il reticolo endoplasmatico**, scoprendone le funzioni e l'importanza.\n\nOgni componente della cellula \u00e8 rappresentato con dettagli straordinari, permettendoti di osservare e comprendere i processi biologici complessi in modo visivamente accattivante. **L'intelligenza artificiale integrata** \u00e8 a tua disposizione per rispondere a qualsiasi domanda tu possa avere durante l'esplorazione, fornendo spiegazioni chiare e dettagliate.\n\nSafari Cellulare non \u00e8 solo un'esperienza educativa passiva; include una serie di **mini giochi interattivi** progettati per consolidare le tue conoscenze in modo divertente e coinvolgente. Attraverso **sfide e quiz**, puoi mettere alla prova la tua comprensione dei concetti biologici, rendendo l'apprendimento un processo attivo e stimolante.\n\nPerfetta per l'uso in ambito educativo o come strumento di autoapprendimento, Safari Cellulare offre un modo nuovo e innovativo per esplorare il mondo microscopico della cellula animale. Con **grafica di alta qualit\u00e0** e un'**esperienza utente intuitiva**, questa app trasforma lo studio della biologia in un'avventura indimenticabile.", "short_description": "Scopri l'affascinante mondo della cellula animale con Safari Cellulare, l'app VR educativa che ti permette di esplorare le strutture cellulari in 3D. Attraverso mini giochi interattivi e un'intelligenza artificiale avanzata, apprendi concetti scientifici divertendoti. Ideale per studenti e appassionati di biologia, questa esperienza immersiva rende l'apprendimento un'avventura entusiasmante."}, {"images": {"nodes": [{"file_name": "Logo.png", "id": "7830788620364802", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974477_7830788637031467_2492816240902607915_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MQC9h0axEYgQ7kNvgGD1Ew-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDR9VwmvQtZQ3oXxuG4aNUNliuWNtwn0vJV0XyiH5qbUw&oe=66E42F2C"}, {"file_name": "Landscape Portrait.png", "id": "1994643360958356", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462955_1994643364291689_8067620305322327621_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ukWxqUFL9IQ7kNvgGheAXF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhZ-XAaLjc-NpboQOwKsyu36o20DC_TQuEio3E5Q_JCQ&oe=66E4148F"}, {"file_name": "Icon.png", "id": "1749848195756080", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_1749848199089413_6210488408238311147_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r2yPB1CmSVgQ7kNvgEAiYwd&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8PVx5O0V8CdjS-stAsowbZ8D9gsNddFyF0NfCnE_zRw&oe=66E41086"}, {"file_name": "Hero Cover.png", "id": "1019117086331658", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_1019117092998324_1164601898764144918_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kXSlg-ujDMIQ7kNvgHlgvRg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTLtbumDZj7noKzDlqWdkU7Xdvj7_-uA2PzLB82KFa5w&oe=66E42AA8"}, {"file_name": "Landscape.png", "id": "872400761490753", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031450_872400768157419_814239069343010651_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VyY-R12ILOQQ7kNvgENMoFp&_nc_ht=scontent.oculuscdn.co