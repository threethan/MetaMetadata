 {"file_name": "Landscape Portrait.png", "id": "840716281119571", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574720_840716291119570_6338633741422904364_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRHJqaIhjcEQ7kNvgE-i41o&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKd3tbT9vuIPhYj_K_zX71jIWICDZvXzBKWRl5leHwZg&oe=66FE6BDB"}, {"file_name": "Icon.png", "id": "488412717275961", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974525_488412720609294_7458364120634917665_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xxOSi1uuyk0Q7kNvgF1o9V9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmXCw_MBEo95WI7iEcfKIMlDE8kGXE8IYwhxnj4orQnw&oe=66FE9551"}, {"file_name": "Landscape Square.png", "id": "427144199756021", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223486_427144203089354_4369279694658394896_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YCsguHoj4v0Q7kNvgFnC8hA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAsljyW_xJ2TGr4Rb0YVlryZSQOeqLQx2LcXFfO2-5Vg&oe=66FE740F"}]}, "id": "1062082695522073", "locale": "it_IT", "screenshots": [{"file_name": "Artboard 5.png", "id": "422140790868918", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_422140794202251_1640211663921085746_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qLThEBUEebAQ7kNvgFQ-uc7&_nc_ht=scontent.oculuscdn.com&oh=00_AYARl2b46Z2PAsnubatRfHX7uA-Ubq_V8aTlzfRL0pc6Ew&oe=66FE7C2A"}, {"file_name": "Artboard 2.png", "id": "468838062692515", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984464_468838066025848_9209980070403449565_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N9sKF7Yr2xcQ7kNvgEzI13o&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjNyuSZ1khdXXNPnKRRshkI5Q3M592OpVXYUKbL2iuvQ&oe=66FE780C"}, {"file_name": "Artboard 4.png", "id": "481654227990009", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031353_481654234656675_3114596455803752280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TBB76Zm-1kQQ7kNvgFHQsTj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAor-fs5PHRoprDnppUnIcSURGnbg68aWjxw2vq2fUtSQ&oe=66FE7690"}, {"file_name": "Artboard 3.png", "id": "3889565187981667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_3889565191315000_5528783709779854295_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvhkhkFP8zwQ7kNvgHABKJX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAk9daTYjaJ7xah1_eHcRjR74ZrEWnFxWjIR2p7UzIvrQ&oe=66FE7624"}, {"file_name": "Artboard 1.png", "id": "867384681933118", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_867384685266451_2340853765823917163_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mpOFdtrwTdkQ7kNvgFUFE-e&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHlPe_0MgP6crYzIgBCrYvziJoA8oPO9RQlfXWjtD0Nw&oe=66FE7A45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "999991165259980", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476756_999991168593313_5483195490028886346_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Arl-bTTq9VAQ7kNvgHWGZje&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNgJ_G8lx_C4pbKmE8a3qtr04gA-fc0W7cZ2rwXuhubw&oe=66FE87B1"}, "display_name": "Safari Cellulare", "keywords": [], "long_description": "**Safari Cellulare** \u00e8 un'applicazione di realt\u00e0 virtuale innovativa che trasforma l'apprendimento della **biologia cellulare** in un'avventura emozionante. Progettata per **studenti, educatori e appassionati di scienza**, questa app ti permette di esplorare una **cellula animale in 3D** come mai prima d'ora. Attraverso un'interfaccia immersiva, puoi navigare tra le diverse strutture cellulari, come **il nucleo, i mitocondri e il reticolo endoplasmatico**, scoprendone le funzioni e l'importanza.\n\nOgni componente della cellula \u00e8 rappresentato con dettagli straordinari, permettendoti di osservare e comprendere i processi biologici complessi in modo visivamente accattivante. **L'intelligenza artificiale integrata** \u00e8 a tua disposizione per rispondere a qualsiasi domanda tu possa avere durante l'esplorazione, fornendo spiegazioni chiare e dettagliate.\n\nSafari Cellulare non \u00e8 solo un'esperienza educativa passiva; include una serie di **mini giochi interattivi** progettati per consolidare le tue conoscenze in modo divertente e coinvolgente. Attraverso **sfide e quiz**, puoi mettere alla prova la tua comprensione dei concetti biologici, rendendo l'apprendimento un processo attivo e stimolante.\n\nPerfetta per l'uso in ambito educativo o come strumento di autoapprendimento, Safari Cellulare offre un modo nuovo e innovativo per esplorare il mondo microscopico della cellula animale. Con **grafica di alta qualit\u00e0** e un'**esperienza utente intuitiva**, questa app trasforma lo studio della biologia in un'avventura indimenticabile.", "short_description": "Scopri l'affascinante mondo della cellula animale con Safari Cellulare, l'app VR educativa che ti permette di esplorare le strutture cellulari in 3D. Attraverso mini giochi interattivi e un'intelligenza artificiale avanzata, apprendi concetti scientifici divertendoti. Ideale per studenti e appassionati di biologia, questa esperienza immersiva rende l'apprendimento un'avventura entusiasmante."}, {"images": {"nodes": [{"file_name": "Logo.png", "id": "7830788620364802", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974477_7830788637031467_2492816240902607915_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t7szHMlxRWkQ7kNvgGoBsXf&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDR7uVZ6eP5khZagZL1wmvG5wmAjlZxiVJ8i4tebjKKg&oe=66FE8D2C"}, {"file_name": "Landscape Portrait.png", "id": "1994643360958356", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462955_1994643364291689_8067620305322327621_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t6YisyCXHUsQ7kNvgGjrZEl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJqOW16SlkQSbp4v5Zuv