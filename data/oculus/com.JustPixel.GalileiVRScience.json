ad3-1.oculuscdn.com&oh=00_AYBBeWgIJ9WqdPtqgGD34npeYT8bTKxV7EBGR5t1OZ1QmA&oe=6741B310"}, {"file_name": "Artboard 3.png", "id": "3889565187981667", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031547_3889565191315000_5528783709779854295_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l2v4iNNwbGsQ7kNvgF0Q8MA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDa8z345EiH3_Wo3jIeH3f_VTM9vELu0LarmFnP87pWtw&oe=6741B2A4"}, {"file_name": "Artboard 1.png", "id": "867384681933118", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003244_867384685266451_2340853765823917163_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NR6F0IzA4J4Q7kNvgEphq5O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD6EnO02vrbBOvG2xeo1S_j4lh7GyTxCfJVeCkPhi5B1Q&oe=6741B6C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "999991165259980", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476756_999991168593313_5483195490028886346_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XGG6eJxfTKoQ7kNvgE1ZDs1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChud_2qNJ3A8LIyQ0BDypWH6h6ydaQtjQPak-h38zpvA&oe=6741C431"}, "display_name": "Safari Cellulare", "keywords": [], "long_description": "**Safari Cellulare** \u00e8 un'applicazione di realt\u00e0 virtuale innovativa che trasforma l'apprendimento della **biologia cellulare** in un'avventura emozionante. Progettata per **studenti, educatori e appassionati di scienza**, questa app ti permette di esplorare una **cellula animale in 3D** come mai prima d'ora. Attraverso un'interfaccia immersiva, puoi navigare tra le diverse strutture cellulari, come **il nucleo, i mitocondri e il reticolo endoplasmatico**, scoprendone le funzioni e l'importanza.\n\nOgni componente della cellula \u00e8 rappresentato con dettagli straordinari, permettendoti di osservare e comprendere i processi biologici complessi in modo visivamente accattivante. **L'intelligenza artificiale integrata** \u00e8 a tua disposizione per rispondere a qualsiasi domanda tu possa avere durante l'esplorazione, fornendo spiegazioni chiare e dettagliate.\n\nSafari Cellulare non \u00e8 solo un'esperienza educativa passiva; include una serie di **mini giochi interattivi** progettati per consolidare le tue conoscenze in modo divertente e coinvolgente. Attraverso **sfide e quiz**, puoi mettere alla prova la tua comprensione dei concetti biologici, rendendo l'apprendimento un processo attivo e stimolante.\n\nPerfetta per l'uso in ambito educativo o come strumento di autoapprendimento, Safari Cellulare offre un modo nuovo e innovativo per esplorare il mondo microscopico della cellula animale. Con **grafica di alta qualit\u00e0** e un'**esperienza utente intuitiva**, questa app trasforma lo studio della biologia in un'avventura indimenticabile.", "short_description": "Scopri l'affascinante mondo della cellula animale con Safari Cellulare, l'app VR educativa che ti permette di esplorare le strutture cellulari in 3D. Attraverso mini giochi interattivi e un'intelligenza artificiale avanzata, apprendi concetti scientifici divertendoti. Ideale per studenti e appassionati di biologia, questa esperienza immersiva rende l'apprendimento un'avventura entusiasmante."}, {"images": {"nodes": [{"file_name": "Logo.png", "id": "7830788620364802", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974477_7830788637031467_2492816240902607915_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0FNsGcdFWAoQ7kNvgEXtkAK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPLq8EalgMRP8xy7-g1CUlSgCL3tiZ9p32_eMaLNBFIg&oe=6741C9AC"}, {"file_name": "Landscape Portrait.png", "id": "1994643360958356", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462955_1994643364291689_8067620305322327621_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XSL_dy_xz7cQ7kNvgFOxPkQ&_nc_zt=