, "short_description": "Discover the fascinating world of the animal cell with Cell Safari, the educational VR app that allows you to explore cell structures in 3D. Through interactive mini-games and advanced artificial intelligence, learn scientific concepts while having fun. Ideal for students and biology enthusiasts, this immersive experience makes learning an exciting adventure."}]}, "developer_name": "Just Ware", "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/93783224", "developer_terms_of_service_url": "https://www.iubenda.com/terms-and-conditions/93783224", "publisher_name": "Just Ware", "support_website_url": "https://justware.it/supporto/", "website_url": "https://justware.it/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8105003776255694"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_493094063451944_436248626179243058_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ks8L9MgvwDcQ7kNvgHuulSg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLbcmqXDEBcZkppyJThZgyf5qV_7bLRFMd-WEi6--8Tg&oe=66F94099"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Cellular Safari", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAME