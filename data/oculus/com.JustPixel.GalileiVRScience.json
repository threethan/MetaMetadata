7kNvgH3NCp5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBA67xUCrO58Lwp8ZpuzEVi5YspsqLrzYul5ve4S7p3rA&oe=6741CC1A"}]}, "id": "842911081150271", "locale": "en_GB", "screenshots": [{"file_name": "Artboard 5.png", "id": "1213102840110249", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982526_1213102843443582_4888038560712825609_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2dABvN01W9QQ7kNvgEDY2lW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfxRY0q243yThSynR7SnRb-n43JDy6Db2q4ZgR79NvOQ&oe=6741AC93"}, {"file_name": "Artboard 2.png", "id": "1429133897785884", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031317_1429133904452550_6409544868446892523_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VjrfE5leYLoQ7kNvgHe5hA5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKEP0cOYJZnCbMX1pBRGcQvYWTmvpHOd0pT471WouQkg&oe=6741C5CD"}, {"file_name": "Artboard 1.png", "id": "1021011425999827", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031547_1021011429333160_4176289926510597494_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0xIbO46UAlsQ7kNvgFy353g&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMTNQysiGK92v5GjJwa0Wbs44acOSEUoxThMUqsnJ2nQ&oe=6741BB61"}, {"file_name": "Artboard 4.png", "id": "524012790104112", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001669_524012793437445_4891316513078544414_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b9VEuIcpcMcQ7kNvgF09fVB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnCN8N0HHV-GMEq6VOUC3fmWsDTBwF7O37dizlKWaCIg&oe=6741CFDA"}, {"file_name": "Artboard 3.png", "id": "1187574142495669", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031470_1187574145829002_8495108821353233334_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N5CexhuihoYQ7kNvgGNvb4b&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCAiuy8X5eAFm2fRDnkGYGwndSeDjWCP8qWIGvvF6whw&oe=6741C270"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974450_2251639131854765_8396477208328520911_n.png", "id": "529809686395654", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476759_529809689728987_2021663405477506286_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KL5sEntdJRIQ7kNvgGOp2UK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFdSdf7bxy909Iax1k4xlXK91_Et6RhuYpLBBzmtSY_g&oe=6741B47F"}, "display_name": "Cellular Safari", "keywords": [], "long_description": "**Safari Cellular** is an innovative virtual reality app that turns learning about **cellular biology** into an exciting adventure. Designed for **students, educators and science enthusiasts**, this app allows you to explore an **animal cell in 3D** like never before. Through an immersive interface, you can navigate through different cell structures, such as **the nucleus, mitochondria, and endoplasmic reticulum**, discovering their functions and importance.\n\nEach component of the cell is represented in stunning detail, allowing you to observe and understand complex biological processes in a visually engaging way. **Integrated artificial intelligence** is at your disposal to answer any questions you may have while exploring, providing clear and detailed explanations.\n\nCellular Safari is not just a passive educational experience; it includes a series of **mini interactive games** designed to consolidate your knowledge in a fun and engaging way. Through **challenges and quizzes**, you can test your understanding of biological concepts, making learning an active and stimulating process.\n\nPerfect for use in education or as a self-study tool, Cellular Safari offers a new and innovative way to explore the microscopic world of the animal cell. With **high-quality graphics** and an **intuitive user experience**, this app turns the study of biology into an unforgettable adventure.", "short_description": "Discover the fascinating world of the animal cell with Cell Safari, the educational VR app that allows you to explore cell structures in 3D. Through interactive mini-games and advanced artificial intelligence, learn scientific concepts while having fun. Ideal for students and biology enthusiasts, this immersive experience makes learning an exciting adventure."}, {"images": {"nodes": [{"file_name": "Landscape Mini.png", "id": "2930927027073306", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974477_2930927030406639_1033799740283778117_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UtP9eMuPx7UQ7kNvgFVBD3G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmhPOpa1gpwxxneOsH7OlhtRRfRaBxRthdf7R7XuCuVw&oe=6741AE0E"}, {"file_name": "Hero Cover.png", "id": "1897915367381648", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207242_1897915370714981_6546028005331927603_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0RWbAvdQ7c0Q7kNvgE0w-4P&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7_cgRnEGW06JWyzkbapxI0ZBFyVgJDU9yOivC-pLavA&oe=6741A54D"}, {"file_name": "Logo.png", "id": "1156101178831306", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982713_1156101182164639_3284781712281521597_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AqjhEhj2O5kQ7kNvgFftz5A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwWWh69iRT1ofigWPc8ec0HbcfN2d-Jhmugo9sfZRX2g&oe=6741AB4F"}, {"file_name": "Landscape.png", "id": "1035480321561334", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982526_1035480328228000_568917300582159945_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tC7DPI5RgSUQ7kNvgEs9hYx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBM2uLl69xJ_ENejorEYhnXCtPmuE2iKuZ-jyHlmue98Q&oe=6741CDB8"}, {"file_name": "Landscape Portrait.png", "id": "840716281119571", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574720_8407162911