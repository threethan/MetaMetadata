cb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Eox1Nr62E0Q7kNvgGqqba5&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1JDNs9UWXin6yINEjtQt7jNRkhikeHUyHS2YO0iecAg&oe=67050938"}, {"file_name": "screen_2560x1440_3.png", "id": "1571326163478591", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036669_1571326166811924_3877117546677275865_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CZ4KTAByJkUQ7kNvgFfgjg0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7bEinj0xDRRJ2nT7yFGemVJZbZCYqiwcKVGlTnnh5ng&oe=67052A60"}, {"file_name": "screen_2560x1440_4.png", "id": "1207507513816858", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395600_1207507517150191_1637305848782642509_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oygBEn7aolUQ7kNvgH4UoSx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVNpXDckijlEOIqT9irv8J72tUwcLNvZzhJULkahTMkg&oe=670534B0"}, {"file_name": "screen_2560x1440_5.png", "id": "356793867398122", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982693_356793870731455_5713479648218928983_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bIh5JZeJIDAQ7kNvgGk6dd_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBo8UsF6Vtg9Hf8QHG2dN8RLyoSRDfbSidB3hiylwvoOA&oe=6705322A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_vr.png", "id": "1254934272209287", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75441583_1254934275542620_6416277115133340062_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eHiTrI4fY1gQ7kNvgGoD6mi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYCZJfug9z5A9RWwOAdtCyQleGrod625azosSzHRGfDQ&oe=670534E7"}, "display_name": "MEGOGO VR", "keywords": ["megogo", "video", "online", "movies"], "long_description": "**Virtual reality is cooler with MEGOGO TV and Movies**\n\nWith our application, you can find yourself in the center of the top stories \u2014 whether it's a thrilling movie, a bright cartoon story, or an unusual adventure. Ready to become a part of a fantastic world while staying at home? Then we're on our way!\n\nNow your evenings will be even more exciting and memorable because thousands of movies, series, and cartoons are waiting for you on our media service. And, of course, don't forget about TV. Here you will find your favorite channels and feel like you are a part of a screenplay.\n\n**Download the app and erase the boundaries of reality**\n\nTo start your journey with MEGOGO, all you need to do is download the app on your VR device. \n\nVirtual reality is closer than ever, and now everyone can experience the magic of this amazing world \u2014 download and enjoy a borderless experience with us!\n", "short_description": "Make your journey into the world of virtual reality even more exciting \u2014 download the MEGOGO TV and Movies app \ud83d\udda5\ufe0f\n\nWatch your favorite TV channels and choose from a collection of top movies, cartoons, and series \u2014 there is enough content for a long time! Download, connect your VR device, erase the boundaries of reality, and enjoy the special atmosphere with us."}]}, "developer_name": null, "developer_privacy_policy_url": "http://megogo.net/ru/rules", "developer_terms_of_service_url": "http://megogo.net/ru/rules", "publisher_name": "MEGOGO LLC", "support_website_url": null, "website_url": "https://megogo.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2777382702530830"}, {"id": "361620458439488"}, {"id": "337573230800174"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8654899227864762"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001728_432694155934033_6461054125400754133_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xQ-7P3ZzW0cQ7kNvgHJgjJv&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCW16GkEMSmzdfmSA0LHBhrVJXIeL8EjgwCAIhkuXJdig&oe=670523B7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MEGOGO VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Movies", "id": "2777382702530830"}, {"topic_name": "News", "id": "361620458439488"}, {"topic_name": "TV Shows", "id": "337573230800174"}], "release_date": 1727168820, "lastRevision": {"nodes": [{"id": "8449760101712010", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8449760035045350", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "876388244030711"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "825310159799796", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MEGOGO VR", "keywords": ["megogo", "video", "online", "movies", "\u043c\u0435\u0433\u043e\u0433\u043e"], "long_description": "**\u0412\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u0430\u044f \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u043a\u0440\u0443\u0447\u0435 \u0441 MEGOGO \u0422\u0412 \u0438 \u041a\u0438\u043d\u043e**\n\n\u0412\u043c\u0435\u0441\u0442\u0435 \u0441 \u043d\u0430\u0448\u0438\u043c \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435\u043c \u0432\u044b \u0441\u043c\u043e\u0436\u0435\u0442\u0435 \u043e\u043a\u0430\u0437\u0430\u0442\u044c\u0441\u044f \u0432 \u0446\u0435\u043d\u0442\u0440\u0435 \u0441\u043e\u0431\u044b\u0442\u0438\u0439 \u0442\u043e\u043f\u043e\u0432\u044b\u0445 \u0441\u044e\u0436\u0435\u0442\u043e\u0432 \u2014 \u0431\u0443\u0434\u044c \u0442\u043e \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0438\u0439 \u0444\u0438\u043b\u044c\u043c, \u044f\u0440\u043a\u0430\u044f \u043c\u0443\u043b\u044c\u0442\u044f\u0448\u043d\u0430\u044f \u0438\u0441\u0442\u043e\u0440\u0438\u044f \u0438\u043b\u0438 \u043d\u0435\u043e\u0431\u044b\u0447\u043d\u043e\u0435 \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435. \u0413\u043e\u0442\u043e\u0432\u044b \u0441\u0442\u0430\u0442\u044c \u0441\u0442\u0430\u0442\u044c \u0447\u0430\u0441\u0442\u044c\u044e \u0444\u0430\u043d\u0442\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043c\u0438\u0440\u0430, \u043d\u0435 \u0432\u044b\u0445\u043e\u0434\u044f \u0438\u0437 \u0434\u043e\u043c\u0430? \u0422\u043e\u0433\u0434\u0430 \u043d\u0430\u043c \u043f\u043e \u043f\u0443\u0442\u0438!\n\n\u0422\u0435\u043f\u0435\u0440\u044c \u0432\u0430\u0448\u0438 \u0432\u0435\u0447\u0435\u0440\u0430 \u0441\u0442\u0430\u043d\u0443\u0442 \u0435\u0449\u0435 \u0431\u043e\u043b\u0435\u0435 \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u043c\u0438 \u0438 \u0437\u0430\u043f\u043e\u043c\u0438\u043d\u0430\u044e\u0449\u0438\u043c\u0438\u0441\u044f, \u0432\u0435\u0434\u044c \u043d\u0430 \u043d\u0430\u0448\u0435\u043c \u043c\u0435\u0434\u0438\u0430\u0441\u0435\u0440\u0432\u0438\u0441\u0435 \u0432\u0430\u0441 \u0436\u0434\u0443\u0442 \u0442\u044b\u0441\u044f\u0447\u0438 \u0444\u0438\u043b\u044c\u043c\u043e\u0432, \u0441\u0435\u0440\u0438\u0430\u043b\u043e\u0432 \u0438 \u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u0432. \u041d\u0443 \u0438 \u043a\u043e\u043d\u0435\u0447\u043d\u043e \u0436\u0435, \u043a\u0443\u0434\u0430 \u0431\u0435\u0437 \u043b\u044e\u0431\u0438\u043c\u043e\u0433\u043e \u0422\u0412? \u0417\u0434\u0435\u0441\u044c \u0432\u044b \u043d\u0430\u0439\u0434\u0435\u0442\u0435 \u043b\u044e\u0431\u0438\u043c\u044b\u0435 \u043a\u0430\u043d\u0430\u043b\u044b \u0438 \u0441\u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0441\u0435\u0431\u044f \u0447\u0430\u0441\u0442\u044c\u044e \u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u044f\u0449\u0435\u0433\u043e \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435. \n\n**\u0417\u0430\u0433\u0440\u0443\u0436\u0430\u0439\u0442\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u0438 \u0441\u0442\u0438\u0440\u0430\u0439\u0442\u0435 \u0433\u0440\u0430\u043d\u0438\u0446\u044b \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438**\n\n\u0427\u0442\u043e\u0431\u044b \u043d\u0430\u0447\u0430\u0442\u044c \u0441\u0432\u043e\u0435 \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0441 MEGOGO, \u0432\u0430\u043c \u043d\u0443\u0436\u043d\u043e \u0432\u0441\u0435\u0433\u043e \u043b\u0438\u0448\u044c \u0437\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 \u043d\u0430 \u0432\u0430\u0448\u0435\u043c VR-\u0434\u0435\u0432\u0430\u0439\u0441\u0435. \n\n\u0412\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u0430\u044f \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0441\u044f \u0431\u043b\u0438\u0436\u0435, \u0447\u0435\u043c \u043a\u043e\u0433\u0434\u0430-\u043b\u0438\u0431\u043e, \u0438 \u0442\u0435\u043f\u0435\u0440\u044c \u043a\u0430\u0436\u0434\u044b\u0439 \u043c\u043e\u0436\u0435\u0442 \u0438\u0441\u043f\u044b\u0442\u0430\u0442\u044c \u043c\u0430\u0433\u0438\u044e \u044d\u0442\u043e\u0433\u043e \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430 \u2014 \u0441\u043a\u0430\u0447\u0438\u0432\u0430\u0439\u0442\u0435  \u0438 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u0439\u0442\u0435\u0441\u044c \u043e\u0442\u0434\u044b\u0445\u043e\u043c \u0431\u0435\u0437 \u0433\u0440\u0430\u043d\u0438\u0446 \u0432\u043c\u0435\u0441\u0442\u0435 \u0441 \u043d\u0430\u043c\u0438!\n", "short_description": "\u0421\u0434\u0435\u043b\u0430\u0439\u0442\u0435 \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432 \u043c\u0438\u0440 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0435\u0449\u0435 \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u0435\u0439  \u2014 \u0441\u043a\u0430\u0447\u0438\u0432\u0430\u0439\u0442\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 MEGOGO \u0422\u0412 \u0438 \u041a\u0438\u043d\u043e \ud83d\udda5\ufe0f\n\n\u0421\u043c\u043e\u0442\u0440\u0438\u0442\u0435 \u043b\u044e\u0431\u0438\u043c\u044b\u0435 \u0422\u0412-\u043a\u0430\u043d\u0430\u043b\u044b, \u0430 \u0442\u0430\u043a \u0436\u0435 \u0432\u044b\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0438\u0437 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438 \u0442\u043e\u043f\u043e\u0432\u044b\u0445 \u0444\u0438\u043b\u044c\u043c\u043e\u0432, \u043c\u0443\u043b\u044c\u0442\u0438\u043a\u043e\u0432 \u0438 \u0441\u0435\u0440\u0438\u0430\u043b\u043e\u0432 \u2014 \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0430 \u0445\u0432\u0430\u0442\u0438\u0442 \u043d\u0430\u0434\u043e\u043b\u0433\u043e! \u0417\u0430\u0433\u0440\u0443\u0436\u0430\u0439\u0442\u0435, \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0430\u0439\u0442\u0435 \u0441\u0432\u043e\u0439 VR-\u0434\u0435\u0432\u0430\u0439\u0441, \u0441\u0442\u0438\u0440\u0430\u0439\u0442\u0435 \u0433\u0440\u0430\u043d\u0438\u0446\u044b \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0438 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u0439\u0442\u0435\u0441\u044c \u043e\u0441\u043e\u0431\u043e\u0439 \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u043e\u0439 \