g", "id": "1905155096615361", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375757_1905155099948694_8778738369372943147_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ysOp1jL_N1kQ7kNvgEvAlNf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AB7rURcObz09wLD0uEBjBqW&oh=00_AYC5f6dFv7ahk7iPDD87XqBELmaHf05D8FvFbsMv8lZM2w&oe=66F53668"}, {"file_name": "WiviCap_Menu.png", "id": "1012519640612356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974570_1012519647279022_6705925294837175412_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wwWBgsRczT8Q7kNvgEhirTH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AB7rURcObz09wLD0uEBjBqW&oh=00_AYB4QomJ8Uqbd1d-Ni-a4aFlLE7XD8LcvKxMJpdNHaWL9g&oe=66F54C23"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "WiVi", "keywords": ["wifi", "networking", "wireless", "analyzer", "scanner"], "long_description": "WiVi is the ultimate AR tool for spatially visualizing and optimizing your WiFi network. Whether you're at home streaming VR games, or engaging in a remote work video meeting, WiVi helps you map and understand your wireless environment with precision.\n\n- **Signal Strength Mapping:** Walk around your space to create a real-time spatial map of your WiFi coverage. Accounts for walls, windows, etc.\n- **Internet Speed & Latency Measurement:** Assess your network\u2019s performance with detailed speed tests and ping analysis.\n- **Interference Detection:** Identify overlapping networks and interference sources to improve your connection quality.\n- **AR-Powered Visualization:** Utilize mixed reality to see your network\u2019s performance through your Meta Quest headset.\n\nWhether you\u2019re a network enthusiast, a professional, or someone just looking to improve their WiFi, WiVi offers the tools you need to optimize your wireless experience.", "short_description": "Explore and map your WiFi like never before with WiVi, the AR-powered tool that visualizes your signal strength, internet speed, and interference in the world around you.\n\nWalk through your home or office to build a detailed map of the space. Ideal for optimizing your wireless setup for streaming games or video meetings."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.niftysoftar.com/wivi-privacy-policy", "developer_terms_of_service_url": "https://www.niftysoftar.com/wivi-terms-of-service", "publisher_name": "Niftysoft Technologies LLC", "support_website_url": "https://www.niftysoftar.com/feedback", "website_url": "https://www.niftysoftar.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8156458974469115"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227815876_880488936797920_4918215733518030332_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ANqkY5xTN4Q7kNvgE22AGz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AB7rURcObz09wLD0uEBjBqW&oh=00_AYARX-hR1cGS66nbgw9tCOkSV_ykSLvC_uoKjoyE9Pg43g&oe=66F536BE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "WiVi", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Business", "id": "421923165850360"}, {"topic_name": "Utilities", "id": 