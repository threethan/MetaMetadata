 "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367587_398515593267606_6418502586751029746_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yX9JEwf61owQ7kNvgEJXv48&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-PaCGMdnrT5L3DrNq8TvhYddJFiAeLGY6dl4qaoQQrA&oe=6752E1C9"}, {"file_name": "WiviCap_Inter.png", "id": "1905155096615361", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375757_1905155099948694_8778738369372943147_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vjDKxdtMU_sQ7kNvgH4qQrq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByPxfHOVcDvwgbMZz-Af2jQUsl3RSm_KvjoZk5zHKovg&oe=6752D0E8"}, {"file_name": "WiviCap_Menu.png", "id": "1012519640612356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974570_1012519647279022_6705925294837175412_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVs5Cl0C3nkQ7kNvgHIVRW1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbcwALYqIomkz27aJyl2Y0vENml_XnA1h3gXlMKkrslw&oe=6752E6A3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "WiVi", "keywords": ["wifi", "networking", "wireless", "analyzer", "scanner"], "long_description": "WiVi is the ultimate AR tool for spatially visualizing and optimizing your WiFi network. Whether you're at home streaming VR games, or engaging in a remote work video meeting, WiVi helps you map and understand your wireless environment with precision.\n\n- **Signal Strength Mapping:** Walk around your space to create a real-time spatial map of your WiFi coverage. Accounts for walls, windows, etc.\n- **Internet Speed & Latency Measurement:** Assess your network\u2019s performance with detailed speed tests and ping analysis.\n- **Interference Detection:** Identify overlapping networks and interference sources to improve your connection quality.\n- **AR-Powered Visualization:** Utilize mixed reality to see your network\u2019s performance through your Meta Quest headset.\n\nWhether you\u2019re a network enthusiast, a professional, or someone just looking to improve their WiFi, WiVi offers the tools you need to optimize your wireless experience.", "short_description": "Explore and map your WiFi like never before with WiVi, the AR-powered tool that visualizes your signal strength, internet speed, and interference in the world around you.\n\nWalk through your home or office to build a detailed map of the space. Ideal for optimizing your wireless setup for streaming games or video meetings."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.niftysoftar.com/wivi-privacy-policy", "developer_terms_of_service_url": "https://www.niftysoftar.com/wivi-terms-of-service", "publisher_name": "Niftysoft Technologies LLC", "support_website_url": "https://www.niftysoftar.com/feedback", "website_url": "https://www.niftysoftar.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8156458974469115"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1089134113214789"}]}, "baseline_offer": {"id": "1089134113214789"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726340340, "status": "PUBLISHED", "id": "1089134113214789"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8157230207725325", "version": "2.20"}, "id": "1474512503205392", "channel_name": "LIVE"}]}, "is