s4-1.oculuscdn.com/v/t64.5771-25/39036625_3511534758973991_8192538750696408030_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rjGLqpNr20IQ7kNvgHNIed_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDQVUUuA3jBRit7IbbsfAh5eebPC0lfbqB471r1XyxjeQ&oe=67864EFF"}, {"file_name": "39.png", "id": "443995806712377", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982721_443995810045710_6496436121171505026_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HJzuVVOsdwIQ7kNvgGzBphG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC1LSrjZ3e6FoIPFh8KFc7JHYPdk6mQlTj-_3Lowc5RZQ&oe=67864B1F"}, {"file_name": "52.png", "id": "286250996191821", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974524_286250999525154_8505747994333153712_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PbuQDNC54FIQ7kNvgFe77tt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBvxB17ViWvrpT0gNFIt2G1auQ_s-CukU3lKv6WpcdRxA&oe=67864A03"}, {"file_name": "83.png", "id": "2866450623626180", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974876_2866450626959513_2327236995567801194_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QVr3BR7W79MQ7kNvgHyjdeJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAQoEtScMf1OBr2QdjfrcBaaDt9GoBQOhcKMhEz_FOurg&oe=67863F5E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_art_landscape.png", "id": "452869179105192", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974805_452869182438525_3402871693932928401_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRTUlQLs95sQ7kNvgGD2vHl&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCOGiClwpq18SSdD929dGAX3WrM2HQyzzx0mCL6GEWZzQ&oe=67863B33"}, "display_name": "Marble Pop Paradise", "keywords": [], "long_description": "EXPERIENCE REALISTIC LANDSCAPES\n\nEngage with ten different, interactive environments, from stunning arctic glaciers to rolling grassy hills to serene ocean islands.\n\nENJOY MUSIC & VIDEOS\n\nListen to your favorite music, throw on a new podcast, surf the web or watch cute cat videos on Youtube all while playing\n\nRELIEVE STRESS WITH MARBLE-POP CHALLENGES\n\nThe marble-pop goals offer players a stimulating, low-pressure change in focus from their everyday routines. Complete levels and unlock new special marbles and special abilities.\n\nACCESSIBLE FOR ALL TYPES OF PLAYERS\n\nWhile easy enough for beginners to pick up and start playing, players looking for more of a challenge can change their shooting angles and positions, customizing the physical effort and marksmanship needed for each shot.", "short_description": "Looking for some stress relief? Sit back, relax and explore mesmerizing scenery while solving stimulating marble pop challenges. Let your worries disappear as you travel to different calming environments and work through the levels with your favorite music playing in the background. Or, feel free to just relax and enjoy the nature!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.winrgames.com/wgw/policy", "developer_terms_of_service_url": null, "publisher_name": "WINR Games Inc", "support_website_url": null, "website_url": "https://www.winrgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "412883553971351"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "11394360808832