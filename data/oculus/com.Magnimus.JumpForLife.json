": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974547_536221635752451_4853644413624356969_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OLSX983Vn6wQ7kNvgFBUOy-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_5WRqUp0deCwawNF-X7EzLFt20L4h-pa970Zun8EPJw&oe=6745BB73"}, {"file_name": "GP_4.png", "id": "544074484618501", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035344_544074487951834_6646070699915706266_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kPZdfHzdwBIQ7kNvgGrgT4p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKkPN1sh3DqpEL8gvuj-y5aSO26pGWaRI71tLMGrer_w&oe=6745C63C"}, {"file_name": "GP_5.png", "id": "481067531585307", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974889_481067534918640_1631627096528002565_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6dTtdMnF_xUQ7kNvgG0avyk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC02FCo5-6zOqU4h-tn1M-sAY8CdcMZ6boHvQubXIq-Bw&oe=67459B45"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Jump For Life", "keywords": ["arcade", "mr", "fitness", "retro", "action"], "long_description": "Jump for life is a first of its kind mixed reality arcade game that converts your floor into a lethal arcade jump machine! For the first time ever, a mixed reality arcade experience that sets your hands free. Your legs are your new controllers.\n\nThe player needs to reach all the numbers in the correct sequence before the time runs out. All the while avoiding the red zones of death. The zones of death keep coming in increasing complexities with each level. Set a high score and compete with players globally.\n\nJump for life is the ultimate test of your agility and presence of mind. \n\nTo play this game, you need to attach the quest-2 controllers on your feet. A separate attachment need to be bought for that. It is available on Amazon as Quest-2 trackpads.\n\nAmazon Link: https://www.amazon.com/Trackstraps-Meta-Quest-Controller-Compatible-Immersion/dp/B0CQ7KNXP2/", "short_description": "Jump for life is a first of its kind mixed reality arcade game that converts your floor into a lethal arcade jump machine! Use your legs for an action packed mixed reality challenge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://magnimus.com/privacy-policy/vital-knights", "developer_terms_of_service_url": null, "publisher_name": "Magnimus ", "support_website_url": null, "website_url": "https://magnimus.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8500588616659032"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "420856407275703"}]}, "baseline_offer": {"id": "420856407275703"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726637521, "status": "PUBLISHED", "id": "420856407275703"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8654805967903962", "version": "0.16.0"}, "id": "1541030276487790", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8500588593325701", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8654805967903962"}, "release_status": "RELEA