=scontent-iad3-1.oculuscdn.com&oh=00_AYB4rL4uY_K57VqvnVMBEZu7LaBDH0jgIa46KMySdSwKlQ&oe=67556F81"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MetaCoverimage ScenezXR.png", "id": "1147384969808452", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974802_1147384973141785_3689711553277891187_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5rFVkgwwGPoQ7kNvgHPhixg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRLZgM4YHOhwLA_Hd1hN8moOTEvbHPt0Ew5vYWJeYurA&oe=67556FB2"}, "display_name": "Scenez XR", "keywords": ["music", "entertainment", "comedy", "4d"], "long_description": "Step into a new dimension of entertainment with Scenez XR, exclusively on Meta Quest 3. Dive into an unparalleled 4D volumetric experience. Witness breathtaking live performances from your favorite musicians, captured in stunning volumetric detail, as they come alive around you. With the power of XR, you can place the artist right in your home, turning your living space into an intimate concert venue. Feel the music, see the performers in 3D, and interact with the environment in ways you never imagined. Scenez XR pushes the boundaries of immersive technology, bringing you closer to the art and artists you love. Get ready to experience concerts like never before, only on Scenez XR.", "short_description": "4D Volumetric Performances brought into your home! \nThe future is NOW!"}]}, "developer_name": "Paul Vowell", "developer_privacy_policy_url": "https://scenez.io/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "4D Fun Inc", "support_website_url": "https://4dfun.io/", "website_url": "https://scenez.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2687655338230691"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": 