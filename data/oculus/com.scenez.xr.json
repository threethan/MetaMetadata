5964404_8521826312028011421_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vtzwZPeESDcQ7kNvgH6RK2M&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8RUgHYbyw31zfRp5PteY0I&oh=00_AYAwpkDPxTkHEDADBkPmVoV8nbGZxIovKWNbDcPiVAcf_A&oe=66E41585"}, {"file_name": "MetaScreenShot ScenezXR Mica1.png", "id": "1493385884904887", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974469_1493385888238220_5074879560501904780_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2kf3DtmL3yMQ7kNvgGXQNrJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8RUgHYbyw31zfRp5PteY0I&oh=00_AYCL2ccSjl-EjHIsujuVBDyheohZzRB-nWU7mxsff0OLWg&oe=66E43846"}, {"file_name": "MetaScreenShot ScenezXR JM.png", "id": "1151098436114581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974886_1151098439447914_4249611160335607262_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BmuQ6wo-u8QQ7kNvgHN7ueK&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8RUgHYbyw31zfRp5PteY0I&oh=00_AYB-SJw8AgNqs8nwKK1ECDrNNw-fiDbPEt6GMHc58Nf56A&oe=66E40E81"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MetaCoverimage ScenezXR.png", "id": "1147384969808452", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974802_1147384973141785_3689711553277891187_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KlZiWY8ywdQQ7kNvgGCr_HZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8RUgHYbyw31zfRp5PteY0I&oh=00_AYCRqrxiPkfJg4Nx1XCi-GIk1BeNO74AiLtFZENQ_t4U9g&oe=66E40EB2"}, "display_name": "Scenez XR", "keywords": [], "long_description": "Step into a new dimension of entertainment with Scenez XR, exclusively on Meta Quest 3. Dive into an unparalleled 4D volumetric experience. Witness breathtaking live performances from your favorite musicians, captured in stunning volumetric detail, as they come alive around you. With the power of XR, you can place the artist right in your home, turning your living space into an intimate concert venue. Feel the music, see the performers in 3D, and interact with the environment in ways you never imagined. Scenez XR pushes the boundaries of immersive technology, bringing you closer to the art and artists you love. Get ready to experience concerts like never before, only on Scenez XR.", "short_description": "4D Volumetric Performances brought into your home! \nThe future is NOW!"}]}, "developer_name": "Paul Vowell", "developer_privacy_policy_url": "https://scenez.io/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "4D Fun Inc", "support_website_url": "https://4dfun.io/", "website_url": "https://scenez.io/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING", "GAMEPAD"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7617908048336498"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001701_866835432205873_6448606357567963446_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mPOY-CvAaZQQ7kNvgFPFPlW&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8RUgHYbyw31zfRp5PteY0I&oh=00_AYCmFazWVuYzhKz1mxjIU0F_UnGT26xj4mT6GZJal72-YQ&oe=66E43E94"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Scenez XR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Music", "id": "668538087410124"}], "release_date": 1721661746, "lastRevision": {"nodes": [{"id": "7244557809004859", "release_type": "SCHEDULED", "