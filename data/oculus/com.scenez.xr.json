g space into an intimate concert venue. Feel the music, see the performers in 3D, and interact with the environment in ways you never imagined. Scenez XR pushes the boundaries of immersive technology, bringing you closer to the art and artists you love. Get ready to experience concerts like never before, only on Scenez XR.", "short_description": "4D Volumetric Performances brought into your home! \nThe future is NOW!"}]}, "developer_name": "Paul Vowell", "developer_privacy_policy_url": "https://scenez.io/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "4D Fun Inc", "support_website_url": "https://4dfun.io/", "website_url": "https://scenez.io/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING", "GAMEPAD"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7617908048336498"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1016174113492877"}]}, "baseline_offer": {"id": "1016174113492877"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721661746, "status": "PUBLISHED", "id": "1016174113492877"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7584293375031299", "version": "0.1.8"}, "id": "434905415937850", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "Andr