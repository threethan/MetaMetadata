ail": {"file_name": "MetaCoverimage ScenezXR.png", "id": "1147384969808452", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974802_1147384973141785_3689711553277891187_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hsNo8DY957wQ7kNvgEBxvNN&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB96I6x_sZvyODN54WH2uforcM1uz--g6457Tt9llKJaQ&oe=671384B2"}, "display_name": "Scenez XR", "keywords": ["music", "entertainment", "comedy", "4d"], "long_description": "Step into a new dimension of entertainment with Scenez XR, exclusively on Meta Quest 3. Dive into an unparalleled 4D volumetric experience. Witness breathtaking live performances from your favorite musicians, captured in stunning volumetric detail, as they come alive around you. With the power of XR, you can place the artist right in your home, turning your living space into an intimate concert venue. Feel the music, see the performers in 3D, and interact with the environment in ways you never imagined. Scenez XR pushes the boundaries of immersive technology, bringing you closer to the art and artists you love. Get ready to experience concerts like never before, only on Scenez XR.", "short_description": "4D Volumetric Performances brought into your home! \nThe future is NOW!"}]}, "developer_name": "Paul Vowell", "developer_privacy_policy_url": "https://scenez.io/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "4D Fun Inc", "support_website_url": "https://4dfun.io/", "website_url": "https://scenez.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "s