86_1151098439447914_4249611160335607262_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZLAmhYbe0EIQ7kNvgExoxly&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnxczHOn6g2Fp4RRqI6CXFo&oh=00_AYAKj5DQf6WvNilGhiWmp7w3TfgesKP7luooTakZDrv9sQ&oe=66F53201"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MetaCoverimage ScenezXR.png", "id": "1147384969808452", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974802_1147384973141785_3689711553277891187_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdBg1xpzSvYQ7kNvgFlLqOT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnxczHOn6g2Fp4RRqI6CXFo&oh=00_AYAciz2zgfRFWaFDpUbYAvx3wNz4BK-JoF-S8SgxpCjKKA&oe=66F53232"}, "display_name": "Scenez XR", "keywords": ["music", "entertainment", "comedy", "4d"], "long_description": "Step into a new dimension of entertainment with Scenez XR, exclusively on Meta Quest 3. Dive into an unparalleled 4D volumetric experience. Witness breathtaking live performances from your favorite musicians, captured in stunning volumetric detail, as they come alive around you. With the power of XR, you can place the artist right in your home, turning your living space into an intimate concert venue. Feel the music, see the performers in 3D, and interact with the environment in ways you never imagined. Scenez XR pushes the boundaries of immersive technology, bringing you closer to the art and artists you love. Get ready to experience concerts like never before, only on Scenez XR.", "short_description": "4D Volumetric Performances brought into your home! \nThe future is NOW!"}]}, "developer_name": "Paul Vowell", "developer_privacy_policy_url": "https://scenez.io/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "4D Fun Inc", "support_website_url": "https://4dfun.io/", "website_url": "https://scenez.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": 