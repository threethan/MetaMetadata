68070_1631769869454147584_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jW3PLnXTACAQ7kNvgFv2Ubn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpi3OFQ37LvzSr1oSZqiHnrAwMQhy6xHDzCl1bOcgjQA&oe=6754518F"}, {"file_name": "Mtm8kX.png", "id": "2529928650591877", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75462955_2529928653925210_6864050379793891328_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JBFbUYXOeCAQ7kNvgEE7CiK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCM9V-LwZsAJGhR9VCtN-htWYlXG-dGdRVjtU_feHefFw&oe=675442B9"}, {"file_name": "D4Fzdl.png", "id": "233927637932719", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75286677_233927641266052_8355620297524641792_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gWQVWTZ9QIMQ7kNvgGQA5dQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpTbPpXzqiLmnaDYRQZiAm0eLlLmbjECHWm2WplTh9vw&oe=675439B9"}, {"file_name": "eOnbXE.png", "id": "227989478493004", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375757_227989481826337_189728200320876544_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nhGk3nqit0kQ7kNvgG-KmDo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCq73HIWtzC7teS6pczIhh85nxVuS9mF8IDRqk96L5i5g&oe=6754411F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/fwKxUK", "id": "1100431366995890", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566685_1100431370329223_1470462940904685568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S2S4ZBh0_CgQ7kNvgF-wedE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwYJuFL_ylRc26egrmSOMRTvZcAwzVdmjYZPsI0hpuXw&oe=675429E6"}, "display_name": "Elixir", "keywords": ["Magic", "Dragon", "Handtracking", "fantasy", "funny"], "long_description": "Elixir is seeking an experienced lead sorceress . . . 's apprentice. You\u2019ll join our team located somewhere in the nether world to feed, wash, and document mysterious creatures (applicants inexperienced with dragon vomit need not apply). The apprentice will also maintain various delicate contraptions while experimenting in an unstable alchemy lab. Constant praise of the sorceress's brilliance is expected.\n\nMust be certified in the quantum manipulation of elemental magicks as they relate to the Oculus Quest device. Availability to work on-site FOREVER a plus. \n\nNo pay.\n\nPlease staple a death certificate to your application in the top left corner angled at precisely 45 degrees (must be your own death certificate).\n\nFURTHER RESPONSIBILITIES\n* Quietness and obedient-ness\n* Maintaining a gullible but enthusiastic temperament\n* Teleporting hither and yon\n* Daily calisthenics of the fingers and the hands\n\nElixir employees enjoy zero benefits, no medical or vision, and an open office setting.", "short_description": "You are the clueless apprentice to an awkward sorceress. She needs your very human hands to operate her contraptions, and everything\u2019s just a little . . . unexpected. By the end, magic has a less-than-desirable impact on the anatomy of your fingers, and it\u2019s nobody\u2019s fault but your own."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Oculus", "support_website_url": null, "website_url": "http://elixir.magnopus.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tra