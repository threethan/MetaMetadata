-u1wWbxgkWFMGy1NLwqut0AIxw&oe=67150142"}, {"file_name": "1gRrYe.png", "id": "649494149168060", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974624_649494152501393_4889968777875161088_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lVmPMhyF20gQ7kNvgFJq-jY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAf91fgu2_GBNHTifK9c9FZOooAt7J_e_U3BGdBqXdhYA&oe=6714F158"}, {"file_name": "PS1tWP.png", "id": "223941032361146", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974555_223941035694479_8181425666768502784_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mD5Wmk9XNCEQ7kNvgGnz_eu&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYsuIpqTY47xtsghDTNfEQJUrcAQGLpFy7SZm9Fkp7LA&oe=6714D608"}, {"file_name": "d5e4uO.png", "id": "233096617897309", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982699_233096621230642_1541719454822432768_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q-84rgnjsYYQ7kNvgHa_rqL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0HRfH65VyZuq1S949fdWVBirEfrWiAudMF0WIwfAGbg&oe=6714DCBD"}, {"file_name": "aDU9NY.png", "id": "513503572678353", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974624_513503576011686_5452742568917860352_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hzqyb58BFvUQ7kNvgHm0EDz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB81WLoCwrv-MEi1a0TQca0_c4mxKlieCkQkkzU9loLgw&oe=6714DB3E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/RTeFWd", "id": "276552923350738", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031433_276552926684071_5398554272214286336_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Aelm182F_fYQ7kNvgF-Wusx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCM20qgcUv0JrZpP25Jph0QlA4HZOgmwUd8RPqfAzf0VQ&oe=6714EEC9"}, "display_name": "Winery Tour in Georgia", "keywords": ["Wine", "Travel", "WineryTour", "Food", "History"], "long_description": "Georgian winemaking method is a part of UNESCO Intangible Heritage. It is the longest uninterrupted tradition of creating wine in the world. Georgia is also one of the oldest winegrowing countries - the pips of the grapes that have been found at Shulaveri Gora historical site are witnessing the fact that the locals were cultivating vines here around 8000 years ago.\nHow does a winery visit look like, once you're in Georgia? Of course, it's a bit of history, a bit of technology, and of course, some excellent food, drinks, songs, and toasts. Take a tour in Giuaani Winery in Manavi (Kakheti), discover more about the Georgian wine, and attend the friendly Georgian supra with the international visitors afterward!\nOf course, this is a demo version that gives you an idea about a half a day winery tour - it takes only one hour to get there from Tbilisi. But a deeper immersion will take you a bit longer. More wineries, more tastings, more exciting landscapes... Georgia is very diverse!", "short_description": "Visit Giuaani Winery in Kakheti with Trails and Wines, and learn more about the Georgian wine and winemaking peculiarities"}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.vrexbox.com/", "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": "http://vr-ex.com/", "website_url": "http://vr-ex.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "TRAVEL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1004954587036166"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://sc