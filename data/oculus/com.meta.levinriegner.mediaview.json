culuscdn.com&oh=00_AYA3ay24Hse9Nm_unNdIOj7C9ItgZRPr7vUzlT_3pczkqA&oe=6703D9C9"}, {"file_name": "Dashboard [2D].png", "id": "543378271489411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982683_543378274822744_1668738253983812144_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vS2wCzd_q9wQ7kNvgG3diEl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkn6XXhwB0TxrpLvbiebHMmP_BsOIZyqzcR47keoauWg&oe=6703B20C"}, {"file_name": "Dashboard [360].png", "id": "8194934723888943", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221322_8194934727222276_7198132996073805409_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WZh93ArmiIkQ7kNvgFHk158&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDkPHjfwPVHyfV6kUFHRtje_NGeqg3c7vg6ql4Sns_Uw&oe=6703BCBF"}, {"file_name": "Dashboard [Ray-Ban].png", "id": "1532366430739995", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86627634_1532366434073328_4454899938512176946_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2OBy-e60f78Q7kNvgH4ZGxg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQ7DLZ5iEeCIejM-36aFyUUMeVKLH8-6uAlSNg49gZyw&oe=6703C04D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Media View", "keywords": ["media", "immersive", "spatial", "panorama"], "long_description": "Experience your photos and videos in a mixed reality environment. Whether for personal projects, professional use, or simply exploring media in a new way, Media View provides an intuitive experience, offering a fresh perspective on an important utility application in a spatial setting.\n\n**Media Compatibility**\n\nWith a continually expanding range of media types, Media View currently supports viewing standard photos and videos, 360\u00b0 media, and panoramas. New formats, like content captured with Ray-Ban Meta, are also being integrated, with more on the way.\n\n**Multi-Panel Viewing**\n\nExperience a fully immersive environment by surrounding yourself with selections of your photos and videos in an immersive floating collage. It\u2019s unlike anything you\u2019ve seen before! View and interact with all media types simultaneously in a spatial environment, creating a dynamic and interactive experience that surrounds you in every direction.\n\n**Immersive Viewing**\n\nToggle between viewing your media around you (with Multi-Panel Viewing) to fully immersing yourself in your space with individual photos or videos in \u201cImmersive View\u201d. Whether it's a 360-degree image, a panorama, or a standard video, Media View allows you to dive deep into immersive views, letting you explore every detail as if you were inside the media itself.\n\n**Current media types supported:**\n- Standard Photos & Videos\n- 360 Photos & Videos\n- Panoramas\n- Ray-Ban Meta Photos & Videos\n", "short_description": "Interact with standard and immersive photos and videos in a mixed reality environment. Media View supports a growing range of media types including standard photos and videos, 360\u00b0 media, panoramas, and Ray-Ban Meta content. Surround yourself with media in an immersive collage or fully dive into individual views. Built with the Meta Spatial SDK for Quest, Media View offers a dynamic, intuitive experience for exploring your media in new ways."}]}, "developer_name": "Meta", "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Meta", "support_website_url": null, "website_url": "https://meta.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "