_nc_sid=6e7a0a&_nc_ohc=v0h_CtRvOI4Q7kNvgECK24s&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG2U37-rko2Wm6mlQ2XdLQx&oh=00_AYCpm_iSMgxhnOMFGr-sJ9P9GDBl9GNtJ9Wf29RXyazniA&oe=66F6A1B9"}, {"file_name": "migrated_image.png", "id": "582124092514203", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974770_616761398764872_2926226150080380928_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cBJd91cPFGIQ7kNvgFiVTwS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG2U37-rko2Wm6mlQ2XdLQx&oh=00_AYBNHNobznVUNQmyFahS1ib8NOier7epN58ibdivACLBVg&oe=66F67DD6"}, {"file_name": "migrated_image.png", "id": "214507646421385", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974645_820859614941200_7592492187703574528_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRwzruUdOkMQ7kNvgFAnDv9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG2U37-rko2Wm6mlQ2XdLQx&oh=00_AYD2TJOp6p7W6nHT_UAAz-UYDT9ftiOJUmXkiQTfYtIvpQ&oe=66F68762"}, {"file_name": "migrated_image.png", "id": "160732235031751", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974579_2097317323685146_8736316079699132416_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WGJDfsmxr_MQ7kNvgGJAhGC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG2U37-rko2Wm6mlQ2XdLQx&oh=00_AYD13hmfflfTocKxcj6BgWqZn5_s00MIzbyBqMtzdvOo1Q&oe=66F688FB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Anceder", "keywords": ["shoot", "arcade", "space", "bullet", "shmup"], "long_description": "Bienvenue in the arcade shoot-them-up (shmup, bullet hell). Choose your ship and try to make the best score.\n\nThe \"MORE\" Update : Now with more bonus, more sounds, more languages (Spanish & Chinese texts), more fun ! The Fury mode is now easier.\n\n- Play the five worlds in a row to make a high score.\n- Original musics in HD. Music are level-long (no repetitive loops).\n- Normal and hard mode. You will make huge scores in hard mode.\n\n- Try the fury mode for an even faster game. \n- Optimized for Oculus Go.\n- Playable with joypad or remote.\n- Scores saved worldwide (if connected to the internet). You can set initials to each score to compare with your visiting friends.\n- You can play lying in bed (see options menu or pause menu).\n\nA bug or idea ? Please write to cedric@anceder.com or twitter @ancedergame", "short_description": "Dive in the arcade shoot-them-up (shmup, shoot'em up, bullet hell). A lot of action is awaiting you. \"Insert coin\" and jump in the shmup !"}]}, "developer_name": "C\u00e9dric Andreu", "developer_privacy_policy_url": "https://www.noixdecroco.com/ancedermbr/privacy.html", "developer_terms_of_service_url": "http://www.anceder.com/anceder", "publisher_name": "C\u00e9dric Andreu", "support_website_url": "http://contact.anceder.com/", "website_url": "http://www.anceder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "zh_CN", "es"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "731699601106484"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974717_2302266453215639_9060570528405782528_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sy5gGOdyaU0Q7kNvgH9l6cd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG2U37-rko2Wm6mlQ2XdLQx&oh=00_AYBlvKivN6KZ3bqt-X1eQnyyv4mpuzDegkGM2l8fQDtHpA&oe=66F69ECB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Anceder", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1554915600, "lastRevision": {"nodes":