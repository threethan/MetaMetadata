_nc_sid=6e7a0a&_nc_ohc=x-uR0X5IaawQ7kNvgHA5j7o&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoW8nnCMqdQlFrnJAUkMHda&oh=00_AYAUzobl8zcyvxDJjHrrwu3COoylFUtP1BsW6wdiTXjbrA&oe=66F15BB9"}, {"file_name": "migrated_image.png", "id": "582124092514203", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974770_616761398764872_2926226150080380928_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mJiM0VmtotMQ7kNvgEovMcH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoW8nnCMqdQlFrnJAUkMHda&oh=00_AYDSVVRKF5bv0v2UZbIHMXs8qT_Y6WfTl6dzSctuTtigpA&oe=66F137D6"}, {"file_name": "migrated_image.png", "id": "214507646421385", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974645_820859614941200_7592492187703574528_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zGtyqJVF7VoQ7kNvgG1svWa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoW8nnCMqdQlFrnJAUkMHda&oh=00_AYD14stN3Y1TgKoNXLIb83-i186ntUX9xIcZ9CaL4PCQmQ&oe=66F14162"}, {"file_name": "migrated_image.png", "id": "160732235031751", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974579_2097317323685146_8736316079699132416_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JWNlaDY8tusQ7kNvgE3LYnM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoW8nnCMqdQlFrnJAUkMHda&oh=00_AYD4J5xeTpRi8V8kL7RILSajJRyOi7u2rOFQvWlT5jqjmA&oe=66F142FB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Anceder", "keywords": ["shoot", "arcade", "space", "bullet", "shmup"], "long_description": "Bienvenue in the arcade shoot-them-up (shmup, bullet hell). Choose your ship and try to make the best score.\n\nThe \"MORE\" Update : Now with more bonus, more sounds, more languages (Spanish & Chinese texts), more fun ! The Fury mode is now easier.\n\n- Play the five worlds in a row to make a high score.\n- Original musics in HD. Music are level-long (no repetitive loops).\n- Normal and hard mode. You will make huge scores in hard mode.\n\n- Try the fury mode for an even faster game. \n- Optimized for Oculus Go.\n- Playable with joypad or remote.\n- Scores saved worldwide (if connected to the internet). You can set initials to each score to compare with your visiting friends.\n- You can play lying in bed (see options menu or pause menu).\n\nA bug or idea ? Please write to cedric@anceder.com or twitter @ancedergame", "short_description": "Dive in the arcade shoot-them-up (shmup, shoot'em up, bullet hell). A lot of action is awaiting you. \"Insert coin\" and jump in the shmup !"}]}, "developer_name": "C\u00e9dric Andreu", "developer_privacy_policy_url": "https://www.noixdecroco.com/ancedermbr/privacy.html", "developer_terms_of_service_url": "http://www.anceder.com/anceder", "publisher_name": "C\u00e9dric Andreu", "support_website_url": "http://contact.anceder.com/", "website_url": "http://www.anceder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "zh_CN", "es"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "731699601106484"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974717_2302266453215639_9060570528405782528_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8hTLO2GeMc4Q7kNvgEGjQs2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoW8nnCMqdQlFrnJAUkMHda&oh=00_AYA8ZMMNdqdI7wM0zhDbCJasqBPIyY_6bYXT0IGYRZHCnw&oe=66F158CB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Anceder", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1554915600, "lastRevision": {"nodes":