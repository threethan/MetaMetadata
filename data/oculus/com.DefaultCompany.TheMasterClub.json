uluscdn.com&oh=00_AYCPWa3Rymk8XiIgBjXVxxU8nExZBcrNvhdUJu-qXVK2iA&oe=676D535B"}, {"file_name": "ScreenShot4.png", "id": "251261660934237", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_251261664267570_1308644332253553952_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sepPyZxoEHEQ7kNvgFclkxe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoftYIchH8nqFA0ztEHRJa4hP3aYdzblhqnCywbrYLAg&oe=676D2CDE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1674681809669861", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974551_1674681813003194_2895250008313765539_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xsulvGGoMy4Q7kNvgFG0HBE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCheN07jGwm4mR0j3kwosam5eNcvx2H-1-hK8ZBN9rNQ&oe=676D5354"}, "display_name": "The Master Club", "keywords": [], "long_description": "Join the Discord community to find other players to play online with:\nhttps://discord.gg/W4KMzaqsas\n\nThe Master Club is a collection of casual games which includes:\n- Air Hockey\n- Archery\n- Basketball\n- Bowling\n- Checkers\n- Chess\n- Football Table\n- Mini Golf\n- Pool Billiard\n- Rubiks Cube 2x2\n- Rubiks Cube 3x3\n- Solitaire\n- Table Tennis\n- Tennis\n- Tic Tac Toe\n- Pistol shooting\n- Chinese Checkers\n- Ludo\n- Backgammon\n- Draw Domino\n\nThis game contains the following features:\n- Single Player mode with 4 levels of difficulty (Easy, Medium, Hard, Master)\n- Multiplayer mode with an internal matchmaking system\n- 60 Achievements to unlock\n- Leaderboards to see your ranking compared to other players\n- Voice chat to talk with your opponent on multiplayer mode\n- Avatar selection\n\nThe game contains the following scenarios:\n- Day Outdoor\n- Night Outdoor\n- Hotel\n- Room\n- Bar\n\nWalk around the scenario using the Thumbstick buttons,\nmove up and down using the Thumbstick buttons,\nthis game uses snap turn to reduce potential motion sickness,\nChess game offers 4 different styles of pieces,\nCheckers game offers 2 different styles of pieces,\nPool game offers 3 different styles of tables,\nRubik's Cube 2x2 and 3x3 contain auto solver\nthat can be stopped at any moment.", "short_description": "Play:\n- Air Hockey\n- Archery\n- Basketball\n- Bowling\n- Checkers\n- Chess\n- Football Table\n- Mini Golf\n- Pool Billiard\n- Rubiks Cube 2x2\n- Rubiks Cube 3x3\n- Solitaire\n- Table Tennis\n- Tennis\n- Tic Tac Toe\n- Pistol shooting\n- Chinese Checkers\n- Ludo\n- Backgammon\n- Draw Domino\n\nOn 5 different scenarios:\n- Day Outdoor\n- Night Outdoor\n- Hotel\n- Room\n- Bar"}]}, "developer_name": null, "developer_privacy_policy_url": "https://midicreationsvr.blogspot.com/p/privacy-policy-updated-at-2021-09-17.html", "developer_terms_of_service_url": null, "publisher_name": "Midi Creations", "support_website_url": null, "website_url": "https://midicreationsvr.blogspot.com/p/who-are-we-indie-virtual-reality-video.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6987874997959350"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974791_265060772873710_365486431202601560_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7n195w7Ltu8Q7kNvgHq2s5P&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_