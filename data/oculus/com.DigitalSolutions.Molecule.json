/v/t64.5771-25/75289720_714589727495611_2213380896301030074_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6_HEZzNcdDIQ7kNvgG3iGu6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQFoTcxkoOgvwdka8uIwyuMpUE2cRwvpZ9xNCoH-AYtQ&oe=674C51D0"}, {"file_name": "02.png", "id": "785032866932681", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035384_785032870266014_7718224772803842566_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1rDJOPKPR9MQ7kNvgEMZVaV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDpWv1zZVLz38AP8KqrzkkhWyNTxmo7F8wa48a5HiaaDA&oe=674C517A"}, {"file_name": "05.png", "id": "1649074942503130", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001659_1649074945836463_2226003676447858643_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ELAhE41EP0QQ7kNvgGyPcxu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTIu0w0c53pIzv7iCLqXUjFzGY9Q-lfZkb61ECYfkjYg&oe=674C31B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "910612357516245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75441584_910612360849578_7228555985229582529_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XzrX_RjzYWYQ7kNvgFJ6KnE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZwMfx0sybVZ4xGQkmMbNWN06qRD4egJr04_jAlaxz-A&oe=674C5C53"}, "display_name": "Atoms and Molecules", "keywords": [], "long_description": " This app provides a series of interactive lessons that detail the structure, properties, and behaviors of atoms and molecules, offering users a hands-on learning experience. Each lesson is followed by engaging tasks that reinforce the concepts taught, allowing learners to apply their knowledge in virtual experiments and quizzes. From visualizing the intricate arrangements of electrons to constructing molecules in a 3D space, this app makes complex scientific concepts accessible and exciting. Perfect for students of all ages, it transforms abstract chemistry principles into tangible experiences, enhancing understanding and retention. Dive into the microscopic world and discover the wonders of chemistry like never before!", "short_description": "Explore the Building Blocks of the Universe with our Educational VR App designed to immerse students in the fascinating world of atoms and molecules."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["mn"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7205168979518246"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "736195948279831"}]}, "baseline_offer": {"id": "736195948279831"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709764140, "status": "PUBLISHED", "id": "736195948279831"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7205217152846762", "version": "1.0"}, "id": "1136967363979095", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7205168962851581", "is_concept": false, "latest_released_binary": {"__typen