1-25/39035384_785032870266014_7718224772803842566_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nYyNiXnlhQYQ7kNvgEzSJWg&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah8PfOEZWHpPKPtWg9-d3bX&oh=00_AYDUudueUSSRN3YMhh4kiGfVHlNIMExwBMdE1GCBBffi2g&oe=66F0087A"}, {"file_name": "05.png", "id": "1649074942503130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001659_1649074945836463_2226003676447858643_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZQldqlFBseEQ7kNvgFD6A8n&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah8PfOEZWHpPKPtWg9-d3bX&oh=00_AYBOCWmL0c7lal-EfY4atBcjX0DsGaP4aC8O52iD3YielQ&oe=66EFE8B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "910612357516245", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441584_910612360849578_7228555985229582529_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f-bohmw9XiAQ7kNvgFu4wCE&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah8PfOEZWHpPKPtWg9-d3bX&oh=00_AYA8tEuZ3QDt0dKM4NTkyKQSgLiDuk8Lf8iSdbAhRiOiLA&oe=66F01353"}, "display_name": "Atoms and Molecules", "keywords": [], "long_description": " This app provides a series of interactive lessons that detail the structure, properties, and behaviors of atoms and molecules, offering users a hands-on learning experience. Each lesson is followed by engaging tasks that reinforce the concepts taught, allowing learners to apply their knowledge in virtual experiments and quizzes. From visualizing the intricate arrangements of electrons to constructing molecules in a 3D space, this app makes complex scientific concepts accessible and exciting. Perfect for students of all ages, it transforms abstract chemistry principles into tangible experiences, enhancing understanding and retention. Dive into the microscopic world and discover the wonders of chemistry like never before!", "short_description": "Explore the Building Blocks of the Universe with our Educational VR App designed to immerse students in the fascinating world of atoms and molecules."}]}, "