1-25/39035384_785032870266014_7718224772803842566_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sUpfOVaarUcQ7kNvgEOAhK0&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8J8Q-FZUmpZ_s6CMupl57f&oh=00_AYBVIxJOUSX-a9MdH9FvhOXwKSHv3tQE02Z1fiSPB0EDNw&oe=66EAC27A"}, {"file_name": "05.png", "id": "1649074942503130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001659_1649074945836463_2226003676447858643_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O7iHIugFZakQ7kNvgGt-0ps&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8J8Q-FZUmpZ_s6CMupl57f&oh=00_AYBmM3e7pxVjmr7_bM3vRxvlEhZMbGo0B9JjNJ4b4-UVZA&oe=66EAA2B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "910612357516245", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441584_910612360849578_7228555985229582529_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nXqQ7CtxwiwQ7kNvgHp7kV_&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8J8Q-FZUmpZ_s6CMupl57f&oh=00_AYCHx0YXhl_22tPoqbv4gKYcBqR9UsNCRNsjxMoaeltXuA&oe=66EACD53"}, "display_name": "Atoms and Molecules", "keywords": [], "long_description": " This app provides a series of interactive lessons that detail the structure, properties, and behaviors of atoms and molecules, offering users a hands-on learning experience. Each lesson is followed by engaging tasks that reinforce the concepts taught, allowing learners to apply their knowledge in virtual experiments and quizzes. From visualizing the intricate arrangements of electrons to constructing molecules in a 3D space, this app makes complex scientific concepts accessible and exciting. Perfect for students of all ages, it transforms abstract chemistry principles into tangible experiences, enhancing understanding and retention. Dive into the microscopic world and discover the wonders of chemistry like never before!", "short_description": "Explore the Building Blocks of the Universe with our Educational VR App designed to immerse students in the fascinating world of atoms and molecules."}]}, "