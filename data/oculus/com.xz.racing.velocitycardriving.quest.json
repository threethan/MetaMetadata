16KFyJVvZJJe9v-Ly9eCGTUmfnTRcw0zxxVxw&oe=66E416A8"}, {"file_name": "3.png", "id": "2211024162439008", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974468_2211024165772341_3723666187956196288_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=52j56G9HROAQ7kNvgGSxMi_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq7VwoMdx-rQoQ2FuJgBdWA&oh=00_AYDOhwiRMlCTymJ46Dx-DfDJ7mLeJVN9yZOvSWXUIQxvHA&oe=66E409EC"}, {"file_name": "6.png", "id": "434223259076021", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_434223262409354_4338271883602423781_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aLq1j_O0Mq0Q7kNvgGMQe6A&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq7VwoMdx-rQoQ2FuJgBdWA&oh=00_AYDL0B_AgYHLXE9Yz6_kVeayJ6--JprMSwukoqqRNWzwmA&oe=66E43667"}, {"file_name": "1.png", "id": "959141248914407", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974834_959141252247740_917842555609860014_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gHwuUcEnUygQ7kNvgF6FWFY&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq7VwoMdx-rQoQ2FuJgBdWA&oh=00_AYDgOgiwmuEk_1-GT2usMInti3EmUmvnGrDgj15chgZ6Dg&oe=66E4378D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Velocity Car Driving/Drift Simulator", "keywords": [], "long_description": "\ud83d\ude97 Velocity Car Driving Simulator - A Tranquil Driving Adventure!\n\nImmerse yourself in the art of driving with Velocity Car Driving Simulator. Unlike traditional racing games, our simulator focuses on delivering a serene and realistic driving experience that allows you to appreciate the beauty of the road.\n\n\ud83c\udf04 Key Features:\n\n\ud83d\udee3\ufe0f Dynamic Environments: Cruise through meticulously designed landscapes and cityscapes.\n\ud83d\ude97 Realistic Driving Physics: Experience lifelike driving physics for a true-to-life sensation.\n\ud83d\uddfa\ufe0f Open-World Exploration: Explore vast open worlds with endless driving possibilities.\n\ud83c\udf05 Day and Night Transitions: Witness the changing landscapes and city lights as you drive through different times of the day.\n\ud83d\udd79\ufe0f Intuitive Controls: Enjoy easy-to-use controls designed for a relaxing and immersive driving experience.\n\ud83d\ude99 Customization and Relaxation:\nVelocity Car Driving Simulator lets you customize your driving experience. Relax, unwind, and enjoy the therapeutic nature of our driving simulator.\n\n\ud83c\udf1f Download now and embark on a tranquil driving journey!\n\nEscape the hustle and bustle of racing and embrace the calm beauty of the road with Velocity Car Driving Simulator.", "short_description": "Explore, drive, and relax in Velocity Car Driving/Drift Simulator."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xzsol.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "XZ SOlutions", "support_website_url": null, "website_url": "https://xzsol.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7464687150244667"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1377108150356484"}]}, "baseline_offer": {"id": "1377108150356484"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711479060, "status": "PUBLISHED", "id": "1377108150356484"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": 