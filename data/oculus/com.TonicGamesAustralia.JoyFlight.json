930505792_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EqpQGDJNKBIQ7kNvgED-rL8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlWUHf7hXm2oaB6d0fZPb2b&oh=00_AYAnh58uQJjMOM7PmwoSrtDxVlhskg-9tSpGh7Iuosku9A&oe=66ED4821"}, "display_name": "Joy Flight", "keywords": [], "long_description": "Motion Controls - Turn on the engine, crank the throttle and grab the flight stick using your VR hands.\n\nHuge Open World - Explore an expansive island chain with 29 distinct island runways to unlock.\n\nDynamic Weather System - Skirt the waves, dodge lightning and enjoy the rain as you fly through the storm with the dynamic weather system.\n\nFree Flight- Fly around the world with no limits, explore into the clouds and beyond.\n\nCustomise Your Aircraft- Choose your own color scheme and fly 3 different light aircraft.\n\nFlight Missions - Pick up passengers and test your skills by delivering them to their destination and earn your place on the leaderboard.", "short_description": "Joy Flight is an open world arcade VR flight game where players will explore, unlock runways with daring landings and complete missions across a large chain of islands! Free to Play"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "http://tonicgamesaustralia.com/JoyFlight-privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Tonic Games Australia", "support_website_url": null, "website_url": "https://tonicgamesaustralia.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "394813081514456"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULU