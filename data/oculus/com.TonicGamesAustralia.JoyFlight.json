n expansive island chain with 29 distinct island runways to unlock.\n\nDynamic Weather System - Skirt the waves, dodge lightning and enjoy the rain as you fly through the storm with the dynamic weather system.\n\nFree Flight- Fly around the world with no limits, explore into the clouds and beyond.\n\nCustomise Your Aircraft- Choose your own color scheme and fly 3 different light aircraft.\n\nFlight Missions - Pick up passengers and test your skills by delivering them to their destination and earn your place on the leaderboard.", "short_description": "Joy Flight is an open world arcade VR flight game where players will explore, unlock runways with daring landings and complete missions across a large chain of islands! Free to Play"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "http://tonicgamesaustralia.com/JoyFlight-privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Tonic Games Australia", "support_website_url": null, "website_url": "https://tonicgamesaustralia.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1271333340292421"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974549_697840841922780_530492384923665435_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QyJNI95Aia0Q7kNvgG1N-Z-&_nc_zt=3&_nc_ht=scontent-sjc3-1.o