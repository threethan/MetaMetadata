 play against other players online.\n\nLet's enjoy playing Shogi in a space we can't experience in real life!", "short_description": "Shogi, a traditional Japanese culture, can be played in a virtual space.\n\nThe pieces are controlled by hand tracking, so you can experience a realistic Shogi game.\nThe area where each piece can move is displayed on the board, so you can play Shogi without worrying about detailed rules.\nYou can play against the CPU or play against other players online.\n\nLet's enjoy playing Shogi in a space we can't experience in real life!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://watnv2948.wixsite.com/my-site/post/privacy-policy", "developer_terms_of_service_url": "https://watnv2948.wixsite.com/my-site/post/vr-shogi-terms-of-use", "publisher_name": "Watnv Studio", "support_website_url": null, "website_url": "https://watnv2948.wixsite.com/my-site/product", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1977060122680015"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982710_1725112931164843_5387958773410583479_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RR8Xx2XQ690Q7kNvgHOkHvA&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD6mB5GM7zw8cV9GoQmBerpl4l9