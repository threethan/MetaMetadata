HWZnkg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkm2ugf0X-lJsS1tne63NPUomhd_Ng2OVaKJAc3XmKMQ&oe=66FE96B4"}, {"file_name": "11.png", "id": "464666675611140", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272216_464666678944473_5500089804967371540_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RcImo1eix1cQ7kNvgEQr0Hp&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4V_3GchAByAFLEJ6YtUnYeFI3YrAwZsXgj5GdjbaE_Q&oe=66FE9800"}, {"file_name": "3.png", "id": "5574726782607145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031510_5574726785940478_1985816967095681989_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOMhYRP3OGsQ7kNvgFe7DHU&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3WrvX4hZA558QmT-AdVG_QnpC-t5zjJGta3OOdhzaYg&oe=66FE853E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "612966413832998", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974560_612966417166331_4326765418550343614_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t44grux-W3wQ7kNvgGn9Mgl&_nc_ht=scontent.oculuscdn.com&oh=00_AYBe8Efko4j7dImYngH0X4l_4hO8P4lKsE8tj0puAmYo0g&oe=66FE8E52"}, "display_name": "War of Wizards", "keywords": [], "long_description": "Draw & cast your spells, magic showdown! War of Wizards is a VR game with MOBA confrontation.\n\nDraw dragons to summon dragons to fight for you, draw fireballs to summon fireballs to shoot at enemies, draw pills to heal yourself...\nYou can cast different spells by drawing different patterns, and the accuracy and size of the spells you make will affect the damage and range of the spells you cast.\n\nIt's a game that uses both your reflexes and your strategy skills.\nThe spells you choose to use depends on your judgment of the enemy player and what strategy you plan to use to achieve victory.\nYou can also dodge attacks flying towards you by dodging your body.\nLead your minions to victory against the enemy!\n\nFeatures:\n\n- PVP MOBA!\n- Draw & cast your spells!\n- Dodge the skills that the enemy fires at you!\n- Use strategy to lead minions to destroy enemy magic crystals!\n", "short_description": "Draw & cast your spells, magic showdown! War of Wizards is a VR game with MOBA confrontation.\n\nDraw dragons to summon dragons to fight for you, draw fireballs to summon fireballs to shoot at enemies, draw pills to heal yourself...\nYou can cast different spells by drawing different patterns, and the accuracy and size of the spells you make will affect the damage and range of the spells you cast.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.warofwizardsvr.com/game_privacy.html", "developer_terms_of_service_url": "http://www.warofwizardsvr.com/game_eula.html", "publisher_name": "Arcane Miracle Entertainment", "support_website_url": null, "website_url": "http://www.warofwizardsvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "802371900948208"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "375406612266724"}, {"status": "PUBLISHED", "id": "474638935492003"}, {"status": "PUBLISHED", "id": "1124141491576019"}, {"status": "PUBLISHED", "id": "6099101230211531"}]}, "baseline_offer": {"id": "474638935492003"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "375406612266724"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "Andr