", "id": "1861738917555866", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031538_1861738920889199_753267939038064968_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5xiUcQYZxbMQ7kNvgGoKwtR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoTao1z46UeCAAkZhmdq86kaQ4Dmg0a8O5fOvxT2DxZQ&oe=673F0530"}, {"file_name": "2023-05-25 15-20-02.00_01_24_04.\uc2a4\ud2f8 004.png", "id": "667128418562201", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75322596_667128421895534_5524128766616187931_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pJYDatJEQCsQ7kNvgHZ_9B5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB74ASKCcOa6am1sygXQGEZUXokdlzdX6AuEnkeMPmM2A&oe=673F170D"}, {"file_name": "2023-05-25 15-20-02.00_01_33_07.\uc2a4\ud2f8 005.png", "id": "837544157788165", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203619_837544161121498_6430345665608267387_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mTDk4WTcWAEQ7kNvgG_Tm9d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCadrCCzSIVFNsvnwjb22xItEXR6UW3jBHrh7bKRITOjA&oe=673F3A5E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BC Landscape.png", "id": "848851033533740", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031491_848851036867073_1573423829073044538_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U-ph-DAtZrEQ7kNvgGx8aCN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBqvAwJhTbHbM3SGj3dzQp69zKNZ5B3GBt7grKnzOju7Q&oe=673F1038"}, "display_name": "Bounty City : Tactical 3-Way Battle ", "keywords": [], "long_description": "Enter 'Bounty City,' a world where fearless outlaws bet their lives in a high-stakes clash. The bounties are gathered into a tempting suitcase, igniting battles for riches and glory. Immerse yourself in this adrenaline-fueled realm, where you fight to script your own destiny. \ud83d\udd2b\u2694\ufe0f\ud83d\udcb0\ud83d\udd25\n\nOur journey has led us to this \u2013 the creation of a unique FPS experience!^^\u2728\nWe've achieved the foundation of a 3-teamed-combat battle mechanic, injecting excitement and unpredictability into the FPS realm.\ud83c\udfaeBut our vision doesn't end here. It's your support and feedback that will propel us forward.\n\nJoin us on Discord, where your voice shapes our evolution.\ud83d\udde3\ufe0f Together, we'll forge a community that celebrates creativity and camaraderie.\ud83e\udd1d Your presence matters, your insights matter, and together, we hope to shape an unforgettable gaming legacy.\n", "short_description": "Welcome to Bounty City, where three teams of outlaws collide, hunting each other down for the ultimate payday."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bountycityvr.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "SG ENTERTEC CO.,LTD.", "support_website_url": null, "website_url": "https://www.sgentertec.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "181052371437853"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "864679405666450"}, {"status": "PUBLISHED", "id": "2134440303615440"}, {"status": "PUBLISHED", "id": "1010469526895193"}, {"status": "PENDING", "id": "1684880111957699"}]}, "baseline_offer": {"id": "2134440303615440"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725908400, "status": "PUBLISHED", "id": "