": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974809_577648177924061_8221018826026877130_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IZNSWGEYMwAQ7kNvgGCCtUo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALgWbFb623irxVvzATWLexMRlqqCM3ARciCFrPa3Ijxg&oe=6707B8EA"}, {"file_name": "1440x1440.png", "id": "566876409004613", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035354_566876412337946_3166019699866820458_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pVb4Gm7ZOO8Q7kNvgG2BLqv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZOuyNkbXoDp_q4aCga66KGxGsk7BCUSOv06cTN9qPWQ&oe=6707A3E6"}, {"file_name": "3000x900.png", "id": "412130584844331", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_412130588177664_6858483323035089068_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l2XZp541bcsQ7kNvgHqAA7O&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0IMy6viOWItcBEzPNaEHvbX6smxui1OiToL8FDtbT8w&oe=6707CEEE"}]}, "id": "1171042090621459", "locale": "en_US", "screenshots": [{"file_name": "ss5.png", "id": "496348539873035", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75295894_496348543206368_6399986635726662187_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=--23bDE-spQQ7kNvgF-6Lrh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtFv5eAw2wh3Zo9oUoaqhmDsLvQdltYRrrBy_elV_B7A&oe=6707CB33"}, {"file_name": "ss4.png", "id": "514276761208341", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982557_514276767875007_4502402261507970842_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5UxNuH__4FQQ7kNvgGXzok6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARA_6pCZoYYDmilRp1N_8jvhiPq1i_aukhlRPJZE02oQ&oe=6707A6BA"}, {"file_name": "ss3.png", "id": "1217283523025996", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982724_1217283526359329_4077163052326033148_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IL7rkC_SiLUQ7kNvgFlI_Ua&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDoyL5DpW1qYhhj2fde19u_7VEdvX6gbpcmFXIi2xlrOw&oe=6707CD62"}, {"file_name": "ss1.png", "id": "498890822861675", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974648_498890826195008_6914655855116972868_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R4yPGFmwRfYQ7kNvgH_aD-6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDj96PSq5sZhtFnBrUH0W7dQApAa5h5J0dCmxI9_Z9_dA&oe=6707A376"}, {"file_name": "ss2.png", "id": "375133182315567", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982645_375133192315566_4560136648475621960_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=id-uMUix6LsQ7kNvgGKw56n&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcuPCVw8g5rMBvFwxXpI-WyK_88G5_XkcWN9C6fEf_DQ&oe=6707C808"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss1.png", "id": "1153098745792919", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75295894_1153098749126252_4587459099070280108_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dalmFJb3T1QQ7kNvgFDQJxc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChb9O1v8YZjlzU1FPPxyLE607jbkl7X1IuQd5_ysSy5g&oe=6707B7B6"}, "display_name": "Merge Blocks", "keywords": ["puzzle", "casual", "comfort", "hypercasual", "math"], "long_description": "Merge Block is a fun and engaging puzzle game that challenges players to use their logic and problem-solving skills. The concept is simple: drag numbered blocks across the screen to combine them. When you merge blocks like +2 and -2, they cancel each other out and form a zero. Your goal is to strategically align and combine blocks to create a zero and clear the level.\n\nAs you progress through the game, the puzzles become more intricate and require careful planning. With its intuitive mechanics and relaxing gameplay, Merge Block is easy to pick up but offers enough depth to keep players coming back for more. Each level introduces new challenges, pushing you to think critically about the placement and movement of blocks.\n\nPerfect for casual gamers and puzzle enthusiasts alike, Merge Block provides an addictive and satisfying experience as you advance through increasingly tricky levels. Whether you're looking for a quick mental challenge or hours of gameplay, Merge Block delivers the perfect blend of simplicity and complexity in a visually appealing and immersive environment.", "short_description": "Merge Block is a puzzle game where players drag and combine numbered blocks to reach zero. The goal is to strategically move blocks like +2 and -2 together to cancel them out and create a zero block. Simple to play but challenging to master, Merge Block tests your logic and problem-solving skills. Enjoy the satisfaction of clearing levels by carefully merging the right numbers and progressing through increasingly difficult puzzles!"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/merge-blocks", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7727181807387854"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ia