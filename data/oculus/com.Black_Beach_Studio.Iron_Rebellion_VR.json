uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003250_209514627821252_6245665988986476602_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHKvi2wnRJ8Q7kNvgGpYAuY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjFJFhanmpbPrKsYVLVlot7TD4NaiqDSrVT5efnitEhg&oe=67274EA2"}, {"file_name": "Movement system.png", "id": "237976158211475", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974904_237976161544808_8793323266759697674_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zBVZBHBJlzsQ7kNvgG7YlJi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBuZCy-2Jyadf1kJE1XB_vYj1Fh_ayqtiV3hHskmgKUDA&oe=67274E0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Core elements of game play.png", "id": "270490351315846", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984472_270490354649179_3938109769099532589_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A2BjF80AhaEQ7kNvgFwW7hE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrbvYEuIWFuyiwxUDoZD1r60GTIhawalXCrlSX5G6ifg&oe=67274BCE"}, "display_name": "Iron Rebellion", "keywords": [], "long_description": "Iron Rebellion is all about the immersive experience of being a mech pilot. We want players to feel truly locked and loaded inside a mechanical titan and give them all of the buttons, levers, and ammunition they need to dominate the battlefield.\n\nWhy Early Access\nOur primary goal for early access is to expand our team, to speed up production, and to flesh out the rest of the games core elements. With your support and the advent of VR we can show the world what a mech game can truly become!\n\nHow long will the game stay in EA\n* V0.9 by the middle of 2022\n* V1.0 out by the end of 2022 to start of 2023.\n\nCurrent Features\n* Competitive 1v1, game mode (data breach)\n* Immersive Virtual game controls\n* Massive multiplayer mech combat\n* Advanced movement and locomotion you can feel\n* Our first mechanized combat unit or (MCU) ready for battle!\n* A large scale combat zone (Frozen outpost)\n* (Social/practice room), with, movements course, 6 player FFA, Mech ball, and more!", "short_description": "Iron Rebellion is a, built for VR, mech combat game with a fully interactable cockpit, and precise / intuitive joystick system. Run, jump, and unleash hell in full VR glory as your mech shakes and rumbles with every command. Initial gameplay supports competitive 1v1, social room with free for all, and soon 6v6 as we grow our early access community!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iron-rebellion.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Black Beach Studio, LLC", "support_website_url": "https://www.iron-rebellion.com/", "website_url": "https://www.iron-rebellion.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "240580144913283"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "382696156836898"}]}, "baseline_offer": {"id": "382696156836898"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636567200, "status": "PUBLISHED", "id": "382696156836898"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8292765577519096", "version": ".9907"}, "id": "155389086734728", "channel_name": "LIV