2.oculuscdn.com/v/t64.5771-25/38974512_559690879963265_294312628677735205_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XZNaVy0LHHUQ7kNvgELA1vh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDstNzFDj1G6KjPeLXS-J4hrI5O6NBGmrkW74yYkmMMA&oe=67275596"}]}, "id": "1108993153907778", "locale": "en_US", "screenshots": [{"file_name": "Buton push render.png", "id": "236732745125057", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974873_236732748458390_7320475154329796134_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ykN80E-A_C8Q7kNvgGkxF6M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArr-eao-pK4Ju4LrxWGljTdyOJV7MkdgwE1HU7nt1jZg&oe=67277288"}, {"file_name": "Mech fight.png", "id": "1203235877557429", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1203235880890762_5235399000336608494_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mlzxt7l4GlIQ7kNvgE96c6L&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1hS_9wVyetuZDYVyaJOtgUKsm4L_SrPg9BeIdJb9J9w&oe=67275AAD"}, {"file_name": "Mech bay.png", "id": "1701930173984980", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568672_1701930177318313_8261861773708530690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p76e1U-Gm4sQ7kNvgFWMrQA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_9FVR-eZ_W4_4tpB7MbVIkhGANgAGIIc36Aab_K1Adg&oe=67277520"}, {"file_name": "Core elements of game play.png", "id": "908716783334316", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974904_908716786667649_9219195802101839858_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TG1r2Au0cbAQ7kNvgFZ1a7c&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpT9Os1Hpb9rQEVjggpNWA_eqsarFmYub-0hAAvDPnVg&oe=67275CC1"}, {"file_name": "Grabbing joysticks.png", "id": "209514624487919", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003250_209514627821252_6245665988986476602_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHKvi2wnRJ8Q7kNvgGpYAuY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjFJFhanmpbPrKsYVLVlot7TD4NaiqDSrVT5efnitEhg&oe=67274EA2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1031294042072107", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974826_1031294045405440_2899522296824019096_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GAN6X_3PsLAQ7kNvgHeuy-f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiGaoLlbURFgxQPllYLRZRZuGdKoxTCpza8-6Fokc09A&oe=672749EC"}, "display_name": "Iron Rebellion", "keywords": [], "long_description": "WHAT IS IRON REBELLION?\nIron Rebellion fulfills the experience of feeling truly locked and loaded inside a mechanical war machine with all of the buttons, levers, and ammunition pilots need to dominate the solar system.\n\nCurrent Features include:\n* Fully interactive Cockpit with Physics Based Interaction\n* Core cockpit module systems (Cargo) (Repair)\n* Cross-Platform Online Combat\n* Mech Classes and customizable loadouts\n* 8 weapons\n* 12 maps\n* 4 game modes\n* AI Bots\n* WIP Mod support\n\nWhy Early Access?\nWe are only a few months away from our full 1.0 launch! Early Access has been an incredible experience, tool and channel to connect VERY closely with our community to help bring out the absolute best game we could.\n\nHow long will the game stay in EA\n* V0.9 by the middle of 2023\n* V1.0 out by the end of 2023 to start of 2024.", "short_description": "In a solar system fracturing under expansion, your mech is your lifeline. Reach out and use every switch and control to outmaneuver and overwhelm the enemy with 40 tons of precision. The battlefield is a shifting code, and adaptation is key. Every component in your mech, and how you choose to build and modify it, can mean life or death. Form an elite 4v4 squad across all platforms. Strap in and join the Rebellion!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iron-rebellion.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Black Beach Studio, LLC", "support_website_url": "https://www.iron-rebellion.com/", "website_url": "https://www.iron-rebellion.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8257128274416160"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984474_1313863246268486_8982737903734854771_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jlfxRkPyLeAQ7kNvgFD1DBE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcuQzncxAUHbr9-m709iDws7bMFltVXwaYrGe6dTA0Nw&oe=67277017"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Iron Rebellion", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1636567142, "lastRevision": {"nodes": [{"id": "6080759088631755", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4076925385769824", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "520164189252306"}, "iarc_email": null, "msrp": null, 