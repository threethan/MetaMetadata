1740416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2BdiYYkRK4wQ7kNvgFQ5V7Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arhwr8UhRmADlqf3S12q3iq&oh=00_AYDTAlBZ8LKmrEVhnt-llWmOgpuIw6ZLYseceKvB6rhKpQ&oe=66F68258"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Box Shooter VR", "keywords": ["Box", "Shooter", "VR", "Simulation", "Laser"], "long_description": "Do you want to get a full VR experience but feel like a huge 3D world is too much? Have you had enough with being a \"cruiser\" and just simply exist in a VR environment? In other words, do you want to immerse yourself in an experience that is \"simple enough\" for you to enjoy VR yet enjoy it more than being a passenger? Then Box Shooter VR is the experience for you. In this game you shoot boxes. Green boxes reward you with points, and stars reward you even more. White boxes add time to your experience while red ones subtract time. Your goal is to get as many points as you can while you have time. Its simple, its fun and most of all, you are in control!", "short_description": "Have you ever wondered what it would feel like shooting lasers through your eyes? Now you can experience it! In this shooter simulator you shoot boxes and stars to collect points and extra time! How long can you last?"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.lemonlimejuice.com/box-shooter-privacy-policy/", "developer_terms_of_service_url": "http://www.lemonlimejuice.com/box-shooter-vr-terms-of-service/", "publisher_name": "Lemon Lime Juice", "support_website_url": null, "website_url": "http://www.lemonlimejuice.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommen