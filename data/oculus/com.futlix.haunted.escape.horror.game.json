MECdIxkU-OMWCtjI53j8yH3_IQ&oe=673739FE"}, {"file_name": "SS4.png", "id": "1668334477232970", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974841_1668334480566303_7727439569636657572_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iMwA6ZAXHk8Q7kNvgETueIz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAv1XjduOihwrG_lo4CZP-hRi5qbc3vxce_eOPI_P2KTA&oe=67371D37"}, {"file_name": "SS5.png", "id": "1213062970013122", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982495_1213062973346455_3756223896267353315_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hTkce9yNZaMQ7kNvgF5IzEp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQcVxUukPVFF9Z7Wbnz6dp51bReJpZaVsvOiKhYtQwTw&oe=67374602"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Haunted Exit Escape Room - Horror Games", "keywords": ["Horror", "Scary", "Haunted", "Granny", "Fear"], "long_description": "Welcome to Haunted Escape, a VR experience that\u2019ll keep you on the edge of your seat! You\u2019ve got one goal: escape the haunted room before the creepy inhabitants get to you. Solve puzzles, avoid terrifying creatures, and make it out alive.\n\nIn Haunted Escape, you\u2019ll encounter some seriously spooky characters\u2014like a Zombie Dog, a dead Joker, and even an eerie Mummy. Each challenge will test your nerves and your puzzle-solving skills. The best part? You can play it alone or with a friend!\n\nThe game offers two modes:\n- Solo Mode: It\u2019s just you against the haunted room\u2014get out before it\u2019s too late!\n- Co-op Mode: Work with a friend to help each other escape. Can you both survive?\n\nKey Features:\n- Play solo or team up in co-op mode.\n- Face off against creepy creatures like Granny, Ghosts, a Zombie Dog, and more.\n- High-quality VR graphics for an immersive, hair-raising experience.\n- Puzzles that challenge your brain while keeping your heart racing.\n- Exclusively available on Oculus Quest.", "short_description": "Get ready for a spooky adventure in Haunted Escape! You\u2019re trapped in a haunted room, and it\u2019s up to you to find a way out. Face creepy creatures like Granny, Ghosts, and even a Zombie Dog. Whether you're going solo or teaming up with a friend, every moment counts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/futlixgames/privacy-policy/meta-oculus-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Futlix Games", "support_website_url": null, "website_url": "https://sites.google.com/view/futlixgames/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26877545548526805"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222939_502391679382737_2216192909991808229_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YahbNA5W9XoQ7kNvgEfIwSb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxi6SJLs-169YQWgQuLNHcOBJiuPZqVrKKJ9Baqg768Q&oe=67372981"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Haunted Exit Escape Room - Horror Games", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Survival", "id": "644354873106712"}, {"topic_