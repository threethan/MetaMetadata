=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDFkaK3R68SUMiri7Vygk_dimuXzH3anYYmoGhLnnfyA&oe=671B94D9"}, {"file_name": "SS3.png", "id": "431218316174072", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569428_431218319507405_2896244797061391283_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqe9fUCFffQQ7kNvgHKdQo6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuzPMTDOpuVtjr3OB9XgToIuKGOAk-ccczg2OnAcbOBg&oe=671B8A7E"}, {"file_name": "SS4.png", "id": "1668334477232970", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974841_1668334480566303_7727439569636657572_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zc6YuAk9EycQ7kNvgHmcn6r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6p68clZjB5V3bC_PpjHbRR0jsDC8-cL8SMz18fgaTQw&oe=671B6DB7"}, {"file_name": "SS5.png", "id": "1213062970013122", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982495_1213062973346455_3756223896267353315_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JWdzsJztSxkQ7kNvgEAjzV6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKLb9mq6ZiN9LgLwWo31lJsmM5fg2jzYz9BIVUa5k6Jg&oe=671B9682"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Haunted Exit Escape Room - Horror Games", "keywords": ["Horror", "Scary", "Haunted", "Granny", "Fear"], "long_description": "Welcome to Haunted Escape, a VR experience that\u2019ll keep you on the edge of your seat! You\u2019ve got one goal: escape the haunted room before the creepy inhabitants get to you. Solve puzzles, avoid terrifying creatures, and make it out alive.\n\nIn Haunted Escape, you\u2019ll encounter some seriously spooky characters\u2014like a Zombie Dog, a dead Joker, and even an eerie Mummy. Each challenge will test your nerves and your puzzle-solving skills. The best part? You can play it alone or with a friend!\n\nThe game offers two modes:\n- Solo Mode: It\u2019s just you against the haunted room\u2014get out before it\u2019s too late!\n- Co-op Mode: Work with a friend to help each other escape. Can you both survive?\n\nKey Features:\n- Play solo or team up in co-op mode.\n- Face off against creepy creatures like Granny, Ghosts, a Zombie Dog, and more.\n- High-quality VR graphics for an immersive, hair-raising experience.\n- Puzzles that challenge your brain while keeping your heart racing.\n- Exclusively available on Oculus Quest.", "short_description": "Get ready for a spooky adventure in Haunted Escape! You\u2019re trapped in a haunted room, and it\u2019s up to you to find a way out. Face creepy creatures like Granny, Ghosts, and even a Zombie Dog. Whether you're going solo or teaming up with a friend, every moment counts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/futlixgames/privacy-policy/meta-oculus-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Futlix Games", "support_website_url": null, "website_url": "https://sites.google.com/view/futlixgames/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "961172191044986"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26877545548526805"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1690119055121234"}]}, "baseline_offer": {"id": "1690119055121234"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727792700, "status": "PUBLISHED", "id": "16901190551212