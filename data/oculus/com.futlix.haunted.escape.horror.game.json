t5sPYARNpSzLNBpld6o_PqPB1A&oe=672CADFE"}, {"file_name": "SS4.png", "id": "1668334477232970", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974841_1668334480566303_7727439569636657572_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gmrKqc2_PHgQ7kNvgFJE6HM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM_0x-mlXLt36-Z3M6rVIUEEzOAXTP0zbbEo_jkC7Teg&oe=672C9137"}, {"file_name": "SS5.png", "id": "1213062970013122", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982495_1213062973346455_3756223896267353315_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qd8q0pZa4MAQ7kNvgF9Wqgn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQiBODvWSqxEi7c6XwWjVGX4P4pnKLM-USTM7EZsuqRg&oe=672CBA02"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Haunted Exit Escape Room - Horror Games", "keywords": ["Horror", "Scary", "Haunted", "Granny", "Fear"], "long_description": "Welcome to Haunted Escape, a VR experience that\u2019ll keep you on the edge of your seat! You\u2019ve got one goal: escape the haunted room before the creepy inhabitants get to you. Solve puzzles, avoid terrifying creatures, and make it out alive.\n\nIn Haunted Escape, you\u2019ll encounter some seriously spooky characters\u2014like a Zombie Dog, a dead Joker, and even an eerie Mummy. Each challenge will test your nerves and your puzzle-solving skills. The best part? You can play it alone or with a friend!\n\nThe game offers two modes:\n- Solo Mode: It\u2019s just you against the haunted room\u2014get out before it\u2019s too late!\n- Co-op Mode: Work with a friend to help each other escape. Can you both survive?\n\nKey Features:\n- Play solo or team up in co-op mode.\n- Face off against creepy creatures like Granny, Ghosts, a Zombie Dog, and more.\n- High-quality VR graphics for an immersive, hair-raising experience.\n- Puzzles that challenge your brain while keeping your heart racing.\n- Exclusively available on Oculus Quest.", "short_description": "Get ready for a spooky adventure in Haunted Escape! You\u2019re trapped in a haunted room, and it\u2019s up to you to find a way out. Face creepy creatures like Granny, Ghosts, and even a Zombie Dog. Whether you're going solo or teaming up with a friend, every moment counts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/futlixgames/privacy-policy/meta-oculus-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Futlix Games", "support_website_url": null, "website_url": "https://sites.google.com/view/futlixgames/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26877545548526805"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222939_502391679382737_2216192909991808229_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q4LJIYIz1QMQ7kNvgHXUDdu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsILnz7twyauticWtGypJ5EiX7sttnVA2C2D2vl2mnLA&oe=672C9D81"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Haunted Exit Escape Room - Horror Games", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Survival", "id": "644354873106712"}, {"topic_