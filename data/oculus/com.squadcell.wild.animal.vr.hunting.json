8982548_1999325547128322_2359855048317788001_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=boE53OB7PM4Q7kNvgGI1_qN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPoUaPNgxGqatQC6NAj038JyPYcXyLnUwhycn2Ue8pww&oe=67387F14"}, {"file_name": "2560X1440_02.png", "id": "1594142981449554", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203615_1594142988116220_5261504339699403538_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jScUIJWJ-R4Q7kNvgE-doip&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7slD_J8F5yPrmKtAR4_pYNKKnxI6vyD9zsQTkTnL_DA&oe=673886A0"}, {"file_name": "2560X1440_05.png", "id": "2238191173178676", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035452_2238191176512009_5747981842467859759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zFACMLMyapcQ7kNvgHvWC_G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4s89JPBO1Abdz6W8Y8NgzU_sYyv_ZF0m3goAqr6TlvQ&oe=67389B85"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Animal_Hunt.png", "id": "351247857973900", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982554_351247864640566_69740848166528796_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QO21kYEfjaoQ7kNvgGw-h4C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBtsxbSYBScZsIkc9MiEnf2wG0NyLa7vIDAb8raISEofQ&oe=673876DE"}, "display_name": "Wild Hunter VR", "keywords": [], "long_description": "Prepare for the ultimate hunting adventure in Wild Hunter VR! Step into the virtual wilderness and explore diverse landscapes teeming with wildlife, including graceful deer, elusive ducks, and powerful tigers.\n\nWith your VR headset on, immerse yourself in stunningly realistic environments, from dense forests to serene lakeshores. Track your prey using advanced tools and keen observation, whether you're patiently waiting in a duck blind or stalking a majestic deer through the underbrush.\n\nBut be warned, you're not alone in these wild lands. Majestic tigers roam the shadows, adding an extra layer of danger to your hunts. With their keen senses and lightning-fast reflexes, they'll keep you on your toes as you navigate the challenges of the wilderness.\n\nChoose your weapons wisely, from traditional bows to high-powered rifles, and adapt your strategy to each hunting scenario. Whether you prefer the thrill of a close-range encounter or the precision of a long-distance shot, Wild Hunter VR offers endless opportunities for excitement and adventure.\n\nExperience the thrill of the hunt like never before in Wild Hunter VR. The wild awaits \u2013 are you ready to test your skills and become the ultimate hunter?", "short_description": "Immerse yourself in the thrill of the hunt with Wild Hunt VR.\n\n\n\n"}]}, "developer_name": "Squad Cell", "developer_privacy_policy_url": "https://squadcell.com/frenzygamesstudios-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "Squad Cell", "support_website_url": null, "website_url": "https://squadcell.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7673254229430137"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "902025261817047"}, {"status": "PUBLISHED", "id": "886180256303674"}, {"status": "PUBLISHED", "id": "1017724523126616"}, {"status": "PUBLISHED", "id": "731782129163269"}]}, "baseline_offer": {"id": "1017724523126616"}, "i