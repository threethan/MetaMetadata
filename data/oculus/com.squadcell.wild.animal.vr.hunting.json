id": "1999325543794989", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_1999325547128322_2359855048317788001_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1h1UkhHFnK8Q7kNvgE87lBU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHTkePnEfHU77wd3ThFw_pC&oh=00_AYAB4BUGFPy20XZNflk518abgAEJ72zfUVTuf1C7MF68cA&oe=66EFFC94"}, {"file_name": "2560X1440_02.png", "id": "1594142981449554", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203615_1594142988116220_5261504339699403538_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B2Rd4hwuiwAQ7kNvgEBc0u_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHTkePnEfHU77wd3ThFw_pC&oh=00_AYBmif0bYG0EmocDITqkm1PLy8L6SVqLIc3wrUcbR-Snjw&oe=66F00420"}, {"file_name": "2560X1440_05.png", "id": "2238191173178676", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035452_2238191176512009_5747981842467859759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tApq0UbrXpwQ7kNvgHKlJWv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHTkePnEfHU77wd3ThFw_pC&oh=00_AYDO5l0ODfPzHzFn9zPL7T4IMgQ7THpYxHQPUDx8nq6HNQ&oe=66F01905"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Animal_Hunt.png", "id": "351247857973900", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982554_351247864640566_69740848166528796_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vdvNaBzyqfoQ7kNvgFcQuaU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHTkePnEfHU77wd3ThFw_pC&oh=00_AYCUMCWpvun4hqMXv-Zrmvyd9bLNVO2amsrEqNH1smXpGA&oe=66EFF45E"}, "display_name": "Wild Hunter VR", "keywords": [], "long_description": "Prepare for the ultimate hunting adventure in Wild Hunter VR! Step into the virtual wilderness and explore diverse landscapes teeming with wildlife, including graceful deer, elusive ducks, and powerful tigers.\n\nWith your VR headset on, immerse yourself in stunningly realistic environments, from dense forests to serene lakeshores. Track your prey using advanced tools and keen observation, whether you're patiently waiting in a duck blind or stalking a majestic deer through the underbrush.\n\nBut be warned, you're not alone in these wild lands. Majestic tigers roam the shadows, adding an extra layer of danger to your hunts. With their keen senses and lightning-fast reflexes, they'll keep you on your toes as you navigate the challenges of the wilderness.\n\nChoose your weapons wisely, from traditional bows to high-powered rifles, and adapt your strategy to each hunting scenario. Whether you prefer the thrill of a close-range encounter or the precision of a long-distance shot, Wild Hunter VR offers endless opportunities for excitement and adventure.\n\nExperience the thrill of the hunt like never before in Wild Hunter VR. The wild awaits \u2013 are you ready to test your skills and become the ultimate hunter?", "short_description": "Immerse yourself in the thrill of the hunt with Wild Hunt VR.\n\n\n\n"}]}, "developer_name": "Squad Cell", "developer_privacy_policy_url": "https://squadcell.com/frenzygamesstudios-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "Squad Cell", "support_website_url": null, "website_url": "https://squadcell.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7673254229430137"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1017724523126616"}, {"status": "PUBLISHED", "id": "731782129163269"}]}, "baseline_offer": {"id": "