11065391453300_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mmSOFtSBfKUQ7kNvgFxzVzu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPZZ_XK5vTk1YPG7wPfDrWwuGT_BFOx9b1s-oJmiYmjA&oe=673718F3"}, {"file_name": "1_skeet.png", "id": "568843747644878", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031337_568843750978211_96975866016613778_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X06rX7BwHoIQ7kNvgEEWMv2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASrUSG_1lrCcaZPSrYc_IkGaCYSFFxOu7GBwJaI_ThkA&oe=6737307E"}, {"file_name": "4_pigeon.png", "id": "344681880716298", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974683_344681884049631_2220794988333194776_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VzXIpP5J0FQQ7kNvgGrUTN-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEOhqRICliWMNGq5V7O83Rbdn2YxZeBGp6uDZ2bO6MQw&oe=67372409"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "553887475822150", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572755_553887479155483_5164197311620824925_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OZ6BoOMjDOwQ7kNvgHd1p3-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2D4AgxcFuOJuUXGhyV3iu4tVzkMGa1rrRsCur54ruLA&oe=67374574"}, "display_name": "Clay Hunt VR", "keywords": [], "long_description": "#1 shotgun shooting simulator from mobile is now available in amazing VR! Shoot clay pigeons in skeet and go hunting pigeons with your trusty pump action shotgun.\n\nShot string physics are accurately simulated so that you can practice your leads and target acquisition with this game.\n\nIn skeet, you can shoot single targets rounds, international skeet with double targets, practice a specific station and all new infinite skeet mode with leaderboards!\n\nThis is an early version of the game and only skeet and pigeon hunting is currently featured. More will come shortly as trap, double trap and sporting clays are added.", "short_description": "#1 shotgun shooting simulator from mobile is now available in amazing VR! Shoot clay pigeons in skeet and go hunting pigeons with your trusty pump action shotgun.\n\nShot string physics are accurately simulated so that you can practice your leads and target acquisition with this game.\n\nThis is an early version of the game and only skeet and pigeon hunting is currently featured. More will come shortly as trap, double trap and sporting clays are added."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.clayhuntpro.com/privacy/clayhuntvr.html", "developer_terms_of_service_url": null, "publisher_name": "Shotgun Gaming Oy", "support_website_url": null, "website_url": "https://www.shotgungaming.com/clayhuntvr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "237884575203004"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1030553725268731"}, {"status": "PUBLISHED", "id": "1457698401756157"}, {"status": "PUBLISHED", "id": "390113175908449"}, {"status": "PUBLISHED", "id": "878799363612117"}]}, "baseline_offer": {"id": "1457698401756157"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1030553725268731"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "85128331988