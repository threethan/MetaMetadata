11065391453300_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7KIWw75zfX0Q7kNvgFU-USC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAy4fSDahWQgb5qPoR6UDmEWbgILUE0D_A1iSKwvuUAmg&oe=6742F673"}, {"file_name": "1_skeet.png", "id": "568843747644878", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031337_568843750978211_96975866016613778_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9xLSJ_LPjZUQ7kNvgFLFRKn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDLp4bejgCeYlWTZ7NL28dUb9mji1wzL5fTIHS2HM2l1A&oe=67430DFE"}, {"file_name": "4_pigeon.png", "id": "344681880716298", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974683_344681884049631_2220794988333194776_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cGQVJrvKZPsQ7kNvgHEEcCY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9HEn1jS4wlnIC83hN0Ozfw8-CejmcobVo5J4wlNn6lw&oe=67430189"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "553887475822150", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572755_553887479155483_5164197311620824925_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sUlm6EB8p4gQ7kNvgF7Ytzi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6XHjiX2jbvtp2fWyz4Y_X-EHflvxWTppDrf1x03J8yQ&oe=674322F4"}, "display_name": "Clay Hunt VR", "keywords": [], "long_description": "#1 shotgun shooting simulator from mobile is now available in amazing VR! Shoot clay pigeons in skeet and go hunting pigeons with your trusty pump action shotgun.\n\nShot string physics are accurately simulated so that you can practice your leads and target acquisition with this game.\n\nIn skeet, you can shoot single targets rounds, international skeet with double targets, practice a specific station and all new infinite skeet mode with leaderboards!\n\nThis is an early version of the game and only skeet and pigeon hunting is currently featured. More will come shortly as trap, double trap and sporting clays are added.", "short_de