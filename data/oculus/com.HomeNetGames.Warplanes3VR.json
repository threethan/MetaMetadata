g&oe=6752E1FE"}]}, "id": "1313139072506716", "locale": "en_US", "screenshots": [{"file_name": "Warplanes_Air_Corp_Screenshot_01.png", "id": "175471902113464", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75439596_175471905446797_2745429162569878945_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r0lWZaBpXDAQ7kNvgFFsEqg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBteaTo4psy9weD18BVUV3DgfrJxPSIISXNgaPNG0n7AQ&oe=6752CBC3"}, {"file_name": "Warplanes_Air_Corp_Screenshot_02.png", "id": "840233397755466", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462206_840233401088799_7316914228671170754_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-pV_saH-HY4Q7kNvgERo_BC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxmQCeppNegnQXpv-xwVzHJOCQ2SynTXxuLjRbKQomdQ&oe=6752F038"}, {"file_name": "Warplanes_Air_Corp_Screenshot_03.png", "id": "1056903785682581", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569442_1056903789015914_5145792403989627104_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T-_ZbGGwsPAQ7kNvgGa7pRj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgbRphCC-6Id6jQ_qa66HlDatlWomHaJmNWQrEKR-9QA&oe=6752EF0F"}, {"file_name": "Warplanes_Air_Corp_Screenshot_04.png", "id": "1424849065021175", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75356795_1424849068354508_2134087355691848473_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=diRpcnrBmpcQ7kNvgHNQw6H&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsbCkVu_8XYP_bhFcBn_aB4hhjkRQvjBDHZojsjv-bLQ&oe=6752CDF2"}, {"file_name": "Warplanes_Air_Corp_Screenshot_05.png", "id": "292838510082316", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86795865_292838516748982_4269870359993611182_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a2nGXXzkSBIQ7kNvgF9khWR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAphQJRNf6_ZkVldCBWpbcWQRwpyp0kh5IhgHP0691pQ&oe=6752D40F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440-CoverLandscape.png", "id": "801667118177259", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974448_801667121510592_8623814251197468352_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P0Wq831bwccQ7kNvgFDfHVf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLAHDpuBmGN8J5bg61jpIVdVkwgoPr0OHwm6SGHQpduQ&oe=6752E983"}, "display_name": "Warplanes: Air Corp", "keywords": [], "long_description": "Move into the middle of the modern battlefield in Warplanes: Air Corp in VR. The third installment of the best-selling Warplanes series introduces a new era of modern military aviation. In addition to fighter jets and multirole combat aircraft you are able to pilot attack helicopters!\n\nFlight simulators are too complicated for you? We got this covered \u2013 both the flight model and the control of machines have been simplified as much as possible so that you can enjoy dynamic and spectacular combat. \n\nUpgrade your machines \u2013 buy modern armaments, adjust them according to mission objectives, so as to inflict the greatest damage on the enemy.  Utilize advanced tactics \u2013 destroy high-tech air defense systems using helicopters, reduce the range of artillery by destroying mobile radars.\n\nFight in the air against a wide range of fighter jets, multirole aircraft, helicopters and armed drones. Destroy ships, tankers, convoys, and an array of modern military vehicles like armored personnel carriers, tanks, and mobile rocket launchers. Fight in urbanized areas, destroy or protect strategic buildings and infrastructure. Use all available units to raze enemy military bases.\n\n\u25cf Acquire a total of 9 machines inspired by the best combat aircraft from around the world.\n\u25cf Adjust the difficulty level of combat to your preference - you can turn off the automatic targeting system and release flares manually.\n\u25cf Friendly flight model and intuitive controls.\n\u25cf COMING SOON: PvP and co-op multiplayer.", "short_description": "Pilot fighter jets, multirole combat aircraft and helicopters on the modern battlefield. \n\n\u25cf The third installment of the hit Warplanes series that takes us to the modern battlefield.\n\u25cf In addition to planes, you can sit behind the controls of attack helicopters!\n\u25cf Acquire a total of 9 machines inspired by the best combat aircraft and helicopters from around the world.\n\u25cf Friendly flight model and intuitive controls."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.homenetgames.com/privacy-policy-vr/", "developer_terms_of_service_url": null, "publisher_name": "Home Net Games", "support_website_url": "https://www.homenetgames.com/support/", "website_url": "https://www.homenetgames.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5154554154610501"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "4710848805807268"}, {"status": "PUBLISHED", "id": "797449575813893"}, {"status": "PUBLISHED", "id": "1887014291667293"}, {"status": "PUBLISHED", "id": "812229673576702"}]}, "baseline_offer": {"id": "797449575813893"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "4710848805807268"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7852171638163881", "version": "1.6.2.4"}, "id"