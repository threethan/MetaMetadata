5558_7521622606854759392_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RrkkKNgxqlQQ7kNvgERKTtD&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANMyrQzaEHe6xPNNNwQGb2W&oh=00_AYDs4NUScfHCjjfOnCmJrHz0D2--ILPvPHgUkgC8-Z_Z-Q&oe=66DC39F7"}, {"file_name": "Feeding_Patient_SS_04.png", "id": "7788589767895302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392876_7788589774561968_5659800657422804262_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IOq6QugLixoQ7kNvgHZi2e4&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANMyrQzaEHe6xPNNNwQGb2W&oh=00_AYCFV8ZnquhQejKwFvZwnALT3OUmcNxb8q6t4d_pwrN4YQ&oe=66DC2CAA"}, {"file_name": "Feeding_Patient_SS_05.png", "id": "2574774736044221", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031562_2574774739377554_8395713396078196642_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fBx020xK-3wQ7kNvgGodVQH&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANMyrQzaEHe6xPNNNwQGb2W&oh=00_AYCe6hb6meVGX4PWZvUXJG_MI2TsqGheMrEWy_abegifMA&oe=66DC3857"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "1005387954181471", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031367_1005387957514804_7746304874855148402_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RrMfSwAjresQ7kNvgH-pput&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANMyrQzaEHe6xPNNNwQGb2W&oh=00_AYCiuATj5I3Sw8QLnbFpWRRWberlKoMI7QiZ7X4N-2QYRA&oe=66DC3C38"}, "display_name": "Feeding Patient Simulator", "keywords": [], "long_description": "The Feeding Patient tutorial immerses Certified Nursing Assistant (CNA) trainees in a realistic virtual environment to practice and master the skills required for properly feeding patients. This application guides users through each step of the process, including preparing food trays, positioning patients for safe eating, and monitoring patients for potential difficulties.  \n\n# Learning Objectives:  \n- Remembering the protocols for patient feeding \n- Understanding the importance of nutrition and safe feeding practices \n- Applying the correct techniques for assisting patients with eating \n- Analyzing the patient's ability to swallow and eat safely \n- Creating a supportive and respectful environment to enhance the patient's mealtime experience \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn how to provide proper feeding assistance through interactive, hands-on practice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7564952043613663"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_1690485805110401_9075115624630073060_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dvb6dsoSA3gQ7kNvgEh6MCG&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANMyrQzaEHe6xPNNNwQGb2W&oh=00_AYBjhGX1lNfkk_AVMx3jC_CNdJRDpfZqiLyHFeIeeItMrA&oe=66DC4C9B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Feeding Patient Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692