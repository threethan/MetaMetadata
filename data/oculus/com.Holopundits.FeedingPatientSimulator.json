472685", "locale": "en_US", "screenshots": [{"file_name": "Feeding_Patient_SS_01.png", "id": "3429266904035591", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031370_3429266907368924_6881361022864404666_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0O3jz235LSAQ7kNvgGbCFs3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCqMCwSubTy1gusTBDoO_jEh4W-47bjyeHg26sq5yopxQ&oe=67712E97"}, {"file_name": "Feeding_Patient_SS_02.png", "id": "1635614177357170", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982685_1635614180690503_695188416581054558_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m_deeZXwn1EQ7kNvgHwMM4t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWA3tcJzrxaW5H9iaN24lMRnKUKPdzJyxwG8u5Nm0U9A&oe=67712212"}, {"file_name": "Feeding_Patient_SS_03.png", "id": "825248129641056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974527_825248132974389_1767739594735541611_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ugWxUo0f9nAQ7kNvgGuKkqi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCuHyFWIBgatkbWH-dHtefVDb3_iKr357xWGs4ND5PH6Q&oe=67711B2C"}, {"file_name": "Feeding_Patient_SS_04.png", "id": "496623763435297", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570298_496623766768630_2581877682244505766_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W8iIyIhOTGYQ7kNvgFmulBs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbHkKOanHy297LAd3OD2zoLG8mRwOkMi3PbjwV9D2QFw&oe=6771353D"}, {"file_name": "Feeding_Patient_SS_05.png", "id": "600572125740865", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974685_600572129074198_695572474938852958_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hLPcWS8b4LkQ7kNvgHiXxDF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8xibNqrVAxmY_W5PMIKzIYOL_SnpW6AdyL89vQPZ7JA&oe=67713709"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Feeding_Patient_SS_03.png", "id": "1208675347489828", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974455_1208675350823161_1656817107211530419_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CJ-pZrvIkT8Q7kNvgEU0Y-5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVVw_8On81IHRYOhboBvqGX2aYVhRorMLra2Q87jCrDg&oe=67714618"}, "display_name": "Feeding Patient Simulator", "keywords": ["CNA", "nurse", "nursing", "feeding", "healthcare"], "long_description": "The Feeding Patient tutorial immerses Certified Nursing Assistant (CNA) trainees in a realistic virtual environment to practice and master the skills required for properly feeding patients. This application guides users through each step of the process, including preparing food trays, positioning patients for safe eating, and monitoring patients for potential difficulties.  \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n# Learning Objectives:  \n- Remembering the protocols for patient feeding \n- Understanding the importance of nutrition and safe feeding practices \n- Applying the correct techniques for assisting patients with eating \n- Analyzing the patient's ability to swallow and eat safely \n- Creating a supportive and respectful environment to enhance the patient's mealtime experience \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn how to provide proper feeding assistance through interactive, hands-on practice with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8567017290073795"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031361_470497512341830_4719008698102470547_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0MAK65rwaOgQ7kNvgE_gFG_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAotCfivo-0qghJ-itf-HQBUZX2xK4wutRvceigzCgZZg&oe=67711962"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Feeding Patient Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1721737196, "lastRevision": {"nodes": [{"id": "7564952063613661", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pd