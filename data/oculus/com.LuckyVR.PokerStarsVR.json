ontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974688_1497268573740322_2007296302005616640_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6tofTYrKTcoQ7kNvgHh3fZ1&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAuu7ED4a2tU-jDwEl8Pt0rTK1oAozRK0dF7W1HNAihKw&oe=67011ECF"}, {"file_name": "migrated_image.png", "id": "1346115318922917", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974908_339481883587410_5992345088708050944_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1DcAWwHd7AIQ7kNvgGXoDfJ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB-NwZqWpHvEw0XqKY0Z9WtqBiQgHxRRstJfXLLDYuERw&oe=670142DC"}, {"file_name": "migrated_image.png", "id": "242748943571033", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974528_2099504643436815_3522082699814633472_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TmeMUS07Q78Q7kNvgFtnkNI&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBz6DzUnnNu_U1VkzN3A_uwqQzZYtwPqZwJdq5VT_ooHA&oe=67012F72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/ZWu7Vw", "id": "951964714974068", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974549_951964718307401_1299692627444105216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G4kzncpPqrQQ7kNvgGrQC-M&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCnmN2CWzjiKAPBAZ1SP8_XqFyCxZl-8mfh9PQsx42kzw&oe=6701219E"}, "display_name": "PokerStars VR", "keywords": ["Poker", "PokerStars", "Social", "Holdem", "Casino"], "long_description": "PokerStars, the world\u2019s leading poker brand, has combined live and online poker in a truly immersive VR experience.\n\n-Study your opponents, pick up on their tells, and chat in real time\n-Handle your chips and cards, just as you would at a real-world poker table\n-Keep the table fun with interactive props and toys, summoned in an instant\n\nThis is the most exciting poker game on the planet, and there\u2019s a seat open for you right now.\n\n- Key Features -\n\n-Authentic poker action\n-A fully immersive, social experience\n-Simple, intuitive, easy to play\n-Play real opponents\n-Realistic physics, from cards and chips to balloons, pistols and more\n-Unlock free chips every day\n\n- Exotic locales -\n\n-Macau 2050: A futuristic re-imagining of Macau by night \n-Macau Suite: An opulent yet intimate and relaxing environment\n-The Showdown Saloon: Play in a classic Wild West saloon\n-The Monte-Carlo Yacht: Take to the high seas\n-The Void: Play with no distractions", "short_description": "Step into the future with this game-changing release from the biggest name in the business. Visually stunning environments; realistic chip and card movements; an endless supply of interactive toys, props and accessories; and the world\u2019s best poker software powering multiplayer Texas Hold\u2019em action."}]}, "developer_name": "Lucky VR Inc.", "developer_privacy_policy_url": "http://www.getluckyvr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.pokerstars.com/poker/ps-vr/tos/", "publisher_name": "The Stars Group Inc.", "support_website_url": null, "website_url": "http://www.starsgroup.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["STRATEGY", "SOCIAL", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "947216472618112"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "578617912645734"}, {"status": "PUBLISHED", "id": "1184051545573403"}]}, "baseline_offer": {"id": "578617912645734"}, "is_approved": true, "firstO