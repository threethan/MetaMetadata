luscdn.com&oh=00_AYBwyIOUjhsMBpSuln7M9zEVJrfKvUWAgh_H_OYjvx4TMA&oe=67138BA5"}, "display_name": "Lord Sword", "keywords": [], "long_description": "Lord Sword is an expansive VR game that offers players the opportunity to experience various combat skills. Players will hone their sword-fighting techniques, hit targets with archery skills, and unleash powerful attacks using cannons.\n\nThe game features challenging missions set in different locations, allowing players to diversify their skill sets. With various types of swords available, players can create unique battle strategies, while each location presents its own challenges and atmosphere, immersing players in a captivating world.\n\nEnemies possess special skills that both test and encourage players to think strategically. Upon defeating enemies, players have the chance to collect their rings. These rings empower players to strengthen their characters and effectively combat more formidable foes. Lord Sword aims to deliver an unforgettable knightly experience with realistic graphics, tactile controls, and a rich gaming experience", "short_description": "Lord Sword is an immersive VR game that takes players on an exciting knightly adventure"}]}, "developer_name": null, "developer_privacy_policy_url": "http://initiumstudio.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "INITIUM STUDIO", "support_website_url": null, "website_url": "http://initiumstudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "suppo