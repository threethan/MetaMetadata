c_ohc=fPfK91lNYLAQ7kNvgH4vXm3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBh94SQ5TXfTkWNgCapNTeXDJJ4qhNAqmZ62pLvloseyg&oe=67274CE3"}, "display_name": "Match Blast", "keywords": ["puzzle", "zen", "relax", "shooter", "space"], "long_description": "Match Blast: A Retro-Inspired VR Shooter\n\nInspired by classic '80s games like Tempest and Asteroids, Match Blast brings a zen-like focus and thrilling gameplay to the VR shooter genre. Strap in and get ready to use your mind and trigger fingers to conquer the odds in this immersive experience.\n\nStrategic Shooting: Stay focused and blast targets coming at you from three tunnels.\n\nUnlockable Rewards: Earn gems to unlock new blasters and level designs.\n\nDual-Wield Fun: Equip blasters in both hands or mix and match to suit your style.\n\nMatch Blast is a must-have for any Quest owner, offering a perfect blend of nostalgia and modern VR action.", "short_description": "Match Blast: A Retro-Inspired VR Shooter\n\nInspired by classic '80s games like Tempest and Asteroids, Match Blast brings a zen-like focus and thrilling gameplay to the VR shooter genre. Strap in and get ready to use your mind and trigger fingers to conquer the odds in this immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/match-blast-privacy", "developer_terms_of_service_url": null, "publisher_name": "John Ray", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor":