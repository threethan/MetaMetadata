087432834433_1989048406849012977_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SlHI4QKCF7wQ7kNvgGHorEs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpHBHdNOYpNzHqR7kj-R1c-XQ-m1iNk2yd59AKn3xoYg&oe=676937E3"}, "display_name": "Match Blast", "keywords": [], "long_description": "Inspired by revered 80's classics like Tempest & Asteroids, Match Blast brings a zen-like focus and fun gameplay to a  first-person shooter style VR game. Strap in and get ready to use your mind and your trigger fingers to beat the odds in Match Blast.\n\n\u2022 Use your wits to stay focused and blast the targets that come at you from the three tunnels before you.\n\u2022 Earn gems to unlock new blasters and level designs.\n\u2022Equip your earned blasters to both hands or mix it up to suit your mood.\n\nMatch Blast is a must have for Quest owners.", "short_description": "Inspired by revered 80's classics like Tempest & Asteroids, Match Blast brings a zen-like focus and fun gameplay to a  first-person shooter style VR game. Strap in and get ready to use your mind and your trigger fingers to beat the odds in Match Blast."}]}, "developer_name": null, "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/match-blast-privacy", "developer_terms_of_service_url": null, "publisher_name": "John Ray", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING