0210222203645_1.png", "id": "738412340403036", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566687_738412343736369_7295909685652399611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jfisUC57OZAQ7kNvgHUtm5a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAapkX2fQUC3gpRlHw-m1VNJ7XlEvEDyfGskUIkHPUcKg&oe=673349CC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OC_CoverLandscape.png", "id": "740112973305075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974469_740112976638408_8491630443241959094_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rdjWDjU5WagQ7kNvgGosj4Z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA0AAsVjC_eA3FdLAnGZTGarzmUA9TUG32KGWFEa140qw&oe=67334715"}, "display_name": "Cards & Tankards", "keywords": [], "long_description": "This is an open beta build that is not ready for release. It lacks polish and will have bugs. Please only install it if you're interested in providing feedback and helping test for bugs.\n\nAre you tired of trying to find a strategy card game that\u2019s complex enough to make every match exhilarating, yet easy enough that anyone can learn to play?\n\nWould you love the opportunity to join a supportive community of players, where you might just make some new friends along the way?\n\nYou\u2019re in luck, because Cards & Tankards is the perfect combination of VR and tabletop gaming; blended together in one incredibly immersive package.\n\nPlay with other players and chat. Play alone against AI. Or you can just enjoy the tavern, have some laughs and observe. The choice is up to you.\n\n* 2 factions, each with their own unique combat mechanics\n* More than 60 cards currently available\n* Completely customizable decks\n* Cross-platform multiplayer, making it easy to connect with friends", "short_description": "This is an open beta build that is not ready for release. It lacks polish and will have bugs. Please only install it if you're interested in providing feedback and helping test for bugs.\n\nGrab a drink, pick your deck and prepare for Cards & Tankards \u2013 VR\u2019s most exciting, immersive and relaxing new strategy card game. Come join our wonderful, welcoming community of players!"}]}, "developer_name": "Divergent Realities", "developer_privacy_policy_url": "https://divergent-realities.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Divergent Realities", "support_website_url": null, "website_url": "https://www.divergent-realities.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1094800827981692"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "185900993738689"}, {"status": "PUBLISHED", "id": "660153722618646"}, {"status": "PUBLISHED", "id": "490921902015647"}]}, "baseline_offer": {"id": "660153722618646"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636399500, "status": "PUBLISHED", "id": "185900993738689"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7807470876021947", "version": "2.3.2"}, "id": "171958747712250", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7807470876021947"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730940200, "id": "7813088665460168", "version": "2.3.2", "version_code": 29387, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7813087395460295"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7807470876021947"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "171958747712250"}]}, "change_log": "Version 2.3.2 Release Notes\nIMPORTANT NOTICE:\nHardware requirements for Cards & Tankards on Android devices have been changed, now requiring 4+ GB Ram and Android 11 or newer. Download today on the Google Play Store!\nYou will now need to log-in monthly if you have Patron of the Old Gods to receive your Gems.\n\nBALANCE CHANGES:\nField Bureaucrat no longer has a Discarded ability, and reduces the cost of the first spell it sees each turn.\nAlkar, the Former Master is now 10 Mana with Mastery 2, and causes you to lose 1 Life for each spell you play.\nKira, Heroine of Garsang no longer raises her own health.\nMastercraft Flesh Golem is now 9 Mana 2/12.\nDreaded Corpse Flinger lowered from 3/3 to 2/3\nForbidden Lotus\u2019s Enhance is now \"To their Banish Zone instead for 3 Coins.\"\nMind Squander is now 2 Mana and no longer gives life.\nBone Amalgamates no longer give health as part of their Last Word.\nSoul Extraction no longer draws a card if it gets a kill.\nCosmic Reanimation now causes all players to summon the top 3 creatures of their Graveyard, dooming them and making them Undead.\nTorch Carrier\u2019s Last Word now instead Shifts all Powder Kegs in all decks to the top.\nSomething Wicked Approaches + Grand Tutoring now only Fetch Non-Legendaries.\nWraith\u2019s Wrath is reduced back to 5 damage.\n\nADDED:\nA brand new Guide Book for providing information about aspects of the game, found in your Watch Menu at the top-right.\nA completely re-done and shortened tutorial.\nAutomatic forfeiting if a player AFKs in ranked.\nA new visual showing the game deciding which player gets the first turn.\nWhilst deciding which player begins, faction banner flags matching the deck\u2019s primary and secondary choices.\nBrand new \"Mana Fragment\" system. The player going second will gain 1 at the beginning of the game.\nTooltips for when you attempt to block and are unable to do so along with why.\nA large number of new quests \u2013 Augur-focused, gamemode-focused and attribute focused.\n\nUPDATED:\nAll existing quests have had a overhaul to make them better to complete\nMilestone Quests have been adjusted to allow greater rewards for more consecutive quest completion.\nAll summons not played directly from the hand are always summoned on the right side of the board.\nPatron of the Old Gods subscription page now has a \"Manage Subscription\" button on Android.\nFlatscreen players are now able to use spells by just dragging them like they would a creature.\nA minor visual change to boost visibility when the quest board has rewards ready to be claimed.\n\nFIXED:\nMystic Envisioner\u2019s ability being triggered by Masters.\nFlatscreen Battle Camera getting pieces stuck on-screen.\nFlatscreen Zones screen can get stuck with no way to close it.\nFlatscreen Redraw screen getting stuck with no way for you to click on it.\nA visual issue where a Flatscreen player moving a card will make it appear to be clipping in their hand to others.\nEndless Enforcers summoning copies even if it\u2019s already died (in the instance of Multi-damaging abilities).\nChanneled Destruction continues to activate even though its counter is 0.\nGrow the Horde keeps waiting for you to make a second selection, even if you have no room.\nCreatures with passives not updating after a spell has been played.", "created_date": 1730848182, "id": "7807470876021947", "version": "2.3.2", "version_code": 29340, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7807469712688730"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7807470876021947"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730846494, "id": "7807368166032218", "version": "2.3.2", "version_code": 29323, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7807366879365680"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7807470876021947"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730843134, "id": "7807159099386458", "version": "2.3.2", "version_code": 29321, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7807157609386607"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7807470876021947"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730796686, "id": "7804072583028443", "version": "2.3.2", "version_code": 29303, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7804071423028559"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}