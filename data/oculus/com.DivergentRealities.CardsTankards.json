210222203645_1.png", "id": "738412340403036", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57566687_738412343736369_7295909685652399611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YEr0InhKI9YQ7kNvgHigcTb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAqKvaDUBC3ie9ub-U00DDpLB8P1nF0TzvlLwk0chq9Cw&oe=677291CC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OC_CoverLandscape.png", "id": "740112973305075", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974469_740112976638408_8491630443241959094_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hBL1loJWCmMQ7kNvgGp2oUC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB9S6Pmmi9ri9h4ja-FatY_52uTikekZHCtkocWLHQa3Q&oe=67728F15"}, "display_name": "Cards & Tankards", "keywords": [], "long_description": "This is an open beta build that is not ready for release. It lacks polish and will have bugs. Please only install it if you're interested in providing feedback and helping test for bugs.\n\nAre you tired of trying to find a strategy card game that\u2019s complex enough to make every match exhilarating, yet easy enough that anyone can learn to play?\n\nWould you love the opportunity to join a supportive community of players, where you might just make some new friends along the way?\n\nYou\u2019re in luck, because Cards & Tankards is the perfect combination of VR and tabletop gaming; blended together in one incredibly immersive package.\n\nPlay with other players and chat. Play alone against AI. Or you can just enjoy the tavern, have some laughs and observe. The choice is up to you.\n\n* 2 factions, each with their own unique combat mechanics\n* More than 60 cards currently available\n* Completely customizable decks\n* Cross-platform multiplayer, making it easy to connect with friends", "short_description": "This is an open beta build that is not ready for release. It lacks polish and will have bugs. Please only install it if you're interested in providing feedback and helping test for bugs.\n\nGrab a drink, pick your deck and prepare for Cards & Tankards \u2013 VR\u2019s most exciting, immersive and relaxing new strategy card game. Come join our wonderful, welcoming community of players!"}]}, "developer_name": "Divergent Realities", "developer_privacy_policy_url": "https://divergent-realities.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Divergent Realities", "support_website_url": null, "website_url": "https://www.divergent-realities.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1094800827981692"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "185900993738689"}, {"status": "PUBLISHED", "id": "660153722618646"}, {"status": "PUBLISHED", "id": "490921902015647"}]}, "baseline_offer": {"id": "660153722618646"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636399500, "status": "PUBLISHED", "id": "185900993738689"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8045416835560682", "version": "2.4.1"}, "id": "171958747712250", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8045416835560682"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "171958747712250"}]}, "change_log": null, "created_date": 1734670422, "id": "8045416835560682", "version": "2.4.1", "version_code": 30012, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8045415968894102"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8045416835560682"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734668565, "id": "8045297492239283", "version": "2.4.1", "version_code": 30010, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8045295822239450"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8045416835560682"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734652195, "id": "8044274722341560", "version": "2.4.1", "version_code": 30002, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8044272875675078"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8045416835560682"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734648938, "id": "8044083499027349", "version": "2.4.1", "version_code": 29999, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8044082685694097"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3073319699437112", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8045416835560682"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "171958747712250"}]}, "change_log": "Version 2.4 Release Notes\n\nIMPORTANT NOTICE\nIf you own the Patron of the Old Gods, make sure to log in monthly to claim your Gems.\n\nBALANCE CHANGES\n(Missed from the previous update) Tombstone Mimic now costs 5 Mana and has stats of 3/4.\nIndentured Servitude no longer has the Discarded ability.\nLowly Lieutenant is now classified as an Underling and no longer has the Discarded ability.\nGrand Tutoring now costs 9 Mana.\nSell-Sword no longer has the Loophole ability. Its Last Word effect is now: \"ALL players gain 1 Life.\"\n\nADDED\nDante now assists new and existing players who created their accounts after December 1st, 2024, introducing mechanics that players may not have encountered before.\n\nUPDATES\nDante has been polished with new facial features and repositioning to better suit VR players during tutorials.\nSlick Grifter and Something Wicked Approaches had their text updated for consistency with other cards.\nTrapjaw Stump and Hungry Mimic now include \"When blocked\" in their descriptions for uniformity.\nUnlawful Trespass has been raised from Common to Rare.\nMystic Envisioner has been reduced from Uncommon to Common.\n\nFIXES\nThe Guidebook now correctly displays milestone limits as 100 instead of 50.\nA typo in the quest \"Kill 5 creatures with damaging spells\" has been corrected.\nMasters no longer trigger \"deals direct damage\" abilities like Messenger Raven when taking damage.\nMasters taking damage no longer incorrectly increment the Reduce your opponent\u2019s Life Total quest.\nPlayers will no longer draw cards if a game is forfeited during the \"first person\" or \"redraw\" steps.\nThe Summon Mastery Creatures quest now correctly increments for creatures granted Mastery.\nThe Summon Taunt Creatures quest now accounts for copies of creatures granted Taunt.\nCreatures summoned by Grand Tutoring with Summon Copy abilities now correctly apply stat changes.\nCopies of Amped creatures that lose the Amped status (via suppression or theft) will no longer be summoned Unexhausted.\nCunning Snaremaster\u2019s first ability now correctly increases the damage of all Banes, not just opponents'.\nVisual artifacts in Flatscreen BattleCam caused by creatures being removed too early have been resolved.\nFlatscreen players no longer encounter errors when performing gestures or swapping havens.\nThe watch menu\u2019s Havens page now correctly displays as Havens, not Taverns.\nOn Android, cards in hand will no longer become unplayable after swapping apps.\nVR players now receive proper error messaging when attempting to block Flight or Loophole creatures.\nTombstone Mimic no longer exhausts itself when copying Amped creatures.\nSkill Siphoner now only copies active attributes from its target, ignoring disabled or suppressed ones.\nA missing tooltip explaining why a creature could not block another (if eligible to block something else) has been added.\nExiting a ranked battle now transitions background music without errors.", "created_date": 1734135025, "id": "8009922482443451", "version": "2.4", "version_code": 29843, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8009921672443532"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}