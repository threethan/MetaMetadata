98328165514_5450313528511793595_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=znCFGk6CsasQ7kNvgHwZh5T&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBz6QacFIttI0aRONxuDpkC_fy_9nKO3QAXV2bE5YHvLA&oe=677295B3"}, "display_name": "Cards & Tankards", "keywords": ["CCG", "TCG", "fantasy", "tabletop", "free"], "long_description": "\"The best VR card game I've ever played\" - Ben Plays VR\n\"My go to VR game whenever I want to have some friendly competition\" - Matteo311\n\nGrab a drink, invite your friends and ready your deck!\n\nCards & Tankards is VR\u2019s first social collectible card game. Collect over 230 cards, battle against other players or the computer and enjoy the immersive atmosphere of playing at your local card store from the comfort of your home!\n\n* 4 factions, each with their own unique combat mechanics\n* More than 230 cards currently available\n* Completely customizable decks\n* Cross-platform multiplayer, making it easy to connect with friends", "short_description": "\"The best VR card game I've ever played\" - Ben Plays VR\n\"My go to VR game whenever I want to have some friendly competition\" - Matteo311\n\nGrab a drink, invite your friends and ready your deck!\n\nCards & Tankards is VR\u2019s first social collectible card game. Collect over 230 cards, battle against other players or the computer and enjoy the immersive atmosphere of playing at your local card store from the comfort of your home!"}]}, "developer_name": "Divergent Realities", "developer_privacy_policy_url": "https://divergent-realities.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Divergent Realities", "support_website_url": null, "website_url": "https://cardsandtankards.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "275629210202852"}, {"id": "1023770785722696"}], 