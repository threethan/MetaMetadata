=1-7&_nc_sid=6e7a0a&_nc_ohc=DNwlZZxB9mEQ7kNvgG6itlo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsTQrNEARB1juSN02awSS2y&oh=00_AYC6rDMQDuovnVjQnAtk6s-oFKP7ZB4lNTQBFarGxUbp2Q&oe=66E810DD"}, {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2024-05-02 145919.png", "id": "944767843853810", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001661_944767847187143_7461031183513120923_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1HFOiO-yDK0Q7kNvgEkLWnY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsTQrNEARB1juSN02awSS2y&oh=00_AYA3hn5ScUWuNSp-zwAT69iMfYKHWVF2fL46W8CjeY1cOA&oe=66E8186B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2024-05-02 151151 (5).png", "id": "1113843839890568", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984465_1113843843223901_2623528631857933740_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q9Uis6ijs_MQ7kNvgFP3znq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsTQrNEARB1juSN02awSS2y&oh=00_AYAzkzlAUfIGqff8U74FQLMD50HwfVNV4OyyxmhEsDKEdw&oe=66E822FB"}, "display_name": "CozyFluffyFit", "keywords": [], "long_description": "This VR app offers games set in a cozy and adorable space where you can engage in activities that involve moving your body. You can put sweets into boxes, catch falling cat plushies, and more. In the game where you put sweets into boxes, you can grab the sweets using the trigger button on the controller and toss them towards the boxes, making it a simple and enjoyable experience. Similarly, in the game where you catch falling cat plushies, you just need to touch the controller to the plushies to catch them, keeping the controls easy and intuitive.\n\nFurthermore, these games are designed to minimize VR motion sickness, providing a comfortable experience for users (although individual experiences may vary). We hope you'll enjoy playing these games and find them delightful! Why not try being soothed by these adorable games?", "short_description": "In this VR app, you can play games that involve moving your body in a cozy and adorable space. You can put sweets into boxes, catch falling cat plushies, and more. Perfect for those who need to get more exercise!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sparkleand.store/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Sparkle and, Inc.", "support_website_url": null, "website_url": "https://www.sparkleand.store/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7390309804356850"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1157606418565577"}]}, "baseline_offer": {"id": "1157606418565577"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715188500, "status": "PUBLISHED", "id": "1157606418565577"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7827107597343733", "version": "1.4"}, "id": "418790131094767", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7377967328924431", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7827107597343733"}, "release_stat