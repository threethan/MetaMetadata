b7\u30e7\u30c3\u30c8 2024-05-02 145919.png", "id": "944767843853810", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001661_944767847187143_7461031183513120923_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c1Kw_UPdeUgQ7kNvgFjEHR_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDsNEnJMrMWsApuRwG55439aWFGGz-bpJyop32QAVsdHQ&oe=671E25EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2024-05-02 151151 (5).png", "id": "1113843839890568", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984465_1113843843223901_2623528631857933740_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C0MrfEqbyKsQ7kNvgEEvFex&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAU_dlDutMh4LweIzWEC97_B2jPl6wrmr0-B7hcyFMVQg&oe=671E307B"}, "display_name": "CozyFluffyFit", "keywords": [], "long_description": "This VR app offers games set in a cozy and adorable space where you can engage in activities that involve moving your body. You can put sweets into boxes, catch falling cat plushies, and more. In the game where you put sweets into boxes, you can grab the sweets using the trigger button on the controller and toss them towards the boxes, making it a simple and enjoyable experience. Similarly, in the game where you catch falling cat plushies, you just need to touch the controller to the plushies to catch them, keeping the controls easy and intuitive.\n\nFurthermore, these games are designed to minimize VR motion sickness, providing a comfortable experience for users (although individual experiences may vary). We hope you'll enjoy playing these games and find them delightful! Why not try being soothed by these adorable games?", "short_description": "In this VR app, you can play games that involve moving your body in a cozy and adorable space. You can put sweets into boxes, catch falling cat plushies, and more. Perfect for those who need to get more exercise!"}]}, "developer_name": null, 