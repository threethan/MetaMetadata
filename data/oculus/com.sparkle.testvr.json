984465_1113843843223901_2623528631857933740_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i-6JCFXmWAUQ7kNvgFdlqgo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCY5ShKXuDEJtnaOMJS4ZJFdO3THVdM4ARyAYCrF-jchQ&oe=66CC737B"}, "display_name": "CozyFluffyFit", "keywords": [], "long_description": "This VR app offers games set in a cozy and adorable space where you can engage in activities that involve moving your body. You can put sweets into boxes, catch falling cat plushies, and more. In the game where you put sweets into boxes, you can grab the sweets using the trigger button on the controller and toss them towards the boxes, making it a simple and enjoyable experience. Similarly, in the game where you catch falling cat plushies, you just need to touch the controller to the plushies to catch them, keeping the controls easy and intuitive.\n\nFurthermore, these games are designed to minimize VR motion sickness, providing a comfortable experience for users (although individual experiences may vary). We hope you'll enjoy playing these games and find them delightful! Why not try being soothed by these adorable games?", "short_description": "In this VR app, you can play games that involve moving your body in a cozy and adorable space. You can put sweets into boxes, catch falling cat plushies, and more. Perfect for those who need to get more exercise!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sparkleand.store/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Sparkle and, Inc.", "support_website_url": null, "website_url": "https://www.sparkleand.store/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_g