": "1396517297689567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001672_1396517301022900_7857274770213288241_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GAGBaWcyh4cQ7kNvgHPDJUT&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3dlKUnCusUErk8v_p_uIvMUvy3NCsgmqrvC9qSgMiGw&oe=66CC6AA3"}, {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2024-05-02 145848.png", "id": "975755090881657", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974909_975755094214990_2405686266225987643_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lHbFLw_s4Y0Q7kNvgHkYG2X&_nc_ht=scontent.oculuscdn.com&oh=00_AYATHT4vdmUaXnwsVkyxd2MF5Dz8-EfW90b98X24My0M1Q&oe=66CC615D"}, {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2024-05-02 145919.png", "id": "944767843853810", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001661_944767847187143_7461031183513120923_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2lOG-0DFehAQ7kNvgHBva0z&_nc_ht=scontent.oculuscdn.com&oh=00_AYC4BQOXYiYWZyH68Zh3_9L_TtWS2BqG5dgtkYjfD_PWRg&oe=66CC68EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2024-05-02 151151 (5).png", "id": "1113843839890568", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984465_1113843843223901_2623528631857933740_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i-6JCFXmWAUQ7kNvgFdlqgo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCY5ShKXuDEJtnaOMJS4ZJFdO3THVdM4ARyAYCrF-jchQ&oe=66CC737B"}, "display_name": "CozyFluffyFit", "keywords": [], "long_description": "This VR app offers games set in a cozy and adorable space where you can engage in activities that involve moving your body. You can put sweets into boxes, catch falling cat plushies, and more. In the game where you put sweets into boxes, you can grab the sweets using the trigger button on the controller and toss them towards the boxes, making it a simple and enjoyable experience. Similarly, in the game where you catch falling cat plushies, you just need to touch the controller to the plushies to catch them, keeping the controls easy and intuitive.\n\nFurthermore, these games are designed to minimize VR motion sickness, providing a comfortable experience for users (although individual experiences may vary). We hope you'll enjoy playing these games and find them delightful! Why not try being soothed by these adorable games?", "short_description": "In this VR app, you can play games that involve moving your body in a cozy and adorable space. You can put sweets into boxes, catch falling cat plushies, and more. Perfect for those who need to get more exercise!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sparkleand.store/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Sparkle and, Inc.", "support_website_url": null, "website_url": "https://www.sparkleand.store/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7390309804356850"}, "review_messages": ["", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404233_1111498230132224_2977581805684884324_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kty5_LkiodAQ7kNvgHpQj7H&_nc_ht=scontent.oculuscdn.com&oh=00_AYBKECiVd7r7Hr6NnAm09B-UjSU2Wmq5qpQlbU6QqPY4oA&oe=66CC76EF"}, "is_concept": false, "is_t