e what living in the house would have been like.  ", "short_description": "Step back in time to the 1950's and explore the avant guarde house design of the cult Australian Architect Iwan Iwanoff "}]}, "developer_name": null, "developer_privacy_policy_url": "https://framelabs.com.au/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Frame Mixed Reality Labs Pty Ltd", "support_website_url": null, "website_url": "https://framelabs.com.au/title/reflections-of-iwanoff/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "467390825054914"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "272092161505044"}]}, "baseline_offer": {"id": "272092161505044"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1634765580, "status": "PUBLISHED", "id": "272092161505044"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6054483484626745", "version": "3"}, "id": "257276892757546", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5254200707988364", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6054483484626745"}, "release_status": "RELEASED"},