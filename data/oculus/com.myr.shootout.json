al.png", "id": "878883400510084", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_878883403843417_1460464026387568389_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JSsiSKcYTc0Q7kNvgEXgYcb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYrZZP2J52cNlxGT5_tVfSuCFjFsxzl-fxgs8L8PkVcA&oe=673B2421"}, {"file_name": "Combat_LaserKill_final.png", "id": "1085322782879996", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031332_1085322789546662_7145848851614864919_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i7oYH0C_FhgQ7kNvgEbIpGa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgG5SSP1glQJOqDPJfwbYNWUe9YwVQs_fU15K2UuZ3dA&oe=673B0BE0"}, {"file_name": "Combat_Towers_final.png", "id": "308092208500250", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_308092211833583_7661029844051711545_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5OOMxLGoVj8Q7kNvgHsOxyQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAM4GP2INMn6UIDmIkWlsDzST016hxFZanBKO47iyxknw&oe=673B396B"}, {"file_name": "Social_Thruster_final.png", "id": "319796260634561", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_319796263967894_260876020070870858_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ee9BNfWB4QYQ7kNvgEVnLdj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBm9LkF9E4TN4l7cdA7iJ5BfEdiDqIDHUM7dHDqxrUoQg&oe=673B1BE2"}, {"file_name": "Social_TheBoys_final.png", "id": "857385049094015", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974650_857385055760681_6887887025027059372_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2OnT-vBvNvIQ7kNvgF09Ps_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD89C9qkpGrBK1jzpVqAIh2T48ZHahmK0eoKeKQkn4jaA&oe=673B357E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1272252106781035", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_1272252110114368_2196436727777597494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqT9FonKfnoQ7kNvgFpD6a3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlue_Uw31grCmxSm_8VcLUr74uWwaw6rfLlMtRteiKgg&oe=673B1B56"}, "display_name": "SHOOTOUT", "keywords": ["free", "social", "multiplayer", "shooter", "arena"], "long_description": "SHOOTOUT is VR multiplayer experience where you become your own hero.\n\nExplore a variety of weapons and modifiers to discover over 1000 unique combinations and abilities to build the loadout that YOU want to play. Change your playstyle and role mid match to adapt quicky to the game and competition. You are one part swap away from becoming a carry, support or mobility hero.\n\nExpress yourself with a catalog of customizables and impose your style on the opposition.\nExplore the depth that this game has to offer and strategize in a PvE arena and then jump into 3v3 PvP Game Modes to battle it out with other players.\n\nPlay with friends or battle alone through an expanding playlist of maps and game modes, and prove once and for all..", "short_description": "SHOOTOUT is a free to play multiplayer shooter where you get to build your own weapons and abilities!\n\nExplore the depth that this game has to offer and strategize in a PvE arena and then jump into 3v3 PvP Game Modes to battle it out with other players. \n\nStarted off a match wanting to be a support but midway realize that you want to change your playstyle? You would have 19 parts to combine freely that make up over 1000 combinations! "}]}, "developer_name": "MYR", "developer_privacy_policy_url": "https://www.myr.gg/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MYR", "support_website_url": null, "website_url": "https://www.shootoutvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "24439816915666599"}, "review_messages": ["Approving your launch submission for release tomorrow:\nThursday 12/14/2024 at 10AM PST"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982453_6986468904726252_6000170085444198997_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QBd6f1sT7kIQ7kNvgHnYirH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCElOF_AHcGJHH2IRRRzLL6G3KzqSPcgPEPeNGvmN4Xow&oe=673B225D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SHOOTOUT", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1702576800, "lastRevision": {"nodes": [{"id": "106344261629325", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5555992527808989", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "626763806194332"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Cover Square.png", "id": "6986468891392920", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982453_6986468904726252_6000170085444198997_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QBd6f1sT7kIQ7kNvgHnYirH&_nc_zt=3&_nc_ht=scontent-i