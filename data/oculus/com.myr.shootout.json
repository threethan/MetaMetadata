591_878883403843417_1460464026387568389_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wlE2qQMZTbgQ7kNvgGQ17i7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBakudrENSoMy0LLM9D09iszs2mtxffWWGtFhyjvr9WNw&oe=67090B21"}, {"file_name": "Combat_LaserKill_final.png", "id": "1085322782879996", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031332_1085322789546662_7145848851614864919_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eQAx2v26-wIQ7kNvgEFyPeO&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDlhz3oCWaSvXT3pgrecyfP-o2bC-46hBHNhtnU9S8jA&oe=67092B20"}, {"file_name": "Combat_Towers_final.png", "id": "308092208500250", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_308092211833583_7661029844051711545_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rZI0zs7MvdAQ7kNvgFCRUVx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtMlkpeWIaz0Zx7yBFnPZvI__qtpt2Lpw9Qcgtm_1IyQ&oe=6709206B"}, {"file_name": "Social_Thruster_final.png", "id": "319796260634561", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_319796263967894_260876020070870858_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oz0eymYFg7EQ7kNvgHLbs-z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXCT1ijEMxWdMyXtRbz7trSYC-O2IOHu7mdRBQ4VuOog&oe=670902E2"}, {"file_name": "Social_TheBoys_final.png", "id": "857385049094015", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974650_857385055760681_6887887025027059372_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OtjcEIKpMocQ7kNvgGK-13L&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPRFv1rIl7I50BFCmL_b086D-dTBgjgwiZ47ZPFlAeXQ&oe=67091C7E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1272252106781035", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_1272252110114368_2196436727777597494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gOydvYoVCS4Q7kNvgGLvu-V&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBhBrS5WTKNDFxqIQQrE4dkGnBF8BP2hdUeu-l0lHHBQ&oe=67090256"}, "display_name": "SHOOTOUT", "keywords": ["free", "social", "multiplayer", "shooter", "arena"], "long_description": "SHOOTOUT is VR multiplayer experience where you become your own hero.\n\nExplore a variety of weapons and modifiers to discover over 1000 unique combinations and abilities to build the loadout that YOU want to play. Change your playstyle and role mid match to adapt quicky to the game and competition. You are one part swap away from becoming a carry, support or mobility hero.\n\nExpress yourself with a catalog of customizables and impose your style on the opposition.\nExplore the depth that this game has to offer and strategize in a PvE arena and then jump into 3v3 PvP Game Modes to battle it out with other players.\n\nPlay with friends or battle alone through an expanding playlist of maps and game modes, and prove once and for all..", "short_description": "SHOOTOUT is a free to play multiplayer shooter where you get to build your own weapons and abilities!\n\nExplore the depth that this game has to offer and strategize in a PvE arena and then jump into 3v3 PvP Game Modes to battle it out with other players. \n\nStarted off a match wanting to be a support but midway realize that you want to change your playstyle? You would have 19 parts to combine freely that make up over 1000 combinations! "}]}, "developer_name": "MYR", "developer_privacy_policy_url": "https://www.myr.gg/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MYR", "support_website_url": null, "website_url": "https://www.shootoutvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommen