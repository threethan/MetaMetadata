inal.png", "id": "878883400510084", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_878883403843417_1460464026387568389_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wv1Z4t2I-owQ7kNvgGgcIT8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCf5EunpzFECldDiXwHsiL-ZlJ-dV5Giq29O-3eWSeALQ&oe=674701A1"}, {"file_name": "Combat_LaserKill_final.png", "id": "1085322782879996", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031332_1085322789546662_7145848851614864919_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vJ5YX1rqbb0Q7kNvgFD1jTW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5CjFdlQlfKXcFqddjvTgK3DXCcPhq8iXQKqr__HKGPQ&oe=6746E960"}, {"file_name": "Combat_Towers_final.png", "id": "308092208500250", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_308092211833583_7661029844051711545_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xgy3xp8rWPQQ7kNvgGNlkLp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBcjwDYPv7HaDys8sjFuUD3GrFoGJdahRCXOu03ueSuPQ&oe=674716EB"}, {"file_name": "Social_Thruster_final.png", "id": "319796260634561", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_319796263967894_260876020070870858_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bvxx_6ohtm0Q7kNvgFQl8gX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLagoOCfQsdDjWAd-jtbvXFkAhAMdm1U0oWaaVQd1hnA&oe=6746F962"}, {"file_name": "Social_TheBoys_final.png", "id": "857385049094015", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974650_857385055760681_6887887025027059372_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wzcGP0QWwSgQ7kNvgG6hHZB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtFV-PVjEnG2LN70vlXvTPH8ey0sEZVmZI3FHEejdNGg&oe=674712FE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1272252106781035", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_1272252110114368_2196436727777597494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k5-nBsolwrwQ7kNvgEtaKFE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQdwMVKb0Piy01VuxdGiJLi3ZaEDvYe8igjfqd7sShAw&oe=6746F8D6"}, "display_name": "SHOOTOUT", "keywords": ["free", "social", "multiplayer", "shooter", "arena"], "long_description": "SHOOTOUT is VR multiplayer experience where you become your own hero.\n\nExplore a variety of weapons and modifiers to discover over 1000 unique combinations and abilities to build the loadout that YOU want to play. Change your playstyle and role mid match to adapt quicky to the game and competition. You are one part swap away from becoming a carry, support or mobility hero.\n\nExpress yourself with a catalog of customizables and impose your style on the opposition.\nExplore the depth that this game has to offer and strategize in a PvE arena and then jump into 3v3 PvP Game Modes to battle it out with other players.\n\nPlay with friends or battle alone through an expanding playlist of maps and game modes, and prove once and for all..", "short_description": "SHOOTOUT is a free to play multiplayer shooter where you get to build your own weapons and abilities!\n\nExplore the depth that this game has to offer and strategize in a PvE arena and then jump into 3v3 PvP Game Modes to battle it out with other players. \n\nStarted off a match wanting to be a support but midway realize that you want to change your playstyle? You would have 19 parts to combine freely that make up over 1000 combinations! "}]}, "developer_name": "MYR", "developer_privacy_policy_url": "https://www.myr.gg/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MYR", "support_website_url": null, "website_url": "https://www.shootoutvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": 