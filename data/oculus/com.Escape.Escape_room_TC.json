."}, {"images": {"nodes": []}, "id": "721775232356470", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte.\n\nThe Creature: Escape Room ist das erste Kapitel dieser spannenden Geschichte.\n\nGehen Sie durch drei v\u00f6llig unterschiedliche Levels mit unglaublichen Herausforderungen.\n\n- Wohnung.\n- Labor.\n- Halle.\n\nJedes Level hat seine eigenen R\u00e4tsel, die in die Umgebung integriert sind.\n\nDie Kreatur: Escape Room ist nicht nur ein Puzzlespiel, es ist eine Geschichte voller Intrigen, Traurigkeit und Hoffnung.", "short_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte."}, {"images": {"nodes": []}, "id": "530681915264945", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Eres un detective enviado a investigar el maltrato de una misteriosa criatura. En este escape room no solo hay puzles, sino tambi\u00e9n personajes e historia.\n\nThe Creature: Escape Room es el primer cap\u00edtulo de esta apasionante historia.\n\nPasa por tres niveles completamente diferentes con desaf\u00edos incre\u00edbles.\n\n- Departamento.\n- Laboratorio.\n- Hangar.\n\nCada nivel tiene sus propios rompecabezas integrados con el entorno.\n\nLa criatura: Escape Room no es solo un juego de rompecabezas, es una historia de intriga, tristeza y esperanza.", "short_description": "Eres un detective enviado a investigar el maltrato de una misteriosa criatura. En este escape room no solo hay puzles, sino tambi\u00e9n personajes e historia."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pages.flycricket.io/the-creature-escape/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "K148GS", "support_website_url": null, "website_url": "https://twitter.com/K148_GS", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "820625748910259"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "539468244306698"}, {"status": "PENDING", "id": "768665825080694"}, {"status": "PUBLISHED", "id": "851568282488738"}]}, "baseline_offer": {"id": "851568282488738"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1655244000, "status": "PUBLISHED", "id": "539468244306698"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5166482776803449", "version": "1.04"}, "id": "1037169543892477", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5110876899030704", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5166482776803449"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "10371