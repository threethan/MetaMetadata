": "687141163065615", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Vous \u00eates un d\u00e9tective envoy\u00e9 pour enqu\u00eater sur les mauvais traitements inflig\u00e9s \u00e0 une cr\u00e9ature myst\u00e9rieuse. Dans cette \"escape room\", il n'y a pas que des puzzles, mais aussi des personnages et de l'histoire.\n\nThe Creature: Escape Room est le premier chapitre de cette histoire passionnante.\n\nPassez par trois niveaux compl\u00e8tement diff\u00e9rents avec des d\u00e9fis incroyables.\n\n- Appartement.\n- Laboratoire.\n-Hangar.\n\nChaque niveau a ses propres puzzles int\u00e9gr\u00e9s \u00e0 l'environnement.\n\nLa cr\u00e9ature : Escape Room n'est pas seulement un jeu de puzzle, c'est une histoire d'intrigue, de tristesse et d'espoir.", "short_description": "Vous \u00eates un d\u00e9tective envoy\u00e9 pour enqu\u00eater sur les mauvais traitements inflig\u00e9s \u00e0 une cr\u00e9ature myst\u00e9rieuse. Dans cette \"escape room\", il n'y a pas que des puzzles, mais aussi des personnages et de l'histoire."}, {"images": {"nodes": []}, "id": "453674273523540", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte.\n\nThe Creature: Escape Room ist das erste Kapitel dieser spannenden Geschichte.\n\nGehen Sie durch drei v\u00f6llig unterschiedliche Levels mit unglaublichen Herausforderungen.\n\n- Wohnung.\n- Labor.\n- Halle.\n\nJedes Level hat seine eigenen R\u00e4tsel, die in die Umgebung integriert sind.\n\nDie Kreatur: Escape Room ist nicht nur ein Puzzlespiel, es ist eine Geschichte voller Intrigen, Traurigkeit und Hoffnung.", "short_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pages.flycricket.io/the-creature-escape/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "K148GS", "support_website_url": null, "website_url": "https://twitter.com/K148_GS", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "458336742832614"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348043_1575551989596159_6220854560707171359_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Ljf87UBnEcQ7kNvgFpsQnv&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZR8Dh3xsLeH9yaO5O-RtqjydY1nTqTYRyPj3UPCRVnA&oe=66DEF73D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Creature: Escape Room", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_na