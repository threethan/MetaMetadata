com&_nc_gid=ANFrR-04lsKgNZQzS_F3NQb&oh=00_AYD7iP8HuPVoJQVv5OTuTYCQtPlci4E3YLSj76GlWdnpXA&oe=66D84A9D"}, {"file_name": "Escreen_2.png", "id": "554719806235592", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580063_554719809568925_4119510991009765398_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-q3A73FTCOYQ7kNvgERmOya&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANFrR-04lsKgNZQzS_F3NQb&oh=00_AYAoJh50SVlZx15M8fyiVphOGCW3vjLmihsp6yVmaA1Kcw&oe=66D858E0"}, {"file_name": "Escreen_3.png", "id": "738901917158663", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221323_738901923825329_5577976255116239868_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4dcyy8Fk3RYQ7kNvgGcLIeD&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANFrR-04lsKgNZQzS_F3NQb&oh=00_AYB9aPnK-wAs84ARTNoP_ypM_dfM4gKrB89XVBtynE6xCQ&oe=66D84129"}, {"file_name": "Escreen_5.png", "id": "744729796576174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230043_744729799909507_7200741171473143701_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=btG5CWP7qrwQ7kNvgF_YddW&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANFrR-04lsKgNZQzS_F3NQb&oh=00_AYDt8iC3CLC6LlbgseUMD3CjLy8OANvA768e2yv2ddGtIg&oe=66D84755"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PortadaHorizonal.png", "id": "575154470701658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230048_575154474034991_1906260858405282920_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=On_czrU2Z8gQ7kNvgFzlwvN&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANFrR-04lsKgNZQzS_F3NQb&oh=00_AYDJOD_c4h-1nd__AloXbry5zG2_Rexi8cJG8oTr6eJLxQ&oe=66D84939"}, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "You are a detective sent to investigate the mistreatment of a mysterious creature. In this escape room there are not only puzzles, but also characters and history.\n\nThe creature: Escape Room is the first chapter of this exciting story.\n\nGo through three completely different levels with incredible challenges.\n\n- Apartment.\n- Laboratory.\n- Hangar.\n\nEach level has its own puzzles integrated with the environment.\n\nThe creature: Escape Room is not just a puzzle game, it is a story of intrigue, sadness and hope.", "short_description": "You are a detective sent to investigate the mistreatment of a mysterious creature. In this escape room there are not only puzzles, but also characters and history."}, {"images": {"nodes": []}, "id": "687141163065615", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Vous \u00eates un d\u00e9tective envoy\u00e9 pour enqu\u00eater sur les mauvais traitements inflig\u00e9s \u00e0 une cr\u00e9ature myst\u00e9rieuse. Dans cette \"escape room\", il n'y a pas que des puzzles, mais aussi des personnages et de l'histoire.\n\nThe Creature: Escape Room est le premier chapitre de cette histoire passionnante.\n\nPassez par trois niveaux compl\u00e8tement diff\u00e9rents avec des d\u00e9fis incroyables.\n\n- Appartement.\n- Laboratoire.\n-Hangar.\n\nChaque niveau a ses propres puzzles int\u00e9gr\u00e9s \u00e0 l'environnement.\n\nLa cr\u00e9ature : Escape Room n'est pas seulement un jeu de puzzle, c'est une histoire d'intrigue, de tristesse et d'espoir.", "short_description": "Vous \u00eates un d\u00e9tective envoy\u00e9 pour enqu\u00eater sur les mauvais traitements inflig\u00e9s \u00e0 une cr\u00e9ature myst\u00e9rieuse. Dans cette \"escape room\", il n'y a pas que des puzzles, mais aussi des personnages et de l'histoire."}, {"images": {"nodes": []}, "id": "453674273523540", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte.\n\nThe Creature: Escape Room ist das erste Kapitel dieser spannenden Geschichte.\n\nGehen Sie durch drei v\u00f6llig unterschiedliche Levels mit unglaublichen Herausforderungen.\n\n- Wohnung.\n- Labor.\n- Halle.\n\nJedes Level hat seine eigenen R\u00e4tsel, die in die Umgebung integriert sind.\n\nDie Kreatur: Escape Room ist nicht nur ein Puzzlespiel, es ist eine Geschichte voller Intrigen, Traurigkeit und Hoffnung.", "short_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pages.flycricket.io/the-creature-escape/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "K148GS", "support_website_url": null, "website_url": "https://twitter.com/K148_GS", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "458336742832614"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348043_1575551989596159_6220854560707171359_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HRB8Sx5RS5wQ7kNvgFMe4O-&_nc_ht=scontent.oculuscdn.com&_nc_gid