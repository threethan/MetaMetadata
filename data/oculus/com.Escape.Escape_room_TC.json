thumbnail": {"file_name": "PortadaHorizonal.png", "id": "575154470701658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230048_575154474034991_1906260858405282920_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5d3Z2pUtWowQ7kNvgED4mZc&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwjs3jRQ0AYAlg1dC_OugGWPCiUOef0nkJF8J6-eUAqw&oe=66DEE0B9"}, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "You are a detective sent to investigate the mistreatment of a mysterious creature. In this escape room there are not only puzzles, but also characters and history.\n\nThe creature: Escape Room is the first chapter of this exciting story.\n\nGo through three completely different levels with incredible challenges.\n\n- Apartment.\n- Laboratory.\n- Hangar.\n\nEach level has its own puzzles integrated with the environment.\n\nThe creature: Escape Room is not just a puzzle game, it is a story of intrigue, sadness and hope.", "short_description": "You are a detective sent to investigate the mistreatment of a mysterious creature. In this escape room there are not only puzzles, but also characters and history."}, {"images": {"nodes": []}, "id": "721775232356470", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte.\n\nThe Creature: Escape Room ist das erste Kapitel dieser spannenden Geschichte.\n\nGehen Sie durch drei v\u00f6llig unterschiedliche Levels mit unglaublichen Herausforderungen.\n\n- Wohnung.\n- Labor.\n- Halle.\n\nJedes Level hat seine eigenen R\u00e4tsel, die in die Umgebung integriert sind.\n\nDie Kreatur: Escape Room ist nicht nur ein Puzzlespiel, es ist eine Geschichte voller Intrigen, Traurigkeit und Hoffnung.", "short_description": "Sie sind ein Detektiv, der geschickt wird, um die Misshandlung einer mysteri\u00f6sen Kreatur zu untersuchen. In diesem \u201eEscape Room\u201c gibt es nicht nur R\u00e4tsel, sondern auch Charaktere und Geschichte."}, {"images": {"nodes": []}, "id": "530681915264945", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Creature: Escape Room", "keywords": [], "long_description": "Eres un detective enviado a investigar el maltrato de una misteriosa criatura. En este escape room no solo hay puzles, sino tambi\u00e9n personajes e historia.\n\nThe Creature: Escape Room es el primer cap\u00edtulo de esta apasionante historia.\n\nPasa por tres niveles completamente diferentes con desaf\u00edos incre\u00edbles.\n\n- Departamento.\n- Laboratorio.\n- Hangar.\n\nCada nivel tiene sus propios rompecabezas integrados con el entorno.\n\nLa criatura: Escape Room no es solo un juego de rompecabezas, es una historia de intriga, tristeza y esperanza.", "short_description": "Eres un detective enviado a investigar el maltrato de una misteriosa criatura. En este escape room no solo hay puzles, sino tambi\u00e9n personajes e historia."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pages.flycricket.io/the-creature-escape/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "K148GS", "support_website_url": null, "website_url": "https://twitter.com/K148_GS", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_pla