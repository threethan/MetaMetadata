3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDsu4CVQTtUSeV12N-vqAHmRDNmnM7AkgrS0LFoTzWkRA&oe=675D822E"}, {"file_name": "ss1.png", "id": "434810578927152", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982480_434810582260485_440581986939748836_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F2FyuvEyMlwQ7kNvgH-uKXA&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD0kTb8aUj6j_KoxcEScB8z1-GlovyZyEdOxEvFYJ9X4w&oe=675D87A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SKY_RUNNER-COVER_LANDSCAPE-2560x1440.png", "id": "1351531712471575", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75630190_1351531715804908_6823304080681783927_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JwQYntbtTXkQ7kNvgGS9Iai&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBCy7OvsqEDo_EVzyaClfkc9WHLVrOL-8d9CFVhdOFC8g&oe=675D5CE8"}, "display_name": "Sky Runner", "keywords": ["Drone", "Flying", "RC", "FPV", "Helicopter"], "long_description": "**Your Mission:**  Take control of agile, heavily-armed drones bristling with explosives and defend your home from waves of hostile missile launchers that emerge from every corner of your room. \ud83d\ude80 Quick thinking and sharp reflexes are your keys to survival. But there's more at stake; a hostage is trapped in the environment. Can you outmaneuver the enemy, rescue the innocent, and claim victory? \n\n**Sky Runner's Key Features:** Immersive Mixed Reality Gameplay: Witness the fusion of your real-world surroundings with intense virtual combat. Every piece of your play space transforms into a dynamic battlefield, bringing a surreal sense of immersion as you pilot your drones.\n\n**Intuitive and Responsive Drone Controls:** Master the art of drone piloting with controls designed to offer both ease of use and precision.\n\n**Strategic Combat with Depth:** Engage in tactical warfare as you navigate the challenges of each mission. Strategize your drone strikes to neutralize the missile launchers while keeping the hostage safe, adding layers of complexity to every encounter.\n\n**Exciting New Content Coming Soon:** Get a sneak peek at upcoming expansions with exclusive preview modes included in Sky Runner. Transform your drone into an aerial firefighter, battling spreading blazes and saving structures from destruction. \ud83d\ude92 Customize your own missions and courses within your unique play space. \ud83d\udee0\ufe0f With more levels and game modes on the horizon, Sky Runner continually evolves to deliver fresh and engaging challenges.\n{938184674781790}", "short_description": "Transform your living room into a high-stakes battleground with Sky Runner, the next level in mixed-reality drone combat.\n\n"}]}, "developer_name": "RudyAA", "developer_privacy_policy_url": "https://www.bomberdronevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Flat2VR Studios", "support_website_url": null, "website_url": "https://bomberdronevr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27315610074692778"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75195913_1098078985074464_8704449177253093793_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1wYLtgANqgQ7kNvgFg3Guc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAx5chpKSrvXzLUeKBedHY_cvRy4PBnlutW9El