588696432_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IszNEHYw2ckQ7kNvgEokWK0&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAkuRxcWAEL1tmYSeLzddZ30gyraN2_0cX4hcYK37friw&oe=675D8BB7"}, {"file_name": "ss2.png", "id": "770291515049945", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974693_770291518383278_7833093441320552225_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNiJLJl59YIQ7kNvgGyfJuA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAvvBNsmbTmgfhsBAaVApM7SIM1RDKBhVBf1DPkoVU0Mg&oe=675D7FF3"}, {"file_name": "ss3.png", "id": "939945031093691", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031547_939945037760357_1152048350112599683_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bhc0ulG-GRwQ7kNvgFofSvN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDsu4CVQTtUSeV12N-vqAHmRDNmnM7AkgrS0LFoTzWkRA&oe=675D822E"}, {"file_name": "ss1.png", "id": "434810578927152", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982480_434810582260485_440581986939748836_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F2FyuvEyMlwQ7kNvgH-uKXA&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD0kTb8aUj6j_KoxcEScB8z1-GlovyZyEdOxEvFYJ9X4w&oe=675D87A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer2.png", "id": "433734469116891", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57569451_433734472450224_566490380937901156_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1sW71EE0ftQQ7kNvgG8a7Ko&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAW0C80Q-oynr3V4CZyUtHRzO72kuZG5sFJG76QhpnZbA&oe=675D7229"}, "display_name": "Bomber Drone", "keywords": [], "long_description": "Take control of heavily-armed drones:  These agile bots bristle with bombs, ready to unleash devastation on your enemies.\n\nYour mission: Eliminate waves of hostile missile launchers that materialize within the confines of your room, using the familiar space as your combat zone. But watch out \u2013 these launchers pack a punch, so stay on your toes!\n\nThe ultimate objective:  You must strategically deploy your drone strikes to neutralize the launchers before they can unleash their payloads. But that's not all! There's an innocent hostage trapped in the environment, adding another layer of urgency to your mission. Can you eliminate the threats, save the hostage, and emerge victorious?\n\nBomber Drone offers:\n\nThrilling MR Gameplay: Blur the lines between reality and the virtual world as your living room transforms into a dynamic battlefield.\nIntuitive Drone Control: Master the art of piloting your bomb-laden drones with ease.\nStrategic Depth: Devise cunning tactics to take down the launchers while protecting the hostage.\n\nBomber Drone: Where virtual warfare meets the comfort of your own home. Are you ready to become the ultimate bomb-wielding hero?", "short_description": "Dive into the adrenaline-pumping world of Bomber Drone, a groundbreaking Mixed-Reality (MR) arcade experience! Strap on your VR headset and step into a virtual battlefield in your actual living room."}]}, "developer_name": "RudyAA", "developer_privacy_policy_url": "https://www.bomberdronevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Frost Punch Games", "support_website_url": null, "website_url": "https://bomberdronevr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "i