_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMqlVeRJ7rvVs2Cps2q04FPIQCwdFR-99KxFSGDNNmlg&oe=676C0829"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer2.png", "id": "433734469116891", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569451_433734472450224_566490380937901156_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j6dcXpoOpcoQ7kNvgFqpANq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByiAL7rNORt5BKwZmbdp4_gH48wE2dfkeYIZ9ENB9WJQ&oe=676BF2A9"}, "display_name": "Bomber Drone", "keywords": [], "long_description": "Take control of heavily-armed drones:  These agile bots bristle with bombs, ready to unleash devastation on your enemies.\n\nYour mission: Eliminate waves of hostile missile launchers that materialize within the confines of your room, using the familiar space as your combat zone. But watch out \u2013 these launchers pack a punch, so stay on your toes!\n\nThe ultimate objective:  You must strategically deploy your drone strikes to neutralize the launchers before they can unleash their payloads. But that's not all! There's an innocent hostage trapped in the environment, adding another layer of urgency to your mission. Can you eliminate the threats, save the hostage, and emerge victorious?\n\nBomber Drone offers:\n\nThrilling MR Gameplay: Blur the lines between reality and the virtual world as your living room transforms into a dynamic battlefield.\nIntuitive Drone Control: Master the art of piloting your bomb-laden drones with ease.\nStrategic Depth: Devise cunning tactics to take down the launchers while protecting the hostage.\n\nBomber Drone: Where virtual warfare meets the comfort of your own home. Are you ready to become the ultimate bomb-wielding hero?", "short_description": "Dive into the adrenaline-pumping world of Bomber Drone, a groundbreaking Mixed-Reality (MR) arcade experience! Strap on your VR headset and step into a virtual battlefield in your actual living room."}]}, "developer_name": "RudyAA", "developer_privacy_policy_url": "https://www.bomberdronevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Frost Punch Games", "support_website_url": null, "website_url": "https://bomberdronevr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25896246746629125"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "791498809540353"}]}, "baseline_offer": {"id": "791498809540353"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712853600, "status": "PUBLISHED", "id": "791498809540353"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "28740880688832369", "version": "1.1"}, "id": "217588828039628", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25082836531303488", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28740880688832369"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "217588828039628"}]}, "change_log": null, "created_date": 1734487655, "id": "28740880688832369", "version": "1.1", "version_code": 100, "release_status": "RELEASED", "status": "APPROVED