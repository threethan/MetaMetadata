-2024-12-19-10h30m14s079.png", "id": "877265734285046", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/75572758_877265737618379_7508554928736894678_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y4t_qUi2dO0Q7kNvgHHpg-r&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYBIcXpcFVe5bj94YeKSqKgm_SySN0qbp9dOaKRbqv8bVQ&oe=677E531C"}, {"file_name": "vlcsnap-2024-12-19-10h31m25s584.png", "id": "2742716422598298", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982511_2742716425931631_245054809884616574_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HNOaWfOomgwQ7kNvgG_5hW6&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAwgRST1SvSk5G1cMRBGSfne-6uDoFhjRhqt1MY8kfeKQ&oe=677E6F84"}, {"file_name": "vlcsnap-2024-12-19-10h31m44s914.png", "id": "1268414077767063", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982503_1268414081100396_4618396570213955071_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pLmfP0DObIQQ7kNvgHVGfzz&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBqVpn-lkQ3QaggbO5amvniZG8IDZVCS-1X553-jySJLA&oe=677E7BDA"}, {"file_name": "vlcsnap-2024-12-19-10h32m10s503.png", "id": "1142917107177995", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39031454_1142917110511328_1919218757973247895_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yT720nCUGgoQ7kNvgHkhzNw&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDVWbChnMtB3ev2P3lFliog0FMfl51n7qTlsFsLvHhZIg&oe=677E6801"}, {"file_name": "vlcsnap-2024-12-19-10h32m32s910.png", "id": "640027455021644", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39003272_640027458354977_7066714027952897299_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yfkl4YYN_rsQ7kNvgFHUohH&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYB3bhZpmhwXXeLfqA6ZZibZYKSIU04or2VgGx-LB_7MWg&oe=677E6013"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Christmas Cover Landscape 2560 x 1440 (1).png", "id": "3734190116871651", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031420_3734190120204984_7048526618196222799_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dpivdTTcl0QQ7kNvgG0viTR&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYA9o40q42u9ee5Kh8_1TXjleapkC5T5OXGHCatkrbZPjQ&oe=677E7909"}, "display_name": "Sky Runner", "keywords": ["Drone", "RC", "FPV", "Christmas", "Holiday"], "long_description": "# Sky Runner is in Active Development!\n\nMore scenarios and multiplayer will be added in the future, and we are looking for YOUR feedback. Join the Flat2VR Discord to share your ideas directly with the developers! \nhttps://discord.gg/yC5498Jd4B\n\n# Make an Impact!\nFrom December 18, 2024, through January 28, 2025, players can experience Gift Drift, a festive new game mode where holiday-themed drones deliver presents while avoiding lumps of coal. However, the stakes here are quite real\u2014every successful delivery in-game makes a notable real-world impact. Learn more by checking out our socials.\n\n{1286300412564115}\n\n# Take Control of the Skies!\n\nSky Runner allows you to experience the thrills of flying a drone without the need of expensive equipment. \n\n{1306304820389672}\n\nFly drones wherever you want in your living room, your backyard \u2013 even in your bathroom! \n\nCreate your own courses, and race to the finish.\n{577523178469471}\n\n{8566109120185328}", "short_description": "Transform your living room into a high-stakes battleground with Sky Runner, the next level in mixed-reality drone combat.\n\n"}]}, "developer_name": "RudyAA", "developer_privacy_policy_url": "https://www.bomberdronevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Flat2VR Studios", "support_website_url": null, "website_url": "https://bomberdronevr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "199010405