ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-yxcw07ZrUIGneLcbDOHGYz2-sjnTKFlxdWuokucU4w&oe=673B3FE0"}, {"file_name": "GESS4.png", "id": "4297632556964233", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974748_4297632563630899_1880199743342134547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ISE3lt4Nu0EQ7kNvgGSGXoi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAD4X9qFvww8DRkXJ125MR5qxtp6PqJbF4QcJnk9UesUA&oe=673B3DA9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "GE_LANDSCAPE_KO_oculus.png", "id": "991885594920821", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982525_991885598254154_7191772466377756642_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4OOQ1J7jC8MQ7kNvgHRai5Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEwIHSlG0xF-YcNHyvf2QZbKc1cxauB_Dj8q-SyMljQw&oe=673B19D6"}, "display_name": "\uae00\ub8e8\ubbf8 \uc544\uc774\uc988", "keywords": [], "long_description": "\ud0dc\uc591\uc774 \uc778\uac04\ub4e4\uc5d0\uac8c \uc5fc\uc99d\uc744 \ub290\ub07c\uace0 \ub2e4\uc2dc\ub294 \ub728\uc9c0 \uc54a\uaca0\ub2e4\uace0 \uacb0\uc2ec\ud588\uc744 \ub54c, \uc5b4\ub460\uc740 \ubb34\ub364\uc5d0\uc11c \uc8fd\uc740 \uc0ac\ub78c\ub4e4\uc744 \uae68\uc6e0\ub2e4. \uc774\ud6c4 \uc778\uac04\uacfc \uc880\ube44\uc758 \ucda9\ub3cc\ub85c \uc138\uc0c1\uc740 \ud63c\ub780\uc5d0 \ube60\uc9c0\uac8c \ub41c\ub2e4.\n\n\ucf5c\ub9b0 \ud328\ub7f4\uc774 \uc6d0\uc791\uc758 \ub0b4\ub808\uc774\uc158\uc744 \ub9e1\uc740 \"\uae00\ub8e8\ubbf8 \uc544\uc774\uc988\"\ub294 \uac10\uc131\uc744 \uc790\uadf9\ud558\ub294 \uc560\ub2c8\uba54\uc774\uc158 3\ubd80\uc791\uc73c\ub85c, \ud658\uc0c1\uc801\uc778 \ub514\uc624\ub77c\ub9c8\uc560\ub2c8\uba54\uc774\uc158\uc774 \uad00\uac1d\uc758 \uc8fc\ubcc0\uc744 \ud718\uac10\uc73c\uba70 \uc774\uc57c\uae30\uac00 \uc9c4\ud589\ub41c\ub2e4.\n\n\uc5b4\uca50\uc9c0 \uadf8\ub9ac\uc6c0\uc5d0 \uac00\uc2b4\uc774 \uba39\uba39\ud574\uc9c0\ub294 \uc880\ube44 \uc18c\ub144 '\uae00\ub8e8\ubbf8'\uc640 \uc778\uac04 \uc18c\ub140 '\ub2c8\ub098'\uc758 \uc0ac\ub791 \uc774\uc57c\uae30\ub97c \ub530\ub77c\uac00\ubcf4\uc790. \uadf8\ub4e4\uc758 \uc6b4\uba85\uc774 \uad50\ucc28\ud558\ub294 \uc0ac\ub791\uc740 \uadf8\uc800 \ud76c\ub9dd\uc758 \ub9c8\uc9c0\ub9c9 \uc528\uc557\uc774 \ub420\uc9c0\ub3c4 \ubaa8\ub978\ub2e4.\n\n\uc120\ub304\uc2a4 \uc601\ud654\uc81c\uc5d0\uc11c \uccab \uc120\uc744 \ubcf4\uc778 \ud6c4(2019), \uc559\uc2dc\uad6d\uc81c\uc560\ub2c8\uba54\uc774\uc158\uc601\ud654\uc81c(2019\ub144)\uc5d0\uc11c '\ucd5c\uace0\uc758 VR \uccb4\ud5d8\uc0c1'\uacfc SXSW(2019)\uc5d0\uc11c '\uc2a4\ud1a0\ub9ac\ud154\ub9c1 \ubd80\ubb38 \uc2ec\uc0ac\uc704\uc6d0\uc0c1'\uc744 \uc218\uc0c1\ud588\ub2e4. \ud55c\uad6d\uc5d0\uc11c\ub294 \ubd80\ucc9c\uad6d\uc81c\ud310\ud0c0\uc2a4\ud2f1\uc601\ud654\uc81c(2019)\uc5d0 \ucd08\uccad\ub418\uc5c8\ub2e4.\n\n\ud638\ub974\ud5e4 \ud14c\ub808\uc18c(Jorge Tereso)\uc640 \ud398\ub974\ub09c\ub3c4 \ub9d0\ub3c4\ub098\ub3c4(Fernando Maldonado)\uac00 \ucc3d\uc791\ud558\uace0, \uc544\ud2c0\ub77c\uc2a4V(Atlas V), \uc624\ud058\ub7ec\uc2a4(Oculus), \uc544\ub974\ub5bc \ud504\ub791\uc2a4(Arte France), \ub77c\uc774\uc5c7(Ryot), \uc54c\ube44\uc698(Albyon)\uacfc \ud37c\uc2a4\ud2b8\uc5d0\ubc84\ub274\uba38\uc2e0(1STAveMachine) \uc81c\uc791, \uce7c\ub808\uc774\ub3c4\uc2a4\ucf54\ud504, \ub860 \uc54c\ud504\uc2a4 \uc2dc\ub124\ub9c8(Rh\u00f4ne Alpes Cin\u00e9ma), \uc720\ud29c\ube0c(Youtube)\uc640 \uc528\uc5d4\uc528(CNC)\uac00 \uc9c0\uc6d0\ud588\ub2e4.\n", "short_description": "\u2018\uae00\ub8e8\ubbf8 \uc544\uc774\uc988\u2019\ub294 \ucf5c\ub9b0 \ud328\ub7f4\uc758 \ubaa9\uc18c\ub9ac\uc640 \ud568\uaed8 \uc778\uac04\ub4e4\uc5d0\uac8c \uc5fc\uc99d\uc774 \ub098\uc11c \uc228\uc5b4 \ubc84\ub9ac\uace0 \ub2e4\uc2dc\ub294 \ub728\uc9c0 \uc54a\uae30\ub85c \uacb0\uc2ec\ud55c \ud0dc\uc591\uc758 \uc774\uc57c\uae30\ub97c \ub4e4\ub824\uc900\ub2e4. \u2018\uae00\ub8e8\ubbf8 \uc544\uc774\uc988\u2019\ub294 6\ucd95(6DoF) 3D \uc2e4\uc2dc\uac04 VR \uc560\ub2c8\uba54\uc774\uc158 \uc2dc\ub9ac\uc988\uc774\ub2e4.\n"}, {"images": {"nodes