65955548202"}]}, "id": "533108197455135"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1671004309616863"}]}, "id": "142364086519470"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1199482320162285"}]}, "id": "295392964236019"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1514447601900695"}]}, "id": "278114242599922"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1072311739534695"}]}, "id": "674032639414629"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1015802351839289"}]}, "id": "975351905910255"}]}}, "firstRevision": {"nodes": [{"application": {"id": "2933720383334150", "release_date": 1590685164, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 8}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4452173501488823"}, "id": "839908306455096"}]}}, "binary": {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2933720383334150", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4452173501488823"}, "release_status": "RELEASED"}, "id": "4452173501488823", "version": "40", "version_code": 40, "release_status": "RELEASED", "status": "APPROVED"}, "live_binary": null, "created_date": 1596017827, "id": "3341079115942261", "is_initial_release": false, "name_with_fallback": "v8", "pdp_metadata_with_fallback": {"version": 1, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "401720634764687"}, "release_status": "RELEASED", "id": "2933720383334150"}, "id": "401720634764687", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2933720383334150", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "624852721414051"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "2568138510165445", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gloomy Eyes", "keywords": ["Tiny", "Zombie", "Movies", "Narrative", "Animation"], "long_description": "Als die Sonne der Menschen \u00fcberdr\u00fcssig wurde und beschloss, nie wieder aufzugehen, lie\u00df die ewige Finsternis die Toten aus ihren Gr\u00e4bern steigen. Menschen und Zombies liefern sich seither einen unerbittlichen Kampf.\n\nDie animierte Trilogie \u201cGloomy Eyes\u201d, erz\u00e4hlt von Max Riemelt, ist eine ergreifende Fabel; fantastische animierte Dioramas drehen sich um Sie herum.\n\nLassen Sie sich von dieser nostalgischen und ber\u00fchrenden Geschichte eines Zombiejungens, Gloomy, und eines Menschenm\u00e4dchens, Nina, mitreissen, die es wagen, verliebt zu sein. Ihre Verbindung steht unter einem schlechten Stern, stellt aber vielleicht den letzten Hoffnungsschimmer dar.\n\nPremiere beim Sundance Film Festival (2019), Gewinner \u2018Best VR experience\u2019 - Internationales Animations-Filmfestival in Annecy (2019) & \u2018Jury Award for Storytelling\u2019 - SXSW (2019).\n", "short_description": "\u201cGloomy Eyes\u201d ist eine animierte Trilogie, erz\u00e4hlt von Max Riemelt. In einer namenlosen Stadt herrscht ewige Finsternis, welche die Toten aus ihren Gr\u00e4bern steigen lie\u00df. Menschen und Zombies liefern sich seither einen unerbittlichen Kampf. \n\nGewinner \u2018Best VR experience\u2019 - Internationales Animations-Filmfestival in Annecy (2019) & \u2018Jury Award for Storytelling\u2019 - SXSW (2019).\n"}, {"images": {"nodes": [{"file_name": "GE_LANDSCAPE_KO_oculus.png", "id": "4130664100355758", "image_typ