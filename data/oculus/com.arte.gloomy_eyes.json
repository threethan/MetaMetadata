Z8Q7kNvgHtbEaH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbMSrFXZHS6OX9a6c00QQG4pP5H1yPyoxFIBOWZIkooQ&oe=673B1459"}, {"file_name": "lheqoC.png", "id": "711263236315061", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003262_711263242981727_4896656935308230656_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ciLN88X9ZzYQ7kNvgFuy3Sc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJZiHulZ77XGbnyMoBgZBdrUytpFWPbvPfD4ATpKTHkw&oe=673B18A5"}, {"file_name": "iXZFrD.png", "id": "570130953693969", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974517_570130957027302_6527753749027356672_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZdQU2OeUujkQ7kNvgHOfgdv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAX4L759z1KntwqFjizYRA0czBYYDtkdTmu3kG1MT7B9Q&oe=673B1B42"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974699_2399292623697835_7048842026309124096_n.png", "id": "586844405600865", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035339_586844408934198_3592402535871053229_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mbm3o9mwKpkQ7kNvgEmRhl8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrrucrmW26pAe2k1wToVj4vrwGVMvRPpy8KypNikkOgA&oe=673B357D"}, "display_name": "Gloomy Eyes", "keywords": ["Tiny", "Zombie", "Movie", "Narrative", "Animation"], "long_description": "When the sun got tired of humans and decided to hide and never rise again, darkness awoke the dead from their graves. Since then, the clash between man and zombie sets the pace of daily life.\n \nNarrated by Colin Farrell, \u201cGloomy Eyes\u201d is an animated trilogy and emotional tale where fantastical animated dioramas twist and rotate around you. \n\nChase the nostalgic and heartwarming story of a zombie boy, Gloomy, and a human girl, Nena, that dare to play with love. Their star-crossed love might just be the last seed of hope.\n\nPremiered at Sundance Film Festival (2019), was awarded \u2018Best VR experience\u2019 at the Annecy International Animation Film Festival (2019) and winner of the \u2018Jury Award for Storytelling\u2019 SXSW (2019).", "short_description": "Narrated by Colin Farrell, \u201cGloomy Eyes\u201d is an animated trilogy set in a town flooded by darkness. Awakened, the dead left their graves and the clash between man and zombie sets the pace of daily life.\n\nLet the fantastical dioramas whirl you deep into the story of a zombie boy, Gloomy, and a human girl, Nena, that dare to play with love.\n\n\u201cGloomy Eyes\u201d won \u2018Best VR experience\u2019 at the Annecy International Animation Film Festival (2019) & winner of the \u2018Jury Award for Storytelling\u2019 SXSW (2019)."}, {"images": {"nodes": []}, "id": "212697933444304", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gloomy Eyes", "keywords": ["Tiny", "Zombie", "Movies", "Narrative", "Animation"], "long_description": "Un jour, le soleil s'est lass\u00e9 des humains, d\u00e9cid\u00e9 de dispara\u00eetre pour ne plus jamais se lever. Les t\u00e9n\u00e8bres ont r\u00e9veill\u00e9 les morts. Zombies et humains se livrent un combat acharn\u00e9.\nAvec la voix de Tahar Rahim et \u00e0 travers de fantastiques dioramas anim\u00e9s qui tournent autour de vous, la trilogie \u201cGloomy Eyes\u201d livre une fable poignante.\nLaissez-vous entra\u00eener dans l\u2019histoire nostalgique et \u00e9mouvante d\u2019un gar\u00e7on zombie, Gloomy, et d\u2019une fille mortelle, Nena, qui osent jouer avec l\u2019amour. Leurs sentiments l\u2019un pour l\u2019autre se pr\u00e9sentent sous de mauvais auspices, mais pourraient repr\u00e9senter la derni\u00e8re lueur d\u2019espoir.\nApr\u00e8s une premi\u00e8re au Sundance Film Festival (2019), \u201cGloomy Eyes\u201d a remport\u00e9 le \u2018Cristal de la meilleure \u0153uvre VR\u2019 au Festival international du film d\u2019animation d\u2019Annecy (2019) et le \u2018Prix du Jury Narration\u2019 - SXSW (2019)", "short_description": "Avec la voix de Tahar Rahim, la trilogie anim\u00e9e \u201cGloomy Eyes\u201d nous pr\u00e9cipite dans le quotidien d\u2019une ville plong\u00e9e dans l\u2019obscurit\u00e9 permanente. Les t\u00e9n\u00e8bres ont r\u00e9veill\u00e9 les morts. Zombies et humains se livrent un combat acharn\u00e9.\n\nA travers de fantastiques dioramas, laissez-vous entra\u00eener dans cette histoire d\u2019un gar\u00e7on zombie, Gloomy, et d\u2019une fille mortelle, Nena, qui osent jouer avec l\u2019amour."}]}, "developer_name": "3DAR, Atlas V", "developer_privacy_policy_url": "https://www.arte.tv/sites/corporate/en/arte-and-your-personal-data/", "developer_terms_of_service_url": null, "publisher_name": "ARTE France", "support_website_url": null, "website_url": "https://www.arte.tv/sites/webproductions/gloomy-eyes/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "zh_TW", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "401720634764687"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974452_936140623489222_5127119442982993920_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=llByDSyuUHoQ7kNvgETAgSO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-ll7lCGzmuT3lwIIJHTGopJcyJ2NQJVTlduFSaqSkEg&oe=673B41D1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gloomy Eyes", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Narrative", "id": "1008279844328894"}], "release_date": 1590685164, "lastRevision": {"nodes": [{"id": "2902833783100132", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2933720383334150", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "624852721414051"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "2686507154920039", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gloomy Eyes", "keywords": ["gloomy", "eyes", "narrative", "love", "farrell"], "long_description": "Mit der Stimme von Max Riemelt erz\u00e4hlt Gloomy Eyes die Geschichte der Sonne, die der Menschen \u00fcberdr\u00fcssig wird und beschlie\u00dft, nie wieder aufzugehen.\n\nDie Finsternis erweckt die Toten zum Leben und l\u00e4sst sie aus ihren Gr\u00e4bern steigen. Der Zombiejunge Gloomy und das Menschenm\u00e4dchen Nena verlieben sich ineinander und f\u00fchlen sich so stark zueinander hingezogen, dass selbst der m\u00e4chtigste Mann der Stadt sie nicht zu trennen vermag.\n \n\u201eGloomy Eyes\u201c ist eine VR-Animationsserie in 6DoF und Echtzeit-3D-Technologie.\n\nErz\u00e4hler: Max Riemelt (Deutsch), Colin Farrell (Englisch), Tahar Rahim (Franz\u00f6sisch), Jorge Drexler (Spanisch), Jam Hsiao (Chinesisch)", "short_description": "Mit der Stimme von Max Riemelt erz\u00e4hlt Gloomy Eyes die Geschichte der Sonne, die der Menschen \u00fcberdr\u00fcssig wird und beschlie\u00dft, nie wieder aufzugehen."}, {"images": {"nodes": []}, "id": "536157073959899", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gloomy Eyes", "keywords": ["gloomy", "eyes", "narrative", "love", "farrell"], "long_description": "Cuando el sol se cans\u00f3 de los humanos, decidi\u00f3 esconderse y no volver a salir nunca m\u00e1s. La oscuridad despert\u00f3 a los muertos de sus tumbas. Un ni\u00f1o zombie llamado Gloomy y una ni\u00f1a mortal llamada Nena se enamoran y se sumergen en una conexi\u00f3n profunda que ni siquiera el hombre m\u00e1s poderoso de la ciudad puede destruir.\n\nGloomy Eyes es una serie de animaci\u00f3n en realidad virtual en 6DoF y 3D en tiempo real que se lanza en 3 episodios.\n\nNarrado por Jorge Drexler (Espa\u00f1ol), Colin Farrell (Ingl\u00e9s), Tahar Rahim (Franc\u00e9s), Max Riemelt (Alem\u00e1n) y Jam Hsiao (Mandar\u00edn).", "short_description": "Cuando el sol se cans\u00f3 de los humanos, decidi\u00f3 esconderse y no volver a salir nunca m\u00e1s. La oscuridad despert\u00f3 a los muertos de sus tumbas. Un ni\u00f1o zombie llamado Gloomy y una ni\u00f1a mortal llamada Nena se enamoran y se sumergen en una conexi\u00f3n profunda que ni siquiera el hombre m\u00e1s poderoso de la ciudad puede destruir."}, {"images": {"nodes": []}, "id": "531083597583809", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gloomy Eyes", "keywords": ["Gloomy", "eyes", "narrative", "love", "farrell"], "long_description": "Avec la voix de Tahar Rahim, Gloomy Eyes raconte l'histoire du soleil qui s'est lass\u00e9 des humains et qui a d\u00e9cid\u00e9 de dispara\u00eetre pour ne plus jamais se lever.\n\nLes t\u00e9n\u00e8bres ont fait sortir les morts de leurs tombes. Un enfant zombie appel\u00e9 Gloomy et une fille mortelle appel\u00e9e Nena tombent amoureux et vivent une connexion profonde que m\u00eame l'homme le plus puissant de la ville ne peut d\u00e9truire.\n \nGloomy Eyes est une s\u00e9rie VR anim\u00e9e en 6DoF & 3D temps r\u00e9el.\u2028\n\nNarrateurs : Tahar Rahim (fran\u00e7ais), Colin Farrell (anglais), Max Riemelt (allemand), Jorge Drexler (espagnol), Jam Hsiao (mandarin).", "short_description": "Avec la voix de Tahar Rahim, Gloomy Eyes raconte l'histoire du soleil qui s'est lass\u00e9 des humains et qui a d\u00e9cid\u00e9 de dispara\u00eetre pour ne plus jamais se lever."}, {"images": {"nodes": []}, "id": "255388645700589", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gloomy Eyes", "keywords": ["gloomy", "eyes", "narrative", "love", "farrell"], "long_description": "\u6545\u4e8b\u8b1b\u8ff0\u4e00\u500b\u7e3d\u662f\u548c\u7fa4\u9ad4\u683c\u683c\u4e0d\u5165\u7684\u5c0f\u7537\u5b69Gloomy\uff0c\u56e0\u70ba\u5077\u4e86\u6751\u9577\u7684\u6771\u897f\uff0c\u4e0d\u5f97\u4e0d\u9003\u5165\u68ee\u6797\u8eb2\u907f\u8cde\u91d1\u7375\u4eba\uff0c\u5728\u904e\u7a0b\u4e2d\u8207\u5c0f\u5973\u5b69Nena\u610f\u5916\u5c55\u958b\u4e00\u6bb5\u7d14\u7d14\u7684\u611b\u3002\n\n\u5495\u5695\u7c73\u7684\u773c\u775b\u662f\u4e00\u90e8\u80fd\u57286Dof\u53ca3D\u5373\u6642\u904b\u7b97\u7684VR\u52d5\u756b\u96fb\u5f71\n\n\u7531\u856d\u656c\u9a30\uff08\u4e2d\u6587\uff09\uff0c\u67ef\u6797\u6cd5\u6d1b\uff08\u82f1\u6587\uff09\uff0c\u5854\u54c8\u00b7\u62c9\u8f9b \uff08\u6cd5\u6587\uff09\u4ee5\u53ca\u99ac\u514b\u65af\u30fb\u745e\u9ea5\u723e\u7279\uff08\u5fb7\u6587\uff09", "short_description": "\u6545\u4e8b\u8b1b\u8ff0\u4e00\u500b\u7e3d\u662f\u548c\u7fa4\u9ad4\u683c\u683c\u4e0d\u5165\u7684\u5c0f\u7537\u5b69Gloomy\uff0c\u56e0\u70ba\u5077\u4e86\u6751\u9577\u7684\u6771\u897f\uff0c\u4e0d\u5f97\u4e0d\u9003\u5165\u68ee\u6797\u8eb2\u907f\u8cde\u91d1\u7375\u4eba\uff0c\u5728\u904e\u7a0b\u4e2d\u8207\u5c0f\u5973\u5b69Nena\u610f\u5916\u5c55\u958b\u4e00\u6bb5\u7d14\u7d14\u7684\u611b\u3002\n\n\u5495\u5695\u7c73\u7684\u773c\u775b\u662f\u4e00\u90e8\u80fd\u57286Dof\u53ca3D\u5373\u6642\u904b\u7b97\u7684VR\u52d5\u756b\u96fb\u5f71\n\n\u7531\u856d\u656c\u9a30\uff08\u4e2d\u6587\uff09\uff0c\u67ef\u6797\u6cd5\u6d1b\uff08\u82f1\u6587\uff09\uff0c\u5854\u