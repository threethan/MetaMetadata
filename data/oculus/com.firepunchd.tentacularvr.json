://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982685_1100593427457516_3388311448974567745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z-fE2XGV6VkQ7kNvgGXJXJB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBSE2k4RAV7BU_W581N1H1aGSKbRXVSbuTZ1VYKc0NeDg&oe=67348768"}, {"file_name": "Tentacular 3.png", "id": "386287840001907", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75230043_386287843335240_714438047075509512_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sM4CU_VKycIQ7kNvgFQOohh&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBgaJ-Zk2HI6aejABwwhkYAJrZ7nUU39nWPRKomTRQtkw&oe=67347B00"}, {"file_name": "Tentacular 10.png", "id": "1087659158633253", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86610704_1087659161966586_9204004686126630774_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AmmzTHU2Z8IQ7kNvgGjPLdv&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYApQHhB0ifAlIR0w8wlUysNzEjpw6rr5YCTGi3qGjLCmQ&oe=673496F2"}, {"file_name": "Tentacular 5.png", "id": "290149593247721", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75207238_290149599914387_4292785376516298710_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iI9pK-6WaD8Q7kNvgFztzc2&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAcFWG9S2oHasCfWhltVv_srS9JDGc8dSGMtGkCCBPTQQ&oe=67349469"}, {"file_name": "Tentacular 1.png", "id": "757174648594798", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572957_757174651928131_7414525875582666581_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZCkwoDFCg8cQ7kNvgE3I9W9&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBGg5a1ZhD07c1c1ZnsuJeHJULZfTcwwMHhcTdm4UAGsQ&oe=67347449"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage.png", "id": "392491582252880", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75334060_392491585586213_7902340650376875221_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5aERGHQqO_AQ7kNvgHG9g3U&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAaqWzT0pseDgXt9aOu7UKYVdgL0hWLi9oP_tCBOXDl7g&oe=6734A77F"}, "display_name": "Tentacular", "keywords": ["Octopus", "Monster", "Puzzle", "Tentacle", "Construction"], "long_description": "Ever felt like a squid out of water? Tentacular plunges you into the ocean-dwelling hulk of a gigantic, kind-hearted tentacled beast trying to figure out its place in the world.\n\nRaised among humans on the bustling and eccentric island of La Kalma, the time has finally come to unravel the secrets of your mysterious origin while working as the world\u2019s strongest handyman. Help your human friends to research a strange and an incredibly powerful energy source through a colossal collection of action-based activities and constructions puzzles, using your titanic tentacles to aid your quest for answers and unlock elements for your playground.\n\nGet your suckers ready!\n\nTactile Tentacles!\nGet a grip on things with fully physics-based tentacles complete with Octo-grade suckers\n\nTitanic Tasks!\nApply lateral thinking and giant limbs to 50+ puzzle and action levels, building huge structures and contraptions\n\nColossal Constructions!\nCultivate your creative side in a constantly expanding Sandbox", "short_description": "Tentacular is a VR game about a gigantic but good-hearted tentacled beast trying to figure out its place in the world."}]}, "developer_name": "Firepunchd Games", "developer_privacy_policy_url": "https://legal.devolverdigital.com/privacy", "developer_terms_of_service_url": "https://legal.devolverdigital.com/terms", "publisher_name": "Devolver Digital", "support_website_url": "https://www.devolverdigital.com/", "website_url": "http://tentacular.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "458592492406387"}}]}, "scheduled_offers": {"count": 28, "nodes": [{"status": "PUBLISHED", "id": "497122259731758"}, {"status": "PUBLISHED", "id": "1509588999646383"}, {"status": "PUBLISHED", "id": "1867539710335720"}, {"status": "PUBLISHED", "id": "503836178303115"}, {"status": "PENDING", "id": "1547378599089553"}, {"status": "PUBLISHED", "id": "230564356569271"}, {"status": "PENDING", "id": "1645449535929842"}, {"status": "PENDING", "id": "1049488809770459"}, {"status": "PENDING", "id": "605192231514913"}, {"status": "PUBLISHED", "id": "200278372814559"}, {"status": "PUBLISHED", "id": "316138407638255"}, {"status": "PENDING", "id": "1315957869053520"}, {"status": "PENDING", "id": "745886103689030"}, {"status": "PUBLISHED", "id": "433951321571945"}, {"status": "PUBLISHED", "id": "884323250111705"}, {"status": "PUBLISHED", "id": "1473915079746130"}, {"status": "PUBLISHED", "id": "1561479624356778"}, {"status": "PENDING", "id": "1548997375624047"}, {"status": "PUBLISHED", "id": "537718901847790"}, {"status": "PUBLISHED", "id": "1065062624704990"}, {"status": "PUBLISHED", "id": "548072737179881"}, {"status": "PUBLISHED", "id": "984621032855406"}, {"status": "PENDING", "id": "2348589898679114"}, {"status": "PUBLISHED", "id": "378353770883463"}, {"status": "PUBLISHED", "id": "458086853004574"}, {"status": "PENDING", "id": "580739097444796"}, {"status": "PENDING", "id": "911315140564089"}, {"status": "PENDING", "id": "3039086689727469"}]}, "baseline_offer": {"id": "378353770883463"}, "is_approved": true, "firstOffer": {"nodes": [{"start_tim