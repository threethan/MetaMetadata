ttps://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_1100593427457516_3388311448974567745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uGWq20P64bsQ7kNvgG2IFg4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDG98xDzMm3ohAp8tJAmrG2CrOGqEIr-bgaVZpDfodDAQ&oe=6767F1E8"}, {"file_name": "Tentacular 3.png", "id": "386287840001907", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75230043_386287843335240_714438047075509512_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5mHbV-RpS7IQ7kNvgE135Da&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqjPZN63bIO_oRlRe9Ayqe12powGHWTxaySF7oG3NxFw&oe=6767E580"}, {"file_name": "Tentacular 10.png", "id": "1087659158633253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86610704_1087659161966586_9204004686126630774_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UxiFGpT940cQ7kNvgE3y4VK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6wut0vRoWOXdsC3tlMvNknA-l2IDYXEdwG2Ry4cDXwg&oe=67680172"}, {"file_name": "Tentacular 5.png", "id": "290149593247721", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207238_290149599914387_4292785376516298710_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QzN_cDEfxO0Q7kNvgEoREOx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlMAuFTHWSscTZvcQPotQYznhjEksaB2mbU2mcWKyCNg&oe=6767FEE9"}, {"file_name": "Tentacular 1.png", "id": "757174648594798", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572957_757174651928131_7414525875582666581_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AopoeVDr90wQ7kNvgGA-Vpc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAC_JfphgO4XXPN9Z46PembNHYiqw2e3Olg8UjWAdsY9A&oe=67681709"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage.png", "id": "392491582252880", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334060_392491585586213_7902340650376875221_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yUqvKIk4mrAQ7kNvgFgFipS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-vQs0OpSQ_roJcv6ke0I_9UzkwCL55WJ_XbCd8O6-BQ&oe=676811FF"}, "display_name": "Tentacular", "keywords": ["Octopus", "Monster", "Puzzle", "Tentacle", "Construction"], "long_description": "Ever felt like a squid out of water? Tentacular plunges you into the ocean-dwelling hulk of a gigantic, kind-hearted tentacled beast trying to figure out its place in the world.\n\nRaised among humans on the bustling and eccentric island of La Kalma, the time has finally come to unravel the secrets of your mysterious origin while working as the world\u2019s strongest handyman. Help your human friends to research a strange and an incredibly powerful energy source through a colossal collection of action-based activities and constructions puzzles, using your titanic tentacles to aid your quest for answers and unlock elements for your playground.\n\nGet your suckers ready!\n\nTactile Tentacles!\nGet a grip on things with fully physics-based tentacles complete with Octo-grade suckers\n\nTitanic Tasks!\nApply lateral thinking and giant limbs to 50+ puzzle and action levels, building huge structures and contraptions\n\nColossal Constructions!\nCultivate your creative side in a constantly expanding Sandbox", "short_description": "Tentacular is a VR game about a gigantic but good-hearted tentacled beast trying to figure out its place in the world."}]}, "developer_name": "Firepunchd Games", "developer_privacy_policy_url": "https://legal.devolverdigital.com/privacy", "developer_terms_of_service_url": "https://legal.devolverdigital.com/terms", "publisher_name": "Devolver Digital", "support_website_url": "https://www.devolverdigital.com/", "website_url": "http://tentacular.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["