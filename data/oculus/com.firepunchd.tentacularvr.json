ll002.png", "id": "1100593424124183", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982685_1100593427457516_3388311448974567745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1R-4ip-UzX8Q7kNvgHtouyX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEfSyt537th1M2jDtS6hFZzmFDcvoiA7gEVQBu1zZITA&oe=671391E8"}, {"file_name": "Tentacular 3.png", "id": "386287840001907", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75230043_386287843335240_714438047075509512_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Usq5qJ_Vh-8Q7kNvgGL4GXy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqOEeZysb3RFrRPBV5GbiDduKgamddweqrKjXDiuDhAA&oe=67138580"}, {"file_name": "Tentacular 10.png", "id": "1087659158633253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86610704_1087659161966586_9204004686126630774_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JtP4azjH7q0Q7kNvgHzWl_T&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxSaeu7d-5ksT4v2Q4AYcLGLvrQf0m7MW_ajDufyIobg&oe=6713A172"}, {"file_name": "Tentacular 5.png", "id": "290149593247721", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207238_290149599914387_4292785376516298710_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mUIEYcMc-0kQ7kNvgEptLt3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCO4MYl2fdrCDniB9xv__fsuOYaWqR0ci5jMZUn4rnA1w&oe=67139EE9"}, {"file_name": "Tentacular 1.png", "id": "757174648594798", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572957_757174651928131_7414525875582666581_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qnGp2xvz8zgQ7kNvgFpkJu9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOV8JzSq6dZcAYNQ0i6CYWVUudRuQH2HqCuo2JidBdcQ&oe=6713B709"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage.png", "id": "392491582252880", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334060_392491585586213_7902340650376875221_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uwOq3aojwycQ7kNvgFGnZ7v&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2fLB80BzHmj-P8jXejY9yfpE3ARTJ74LcvisDLm3GUA&oe=6713B1FF"}, "display_name": "Tentacular", "keywords": ["Octopus", "Monster", "Puzzle", "Tentacle", "Construction"], "long_description": "Ever felt like a squid out of water? Tentacular plunges you into the ocean-dwelling hulk of a gigantic, kind-hearted tentacled beast trying to figure out its place in the world.\n\nRaised among humans on the bustling and eccentric island of La Kalma, the time has finally come to unravel the secrets of your mysterious origin while working as the world\u2019s strongest handyman. Help your human friends to research a strange and an incredibly powerful energy source through a colossal collection of action-based activities and constructions puzzles, using your titanic tentacles to aid your quest for answers and unlock elements for your playground.\n\nGet your suckers ready!\n\nTactile Tentacles!\nGet a grip on things with fully physics-based tentacles complete with Octo-grade suckers\n\nTitanic Tasks!\nApply lateral thinking and giant limbs to 50+ puzzle and action levels, building huge structures and contraptions\n\nColossal Constructions!\nCultivate your creative side in a constantly expanding Sandbox", "short_description": "Tentacular is a VR game about a gigantic but good-hearted tentacled beast trying to figure out its place in the world."}]}, "developer_name": "Firepunchd Games", "developer_privacy_policy_url": "https://legal.devolverdigital.com/privacy", "developer_terms_of_service_url": "https://legal.devolverdigital.com/terms", "publisher_name": "Devolver Digital", "support_website_url": "https://www.devolverdigital.com/", "website_url": "http://tentacular.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "3948