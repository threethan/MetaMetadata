0231_9140222972767105016_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MkoHuHjqc8EQ7kNvgEL_xEl&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1iaaQoU6-658rPSSV88NyX&oh=00_AYDHdD397BJ3CZ8BTtNjmWoULu-HpUwvbSaXZLTUZ6mlfg&oe=66CAFFF6"}, "display_name": "Alvo", "keywords": ["shooter", "fps", "multiplayer", "zombies", "action"], "long_description": "*Now crossplay with all major VR Headsets\n\n Faster-paced gameplay provides an experience like no other, in this accessible, VR Shooter.\n\nGain the edge on the battlefield by running, jumping, sliding, crawling and more to find the lethal shot.\n\nFeatures-\nManual and automatic reload\nPlay standing or seated\nPerk System\nKillstreaks\nProgression\nVariety of guns, melee equipment and grenades\nLeaderboard\nGame Modes- Free for All, Team Death Match/TDM Hardpoint, Search and Destroy, 4 Player Coop Zombies", "short_description": "*Now crossplay with all major VR Headsets\n\n Faster-paced gameplay provides an experience like no other, in this accessible, VR Shooter.\n\nGain the edge on the battlefield by running, jumping, sliding, crawling and more to find the lethal shot.\n\nFeatures-\nManual and automatic reload\nPlay standing or seated\nPerk System\nKillstreaks\nProgression\nVariety of guns, melee equipment and grenades\nLeaderboard\nGame Modes- Free for All, Team Death Match/TDM Hardpoint, Search and Destroy, 4 Player Coop Zombies"}]}, "developer_name": "OutsideIn Entertainment", "developer_privacy_policy_url": "https://alvogame.com/privacy-policy/", "developer_terms_of_service_url": "https://alvogame.com/terms-of-service/", "publisher_name": "OutsideIn Entertainment", "support_website_url": null, "website_url": "https://alvogame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "ACTION", "HORROR"]