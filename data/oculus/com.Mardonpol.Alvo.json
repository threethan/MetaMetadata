il": {"file_name": "trailer_art.png", "id": "664041291446516", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39035326_664041294779849_7712559248636671527_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E5shmjHQRysQ7kNvgFFdOeM&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYAWDbk99yHBcEKW_3Drd3p_72clZ96ZIR_aiLjJHy5bWQ&oe=6728C4B9"}, "display_name": "Alvo", "keywords": ["shooter", "online", "coop", "fps", "multiplayer"], "long_description": "Feel the heat of battle like never before! \n\nALVO is a fast-paced competitive online VR shooter. Experience a revolution in VR movement as you jump, run, prone and slide around the battlefield.\n\nChoose from a selection of killstreaks, perks and weapons to give you the tactical advantage. \n\nPush yourself up the leaderboard by completing daily or weekly challenges. Unlock more equipment as your rank up through the progression system.\n\nGame Modes:\nTraining Mode (AI only)\nFree For All\nTeam Deathmatch\nSearch & Destroy\nZombies (Coming Soon)\n", "short_description": "Feel the heat of battle like never before! \n\nALVO is a fast-paced competitive online VR shooter. Experience a revolution in VR movement as you jump, run, prone and slide around the battlefield.\n\nChoose from a selection of killstreaks, perks and weapons to give you the tactical advantage. \n\nPush yourself up the leaderboard by completing daily or weekly challenges. Unlock more equipment as your rank up through the progression system."}]}, "developer_name": "Mardonpol Inc", "developer_privacy_policy_url": "https://alvogame.com/privacy-policy/", "developer_terms_of_service_url": "https://alvogame.com/terms-of-service/", "publisher_name": "OutsideIn Entertainment", "support_website_url": null, "website_url": "https://alvogame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "