gnal Simulator dynamically changes results according to the treatment.\nIP_T accommodates up to 10 healthcare professionals online, making it ideal for leader education and team training in medical and nursing schools, as well as hospitals.", "short_description": "IP_T is a severe trauma patient management simulator developed based on ATLS and ABCDE Primary Survey protocols."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrad.one/bbs/board.php?bo_table=Resources&wr_id=12", "developer_terms_of_service_url": "https://vrad.one/bbs/board.php?bo_table=Resources&wr_id=11", "publisher_name": "VRAD", "support_website_url": null, "website_url": "https://vrad.one/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8176441185707613"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "356348760169844"}]}, "baseline_offer": {"id": "356348760169844"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718379360, "status": "PUBLISHED", "id": "356348760169844"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8661715270513533", "version": "1.0.0.5"}, "id": "342424495054874", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "A