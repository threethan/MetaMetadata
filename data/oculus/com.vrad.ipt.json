s://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974902_442593838249941_3103796369012299537_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vkCmUImi4b8Q7kNvgFf_k1j&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDvLvbXfvDh1ttFpVQljQ2WxbTnp5G-mXshaXyWEIrOiA&oe=670F93AC"}, {"file_name": "011.IP_T_Screenshot_03.png", "id": "743045394684851", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031313_743045398018184_1218810291694551795_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P6_raoWwaj8Q7kNvgGfvsbn&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCgGYGisF-ypFlg5YUTjvRka9obavG7K2AM6_oT1cPXXg&oe=670F894E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "003.IP_T_coverImag.png", "id": "408852298449958", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003266_408852301783291_3866988320546917830_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZ4BUj5TcjYQ7kNvgE1WXBz&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCqUXEqv489jhRFleDbILWRZH-CTXnO3clIGwiXBYZjLQ&oe=670FA2C5"}, "display_name": "IP-T", "keywords": [], "long_description": "Note: You can experience full content if you register as an institution.\n\nIP_Trauma is an Interprofessional training simulator that allows multiple healthcare professionals to learn severe trauma management techniques in a collaborative, multi-player environment.\nIP_Trauma offers over 50 treatments from the ABCDE Primary Survey, including ultrasound, X-ray, CT scans, and blood tests. Built-in manually adjustable Bio Signal Simulator dynamically changes results according to the treatment.\nIP_T accommodates up to 10 healthcare professionals online, making it ideal for leader education and team training in medical and nursing schools, as well as hospitals.", "short_description": "IP_T is a severe trauma patient management simulator developed based on ATLS and ABCDE Primary Survey protocols."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrad.one/bbs/board.php?bo_table=Resources&wr