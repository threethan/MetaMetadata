ts": [{"file_name": "009.IP_T_Screenshot_01.png", "id": "423833396951310", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566679_423833400284643_1212261317333319647_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9OM1Gf_qmqQQ7kNvgGIBglU&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az-9f42WGJv4qQ4QqPBg61N&oh=00_AYDXwlzZ_l-fNWYjLHMHJhnA2fp1fz_6u_94wP9fGtFLDg&oe=66F40234"}, {"file_name": "013.IP_T_Screenshot_05.png", "id": "942386967524677", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982503_942386970858010_5963288187753388721_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7a8BjFaHJjgQ7kNvgFGMsP8&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az-9f42WGJv4qQ4QqPBg61N&oh=00_AYB2tWdtuidF1vaIb0aWig3lrKUQTXYGZ5BuJbjVKlJ6Gw&oe=66F3E1E7"}, {"file_name": "010.IP_T_Screenshot_02.png", "id": "1828110134367572", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221326_1828110137700905_7619748166346537231_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nut8Ey2wXPIQ7kNvgHbRcQI&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az-9f42WGJv4qQ4QqPBg61N&oh=00_AYCxQ--9MCNF5_awh4_rTwyPqaAuI-t2Vxr8I8kXiSuQBg&oe=66F3EB89"}, {"file_name": "012.IP_T_Screenshot_04.png", "id": "7402612183155134", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031365_7402612193155133_6479641410943761449_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XrrbHxCA_soQ7kNvgHaN1Ba&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az-9f42WGJv4qQ4QqPBg61N&oh=00_AYC4smjnYdccPXPpiH7EuBGvQ3ojYkAVEcZUZtsJyFOJoA&oe=66F40117"}, {"file_name": "011.IP_T_Screenshot_03.png", "id": "2581322905362466", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982500_2581322908695799_1091018286263535443_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WUaCwe8eaqQQ7kNvgE3bKi_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az-9f42WGJv4qQ4QqPBg61N&oh=00_AYC0gf8H2AhKOI-aOCbvA8zZZ0DE0_f1V66I7_AkzlmUdg&oe=66F3F8F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "003.IP_T_coverImag.png", "id": "26225291713736987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240108_26225291720403653_1043916596752636418_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OKOdmKcdGdQQ7kNvgFmZOS5&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az-9f42WGJv4qQ4QqPBg61N&oh=00_AYD9FnrNgL1JKm_DNzCV6EX65oblisxgqCU_3J-Lbe9bZQ&oe=66F3FDED"}, "display_name": "IP-T", "keywords": [], "long_description": "\uc911\uc694 : \uae30\uad00 \ub4f1\ub85d\uc744 \ud558\uc2dc\uba74 \ubaa8\ub4e0 \ucf58\ud150\uce20\ub97c \uc0ac\uc6a9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\nIP_Trauma : [\uc544\uc774\ud53c_\ud2b8\ub77c\uc6b0\ub9c8]\ub294 \uc911\uc99d\uc678\uc0c1\ud658\uc790 \ucc98\uce58 \ubc29\ubc95\uc744 \ub2e4\uc911\uc0ac\uc6a9\uc790 \ud658\uacbd\uc5d0\uc11c \uc5ec\ub7ec \uc758\ub8cc\uc9c4\uc774 \ud568\uaed8 \ud559\uc2b5\ud560 \uc218 \uc788\ub294 \ub2e4\uc9c1\uc885 \uc5f0\uacc4\uad50\uc721 \uc2dc\ubbac\ub808\uc774\ud130\uc785\ub2c8\ub2e4.\nIP_T\ub294 \uc138\uacc4\uc801\uc73c\ub85c \ub110\ub9ac \uc54c\ub824\uc9c4 ATLS\uc758 \ub0b4\uc6a9\uacfc ABCDE Primary Survey \ub0b4\uc6a9\uc744 \uae30\ucd08\ub85c \ud558\uc600\uc2b5\ub2c8\ub2e4.\nIP_T\ub294 \ucc98\uce58\uc5d0 \ub530\ub77c \ub2a5\ub3d9\uc801\uc73c\ub85c \ubcc0\ud654\ud558\uac70\ub098, \ud2b9\uc815 \uc0c1\ud669\uc744 \ubd80\uc5ec\ud560 \uc218 \uc788\ub3c4\ub85d \uc218\ub3d9\uc73c\ub85c \uc870\uc808 \uac00\ub2a5\ud55c Bio Signal \uc2dc\ubbac\ub808\uc774\ud130\ub97c \ubc14\ud0d5\uc73c\ub85c\nABCDE Primary Survey\uc5d0 \ud3ec\ud568\ub418\ub294 50\uc5ec \uac00\uc9c0 \ucc98\uce58\uc640 \ucd08\uc74c\ud30c, X-Ray, CT, \ud608\uc561\uac80\uc0ac \ub4f1 \ub2e4\uc591\ud55c \uac80\uc0ac \uacb0\uacfc\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\ucd5c\ub300 10\uba85\uc758 \uc758\uc0ac, \uac04\ud638\uc0ac\uac00 \uc628\ub77c\uc778\uc73c\ub85c \uc811\uc18d\ud558\ub294 VR \uc2dc\ubbac\ub808\uc774\ud130\ub85c \ub2a5\ub3d9\uc801\uc778 \ud310\ub2e8\uc744 \ud1b5\ud55c \ub9ac\ub354\uad50\uc721\uacfc \ud300 \ud6c8\ub828\uc5d0 \uc0ac\uc6a9\ub420 \uc218 \uc788\uc5b4 \uc758\uacfc\ub300\ud559\uacfc \uac04\ud638\ub300\u