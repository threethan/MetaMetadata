tps://scontent.oculuscdn.com/v/t64.5771-25/39031313_743045398018184_1218810291694551795_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YYjlQrWilYsQ7kNvgFnp0R2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDF3X2f2jC6f53E6NmHGva5u_i9Wucb_mfEZWE5ydW12g&oe=66F2884E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "003.IP_T_coverImag.png", "id": "408852298449958", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003266_408852301783291_3866988320546917830_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=INydi8CqEtEQ7kNvgFFsqjt&_nc_ht=scontent.oculuscdn.com&oh=00_AYCd7PDQ74y1DdU4lwZwWpOfQr2E61DMgF3rSpywd0GMbQ&oe=66F2A1C5"}, "display_name": "IP-T", "keywords": [], "long_description": "Note: You can experience full content if you register as an institution.\n\nIP_Trauma is an Interprofessional training simulator that allows multiple healthcare professionals to learn severe trauma management techniques in a collaborative, multi-player environment.\nIP_Trauma offers over 50 treatments from the ABCDE Primary Survey, including ultrasound, X-ray, CT scans, and blood tests. Built-in manually adjustable Bio Signal Simulator dynamically changes results according to the treatment.\nIP_T accommodates up to 10 healthcare professionals online, making it ideal for leader education and team training in medical and nursing schools, as well as hospitals.", "short_description": "IP_T is a severe trauma patient management simulator developed based on ATLS and ABCDE Primary Survey protocols."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrad.one/bbs/board.php?bo_table=Resources&wr_id=12", "developer_terms_of_service_url": "https://vrad.one/bbs/board.php?bo_table=Resources&wr_id=11", "publisher_name": "VRAD", "support_website_url": null, "website_url": "https://vrad.one/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}]