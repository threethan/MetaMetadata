d=6e7a0a&_nc_ohc=MZHFSLufGc0Q7kNvgH1j1QP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfmomXi9laNmcV9vRwBXfBsRdXqP_Kh6kU4hiv-us6qA&oe=677A656D"}, {"file_name": "Painting_Drone.png", "id": "9311437182211773", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031514_9311437185545106_4507217590244176915_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QXawJNpMd68Q7kNvgEt2goq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApUaUUdi576FKngJwYwG6dckS4btfbXaRr3RuC_XLEeg&oe=677A7769"}, {"file_name": "Finished_Model_Mimic.png", "id": "926579145566818", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031396_926579148900151_4980902188419380458_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iJE7AbsX8PAQ7kNvgG14IcX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7rbBKad77nYe1-sQ4IkNiVPB_E8GuBCAk5tdwFC5tag&oe=677A5988"}, {"file_name": "Fantasy_Pack.png", "id": "1287548819265246", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982593_1287548822598579_8780483558394124917_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SGmyswaZhygQ7kNvgE394SZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCfq_3hEVVOdnTHSVlamMMhoiPtT9XguE1EQpC3oMC9Hg&oe=677A7F6A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Cover_Image_2560_X_1440.png", "id": "3796886113899694", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031396_3796886120566360_7833945356597784028_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6-mSOfWLO_EQ7kNvgFGKNZy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTY1lio5MvDNerKMkzGVgBNjqo7s-yFMkQLZPKTchUdg&oe=677A5F2E"}, "display_name": "Color-A-Cube", "keywords": ["voxel", "coloring", "relax", "chill", "painting"], "long_description": "**Dive** into a **relaxing**, **color-filled** escape with Color A Cube. This immersive coloring experience lets you bring voxel worlds to life, one cube at a time. Discover unique themes and models, with new content inspired by our community!\n\n{560028636645784}\n**Claim** your first pack **for free!** Download now and choose from:\n\n- Fantasy Pack\n- Animal Pack\n- Sci-Fi Pack\n\nEach of these packs has unique and fun models for you to paint!\n\n{1143127904042401}{8799122136832134}\n**Unwind** and **relax** as you paint vibrant voxel environments and characters. Enjoy the process, discover hidden details, and find calm in every voxelated corner.\n{426619937211884}{1080121970080651}\nWith the Meta Quest 3 lineup, you can choose to play in either Mixed Reality (MR) or Virtual Reality (VR). Paint your models your way\u2014whether you're sitting or standing, the experience is tailored to your comfort and creativity!\n{481204747741603}\n\nWe\u2019re dedicated to keeping the game fresh, exciting, and constantly improving shaped in part by your valuable feedback!\n\n- A steady stream of new content\n- Difficulty levels\n- New modes\n- Diorama's to showcase your creations\n- Extended shop\n- More to be revealed!\n\n# Why Early Access?\n\nWe\u2019re launching in early access to involve our community in shaping the game. Your feedback will help us refine features, add content, and create the best experience possible! Join our Discord server to share your ideas, report bugs, and participate in discussions.\n", "short_description": "Wishlist now to claim your free pack!\n\nDive into a relaxing, color-filled escape with Color A Cube. This immersive coloring experience lets you explore and bring voxel worlds to life, one cube at a time."}]}, "developer_name": "AlterEyes", "developer_privacy_policy_url": "https://bigshots-vr.com/ColorACube/privacy.html", "developer_terms_of_service_url": "https://bigshots-vr.com/ColorACube/tos.html", "publisher_name": "AlterEyes", "support_website_url": null, "website_url": "https://altereyes.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id"