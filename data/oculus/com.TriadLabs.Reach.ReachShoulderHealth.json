=dQMdVihAmfoQ7kNvgGn33kR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDegahTCiOhLzUpAy12mTPvSKM6nsgJJnPWseknFXHzYQ&oe=6783BFCD"}, {"file_name": "reach_firefly.png", "id": "755309839272338", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974686_755309842605671_7728528923536068710_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B2JhgNG1n5UQ7kNvgGP7cKB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAuEWfJDDqhmTUY3_ySOvD73MOfJprBAH3I3PG7DDzaRA&oe=6783A553"}, {"file_name": "reach_SGmenu.png", "id": "1244146662860070", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974454_1244146666193403_9053285987101141685_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MJDNXLDIh-EQ7kNvgHRuFnW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhy0DOlJty8_F8ckGllsutwGWv4rxhf8qPO2EzYr3sZg&oe=678396C0"}, {"file_name": "reach_tubetrouble.png", "id": "880303863224221", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974923_880303866557554_7548382632520109569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QfTLWArb9l8Q7kNvgG4jwJN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAzTgZqpMvFXyIbPIW_Dm9q9HC8R97NIw4lZGoHE42ofA&oe=6783A629"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ReachAppCoverArt.png", "id": "732182794964501", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569448_732182798297834_7468334677055046962_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JMDbViwvEZ0Q7kNvgGqDeAd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCeUyt8vjnleQOCkaFF7rotiTere7oVxDN62ROKZiT9RQ&oe=6783BB2D"}, "display_name": "Reach Shoulder Health", "keywords": [], "long_description": "Shoulder pain, stiffness, or weakness? You're not alone! One out of three people will develop shoulder strength or mobility issues in their lifetime. If you\u2019re one of them, you know how profoundly shoulder problems can impact your everyday activities. \n\nMovement exercises done regularly can increase a shoulder's range of motion and strength. Reach is on a mission to create VR experiences that identify your shoulder limitations and recruit movement specific to your strengths and weaknesses, all within immersive VR environments like a quiet, starry evening or a fast-paced galactic battle!\n\nReach\u2019s Beta release includes a Firefly Assessment experience and two games. Each of these experiences tracks your motion progress and provides useful analysis to you in a web-based portal. And, don't forget to check back soon-- more Reach VR experiences are in development!\n\nGive Reach a try, and play your way to better shoulder health-- virtually!", "short_description": "Welcome to Reach, the VR app designed to help you build shoulder strength and mobility! The Reach system includes range of motion assessments, VR games that are algorithmically tailored to your shoulder\u2019s range of motion, and the Reach Portal, where you can view your goals and progress reports. Whether you're catching fireflies in a quiet forest or protecting intergalactic space from an onslaught of invaders, Reach will encourage you on your journey!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://reach-vr.com/terms/", "developer_terms_of_service_url": null, "publisher_name": "Triad Labs", "support_website_url": "http://reach-vr.com/support/", "website_url": "http://reach-vr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "UTILITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3305173619754342"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "755446202553800"}]}, "baseline_offer": {"id": "755446202553800"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1677771180, "status": "PUBLISHED", "id": "755446202553800"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27482171104707411", "version": "1.00.154"}, "id": "439359598176608", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1736289657, "id": "28384505677807278", "version": "1.00.165", "version_code": 180, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732570094, "id": "27953822384208945", "version": "1.00.155", "version_code": 170, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBina