=PxBUBBp42xcQ7kNvgEfSiqi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDIo2M4d-487f4zjNySGxevpt1IR6DP6dQV2asL5HdKLg&oe=6723824D"}, {"file_name": "reach_firefly.png", "id": "755309839272338", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974686_755309842605671_7728528923536068710_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Txbjznglxd0Q7kNvgHuFNpi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAV85oWFS_D2jjGcNv27O06AyEcJEQ1wskPx2dE8nUoFg&oe=672367D3"}, {"file_name": "reach_SGmenu.png", "id": "1244146662860070", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974454_1244146666193403_9053285987101141685_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UG_5lQbkMKcQ7kNvgGrI_KB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBvv1Kc5aCMRwCLU4W5nt03yOaZzFg1FcPCqIcr59wNGQ&oe=67235940"}, {"file_name": "reach_tubetrouble.png", "id": "880303863224221", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974923_880303866557554_7548382632520109569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_I69JN8Ck-oQ7kNvgE70wKc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9pq6lepFVtlQ7Dc2M80RD_L-NpuH5EppOOBvMVwgdcA&oe=672368A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ReachAppCoverArt.png", "id": "732182794964501", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569448_732182798297834_7468334677055046962_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kff9R3j7E6kQ7kNvgGWTKTU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxFFQUsx7vXtqz2gQfCgE6BxBmHc7kkp-tDzUig-_BiQ&oe=67237DAD"}, "display_name": "Reach Shoulder Health", "keywords": [], "long_description": "Shoulder pain, stiffness, or weakness? You're not alone! One out of three people will develop shoulder strength or mobility issues in their lifetime. If you\u2019re one of them, you know how profoundly shoulder problems can impact your everyday activities. \n\nMovement exercises done regularly can increase a shoulder's range of motion and strength. Reach is on a mission to create VR experiences that identify your shoulder limitations and recruit movement specific to your strengths and weaknesses, all within immersive VR environments like a quiet, starry evening or a fast-paced galactic battle!\n\nReach\u2019s Beta release includes a Firefly Assessment experience and two games. Each of these experiences tracks your motion progress and provides useful analysis to you in a web-based portal. And, don't forget to check back soon-- more Reach VR experiences are in development!\n\nGive Reach a try, and play your way to better shoulder health-- virtually!", "short_description": "Welcome to Reach, the VR app designed to help you build shoulder strength and mobility! The Reach system includes range of motion assessments, VR games that are algorithmically tailored to your shoulder\u2019s range of motion, and the Reach Portal, where you can view your goals and progress reports. Whether you're catching fireflies in a quiet forest or protecting intergalactic space from an onslaught of invaders, Reach will encourage you on your journey!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://reach-vr.com/terms/", "developer_terms_of_service_url": null, "publisher_name": "Triad Labs", "support_website_url": "http://reach-vr.com/support/", "website_url": "http://reach-vr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3305173619754342"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "755446202553800"}]}, "baseline_offer": {"id": "755446202553800"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1677771180, "status": "PUBLISHED", "id": "755446202553800"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27482171104707411", "version": "1.00.154"}, "id": "439359598176608", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "439359598176608"}]}, "change_log": "Features:\n\n* Tube Trouble now features a level progression map. No more starting at level 1 every time you play! \n* 100 new Tube Trouble levels to unlock and explore. \n* 100 new Star Beams levels to unlock and explore.\n* Please note Level progression may be reset to accommodate new levels in some experiences\n* Now when you respond to our daily pain survey, our system will automatically adjust how much the games require you to move your shoulders, as well as the length of your recommended daily session. \n* We removed a limit on the number of simultaneous stars in Star Beams\n* We added clarifying audio for the seated mode to make it clear that the games CAN be played while seated.\n\n\n\n\n", "created_date": 1729096043, "id": "27482171104707411", "version": "1.00.154", "version_code": 169, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "439359598176608"}]}, "change_log": null, "created_date": 1729090450, "id": "27481477104776811", "version": "1.00.153", "version_code": 168, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "439359598176608"}]}, "change_log": null, "created_date": 1729041326, "id": "27474943555430166", "version": "1.00.152", "version_code": 167, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "439359598176608"}]}, "change_log": "* Level Progression Map: Star Beams now features a level progression map, allowing you to easily replay any previously completed level and track your progress through the game.\n* Organized Game Levels: Star Beams Levels are now neatly organized into groups, making it easier to navigate through your journey.\n* Enhanced Virtual Keyboard: The virtual keyboard has been updated to include all characters necessary for inputting an email address, ensuring smooth and accurate entry.\n* Persistent VR Link Code: The VR Link code is now always visible on the \u201cAbout\u201d tab of the main menu, providing quick access whenever needed.\n* Smoother New User Experience: New users no longer obligated to take shoulder health survey before entering the app.\n* Assessment Improvements: You\u2019ll encounter fewer unreachable targets during the Firefly Assessment\n* Performance Enhancements: Levels load much faster now!\n* Bug Fixes and Improvements: Various bug fixes have been implemented", "created_date": 1724945612, "id": "26769819045942624", "version": "1.00.143", "version_code": 158, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8275868042431005", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27482171104707411"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "439359598176608"}]}, "change_log": "New\n* Daily shoulder pain survey\n* Game use is now limited until SPADI survey is taken\n\nImprovements\n* Virtual keyboard now supports all special characters allowed in email addresses\n* VR link code persistent on about tab\n\nFixes\n* Stars celebration animation bug fix\n* Miscellaneous Star Beams minor bug fixes\n\n\n\n\n", "created_date": 1719434298, "id": "26111029295154939", "version": "1.00.130", "version_code": 145, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}