ile_name": "Frame 27.png", "id": "385600343427476", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984447_385600346760809_2522541645647684494_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ju1WFu6FVgsQ7kNvgF0ib0d&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbjLoq44xdcu3-qgy1CvHKKLtQJp9LvOANcg5j11RsmQ&oe=66D4699E"}, {"file_name": "Frame 31.png", "id": "1309691912772051", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031418_1309691916105384_5370953056812536091_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fkT42xbYXEsQ7kNvgGy_NcB&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjbjKls6m6USxujduOXe2bXTZ6ri2b__Ql1fy6WHgF2g&oe=66D45951"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "360336569386593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_360336572719926_1631164337076352504_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o4D9VzRQkIQQ7kNvgEti-Na&_nc_ht=scontent.oculuscdn.com&oh=00_AYAc7p2dkvkgG4NU_nhol2Ys_dhHshY95LXMphJ3INXxwA&oe=66D434E3"}, "display_name": "Nostraverse", "keywords": [], "long_description": "Welcome to Nostraverse.\n\nHere at Nostraverse, we offer companies a virtual presence in the Metaverse.\nOur goal is to make life better for everybody.\nWe are a Metaverse offering solutions for companies as well as for customers.\nIn our app, you can present your company to your clients in a whole new way and can interact with them easier than ever.\nAs a customer, you have the chance to stay in contact with your consultants, lawyers, etc. in a totally new and unprecedented way. Nostraverse allows you to meet up in person without even getting out of your home.\n\nStay Connected:\n- Rent your own space\n- Meet up with your colleagues\n- Create digital twins of real-life spaces\n\nBe Yourself:\n- Create your lifelike avatar in just a matter of seconds by uploading a selfie\n\nComing Soon:\n- Explore a variety of cultural experiences such as museums, art exhibitions, and more", "short_description": "Welcome to Nostraverse.\n\nHere at Nostraverse, we offer companies a virtual presence in the Metaverse.\n\nStay Connected:\n- Have your own space\n- Meet up with your colleagues\n- Create digital twins of real-life spaces\n\nBe Yourself:\n- Create your lifelike avatar in just a matter of seconds by uploading a selfie\n\nComing Soon:\n- Explore a variety of cultural experiences such as museums, art exhibitions, and more"}]}, "developer_name": null, "developer_privacy_policy_url": "https://nostraverse.com/flint/privacy", "developer_terms_of_service_url": "https://nostraverse.com/flint/legal", "publisher_name": "Nostraverse", "support_website_url": null, "website_url": "https://www.nostraverse.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "SIMULATION", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "1034458094099304"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "905254094201144"}]}, "baseline_offer": {"id": "905254094201144"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1659423600, "status": "PUBLISHED", "id": "905254094201144"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7634142296708913", "version": "0.9.28"}, "id": "758366455614730", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_applic