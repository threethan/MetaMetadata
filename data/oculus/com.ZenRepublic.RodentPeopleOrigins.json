.com/v/t64.5771-25/39031630_166494281681909_7116265393689918265_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j-bGtBZBZ5AQ7kNvgFzIcJE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCC081QRjOPpxNrKvxU8Y-5hTLa4JvzFqaedVEn5S0X_A&oe=66D4568F"}, {"file_name": "duckshoot.png", "id": "129990952313291", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031331_129990955646624_1190158248008757430_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DBW4g87eY4IQ7kNvgEtVokA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVqCK5soTOlrQklh2bZIO4EYIsqIjkT3MJOvnwNG60bA&oe=66D447BA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "RodentPeopleCover.png", "id": "245883636999278", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031428_245883640332611_3679024618240417657_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBygP2isKawQ7kNvgEiJX93&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUmfdzVtFoAtJtia7NRfc-nFjQ7UWb6wqccSEgozjfdQ&oe=66D4418E"}, "display_name": "Rodent People: Origins", "keywords": [], "long_description": "Rodent People are rats with human level brain power and a body enhanced with bionic parts, who somehow found themselves locked up in a prison.\nAt the first glance, life inside the cell is not too bad. Rodents occupy themselves by working and earning money, which they can then spend on food and other things. However, the days quickly start blending together, and the Rodent People can't keep on living in a prison cell - they decide to break out and find out the mystery behind why they were incarcerated in the first place.\n\nWhile the game is best experienced with team, you are free to tackle the mission on your own. Choose any rodent and use your wits to escape the prison!", "short_description": "Rodent People: Origins is a multiplayer VR escape room, in which teams of up to 4 players use their wits and cooperation to solve innovative, story driven puzzles to try and break out of a prison cell playing as the incarcerated rats - the Rodent People."}]}, "developer_