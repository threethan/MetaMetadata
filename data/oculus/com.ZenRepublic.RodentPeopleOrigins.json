_18Q7kNvgHKGpb1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_dfEYcULslcoznofnkHRkccz_zFrwMUc3PlslxUnj8g&oe=67275942"}, {"file_name": "puzzlesolving.png", "id": "166494275015243", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031630_166494281681909_7116265393689918265_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_DoooyEP8w8Q7kNvgEVUC-B&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqfSuJCqPCid_BruC8WWzeUvpkQH_BifpEunLb6GoZNg&oe=6727650F"}, {"file_name": "duckshoot.png", "id": "129990952313291", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031331_129990955646624_1190158248008757430_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Q3_gPts3m0Q7kNvgGIZ1fE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUbG9lpjvkp0vl8LVqJr5yDLKnSE_oCVTD2VHlT34DVw&oe=6727563A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "RodentPeopleCover.png", "id": "245883636999278", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031428_245883640332611_3679024618240417657_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IphyOaP0faAQ7kNvgFlxo4d&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAURsz1J3JF7JqChM8EN_x8hW2JlImf5ISwHf1JfIpKVw&oe=6727500E"}, "display_name": "Rodent People: Origins", "keywords": [], "long_description": "Rodent People are rats with human level brain power and a body enhanced with bionic parts, who somehow found themselves locked up in a prison.\nAt the first glance, life inside the cell is not too bad. Rodents occupy themselves by working and earning money, which they can then spend on food and other things. However, the days quickly start blending together, and the Rodent People can't keep on living in a prison cell - they decide to break out and find out the mystery behind why they were incarcerated in the first place.\n\nWhile the game is best experienced with team, you are free to tackle the mission on your own. Choose any rodent and use your wits to escape the prison!", 