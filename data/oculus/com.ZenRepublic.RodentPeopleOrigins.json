33YQ7kNvgHZBugN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA9I77wLMj7GUUnjxxCywWDVUYX2cQqE7Z-3jGtwOD5vA&oe=67348842"}, {"file_name": "puzzlesolving.png", "id": "166494275015243", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031630_166494281681909_7116265393689918265_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L1fB9mOpUU4Q7kNvgFx_lIO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB_9aSdbpc8ygtI-sa5IWitTBtERkraEg8pToKDG7TzVA&oe=6734940F"}, {"file_name": "duckshoot.png", "id": "129990952313291", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031331_129990955646624_1190158248008757430_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oKKJBUURC5oQ7kNvgHar65Q&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBzfsTWK4Q9za-XGvBZDMkKG32BQPq_W-KTH_Esp86GdA&oe=6734853A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "RodentPeopleCover.png", "id": "245883636999278", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031428_245883640332611_3679024618240417657_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SIjn5RXyAmQQ7kNvgG0wGdW&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDV7swc2_e7BHV9Mm3oD2r8A_uBpwTuU2Fs-mk95sxahA&oe=67347F0E"}, "display_name": "Rodent People: Origins", "keywords": [], "long_description": "Rodent People are rats with human level brain power and a body enhanced with bionic parts, who somehow found themselves locked up in a prison.\nAt the first glance, life inside the cell is not too bad. Rodents occupy themselves by working and earning money, which they can then spend on food and other things. However, the days quickly start blending together, and the Rodent People can't keep on living in a prison cell - they decide to break out and find out the mystery behind why they were incarcerated in the first place.\n\nWhile the game is best experienced with team, you are free to tackle the mission on your own. Choose any rodent and use your wits to escape the prison!", 