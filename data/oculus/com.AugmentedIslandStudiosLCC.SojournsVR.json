_369999689300826_7232273061354351877_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F0r3oVVJ82AQ7kNvgH00qdG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBruWGcwZ7LOLzywp6AMWUbmOpoVwlOuyg668BQNPJ2EA&oe=6703B399"}, {"file_name": "WinterCabin_4K_08.02.png", "id": "253134537839609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75355155_253134541172942_3942289714588422989_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bm_armOTKP0Q7kNvgHr5Qml&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJ5aJ-YQvqFvSr-2r1mmozNt5s64C-LvhOlNw0CGUcTw&oe=6703CB30"}, {"file_name": "Provence_Day_4K_08.02.png", "id": "916107236718338", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031529_916107240051671_9178672613812254110_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8L79zUEqJH4Q7kNvgHeErpI&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDW3f6mR3coAPmcT5bguFTz-vdBl4BKcUlLOK-HGimmkQ&oe=6703C8C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SojournsLandscape.png", "id": "1775457712975068", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974631_1775457716308401_1536189248167635739_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vSGZDna3BfUQ7kNvgHRHWxq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAbEm93HvMtmep1Jb0wtYpQZddHpyoKCfTXr6SavCedrg&oe=6703D0EA"}, "display_name": "Sojourns Wellness", "keywords": [], "long_description": "Immerse yourself in a sanctuary for the mind with Sojourns Wellness app. Explore serene landscapes that promote relaxation and wellness, each meticulously crafted to provide a soothing backdrop for your journey. \n\nThe app allows you to interact with these tranquil environments in various ways, personalizing your space for a truly immersive experience. This is more than just a virtual reality experience; it\u2019s a haven of calm in the virtual world. Dive into tranquility and experience the transformative power of wellness today.", "short_description": "Experience tranquility with Sojourns and immerse