al world. Select dawn, afternoon, or evening for your escapes."}]}, "developer_name": null, "developer_privacy_policy_url": "https://augmentedislandstudios.com/sojourns-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Augmented Island Studios", "support_website_url": null, "website_url": "https://augmentedislandstudios.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24528302636756812"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1591377288384156"}, {"status": "PUBLISHED", "id": "1566568947509843"}]}, "baseline_offer": {"id": "1591377288384156"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712071440, "status": "PUBLISHED", "id": "1591377288384156"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25427557536831313", "version": "6.5"}, "id": "1541591112913900", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "24528302623423480", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "25427557536831313"}, "release_status": "RELEASED"}, "binary_release_channels"