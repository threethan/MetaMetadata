01mGmXA&oe=67138625"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1000043382.png", "id": "2206767403005080", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984440_2206767406338413_6104468743794551067_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o7zWkgCCd7EQ7kNvgEsqG3i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2QYV0uMUnaHh26u6nyrmcVm16A0ytqYx7ZivQIpAIiA&oe=67138F3C"}, "display_name": "Dog Park", "keywords": [], "long_description": "Dog Park  is designed to be cartoony and whimsical. It features bright, colorful graphics that will bring the world of the dog park to life in a playful way. You'll get to experience all the fun activities that make up this virtual playground, like bouncing on trampolines and chatting with other dogs. Plus, with an environment designed for creativity and collaboration between players, you\u2019re sure to have a blast while playing this unique game! ", "short_description": "Dog Park lets you be a dog and explore the dog park. You'll have the chance to play with other dogs, bounce on trampolines, and chase balls in an immersive environment. With cartoony graphics and sound effects, this game is sure to provide hours of entertainment for everyone who plays!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/mep478/dog-park-stuff/main/privacy%20policy", "developer_terms_of_service_url": null, "publisher_name": "Electric", "support_website_url": null, "website_url": "https://sites.google.com/view/dogparkvr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memor