 is sure to provide hours of entertainment for everyone who plays!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/mep478/dog-park-stuff/main/privacy%20policy", "developer_terms_of_service_url": null, "publisher_name": "Electric", "support_website_url": null, "website_url": "https://sites.google.com/view/dogparkvr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25118456874469576"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "8171060842923151"}]}, "baseline_offer": {"id": "8171060842923151"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715139359, "status": "PUBLISHED", "id": "8171060842923151"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26704744529174128", "version": "2.5.33"}, "id": "442332198166513", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25118456857802911", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "26704744529174128"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE",