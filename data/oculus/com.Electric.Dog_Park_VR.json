com&oh=00_AYCoHO73iAGQqtvZkRgVUx8kiE3t-zMNYnVfOb7TLqR1Qw&oe=6722317B"}, "display_name": "Dog Park VR", "keywords": [], "long_description": "Dog Park is designed to be cartoony and whimsical. It features bright, colorful graphics that will bring the world of the dog park to life in a playful way. You'll get to experience all the fun activities that make up this virtual playground, like bouncing on trampolines and chatting with other dogs. Plus, with an environment designed for creativity and collaboration between players, you\u2019re sure to have a blast while playing this unique game! ", "short_description": "Dog Park lets you be a dog and explore the dog park. You'll have the chance to play with other dogs, bounce on trampolines, and chase balls in an immersive environment. With cartoony graphics and sound effects, this game is sure to provide hours of entertainment for everyone who plays!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/mep478/dog-park-stuff/main/privacy%20policy", "developer_terms_of_service_url": null, "publisher_name": "Electric", "support_website_url": null, "website_url": "https://sites.google.com/view/dogparkvr/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "26831580763157170"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771