nt.oculuscdn.com&_nc_gid=A9GIh1RWTDFpRrb0wUc8gzG&oh=00_AYCGBqlKmwL_-WQHMmWv953wePiqZUllmEGJjAdUbj-fog&oe=66E2BE26"}, {"file_name": "Untitled45_20240603015524.png", "id": "7738710106236934", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036702_7738710109570267_1302902507179128022_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q4sD0FKmBD8Q7kNvgEc8Hka&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9GIh1RWTDFpRrb0wUc8gzG&oh=00_AYCanx_Zvl3dXIzIXUYYvA0SZajee15aE87Kkg5RPC0d0Q&oe=66E2B75D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38984463_312284498595611_7868954328370834595_n.png", "id": "1623661808471739", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036676_1623661811805072_1393075819203053519_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FlIzpO5BhTUQ7kNvgEgxtwh&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9GIh1RWTDFpRrb0wUc8gzG&oh=00_AYBSt2gYyk0RQ-bZvCUHpbAIfk8td_4TfuD2f14IhYwsew&oe=66E2B993"}, "display_name": "Dog Park VR", "keywords": [], "long_description": "Dog Park is designed to be cartoony and whimsical. It features bright, colorful graphics that will bring the world of the dog park to life in a playful way. You'll get to experience all the fun activities that make up this virtual playground, like bouncing on trampolines and chatting with other dogs. Plus, with an environment designed for creativity and collaboration between players, you\u2019re sure to have a blast while playing this unique game! ", "short_description": "Dog Park lets you be a dog and explore the dog park. You'll have the chance to play with other dogs, bounce on trampolines, and chase balls in an immersive environment. With cartoony graphics and sound effects, this game is sure to provide hours of entertainment for everyone who plays!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/mep478/dog-park-stuff/main/privacy%20policy", "developer_terms_of_service_url": null, "publisher_name": "Electric", "support_website_