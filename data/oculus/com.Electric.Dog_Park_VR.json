1196466481634221_9076739026019090644_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTEWS9o361gQ7kNvgE9WFko&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDHJeqKEuSe_e8LSlPt3IfC7fO_bHMunB_ZNzH1vTb_hA&oe=674083FB"}, "display_name": "Dog Park VR", "keywords": [], "long_description": "Dog Park is designed to be cartoony and whimsical. It features bright, colorful graphics that will bring the world of the dog park to life in a playful way. You'll get to experience all the fun activities that make up this virtual playground, like bouncing on trampolines and chatting with other dogs. Plus, with an environment designed for creativity and collaboration between players, you\u2019re sure to have a blast while playing this unique game! ", "short_description": "Dog Park lets you be a dog and explore the dog park. You'll have the chance to play with other dogs, bounce on trampolines, and chase balls in an immersive environment. With cartoony graphics and sound effects, this game is sure to provide hours of entertainment for everyone who plays!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/mep478/dog-park-stuff/main/privacy%20policy", "developer_terms_of_service_url": null, "publisher_name": "Electric", "support_website_url": null, "website_url": "https://sites.google.com/view/dogparkvr/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["M