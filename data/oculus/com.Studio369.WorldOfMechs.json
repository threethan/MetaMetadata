4X10UkNMQ7kNvgGPbYHr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjbqnol4hep6Sb3AZsjDYk0OsNedolwh9XTW6eOY9nCw&oe=671F7A5D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QPP_WorldofMechs_2560x1440.png", "id": "275784341430859", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974610_275784344764192_1043956551782677645_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BaETNxVMEC0Q7kNvgG_sM_Y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAl1FfjqzE0-tGyeYCVw8awZiKf7PruRNB5Ke8aCOtnQw&oe=671F7AA8"}, "display_name": "World Of Mechs", "keywords": ["Action", "Mechs", "Multiplayer", "Shooter", "Deathmatch"], "long_description": "Fire up your boosters and dive into supersized online multiplayer mayhem in VR! World of Mechs ain\u2019t about pressing buttons or flipping switches - it\u2019s all about high-speed, curb-stomping, jump-in / jump-out action. Flex your supremacy in online modes like Team Deathmatch and Domination, or take down bosses in the single-player campaign to become a mech pilot legend. The ultimate VR mech battle awaits!\n\n\"World of Mechs is an instantly enjoyable experience.\" - VRFocus\n\nONLINE ONSLAUGHT: Wreak online foes with up to 3 friends on five maps and 4 modes.\n\nCOMBAT STYLES: Select from 32 mechs across 8 different class types to fit your combat style. Jam radar sensors, enable stealth cloaking, and unleash Barrage missiles to crush the opposition.\n\nCAMPAIGN MODE: Pulverize bosses, earn cash for upgrades and become the best of the best.\n\nBUILT FOR QUEST 2: Headset Targeting System and VR visual performance optimizations customized to enhance gameplay.\n", "short_description": "Fire up your boosters and dive into supersized online multiplayer mayhem in VR! World of Mechs ain\u2019t about pressing buttons or flipping switches - it\u2019s all about high-speed, curb-stomping, jump-in / jump-out action. Flex your supremacy in online modes like Team Deathmatch and Domination, or take down bosses in the single-player campaign to become a mech pilot legend. The ultimate VR mech battle awaits!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.369.fun/privacy", "developer_terms_of_service_url": null, "publisher_name": "Studio 369 Inc", "support_website_url": null, "website_url": "http://worldofmechs.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "582224746639555"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984466_745798199761940_7975058141899970176_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OHWq1srxEuIQ7kNvgGDj44q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQItaST-bRX31KT9kNcaWZy61tAhJbferNzzimjDkRDA&oe=671F78FE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "World Of Mechs", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1654189161, "lastRevision": {"nodes": [{"id": "169053825180149", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4017841368311255", "is_first_party": false, "enables_in_app_ads": false, "is_con