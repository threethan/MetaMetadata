le_name": "005.png", "id": "508206964108473", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86613167_508206967441806_5947248506887917381_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lwPagJ_36soQ7kNvgFBauqt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaT85NWBH1Lacz6b2bNajnibGYXuf-GZ_HQa2KZdWcmg&oe=66EEB521"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QPP_WorldofMechs_2560x1440.png", "id": "275784341430859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974610_275784344764192_1043956551782677645_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_jospNzb-xUQ7kNvgHNLTMM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLYqT4S9QnBWXQwJosaaGviKqHWoH2OZEGtjRqqv9Lkg&oe=66EEB328"}, "display_name": "World Of Mechs", "keywords": ["Action", "Mechs", "Multiplayer", "Shooter", "Deathmatch"], "long_description": "Strap in and get ready for heart-pumping mech battlin\u2019 VR action! World of Mechs is the only online competitive squad-based VR mech game that delivers the feeling of thrashing across city blocks in a 10-ton robotic war machine while launching a salvo of missiles on the opposition. Feel the adrenaline rush of leading a flanking charge with weapons ablaze and jump-jets engaged. Blast off into the single-player campaign to take down menacing bosses and become the world\u2019s most-feared ace pilot.\n\nONLINE ONSLAUGHT: Dive into the multiplayer VR arena with 3 friends to battle online foes on five maps in 4 modes.\n\nCOMBAT STYLES: Select from 32 mechs across 8 different class types to fit your combat style. Use special abilities to jam radar sensors, deploy landmines, and enable stealth cloaking.\n\nSINGLE-PLAYER: Earn cash for upgrades and learn winning tactics in Campaign Mode.\n\nBUILT FOR QUEST 2: Headset Targeting System and VR visual performance optimizations customized to enhance gameplay.", "short_description": "Strap in and get ready for heart-pumping mech battlin\u2019 VR action! World of Mechs is the only online competitive squad-based VR mech game that delivers the feeling of thrashing across city blocks in a 10-ton robotic war machine while launching a salvo of missiles on the opposition. Feel the adrenaline rush of leading a flanking charge with weapons ablaze and jump-jets engaged. Blast off into the single-player campaign to take down menacing bosses and become the world\u2019s most-feared ace pilot."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.369.fun/privacy", "developer_terms_of_service_url": null, "publisher_name": "Studio 369 Inc", "support_website_url": null, "website_url": "http://worldofmechs.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "672665650577286"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PUBLISHED", "id": "823188216629809"}, {"status": "PENDING", "id": "890481469004231"}, {"status": "PENDING", "id": "1240373376558136"}, {"status": "PUBLISHED", "id": "5760717160715291"}, {"status": "PUBLISHED", "id": "1525267081210693"}, {"status": "PUBLISHED", "id": "592807395626582"}, {"status": "PENDING", "id": "304756105483060"}, {"status": "PUBLISHED", "id": "560671542353024"}, {"status": "PUBLISHED", "id": "3004937209813020"}, {"status": "PUBLISHED", "id": "416502520593624"}, {"status": "PENDING", "id": "1479607572452082"}, {"status": "PENDING", "id": "726083242335467"}, {"status": "PUBLISHED", "id": "883762545937781"}]}, "baseline_offer": {"id": "5606715423530