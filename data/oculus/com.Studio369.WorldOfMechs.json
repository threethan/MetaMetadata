9_6102046085102589726_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FpaGQRZR2hYQ7kNvgGP1JGL&_nc_ht=scontent.oculuscdn.com&oh=00_AYALkXTADnYHBE_h6fp_1q5ULNiceMLxiyc7DdzZbcNYjg&oe=66EE9B7D"}]}, "id": "1213002142850066", "locale": "en_US", "screenshots": [{"file_name": "002.png", "id": "1136943040436511", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982498_1136943043769844_6053554436810189057_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_iQ_9bhQ-igQ7kNvgGHwrM4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEBnjwY6mAGEzZqkiTMrognKMGgd338XlP47Bpm5jsag&oe=66EE9255"}, {"file_name": "003.png", "id": "686583705946250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974842_686583709279583_2875245439042076354_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3KWBXVteKxAQ7kNvgFcZSpA&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdPfaTky3OgLP57OmhZnsjbixRJLiCpHfkZnNlG6c30A&oe=66EEC367"}, {"file_name": "004.png", "id": "717772666074001", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974460_717772669407334_7411742698121570967_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W5d0-Ei_05kQ7kNvgHDrg0i&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJ0GJradgWBz335LZ0Uisc614GRFkHi-gn72KGIfILNA&oe=66EEC139"}, {"file_name": "005.png", "id": "508206964108473", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86613167_508206967441806_5947248506887917381_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lwPagJ_36soQ7kNvgFBauqt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaT85NWBH1Lacz6b2bNajnibGYXuf-GZ_HQa2KZdWcmg&oe=66EEB521"}, {"file_name": "001 new.png", "id": "1452373495193937", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031647_1452373498527270_7075553710083891822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OJ_W5SErodkQ7kNvgHc6XNh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCO05I0fm8xoy7PEaLpzzZTFx6okjdX6-SWHsaIAOlL8g&oe=66EEB2DD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QPP_WorldofMechs_2560x1440.png", "id": "275784341430859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974610_275784344764192_1043956551782677645_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_jospNzb-xUQ7kNvgHNLTMM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLYqT4S9QnBWXQwJosaaGviKqHWoH2OZEGtjRqqv9Lkg&oe=66EEB328"}, "display_name": "World Of Mechs", "keywords": ["Action", "Mechs", "Multiplayer", "Shooter", "Deathmatch"], "long_description": "Fire up your boosters and dive into supersized online multiplayer mayhem in VR! World of Mechs ain\u2019t about pressing buttons or flipping switches - it\u2019s all about high-speed, curb-stomping, jump-in / jump-out action. Flex your supremacy in online modes like Team Deathmatch and Domination, or take down bosses in the single-player campaign to become a mech pilot legend. The ultimate VR mech battle awaits!\n\n\"World of Mechs is an instantly enjoyable experience.\" - VRFocus\n\nONLINE ONSLAUGHT: Wreak online foes with up to 3 friends on five maps and 4 modes.\n\nCOMBAT STYLES: Select from 32 mechs across 8 different class types to fit your combat style. Jam radar sensors, enable stealth cloaking, and unleash Barrage missiles to crush the opposition.\n\nCAMPAIGN MODE: Pulverize bosses, earn cash for upgrades and become the best of the best.\n\nBUILT FOR QUEST 2: Headset Targeting System and VR visual performance optimizations customized to enhance gameplay.\n", "short_description": "Fire up your boosters and dive into supersized online multiplayer mayhem in VR! World of Mechs ain\u2019t about pressing buttons or flipping switches - it\u2019s all about high-speed, curb-stomping, jump-in / jump-out action. Flex your supremacy in online modes like Team Deathmatch and Domination, or take down bosses in the single-player campaign to become a mech pilot legend. The ultimate VR mech battle awaits!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.369.fun/privacy", "developer_terms_of_service_url": null, "publisher_name": "Studio 369 Inc", "support_website_url": null, "web