.com&_nc_gid=AlOcxmpBNExyd9F_7vAuD-x&oh=00_AYDH0RW5thFYSF-rMf9G7x-LJVWMnZhP6nhtDyu1Iozj-w&oe=66EEAE87"}, {"file_name": "2_HighresScreenshot00032_2560x1440.png", "id": "751530432138512", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974879_751530435471845_37787088935008532_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S9BRrWqfIcsQ7kNvgHxzjd9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlOcxmpBNExyd9F_7vAuD-x&oh=00_AYChh2lZKc5LBrPW3j3llhEJ9sHZ3yNGCpeSO0zPE4J0Mw&oe=66EEAFDC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "first_steps_handtracking_poster.png", "id": "135378945161578", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031528_135378948494911_7379521461747766087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dnx22INfLB4Q7kNvgHRNsaz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlOcxmpBNExyd9F_7vAuD-x&oh=00_AYB5W1nCtx_4E5TdTmJKZx78-j6fyoz3HLNJy5d6TocWDA&oe=66EEBE0D"}, "display_name": "First Steps With Hand Tracking", "keywords": [], "long_description": "If you\u2019re a developer, you should check out how hand tracking can replace your Touch Controller experience. This experimental version of First Steps showcases how your Touch Controllers can be replaced with hand tracking, and add a new dimension to your application. Our development team did not have to redesign new mechanics, but were able to replace Touch Controllers with Hands without a heavy lift.", "short_description": "First Steps is a highly acclaimed introduction to virtual reality by Oculus. First Steps was originally released to showcase our Touch Controllers. However we\u2019ve upgraded the experience by adding hand tracking to this Oculus Quest and Quest 2 experience. "}]}, "developer_name": "Oculus", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/blog/