.com&_nc_gid=AbQvZNc5ilQ3HddwYHF8Uis&oh=00_AYA2m5Kx7vdExB9qmCaNvk2xjp0ZrMwrUg5tm5ILb2DLTw&oe=66F3F487"}, {"file_name": "2_HighresScreenshot00032_2560x1440.png", "id": "751530432138512", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974879_751530435471845_37787088935008532_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d0geIB2l0eYQ7kNvgH_EHJF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbQvZNc5ilQ3HddwYHF8Uis&oh=00_AYA848Uc4qROqIlu_Xb9A2an_VCjxhASMN5eaNW_pGACig&oe=66F3F5DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "first_steps_handtracking_poster.png", "id": "135378945161578", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031528_135378948494911_7379521461747766087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LwZ6Zp6MGvIQ7kNvgEMGKHm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbQvZNc5ilQ3HddwYHF8Uis&oh=00_AYDtyOcVxf4lWQ1EYIAm2E38Nh2UkiQdVjLeb7R_g6g84w&oe=66F4040D"}, "display_name": "First Steps With Hand Tracking", "keywords": [], "long_description": "If you\u2019re a developer, you should check out how hand tracking can replace your Touch Controller experience. This experimental version of First Steps showcases how your Touch Controllers can be replaced with hand tracking, and add a new dimension to your application. Our development team did not have to redesign new mechanics, but were able to replace Touch Controllers with Hands without a heavy lift.", "short_description": "First Steps is a highly acclaimed introduction to virtual reality by Oculus. First Steps was originally released to showcase our Touch Controllers. However we\u2019ve upgraded the experience by adding hand tracking to this Oculus Quest and Quest 2 experience. "}]}, "developer_name": "Oculus", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/blog/