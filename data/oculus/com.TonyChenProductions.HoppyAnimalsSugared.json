BFP1oxkwG56EA6m15koQhh7wzgEhnxGcdc3OnFjjBK4w&oe=6769605A"}, {"file_name": "migrated_image.png", "id": "528595694527658", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974690_585304771888829_1788145140460683264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jAj4YLjN3gcQ7kNvgEPrDke&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCk12P0WFwxtoUhyL4FUnyxtki8xajNalEvxFAbdCRjiA&oe=67693EC3"}, {"file_name": "migrated_image.png", "id": "201896287755749", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974690_2137435572947402_7965272821892907008_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FK5qhOG6QA4Q7kNvgFfo4qk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9G2_3GQb-7jDUMba0ug-BIzFK-CyrvEdPJQeHN3mGuA&oe=6769361E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hoppy Animals", "keywords": ["Hoppy", "Animals", "Platformer", "Candy", "Animal"], "long_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over).\n\nYou will stroll by plants made of lollipops, pudding, and ice cream cones, run on ground made of cookies, cake, and croissants, and hop on structures made of bread, chocolate, and slices of pie.\n\n- Control with touchpad, gamepad, or Gear VR/Oculus Go Controller\n- The mood is delight, happiness, and wonder\n- Characters can move freely in 3D\n- Comfortable gameplay (VR dizziness minimized)\n\nThis game will make you very glad that you own a Gear VR or Oculus Go!", "short_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over)."}]}, "developer_name": "Tony Chen", "developer_privacy_policy_url": "ht