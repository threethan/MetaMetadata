_ht=scontent.oculuscdn.com&oh=00_AYC5jZJ8sQz6D5IvaAkbtqNwl64-eUmmPJGGyVvJFhAUXg&oe=66FE6A5D"}, {"file_name": "migrated_image.png", "id": "200231011236659", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_235577060647554_2277918154057318400_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3MDKFdjWTzsQ7kNvgExsn50&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRsdbL3bo5xYW6YbH78nvzKv0kwAGXLuUG1BU0BQBNMw&oe=66FE6BD5"}]}, "id": "591443245125795", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "3166311666926634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974562_877868992408384_6444996322008236032_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NdrDXR2ttpkQ7kNvgENbMb4&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxI8iau1AlF5Fgx3x8kUsS6pv6hQvatS4sgI1MUULOAQ&oe=66FE7A36"}, {"file_name": "migrated_image.png", "id": "814733379010198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974753_674936926224269_1599372192406044672_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYtH1GkCC8YQ7kNvgHO_VvR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGpTmXndArJznxq0ldOax4yMwvXXony52JWYBLA-BZKA&oe=66FE78C0"}, {"file_name": "migrated_image.png", "id": "687042665365677", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982543_1061958097299808_3288039422070620160_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CxEP_b23RQ4Q7kNvgGaNs3K&_nc_ht=scontent.oculuscdn.com&oh=00_AYD4Jnn9FUycKxA3tVJkrGVqZxGBB8IPlDhbaK5F5vKpDA&oe=66FE96DA"}, {"file_name": "migrated_image.png", "id": "528595694527658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974690_585304771888829_1788145140460683264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XBnXnLwb1F4Q7kNvgGsZiWp&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3Hu54ExdgAf5lI0aJqD5wQ4ZwlVDUJ5FK9DRQQKvrnw&oe=66FE7543"}, {"file_name": "migrated_image.png", "id": "201896287755749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974690_2137435572947402_7965272821892907008_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2oCFuDOKgHQQ7kNvgGSLhZ4&_nc_ht=scontent.oculuscdn.com&oh=00_AYA22wV9V0g2HLMnOqYTudML2DtinjTbZWYUP5ZjUAK8cw&oe=66FE6C9E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hoppy Animals", "keywords": ["Hoppy", "Animals", "Platformer", "Candy", "Animal"], "long_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over).\n\nYou will stroll by plants made of lollipops, pudding, and ice cream cones, run on ground made of cookies, cake, and croissants, and hop on structures made of bread, chocolate, and slices of pie.\n\n- Control with touchpad, gamepad, or Gear VR/Oculus Go Controller\n- The mood is delight, happiness, and wonder\n- Characters can move freely in 3D\n- Comfortable gameplay (VR dizziness minimized)\n\nThis game will make you very glad that you own a Gear VR or Oculus Go!", "short_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over)."}]}, "developer_name": "Tony Chen", "developer_privacy_policy_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "developer_terms_of_service_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "publisher_name": "Tony Chen Productions", "support_website_url": null, "website_url": "https://tonychenproductions.weebly.com/hoppy-animals.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "ACTION"], "has_in_app_ads": false, "inter