0460683264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZZwtycAdDg4Q7kNvgHAQNXI&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYASz7ZEnL0gehzZkJQw7gLEg9klKs8twe3gESvfyQJaUA&oe=67011843"}, {"file_name": "migrated_image.png", "id": "201896287755749", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974690_2137435572947402_7965272821892907008_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PEI1twDGSwkQ7kNvgEaF-u3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDkfIsVvRiAh0VBEG8U7oMATcMN9c1Wtjid76GGLbN0LA&oe=67010F9E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hoppy Animals", "keywords": ["Hoppy", "Animals", "Platformer", "Candy", "Animal"], "long_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over).\n\nYou will stroll by plants made of lollipops, pudding, and ice cream cones, run on ground made of cookies, cake, and croissants, and hop on structures made of bread, chocolate, and slices of pie.\n\n- Control with touchpad, gamepad, or Gear VR/Oculus Go Controller\n- The mood is delight, happiness, and wonder\n- Characters can move freely in 3D\n- Comfortable gameplay (VR dizziness minimized)\n\nThis game will make you very glad that you own a Gear VR or Oculus Go!", "short_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over)."}]}, "developer_name": "Tony Chen", "developer_privacy_policy_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "developer_terms_of_service_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "publisher_name": "Tony Chen Productions",