_ht=scontent.oculuscdn.com&oh=00_AYBLfxfY-pAzMWnRErhG11sHYvbj3eSt8rv5pYxGFoCGzw&oe=66FA75DD"}, {"file_name": "migrated_image.png", "id": "200231011236659", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_235577060647554_2277918154057318400_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ELKD08WIf9cQ7kNvgG9GLbf&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRCxNSd5jxxV2O3BG0PDXaklkM2efhoOsK0cse0VtQmQ&oe=66FA7755"}]}, "id": "591443245125795", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "3166311666926634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974562_877868992408384_6444996322008236032_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zMeadpxNZYkQ7kNvgFWIxYt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBL-0So-2ocugMdFyyIZjf8S9RuUO8maNp5caSAAubhLQ&oe=66FA85B6"}, {"file_name": "migrated_image.png", "id": "814733379010198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974753_674936926224269_1599372192406044672_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k9OQW0mehH0Q7kNvgEkUis6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBThGiwG_X5GbiE47dSgJUsSUOctFmofkDTiKfcSk50PA&oe=66FA8440"}, {"file_name": "migrated_image.png", "id": "687042665365677", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982543_1061958097299808_3288039422070620160_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pYD-BOA2J00Q7kNvgE6XHdf&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPrtYL2gQREdKESrH2RT2kuitQo9pp7e7yD-tPLbnjeg&oe=66FAA25A"}, {"file_name": "migrated_image.png", "id": "528595694527658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974690_585304771888829_1788145140460683264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gQizM_U030AQ7kNvgF0aUAA&_nc_ht=scontent.oculuscdn.com&oh=00_AYD24iFLW-2uRXS2XTjAQzeFmrH4-kGH_Y0G1WryHVhuQw&oe=66FA80C3"}, {"file_name": "migrated_image.png", "id": "201896287755749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974690_2137435572947402_7965272821892907008_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z3Eoj2SFUV0Q7kNvgHMSwZL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBmH-NfNBvA8vw-aaRZQlNvgAXwR61bepJGRwNLxKf7pA&oe=66FA781E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hoppy Animals", "keywords": ["Hoppy", "Animals", "Platformer", "Candy", "Animal"], "long_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over).\n\nYou will stroll by plants made of lollipops, pudding, and ice cream cones, run on ground made of cookies, cake, and croissants, and hop on structures made of bread, chocolate, and slices of pie.\n\n- Control with touchpad, gamepad, or Gear VR/Oculus Go Controller\n- The mood is delight, happiness, and wonder\n- Characters can move freely in 3D\n- Comfortable gameplay (VR dizziness minimized)\n\nThis game will make you very glad that you own a Gear VR or Oculus Go!", "short_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over)."}]}, "developer_name": "Tony Chen", "developer_privacy_policy_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "developer_terms_of_service_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "publisher_name": "Tony Chen Productions", "support_website_url": null, "website_url": "https://tonychenproductions.weebly.com/hoppy-animals.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "ACTION"], "has_in_app_ads": false, "inter