c=Jeg7BE-sH1QQ7kNvgGy-ctb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuxXQvC8j6cAV3M3-XyoTW-kwCfNgNfvmLjgeZcAKNIA&oe=672DF019"}, {"file_name": "migrated_image.png", "id": "195178495233514", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974454_379098659512202_2039537869877411840_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ac1OtTFeYI4Q7kNvgG9cDPh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDy9UgAHinDAF4SOB8wMeC6e4hBVxjp-b08wpRN0Rfzqw&oe=672E0AA5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "YouTube cover trimmed 2560x1440.png", "id": "1588393144651699", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75286674_1588393147985032_8464614538505281207_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hE6ylnmODGcQ7kNvgGUhDn7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlDRsDWXvz_JU8_AY1LJJkN8nCCUHn07m57B-zetvtcA&oe=672DF3F6"}, "display_name": "Hoppy Animals", "keywords": ["Hoppy", "Animals", "Hopping", "Animal"], "long_description": "\"It's a very interesting game. There is not a lot of these in VR.\" - GoBros\n\nHoppy Animals is a third-person action-adventure 3D platformer game.\n\nSet in an imaginative, cartoonish candy world and nightmare world, a dog, a cat and a mouse will test their abilities against various obstacles, including scimitar-wielding, firearm-slinging undead pirates!\n\n- Designed specifically for Gear VR and Oculus Go\n- Over 40 levels of gameplay\n- Family-friendly\n- Visually beautiful\n- Adorable orchestral soundtrack\n- Multi-cast voice acting\n- Almost like participating in an animated movie\n- Comfortable gameplay (VR dizziness minimized, standing or swivel chair not required)\n- Supports Oculus Go and Gear VR controllers\n- Supports bluetooth gamepad\n\nImmerse in a beautiful fairy tale of talking animals, pirates and candies. You will visit a candy town, ride in a giant butterfly ship, and brave a cartoonish haunted house. This game is sheer eye candy, literally, and it just makes you feel good!", "short_description": "Control a dog, a cat and a mouse in this action-adventure 3D platformer game. Immerse in a beautiful fairy tale of talking animals, pirates and candies."}]}, "developer_name": "Truthveyor Studio", "developer_privacy_policy_url": "http://truthveyor.weebly.com/privacy-policy.html", "developer_terms_of_service_url": "https://www.truthveyor.com/privacy-policy-terms-of-service.html", "publisher_name": "Tony Chen Productions", "support_website_url": null, "website_url": "https://www.truthveyor.com/hoppy-animals.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "658266085320995"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262744_2664980683545851_4477112546876194816_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vPJIrYVWubkQ7kNvgHgwtWy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCa8AQ_6E_ysZhauqCZP6J1w77ApH31Xdw6--8fXkbt5Q&oe=672DF7E0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hoppy Animals", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1597338028, "lastRevision": {"nodes": [{"id": "1886637874977228", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2018808911513771", "is_first_party": fa