_ht=scontent.oculuscdn.com&oh=00_AYB1Ihch0CAsqr9ZSTIkZ2Z4-9l8O85GtPvca9wUUYQdOw&oe=66F7D2DD"}, {"file_name": "migrated_image.png", "id": "200231011236659", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_235577060647554_2277918154057318400_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ELKD08WIf9cQ7kNvgGXknuR&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0qYrhThlmQsodXwX1BJaClDcn-F0s6l0e6fSjuXDpxw&oe=66F7D455"}]}, "id": "591443245125795", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "3166311666926634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974562_877868992408384_6444996322008236032_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6oRZ9UkjVu0Q7kNvgEy_bYT&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMTRu3cdM6Z7f8D0JLHBF-AwWqmDQdIZD9aWiTRiz4Ig&oe=66F7E2B6"}, {"file_name": "migrated_image.png", "id": "814733379010198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974753_674936926224269_1599372192406044672_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k9OQW0mehH0Q7kNvgEEdmg8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwm2yRetPxMrAjAWS-Bugo1Myr-uSSiXUQWbjWoBPIWA&oe=66F7E140"}, {"file_name": "migrated_image.png", "id": "687042665365677", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982543_1061958097299808_3288039422070620160_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F1KL3sNabR4Q7kNvgE3n9Pe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsaWY1qd9Nfd7V1NNmkeR4kGnZuWSZjDDIk99D-K4_aw&oe=66F7FF5A"}, {"file_name": "migrated_image.png", "id": "528595694527658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974690_585304771888829_1788145140460683264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gQizM_U030AQ7kNvgFfPhIz&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-eLYVx4SYMU7kp-wbw_JBNL7cJDojbXTisdgMex8EjQ&oe=66F7DDC3"}, {"file_name": "migrated_image.png", "id": "201896287755749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974690_2137435572947402_7965272821892907008_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oaDILZmerD0Q7kNvgGqZsVx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCepQjL-uuNP5nwHxdb6q9Z1cdTa6nq9it9Sx3lJJTyeQ&oe=66F7D51E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hoppy Animals", "keywords": ["Hoppy", "Animals", "Platformer", "Candy", "Animal"], "long_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over).\n\nYou will stroll by plants made of lollipops, pudding, and ice cream cones, run on ground made of cookies, cake, and croissants, and hop on structures made of bread, chocolate, and slices of pie.\n\n- Control with touchpad, gamepad, or Gear VR/Oculus Go Controller\n- The mood is delight, happiness, and wonder\n- Characters can move freely in 3D\n- Comfortable gameplay (VR dizziness minimized)\n\nThis game will make you very glad that you own a Gear VR or Oculus Go!", "short_description": "Designed from the ground up for Gear VR and Oculus Go, and suitable for the whole family, Hoppy Animals is a third person game set in a remarkably stunning and explorable 3D candy world. Characters can run, jump, attack and talk (voiced over)."}]}, "developer_name": "Tony Chen", "developer_privacy_policy_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "developer_terms_of_service_url": "https://tonychenproductions.weebly.com/privacy-policy--terms-of-service.html", "publisher_name": "Tony Chen Productions", "support_website_url": null, "website_url": "https://tonychenproductions.weebly.com/hoppy-animals.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "ACTION"], "has_in_app_ads": false, "inter