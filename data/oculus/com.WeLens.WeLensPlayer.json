_ohc=JevliLbRyPMQ7kNvgGPEGsJ&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYD5n_bmd3BJW33lJ5rN20bEONjKsXz00_xpQI1nkPzo-A&oe=6728C60E"}, {"file_name": "migrated_image.png", "id": "327628094868336", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/12482255_319330811907499_8106333089925431296_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=21FmAWiaRXUQ7kNvgGKPTBm&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYC4MtV-e6FmBEFBZAiB9hAlSaAWVX7M5EJNFMo2gTQ9gA&oe=6728C1A1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "LensPass", "keywords": ["WeLens", "LensPass", "Video", "Cinema", "Sync"], "long_description": "Use LensPass to watch and share 360-degree videos, with support for 3D formats and spatial audio. Pair LensPass with the accompanying LensPass Android app for more capabilities including: \n\n* Monitor and control VR viewings on any number of headsets over WiFi. Sync headsets and get real-time device battery and temperature levels.\n\n* Use Theater Mode for streamlined viewings where all viewer controls are disabled.  You can customize your screening setup with a short countdown sequence and other options to fit the needs of your VR screening.\n\n* Add your own logo and message through the LensPass Screening Dashboard.\n\n* After your VR screenings, view auto-generated analytics reports that show include the viewing completion rates and other information", "short_description": "Use LensPass to watch and share 360-degree videos, and pair it with the accompanying LensPass Android app for more customization and control features that are designed to help share VR experiences."}]}, "developer_name": "WeLens, Inc.", "developer_privacy_policy_url": "http://www.welens.com/privacy", "developer_terms_of_service_url": "http://www.welens.com/terms", "publisher_name": "WeLens, Inc.", "support_website_url": null, "website_url": "http://www.welens.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_ta