31_148169215899155_5024626920411627520_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NlfnIIsAwSgQ7kNvgGfGQzv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4XX84fpt0Jm0LuzrXtbR8&oh=00_AYCsIPv4BQPW6y10_IAWDbqIuK3hm-PheJofrdPfyvBehQ&oe=66E0438E"}, {"file_name": "migrated_image.png", "id": "327628094868336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482255_319330811907499_8106333089925431296_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vnSMtysec10Q7kNvgF3jdbu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4XX84fpt0Jm0LuzrXtbR8&oh=00_AYBr50xEIM3tSsjL-igNE2pAGs4doNnJVWdJtA1Il0GPMg&oe=66E03F21"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "LensPass", "keywords": ["WeLens", "LensPass", "Video", "Cinema", "Sync"], "long_description": "Use LensPass to watch and share 360-degree videos, with support for 3D formats and spatial audio. Pair LensPass with the accompanying LensPass Android app for more capabilities including: \n\n* Monitor and control VR viewings on any number of headsets over WiFi. Sync headsets and get real-time device battery and temperature levels.\n\n* Use Theater Mode for streamlined viewings where all viewer controls are disabled.  You can customize your screening setup with a short countdown sequence and other options to fit the needs of your VR screening.\n\n* Add your own logo and message through the LensPass Screening Dashboard.\n\n* After your VR screenings, view auto-generated analytics reports that show include the viewing completion rates and other information", "short_description": "Use LensPass to watch and share 360-degree videos, and pair it with the accompanying LensPass Android app for more customization and control features that are designed to help share VR experiences."}]}, "developer_name": "WeLens, Inc.", "developer_privacy_policy_url": "http://www.welens.com/privacy", "developer_terms_of_service_url": "http://www.welens.com/terms", "publisher_name": "WeLens, Inc.", "support_website_url": null, "website