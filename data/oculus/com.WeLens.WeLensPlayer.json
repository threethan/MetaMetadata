im4qP0wOwgQ7kNvgGjRJiw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB0j9mAFEl44lq59dVYnjeljhGVBK8Mp_ZNhXKYfEtuHA&oe=6723800E"}, {"file_name": "migrated_image.png", "id": "327628094868336", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12482255_319330811907499_8106333089925431296_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5WmrttKxTqEQ7kNvgE9ZdlX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLu7oJgYVwBNW6qPFx02B71yyMG_C1fe7rqt09q5YSHA&oe=67237BA1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "LensPass", "keywords": ["WeLens", "LensPass", "Video", "Cinema", "Sync"], "long_description": "Use LensPass to watch and share 360-degree videos, with support for 3D formats and spatial audio. Pair LensPass with the accompanying LensPass Android app for more capabilities including: \n\n* Monitor and control VR viewings on any number of headsets over WiFi. Sync headsets and get real-time device battery and temperature levels.\n\n* Use Theater Mode for streamlined viewings where all viewer controls are disabled.  You can customize your screening setup with a short countdown sequence and other options to fit the needs of your VR screening.\n\n* Add your own logo and message through the LensPass Screening Dashboard.\n\n* After your VR screenings, view auto-generated analytics reports that show include the viewing completion rates and other information", "short_description": "Use LensPass to watch and share 360-degree videos, and pair it with the accompanying LensPass Android app for more customization and control features that are designed to help share VR experiences."}]}, "developer_name": "WeLens, Inc.", "developer_privacy_policy_url": "http://www.welens.com/privacy", "developer_terms_of_service_url": "http://www.welens.com/terms", "publisher_name": "WeLens, Inc.", "support_website_url": null, "website_url": "http://www.welens.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [],