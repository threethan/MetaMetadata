oculuscdn.com/v/t64.5771-25/39003224_511784736012705_1616856617721004032_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qQUYdhMWz9cQ7kNvgHH2JBd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVhsJF1sFLq47YWw_GeJLTp&oh=00_AYDdWyjERB6izpyuQH7MtBs5peLFZJYra5-1hy2RfVyNkw&oe=66D6EDB5"}, {"file_name": "migrated_image.png", "id": "235108140977493", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982559_296345414378321_8211754531084566528_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2d3cv6bcOwwQ7kNvgFjaBd4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVhsJF1sFLq47YWw_GeJLTp&oh=00_AYCz3bSz6PKvN4rSpf0ZiyA2GCy5JRC3khukXNMO3YtMxw&oe=66D6E993"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/lZ6Ryf", "id": "2133195983651863", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974506_2133195986985196_2245220671112085504_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ybkUo9u_bvYQ7kNvgGNLSjz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVhsJF1sFLq47YWw_GeJLTp&oh=00_AYCcWviG74LoFcMVjr-Td2HIfrmKnieloCkPp1sPUie1qA&oe=66D70D2A"}, "display_name": "Hockey Player VR", "keywords": ["hockey", "sport", "nhl", "multiplayer", "ice"], "long_description": "Play hockey in first person view and develop your own tactics and tricks. Finally, a hockey game where you have 100% control. Test out your puck skills in online multiplayer mode.\n\nFeatures:\n- 4 training modes\n- Multiplayer for 2 or 4 players\n- 100% control\n- Realistic physics\n- Leaderboards\n- Voice chat\n\nIt's quite easy to start playing it but if you want to become a master then well, be prepared for a countless hours spent on the virtual hockey arena. Feel invited to play the game, you will be surprised!", "short_description": "Play hockey in first person view."}]}, "developer_name": "Brosvision s.r.o.", "developer_privacy_policy_url": "http://hockeyplayervr.com/terms-of-use/", "developer_terms_of_service_url": "http://hockeyplayervr.com/terms-of-use/", "publisher_name": "Brosvision s.r.o.", "support_website_url