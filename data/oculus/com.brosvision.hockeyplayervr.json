4", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39003224_511784736012705_1616856617721004032_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dpjx095HyGoQ7kNvgFNvaV0&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYABTCtuK_xYpW7tcQTVcrTJtlNt9W-89PRXt8NHIJNcDw&oe=675820B5"}, {"file_name": "migrated_image.png", "id": "235108140977493", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982559_296345414378321_8211754531084566528_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RN4UvNrRkj0Q7kNvgHtTKWy&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBhLz7MBm5yiKiyp8hkT2Pf4BvGcAtBtDmdWqv4WOu33w&oe=67581C93"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/lZ6Ryf", "id": "2133195983651863", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974506_2133195986985196_2245220671112085504_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pc5fEbykCPoQ7kNvgFAO__k&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDK-w1n1MwI6n_OZxcXo_0SrD2f1n9yYejz3woWfUSzKQ&oe=6758402A"}, "display_name": "Hockey Player VR", "keywords": ["hockey", "sport", "nhl", "multiplayer", "ice"], "long_description": "Play hockey in first person view and develop your own tactics and tricks. Finally, a hockey game where you have 100% control. Test out your puck skills in online multiplayer mode.\n\nFeatures:\n- 4 training modes\n- Multiplayer for 2 or 4 players\n- 100% control\n- Realistic physics\n- Leaderboards\n- Voice chat\n\nIt's quite easy to start playing it but if you want to become a master then well, be prepared for a countless hours spent on the virtual hockey arena. Feel invited to play the game, you will be surprised!", "short_description": "Play hockey in first person view."}]}, "developer_name": "Brosvision s.r.o.", "developer_privacy_policy_url": "http://hockeyplayervr.com/terms-of-use/", "developer_terms_of_service_url": "http://hockeyplayervr.com/terms-of-use/", "publisher_name": "Brosvision s.r.o.", "support_website_u