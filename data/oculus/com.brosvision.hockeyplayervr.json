cdn.com/v/t64.5771-25/39003224_511784736012705_1616856617721004032_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QZcDFYTHWdkQ7kNvgHBCCXH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7DqADqx2yPG0hqKSXA5jtr&oh=00_AYD8CIT_LMzp6QZ6jat4OlUmbc7bHlOFgtkf-EjlXs2xFA&oe=66F54035"}, {"file_name": "migrated_image.png", "id": "235108140977493", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982559_296345414378321_8211754531084566528_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AX3RsGHGfzoQ7kNvgEvA233&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7DqADqx2yPG0hqKSXA5jtr&oh=00_AYBVhQDsoS22GV5bbhIdqZjzxXr0LGptTn0GlI6VLfNq0A&oe=66F53C13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/lZ6Ryf", "id": "2133195983651863", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974506_2133195986985196_2245220671112085504_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TB_yYheFzo8Q7kNvgH-d1fT&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7DqADqx2yPG0hqKSXA5jtr&oh=00_AYCEw2965ZMo7q8onVL75ic48-cwqz1Lfg0CndhK-9pNFA&oe=66F55FAA"}, "display_name": "Hockey Player VR", "keywords": ["hockey", "sport", "nhl", "multiplayer", "ice"], "long_description": "Play hockey in first person view and develop your own tactics and tricks. Finally, a hockey game where you have 100% control. Test out your puck skills in online multiplayer mode.\n\nFeatures:\n- 4 training modes\n- Multiplayer for 2 or 4 players\n- 100% control\n- Realistic physics\n- Leaderboards\n- Voice chat\n\nIt's quite easy to start playing it but if you want to become a master then well, be prepared for a countless hours spent on the virtual hockey arena. Feel invited to play the game, you will be surprised!", "short_description": "Play hockey in first person view."}]}, "developer_name": "Brosvision s.r.o.", "developer_privacy_policy_url": "http://hockeyplayervr.com/terms-of-use/", "developer_terms_of_service_url": "http://hockeyplayervr.com/terms-of-use/", "publisher_name": "Brosvision s.r.o.", "support_website_url": "ht