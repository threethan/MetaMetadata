hClh0HgMoF4ljvAF6enUZCdhWuX4oPx3aA&oe=66F14401"}, {"file_name": "HORIZONTAL_COMP_3 (0-00-33-54).png", "id": "1458793048299052", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035383_1458793051632385_6201125288883864638_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qLJMs-P-B_MQ7kNvgEAT_dI&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ar_v90gFSaRO7V67aZtrtqA&oh=00_AYAvd61068KN7E7PuaVLX79XRWhQM9WvEppU_bLeoxTX2A&oe=66F158FE"}, {"file_name": "Screenshot4.png", "id": "827134765720718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982592_827134769054051_8012892633401113797_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l2UeTxPeOsAQ7kNvgF714mk&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ar_v90gFSaRO7V67aZtrtqA&oh=00_AYAE5ob-2wAuI8x8HwRk41DKkEpevXCXxSOeq6uuL9Cayg&oe=66F15D23"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SaberCity_Trailer_Thumbnail_1.png", "id": "117461424774283", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75639796_117461428107616_4506053201965282111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0WBPxSl1ecQQ7kNvgFyXK9I&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ar_v90gFSaRO7V67aZtrtqA&oh=00_AYByp99Fiu1oFQxQLFRZ68VKnWvQXH-Ed59h0EUKv21mBg&oe=66F1633B"}, "display_name": "Saber City", "keywords": [], "long_description": "Saber City is a 2-player co-located dueling game for Meta Quest. 2 players can link their headsets in the same physical space and battle with melee and ranged weapons. Saber City features mixed reality gameplay, so you and a friend can see each other in the real world ,via the Oculus Quest\u2019s cameras, and battle in AR.\n\n***NOTE:  Saber City is a multiplayer game and requires 2 Meta Quest headsets to play.\n\nIMPORTANT: Please maintain at least 3 feet distance between yourself and the other player. Be aware of your surroundings. Do not run with the headset on.\n\nYou can choose from 4 different character battle kits with unique weapons to wield in mixed reality. The current version of Saber City includes support for Meta Quest Pro and Quest 3.\n\nBattle Kits:\n\nCOWBORG - Cyber cowboy with cattle prod and shotgun\n\nSKYLORD - Hammer wielding warrior from beyond\n\nSKULL CZAR - Possessing dark energy sword and magic bow\n\nSABER SENTINAL - AR soldier with saber and pistol\n\nFor questions and feedback please join the Saber City Discord server: https://discord.gg/EhuQSbNeYV\n\nor contact via email: contact@yarwad.com\n\n", "short_description": "Saber City is a 2 player shared-space dueling game where players battle for supremacy in mixed-reality"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.yarwad.com/sabercityprivacy", "developer_terms_of_service_url": null, "publisher_name": "Yarwad Publishing Empire", "support_website_url": null, "website_url": "https://www.yarwad.com/sabercity", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "989292178968412"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974567_213612351474158_2022969543714240672_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TbNi51-2ffoQ7kNvgGi3xc-&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ar_v90gFSaRO7V67aZtrtqA&oh=00_AYBQSS8OJWuUfT__Jre0nEoLXGGY_vecx7RhhfDvLW3pbA&oe=66F148EE"}, "is_concept": false, "is_test": false, "is_trial_o