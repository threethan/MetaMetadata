ile_name": "backdrop.png", "id": "324032987397879", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982463_324032990731212_9137945319613836111_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l5m5KKDomZMQ7kNvgEjn0O6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYyqMrn-NNb_aTfxJ3WDi1CA4_s7yRUTMJRtDZTK2FZw&oe=67276CE4"}]}, "id": "880595643790616", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "492736460275258", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86625092_492736466941924_3247671518079131392_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RGuvoifm_BkQ7kNvgEyV8e8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFwGuYwWzs1FZRWPLB4-OF9qHlO1SnWzTUBsHzH3kvrw&oe=672750D3"}, {"file_name": "screenshot1.png", "id": "2831163313724379", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974468_2831163320391045_6625642741675889539_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RBjKO8UU8DkQ7kNvgGtSwQ4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUP1sCX2F1dSZkG0lDO_HjmOSAchLkVeglHkUfr4tqgw&oe=6727451A"}, {"file_name": "lostrooms1.png", "id": "936118161662883", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031569_936118164996216_4916112338171934752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ln4zINFe6Q4Q7kNvgFogMhf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABD8rRFg86jJefBPUf8IELdM-95OevlR-3tiVFW6TdvA&oe=672751E2"}, {"file_name": "lostrooms2.png", "id": "8852489891448218", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031354_8852489901448217_1171953163224386872_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=byPd3R7WFrIQ7kNvgGKgxyj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAG9Y51CCN0MZ5hgqCDlg-bwMPC3kPTCgF4ERuUg58nUA&oe=672754BE"}, {"file_name": "lost rooms 3.png", "id": "1093681705759567", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982538_1093681712426233_288620176058379747_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5RVr3ms3tE0Q7kNvgE-f9pB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoIO-lA7yQQG5Yir-B0E4RZ99qqlFZKIJcitq3VYpEsg&oe=67276E9F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Lost Rooms", "keywords": [], "long_description": "Lost Rooms is a thrilling VR game where players explore the eerie and infinite maze of the Backrooms, a series of seemingly endless, interconnected rooms with unsettling vibes. What sets Lost Rooms apart is its unique locomotion system inspired by Gorilla Tag. Instead of traditional VR movement, players use their arms and hands to physically propel themselves through the environment, climbing walls, vaulting over obstacles, and navigating tight spaces. The game combines the creepy, mysterious atmosphere of the Backrooms with the dynamic, immersive movement mechanics, making each exploration tense and exhilarating.", "short_description": "Lost Rooms is a VR game where you explore the eerie Backrooms using Gorilla Tag-style locomotion. Propel yourself through endless, unsettling rooms by physically climbing, jumping, and vaulting, blending horror with dynamic, immersive movement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/lost-rooms-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ronkos", "support_website_url": null, "website_url": "https://sites.google.com/view/lost-rooms-vr/about", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supporte