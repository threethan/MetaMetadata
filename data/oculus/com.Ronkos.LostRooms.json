ile_name": "backdrop.png", "id": "324032987397879", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982463_324032990731212_9137945319613836111_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=shQLr4XX_tUQ7kNvgG2fd_W&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmw3Dfc5netBEpyyOyL8cN8HiRuAPr3MpXHH3OToqdQQ&oe=675C28E4"}]}, "id": "880595643790616", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "492736460275258", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86625092_492736466941924_3247671518079131392_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SV4Wf0oLDfgQ7kNvgE0xEqt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYIIadJuY0jHUJxvU3RcpIi2WqzNQ80pQaqQs796RQEw&oe=675C0CD3"}, {"file_name": "screenshot1.png", "id": "2831163313724379", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974468_2831163320391045_6625642741675889539_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Y2V5JTmg3EQ7kNvgG4jb8p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAA35grZSVc2jkqngWYEkq3taT0hxKR0qMvFx9r-AcCBQ&oe=675C395A"}, {"file_name": "lostrooms1.png", "id": "936118161662883", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031569_936118164996216_4916112338171934752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lpZ8PdeIzowQ7kNvgFdp9l-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAy3zJl4v2CtQpZ_jfwF30I-kLlDZVsGTXFWkDzwVzs3Q&oe=675C0DE2"}, {"file_name": "lostrooms2.png", "id": "8852489891448218", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031354_8852489901448217_1171953163224386872_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yjYjREIu7i4Q7kNvgGtdhuL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxd01wSkMmAm-AUB4e0AnLvHuL6CUMSkqe-RTjMLLRwA&oe=675C10BE"}, {"file_name": "lost rooms 3.png", "id": "1093681705759567", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982538_1093681712426233_288620176058379747_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RtoPtCbn4OAQ7kNvgHv0gdS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5TGPGIsDEwcbWsFWe75UEXaPk2RvdrtP72x4LCCvqFQ&oe=675C2A9F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Lost Rooms", "keywords": [], "long_description": "Lost Rooms is a thrilling VR game where players explore the eerie and infinite maze of the Backrooms, a series of seemingly endless, interconnected rooms with unsettling vibes. What sets Lost Rooms apart is its unique locomotion system inspired by Gorilla Tag. Instead of traditional VR movement, players use their arms and hands to physically propel themselves through the environment, climbing walls, vaulting over obstacles, and navigating tight spaces. The game combines the creepy, mysterious atmosphere of the Backrooms with the dynamic, immersive movement mechanics, making each exploration tense and exhilarating.", "short_description": "Lost Rooms is a VR game where you explore the eerie Backrooms using Gorilla Tag-style locomotion. Propel yourself through endless, unsettling rooms by physically climbing, jumping, and vaulting, blending horror with dynamic, immersive movement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/lost-rooms-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ronkos", "support_website_url": null, "website_url": "https://sites.google.com/view/lost-rooms-vr/about", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supporte