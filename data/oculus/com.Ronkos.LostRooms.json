4f10_sLnfXk_ICfBwV7nPyDwfwPfg&oe=677BB0D3"}, {"file_name": "screenshot1.png", "id": "2831163313724379", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974468_2831163320391045_6625642741675889539_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=37lamPm81cwQ7kNvgHEfjdV&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD1GFTipWDf7-3v8hudhfsBOPtWBMh-TnrYFjeOdXhFLA&oe=677BDD5A"}, {"file_name": "lostrooms1.png", "id": "936118161662883", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031569_936118164996216_4916112338171934752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6DkgXe9BUHEQ7kNvgHaJsW8&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCSkLrXhGxzHh_NUWmzzT_2Z0d2kWDyHK0lJYCCIpp0mw&oe=677BB1E2"}, {"file_name": "lostrooms2.png", "id": "8852489891448218", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031354_8852489901448217_1171953163224386872_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4nhj-XX3x3wQ7kNvgHNJIMF&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCp6Anh780MaTvCiPUbXO_FYPrJWWiiuyCjBXkDBoTzAA&oe=677BB4BE"}, {"file_name": "lost rooms 3.png", "id": "1093681705759567", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982538_1093681712426233_288620176058379747_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CB9gqJlZHPQQ7kNvgHswT_a&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCotMhNNcdx9TAdoRNpmBicJi-rSlm7Cmtv-9ERBS2j9Q&oe=677BCE9F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Lost Rooms", "keywords": [], "long_description": "Lost Rooms is a thrilling VR game where players explore the eerie and infinite maze of the Backrooms, a series of seemingly endless, interconnected rooms with unsettling vibes. What sets Lost Rooms apart is its unique locomotion system inspired by Gorilla Tag. Instead of traditional VR movement, players use their arms and hands to physically propel themselves through the environment, climbing walls, vaulting over obstacles, and navigating tight spaces. The game combines the creepy, mysterious atmosphere of the Backrooms with the dynamic, immersive movement mechanics, making each exploration tense and exhilarating.", "short_description": "Lost Rooms is a VR game where you explore the eerie Backrooms using Gorilla Tag-style locomotion. Propel yourself through endless, unsettling rooms by physically climbing, jumping, and vaulting, blending horror with dynamic, immersive movement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/lost-rooms-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ronkos", "support_website_url": null, "website_url": "https://sites.google.com/view/lost-rooms-vr/about", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8694412967284119"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1648278919077957"}]}, "baseline_offer": {"id": "1648278919077957"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729191600, "status": "PUBLISHED", "id": "1648278919077957"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8351697744888978", "version": "0.01"}, "id": "1900965487085408", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename"