302_101911450301399_4330276355284402176_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DMRivyEnj3wQ7kNvgHoyr7l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeSmDxTXHIkSgGE_wzUpDvSL171YtBgqpC3cI0lwyAcg&oe=671F6BE8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Duel VR", "keywords": ["multiplayer", "fps", "arena", "shooter", "duel"], "long_description": "Enter the virtual reality and become the best duelist!\nThe Duel is a multiplayer FPS (first person shooter) for the Samsung GearVR. You can play against the AI, or even better, challange someone else! You fight for your life in the 80's inspired neon sci-fi world. Jump around the cliffs by swipeing and shoot down your opponent. Charge your shot by holding on the touchpad on your GearVR.\nDo you have what it takes to become the champion?\nThe game was created for the 2017 Budapest PlayIT show as a tech demo, but after the overwhelming success it's available in the Occulus store!", "short_description": "In the year 2544 technology overtook the human race. The remaining people roam the barren neon wasteland. You are alone. You meet a hostile stranger on the cliffs in a gravitational anomaly, he attacks you but you dodge it. It's you or him. Fight!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.pocketgames.eu/privacy", "developer_terms_of_service_url": "http://www.pocketgames.eu/terms", "publisher_name": "Pocket Games Ltd.", "support_website_url": null, "website_url": "http://www.pocketgames.eu/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes