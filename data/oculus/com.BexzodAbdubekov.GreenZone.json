1_969196394885208_7115778398273723767_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U7TxP2T8l9QQ7kNvgFcWZHX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCABkmSGHdxfECXGWGwWVXNr9xLUBYCDSFSbljvaMJxWw&oe=671CE71E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "25601440.png", "id": "1009902807136482", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031425_1009902810469815_1845567791388563259_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2uI86VR4Z1MQ7kNvgGK7h4u&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDM6zUudUhKkWiilGAQNnJzhEizocrVZCzL6_53jf4tQ&oe=671CCA64"}, "display_name": "Green Zone", "keywords": [], "long_description": "Immerse yourself in a post-apocalyptic world filled with toxic zombies in this thrilling Oculus Quest game. Players must navigate through a variety of environments, each presenting unique challenges and threats. Equip yourself with a diverse array of weapons, from firearms to explosives, and strategically place mines and barriers to fortify defenses. As you progress, you'll need to defend cities from waves of relentless zombies, using every tool and tactic at your disposal. Master the art of survival, adapt to changing scenarios, and unlock new levels and equipment to enhance your fighting capabilities. This intense VR experience not only tests your combat skills but also your ability to strategize under pressure. Prepare for an adrenaline-pumping adventure that keeps you on the edge of your seat!", "short_description": "Survive amidst toxic zombies in diverse locations in this new Oculus Quest game! Defend cities using an arsenal of weapons, mines, and barriers. Discover unique tactics and strategies to fight for your life!"}]}, "developer_name": "Bexzod Abdubekov", "developer_privacy_policy_url": "https://www.facebook.com/permalink.php?story_fbid=122108972456316995&id=61559509877826", "developer_terms_of_service_url": null, "publisher_name": "Bexzod Abdubekov", "support_website_url": n