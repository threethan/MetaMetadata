ps://scontent.oculuscdn.com/v/t64.5771-25/38984443_771949241669310_8954657424478505704_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KMj4V1C2X_MQ7kNvgHXScBw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiWfrgAh5F3qBfs2T1ZKr0V&oh=00_AYBYuAnCoKKuZrNRQzmqJNcCdPg6YO9KmZsygT_efAIRHw&oe=66EAB63D"}, {"file_name": "sc3.png", "id": "1137471304069427", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_1137471307402760_7212815590231567740_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hqh4blVxTxsQ7kNvgGkf0lI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiWfrgAh5F3qBfs2T1ZKr0V&oh=00_AYDBhR_EQ8V45ptdBxN_LhwuU53mIvdD6vyzvweSB-IjtA&oe=66EA9D2A"}, {"file_name": "sc5.png", "id": "969196391551875", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520131_969196394885208_7115778398273723767_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e47zbIkguX0Q7kNvgFjuFIB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiWfrgAh5F3qBfs2T1ZKr0V&oh=00_AYAruzpYvuzp3HcJ7QneM_7jTKP66L-rLsLluClCOjcXtA&oe=66EACE1E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "25601440.png", "id": "1009902807136482", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031425_1009902810469815_1845567791388563259_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SKO5w7_wC7QQ7kNvgH_9mvs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiWfrgAh5F3qBfs2T1ZKr0V&oh=00_AYAz1vK9z3r-drnMbe0XyL3w7FLPISSyCl8oYJFoZ3XrcQ&oe=66EAB164"}, "display_name": "Green Zone", "keywords": [], "long_description": "Immerse yourself in a post-apocalyptic world filled with toxic zombies in this thrilling Oculus Quest game. Players must navigate through a variety of environments, each presenting unique challenges and threats. Equip yourself with a diverse array of weapons, from firearms to explosives, and strategically place mines and barriers to fortify defenses. As you progress, you'll need to defend cities from waves of relentless zombies, using every tool and tactic at your disposal. Master the art of survival, adapt to changing scenarios, and unlock new levels and equipment to enhance your fighting capabilities. This intense VR experience not only tests your combat skills but also your ability to strategize under pressure. Prepare for an adrenaline-pumping adventure that keeps you on the edge of your seat!", "short_description": "Survive amidst toxic zombies in diverse locations in this new Oculus Quest game! Defend cities using an arsenal of weapons, mines, and barriers. Discover unique tactics and strategies to fight for your life!"}]}, "developer_name": "Bexzod Abdubekov", "developer_privacy_policy_url": "https://www.facebook.com/permalink.php?story_fbid=122108972456316995&id=61559509877826", "developer_terms_of_service_url": null, "publisher_name": "Bexzod Abdubekov", "support_website_url": null, "website_url": "https://www.facebook.com/61559509877826/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7539303849513004"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "7279299522188941"}]}, "baseline_offer": {"id": "7279299522188941"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719939613, "status": "PUBLISHED", "id": "7279299522188941"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7604573366319385", "version": "10.5"}, "id": "1127824978543523"