ontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982552_1169135374420388_6293911121741024416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2FmMa9vKmyEQ7kNvgEfD27I&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAozrJnynfUq-oTmgr7X-sBnG4CYMWuKqn0Cpm-AUQGCA&oe=6731FF63"}, {"file_name": "04.png", "id": "1520189882206418", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974634_1520189885539751_7692488707065977719_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ghVIfUMmhboQ7kNvgF-pqR4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0PFJnAknco8_jnvDWQZZD-4mxrUgLCv_awgIxiqKlvQ&oe=6731EDA3"}, {"file_name": "05.png", "id": "2761596014023435", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031470_2761596017356768_4889208200295540953_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ucJ9EV1yrfQQ7kNvgFcD1LY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAj7pYQOFRpqPMB6dgQtIRwxfJsMQkeTjnnBu_sXpsVHg&oe=6731D3CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-page.png", "id": "1010717270281535", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031363_1010717273614868_2908544520494993945_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iP7KsiWEiQcQ7kNvgFqc5Dq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYdBxXDUmzcBHaMk8QVQoK-fC_7xoHQk4xuFWngxj1Bw&oe=6732048B"}, "display_name": "Sportsverse", "keywords": [], "long_description": "**Dive into a dynamic and immersive sports experience with multiple interactive elements and a variety of games.** \n\n\n**Here\u2019s what\u2019s included in this launch:**\n\n\n**Features:**\n- Cricket: Swing your bat like a pro in a thrilling cricket experience.\n- Darts: Aim for the bullseye in our realistic dart game with precise controls.\n- Archery: Test your precision and skill with our archery challenges.\n- Bowling: Knock down pins in a fully immersive bowling alley.\n- Basketball: Shoot hoops and practice your dribbling in a fun and interactive basketball setup.\n\n\n**Interactive Elements:**\n- Music Drum Set: Create your own beats and enjoy the rhythm.\n- Joy Ride: Take a fun ride and explore the environment.\n- Disc Shooting Game: Test your reflexes and accuracy.\n- Firecracker Celebration Gun: Celebrate with a bang using our firecracker gun.\n- Can Knockdown: Challenge yourself with a classic can knockdown game.\n- Interactive Pet Dogs: Play and interact with adorable pet dogs.\n- Whack a Mole: Enjoy the classic fun of whacking moles popping up.\n\nRoam and explore these interactive elements within the environment to enhance your Sportsverse experience.\n\n\nDownload now and start your Sportsverse journey!\n", "short_description": "Welcome to the first release of Sportsverse! Dive into an exciting sports experience with interactive elements and games like cricket, darts, archery, bowling, and basketball. Enjoy realistic physics, intuitive controls, and stunning graphics that bring each sport to life. Download now and start your Sportsverse journey!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zudolabs.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Zudo Labs", "support_website_url": null, "website_url": "https://www.zudolabs.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1672577396871977"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8013569135392559"}}]}, "schedule