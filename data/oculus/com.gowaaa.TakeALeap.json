kZb8-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPMKxHNW3BTEW_u0OxnDuS7w18MdKHmoaVDnwXLUiOrA&oe=6714E4C1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape.png", "id": "1734306984040066", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982458_1734306987373399_4942166436161752495_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWtruRiRo4sQ7kNvgEIzfUo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBuyZY4DgDwLjHOA0JMTqUy63kpZX9Nf0v8Abcd78mCdQ&oe=6714EABB"}, "display_name": "Take a Leap", "keywords": ["easy", "casual", "Bussin", "Flex", "Rizz"], "long_description": "When was the last time you took a leap of faith? \n\nThis game strips everything back to basics \u2014 no frills, no distractions. Just you, your courage, and the thrill of the jump. Whether you're playing on your stove, ceiling, window, or door, all you need is one hand or one controller to leap forward. \n\n And when you fail? Get back up and leap again.", "short_description": "When was the last time you took a leap of faith? \n\nThis game strips everything back to basics \u2014 no frills, no distractions. Just you, your courage, and the thrill of the jump. Whether you're playing on your stove, ceiling, window, or door, all you need is one hand or one controller to leap forward. \n\n And when you fail? Get back up and leap again."}]}, "developer_name": "Lost Mood", "developer_privacy_policy_url": "https://lostmood.notion.site/Lost-mood-data-privacy-policies-04400bffc2da4e68acdb08cf33f08eb6?pvs=74", "developer_terms_of_service_url": null, "publisher_name": "Lost Mood", "support_website_url": null, "website_url": "https://www.tiktok.com/@lostmood.co", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "inter