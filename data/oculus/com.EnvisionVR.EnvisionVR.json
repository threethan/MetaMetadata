kNvgEECw8l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnloZaVXKAAd3KF3DZJL2RUMTFyeSikUWpIazygNBWiA&oe=673F3197"}, {"file_name": "Screenshot 5.png", "id": "205951574795327", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035418_205951578128660_1579138383483255034_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6TzQXrD4ypEQ7kNvgESABkq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBVkK4LA4SXRFrLNTx4qabZZaKIFxa6PI6Pvuy1GCBxTQ&oe=673F1EA1"}, {"file_name": "Screenshot 4.png", "id": "416625599619788", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974463_416625602953121_7594553924077517136_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DYcFzxNOmk8Q7kNvgFev_um&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAn2Pl3SSwGTijqlxdxhlqq4e128l98y8ZzJLWBj6GQVw&oe=673F1CF0"}, {"file_name": "Screenshot 1.png", "id": "919430915620427", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982450_919430918953760_3431993627679132075_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dhBqTcY7c1IQ7kNvgFAmlBT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBL6GL2_4i8v5ZNaEfpRg40Q52yZ5qg_viwB12_-9brPQ&oe=673F2272"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Thumbnail.png", "id": "1003097757117807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569468_1003097767117806_5720121769644944108_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SAPhW1z6ptYQ7kNvgFrt6fn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQPFyKh9lO3o0BMG6g56Pu6-UGD6chrdxWYfmqUtDerg&oe=673F17D4"}, "display_name": "EnvisionVR", "keywords": [], "long_description": "Our EnvisionVR app allows you to view your future projects in high-fidelity Virtual Reality.\n\nCreate virtual inspections of your off-the-plan properties in VR. You can talk to buyers in real-time, explain what they are seeing and navigate them throughout the property.\n\nOff-the-plan properties have been sold in the same way for years with brochures, high-quality photo renders, and stylish display suites. Whilst they do the trick, here at EnvisionVR we like to take things to the next level. That's why we created our world-first EnvisionVR app which allows you to view your future project in high-fidelity Virtual Reality and Augmented Reality using a VR headset or smart device. Our VR experiences are completely mobile, multi-person and collaborative coupled with an easy- to-use interface that will enhance your sales process.", "short_description": "Our EnvisionVR app allows you to view your future projects in high-fidelity Virtual Reality.\n\nCreate virtual inspections of your off-the-plan properties in VR. You can talk to buyers in real-time, explain what they are seeing and navigate them throughout the property."}]}, "developer_name": null, "developer_privacy_policy_url": "https://envisionvr.net/app-privacy-policy/", "developer_terms_of_service_url": "https://envisionvr.net/app-terms-of-use/", "publisher_name": "Envision VR Pty Ltd", "support_website_url": null, "website_url": "https://envisionvr.net/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "472978657736445"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "424431802146958"}]}, "baseline_offer": {"id": "424431802146958"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1628