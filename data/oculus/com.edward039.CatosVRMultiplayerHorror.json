m/v/t64.5771-25/75340711_483202763945694_4137255736493102900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gUycubhhdMoQ7kNvgHdgGmh&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBzs9cnz-iZ-Qeatj0Z5lt_qnKIpbPJVf2UcLfwcYmeDw&oe=671A36C4"}]}, "id": "3265498780432759", "locale": "en_US", "screenshots": [{"file_name": "screenshot 5.png", "id": "1295199511212878", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982649_1295199521212877_6458952947052672854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8SV4Ye_pWR4Q7kNvgFOtNBW&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDd4zmw4FjgYaM9Otr6KCsTSmQKeEEhaxvaxCf4Krvy8Q&oe=671A4E43"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_FQdpc9l7r4Q7kNvgE798Gl&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCq3kk9Lq7QMh_AGvbYkhnsuHde7K94haAG02Egy53jWA&oe=671A2753"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hkMbwEAjGcwQ7kNvgHhdzKg&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYB6RyDv7P0M7FMfASm35KWYCoVz9E09JnrMPFMLr-YXJw&oe=671A3F55"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=79_O_y2oA6sQ7kNvgGpfwfB&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBEwlJdC2TPIptzMTqOKImopzoUYU-I_qn935XY1u1z8Q&oe=671A1FB8"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I1VqX9kEKWYQ7kNvgFgXQoN&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBTgKISwSEE1NWe8ATDJe9xUmvBrI--6jiXYhuSGGw1iQ&oe=671A265A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A0FB3xaVnHsQ7kNvgEskvw1&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCFjpqbNWLVLT4Hhw6mIZxOVI4_mVuqiQuW_D4B76liyQ&oe=671A2BFC"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6