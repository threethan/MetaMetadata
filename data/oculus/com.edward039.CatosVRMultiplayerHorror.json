=1-7&_nc_sid=6e7a0a&_nc_ohc=Q8iceJSclj0Q7kNvgEKBYVY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZHEGqwJEb8D51PsyTlhsOTl6j2HKzi8PR7WEaL9BxPg&oe=66FD4D43"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VA4QNZoqV3gQ7kNvgEnvE_0&_nc_ht=scontent.oculuscdn.com&oh=00_AYCA4SbMDwSmE-28vFvqWGyai3IpaqISFxZOD-XpEWmc5w&oe=66FD2653"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HeLIUZFqd8YQ7kNvgGMZWL8&_nc_ht=scontent.oculuscdn.com&oh=00_AYACe2BuN1Jp54irITyIKLYxE59CIYryNKt4mWlnPG0uzA&oe=66FD3E55"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KJOoMsp2ZWoQ7kNvgHhjGxH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeh6XGJqgrTU6Qnd1XO6mh1A-JAWvXB99Dj0FgvaUBjg&oe=66FD1EB8"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=712D6V7m6_MQ7kNvgG2vor3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCABqL9iDLOtYXA3uVNu7fTvjI_iZl8Tbg6Rnl7haMsBA&oe=66FD255A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IQaDMTkgR1wQ7kNvgH6W38i&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5jFrjuud4llsd37ADOg22ktL8Jvh7UVeR0HFx58s6KA&oe=66FD2AFC"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6MT-EqLElEarBumhh0yoj_LrrVNxP8FTubM/", "developer_terms_of_service_url": null, "publisher_name": "edward039", "support_website_url": null, "website_url": "https://linktr.ee/edward039", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SPORTS", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_