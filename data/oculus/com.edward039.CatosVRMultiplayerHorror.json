08oZhZxJOaGWrc_C7l4PTK7bZoFQ15W8P9z-1OHEExw&oe=670FAAC4"}]}, "id": "3265498780432759", "locale": "en_US", "screenshots": [{"file_name": "screenshot 5.png", "id": "1295199511212878", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982649_1295199521212877_6458952947052672854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dKnaCFrB194Q7kNvgGUR7GP&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAw1K6gMT1cHeLa0CAceZ95ONj3otOuPcXiN0B6Ri-hsw&oe=670F8A03"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6J7K-bzVh-0Q7kNvgHLHYaJ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDBnuCH8GbZdsz-2IrR_T10ORgC-nD3D-Qsozbq7TbFDQ&oe=670F9B53"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ee0FrJCM_RYQ7kNvgH2ZUW7&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCfCzsyg6Gm8bTLJiN0sdxzWPCYNgs4Cjg0_oEZZMFrtA&oe=670FB355"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=naxqbCsn944Q7kNvgHtoMih&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDknAejT984ocCG9azoKDdCr6XmvBKfiXw99SeIzn0dhw&oe=670F93B8"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=91hC4q1vC3sQ7kNvgFxp23g&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDfd-cpO7XULOwaQOkbnqENe5tRJBD7659AAtM42DmZHw&oe=670F9A5A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Widdh82q7LQQ7kNvgGDSaS9&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDbdUWO6Da5_lgt8F-kF9Q2UEOfyJxWVHM7poCCkpCOUQ&oe=670F9FFC"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6MT-EqLElEarBumhh0yoj_LrrVNxP8FTubM/", "developer_terms_of_service_url": null, "publisher_name": "edward039", "support_website_url": null, "website_url": "https://linktr.ee/edward039", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED",