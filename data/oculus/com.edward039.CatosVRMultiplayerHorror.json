V2ZqN86mL9AwLKn6G-TGsyLGZFyPK4AJ39nwtg&oe=66E82FC8"}, {"file_name": "1x1.png", "id": "483202753945695", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340711_483202763945694_4137255736493102900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N_ey7uwrhnQQ7kNvgGebPH0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYBAzN6Ng1odWwuzrFuYUdQpwdB9MTKtC9L5CpL5-8Yzsw&oe=66E81DC4"}]}, "id": "3265498780432759", "locale": "en_US", "screenshots": [{"file_name": "screenshot 5.png", "id": "1295199511212878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982649_1295199521212877_6458952947052672854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WR5yjPI513sQ7kNvgFwBweg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYAEqfqs3d-5mIX-Ac7qYT6icw_ApjX6GUcawzJfoPjNKA&oe=66E7FD03"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NKYe9HKeae0Q7kNvgEX97AN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYA18RJun3oUgyQjmoHHgvBPSPyh1pvkOA5gNBybldz70A&oe=66E80E53"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XwWgLj8gzgUQ7kNvgHWKY12&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYC1tQ-Cg-EVBNCQ6ihZz11dkHwcwyBQkPVAxGUjo67E7Q&oe=66E82655"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FBQDF9iH-MEQ7kNvgGPzgrJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYDBjjlwOG2Ou1mn1LSeAjMyVcH3fAPG5QJyTc-6qEM7HQ&oe=66E806B8"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qwCcP5EOnC0Q7kNvgGOK-pD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYA5hu_bAlx3so4naUYfJ9aDwvCnjljl68cB4jCME4toqQ&oe=66E80D5A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zPF5Abx_-cgQ7kNvgHi1pEl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZwAMktOBu_W-QWGg12bXrS&oh=00_AYDQzQFOEvTmY1eiAd6MMx3akz4fkoOnql5xQ7gRg8xHNg&oe=66E812FC"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6MT-EqLElEarBumhh0yoj_LrrVNxP8FTubM/", "developer_terms_of_service_url": null, "publisher_name": "edward039", "support_website_url": null, "website_url": "https://linktr.ee/edward039", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SPORTS", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "1818081928546082"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2337540449752749"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674669600, "status": "PUBLISHED", "id": "2337540449752749"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7398755406872678", "version": "0.1.3"}, "id": "553564912832294", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5598329350248635", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "73987554068