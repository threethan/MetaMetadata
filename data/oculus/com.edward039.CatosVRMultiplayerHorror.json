nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L0N-nikyFsgQ7kNvgHDp9tY&_nc_ht=scontent.oculuscdn.com&oh=00_AYCaeM8UYFd5v8xqZcmIfsGLMWNByCfJrBv-6TqguY_xDQ&oe=66DC1F83"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LxDSbmH3gcEQ7kNvgFQ-7pV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCcDHxIg1X_CacUahfaN8QOldVGsyEVgTwJEM2Ux24Shg&oe=66DC30D3"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bczegoZFUcsQ7kNvgHxSnY2&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6RmQlqYyMqoARk0er-lKvK8oW2q1RaDAyU8NA0kodcg&oe=66DC48D5"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1To1pZMQbYQ7kNvgHYvUnC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCxG4nIV6nUrbVRiL_d3sFvZNO8RGEoIr85IViwHPgaZg&oe=66DC2938"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wJFSdc2YykAQ7kNvgGz_5my&_nc_ht=scontent.oculuscdn.com&oh=00_AYASAMWK5IoZjBjvh1Vz3PnjH3caIO0CgXiO_dh8CS6LYg&oe=66DC2FDA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ODkiFD26urIQ7kNvgERO0Gi&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWbp6_abvniNCDJdH2NuvC_c_ioc3bTCbMcNI-ZzVJjg&oe=66DC357C"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6MT-EqLElEarBumhh0yoj_LrrVNxP8FTubM/", "developer_terms_of_service_url": null, "publisher_name": "edward039", "support_website_url": null, "website_url": "https://linktr.ee/edward039", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SPORTS", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MO