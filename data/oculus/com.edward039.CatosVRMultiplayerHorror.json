1UXgxGMQNCna8U8rFx55KeOIfNMY9xFA&oe=66EC2448"}, {"file_name": "1x1.png", "id": "483202753945695", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340711_483202763945694_4137255736493102900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_8mbVPFQlCAQ7kNvgG3_Kx8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYCFaV9BLu8wvXwvswD3gxhkPa_XJZnBeFSnZC3uMic8vw&oe=66EC1244"}]}, "id": "3265498780432759", "locale": "en_US", "screenshots": [{"file_name": "screenshot 5.png", "id": "1295199511212878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982649_1295199521212877_6458952947052672854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nu-EzlMzaogQ7kNvgEnq5IV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYDUrN3nZ7InSlEkEaVLSAnUd5D8QAuYt0dk6sQtuvEvtg&oe=66EC29C3"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yg4wB80n5owQ7kNvgGoEO1E&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYBnDvkDXANp4iFW1rm8KYSHr0C0sXKlUfbYO0fmsZ_-cA&oe=66EC02D3"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H7lcIMgJgNwQ7kNvgHNZ_wg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYDQ2fr-hWioU_6s1_DhgFk6yfuBRkujIzCPv4d8wz4T-w&oe=66EC1AD5"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QMWj5J9y8j4Q7kNvgFogkB6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYCGx8GUK-wNiwEOJQTWKv8wpEWEzgUDbQ5pk5Y7yFAnnw&oe=66EBFB38"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GLBwwjnQpC8Q7kNvgG-QgTd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYC_NBYN1OvglqgfC78wBRNj40W66XqmxsuM6lef4UjtWg&oe=66EC01DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PdvUhYGIr-MQ7kNvgFBkBRl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AykT_eLd-sBQVOq6OWcDK14&oh=00_AYAPsYLv-ieAXjRXKvFYRMAk9Nm3asrz5FHERuSBkCYsEg&oe=66EC077C"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6MT-EqLElEarBumhh0yoj_LrrVNxP8FTubM/", "developer_terms_of_service_url": null, "publisher_name": "edward039", "support_website_url": null, "website_url": "https://linktr.ee/edward039", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SPORTS", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "1818081928546082"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2337540449752749"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674669600, "status": "PUBLISHED", "id": "2337540449752749"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7398755406872678", "version": "0.1.3"}, "id": "553564912832294", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5598329350248635", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7398755406872678"