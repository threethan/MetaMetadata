.com&oh=00_AYB0z7gys-r7xg_W-gK_wWA6ZB9toH8jzGyEsGoLGoHadg&oe=676D4544"}]}, "id": "3265498780432759", "locale": "en_US", "screenshots": [{"file_name": "screenshot 5.png", "id": "1295199511212878", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982649_1295199521212877_6458952947052672854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_eC7mDVhUAsQ7kNvgH8D5jd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPYNGPKzxi4NWty7GYfihqos3hzNTWAFYovPPlM0s2FA&oe=676D5CC3"}, {"file_name": "Screenshot 2.png", "id": "1276292999880266", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75441580_1276293003213599_8336904981038554479_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H4gfubT68vEQ7kNvgFUslJZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQcBMrTQstvwSacNCH7ftp5hMYv7YxYzhC0jx_f23WJA&oe=676D35D3"}, {"file_name": "Screenshot 3.png", "id": "952869092342556", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210389_952869095675889_8689739504969989920_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ySgOgmsB2d4Q7kNvgEx4QC-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJ91-LViNXIvnRUzdwik1jntyMcDlQUk7gKY5mKRaPJg&oe=676D4DD5"}, {"file_name": "screensot 1.png", "id": "693565125508198", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75297584_693565128841531_1924786726742599797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YtIKwnKLMeUQ7kNvgHtgcEK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAET3_qgeOh4d_hyDUMcoiegU5AeLI5VbPa7mxG3X1keA&oe=676D2E38"}, {"file_name": "screenshot 4.png", "id": "599255852034780", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75441575_599255855368113_4875613609997393798_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DfnnGK4TkYkQ7kNvgHn9p7h&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxgNWlaob7OhvWzIUR-2L8sFlvo4PzVGerSHvqFPuXaw&oe=676D34DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage2.png", "id": "550828886603208", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75230043_550828889936541_4050318236120305444_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AYBMmg75TvQQ7kNvgGtzpZp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwBttsGflsDPs570R9DuMjsjD8VnRbAFzyojgw2ybsAA&oe=676D3A7C"}, "display_name": "Catos VR: Multiplayer Horror", "keywords": [], "long_description": "Game is based on hand movement, be sure you are wearing straps! \n\nA cat player running away from the monster, ruuuun! A new horror game, where you can find and friend with absolutely random people, run, scream and have fun! You have a display at the spawn area, and a camera on a table. Theres only 1 camera, so make sure everyone is okay if someone takes It! If you are scared, or you all teamed up and want to plant the camera to watch where the monster is, theres a display to look on! It translates cameras live, so you can see whats happening in specific room, place or even with a player! Imagine you all staying in 1 corner, 9 people, waiting for a monster to see how he looks like, and he just arriving from another corner and destroys you! And this one person who was staying in front of the display and he saw you've got killed.. Painful. Oh, whats the map? What corners? Vents!! I found them pretty scary for a horror. Map is pretty big there! Dont forget to take your equipment with you! I think you will need a flashlight :) !\n\n ", "short_description": "An all new multiplayer horror game! You can find new friends, play with just random people and screaaaam! Game is about a cat running away from a monster. If you are bored or dont have a game to play after you bought an Oculus Quest, you might like this one! "}]}, "developer_name": "edward039", "developer_privacy_policy_url": "https://docs.google.com/document/d/1r2ZdKHJC6MT-EqLElEarBumhh0yoj_LrrVNxP8FTubM/", "developer_terms_of_service_url": null, "publisher_name": "edward039", "support_website_url": null, "website_url": "https://linktr.ee/edward039", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SPORTS", "ACTION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "1818081928546082"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2337540449752749"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674669600, "status": "PUBLISHED", "id": "2337540449752749"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7398755406872678", "version": "0.1.3"}, "id": "553564912832294", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5598329350248635", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7398755406872678"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "553564912832294"}]}, "change_log": null, "created_date": 1714771352, "id": "7398755406872678", "version": "0.1.3", "version_code": 170, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "Android