dn.com/v/t64.5771-25/43931327_246141427909407_6276687811146681097_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvjNqF6sSI4Q7kNvgG2EmeQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7ofFR5lGxAdtX_oeZ5uwt&oh=00_AYDKaegXcu-oyOeugS8OEMvgEsF7CCh39ngvj5dHRrNHmA&oe=66F15C72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Poster - Cover.png", "id": "1497330271070248", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982723_1497330274403581_1010539024953878920_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JhxAJGJcF0QQ7kNvgHat1HB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7ofFR5lGxAdtX_oeZ5uwt&oh=00_AYA7j1pR9WLslQMOv-Jue0Ch0aRx4z6In_ceEgATRgtqqg&oe=66F13593"}, "display_name": "If You Are Not Dumb", "keywords": ["mr", "mixed", "reality", "puzzling", "places"], "long_description": "What if a puzzle looks simple BUT you end up feeling dumb!!\n\nIf You Are Not Dumb is a funny and quirky puzzle game.\n\nA game gives you situation based puzzles. A few objects to interact with and One instruction to follow!\n\nEach puzzle has its own logic.\n\nSituations are like -\n- Hide from the eyes, but eyes are everywhere\n- Extinguish fire when there is not water around you\n- Type BOX but without any keyboard!\n\nand many more!!\n\nA game also supports mixed reality! \n\nGive it a try! You will love the puzzles.. or at least you will realise that you are dumb (:\n\nTUK", "short_description": "What if a puzzle looks simple BUT you end up feeling dumb!!\n\nIf You Are Not Dumb is a funny and quirky puzzle game.\n\nA game gives you situation based puzzles. A few objects to interact with and One instruction to follow!\n\nEach puzzle has its own logic.\n\nSituations are like -\n- Hide from the eyes, but eyes are everywhere\n- Extinguish fire when there is not water around you\n- Type BOX but without any keyboard!\nand many more!!\n\nGive it a try! \nTUK"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1splZFw2pxh7oXEIZ2IEvGiG