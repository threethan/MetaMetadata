OHCPQMX3Mcmvchc51_f1ujGawdDBWA&oe=66F3E136"}, {"file_name": "SS 6.png", "id": "2197528600634624", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54770914_2197528603967957_7988230609053349225_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JDppuW-gQUIQ7kNvgG4f4B5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HCgDx-QYmcW0Pd6UqWnc0&oh=00_AYCkPH5SDIF1CB6QaeUNeKjPwjUffOyqxTs9IGYPg_WxhQ&oe=66F3FA74"}, {"file_name": "SS 3.png", "id": "246141424576074", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931327_246141427909407_6276687811146681097_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvjNqF6sSI4Q7kNvgHSfhqz&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HCgDx-QYmcW0Pd6UqWnc0&oh=00_AYDL_oS1od07l5Unfl8KBSbzUc1JOV21amznYswbTpC9Ng&oe=66F3FF72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover.png", "id": "1603695693441392", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984449_1603695696774725_7385735425873954970_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wP771o48vTgQ7kNvgHFdzmd&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-HCgDx-QYmcW0Pd6UqWnc0&oh=00_AYCIfkHBwfvu0J2g61uz0-d_bRSuolYRcSZJJ7IjTfsX8g&oe=66F3E12E"}, "display_name": "If You Are Not Dumb", "keywords": [], "long_description": "Puzzles with the most unexpected solutions in VR.\n- How to put off fire when there is no water?\n- How can you type without any keyboard?\n- Where can you hide from the eyes that see everything?\n- Sunset?? But where is the sun??? \n\nAre you smart enough to solve all puzzle in a game?\n\nStill not sure about a game??\n\nReasons to NOT play this game\n- You are dumb\n- and you are sure about that\n\nReasons to play this game\n- There is not such VR game\n\nEach puzzle is a simple and short instructions\nYou need\n- A working brain\n- Out of the box thinking \n- More than a little patience\n\nI promise you will recommend this game to your friends, family\u2026 Or Enemies for sure (:\n\nReady to test your dumb levels? \nTUK", "short_description": "Puzzles w