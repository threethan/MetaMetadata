pJj0eCoz98K5VSBpOG3_jCnp5Dbi7w&oe=66F532B6"}, {"file_name": "SS 6.png", "id": "2197528600634624", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54770914_2197528603967957_7988230609053349225_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JDppuW-gQUIQ7kNvgH6vGr1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR2l_rDNSUJdCmDosEvDz81&oh=00_AYD0cwiXIi_JciHLSQT53sKHiNQ_9ZzNhUklLWWsXt6Lwg&oe=66F54BF4"}, {"file_name": "SS 3.png", "id": "246141424576074", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931327_246141427909407_6276687811146681097_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c5IRLU0zaTQQ7kNvgFo0oUl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR2l_rDNSUJdCmDosEvDz81&oh=00_AYBcEjIkDxvQtwdyNLPT2K0IbKRsvXTCubJFh-0jIKRwMw&oe=66F550F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover.png", "id": "1603695693441392", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984449_1603695696774725_7385735425873954970_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zsUe5AThhVgQ7kNvgHpoM0z&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR2l_rDNSUJdCmDosEvDz81&oh=00_AYD0IkRF7kDY4DS0w4hwnBsn-8tZiLXPoW3bQGYyxfiRUg&oe=66F532AE"}, "display_name": "If You Are Not Dumb", "keywords": [], "long_description": "Puzzles with the most unexpected solutions in VR.\n- How to put off fire when there is no water?\n- How can you type without any keyboard?\n- Where can you hide from the eyes that see everything?\n- Sunset?? But where is the sun??? \n\nAre you smart enough to solve all puzzle in a game?\n\nStill not sure about a game??\n\nReasons to NOT play this game\n- You are dumb\n- and you are sure about that\n\nReasons to play this game\n- There is not such VR game\n\nEach puzzle is a simple and short instructions\nYou need\n- A working brain\n- Out of the box thinking \n- More than a little patience\n\nI promise you will recommend this game to your friends, family\u2026 Or Enemies for sure (:\n\nReady to test your dumb levels? \nTUK", "short_description": "Puzzles w