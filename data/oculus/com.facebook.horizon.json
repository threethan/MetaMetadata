683173823658796256_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PURZ7hQ40XAQ7kNvgF9053h&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFtyHFHcPf7I0nhmHd86_MijSrXJUHItNy4kDsChjIDg&oe=6739BF2F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape(2560x1440).png", "id": "339551810558030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75557068_339551817224696_555420546150037652_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fEdxO4GgTeEQ7kNvgEbWR16&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzw23ThAc3IQ9-St0BetZNmQg8lizjpElP6VSTpPKtdg&oe=6739DAB2"}, "display_name": "Facebook Horizon", "keywords": ["create", "social", "multiplayer", "explore", "free"], "long_description": "Welcome to Facebook Horizon, a social experience where you can explore, play and create. With new worlds in the making, you can join together with people around the world in ever-expanding adventures and amazing experiences. Discover new places with friends, solve interactive puzzles or form teams to compete in action-packed games. You can even design worlds of your own or get to know other members of the community and be inspired by their creations. In Horizon, you're not just a visitor. You're part of what makes it great.\n\nTo join the beta waitlist, please visit http://www.oculus.com/facebook-horizon", "short_description": "Facebook Horizon is a social experience where you can explore, play and create. In Horizon, you\u2019re not just a visitor. You're part of what makes it great. To join the beta waitlist, please visit http://www.oculus.com/facebook-horizon"}]}, "developer_name": "Facebook", "developer_privacy_policy_url": "https://www.oculus.com/legal/horizon-data-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/horizon-terms-of-service/", "publisher_name": "Facebook", "support_website_url": null, "website_url": "http://www.oculus.com/facebookhorizon", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MO