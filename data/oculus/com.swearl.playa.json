-lhr6-2.oculuscdn.com/v/t64.5771-25/38974887_1758103468034655_4389833857858152046_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EEH13cwp60EQ7kNvgEMZFJs&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCUyTMOU2GUgmpWkpskqIrj8uWzoe2mwDoK2tCAxkag2g&oe=67164CF1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_thumb.png", "id": "120641316606379", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75240108_120641319939712_3168964486158324537_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t6QkTZZqwhgQ7kNvgE3kB5L&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDWM1uUhMYpKEpxepi5jEm_huGqhXVG1fpKi01hGiHe-A&oe=67163EA7"}, "display_name": "PLAY'A Video Player", "keywords": [], "long_description": "Exclusive to users that don\u2019t like complications - PLAY'A is the versatile virtual reality video player created to match a busy lifestyle.  Whether its a simple and intuitive interface, a very hip contemporary design, playback from local file storage or streaming from the network connected servers, PLAY\u2019A does it right and it does it with style! \n\nNavigation is easy in and out of VR. Just jump on a couch and turn it on - you are ready to go!\n\nAt their fingertips, the users like you will find:\n- 2D, 3D, flat, fisheye, 180\u00b0 and 360\u00b0 Videos automatically recognized\n- Picture viewer with slideshow\n- 8K video support (Oculus Quest 2)\n- Most video formats supported\n- Intuitive user interface\n- Shake smoothing\n- Privacy modes\n- Convenient folder navigation\n- Picture adjustments: brightness, contrast, saturation, sharpen, tint, temperature\n- VR Video adjustments: tilt, height, zoom, playback speed\n\nJust download and see it for yourself ! ;)", "short_description": "Exclusive to users that don\u2019t like complications - PLAY\u2019A is the versatile virtual reality video player created to match a busy lifestyle.  Whether it is a simple and intuitive interface, a very hip contemporary design, playback from local file storage or streaming from the network connected servers, PLAY\u2019A does it right and it does it with style! \n\nNavigation is easy in and out of virtual reality. Just jump on a couch and turn it on - you are ready to go!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://playavr.com/privacy", "developer_terms_of_service_url": "https://playavr.com/terms", "publisher_name": "Swearl, LLC", "support_website_url": "https://playavr.com/contact", "website_url": "https://playavr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6692258470903807"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035308_2908931336018724_6418101513512440507_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZQGZbZDCntQQ7kNvgEN-vdP&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYA3gRGlktQ4f_xFybXHG4qMXNJ9cMO9wq_SY9HE6O2NQg&oe=67163678"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PLAY'A Video Player", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Media & Streaming", "id": "384928226018505"}], "release_date": 1617065190, "lastRevision": {"nodes": [{"id": "475735300255798", "release_type": "SCHEDULED", "administ