: "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974703_1039291073729370_4733580831308276218_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vOcRt1w_QBQQ7kNvgHgFJd-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpVItyW_-tpT66faRMpEXAljrGf5GrMXkthemZtf5EFQ&oe=6703C6FF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_landscape.png", "id": "1089215391856861", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982514_1089215395190194_5023217157685857883_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpKl16tuQPkQ7kNvgE-hvBb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3OcUqd5RtgKoCsuFAcX7rF_9qmbmBy2sIW3F0zLGa3A&oe=6703D808"}, "display_name": "Till Tomorrow Demo", "keywords": [], "long_description": "As an adventurer, you\u2019ve been thrown into a remote island by a fierce storm. You must survive on and escape from it eventually.\n\nBuild your skill set for living in the wild along the journey, no matter it is forking fishes, hunting with bows, farming, or making houses! Those will definitely help to realize your goal and build up the gears needed for your next challenge.   Have great adventures to explore the 'dark forest' where you may need to fight against mystery malicious creatures and collect treasures as a reward.   No one knows what risks you'll have to resolve till tomorrow\u2026\n\nJoin discord: https://discord.gg/qMkyDn4NEM\n\nWe are a tiny indie VR game studio and it will be awesome to hear what you think about the game, good or bad. Looking forward to hearing from you all!\n\nTry out the Early-Access release version here:\nhttps://www.oculus.com/experiences/quest/4825294284255836/\n\n*Multiplay mode* is available for the early-access version NOW! Build and explore the islands with friends together!", "short_description": "When rescue does not seem possible, can you survive along with the island? Hunting, farming, building, crafting to thrive on the island.\n\nMultiplay mode is available for the early-access version NOW! Build and explore the islands with friends together!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://fvworks.github.io/TillTomorrow/privacy/", "developer_terms_of_service_url": null, "publisher_name": "self", "support_website_url": null, "website_url": "https://fvworks.github.io/TillTomorrow/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "334906195547638"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569484_596630134895079_7288430088171191098_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=seEAmhGzpzoQ7kNvgEB-jX7&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCg_1b4QVq2JsHxybfW5WVB5K28psBmhsKoPtgTX51GdQ&oe=6703BB1A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Till Tomorrow Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1643327649, "lastRevision": {"nodes": [{"id": "863172351170875", "release_type": "SCHEDULED", "administration_status"