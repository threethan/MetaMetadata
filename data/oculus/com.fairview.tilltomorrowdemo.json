771-25/38974635_338683468099435_4070775363608675625_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_0q5YKR10_MQ7kNvgHlH4fq&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDnBROWdK5l3Y3fZeWUyLld_i4rB1DSATUoNGzEyHukKA&oe=671A275B"}, {"file_name": "4.png", "id": "628257738498498", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75404377_628257741831831_5666057631159280683_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w8jBgVYLozEQ7kNvgGbgZs2&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAtGVJ8H-8i-Z-t0u0BUte0LMBhFkAN5y1EMYVQCdiy7Q&oe=671A33C8"}, {"file_name": "1.png", "id": "200507732269830", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/57569442_200507735603163_6465344700726325110_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GNVWSxyQ1SoQ7kNvgHThI4i&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYB_mk73njIhw10Fd4E0GOWncuMDQZl16BlcAe-QhkqY5A&oe=671A1845"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Till Tomorrow Demo", "keywords": [], "long_description": "As an adventurer, you\u2019ve been thrown into a remote island by a fierce storm. You must survive on and escape from it eventually.\n\nBuild your skill set for living in the wild along the journey, no matter it is forking fishes, hunting with bows, farming, or making houses! Those will definitely help to realize your goal and build up the gears needed for your next challenge.   Have great adventures to explore the 'dark forest' where you may need to fight against mystery malicious creatures and collect treasures as a reward.   No one knows what risks you'll have to resolve till tomorrow\u2026\n\nWe are a tiny indie VR game studio and your comments/reviews are the fuel for us to continuously update the game! So talk to us with any of your thoughts about the game. They'll be greatly appreciated. BTW, multi-player mode is on the way\u2026", "short_description": "When rescue does not seem possible, can you survive along with the island? Hunting, farming, building, crafting to thrive on the island."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fvworks.github.io/privacy/", "developer_terms_of_service_url": null, "publisher_name": "self", "support_website_url": null, "website_url": "https://fvworks.github.io/TillTomorrow/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "536186340787139"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24200571182874653", "version": "0.7.0.20"}, "id": "288582003215273", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7067531616605210", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "24200571182874653"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "288582003215273"}]}, "change_log": null, "created_date": 1694155921, "id": "24200571182874653", "version": "0.7.0.20", "version_code": 59, "release_status": "RELEASED", "status": "APPROVED", "binary_test_r