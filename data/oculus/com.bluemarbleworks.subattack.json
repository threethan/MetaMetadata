: {"file_name": "SubAttackCoverLandscape.png", "id": "2026642160806481", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974879_2026642170806480_2105458039432183189_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bdQ7EPj3N58Q7kNvgGu6Gta&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3Pixr4fw-nSuGsR7bSpf8GDVkgRf8q1F2c5q40FSCcQ&oe=670D14D6"}, "display_name": "Sub Attack", "keywords": [], "long_description": "Command your own World War II era submarine and accept your dangerous mission to sink enemy ships, but watch out for their depth charges!\nYou\u2019ve got a job to do soldier! Do you have the skill and guts to complete this dangerous mission?\nWelcome to the silent service. Meet the Admiral in the mission room for your briefing. Enter the conning tower and find enemy ships using a vintage hydrophone. Shift the depth lever using your Oculus Go Controller and raise the periscope and scan the dark waters of the vast ocean for enemy ships. Fire your torpedoes and sink them before the enemy escapes. Dive and escape the enemy\u2019s depth charges to complete your mission and live another day! Earn mission ribbons, medals, and advance in rank as you complete more missions and do your duty! ", "short_description": "Command your own World War II era submarine and accept your dangerous mission to sink enemy ships, but watch out for their depth charges!\nYou\u2019ve got a job to do soldier! Do you have the skill and guts to complete this dangerous mission? \nComplete missions by using your Oculus Go Controller to interact with the depth lever, periscope, and steering wheel to find enemy ships, sink them, and escape depth charges to earn mission ribbons, medals, and rank advancements!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bluemarbleworks.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Blue Marble Works", "support_website_url": null, "website_url": "https://www.bluemarbleworks.com/", "categor