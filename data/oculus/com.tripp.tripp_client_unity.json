ywords": ["meditation", "calm", "focus", "mindfulness", "brain"], "long_description": "The Washington Post calls TRIPP \"Meditation meets a video game, meets a Happy Pill!\" Based on scientific research, TRIPP's award-winning platform helps you change the way you feel through targeted, deeply immersive experiences that leave you feeling calm and focused, less stressed and anxious. The TRIPP platform delivers daily updates to its subscribers. TRY the FREE demo and unlock the full offering at TRIPP.com with a credit card - You can cancel anytime during the 7 Day Trial at no charge. \nTRIPP's free Mobile app lets you personalize your TRIPPs which drives a deeper internal connection. Outside of the core daily TRIPPs for FOCUS and CALM, more experiences will be added to the TRIPP catalogue on a regular basis. We welcome your feedback at support@tripp.com. TRIPP - Fitness for Your Inner Self! Footage captured in-engine.", "short_description": "Based on scientific research, TRIPP helps you change the way you feel through targeted, deeply immersive exercises that leave you feeling calm and focused, less stressed and anxious. The TRIPP platform delivers daily updates to its subscribers. We add new experiences regularly. TRY the FREE demo and unlock the full offering at TRIPP.com with a credit card - You can cancel anytime during the 7 Day Trial at no charge. TRIPP - Fitness for Your Inner Self!"}]}, "developer_name": "TRIPP, Inc.", "developer_privacy_policy_url": "https://www.tripp.com/privacy-policy", "developer_terms_of_service_url": "https://www.tripp.com/terms_of_use", "publisher_name": "TRIPP, Inc.", "support_website_url": null, "website_url": "https://www.tripp.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "RELAXATION_MEDITATION", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FO