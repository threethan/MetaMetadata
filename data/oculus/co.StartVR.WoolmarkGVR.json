luscdn.com/v/t64.5771-25/12139007_193200411282258_6175653618591465472_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lLSDDHWTK8Q7kNvgGs8JXc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDS5FxxNmCixGt-otedQcHy8jdq-Mr4MavbO3uFD-x1Hg&oe=6713AD67"}, {"file_name": "migrated_image.png", "id": "1078864292481303", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12482156_267110507159936_2770946812993863680_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=548Uo8p1utAQ7kNvgGhk7Ak&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrKRT8fMk4GKy_VazJd8c6_oITbsycqqjNPth-FJg2yQ&oe=671392BF"}, {"file_name": "migrated_image.png", "id": "152817222602114", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12410407_1788577747891645_2594497410306670592_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10dscRV6IB0Q7kNvgGxPrRb&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrZzjnPyN8xJUdp5WaQYIG3GSn_JlKSmDtsF-5nbxtmg&oe=67139BD2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Woolmark VR", "keywords": ["Australian", "wool", "Merino", "fashion", "textile"], "long_description": "The Woolmark Company is the global authority on wool. Within our virtual reality experience, designed to be viewed using a HMD headset, you can be transported to the origins of nature\u2019s miracle fibre, step inside its lab of textile and manufacturing innovations, and discover its upcoming and ongoing collaborative partnerships.", "short_description": "The official VR app for Woolmark company"}, {"images": {"nodes": []}, "id": "1282318851977960", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Woolmark VR", "keywords": ["woolmark", "m\u00e9rinos", "mode", "\u00e9ducation", "textile"], "long_description": "The Woolmark Company est l\u2019institution mondiale de la laine. Gr\u00e2ce \u00e0 notre exp\u00e9rience de r\u00e9alit\u00e9 virtuelle, con\u00e7ue pour \u00eatre compatible avec un casque HDM, vous serez transport\u00e9s jusqu\u2019aux origines du miracle de la nature qu\u2019est cette fibre, pourrez p\u00e9n\u00e9trer dans notre laboratoire du textile et au c\u0153ur de nos innovations de fabrication et d\u00e9couvrir nos futurs partenariats.", "short_description": "L\u2019application de VR officielle de Woolmark"}, {"images": {"nodes": []}, "id": "1105024843179131", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Woolmark VR", "keywords": ["\uc778\ud130\ub799\ud2f0\ube0c", "Merino", "\ud604\uc2e4", "\uad50\uc721", "\uc591\ubaa8"], "long_description": "The Woolmark Company\ub294  \uc591\ubaa8\uc758 \uc138\uacc4\uc801\uc778 \uad8c\uc704\uc790\uc785\ub2c8\ub2e4. HDM \ud5e4\ub4dc\uc14b\uc744 \ud1b5\ud574\uc11c \ubcf4\uae30 \uc704\ud574 \ub514\uc790\uc778 \ub41c \uc800\ud76c\uc758 \uac00\uc0c1 \ud604\uc2e4 \uccb4\ud5d8\uc744 \ud1b5\ud574 \uc790\uc5f0\uc758 \uae30\uc801\uc758 \uc12c\uc720\uc758 \uae30\uc6d0\uc744 \ubcf4\uace0, \uc637\uac10\uacfc \uc81c\uc870 \ud601\uc2e0 \uc5f0\uad6c\uc18c \uc548\uc744 \ub458\ub7ec\ubcf4\uba74\uc11c, \ub2e4\uac00\uc624\ub294 \ud639\uc740 \uacc4\uc18d \uc9c4\ud589\uc911\uc778 \uacf5\ub3d9 \ud30c\ud2b8\ub108\uc27d\uc744 \ubc1c\uacac\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "Woolmark company\uc758 \uacf5\uc2dd VR"}, {"images": {"nodes": []}, "id": "1083013368748440", "locale": "zh_HK", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Woolmark VR", "keywords": ["woolmark", "\u4ea4\u4e92", "\u7f8a\u6bdb", "Merino", "\u865a\u62df"], "long_description": "Woolmark Company\u662f\u5168\u7403\u7f8a\u6bdb\u5236\u54c1\u7684\u6743\u5a01\u3002\u901a\u8fc7\u6211\u4eec\u7684\u865a\u62df\u73b0\u5b9e\u4f53\u9a8c\uff0c \u60a8\u53ef\u4ee5\u4f7f\u7528HDM\u5934\u663e\u6765\u63a2\u7d22\u8fd9\u79cd\u81ea\u7136\u5947\u8ff9\u2014\u2014\u7f8a\u6bdb\u7ea4\u7ef4\u7684\u8d77\u6e90\uff0c\u8fdb\u5165\u6211\u4eec\u7684\u7eba\u7ec7\u548c\u5236\u