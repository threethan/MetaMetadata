1.oculuscdn.com&oh=00_AYDdOaE6znOkz4OocYI26ptafRpWrBP8VW2S23sB_-GJiw&oe=67164D4F"}, {"file_name": "VRShogiMates02cropped.png", "id": "398942312562424", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75404387_398942315895757_5737287799332143666_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aQ2H7qZRyJsQ7kNvgHLHREz&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCCNCRFLj0qbFqLD1COjkTWcJp7iWF757aa3yBKcMo5YA&oe=67163CBB"}, {"file_name": "VRShogiMates03cropped.png", "id": "337914812432265", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974774_337914815765598_1762840369253842605_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8QkrDgobgPcQ7kNvgFkA3wT&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBsWjHv4OwWPx0khO0PcxyDXXcXwofYpB0fj7uQS57ofA&oe=67163721"}, {"file_name": "VRShogiMates04cropped.png", "id": "367552249204365", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031624_367552252537698_6058304213158592905_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7R69fwESugMQ7kNvgG5HXrn&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYDF7dt8WgvPD-GOrLZ5ACdr4CE_hD_1qg1nwjaL2_u83w&oe=67162D65"}, {"file_name": "Chess cropped.png", "id": "902765531159168", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38984463_902765534492501_3956653358745274292_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_7b46FvHVtsQ7kNvgEmwt3R&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCCzEswnEU1jlgLg_jynPAe0dp-7h7XZnpMIjWzOjzydg&oe=67162863"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerScreenshot cropped.png", "id": "717849803637730", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982545_717849806971063_8753740338935084738_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lWdTg-9gjDkQ7kNvgGJjpGV&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDUKH-IxRZehohvSVhOsTHQr9SBiMOUWEVXVgpVwLqw4g&oe=6716423B"}, "display_name": "VRShogiMates", "keywords": [], "long_description": "Welcome to VRShogiMates, your gateway to a captivating virtual realm of classic board games! As a solo developer's passion project, this app delivers an unparalleled experience featuring Shogi, Chu Shogi, Chess, Xiangqi, and the unique Gungi from Hunter X Hunter.\n\nMultiplayer Mode:\nChallenge opponents worldwide in real-time or correspondence matches. Whether facing friends or discovering new adversaries, the global multiplayer functionality ensures a dynamic and engaging experience.\n\nHow to play:\nNew to these intricate games? No problem! VRShogiMates provides comprehensive rules, instructions, and a game record for each game type to help you learn. Explore the rules, grasp essential strategies, and elevate your skills!\n\nRegular Updates and Support:\nMy commitment doesn't end at launch. Expect continuous updates, bug fixes, performance enhancements, and exciting new features driven by valuable feedback from us.\n\nUnique Highlights:\nVenture into the unexplored VR realms of Shogi, Chu Shogi, Xiangqi, and Gungi - experiences currently not offered by any other VR app on the market! The last game type, Gungi, brings a touch of fantasy to your gaming repertoire. It\u2019s refreshingly different from other board games, check it out!\n\nEmbark on this virtual journey, where tradition meets innovation, and every move is a step towards victory. VRShogiMates is not just a game; it's a portal to a world where strategy, competition, and community converge. Join us and redefine your board gaming experience!", "short_description": "Dive into the immersive world of board games with VRShogiMates! Play Shogi, Chu Shogi, Chess, Xiangqi, and Gungi in a stunning virtual environment. Challenge friends globally in real-time or turn-based multiplayer. Learn the rules for all the games, while enjoying regular updates for an ever-evolving gaming experience.\n\nInternet connection is required to play. (For now)\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://a