_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDBtmG8JtIYQyaonHwal8ZLM-h7-aR5_1bhyu5ZAVGNRg&oe=677676A1"}]}, "id": "1603136713571480", "locale": "en_US", "screenshots": [{"file_name": "VRShogiMates Tsume challenge 1  (Black to mate in 13 moves)-2560x1440.png", "id": "1212274000044966", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982440_1212274003378299_6748105456435770728_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nGwEek2kbC8Q7kNvgG0h0rV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCcUinqdmmvGXWIPE-FvDm1eD5YFCBe-0Oj4Z7ffRP__w&oe=67766BFC"}, {"file_name": "VRShogiMates02cropped.png", "id": "398942312562424", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75404387_398942315895757_5737287799332143666_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dfgCRz3gEtQQ7kNvgE_gRyK&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBU2VgqXO-jM7gqGvEgj9O3BM-e_q-sX1yX5sl05IL46Q&oe=67767A3B"}, {"file_name": "VRShogiMates03cropped.png", "id": "337914812432265", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974774_337914815765598_1762840369253842605_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ijK-2sZ-sQ0Q7kNvgEr7ItS&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA2ekGuBtzMilfCjRzQjFJ3hq_DcwE9Dm3-Jw95naqwVg&oe=677674A1"}, {"file_name": "Gungi 2-2560x1440.png", "id": "1113992063485287", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974497_1113992066818620_843721057957030660_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BT_jPSJegpUQ7kNvgHQUPRU&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBTaq2HHWzHc__AnvEY_VQMPlTyrrVyGLCGqv7y4Zsmfw&oe=67769493"}, {"file_name": "Chess cropped.png", "id": "902765531159168", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984463_902765534492501_3956653358745274292_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2DQQJCbgiAQ7kNvgFafO44&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAzZO_WfJNHBA1tCid8vB8okg_0G81Spika4E8NWpA3aA&oe=677665E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerScreenshot cropped.png", "id": "717849803637730", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982545_717849806971063_8753740338935084738_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hAq8RmATPvwQ7kNvgHnIVCG&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD-g1b6YCOLBk9tnlH96A8gMokaEKahUEocU5gOEGdMwQ&oe=67767FBB"}, "display_name": "VRShogiMates", "keywords": ["shogi", "chess", "xiangqi", "chushogi", "gungi"], "long_description": "Welcome to VRShogiMates, your gateway to a captivating virtual realm of classic board games! As a solo developer's passion project, this app delivers an unparalleled experience featuring Shogi, Chu Shogi, Chess, Xiangqi, and the unique Gungi from Hunter X Hunter.\n\nMultiplayer Mode:\nChallenge opponents worldwide in real-time or correspondence matches. Whether facing friends or discovering new adversaries, the global multiplayer functionality ensures a dynamic and engaging experience.\n\nHow to play:\nNew to these intricate games? No problem! VRShogiMates provides comprehensive rules, instructions, and a game record for each game type to help you learn. Explore the rules, grasp essential strategies, and elevate your skills!\n\nRegular Updates and Support:\nMy commitment doesn't end at launch. Expect continuous updates, bug fixes, performance enhancements, and exciting new features driven by valuable feedback from us.\n\nUnique Highlights:\nVenture into the unexplored VR realms of Shogi, Chu Shogi, Xiangqi, and Gungi - experiences currently not offered by any other VR app on the market! The last game type, Gungi, brings a touch of fantasy to your gaming repertoire. It\u2019s refreshingly different from other board games, check it out!\n\nEmbark on this virtual journey, where tradition meets innovation, and every move is a step towards victory. VRShogiMates is not just a game; it's a portal to a world where strategy, competition, and community converge. Join us and redefine your board gaming experience!", "short_description": "Dive into the immersive world of board games with VRShogiMates! Play Shogi, Chu Shogi, Chess, Xiangqi, and Gungi in a stunning virtual environment. Challenge friends globally in real-time or turn-based multiplayer. Learn the rules for all the games, while enjoying regular updates for an ever-evolving gaming experience.\n\nInternet connection is required to play. (For now)\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.websitepolicies.com/policies/view/a41733bc", "developer_terms_of_service_url": null, "publisher_name": "David Laszlo Banfai", "support_website_url": null, "website_url": "https://vrshogimates.wixsite.com/home", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8601406423282399"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982643_3068358549984618_2984224514881958729_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uI2UgfbYB8EQ7kNvgEmxLdc&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCMh7CDGrKzonEF0DAwPpOiysR628nLSOFx_wJ4_UF38A&oe=67767B00"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRShogiMates", "platform": "ANDROID_6DOF", "context_category": {"context_categor