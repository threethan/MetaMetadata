nc_sid=6e7a0a&_nc_ohc=G3cOkPqa8xkQ7kNvgGTJu_B&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmQSczwXejmA0sYI8WkF3uizzRLWR92G2BvLUWSZYvmw&oe=6759793B"}, {"file_name": "VRShogiMates03cropped.png", "id": "337914812432265", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974774_337914815765598_1762840369253842605_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yZHmcr0YyzEQ7kNvgHtGUV1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZ_Tg59B6ZwE-1oHW4RMA8Wbh7oLDNaSIB7CqXJKseCg&oe=675973A1"}, {"file_name": "VRShogiMates04cropped.png", "id": "367552249204365", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_367552252537698_6058304213158592905_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AJAfTW3W3wwQ7kNvgEBkGpy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1BsO4CusJbHikRVWsGutd03a-MDOYLBDalZoUec-Y4w&oe=675969E5"}, {"file_name": "Chess cropped.png", "id": "902765531159168", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984463_902765534492501_3956653358745274292_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Ntoa2H1WPYQ7kNvgGIQhR_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB-IuDj9JhxkOkovV0eOYrbexD34z7GSYKIC0Fnk9ZM-A&oe=675964E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerScreenshot cropped.png", "id": "717849803637730", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982545_717849806971063_8753740338935084738_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ooEm-b5rL_sQ7kNvgHa-YZR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDT7G2E5yLISvngst-5wW3XwdRXK12zULsU47FM7mYcvg&oe=67597EBB"}, "display_name": "VRShogiMates", "keywords": [], "long_description": "Welcome to VRShogiMates, your gateway to a captivating virtual realm of classic board games! As a solo developer's passion project, this app delivers an unparalleled experience featuring Shogi, Chu Shogi, Chess, Xiangqi, and the unique Gungi from Hunter X Hunter.\n\nMultiplayer Mode:\nChallenge opponents worldwide in real-time or correspondence matches. Whether facing friends or discovering new adversaries, the global multiplayer functionality ensures a dynamic and engaging experience.\n\nHow to play:\nNew to these intricate games? No problem! VRShogiMates provides comprehensive rules, instructions, and a game record for each game type to help you learn. Explore the rules, grasp essential strategies, and elevate your skills!\n\nRegular Updates and Support:\nMy commitment doesn't end at launch. Expect continuous updates, bug fixes, performance enhancements, and exciting new features driven by valuable feedback from us.\n\nUnique Highlights:\nVenture into the unexplored VR realms of Shogi, Chu Shogi, Xiangqi, and Gungi - experiences currently not offered by any other VR app on the market! The last game type, Gungi, brings a touch of fantasy to your gaming repertoire. It\u2019s refreshingly different from other board games, check it out!\n\nEmbark on this virtual journey, where tradition meets innovation, and every move is a step towards victory. VRShogiMates is not just a game; it's a portal to a world where strategy, competition, and community converge. Join us and redefine your board gaming experience!", "short_description": "Dive into the immersive world of board games with VRShogiMates! Play Shogi, Chu Shogi, Chess, Xiangqi, and Gungi in a stunning virtual environment. Challenge friends globally in real-time or turn-based multiplayer. Learn the rules for all the games, while enjoying regular updates for an ever-evolving gaming experience.\n\nInternet connection is required to play. (For now)\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.websitepolicies.com/policies/view/a41733bc", "developer_terms_of_service_url": null, "publisher_name": "David Laszlo Banfai", "support_website_url": null, "website_url": "https://vrshogimates.wixsite.com/home", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": []