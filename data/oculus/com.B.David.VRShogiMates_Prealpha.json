}, {"file_name": "VRShogiMates02cropped.png", "id": "398942312562424", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75404387_398942315895757_5737287799332143666_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m5w1JHk5KIoQ7kNvgHD-AaJ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA6-cNao5ctO-WBlvm9oGGWNn3vqSMevOHif7NpfwQ84g&oe=670124BB"}, {"file_name": "VRShogiMates03cropped.png", "id": "337914812432265", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974774_337914815765598_1762840369253842605_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cI8EiMrb9WQQ7kNvgGjIocn&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDf7iocFZ3pNf1KZfzDdQM76q3AWV223LPpoMRY9CX_2A&oe=67011F21"}, {"file_name": "VRShogiMates04cropped.png", "id": "367552249204365", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031624_367552252537698_6058304213158592905_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tI7n6C7a10Q7kNvgF-cMch&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCmUXc0tCdu2I2LRVZrH8MBcMEVKOOw_LttqvnxLLjFkQ&oe=67011565"}, {"file_name": "Chess cropped.png", "id": "902765531159168", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984463_902765534492501_3956653358745274292_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lv0rvYe7nGwQ7kNvgH_C1oY&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDD8VQXxz6hyG0D_wUGjHdHo4ntZ8BzmxbO13vmAmLIiQ&oe=67011063"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerScreenshot cropped.png", "id": "717849803637730", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982545_717849806971063_8753740338935084738_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NwWgtZjFfvoQ7kNvgEUyKvv&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBbH7Tndls4ZLiEHU0V64afkQec0qniGf5bghPdU0aKjA&oe=67012A3B"}, "display_name": "VRShogiMates", "keywords": [], "long_description": "Welcome to VRShogiMates, your gateway to a captivating virtual realm of classic board games! As a solo developer's passion project, this app delivers an unparalleled experience featuring Shogi, Chu Shogi, Chess, Xiangqi, and the unique Gungi from Hunter X Hunter.\n\nMultiplayer Mode:\nChallenge opponents worldwide in real-time or correspondence matches. Whether facing friends or discovering new adversaries, the global multiplayer functionality ensures a dynamic and engaging experience.\n\nHow to play:\nNew to these intricate games? No problem! VRShogiMates provides comprehensive rules, instructions, and a game record for each game type to help you learn. Explore the rules, grasp essential strategies, and elevate your skills!\n\nRegular Updates and Support:\nMy commitment doesn't end at launch. Expect continuous updates, bug fixes, performance enhancements, and exciting new features driven by valuable feedback from us.\n\nUnique Highlights:\nVenture into the unexplored VR realms of Shogi, Chu Shogi, Xiangqi, and Gungi - experiences currently not offered by any other VR app on the market! The last game type, Gungi, brings a touch of fantasy to your gaming repertoire. It\u2019s refreshingly different from other board games, check it out!\n\nEmbark on this virtual journey, where tradition meets innovation, and every move is a step towards victory. VRShogiMates is not just a game; it's a portal to a world where strategy, competition, and community converge. Join us and redefine your board gaming experience!", "short_description": "Dive into the immersive world of board games with VRShogiMates! Play Shogi, Chu Shogi, Chess, Xiangqi, and Gungi in a stunning virtual environment. Challenge friends globally in real-time or turn-based multiplayer. Learn the rules for all the games, while enjoying regular updates for an ever-evolving gaming experience.\n\nInternet connection is required to play. (For now)\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.websitepolicies.com/policies/view/a41733bc", "developer_terms_of_service_url": null, "publisher_name": "David Laszlo Banfai", "support_website_url": null, "website_url": "https://vrshogimates.wixsite.com/home", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "879473995923081"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7281388235284231"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "8539910886030335"}, {"status": "PUBLISHED", "id": "407905571594429"}, {"status": "PUBLISHED", "id": "1091349662049190"}]}, "baseline_offer": {"id": "407905571594429"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "8539910886030335"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7782343305188719", "version": "1.4.7"}, "id": "5488088387937441", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5395133457243061", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7782343305188719"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "5488088387937441"}]}, "change_log": null, "created_date": 1720074356, "id": "7782343305188719", "version": "1.4.7", "version_code": 8