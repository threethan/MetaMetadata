n.com&oh=00_AYALGWJQcb2Hh_uVohjJgjcui-PySvzLf90l-2avWOVxiQ&oe=6783C0AB"}, {"file_name": "forest.png", "id": "1829399834149597", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035455_1829399837482930_3828830269880611024_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Iofy7KtRWMUQ7kNvgFjg-r_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDoR4QrD0qBL5bG4yMIL0aHChxlGkoxE44z5BbgMWQH_Q&oe=67839AF7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monkey Game", "keywords": [], "long_description": "Monkey Game is an exciting and unique virtual reality multiplayer game that takes you on an adventure with your friends as you play as a monkey's. Jump, run, and explore with your friends through four different maps: Forest, Shop, and TV Zone. With more maps to come soon, you'll never run out of new places to explore! Challenge your friends to races, obstacle courses, and other fun challenges. With realistic graphics, you'll feel like you're really in the game. So grab your friends and join the adventure in Monkey Game!", "short_description": "Monkey Game is a fun game to check out if you want to chill with friends and meet new people you can also put on hats and hold things in your hand as cosmetics and there's a tv area to laugh have fun with friends"}]}, "developer_name": "DeeJr", "developer_privacy_policy_url": "https://sites.google.com/view/eclipse-studios-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "Eclipse Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/monkeygamers/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null,