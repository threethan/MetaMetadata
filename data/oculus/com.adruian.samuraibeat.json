9859107_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0xfpyXBfpQgQ7kNvgFofE5V&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbtbTZC6J7uO1i8ztt2pGtR1Qc1QP9JQxOkFaIq_3uew&oe=66DADD84"}]}, "id": "1461430108582009", "locale": "en_US", "screenshots": [{"file_name": "ScreenShot1-00001.png", "id": "2852343128234936", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_2852343131568269_4832192315566079662_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AGgGQwkz6kMQ7kNvgFo_FoJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAP3O87d0EUidW5icoa5oaaTASnKKItst7Mra2FCwUPJw&oe=66DADF99"}, {"file_name": "ScreenShot1-00001.png", "id": "629632322372544", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_629632329039210_265776331660726017_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KtsQULBF0ZUQ7kNvgH8iSSz&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1eoMh5CJtIfK7KviGkNmvScS5tHvRzc9LeAyI899wYA&oe=66DAF7E4"}, {"file_name": "ScreenShot1-00001-00001.png", "id": "629424435750687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035353_629424439084020_2253705338990676185_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S3_Lh13vQpoQ7kNvgEMW-lq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAOxiJyDHJX2FLrAq3UfzKVdJVfjd_WH79jAk7pAx79XA&oe=66DAFC84"}, {"file_name": "ScreenShot1-00001-00001-00001.png", "id": "1727235967721295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003225_1727235971054628_4166078730741304269_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qggO35QGZdEQ7kNvgGnprX2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCyj2U3X3asdWH6yhskHvEo7AMsTJqHaPng8hKDbKH93Q&oe=66DAFF5C"}, {"file_name": "ScreenShot1-00001-00001-00001-00001.png", "id": "688651613027035", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568679_688651616360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sTH17Apl5msQ7kNvgHMuqM6&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfSKl7yr793anXThCTpPaM89LeFjpEGZD8JqoOMWHY8w&oe=66DADDFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Samurai-beat-2560x1440.png", "id": "1017727499238624", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1017727502571957_6682344747682186393_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hZB05FPQrdcQ7kNvgEqkyOj&_nc_ht=scontent.oculuscdn.com&oh=00_AYBcS5v3BRyUDVzoDfKjl0wsu478EZDPAvd1WlUOU19pIQ&oe=66DAF660"}, "display_name": "Samurai Beat", "keywords": [], "long_description": "WANING: This app is in Early Access. It lacks songs and difficulties that will be added in the following weeks. Also, every level may be change or redo in the future.\n\nEmbark on an experience where ancient samurai traditions meet the pulsating beats of modern music. Samurai Beats is a virtual reality rhythm game that puts you in the shoes of a samurai, testing your skills, reflexes, and sense of rhythm like never before. Are you ready to step into a world where harmony and precision are the keys to victory?\n\nThe game mechanics are designed to keep you fully immersed and engaged. As the rhythmic patterns flow through your ears, it's up to you to synchronize your movements and swiftly slice through the bamboo, matching the beats and maintaining an unbroken flow. The seamless integration of virtual reality allows you to physically wield your katana, making each slice feel exhilarating real.\n\nBut the path to becoming a true samurai is not without its perils. Beware of the arrows that rain down upon you, as a single mistake can prove fatal. Dodge, sidestep, and maneuver your way through the storm of projectiles while never losing your rhythm. Let the music guide your every move and lead you to victory.", "short_description": "Slice bamboo to the rhythm while dodging arrows to maintain your flow and pace. Will you conquer the beat and become a true samurai master? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://web.samuraibeatvr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Adrian Botana Perez", "support_we