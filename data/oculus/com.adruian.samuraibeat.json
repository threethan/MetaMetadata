9859107_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h8rQAm7fn5IQ7kNvgEWfivA&_nc_ht=scontent.oculuscdn.com&oh=00_AYApZy7yJBC8brWiAW5d7s4xHyK8vsheEzVwJjOvYYS7wA&oe=66CB0B84"}]}, "id": "1461430108582009", "locale": "en_US", "screenshots": [{"file_name": "ScreenShot1-00001.png", "id": "2852343128234936", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_2852343131568269_4832192315566079662_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wi39Kb1ueo4Q7kNvgF4XwnK&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUQ73ZynyYHPv16oRH8YCt979PfJVuv4s0QEsQ0FHcqg&oe=66CB0D99"}, {"file_name": "ScreenShot1-00001.png", "id": "629632322372544", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_629632329039210_265776331660726017_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TaLF_xsotqIQ7kNvgFJEmSU&_nc_ht=scontent.oculuscdn.com&oh=00_AYB2g-dAW7HoBTBAL8np6ZUDazFyGZZaRzI9fikNWQGsVQ&oe=66CB25E4"}, {"file_name": "ScreenShot1-00001-00001.png", "id": "629424435750687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035353_629424439084020_2253705338990676185_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ayZdD5UM7NQQ7kNvgG2rN0v&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSseA-4tx3olO9Yfb1DIPwGM2hXhEQYPQLwSTJ3APSzQ&oe=66CB2A84"}, {"file_name": "ScreenShot1-00001-00001-00001.png", "id": "1727235967721295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003225_1727235971054628_4166078730741304269_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LqeFf18QvFoQ7kNvgESdao-&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-5V3YJK_S2YstsQldGDnC1q39TsM5rbM0gVCIEbI_Ag&oe=66CB2D5C"}, {"file_name": "ScreenShot1-00001-00001-00001-00001.png", "id": "688651613027035", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568679_688651616360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fRFoapL_YuQQ7kNvgFt4pR5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCIirGfi51Kga0MUolNch_HW30vJwSqoq0y75lrsl6m2A&oe=66CB0BFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Samurai-beat-2560x1440.png", "id": "1017727499238624", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1017727502571957_6682344747682186393_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OVMPWs8GuLAQ7kNvgEa4VBy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYf7VoN1wvKBVH_Monpf6Ti8c5rfRE8vzHEEe68TgjDQ&oe=66CB2460"}, "display_name": "Samurai Beat", "keywords": [], "long_description": "WANING: This app is in Early Access. It lacks songs and difficulties that will be added in the following weeks. Also, every level may be change or redo in the future.\n\nEmbark on an experience where ancient samurai traditions meet the pulsating beats of modern music. Samurai Beats is a virtual reality rhythm game that puts you in the shoes of a samurai, testing your skills, reflexes, and sense of rhythm like never before. Are you ready to step into a world where harmony and precision are the keys to victory?\n\nThe game mechanics are designed to keep you fully immersed and engaged. As the rhythmic patterns flow through your ears, it's up to you to synchronize your movements and swiftly slice through the bamboo, matching the beats and maintaining an unbroken flow. The seamless integration of virtual reality allows you to physically wield your katana, making each slice feel exhilarating real.\n\nBut the path to becoming a true samurai is not without its perils. Beware of the arrows that rain down upon you, as a single mistake can prove fatal. Dodge, sidestep, and maneuver your way through the storm of projectiles while never losing your rhythm. Let the music guide your every move and lead you to victory.", "short_description": "Slice bamboo to the rhythm while dodging arrows to maintain your flow and pace. Will you conquer the beat and become a true samurai master? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://web.samuraibeatvr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Adrian Botana Perez", "support_we