9859107_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X5-zKNn3JxYQ7kNvgGm9Ba-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAVyHLvCYJKuUYoXIRyOhmf_UTJ5FnBJ6y3nxcEsCw7NA&oe=66CF0004"}]}, "id": "1461430108582009", "locale": "en_US", "screenshots": [{"file_name": "ScreenShot1-00001.png", "id": "2852343128234936", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_2852343131568269_4832192315566079662_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5VCFEqntbEQQ7kNvgGUvn8w&_nc_ht=scontent.oculuscdn.com&oh=00_AYAB9Avw1SeXvwj-HoY0lCqUEhqeWElEvtGMAOVQDgZEoA&oe=66CF0219"}, {"file_name": "ScreenShot1-00001.png", "id": "629632322372544", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_629632329039210_265776331660726017_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_v4YNplWcCsQ7kNvgH5bTnC&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5dKgs30evPeGaRLlMaJ7flV2YHGDlXNFWxI_Kppazyg&oe=66CF1A64"}, {"file_name": "ScreenShot1-00001-00001.png", "id": "629424435750687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035353_629424439084020_2253705338990676185_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UNIBc9Jrei4Q7kNvgFa2X6m&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoBbdpm-OZkvnIrcsYsjSRatwImFj7eI3BPVFaU6TnkQ&oe=66CF1F04"}, {"file_name": "ScreenShot1-00001-00001-00001.png", "id": "1727235967721295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003225_1727235971054628_4166078730741304269_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gT248-HBDFYQ7kNvgEBqX-F&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhpBGmRBTD-w_MS2Df6W78GPVGpMSHGGPrO9T6M6D8xA&oe=66CF21DC"}, {"file_name": "ScreenShot1-00001-00001-00001-00001.png", "id": "688651613027035", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568679_688651616360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAwRAcZwfZMQ7kNvgGzmNJS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDH23tEbadWqxbJ--FH0ZU6j8xEO-LitYaOh4iBiR3n2Q&oe=66CF007E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Samurai-beat-2560x1440.png", "id": "1017727499238624", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1017727502571957_6682344747682186393_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_iTVf7U7_w8Q7kNvgHqMJG8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPZkoYx18RVHBaX2fC5nMdJmgF3MmwsK9a-7GThgpBiQ&oe=66CF18E0"}, "display_name": "Samurai Beat", "keywords": [], "long_description": "WANING: This app is in Early Access. It lacks songs and difficulties that will be added in the following weeks. Also, every level may be change or redo in the future.\n\nEmbark on an experience where ancient samurai traditions meet the pulsating beats of modern music. Samurai Beats is a virtual reality rhythm game that puts you in the shoes of a samurai, testing your skills, reflexes, and sense of rhythm like never before. Are you ready to step into a world where harmony and precision are the keys to victory?\n\nThe game mechanics are designed to keep you fully immersed and engaged. As the rhythmic patterns flow through your ears, it's up to you to synchronize your movements and swiftly slice through the bamboo, matching the beats and maintaining an unbroken flow. The seamless integration of virtual reality allows you to physically wield your katana, making each slice feel exhilarating real.\n\nBut the path to becoming a true samurai is not without its perils. Beware of the arrows that rain down upon you, as a single mistake can prove fatal. Dodge, sidestep, and maneuver your way through the storm of projectiles while never losing your rhythm. Let the music guide your every move and lead you to victory.", "short_description": "Slice bamboo to the rhythm while dodging arrows to maintain your flow and pace. Will you conquer the beat and become a true samurai master? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://web.samuraibeatvr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Adrian Botana Perez", "support_we