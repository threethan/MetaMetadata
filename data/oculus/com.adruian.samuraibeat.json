": "1727235967721295", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003225_1727235971054628_4166078730741304269_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aNOPXGEMG_sQ7kNvgFy3jca&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDeEODR4JWaTp10mTt-uJ7VoK18fz3aKdqAtN6y4fuByA&oe=6776905C"}, {"file_name": "ScreenShot1-00001-00001-00001-00001.png", "id": "688651613027035", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57568679_688651616360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X4Kssaqr-e0Q7kNvgEcTw4D&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAWLzR5UaWoSxH4nNY4R9msHcOyYjEqvTHbFlDN2T9X4g&oe=67766EFE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Samurai Beat", "keywords": [], "long_description": "Samurai Beat is a Virtual Reality Rhythm game in which you experience the feeling of training like a warrior.\n\nPractice the ancient Samurai training, Tameshigiri, where cutting bamboo with precision and timing is the key to success. The original technique has a slow rhythm inheritance from Edo period, the music spice thing a bit while preserving the flow origins. Preserve the tempo while dodging and parring projectiles.", "short_description": "Samurai Training VR Rhythm game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://adrianbotana.github.io/samurai-beat-website/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Adrian Botana Perez", "support_website_url": null, "website_url": "https://adrianbotana.github.io/samurai-beat-website", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "