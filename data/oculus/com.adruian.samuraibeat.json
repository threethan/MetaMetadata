": "1727235967721295", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003225_1727235971054628_4166078730741304269_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sWOBitDdWPIQ7kNvgH9thKC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCL6Bt_87FCpQbSRfdAXwxOpkfaM2Nlq9oBPRTPQOL3gw&oe=67656CDC"}, {"file_name": "ScreenShot1-00001-00001-00001-00001.png", "id": "688651613027035", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568679_688651616360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sruJep5HuUQQ7kNvgE_w2Ym&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVDNGRWDkTQUWyXE9gcigDLdpa5b8glBDdxjOtvlMFOA&oe=67654B7E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Samurai Beat", "keywords": [], "long_description": "Samurai Beat is a Virtual Reality Rhythm game in which you experience the feeling of training like a warrior.\n\nPractice the ancient Samurai training, Tameshigiri, where cutting bamboo with precision and timing is the key to success. The original technique has a slow rhythm inheritance from Edo period, the music spice thing a bit while preserving the flow origins. Preserve the tempo while dodging and parring projectiles.", "short_description": "Samurai Training VR Rhythm game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://adrianbotana.github.io/samurai-beat-website/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Adrian Botana Perez", "support_website_url": null, "website_url": "https://adrianbotana.github.io/samurai-beat-website", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "