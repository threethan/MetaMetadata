16360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G2q1djtHLH4Q7kNvgGoVVZ2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDoGSxRv4AlEoaWnaBLppLoxndEOr4Xs-R21IfLEuj8Fg&oe=67839DFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Samurai-beat-2560x1440.png", "id": "1017727499238624", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974518_1017727502571957_6682344747682186393_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EWnd68i7uwkQ7kNvgEEZULY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9x3mqo5wFSzwR4wEUOzGZbfiS48cht2qdAIaY8zV6Jw&oe=6783B660"}, "display_name": "Samurai Beat", "keywords": [], "long_description": "WANING: This app is in Early Access. It lacks songs and difficulties that will be added in the following weeks. Also, every level may be change or redo in the future.\n\nEmbark on an experience where ancient samurai traditions meet the pulsating beats of modern music. Samurai Beats is a virtual reality rhythm game that puts you in the shoes of a samurai, testing your skills, reflexes, and sense of rhythm like never before. Are you ready to step into a world where harmony and precision are the keys to victory?\n\nThe game mechanics are designed to keep you fully immersed and engaged. As the rhythmic patterns flow through your ears, it's up to you to synchronize your movements and swiftly slice through the bamboo, matching the beats and maintaining an unbroken flow. The seamless integration of virtual reality allows you to physically wield your katana, making each slice feel exhilarating real.\n\nBut the path to becoming a true samurai is not without its perils. Beware of the arrows that rain down upon you, as a single mistake can prove fatal. Dodge, sidestep, and maneuver your way through the storm of projectiles while never losing your rhythm. Let the music guide your every move and lead you to victory.", "short_description": "Slice bamboo to the rhythm while dodging arrows to maintain your flow and pace. Will you conquer the beat and become a true samurai master? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://web.samuraibeatvr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Adrian Botana Perez", "support_website_url": null, "website_url": "https://web.samuraibeatvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7138450016187176"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982499_802165738031815_3516408336111490985_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WYJGi4fKf1AQ7kNvgHATIiF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDsmDYpSQPy_z7oRWow9Ot_bWI0A0AgARxrLuU5bsV1rg&oe=6783A121"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Samurai Beat", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Rhythm", "id": "1672577396871977"}], "release_date": 1689809520, "lastRevision": {"nodes": [{"id": "5182757608423103", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5182757595089771", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iar