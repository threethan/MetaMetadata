s://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035411_648940530498766_6849325436539859107_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2gKZqpbkUywQ7kNvgHztRAQ&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCcL-y6HFNkQGXvoQ-GGTWgSrT1O5iG_tR6l_VkOcSfug&oe=67026A84"}]}, "id": "1461430108582009", "locale": "en_US", "screenshots": [{"file_name": "ScreenShot1-00001.png", "id": "2852343128234936", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982698_2852343131568269_4832192315566079662_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZBR15ryp_cAQ7kNvgFHB725&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDNTwAJNlsganUM0m5KVxtXmFL4idicz0pA8ZE4iubU6A&oe=67026C99"}, {"file_name": "ScreenShot1-00001.png", "id": "629632322372544", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982551_629632329039210_265776331660726017_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vEuVwBZTuu8Q7kNvgFagLn6&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYD68-rh4BZfp-Nstz5bRDdFthBJB_UB8dtYkuro7Rw2xA&oe=670284E4"}, {"file_name": "ScreenShot1-00001-00001.png", "id": "629424435750687", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035353_629424439084020_2253705338990676185_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tajuJ5LwPtUQ7kNvgG_UHkN&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBW1kczlMEiFM5Q9mtmGeOxdfH-tXcX48HVy0JYOh3lfw&oe=67028984"}, {"file_name": "ScreenShot1-00001-00001-00001.png", "id": "1727235967721295", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39003225_1727235971054628_4166078730741304269_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vOCSuqnNMRMQ7kNvgHKgqge&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCJy_evXQO8Vtrgj6CjHtgfOb81Oe4otRB96F2GOwbyOA&oe=67028C5C"}, {"file_name": "ScreenShot1-00001-00001-00001-00001.png", "id": "688651613027035", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57568679_688651616360368_5282574286227163013_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vsYzNg_VUbEQ7kNvgHglvmw&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB-7-fM-BJkSg48ZZKZB-huJ-2-oQnzzcTSL54ehdE97g&oe=67026AFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Samurai-beat-2560x1440.png", "id": "1017727499238624", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974518_1017727502571957_6682344747682186393_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ui1yZsnxBuwQ7kNvgGBgmv8&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDCIgndsNVd8eKFkzJIKaAULAu42uedfRrrKv3pczFLVw&oe=67028360"}, "display_name": "Samurai Beat", "keywords": [], "long_description": "WANING: This app is in Early Access. It lacks songs and difficulties that will be added in the following weeks. Also, every level may be change or redo in the future.\n\nEmbark on an experience where ancient samurai traditions meet the pulsating beats of modern music. Samurai Beats is a virtual reality rhythm game that puts you in the shoes of a samurai, testing your skills, reflexes, and sense of rhythm like never before. Are you ready to step into a world where harmony and precision are the keys to victory?\n\nThe game mechanics are designed to keep you fully immersed and engaged. As the rhythmic patterns flow through your ears, it's up to you to synchronize your movements and swiftly slice through the bamboo, matching the beats and maintaining an unbroken flow. The seamless integration of virtual reality allows you to physically wield your katana, making each slice feel exhilarating real.\n\nBut the path to becoming a true samurai is not without its perils. Beware of the arrows that rain down upon you, as a single mistake can prove fatal. Dodge, sidestep, and maneuver your way through the storm of projectiles while never losing your rhythm. Let the music guide your every move and lead you to victory.", "short_description": "Slice bamboo to the rhythm while dodging arrows to maintain your flow and pace. Will you conquer the beat and become a true samurai master? "}]}, "developer_name": null, "