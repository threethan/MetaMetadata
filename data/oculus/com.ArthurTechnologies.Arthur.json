v/t64.5771-25/39031462_251792223241590_6244672025863054851_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lMIqZxke454Q7kNvgFKRuRo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDD4s6Z9BN85J-bqrvP4kHZ3BXok6XfTpil-AoUtJ0ktg&oe=677BCA20"}, {"file_name": "Screenshot_OSR_00024--cropped--rescaled.png", "id": "248238586882821", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982488_248238593549487_3226899241555173807_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9h51TS5QzHQQ7kNvgGlI0eo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCCbQi-ilUN5VwBY6iqhdFdBxv5VpuBxO5spO_VKw3TLg&oe=677BCCBA"}, {"file_name": "Screenshot_OSR_00031--cropped--rescaled.png", "id": "1196335724116395", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031395_1196335727449728_3287014057082450871_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qRrdsyr84qwQ7kNvgFgskrw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCOPLL0XjDuaoqhJzOCB_S5djGpttULIM5TktAUML55DA&oe=677BDAB8"}, {"file_name": "Screenshot_OSR_00019--cropped--rescaled.png", "id": "271183801240465", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984461_271183804573798_6711551754688486295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xaLmWKvnmSsQ7kNvgG9qoDQ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBFc-zig57S3u2lQtSecwPbxD0-sUW4_zyfy4TdUx4zgw&oe=677BDBF0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2021_Arthur_OSR_k1--thumbnail--rescaled.png", "id": "768135187240762", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982658_768135190574095_1214029505073396689_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4uHZn9OWNWYQ7kNvgH73W4G&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDN7-YqKDQ_j9XdRhzFUS7p53PsuPwgL41Vd6QrcTOPfw&oe=677BAA86"}, "display_name": "Arthur", "keywords": ["productivity", "utility", "meetings", "collaboration", "office"], "long_description": "Arthur is your virtual office space. It allows you and your team to meet, collaborate and manage your work. In Arthur, you feel like you\u2019re in the same location as your teammates, but you can still enjoy all the advantages of digital collaboration. By using Arthur, you empower yourself and your team to maximize levels of remote productivity and free yourself from geographic and physical constraints.\n\nThe version of Arthur available in this store offers a free and light Consumer space with unlimited session time and exciting productivity features for smaller teams that do not need as much room. In case your virtual office gets too crowded, you can simply upgrade to additional spaces.\n\nFor teams with needs of high scalability for team size and space, check out our fully-fledged virtual office in the Professional lobby or www.arthur.digital/product-portfolio to find out more.", "short_description": "Arthur is your virtual office space. It allows you and your team to meet, collaborate and manage your work. In Arthur, you feel like you\u2019re in the same location as your teammates, but you can still enjoy all the advantages of digital collaboration. By using Arthur, you empower yourself and your team to maximize levels of remote productivity and free yourself from geographic and physical constraints."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arthur.digital/privacy-policy.html", "developer_terms_of_service_url": "https://arthur.digital/license-agreement.html", "publisher_name": "Arthur Technologies Inc.", "support_website_url": "https://arthurtechnologies.zendesk.com/", "website_url": "https://arthur.digital/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY", "SOCIAL", "UTILITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MO