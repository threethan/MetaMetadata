 "video_trailer_thumbnail": null, "display_name": "Moment", "keywords": ["meditation", "mindfulness", "nature", "3d", "calming"], "long_description": "At Reality Mint we recognize that daily routines have shifted and people are looking for new ways to manage their mental health. So we\u2019ve decided to release an early version of MOMENT, an immersive experience designed for mindfulness practice and meditation. \n\nAs our development team works to integrate additional features, we hope you are able to take this opportunity to enjoy some relaxing nature scenes and find your MOMENT.", "short_description": "Getting cabin fever? Step outside with MOMENT!\n \nWe at Reality Mint want to help everyone dealing with the stress of isolation and uncertainty during this pandemic, so we\u2019re releasing some scenes from our upcoming app MOMENT, a platform for mindfulness and meditation.\n \nSo if you\u2019re feeling you need an escape, please take a MOMENT on us to enjoy some relaxing nature scenes beautifully captured in stunning 8k 3d."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/51410546", "developer_terms_of_service_url": "https://www.iubenda.com/terms-and-conditions/51410546", "publisher_name": "Reality Mint LLC", "support_website_url": null, "website_url": "http://www.realitymint.com/moment", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3516711369