25/38974854_227800325088514_6018629713033953280_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9VZx8sbsEXUQ7kNvgERmRdC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgnPsH0ejTbW35-Kx6nFKepBLJoFyx3oeRRlW0qBJ_AA&oe=66E6C8DB"}, {"file_name": "9RgCiR.png", "id": "214361103125640", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974704_214361106458973_8437851522330525696_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gRbykm-u_foQ7kNvgHlOA6y&_nc_ht=scontent.oculuscdn.com&oh=00_AYCy-p4d1LLbfNQyn_DX4AL1vb8O0KuKyJVsq82MPiqaSw&oe=66E6DA90"}, {"file_name": "l3Fi37.png", "id": "155720132369367", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974811_155720135702700_2579167280457842688_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3CzivN8mgvEQ7kNvgFaunbq&_nc_ht=scontent.oculuscdn.com&oh=00_AYD0vxzJQ62t13ucfC51BmN3dWeuWOWGgoBow2f4nT8uBg&oe=66E6D503"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Moment", "keywords": ["meditation", "mindfulness", "nature", "3d", "calming"], "long_description": "At Reality Mint we recognize that daily routines have shifted and people are looking for new ways to manage their mental health. So we\u2019ve decided to release an early version of MOMENT, an immersive experience designed for mindfulness practice and meditation. \n\nAs our development team works to integrate additional features, we hope you are able to take this opportunity to enjoy some relaxing nature scenes and find your MOMENT.", "short_description": "Getting cabin fever? Step outside with MOMENT!\n \nWe at Reality Mint want to help everyone dealing with the stress of isolation and uncertainty during this pandemic, so we\u2019re releasing some scenes from our upcoming app MOMENT, a platform for mindfulness and meditation.\n \nSo if you\u2019re feeling you need an escape, please take a MOMENT on us to enjoy some relaxing nature scenes beautifully captured in stunning 8k 3d."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ww