25/38974854_227800325088514_6018629713033953280_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kZXIEO5-b8EQ7kNvgFFSpo5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOXrY-_sKr7aZ2Z4S4s-DAj-JJON2JvF8d9gVlHQZHuQ&oe=66D3025B"}, {"file_name": "9RgCiR.png", "id": "214361103125640", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974704_214361106458973_8437851522330525696_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5-fv_632wjQQ7kNvgECWuqh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCWE5HEDAkFKMem84KCFD3EHEeGn1OxqFl8iePRpR9C7Q&oe=66D31410"}, {"file_name": "l3Fi37.png", "id": "155720132369367", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974811_155720135702700_2579167280457842688_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fqQlZKluuusQ7kNvgHi5Cwa&_nc_ht=scontent.oculuscdn.com&oh=00_AYDS0j8GLr7Pcq89BEUg8hSQTQRTgsMqkDLTqZZwxGuyiw&oe=66D30E83"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Moment", "keywords": ["meditation", "mindfulness", "nature", "3d", "calming"], "long_description": "At Reality Mint we recognize that daily routines have shifted and people are looking for new ways to manage their mental health. So we\u2019ve decided to release an early version of MOMENT, an immersive experience designed for mindfulness practice and meditation. \n\nAs our development team works to integrate additional features, we hope you are able to take this opportunity to enjoy some relaxing nature scenes and find your MOMENT.", "short_description": "Getting cabin fever? Step outside with MOMENT!\n \nWe at Reality Mint want to help everyone dealing with the stress of isolation and uncertainty during this pandemic, so we\u2019re releasing some scenes from our upcoming app MOMENT, a platform for mindfulness and meditation.\n \nSo if you\u2019re feeling you need an escape, please take a MOMENT on us to enjoy some relaxing nature scenes beautifully captured in stunning 8k 3d."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ww