25/38974854_227800325088514_6018629713033953280_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4V9lwWUWuD4Q7kNvgEj9Ys2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVLEPa-BaSuFM-AOA_9jO_sMXu5-Q-IDw6O55S8i24MA&oe=66D999DB"}, {"file_name": "9RgCiR.png", "id": "214361103125640", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974704_214361106458973_8437851522330525696_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EF1F2Vdz9dgQ7kNvgFQs31-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrF3y94SEfcKy65uJhqbJFoVUoofsIt5DQl-YSS7zwIg&oe=66D9AB90"}, {"file_name": "l3Fi37.png", "id": "155720132369367", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974811_155720135702700_2579167280457842688_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dgqSgpgXMpoQ7kNvgHWoJL4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBoYZeO-D-2_Coq8e6cdLE4g8U9bzf8CTAwBzDBRmMjxw&oe=66D9A603"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Moment", "keywords": ["meditation", "mindfulness", "nature", "3d", "calming"], "long_description": "At Reality Mint we recognize that daily routines have shifted and people are looking for new ways to manage their mental health. So we\u2019ve decided to release an early version of MOMENT, an immersive experience designed for mindfulness practice and meditation. \n\nAs our development team works to integrate additional features, we hope you are able to take this opportunity to enjoy some relaxing nature scenes and find your MOMENT.", "short_description": "Getting cabin fever? Step outside with MOMENT!\n \nWe at Reality Mint want to help everyone dealing with the stress of isolation and uncertainty during this pandemic, so we\u2019re releasing some scenes from our upcoming app MOMENT, a platform for mindfulness and meditation.\n \nSo if you\u2019re feeling you need an escape, please take a MOMENT on us to enjoy some relaxing nature scenes beautifully captured in stunning 8k 3d."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ww