3-2.oculuscdn.com&oh=00_AYBVfxmujGjiLqfmI5ZvY4fc3fAuooRVzrTVs-Bn5XhPFw&oe=671CEA34"}, {"file_name": "screenshot2.png", "id": "1851794028551932", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982676_1851794031885265_1612709899273729954_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-1jIL0xJFioQ7kNvgEEHNSN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqc0ZmFxpyE6W50cv_wrQx2aeJXnMoY4StjJwz7tr9Yw&oe=671CD507"}, {"file_name": "screenshot3.png", "id": "644467577870495", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982629_644467584537161_3907703598817595077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hTgBhEKGB4kQ7kNvgECdtGe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZxc_z9s11oPhC0Ke7OdZDk5VKavdg1r-km4Lm9dr-Qw&oe=671CC969"}, {"file_name": "screenshot4.png", "id": "677538871087238", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375766_677538874420571_8937027655834237167_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ij2OxqcL80oQ7kNvgGg97WS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByBgDBsmj3PiVNaVnmQqV8k2IHh4U805AY_QaglXsxUQ&oe=671CEBCC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "1958384901188512", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982461_1958384904521845_1840289094503006758_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mwASy-jrFQ4Q7kNvgHGlsfi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnkVvLYqBPOgbILjnPYVVOS3xVa9IM4reJVblvdQQ62w&oe=671CCC68"}, "display_name": "Shinobi no mono", "keywords": [], "long_description": "Japan 1683 - Aogashima Island\nOda Ishida, a renegade samurai takes up arms to avenge his lord who was savagely murdered by the men of Ishi Kinoshita, a local lord from the Sekigahara region.\nIt is on this island that the legend of Shinobi no mono begins.\n\nExclusively for meta quest. \nVid\u00e9o capture from meta quest 2.\n\nIt's a stealth game with 8 levels including the island, the fishing port, the meadow, the mountain, the snow, the cave, the Japanese medieval town and an end bonus level.\n\nThe game has a tutorial which is a level in its own right and which allows you to familiarize yourself with the combat modes\n\nReal shadows, snow particules, rain particules, halo effect, ...\n\nSeveral enemy types including samurais, ninjas, bosses, geishas\nStory Mode\nThere is support for managing motion sickness issues.\nYou can climb everywhere to escape your enemies or to spy on them before attacking.\nYou have access to several types of weapons including shurikens, bows and katanas.\nAmmo is limited, so you must collect what you find.", "short_description": "It's a stealth game with 8 levels including the island, the fishing port, the meadow, the mountain, the snow, the cave, the Japanese medieval town and an end bonus level."}]}, "developer_name": "Nicolas Pincemin", "developer_privacy_policy_url": "https://www.shinobinomonovr.go.yo.fr/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Unity", "support_website_url": null, "website_url": "https://www.shinobinomonovr.go.yo.fr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6468324949943461"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1920011568519901"}, {"status": "PUBLISH