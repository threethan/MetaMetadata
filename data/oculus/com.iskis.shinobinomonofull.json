1612709899273729954_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DRyME5VoZvQQ7kNvgH-kf3-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDe__GeenXq0pnGdK8TioER2VvecQ37eOtbL5tzQPExGA&oe=66D84707"}, {"file_name": "screenshot3.png", "id": "644467577870495", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982629_644467584537161_3907703598817595077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gcbjvZzkryEQ7kNvgGqeEL1&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9zm0IW195JA-2QZh8CvMNR1us8a_XZtd2SRY2LZ1WjA&oe=66D83B69"}, {"file_name": "screenshot4.png", "id": "677538871087238", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375766_677538874420571_8937027655834237167_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nALH7mGgBW0Q7kNvgGA9NcV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCt59cO4XTyDmA3Q_isith1ZJZv4esU8f-jf3VuKP4qfA&oe=66D85DCC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "1958384901188512", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_1958384904521845_1840289094503006758_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z30j6YAZGaYQ7kNvgGwcZcI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMghcZrtpcoqEB5jiuM5vnIzjVHiSNrkBLg0hBHksKoQ&oe=66D83E68"}, "display_name": "Shinobi no mono", "keywords": [], "long_description": "Japan 1683 - Aogashima Island\nOda Ishida, a renegade samurai takes up arms to avenge his lord who was savagely murdered by the men of Ishi Kinoshita, a local lord from the Sekigahara region.\nIt is on this island that the legend of Shinobi no mono begins.\n\nExclusively for meta quest. \nVid\u00e9o capture from meta quest 2.\n\nIt's a stealth game with 8 levels including the island, the fishing port, the meadow, the mountain, the snow, the cave, the Japanese medieval town and an end bonus level.\n\nThe game has a tutorial which is a level in its own right and which allows you to familiarize yourself with the combat modes\n\nReal shadows, snow particules, rain particules, halo effect, ...\n\nSeveral enemy types including samurais, ninjas, bosses, geishas\nStory Mode\nThere is support for managing motion sickness issues.\nYou can climb everywhere to escape your enemies or to spy on them before attacking.\nYou have access to several types of weapons including shurikens, bows and katanas.\nAmmo is limited, so you must collect what you find.", "short_description": "It's a stealth game with 8 levels including the island, the fishing port, the meadow, the mountain, the snow, the cave, the Japanese medieval town and an end bonus level."}]}, "developer_name": "Nicolas Pincemin", "developer_privacy_policy_url": "https://www.shinobinomonovr.go.yo.fr/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Unity", "support_website_url": null, "website_url": "https://www.shinobinomonovr.go.yo.fr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6468324949943461"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1051490099078736"}, {"status": "PUBLISHED", "id": "1415915649333444"}]}, "baseline_offer": {"id": "1415915649333444"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1695245308, "status": "PUBLISHED", "id": "1051490099078736"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"