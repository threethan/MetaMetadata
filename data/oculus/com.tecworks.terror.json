YIPsv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMRaiipRu-XIfO4AVaZJvHf&oh=00_AYDO55DnPfyi73urjnHDLj-OxLXMc0aOhbbFQCP4CJqyUA&oe=66F150BF"}, {"file_name": "e57570301_710702087589570_1834160870098337765_n.png", "id": "1531304567689053", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367591_1531304574355719_4651695625402723499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bh7qLuPMJ7EQ7kNvgHx-wWO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMRaiipRu-XIfO4AVaZJvHf&oh=00_AYB8kB-4e4dy4qacQygBAysx6lNVsv0F_A_sA0mYv2m_tA&oe=66F13894"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videocover.png", "id": "334089665973844", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367591_334089669307177_4932419493797319377_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d_a2UUO1y4MQ7kNvgE9zuga&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMRaiipRu-XIfO4AVaZJvHf&oh=00_AYB_ATDK8zKIFw87bBdjgH4NLKkmh-guRNye54Ev8n0Z9g&oe=66F16201"}, "display_name": "Terror Cave", "keywords": ["horror", "terror", "cave", "theme", "park"], "long_description": "Welcome to Terror Cave, one amazing experience that will reproduce the effect of the famous theme parks terror caves where you sit down on a chair and a series of weird creatures will try to scare you, while you cross into a suggestive scenario.\n\nIf you are impressionable person that can easy be scared and are afraid to not support strong emotions, we recommend you the \"Sweety\" version of the experience, that will drive you in a tour with mild emotive and amazing feelings, but if you are brave and love high impact, go ahead with the \"scary\" version, and get ready to be shocked with strong emotions!\n\nFREE VERSION WITH SWEETY MODE ENABLED.\n\n", "short_description": "Welcome to Terror Cave, one amazing experience that will reproduce the effect of the famous theme parks terror caves where you sit down on a chair and a series of weird creatures will try to scare you, while you cross into a suggestive scenario, FREE VERSION WITH SWEETY MODE ENABLED."}]}, "developer_name": null, "developer_privacy_policy_url": "http://jined.great-site.net/privacypolicy.htm", "developer_terms_of_service_url": null, "publisher_name": "Tecworks", "support_website_url": null, "website_url": "http://jined.great-site.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "541611600222565"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8157309301065009"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974704_1662975800940151_7256254304395066438_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HlB9_8uHFhUQ7kNvgGX32aX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMRaiipRu-XIfO4AVaZJvHf&oh=00_AYCYV5dGU3B0Jg4JbGNmVNYcBKJVAPXfgGm01J6q4kC84A&oe=66F146AD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Terror Cave", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Experimental", "id": "541611600222565"}, {"topic_name": "Horror", "id": "411892083130028"}], "release_date": 1698941058, "lastRevision": {"nodes": [{"id": "6864700500325902", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6864700