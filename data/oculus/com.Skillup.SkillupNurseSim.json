deo_trailer_thumbnail": {"file_name": "Skillup_Landscape.png", "id": "348096568245352", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451778_348096574912018_3005572446759952788_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DCS7Ni7u1QoQ7kNvgG6dw8u&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZQxr6xWBnua8U497BMJDb2p4FTeqJ0hNeZ95nhjAU3g&oe=66E416EE"}, "display_name": "Skillup VR NurseSIM", "keywords": [], "long_description": "Skillup VR NurseSIM is designed for junior healthcare professionals to practice their basic nursing skills. Developed together with a Norwegian vocational institution, the simulation pack offers multiple scenarios set in both clinical and home environments, for users to familarize themselves with ABCDE-assessment, the NEWS2 scoring system and ISBAR communication techniques.\n\n- 8 training scenarios of different patient profiles\n- Multiplayer setup\n- English and Norwegian language options\n- Intuitive, interactive and wireless\n- Compatible with Meta Quest 2 and 3\n- NEWS2 Scoring System \n- ISBAR Communication Framework\n- Facilitator control, communication and supervision capability *\n\n* Add-on application.", "short_description": "Skillup VR NurseSIM is designed for junior healthcare professionals to practice their basic nursing skills. Developed together with a Norwegian vocational institution, the simulation pack offers multiple scenarios set in both clinical and home environments, for users to familarize themselves with ABCDE-assessment, the NEWS2 scoring system and ISBAR communication techniques."}, {"images": {"nodes": []}, "id": "1220784722286406", "locale": "nb_NO", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Skillup VR NurseSIM", "keywords": [], "long_description": "Skillup VR NurseSIM er designet for helsefagarbeidere for \u00e5 praktisere sine grunnleggende sykepleieferdigheter. Utviklet sammen med en norsk fagskole, tilbyr simuleringspakken flere scenarier satt i b\u00e5de kliniske og hjemmemilj\u00f8er, for \u00e5 la brukere \u00e5 bli kjent med ABCDE-unders\u00f8kelse, NEWS2-scoringssystemet og ISBAR-kommunikasjonsteknikker.\n\n- 8 treningsscenarier med forskjellige pasientprofiler\n- Flerspiller\n- Engelsk og norsk spr\u00e5kvalg\n- Intuitivt, interaktivt og tr\u00e5dl\u00f8st\n- Kompatibel med Meta Quest 2 og 3 og PICO 4\n- NEWS2 Scoringssystem\n- ISBAR Kommunikasjon Rammeverk\n- Mulighet for fasilitatorkontroll, kommunikasjon og veiledning *\n\n* Tilleggsapplikasjon.", "short_description": "Skillup VR NurseSIM er designet for helsefagarbeidere for \u00e5 praktisere sine grunnleggende sykepleieferdigheter. Utviklet sammen med en norsk fagskole, tilbyr simuleringspakken flere scenarier satt i b\u00e5de kliniske og hjemmemilj\u00f8er, for \u00e5 la brukere \u00e5 bli kjent med ABCDE-unders\u00f8kelse, NEWS2-scoringssystemet og ISBAR-kommunikasjonsteknikker."}]}, "developer_name": null, "developer_privacy_policy_url": "https://skillupvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Skillup AS", "support_website_url": null, "website_url": "https://skillupvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nb"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7785353478240113"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65397209_429766933032764_25096