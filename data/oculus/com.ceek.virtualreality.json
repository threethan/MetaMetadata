BMv&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5S4X5hbFPLrJ3ceIxfh8ZG&oh=00_AYA3Ip9Qfvb-7a4vDWancYPm1nd2YP5sv9pafzKKS4aPKw&oe=66F00090"}, {"file_name": "migrated_image.png", "id": "609037693056564", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031401_3071876196160464_1532067516552052736_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=otSOdP2fRMAQ7kNvgEHus2X&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5S4X5hbFPLrJ3ceIxfh8ZG&oh=00_AYDPT2QjJVXnWDIyUoQiXX33t2xOQFQ_lZkLKKpMfqYFJg&oe=66F00F04"}, {"file_name": "migrated_image.png", "id": "1437540346428145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001678_471488656843879_7684089366087467008_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oeaMtGiWYwsQ7kNvgGTeL1R&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5S4X5hbFPLrJ3ceIxfh8ZG&oh=00_AYBdcaeVVodWNkNZTaaLVi8bn-9AYrfplk8aV6uuMRdk2w&oe=66EFF157"}, {"file_name": "migrated_image.png", "id": "2417312001893072", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982672_2863684516987350_9052735043474030592_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6akCOw0BBu4Q7kNvgEV9Veb&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5S4X5hbFPLrJ3ceIxfh8ZG&oh=00_AYDF8eVcyO3GyqGQg7xGOVWBrGRwpHYr2BC9APzonTLk8g&oe=66F0179E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CEEK Virtual Reality", "keywords": ["CEEK", "CEEKVR", "VRConcerts", "VRmovie", "VRmusic"], "long_description": "From 360 VR Videos to True 3D and 180 immersive, CEEK delivers compelling experiences intensified by our award winning patent AWARDED 4D virtual reality audio and AI visual technologies.\n\nFeatures Include: \n- In-app Navigation\n- Mobile VR interaction \n- Multiple VR Environments to choose from\n- Multiple Concerts \n\nExperience your favorite Music Stars in concert, backstage, all access interviews, and intimate performances in 360 VR and 180 VR on ultra-huge \u201cMe Max\u201d Screens in magical environments. Hundreds of top performances\u2014all on one single app \u2013 no need for multiple app downloads. From Lady Gaga to Katy Perry, Snoop Dogg, NAS and Sting, CEEK VR brings you the best documentaries, interviews, and concerts from around the world are on CEEK now, with greater top performances being added regularly. \n\nCEEK VR is the definitive destination for exciting music concerts and premium entertainment experiences in Virtual Reality.", "short_description": "CEEK VR VENUES magnifies and transforms your phone into the most engulfing VR Concert Arena."}]}, "developer_name": "CEEK VR Inc", "developer_privacy_policy_url": "https://www.ceek.com/privacy/", "developer_terms_of_service_url": "https://ceek.com/terms", "publisher_name": "CEEK VR Inc", "support_website_url": null, "website_url": "http://ceek.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPERIENCE_360_NON_GAME", "MOVIE", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "253546533592781"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974607_428143398008493_8797652043796840448_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q0K8fA3JO1AQ7kNvgGUoPlm&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5S4X5hbFPLrJ3ceIxfh8ZG&oh=00_AYB21ILTIZaWfUIj-zLh911o6YanllvubKi3kP6SOn-flg&oe=66EFECD2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CEEK Virtual Reality", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1562173200, "lastRevision": {"nodes":