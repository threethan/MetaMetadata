4pBJQqa3OSJaXfmOzTukdmCTRuRm3s2wmEwBg&oe=6724BC90"}, {"file_name": "migrated_image.png", "id": "609037693056564", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031401_3071876196160464_1532067516552052736_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xx70B3uHNn8Q7kNvgHJT92H&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAczSS2LltE9KEldfwGeTdvQe-kVoenwNS4I6scc0Dc_w&oe=6724CB04"}, {"file_name": "migrated_image.png", "id": "1437540346428145", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001678_471488656843879_7684089366087467008_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNv3DU6cax0Q7kNvgGfVGrb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCmiCHTohQkxq-lYxpaYvHnBGw71ZpXmmIvdL7A7vXm_w&oe=6724AD57"}, {"file_name": "migrated_image.png", "id": "2417312001893072", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982672_2863684516987350_9052735043474030592_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QDietK-0FZkQ7kNvgGLJ-Tq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA3CDMKlf2OPgBCJZB2_XLIadE_g461Ep2QgAgm0zp_FA&oe=6724D39E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CEEK Virtual Reality", "keywords": ["CEEK", "CEEKVR", "VRConcerts", "VRmovie", "VRmusic"], "long_description": "From 360 VR Videos to True 3D and 180 immersive, CEEK delivers compelling experiences intensified by our award winning patent AWARDED 4D virtual reality audio and AI visual technologies.\n\nFeatures Include: \n- In-app Navigation\n- Mobile VR interaction \n- Multiple VR Environments to choose from\n- Multiple Concerts \n\nExperience your favorite Music Stars in concert, backstage, all access interviews, and intimate performances in 360 VR and 180 VR on ultra-huge \u201cMe Max\u201d Screens in magical environments. Hundreds of top performances\u2014all on one single app \u2013 no need for multiple app downloads. From Lady Gaga to Katy Perry, Snoop Dogg, NAS and Sting, CEEK VR brings you the best documentaries, interviews, and concerts from around the world are on CEEK now, with greater top performances being added regularly. \n\nCEEK VR is the definitive destination for exciting music concerts and premium entertainment experiences in Virtual Reality.", "short_description": "CEEK VR VENUES magnifies and transforms your phone into the most engulfing VR Concert Arena."}]}, "developer_name": "CEEK VR Inc", "developer_privacy_policy_url": "https://www.ceek.com/privacy/", "developer_terms_of_service_url": "https://ceek.com/terms", "publisher_name": "CEEK VR Inc", "support_website_url": null, "website_url": "http://ceek.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPERIENCE_360_NON_GAME", "MOVIE", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "253546533592781"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974607_428143398008493_8797652043796840448_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sd3E8mF1VTUQ7kNvgFRaZtn&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCE8-rarX7NQozIfuNvNXWhb7Hj1wDCcADM4lY7bdSj2g&oe=6724A8D2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CEEK Virtual Reality", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1562173200, "lastRevision": {"nodes": [{"id": "1921918521192813", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"appl