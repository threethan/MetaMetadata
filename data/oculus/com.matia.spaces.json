VGCw&oe=66CAFA7A"}, {"file_name": "screenshot4.png", "id": "346994598446419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035334_346994601779752_4423657160466511523_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XEUVBBbECn8Q7kNvgF0D1n4&_nc_ht=scontent.oculuscdn.com&oh=00_AYC2YXpLRGzYsLuNP7oHCqwKAQUUEdofs-9vZigFArODSA&oe=66CB18AB"}, {"file_name": "screenshot1.png", "id": "2879195512258229", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035334_2879195515591562_7579821966307778480_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F8m9HoZr3rcQ7kNvgHZmD2F&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_FMiMpk0-GFNIFB3fk29W9SyL2xYE9J3xnWf_oL27dw&oe=66CB115F"}, {"file_name": "screenshot3.png", "id": "456021107239817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568672_456021110573150_8085706203850155985_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VPCLJlMZlNQQ7kNvgHg9fuj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuL5qfTKI3jwh_8eSYRIdAz-i6N3FzzOzgkdoDJTdTGw&oe=66CB2BF9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer-cover-image.png", "id": "1706347306840455", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580068_1706347310173788_6054781611093722483_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Ss5U1KtdnEQ7kNvgGk3dJa&_nc_ht=scontent.oculuscdn.com&oh=00_AYDU_mf3P2Vlb3N1nzxNf6n1MZIRZFhZ5zksBLgEjxYIfw&oe=66CB2755"}, "display_name": "CoDo Spaces", "keywords": [], "long_description": "CoDo is your passport to positive. Connect closely, engage simply, center solo.\n\nDitch the scroll, embrace the soul. Get CoDo and embark on a journey that transcends the limitations and distractions of traditional social media and video calls. With CoDo, you can travel to exotic virtual locations where friendships deepen, wellness flourishes and loneliness disappears. Whether you're seeking vibrant social experiences with distant friends and family or moments of personal reflection, CoDo offers immersive environments for any mood. Connect with friends and loved ones in stunning 360-degree locations, or find your calm in serene digital retreats designed for mindfulness and self-discovery. CoDo is your passport to real connections and personal serenity in the digital age, redefining what it means to be truly present and engaged in our interconnected world.", "short_description": "CoDo is your passport to positive. Connect closely, engage simply, center solo.\n\nDitch the scroll, embrace the soul. Get CoDo and travel to exotic locations where friendships deepen and wellness flourishes. CoDo is your passport to real connections and personal serenity in the digital age. Replace the distractions of social media and video calls with pure, authentic connections in beautiful places around the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://codo.world/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Matia Labs, Inc.", "support_website_url": null, "website_url": "https://codo.world/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1067126693731825"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7371461509647256"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2934798556659751"}]}, "baseline_offer": {"id": "2934798556659751"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721445360, "status": "PUBLISHED