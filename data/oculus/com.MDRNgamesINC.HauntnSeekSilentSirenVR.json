Bg4V_K0dAJ15EEQCkVsfZ1szis5f-zWdYhQo17jgFzhw&oe=6717A351"}, {"file_name": "hnsscreen3.png", "id": "794438099336830", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75493236_794438102670163_7433929580475462076_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bu95oXGwq-8Q7kNvgETs1Nd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8vqCuSWUQW8XrVacbnOfxCeyv6E-tyXpCQpysAIJdlw&oe=6717785D"}, {"file_name": "hnsscreen5.png", "id": "799915842242611", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031418_799915845575944_9043712205913483037_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FXDkO162sPAQ7kNvgHjAW62&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOIrxKwHzbygWJAF2fEZyXlQV8jdB6tb024auznRr8fg&oe=67178FF8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "hns cover main 1400.png", "id": "342422902024198", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43931327_342422905357531_5260086719006314498_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kq1xAby0R9cQ7kNvgENEJvW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFgaQ-LyqsYhmKdPULSyffgDHY8NLNE3TSPqfgBuY-Pg&oe=6717A6A0"}, "display_name": "Haunt n Seek: Silent Siren", "keywords": ["Horror", "adventure", "scary", "storyline", "action"], "long_description": "Pre-orders & Finishing Story mode.\nThis is the last public update until the game is done & shipped\n\nComing October 8th\nSilent Siren - Immerse yourself in the life of Dex. A troubled character with a murky past and a mysterious radio as their only guide. Unravel puzzles, confront ghastly entities, and fight through a series of mind bending challenges within The Silent Sirens eerie universe. Uncovering Dex's sins of his past, he must face his own guilt and over come echoes of his actions. This horror game blends psychological intrigue with the supernatural, questioning the boundaries between guilt, reality, and redemption.\n\nEscape Rooms - Explore huge open worlds or find the keys to find the exit button to the \"Safe House\". You can find some fun games that take advantage of the XR/VR experience like a life size shooting range with a dart board & bow and arrow, chess, pool, foose-ball and more. Play by yourself or hop online and race to escape these skin crawling & under-worldly maps. PVP, puzzle, or timed modes, team up or betray your friends to escape.\n", "short_description": "Pre-release to support the developer\n\nSingle player - Maze mode - Find the buttons to reach the next level.\n\nEscape rooms - Find the keys to the exit...\n\nEscape rooms online, and full single player coming October 8th\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://hauntnseek.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Nathan Pacheco", "support_website_url": null, "website_url": "http://www.hauntnseek.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}, {"id": "411892083130028"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8098298906932572"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1618980035559328"}]}, "baseline_offer": {"id": "1618980035559328"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726677960, "status": "PUBLISHED", "id": "1618980035559328"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nod