0541789913_6017184629597840175_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qUwDgERAujIQ7kNvgEQnfvL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDH6yWveurrvMsN8rklsRPbbjawz2oNfUcrVhx8VRJXNQ&oe=6717809A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "hns cover main 1400.png", "id": "342422902024198", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43931327_342422905357531_5260086719006314498_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kq1xAby0R9cQ7kNvgENEJvW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFgaQ-LyqsYhmKdPULSyffgDHY8NLNE3TSPqfgBuY-Pg&oe=6717A6A0"}, "display_name": "Haunt n Seek: Silent Siren", "keywords": ["horror", "story", "survival", "thriller", "action"], "long_description": "Join the Discord \nhttps://discord.gg/jdN5WXG85K\n\nStory Mode:\n\nUpon waking in the eerie, fog-enshrouded universe of Silent Siren, Dex Mercer finds himself holding a mysterious radio, guided to mysterious buttons around the world by an familiar friend, named Larse. With no memory of how he arrived, Dex is on a quest to uncover the chilling mysteries of the town and face the haunting truths of his past, all while the spectral voice of his wife. \n\nEscape Rooms (Playable but Under Construction):\n\nReplay the levels from the single player with an escape room twist. Unlock your way to a special bonus levels. Featuring a 1:1 recreation of Terciera, Azores, Portugal, where the solo developer experience real paranormal activities.\n\nHockey Ministicks VR (easter Egg)\n\nYes - Online hockey as well as air hockey and more mini games are featured in the game. This is the full game of Hockey Ministicks VR.\n\n\n3d artist credits \nhttps://docs.google.com/document/d/1Xf-n4twUJ5YzCMSq9IJHyNH_VdnL6L_bp3jg9rIVGZo/edit?usp=sharing", "short_description": "Solo-Developed world of Haunt N Seek: Silent Siren - A story driven survival horror game about the character Dex, a lost man fighting for freedom from his own mind. Replay the story mode levels with an Escape Room mode & go online with some Hockey Ministicks VR(Full Game included)"}]}, "developer_name": null, "developer_privacy_policy_url": "https://hauntnseek.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Nathan Pacheco", "support_website_url": null, "website_url": "http://www.hauntnseek.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}, {"id": "411892083130028"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8402086893220437"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75300187_878034694199591_3173067084842070114_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XJ7kTNTuvVEQ7kNvgE0IbqC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCiCFEmIuHSXwmmJzpylNfZBEeQnb5jZ8qu6FmiQOzz3w&oe=67178264"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Haunt n Seek: Silent Siren", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Horror", "id": "411892083130028"}], "release_date": 1726677960, "lastRevision": {"nodes": [{"id": "7615414915220976", "release_type": "SCHEDULED", "administration_status": "APPROVED"