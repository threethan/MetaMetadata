uluscdn.com&_nc_gid=Au1DJwogdiRrtrt7TC0yqqF&oh=00_AYDfTkGz-7NFBKlnr6ZC37XxRFqcNqTky9pOQmokTbeCQw&oe=66ED4933"}, {"file_name": "ShootingRifle.png", "id": "947097497074017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612009_947097500407350_1058532208517142023_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NDgXg6nFZYUQ7kNvgGFdU3H&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1DJwogdiRrtrt7TC0yqqF&oh=00_AYDyCUAzouB7aO5kpttHMEqFLiVOyvK_GEDKpvNv72mq0w&oe=66ED52A6"}, {"file_name": "PointingGunAtEnemy.png", "id": "1518320245559853", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031369_1518320248893186_775263258796848259_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lw4LM671ztgQ7kNvgEBSC15&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1DJwogdiRrtrt7TC0yqqF&oh=00_AYAT88kM22LZwTpcyDsFTNKOxSGeZIY5fUBBIU6k7rTSsA&oe=66ED53AD"}, {"file_name": "Portrait Art (2).png", "id": "380447998341569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_380448005008235_1331657312051459764_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GrATnox9YBkQ7kNvgHIPyhk&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1DJwogdiRrtrt7TC0yqqF&oh=00_AYBL4wj-D0oJuwtB_Pydm4z9tGzo0T-xLDkzhk0ce3r0tw&oe=66ED4F60"}, {"file_name": "Portrait Art (3).png", "id": "1848879945596039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031459_1848879952262705_6247747339827501209_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_ruq6skvarAQ7kNvgG6cAKJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au1DJwogdiRrtrt7TC0yqqF&oh=00_AYAdwCPACvyex6tSAt79w2L7_AQFlVVMRxnNY9fsuwDgkQ&oe=66ED6B6C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boneless", "keywords": [], "long_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies.\n\nGuns:\nPistol (With attachments)\nRevolver\nShotgun\nUZI\nMP5 (with attachments)\nRifle (with attachments)\nHeavy Rifle (with attachments)\n\n\nThere are three different maps, each with a day and night variation. These include:\n\nArena:\n\n{1708491613222297}\n\nCourt:\n\n{1021883305934741}\n\n\nCity:\n\n\n\n{1092983475260344}\n\n\nYou can engage in hand to hand or ranged combat with enemies. Or both!\n\n\n{4083272078562911}\n\nThe game also features two handed guns with scopes such as rifles.\n\n{3669989183213932}\n\nThere is also an external camera for video recording.\n\n{457804259952906}\n", "short_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies."}]}, "developer_name": "XRS Interactive", "developer_privacy_policy_url": "https://xrs-interactive.com/boneless-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "XRS Interactive", "support_website_url": "https://xrs-interactive.com/", "website_url": "https://xrs-interactive.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8142177825845364"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974910_1170945560991342_2190084726796334121_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5y8oSrZE9CMQ7kNvg