uluscdn.com&_nc_gid=A2-jGTjq2r0coFJ9cEYT2ea&oh=00_AYA-PYydGrUK_D_I7MsPFgxvHVuJ8VmGPkEFlgcBX5AknQ&oe=66E954B3"}, {"file_name": "ShootingRifle.png", "id": "947097497074017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612009_947097500407350_1058532208517142023_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_PXH8PAREh8Q7kNvgHTCZA7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2-jGTjq2r0coFJ9cEYT2ea&oh=00_AYCKtqcky5cr3fsepESXpQfGvas_lHtQ4A8LvTZBfn4yAg&oe=66E95E26"}, {"file_name": "PointingGunAtEnemy.png", "id": "1518320245559853", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031369_1518320248893186_775263258796848259_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R4cGG5TO-G4Q7kNvgEMAhk5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2-jGTjq2r0coFJ9cEYT2ea&oh=00_AYDUG3SJN_AUaZfrH-IxtPBRjEhUK6zvz3nQ8xyZS1LaDQ&oe=66E95F2D"}, {"file_name": "Portrait Art (2).png", "id": "380447998341569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_380448005008235_1331657312051459764_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p4kB9AAZcUcQ7kNvgHUHszZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2-jGTjq2r0coFJ9cEYT2ea&oh=00_AYA77z8RsusqO8EBisxRhWQpyaaHv_l7o6p5ZmqazVoSYQ&oe=66E95AE0"}, {"file_name": "Portrait Art (3).png", "id": "1848879945596039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031459_1848879952262705_6247747339827501209_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3OZAX_TB_YQ7kNvgG_YJ-4&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2-jGTjq2r0coFJ9cEYT2ea&oh=00_AYAjdUVE94PAIotpcwvG55rXM0cGrz6n1lik9dc6C1av3Q&oe=66E976EC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boneless", "keywords": [], "long_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies.\n\nGuns:\nPistol (With attachments)\nRevolver\nShotgun\nUZI\nMP5 (with attachments)\nRifle (with attachments)\nHeavy Rifle (with attachments)\n\n\nThere are three different maps, each with a day and night variation. These include:\n\nArena:\n\n{1708491613222297}\n\nCourt:\n\n{1021883305934741}\n\n\nCity:\n\n\n\n{1092983475260344}\n\n\nYou can engage in hand to hand or ranged combat with enemies. Or both!\n\n\n{4083272078562911}\n\nThe game also features two handed guns with scopes such as rifles.\n\n{3669989183213932}\n\nThere is also an external camera for video recording.\n\n{457804259952906}\n", "short_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies."}]}, "developer_name": "XRS Interactive", "developer_privacy_policy_url": "https://xrs-interactive.com/boneless-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "XRS Interactive", "support_website_url": "https://xrs-interactive.com/", "website_url": "https://xrs-interactive.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8142177825845364"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974910_1170945560991342_2190084726796334121_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dr1A3RTyi1AQ7kNvg