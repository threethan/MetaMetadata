dn.com/v/t64.5771-25/38982608_420054350807373_1770066327329829218_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G6m4_ge-kM8Q7kNvgGGdcmv&_nc_ht=scontent.oculuscdn.com&oh=00_AYC0RQkgxnr6rgmMjbhgDwaA63CeArE0eJjgndnCpSpXPA&oe=66E6B1B3"}, {"file_name": "ShootingRifle.png", "id": "947097497074017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612009_947097500407350_1058532208517142023_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_PXH8PAREh8Q7kNvgHGIGP_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnKrrTST73OL8zQ1cQzhJRXzC0FOK7O0j93BlaQvwobw&oe=66E6BB26"}, {"file_name": "PointingGunAtEnemy.png", "id": "1518320245559853", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031369_1518320248893186_775263258796848259_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R4cGG5TO-G4Q7kNvgEK6Xlu&_nc_ht=scontent.oculuscdn.com&oh=00_AYBU1OYa7sWOrsLLV5ALHkAfNP4clDP3Sh-zPkQ0TDXXYA&oe=66E6BC2D"}, {"file_name": "Portrait Art (2).png", "id": "380447998341569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_380448005008235_1331657312051459764_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p4kB9AAZcUcQ7kNvgE2L9ph&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdz69f9VEGiZUuqKigygm-HqONeXBYZL2pzOmgSAY9Dg&oe=66E6B7E0"}, {"file_name": "Portrait Art (3).png", "id": "1848879945596039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031459_1848879952262705_6247747339827501209_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y9Rpsfv62BgQ7kNvgE9L-oJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxfetTCnOqDwxAjZXamcYggFoa5nfQccTEyPrdhUgGJw&oe=66E6D3EC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boneless", "keywords": [], "long_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies.\n\nGuns:\nPistol (With attachments)\nRevolver\nShotgun\nUZI\nMP5 (with attachments)\nRifle (with attachments)\nHeavy Rifle (with attachments)\n\n\nThere are three different maps, each with a day and night variation. These include:\n\nArena:\n\n{1708491613222297}\n\nCourt:\n\n{1021883305934741}\n\n\nCity:\n\n\n\n{1092983475260344}\n\n\nYou can engage in hand to hand or ranged combat with enemies. Or both!\n\n\n{4083272078562911}\n\nThe game also features two handed guns with scopes such as rifles.\n\n\n{3669989183213932}\n\nThe game also features a parkour course with a zipline in the warehouse map.\n\n\n{7682382745157338}\n\nThere is also an external camera for video recording.\n\n{457804259952906}\n", "short_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xrs-interactive.com/boneless-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "XRS Interactive", "support_website_url": "https://xrs-interactive.com/", "website_url": "https://xrs-interactive.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7942150562514759"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "466357515736262"}]}, "baseline_offer": {"id": "466357515736262"}, "is_