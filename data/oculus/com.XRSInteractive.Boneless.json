/v/t64.5771-25/38982608_420054350807373_1770066327329829218_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLga_UNGy3kQ7kNvgH8Dvh0&_nc_ht=scontent.oculuscdn.com&oh=00_AYBN6sFaBW6eAIs2Z1B0ynYkAk1jK8EyuFGCjyo1nevgCA&oe=66F28F33"}, {"file_name": "ShootingRifle.png", "id": "947097497074017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612009_947097500407350_1058532208517142023_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sqJFQORrrPAQ7kNvgFEKrKj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXE_NXJDTV5TEd3EfXEwtp4EXTFlI2VT-d8IUIi6t8Dg&oe=66F298A6"}, {"file_name": "PointingGunAtEnemy.png", "id": "1518320245559853", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031369_1518320248893186_775263258796848259_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=24KXMtn4ADwQ7kNvgGrUiyy&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0RxCuaNe7rm38qSLaRk-z0RCSymvCxBYGcEw9rE7H4w&oe=66F299AD"}, {"file_name": "Portrait Art (2).png", "id": "380447998341569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_380448005008235_1331657312051459764_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jWzHTL34U2cQ7kNvgFkfpwb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSvqZrfo3G2lJkLxVxeKarDx06S2SzzDwr2NQCUqd5zA&oe=66F29560"}, {"file_name": "Portrait Art (3).png", "id": "1848879945596039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031459_1848879952262705_6247747339827501209_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2-H5aN3MOt4Q7kNvgE_M3Kr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkvCOZZ0hKNLzjbaQe88B8iCfgc_Fy9oZ35gMVwnoBqQ&oe=66F2B16C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boneless", "keywords": [], "long_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies.\n\nGuns:\nPistol (With attachments)\nRevolver\nShotgun\nUZI\nMP5 (with attachments)\nRifle (with attachments)\nHeavy Rifle (with attachments)\n\n\nThere are three different maps, each with a day and night variation. These include:\n\nArena:\n\n{1708491613222297}\n\nCourt:\n\n{1021883305934741}\n\n\nCity:\n\n\n\n{1092983475260344}\n\n\nYou can engage in hand to hand or ranged combat with enemies. Or both!\n\n\n{4083272078562911}\n\nThe game also features two handed guns with scopes such as rifles.\n\n\n{3669989183213932}\n\nThe game also features a parkour course with a zipline in the warehouse map.\n\n\n{7682382745157338}\n\nThere is also an external camera for video recording.\n\n{457804259952906}\n", "short_description": "Boneless VR is an experimental Virtual Reality physics sandbox game built to test the limits of what's possible in VR. The game features unique maps, unique weapons, such as guns and swords and multiple enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xrs-interactive.com/boneless-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "XRS Interactive", "support_website_url": "https://xrs-interactive.com/", "website_url": "https://xrs-interactive.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7942150562514759"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "466357515736262"}]}, "baseline_offer": {"id": "466357515736262"}, "is_approv