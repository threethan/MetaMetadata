ioral change. The human instinct to freeze or follow\u2014exactly the wrong instinct in an active shooter situation\u2014is replaced with response-ready reactions that are then second-nature in a time of crisis.", "short_description": "Active Shooter Survival is an Immersive Training for users to practice how to protect themselves in the event of an active shooter situation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.incitevr.com/solutions/safety/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "inciteVR", "support_website_url": null, "website_url": "https://www.incitevr.com/solutions/safety/active-shooter", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3252924431661080"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "127275169432172"}]}, "baseline_offer": {"id": "127275169432172"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1623747900, "status": "PUBLISHED", "id": "127275169432172"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4321472567897615", "version": "21.5.24"}, "id": "425795848687388", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typenam