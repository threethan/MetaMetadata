5472391227686_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ey6cNV1HZOsQ7kNvgFUgZOJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC7SF0l4SLLPysnAk_4d3whjS4grG_6QWlcVkx4PKpfZA&oe=6773CB7F"}, {"file_name": "s7.png", "id": "723704731946394", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580066_723704735279727_1657339152001791804_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-a9et8-cR4MQ7kNvgH6J-dW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUYpJmhiR6vhI3D1t_8tJIB4Z-hd1YkceTjepRLboMgQ&oe=6773D10F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer-screenshot.png", "id": "342309257413087", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334061_342309264079753_2615715454138737248_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SwLnnW-5mssQ7kNvgFjNWOO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdtuqhzz6GbuWWMINAqsrBX25w77iddFcqJHhtJI8NrA&oe=6773C31A"}, "display_name": "Fake Racing", "keywords": [], "long_description": "Fake Racing is an indie racing game with an unusual visual style. \n\nFeatures:\n\n- The monochrome pixelized renderer was created specifically for this game. It uses a custom 3D-dithering shading technique to achieve a retro visual style with one of the three available monochrome palettes. \n- Fake car physics. Non-realistic but fun for casual play.\n- Attack from the Air: compete not only against your opponents, but also against the enemy helicopter. This mode creates an extra challenge for the race leaders, making the race more intense. \n- Four tracks with reverse and mirror options. \n\n\nGame modes:\n\n- Attack from the air;\n- Elimination;\n- Classic race. \n", "short_description": "A retro-style indie racing game with a monochrome pixel graphics and a fake car physics. Features Air Attack and Elimination modes. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.romanshuvalov.com/fakeracing/privacy-policy", "developer_terms_of_service_ur