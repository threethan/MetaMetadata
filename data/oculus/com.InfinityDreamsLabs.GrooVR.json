\nEach hit is strongly supported by playing the sound of the drum of the song and visual effects to emphasize the rhythm.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://infinity-dreams.vercel.app/PrivacyPolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Infinity Dreams Labs", "support_website_url": null, "website_url": "https://infinity-dreams.vercel.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "485879986276226"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PENDING", "id": "1452594755451016"}, {"status": "PUBLISHED", "id": "269835001257948"}, {"status": "PUBLISHED", "id": "694372575600701"}, {"status": "PUBLISHED", "id": "589344148945469"}, {"status": "PUBLISHED", "id": "1429649580795914"}, {"status": "PUBLISHED", "id": "1565904397487751"}, {"status": "PUBLISHED", "id": "1389545791457348"}, {"status": "PUBLISHED", "id": "666932468246049"}, {"status": "PUBLISHED", "id": "402188184688037"}, {"status": "PUBLISHED", "id": "478813846909580"}]}, "baseline_offer": {"id": "1565904397487751"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1452594755451016"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "698