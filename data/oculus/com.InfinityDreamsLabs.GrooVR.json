": "1275594566374543", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75514546_1275594569707876_2405160809557612400_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J61Vs6nD5gYQ7kNvgHujG7x&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCodcag3Zp_CiI_8uSCoG9yFozeFXULhHxLc2R7gkClUg&oe=67502AF1"}, {"file_name": "2.png", "id": "695423229007064", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031579_695423232340397_8233073057695991675_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I4ClTRoetHsQ7kNvgGlEMPh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFPj3ty9FWxze2VeJASYWYL1xjpBUR_YcTiNKg5PxMHA&oe=6750330A"}, {"file_name": "3.png", "id": "801440204254650", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974452_801440207587983_1824399304746932453_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fBDR1dAmQVQQ7kNvgFYXdW5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_ycm8WosUuUlnSNmwVp2KKn9TicrbZxmFvF2qWm_rTw&oe=67502B90"}, {"file_name": "4.png", "id": "792826345604801", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974751_792826348938134_879559281621796926_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HtxprvwClNgQ7kNvgFjSheU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9GSJ4-aVSyPpaX8V6FqHzFLmk7tK_q77DV1Qi8FiRPw&oe=67502812"}, {"file_name": "5.png", "id": "207615452017155", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031644_207615455350488_796591876062385052_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8qGjgfsrQ2gQ7kNvgFFlGm_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAs_iIWsi9snEdkHr2z1H4GYH028DTlQGJvMLM-jSI41Q&oe=675048F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt - Landscape.png", "id": "1061575105192761", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572937_1061575108526094_3091268314292878287_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V98wXjgIjKAQ7kNvgE_Al_m&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1DmUegz6k4iAnElIN5nPnUykb5fnThmTTI1NFkbsxbg&oe=67504BD7"}, "display_name": "GrooVR: Air Drumming", "keywords": [], "long_description": "Unleash your inner musician with GrooVR, the ultimate virtual reality rhythm game. Say goodbye to boring, senseless games and immerse yourself in a realistic and engaging drumming experience.\n\nWith GrooVR, you'll have the opportunity to play the drums in a variety of genres including Punk, Metal, Pop-punk, Rock'n'roll, and Industrial, we have a catalog of 41 songs to enjoy. The game supports mixed reality capture for an even more immersive experience.\n\nCustomize your drum set-up and play the way you want. We're constantly updating the game with new music and techniques to ensure an enjoyable and engaging experience. The game also features variety of street environments, from urban to suburban. Whether you're a beginner or a seasoned pro, you can start on medium difficulty and increase the challenge as you progress.\n\nExperience the thrill of drumming in a realistic street environment with GrooVR. Take the first step towards becoming an expert virtual drummer today.", "short_description": "Unleash your inner musician with GrooVR, the ultimate virtual reality rhythm game. Play drums in a variety of genres & environments, with 41 songs & mixed reality capture. Customize your set-up & increase difficulty as you progress. Experience the thrill of drumming in a realistic street environment"}]}, "developer_name": "Mercuryo Tecnologia", "developer_privacy_policy_url": "http://mercuryotecnologia.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mercuryo Tecnologia", "support_website_url": "https://mercuryotecnologia.com/contato/", "website_url": "http://mercuryotecnologia.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"