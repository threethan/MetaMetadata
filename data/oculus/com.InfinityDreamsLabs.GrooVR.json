s://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982445_4249367501793893_2946959581537283578_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CpihR8-9lLEQ7kNvgHZBUEw&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAOXog-5pQ-oupKpGXADBgw8yinc3KiFqwcS_tZPw6BKA&oe=67263096"}, {"file_name": "Screenshots 1.png", "id": "1029347187868523", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974649_1029347191201856_1702021506251304605_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OFwe0Fn9ru0Q7kNvgH_HuNF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBZlTjVnd5IoGAOMTsz8dKnzKmoJe0RAP35jM1xOoOFhg&oe=672638C9"}, {"file_name": "Screenshots 5.png", "id": "546937099673884", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984471_546937103007217_311446915470168227_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ObfJGDY6XygQ7kNvgHcnRZj&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDrGVM5PrhuoIwgQdNBeyqniB67J-8B-zsdcAhWOhNTDw&oe=67261C62"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "GrooVR - Air Drumming (Demo)", "keywords": [], "long_description": "GrooVR is a unique VR rhythm game where your goal is to hit the beats (represented by small plates) as they are coming at the parts of the drum. \n\nEvery beat indicates which stick you need to use and also the direction you need to match. All the music is composed to perfectly fit the handmade levels. \n\nOur goal is to make players learn how to play drums.\n\nEach hit is strongly supported by playing the sound of the drum of the song and visual effects to emphasize the rhythm.\n", "short_description": "GrooVR is a unique VR rhythm game where your goal is to hit the beats (represented by small plates) as they are coming at the parts of the drum. \n\nEvery beat indicates which stick you need to use and also the direction you need to match. All the music is composed to perfectly fit the handmade levels. \n\nOur goal is to make players learn how to play drums.\n\nEach hit is strongly supported by playing the sound of the drum of the song and visual effects to emphasize the rhythm.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://infinity-dreams.vercel.app/PrivacyPolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Infinity Dreams Labs", "support_website_url": null, "website_url": "https://infinity-dreams.vercel.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "485879986276226"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PENDING", "id": "1452594755451016"}, {"status": "PUBLISHED", "id": "269835001257948"}, {"status": "PUBLISHED", "id": "694372575600701"}, {"status": "PUBLISHED", "id": "589344148945469"}, {"status": "PUBLISHED", "id": "1429649580795914"}, {"status": "PUBLISHED", "id": "1565904397487751"}, {"status": "PUBLISHED", "id": "1389545791457348"}, {"status": "PUBLISHED", "id": "666932468246049"}, {"status": "PUBLISHED", "id": "402188184688037"}, {"status": "PUBLISHED", "id": "478813846909580"}]}, "baseline_offer": {"id": "1565904397487751"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1452594755451016"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "698