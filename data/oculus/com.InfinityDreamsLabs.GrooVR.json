": "1275594566374543", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75514546_1275594569707876_2405160809557612400_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d6z-XpV30xUQ7kNvgHA9PCK&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDy7o-E7l62fQR-hHRq7rzBoN3KXGdvZsAvjf_m1qHw7g&oe=675FFCF1"}, {"file_name": "2.png", "id": "695423229007064", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031579_695423232340397_8233073057695991675_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n7CNSRrBMSkQ7kNvgEN8XtY&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCUL-x29xJBNFmY9DzjeADLuvGi_esc9kBYEwt6BlGilA&oe=6760050A"}, {"file_name": "3.png", "id": "801440204254650", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974452_801440207587983_1824399304746932453_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=38uYBtRVWPAQ7kNvgGVK77A&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYA-wX_2ykfKbLVtUXo-APwF-Ye9z405PgIC8quTA1Z0pw&oe=675FFD90"}, {"file_name": "4.png", "id": "792826345604801", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974751_792826348938134_879559281621796926_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kIVdg75DmDQQ7kNvgHWs5WW&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYANIrVnF4cZP85sbVrayuumtnJOlTdEatkg3T-DxyqNTQ&oe=675FFA12"}, {"file_name": "5.png", "id": "207615452017155", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031644_207615455350488_796591876062385052_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NCOWdy0z9UEQ7kNvgHQcEKq&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAxmO4KBZeu7kF0vaxhmCAY7APcD_m50KHeHSXL8YZ2rw&oe=67601AF8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt - Landscape.png", "id": "1061575105192761", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57572937_1061575108526094_3091268314292878287_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tko1rDtLX8AQ7kNvgFUr_3g&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYC2JsEtVstq2w6XhHwDXFZRMG0el1hXf9uZbwYu7l7wCg&oe=67601DD7"}, "display_name": "GrooVR: Air Drumming", "keywords": [], "long_description": "Unleash your inner musician with GrooVR, the ultimate virtual reality rhythm game. Say goodbye to boring, senseless games and immerse yourself in a realistic and engaging drumming experience.\n\nWith GrooVR, you'll have the opportunity to play the drums in a variety of genres including Punk, Metal, Pop-punk, Rock'n'roll, and Industrial, we have a catalog of 41 songs to enjoy. The game supports mixed reality capture for an even more immersive experience.\n\nCustomize your drum set-up and play the way you want. We're constantly updating the game with new music and techniques to ensure an enjoyable and engaging experience. The game also features variety of street environments, from urban to suburban. Whether you're a beginner or a seasoned pro, you can start on medium difficulty and increase the challenge as you progress.\n\nExperience the thrill of drumming in a realistic street environment with GrooVR. Take the first step towards becoming an expert virtual drummer today.", "short_description": "Unleash your inner musician with GrooVR, the ultimate virtual reality rhythm game. Play drums in a variety of genres & environments, with 41 songs & mixed reality capture. Customize your set-up & increase difficulty as you progress. Experience the thrill of drumming in a realistic street environment"}]}, "developer_name": "Mercuryo Tecnologia", "developer_privacy_policy_url": "http://mercuryotecnologia.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mercuryo Tecnologia", "support_website_url": "https://mercuryotecnologia.com/contato/", "website_url": "http://mercuryotecnologia.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"