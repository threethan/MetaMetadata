6e7a0a&_nc_ohc=DbLb3gkNox8Q7kNvgEOCqpz&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCO3LrrmGyzUZ0O2YvLNZ_D9mT94pspz3xYn-hr242LrQ&oe=67110851"}, {"file_name": "4.png", "id": "1238784160796244", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75393559_1238784164129577_6520858314431013970_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nj5hIKp16iMQ7kNvgGkQ-em&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBQuz-Mp4Dt1UcAxGWGfLTLLfIfhUUuaupDWHjZWDs7QQ&oe=67110B3A"}, {"file_name": "2.png", "id": "1023117479410297", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75196225_1023117482743630_2968125802103535690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W9N3oNaxtOYQ7kNvgHgx05M&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAp5l-_YwydyzhPUEbxnEXIyE-ou0hBh7oxbtdjJeColw&oe=67110336"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1171020204116800", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75393560_1171020207450133_8492329113192424785_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4heNTni-gpIQ7kNvgFKiQzp&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC-hmzubE7o9qmYwVywgc9CvK13_P71mvhgXqJPMyVLBA&oe=6710E85A"}, "display_name": "Ninja's Last Stand", "keywords": [], "long_description": "In a world torn apart by war and chaos, the ancient art of the ninja is the last hope for survival. As the world descends into darkness, you, a skilled ninja warrior, must defend against relentless assaults using your katana and futuristic gun. Set against the backdrop of a war-torn landscape illuminated by the dying light of the setting sun, \"Ninja's Last Stand\" immerses you in a gripping narrative of honor, duty, and survival.\nKey Features\n\n1. Immersive VR Experience\n\n    Step into a fully immersive VR world where every slash of your katana and every shot from your gun feels real. The high-fidelity graphics and realistic soundscapes create an unparalleled sense of presence and engagement.", "short_description": "Storyline\n\nIn a world torn apart by war and chaos, the ancient art of the ninja is the last hope for survival. As the world descends into darkness, you, a skilled ninja warrior, must defend against relentless assaults using your katana and futuristic gun. Set against the backdrop of a war-torn landscape illuminated by the dying light of the setting sun, \"Ninja's Last Stand\" immerses you in a gripping narrative of honor, duty, and survival."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/ninjas-last-stand/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "WHR26 Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/ninjas-last-stand", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7691412447623754"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7756901807741484", "version": "1.0"}, "id": "778239654390978", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application