.", "short_description": "Storyline\n\nIn a world torn apart by war and chaos, the ancient art of the ninja is the last hope for survival. As the world descends into darkness, you, a skilled ninja warrior, must defend against relentless assaults using your katana and futuristic gun. Set against the backdrop of a war-torn landscape illuminated by the dying light of the setting sun, \"Ninja's Last Stand\" immerses you in a gripping narrative of honor, duty, and survival."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/ninjas-last-stand/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "WHR26 Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/ninjas-last-stand", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7691412447623754"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7756901807741484", "version": "1.0"}, "id": "778239654390978", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7691412417623757", "is_c