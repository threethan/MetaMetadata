n.\n6. The app runs noticeably lower than 60 frames per second on supported devices. Please refer to https://developer.oculus.com/blog/how-to-optimize-your-oculus-quest-app-w-renderdoc-walkthroughs-of-key-usage-scenarios-and-optimization-tips-part-1/ and https://developer.oculus.com/blog/how-to-optimize-your-oculus-quest-app-w-renderdoc-walkthroughs-of-key-usage-scenarios-and-optimization-tips-part-2/?locale=en_US"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031359_387467107580821_2830420834373503656_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mgkllBhYxsUQ7kNvgHCiD-3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUv0TaamQ9O-L2Df9naR-L6r6R-HkDOX33Kj6FyS4YXw&oe=671B6E1C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bloodless", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1727824080, "lastRevision": {"nodes": [{"id": "7768109119982068", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7768109089982071", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1017426146783201"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "image (1).png", "id": "2859995087474016", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75429290_2859995090807349_2672987239205654210_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hKUODk3XRqsQ7kNvgGvIqrD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARthQvpD2bJsa_gbJWuQkH57zbdZt8tl7tIHD6X3jX4g&oe=671B92AF"}, {"file_nam