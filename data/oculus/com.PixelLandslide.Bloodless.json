r second on supported devices. Please refer to https://developer.oculus.com/blog/how-to-optimize-your-oculus-quest-app-w-renderdoc-walkthroughs-of-key-usage-scenarios-and-optimization-tips-part-1/ and https://developer.oculus.com/blog/how-to-optimize-your-oculus-quest-app-w-renderdoc-walkthroughs-of-key-usage-scenarios-and-optimization-tips-part-2/?locale=en_US"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031359_387467107580821_2830420834373503656_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cUNhIAC7QbcQ7kNvgGrx20d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6l5RC1OYfH8N1zgbn6LqdSaZ9ILvkLnkxvOKDKcg81Q&oe=673B121C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bloodless", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1727824080, "lastRevision": {"nodes": [{"id": "7768109119982068", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7768109089982071", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1017426146783201"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "image (1).png", "id": "2859995087474016", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75429290_2859995090807349_2672987239205654210_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0XHmUQlq_40Q7kNvgGsw0le&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDV5Vp5bPqSNhiIkATeBtNtEau2td9STGvXuFY4p9Bj9A&oe=673B36AF"}, {"file_name": "MainScene_Custom..._19.09.2024_15-57-20.png", "id": "1803604120170967", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculusc