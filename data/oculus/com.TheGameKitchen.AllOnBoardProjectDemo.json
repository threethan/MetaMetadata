ontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031639_444485658748540_2004858343361051430_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mVPtELvWLKkQ7kNvgE5_Tbq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8iKIdPZ7w2iYOe51yzIrM-deSoOIWC6JqhzTr98iAsQ&oe=6713A7F7"}]}, "id": "1566053697633818", "locale": "en_US", "screenshots": [{"file_name": "MR_2560x1440.png", "id": "3926993714243148", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75540501_3926993717576481_5999768018423374910_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TwhvrZxDDeYQ7kNvgFCGyHT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCOLkOSGSuvuaCh1hid2q7oXqH7nUeXTrUZpgUPh6YlyQ&oe=67139197"}, {"file_name": "Istanbul_2560x1440.png", "id": "1609506353108476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035469_1609506356441809_5222853278055771583_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MM09ZH4WgVwQ7kNvgHuPoAW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIF59ytNHTPfgo9mjrSiMwlVHRmCoMWgt8f-iGeaBMUA&oe=67138601"}, {"file_name": "ETDC_2560x1440.png", "id": "457727553971002", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974527_457727557304335_3237724291120605108_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rEMlsv0YWB8Q7kNvgG3E9N7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDleTd3gbII9L-nJ9KE5Wn6mmgdlBG9yL3xXfbU0Fqd_A&oe=6713A6E8"}, {"file_name": "RallymanGT_2560x1440.png", "id": "461759443544695", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031359_461759446878028_1513041090128553992_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qtl7p6JeBLIQ7kNvgFWqyyV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkuXlpUPiSZ1FFPjUgL9UHUGr84XBNo7guht4RZMblMw&oe=671399B9"}, {"file_name": "TBI_2560x1440.png", "id": "3832428817085206", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572940_3832428820418539_7817805165391346146_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vmLYK1APZrcQ7kNvgEPExmz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-Ortk0vNY21GDWgYFTreqv7A3CZSfWXgW3gMMzkI7lA&oe=67137FC5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "552619510764476", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570288_552619514097809_150010993699126353_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YWdsXOMo6ygQ7kNvgEcTWMw&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCok10frIkzReGLBBSirvbMTAa0UZfEWyzKWTYJPl8H-w&oe=6713B19C"}, "display_name": "All On Board! - Demo", "keywords": ["tabletop", "board", "multiplayer", "dice", "card"], "long_description": "All On Board! is a revolutionary tabletop platform built from the ground up specifically for VR, created by and for board game enthusiasts. As **the only platform natively built for VR**, All On Board! fully exploits the capabilities of virtual reality to deliver an **unmatched board gaming experience**. This includes **predictive selection** and positioning of board elements while enjoying **realistic physical interactions** close to real life. A unique platform that is **constantly evolving**, both functionally and in its game catalog, packed with **beloved franchises** among board game enthusiasts.\n\nExperience the joy of discovering new games, just like browsing the latest releases at your favorite store: All On Board! brings you shared moments of discussion, laughter, and nostalgia reminiscent of past adventures and unforgettable games.\n\n# Features:\n- **Only one player is required to purchase game titles**: If you own a game, you can invite your friends to play for free, just like in real life\n- Experience interactions that are **intuitive and naturally immersive**\n- **Top-tier games meticulously adapted for VR**, ensuring exceptional gameplay and smooth interactions\n- Quickly learn the rules with **in-game tutorials and contextual help** that provides more information about any component\n- **Tailored gameplay for 1 to multiple players,** including solo and co-op modes. You can even tackle cooperative games on your own!\n- **Cross-platform support**\n- Play in your preferred language, with **ongoing additions to our language support**", "short_description": "Designed from the ground up for VR, All On Board! offers seamless board game experiences. Join this ever-evolving platform and connect with fellow board game enthusiasts! Choose your avatar and enjoy playing solo or with friends, diving into some of the most popular board game franchises."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thegamekitchen.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "The Game Kitchen", "support_website_url": null, "website_url": "https://thegamekitchen.com/all-on-board-vr/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "8445333772199824"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1211903400114553"}]}, "baseline_offer": {"id": "1211903400114553"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728895980, "status": "PUBLISHED", "id": "1211903400114553"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8456055334461001", "version": "0.4.20241014"}, "id": "884338983216186", "channel_name": "LIV