99113017996", "version": "2.1.9"}, "id": "564552832079213", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5605318496232756", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8770799113017996"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "564552832079213"}]}, "change_log": "[New]\n\u2728\ufe0f\ud06c\ub9ac\uc2a4\ub9c8\uc2a4\ub97c \uc704\ud55c \uc5c5\ub370\uc774\ud2b8\ud83c\udf84\n\uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc544\ub291\ud55c \ud06c\ub9ac\uc2a4\ub9c8\uc2a4 \ub77c\uc6b4\uc9c0\uc5d0\uc11c \ubcf4\ub4dc\uac8c\uc784\uc744 \uc990\uae30\uace0, \ub208 \uc313\uc778 \uc815\uc6d0\uc5d0\uc11c \ub208\uc0ac\ub78c\uc744 \ub9cc\ub4e4\uba70 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4\ubcf4\uc138\uc694!\n\n[Fixed]\n- 'Rummy' \uce74\ub4dc \uc81c\ucd9c \uc218\uc815\n- 'YutNori' \uadf8\ub7a9 \uc0c1\ud638\uc791\uc6a9 \uc218\uc815\n\n[Changed]\n- \uac8c\uc784 \uc804\uccb4 \ubc30\uacbd\uc74c \ubcc0\uacbd (20% \uac10\uc18c)\n----------------------------------------------------\n\n[New]\n\u2728Update for Christmas\ud83c\udf84\nGather with friends in a cozy Christmas lounge to enjoy board games, and create unforgettable memories by building snowmen in the snow-covered garden!\n\n[Fixed]\n- Fixed 'Rummy' card submission\n- Fixed 'YutNori' grab interaction\n\n[Changed]\n- Changed the game's overall background music (20% reduction)\n----------------------------------------------------\n\n[\u65b0\u7684]\n- \u6dfb\u52a0\u4e86\u201c\u5723\u8bde\u5ba4\u201d\u6237\u5916\u80cc\u666f\n\uff08\u5806\u96ea\u4eba\u88c5\u9970/\u6253\u96ea\u4ed7/\u7167\u76f8\u4ead\uff09\n\n[\u56fa\u5b9a]\n- \u4fee\u6b63\u4e86\u201c\u62c9\u7c73\u7eb8\u724c\u201d\u5361\u63d0\u4ea4\u95ee\u9898\n- \u4fee\u590d\u4e86\u201c\u63b7\u67f6\u6e38\u