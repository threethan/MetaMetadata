id": "1004877167789671", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031359_1004877171123004_1970934161746196061_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sx0VecHLr40Q7kNvgH4blHY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4uWDNVJH-p7T7kXMqmsz044kBkuAEdtijHU2zKZeegQ&oe=675451CE"}, {"file_name": "OneCard.png", "id": "973194844554649", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974860_973194847887982_4612231095307736624_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PSQphkYITP0Q7kNvgGmCYxt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLJyDZPOUmvgsY7UionVFEzQnENIpMoDcEzo4W3oYFxw&oe=675427F4"}, {"file_name": "Othello.png", "id": "1169262260963445", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036672_1169262264296778_8678668044385453575_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qtYwU64XZWkQ7kNvgFz29T1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmmVY8eu6rWU6VoflZIMKCnkDcj5t1eoCX9BwPS-596Q&oe=67545166"}, {"file_name": "Checkers.png", "id": "3680115255651368", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001727_3680115258984701_8052417639813105498_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_x6Wu-7YSE8Q7kNvgHQ2kyq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5-udSRIRbLUQji1hHg-gh51PHsGKWZo97wSYNDSDv9A&oe=675425ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\ud14c\uc774\ube14\ud30c\ud2f0-\ud64d\ubcf4\uc601\uc0c1---frame-at-1m2s.png", "id": "1746124902833245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75429290_1746124909499911_2726300108008323754_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1EumHYWpqjQQ7kNvgHr3bFD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBPhcnvJTDhImIZVzXSvbJL2-Iah_7noNkBCZIATamkGQ&oe=67542904"}, "display_name": "Table Party", "keywords": ["tablegame", "boardgame", "tabletop", "casualgame", "familygame"], "long_description": "Hello players!\nTable Party is a party game in which you can compete by playing 14 types of board games and casual games together.\nPlay with your friends and family and enjoy a great and warm time.\n\nIncluded\n\ud83c\udfae11 types of board games: Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi, One card, Catch the Ghost\n\ud83c\udfae3 types of causal games : Stack Up, Flying Arrow, Whack a Mole\n\nFeatures\n\u2705 It provides single play with AI or multi-play with up to 4 players.\n\u2705 You can choose quick matching or join party to play games.\n\u2705 Create a party and invite friends using a four-digit invitation code\n\u2705 Meta account avatar support: Show off your unique style with your Meta account avatar!\n\u2705 Win with a high score and record my score on the global leaderboard.\n\u2705 Within this year, beloved licensed board games will be added.\n\u2705 Party Room: This dedicated space lets you hang out with your friends before diving into a game. Use voice chat to discuss and pick the perfect game for your party.\n\u2705 Community Room: Up to 10 players can gather and play! Play with interactive props, score goals at basketball games, or challenge your friends to play darts.\n\n\u2728Now Updates!! - New Board Game : Catch the Ghost!\ud83d\udc7b\n\nWe're constantly working to make Table Party the best place to hang out and have fun with friends in VR.\nThis update is just the beginning, and we can't wait to see what kind of parties you create!\n\n[Join us]. We invite you to join us on the official Discord : https://discord.gg/FguwhrGpuf", "short_description": "Hello players!\n\nTable Party is a party game in which you can compete by playing 14 types of board games and party games together.\nPlay with your friends& family and enjoy a great and warm time.\n\nIncluded\n\ud83c\udfae11 types of board games: Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi, One card, Catch the Ghost\n\ud83c\udfae3 types of causal games : Stack Up, Flying Arrow, Whack a Mole"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/tableparty-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "DIVE XR", "support_website_url": "https://tableparty.bio.link/", "website_url": "https://tableparty.world/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "1700921480735423"}, {"id": "1023770785722696"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8518911288206781"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036662_1626397311550568_4363021870429209175_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vVhWkUoOoZsQ7kNvgFQpNL5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB54FAUxS3-BE5Nqx6lM-xbJIYLxtf31xcs97JinxTs7Q&oe=67543B80"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Table Party", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Tabletop", "id": "1676485315806614"}, {"topic_name": "Party Game", "id": "1700921480735423"}, {"topic_name": "Hangout", "id": "1023770785722696"}], "release_date": 1680020018, "lastRevision": {"nodes": [{"id": "5605318526232753", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": 