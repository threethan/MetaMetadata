101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YWMSXX0dLVMQ7kNvgETiIFx&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBwwiMnkt5IvRtYIRP49WED9whkMTYjnC7vLab3jjBaHA&oe=670BAD81"}]}, "id": "196045786467192", "locale": "en_US", "screenshots": [{"file_name": "yatch.png", "id": "871559620526613", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974671_871559623859946_3801867750823793187_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GuM4IS1-P4EQ7kNvgFRmrLi&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBKvROnOtmxaZFAZeTsgHNG6BpaU0liXi2uW5vBn1AMWw&oe=670BC1A7"}, {"file_name": "yut.png", "id": "6132789563399336", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75240095_6132789566732669_6834733629130888432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cx8EoEvbk7cQ7kNvgHg4u3T&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCWxQQB3mw9eP-3H6ppQATU4N_WTlKnTkRDKJTex_HqCw&oe=670B9E73"}, {"file_name": "onecard.png", "id": "610033584227099", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031474_610033587560432_3215734240479783219_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n2DIPtRLDp4Q7kNvgGi6MiZ&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCYVfeD9nxkhfAWRGFNvcEZ_v59wTBDbCEa_TpMqO_I6Q&oe=670BB133"}, {"file_name": "mole.png", "id": "921781818961118", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/57572938_921781825627784_2927134400183828765_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DlyYqedEH9EQ7kNvgEGn8UG&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCy-AZk2m-aCKFrgS-oMKCXZL5NFBYgMR6JnfXy3ecSag&oe=670BCD3C"}, {"file_name": "KrJanggi.png", "id": "472121881748157", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974520_472121885081490_1892531947339875431_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1LPX_dm7RpcQ7kNvgFpdWy0&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCG0CjWST2yA5ItbQGnPXMQf-ZXFuqU-sxq_lx1bNI8oQ&oe=670BA0C4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TableParty_CoverLandscape.png", "id": "878196316837935", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39036614_878196320171268_6372722976452859490_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g8SlBEnZgCMQ7kNvgFzmq5H&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBwVXXm-OYK3LsJSHRpkhQPObLQu2DeOYcqbeEIvhRvsA&oe=670B97BF"}, "display_name": "Table Party", "keywords": [], "long_description": "Welcome to the fantastic boardgame world!\nIf you want to play board games in VR, download Table Party right now! You can enjoy a variety of content in a wonderful virtual space with everyone.\nEnjoy 10 board games and 3 casual games in a fantastic virtual world with the cool look I imagined!\nNo friends to play with?\nDo not worry!\nYou can make friends with people from all over the world and hang out in the virtual world.\nAlso, more games and contents will be added, so please look forward to it.\nHave Fun!\n\nFeatures:\nSingle play / Multi play \nYou can customize your avatar in your private room.\n10 types of board games: One card, Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi\n3 types of causal games : Stack Up, Flying Arrow, Whack a Mole", "short_description": "Welcome to the fantastic boardgame world!\nIf you want to play board games in VR, download Table Party right now! You can enjoy a variety of content in a wonderful virtual space with everyone.\nEnjoy 9 board games and 4 casual games in a fantastic virtual world with the cool look I imagined!\nNo friends to play with?\nDo not worry!\nYou can make friends with people from all over the world and hang out in the virtual world.\nHave fun!"}, {"images": {"nodes": []}, "id": "188481697255683", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Table Party", "keywords": [], "long_description": "\ud658\uc0c1\uc801\uc778 \ubcf4\ub4dc\uac8c\uc784 \uc138\uacc4\uc5d0 \uc624\uc2e0 \uac83\uc744 \ud658\uc601\ud569\ub2c8\ub2e4!\n\uac00\uc0c1 \ud604\uc2e4\uc5d0\uc11c \ub354\uc6b1 \uc7ac\ubbf8\uc788\uac8c \ubcf4\ub4dc\uac8c\uc784\uc744 \uc990\uae30\uace0 \uc2f6\uc73c\uba74 \uc9c0\uae08 \ubc14\ub85c Table Party\ub97c \ub2e4\uc6b4\ubc1b\uc73c\uc138\uc694!\n\uba4b\uc9c4 \uac00\uc0c1\uacf5\uac04\uc5d0\uc11c \uc5ec\ub7ec \uce5c\uad6c\ub4e4\uacfc \ubcf4\ub4dc\uac8c\uc784 10\uc885, \uce90\uc8fc\uc5bc \uac8c\uc784 3\uc885\uc744 \uc990\uae38 \uc218 \uc788\uc5b4\uc694.\n\ub0b4\uac00 \uc0c1\uc0c1\ud558\ub358 \uba4b\uc9c4 \ubaa8\uc2b5\uc73c\ub85c \ud658\uc0c1\uc801\uc778 \uac00\uc0c1\uc138\uacc4\uc758 \ud50c\ub808\uc774\ub97c \uc990\uaca8\ubcf4\uc138\uc694!\n\uac19\uc774 \ub180 \uce5c\uad6c\uac00 \uc5c6\ub2e4\uad6c\uc694?\n\uac71\uc815\ud558\uc9c0 \ub9c8\uc138\uc694!\n\uc804\uc138\uacc4 \uc0ac\ub78c\ub4e4\uacfc \uce5c\uad6c\uac00 \ub418\uc5b4 \uac00\uc0c1\uc138\uacc4\uc5d0\uc11c \uc5b4\uc6b8\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\ucd94\uac00\uc801\uc73c\ub85c, \uac8c\uc784\uacfc \ucf58\ud150\uce20\uac00 \ub354 \ucd94\uac00\ub420 \uc608\uc815\uc774\ub2c8 \uae30\ub300\ud574 \uc8fc\uc138\uc694.\n\n\uae30\ub2a5 : \n- \uc2f1\uae00\ud50c\ub808\uc774(\uc77c\ubd80) / \uba40\ud2f0\ud50c\ub808\uc774\n- \uce90\ub9ad\ud130 \ucee4\uc2a4\ud130\ub9c8\uc774\uc9d5 \uac00\ub2a5\n- 10\uac00\uc9c0 \ubcf4\ub4dc\uac8c\uc784 \uc81c\uacf5 : \uc6d0\uce74\ub4dc, \uc694\ud2b8 \ub2e4\uc774\uc2a4, \uc624\ub378\ub85c, \uccb4\uc2a4, \uccb4\ucee4, \ub7ec\ubbf8, \uc9c4\ub7ec\ubbf8, \uc737\ub180\uc774, \uc624\ubaa9, \uc7a5\uae30\n- 3\uac00\uc9c0 \uce90\uc8fc\uc5bc\uac8c\uc784 \uc81c\uacf5 : \ube14\ub85d\uc313\uae30, \ud65c\uc3d8\uae30\uac8c\uc784, \ub450\ub354\uc9c0\uc7a1\uae30 \uac8c\uc784", "short_description": "\ud658\uc0c1\uc801\uc778 \ubcf4\ub4dc\uac8c\uc784 \uc138\uacc4\uc5d0 \uc624\uc2e0 \uac83\uc744 \ud658\uc601\ud569\ub2c8\ub2e4!\n\uac00\uc0c1 \ud604\uc2e4\uc5d0\uc11c \ub354\uc6b1 \uc7ac\ubbf8\uc788\uac8c \ubcf4\ub4dc\uac8c\uc784\uc744 \uc990\uae30\uace0 \uc2f6\uc73c\uba74 \uc9c0\uae08 \ubc14\ub85c Table Party\ub97c \ub2e4\uc6b4\ubc1b\uc73c\uc138\uc694!\