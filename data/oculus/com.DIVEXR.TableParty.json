11&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ECw1mmsMfzMQ7kNvgF04i9I&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiZgtgsNLRkMLvl5u6WI6HGzdIfphqprMNvh8Q4RN5xA&oe=67371B9B"}, {"file_name": "right_immersive_tableparty.png", "id": "846074040963443", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974721_846074044296776_4350512281988633128_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=etkbqbkg8h4Q7kNvgGV0Z5G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBx8TW6yKQZ0PhESWKT7tTZvEA9enBqbt03XYJW5XfSOA&oe=67373B68"}, {"file_name": "left_immersive_tableparty.png", "id": "508433298566180", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75612008_508433301899513_8062498465047080369_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Dls0p7AFhMQ7kNvgFw2etc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1FodbAVXBlvODiWSOHhoiQzKHodZyvgsEUHChoeWY-A&oe=6737327E"}]}, "id": "437422769118804", "locale": "en_US", "screenshots": [{"file_name": "YachtDice.png", "id": "1619534035288166", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035344_1619534038621499_2002293431732581668_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RnIhV-YtBHcQ7kNvgGSJwBo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAG-s0tJxzZ5k96_1jrGmT4Ep9RRk5koPyiER_BKFZL0Q&oe=67374C28"}, {"file_name": "GinRummy.png", "id": "1004877167789671", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031359_1004877171123004_1970934161746196061_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E17tnRsbOH4Q7kNvgFnadsN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1hO-r-VGqW9fzkvobf8IKGyKYeLFdxHxBKojlbR8_UA&oe=6737188E"}, {"file_name": "OneCard.png", "id": "973194844554649", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974860_973194847887982_4612231095307736624_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7owXBnA1AEQ7kNvgHoPZ6S&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDwGgwlDDBb8zwDQsIldLRi3Etm3U0K0QSosj9OiOXsNg&oe=673726F4"}, {"file_name": "Othello.png", "id": "1169262260963445", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036672_1169262264296778_8678668044385453575_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ES_CKODaKmwQ7kNvgEmTJTI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqJnInIg3R-88iiAQJIu5PsXV4t9Usc7X67kRL94J1Lw&oe=67371826"}, {"file_name": "Checkers.png", "id": "3680115255651368", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001727_3680115258984701_8052417639813105498_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XIe3l4CADM8Q7kNvgGBMsmF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOhgCbHREg-9Yyrd8tBj3UdWjmorgORv60uuDfXzM7Zw&oe=673724ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "840362334948083", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031607_840362338281416_3860118050106765431_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oKgMYM8V_8AQ7kNvgEbKTmQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDI7Wu4sfzZKXPuO95lISYBSpsCdcdJuGgLwKKuE8xJWw&oe=67373A03"}, "display_name": "Table Party", "keywords": ["tablegame", "boardgame", "party", "table", "mutiplay"], "long_description": "Hello players!\nTable Party is a party game in which you can compete by playing 13 types of board games and casual games together.\nPlay with your friends and family and enjoy a great and warm time.\n\nIncluded\n\ud83c\udfae10 types of board games: One card, Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi\n\ud83c\udfae3 types of causal games : Stack Up, Flying Arrow, Whack a Mole\n\nFeatures\n\u2705 It provides single play against AI and multi-play with up to 4 players.\n\u2705 You can choose quick matching or join party.\n\u2705 Create a party and invite friends using a four-digit invitation code\n\u2705 Meta account avatar support: Show off your unique style with your Meta account avatar!\n\u2705 Win with a high score and record my score on the global leaderboard.\n\u2705 Within this year, beloved licensed board games will be added.\n\nNow Updates!! :  Party Room and Community Room:\n- Party Room: This dedicated space lets you hang out with your friends before diving into a game. Use voice chat to discuss and pick the perfect game for your party.\n- Community Room: Up to 8 players can gather and play! Play with interactive props, score goals at basketball games, or challenge your friends to play darts.\n\nWe're constantly working to make Table Party the best place to hang out and have fun with friends in VR.\nThis update is just the beginning, and we can't wait to see what kind of parties you create!\n\n[Join us]. We invite you to join us on the official Discord (https://discord.com/invite/A3GvvMPDKg).", "short_description": "Hello players!\n\nTable Party is a party game in which you can compete by playing 13 types of board games and party games together.\nPlay with your friends& family and enjoy a great and warm time.\n\nIncluded\n\ud83c\udfae10 types of board games: One card, Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi\n\ud83c\udfae3 types of causal games : Stack Up, Flying Arrow, Whack a Mole"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/tableparty-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "DIVE XR", "support_website_url": null, "website_url": "https://tableparty.world/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "1700921480735423"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOV