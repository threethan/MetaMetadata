{"data": {"node": {"__typename": "Application", "id": "5605318496232756", "organization": {"id": "106237975283561", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "5605318496232756"}]}, "id": "3403143166599169"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "4766954810024932"}]}, "id": "681007532899399"}]}}, "firstRevision": {"nodes": [{"application": {"id": "5605318496232756", "release_date": 1680020018, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 5}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8770799113017996"}, "id": "564552832079213"}]}}, "binary": null, "live_binary": null, "created_date": 1729664946, "id": "8441472755950635", "is_initial_release": false, "name_with_fallback": "v5", "pdp_metadata_with_fallback": {"version": 4, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8518911288206781"}, "release_status": "RELEASED", "id": "5605318496232756"}, "id": "8518911288206781", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5605318496232756", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1221583608768817"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "9239363192760246", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Table Party", "keywords": [], "long_description": "\ud14c\uc774\ube14 \ud30c\ud2f0\ub294 14\uac00\uc9c0 \ubcf4\ub4dc\uac8c\uc784\uacfc \uce90\uc8fc\uc5bc \uac8c\uc784\uc744 \ud568\uaed8 \ud50c\ub808\uc774\ud558\uba70 \uacbd\uc7c1\ud560 \uc218 \uc788\ub294 \ud30c\ud2f0 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\uce5c\uad6c\ub098 \uac00\uc871\ub4e4\uacfc \ud14c\uc774\ube14 \ud30c\ud2f0\uc5d0\uc11c \uc990\uac81\uace0 \ub530\ub73b\ud55c \uc2dc\uac04 \ubcf4\ub0b4\uc138\uc694! \n\n[\ud3ec\ud568 \uc0ac\ud56d]\n\ud83c\udfae\ubcf4\ub4dc \uac8c\uc784 11\uc885:  \uc694\ud2b8 \uc8fc\uc0ac\uc704, \uc624\ub378\ub85c, \uccb4\uc2a4, \uccb4\ucee4, \ub7ec\ubbf8, \uc9c4 \ub7ec\ubbf8, \uc737\ub180\uc774, \uc624\ubaa9, \uc7a5\uae30, \uc6d0\uce74\ub4dc, \uce90\uce58 \ub354 \uace0\uc2a4\ud2b8\n\ud83c\udfae\uce90\uc8fc\uc5bc \uac8c\uc784 3\uc885 : \uc2a4\ud0dd\uc5c5, \ub0a0\uc544\ub77c \ud654\uc0b4, \ub450\ub354\uc9c0 \uc7a1\uae30\n\n[\ud2b9\uc9d5]\n\u2705 AI\uc640\uc758 \uc2f1\uae00 \ud50c\ub808\uc774\uc640 \ucd5c\ub300 4\uc778 \uba40\ud2f0 \ud50c\ub808\uc774\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\u2705 \ube60\ub978 \ub9e4\uce6d \ub610\ub294 \ud30c\ud2f0 \uac00\uc785\uc744 \uc120\ud0dd\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\u2705 4\uc790\ub9ac \ucd08\ub300 \ucf54\ub4dc\ub97c \uc0ac\uc6a9\ud558\uc5ec \ud30c\ud2f0\ub97c \ub9cc\ub4e4\uace0 \uce5c\uad6c\ub97c \ucd08\ub300\ud558\uc138\uc694.\n\u2705 \uba54\ud0c0 \uacc4\uc815 \uc544\ubc14\ud0c0 \uc9c0\uc6d0: \uba54\ud0c0 \uacc4\uc815 \uc544\ubc14\ud0c0\ub85c \ub098\ub9cc\uc758 \uc2a4\ud0c0\uc77c\uc744 \ubf50\ub0b4 \ubcf4\uc138\uc694.\n\u2705 \ub192\uc740 \uc810\uc218\ub85c \uc2b9\ub9ac\ud558\uace0 \uae00\ub85c\ubc8c \ub9ac\ub354\ubcf4\ub4dc\uc5d0 \ub0b4 \uc810\uc218\ub97c \uae30\ub85d\ud558\uc138\uc694.\n\u2705 \uc62c\ud574 \uc548\uc5d0 \uc778\uae30 \ub77c\uc774\uc120\uc2a4 \ubcf4\ub4dc \uac8c\uc784\uc774 \ucd94\uac00\ub420 \uc608\uc815\uc785\ub2c8\ub2e4.\n\u2705 \ud30c\ud2f0\ub8f8: \uc774 \uc804\uc6a9 \uacf5\uac04\uc5d0\uc11c\ub294 \uac8c\uc784\uc744 \uc2dc\uc791\ud558\uae30 \uc804\uc5d0 \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc5b4\uc6b8\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc74c\uc131 \ucc44\ud305\uc744 \uc0ac\uc6a9\ud558\uc5ec \ud300\uc6d0\ub4e4\uacfc \ud568\uaed8 \ud50c\ub808\uc774\ud560 \uac8c\uc784\uc744 \uc120\ud0dd\ud558\uc138\uc694.\n\u2705 \ucee4\ubba4\ub2c8\ud2f0 \ub8f8: \ucd5c\ub300 8\uba85\uc774 \ubaa8\uc5ec\uc11c \ub180 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uc18c\ud488\uc744 \uac00\uc9c0\uace0 \ub180\uac70\ub098, \ub18d\uad6c \uac8c\uc784\uc5d0\uc11c \uace8\uc744 \ub123\uac70\ub098, \uce5c\uad6c\ub4e4\uacfc \ub2e4\ud2b8 \uac8c\uc784\uc5d0 \ub3c4\uc804\ud574 \ubcf4\uc138\uc694.\n\n\n\u2728\ud575\uc2ec \uc5c5\ub370\uc774\ud2b8 - \uc0c8\ub85c\uc6b4 \ubcf4\ub4dc\uac8c\uc784 \ucd94\uac00 : \uce90\uce58 \ub354 \uace0\uc2a4\ud2b8\ud83d\udc7b\n\n\uc5ec\ub7ec\ubd84\uc774 Table Party\uc5d0\uc11c \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub294 \ucd5c\uace0\uc758 \uacf5\uac04\uc744 \ub9cc\ub4e4\uae30 \uc704\ud574 \ub04a\uc784\uc5c6\uc774 \ub178\ub825\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\uc774\ubc88 \uc5c5\ub370\uc774\ud2b8\ub294 \uc2dc\uc791\uc5d0 \ubd88\uacfc\ud558\uba70, \uc5ec\ub7ec\ubd84\ub4e4\uc774 \uc5b4\ub5a4 \ud30c\ud2f0\ub97c \ub9cc\ub4e4\uc5b4\ub0bc\uc9c0 \uae30\ub300\uac00 \ub429\ub2c8\ub2e4!\n\n[\ucd08\ub300]. \uacf5\uc2dd Discord(https://discord.com/invite/https://discord.gg/FguwhrGpuf)\uc5d0\uc11c \uc5ec\ub7ec\ubd84\uc744 \ucd08\ub300\ud569\ub2c8\ub2e4. \ub2e4\ub978 \ud50c\ub808\uc774\uc5b4\ub97c \ub9cc\ub098\uace0, \uac8c\uc784 \uacbd\ud5d8\uc744 \uacf5\uc720\ud558\uace0, \uce5c\uad6c\ub97c \uc0ac\uadc0\uace0, \uac1c\ubc1c\uc790\ub4e4\uc5d0\uac8c \ubb38\uc758\ud558\uac70\ub098 \uc758\uacac\uc744 \ub0a8\uae30\uace0, \ucd5c\uc2e0 \uc5c5\ub370\uc774\ud2b8 \uc18c\uc2dd\uc774\ub098 \uc774\ubca4\ud2b8 \uc815\ubcf4\ub97c \uc5bb\uc73c\uc2dc\uae30\ub97c \uae30\ub300\ud569\ub2c8\ub2e4!", "short_description": "\ud14c\uc774\ube14 \ud30c\ud2f0\ub294 14\uac00\uc9c0 \ubcf4\ub4dc\uac8c\uc784\uacfc \uce90\uc8fc\uc5bc \uac8c\uc784\uc744 \ud568\uaed8 \ud50c\ub808\uc774\ud558\uba70 \uacbd\uc7c1\ud560 \uc218 \uc788\ub294 \ud30c\ud2f0 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\uce5c\uad6c\ub098 \uac00\uc871\ub4e4\uacfc \ud14c\uc774\ube14 \ud30c\ud2f0\uc5d0\uc11c \uc990\uac81\uace0 \ub530\ub73b\ud55c \uc2dc\uac04 \ubcf4\ub0b4\uc138\uc694! \n\n[\ud3ec\ud568 \uc0ac\ud56d]\n\ud83c\udfae\ubcf4\ub4dc \uac8c\uc784 11\uc885:  \uc694\ud2b8 \uc8fc\uc0ac\uc704, \uc624\ub378\ub85c, \uccb4\uc2a4, \uccb4\ucee4, \ub7ec\ubbf8, \uc9c4 \ub7ec\ubbf8, \uc737\ub180\uc774, \uc624\ubaa9, \uc7a5\uae30, \uc6d0\uce74\ub4dc, \uce90\uce58 \ub354 \uace0\uc2a4\ud2b8\n\ud83c\udfae\uce90\uc8fc\uc5bc \uac8c\uc784 3\uc885 : \uc2a4\ud0dd\uc5c5, \ub0a0\uc544\ub77c \ud654\uc0b4, \ub450\ub354\uc9c0 \uc7a1\uae30"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "7649569555143308", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974561_7649569558476641_3142001480912758489_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AVGeL4AkVNgQ7kNvgHWyzrQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBC2jP6Ez13TYqkv63UezUKQpucd4pa7bvLarHzEGK6ag&oe=676C0543"}, {"file_name": "MiniLandscape.png", "id": "2074747812969341", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003255_2074747816302674_7817191131910045021_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TEoXJ06QyAsQ7kNvgFPObvV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpgPHELZNGLsdYsDqxT1z__pXK9zEomGcoMQcjbJd2pA&oe=676C0754"}, {"file_name": "TableParty_icon.png", "id": "1687023045489331", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974512_1687023048822664_5810002386210948502_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3MUULDdYGA4Q7kNvgFVGPNE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYACI7FRjczGQP8LEFCjJsSLt342JZI-6qVQX7koCBZ3hg&oe=676BDFF5"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "1626397308217235", "image_type": "APP_IMG_COVER_SQUARE", "uri