11&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XGDjH9T3JKIQ7kNvgF_279s&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7BiSEi9Tr5ezBvrlGC4At0G3NMWXaPhiuP16Whd1trw&oe=673B101B"}, {"file_name": "right_immersive_tableparty.png", "id": "846074040963443", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974721_846074044296776_4350512281988633128_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pgg5dcdz6AgQ7kNvgHEs0mr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRmfqenZiVbYn-y4HRHvM-QL5DGW7cGAvyGOOJc6Wtrg&oe=673B2FE8"}, {"file_name": "left_immersive_tableparty.png", "id": "508433298566180", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75612008_508433301899513_8062498465047080369_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dAAmpUlT6MUQ7kNvgEsGH35&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2z8hIDwD0C4Pa4VOEpLF1yh9eUQoRgQNCZwPZBdnojw&oe=673B26FE"}]}, "id": "437422769118804", "locale": "en_US", "screenshots": [{"file_name": "YachtDice.png", "id": "1619534035288166", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035344_1619534038621499_2002293431732581668_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f7d-XEOEp3YQ7kNvgEVEgRW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAK3_PHtKeHeVnlbzq73o_CVb0dYNO9nsV2gfH2hvDXyg&oe=673B40A8"}, {"file_name": "GinRummy.png", "id": "1004877167789671", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031359_1004877171123004_1970934161746196061_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XHxzGWa5S6cQ7kNvgHkA4Hi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7xEY1iR5-HrnztNRVhP_pwMmNX2FIk1s08Fqe5XuNag&oe=673B0D0E"}, {"file_name": "OneCard.png", "id": "973194844554649", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974860_973194847887982_4612231095307736624_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nx9ZJpNZWM0Q7kNvgG7uF2D&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqWEMMaE_3uZH10MpyyptGDfPa0Ak2DLc6NaJZn-9ecQ&oe=673B1B74"}, {"file_name": "Othello.png", "id": "1169262260963445", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036672_1169262264296778_8678668044385453575_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QC_M38yVcc0Q7kNvgGxdEqB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDo5BZG2RryNvaWVLS3_MxvyN3dxDIngy0mpap5Hrs9HQ&oe=673B0CA6"}, {"file_name": "Checkers.png", "id": "3680115255651368", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001727_3680115258984701_8052417639813105498_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JBCFCvCOjW4Q7kNvgGni4ai&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwllya-9GBwOuwxR7HTYEqOn55bgdZmIKPIv--Y2FSbQ&oe=673B196D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "840362334948083", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031607_840362338281416_3860118050106765431_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZFwpeAIas8gQ7kNvgEg0Ufc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLzQNq1rLKQlrmC0_cXFzhCrEF17bJlPfU46MvW_Mu8Q&oe=673B2E83"}, "display_name": "Table Party", "keywords": ["tablegame", "boardgame", "party", "table", "mutiplay"], "long_description": "Hello players!\nTable Party is a party game in which you can compete by playing 13 types of board games and casual games together.\nPlay with your friends and family and enjoy a great and warm time.\n\nIncluded\n\ud83c\udfae10 types of board games: One card, Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi\n\ud83c\udfae3 types of causal games : Stack Up, Flying Arrow, Whack a Mole\n\nFeatures\n\u2705 It provides single play against AI and multi-play with up to 4 players.\n\u2705 You can choose quick matching or join party.\n\u2705 Create a party and invite friends using a four-digit invitation code\n\u2705 Meta account avatar support: Show off your unique style with your Meta account avatar!\n\u2705 Win with a high score and record my score on the global leaderboard.\n\u2705 Within this year, beloved licensed board games will be added.\n\nNow Updates!! :  Party Room and Community Room:\n- Party Room: This dedicated space lets you hang out with your friends before diving into a game. Use voice chat to discuss and pick the perfect game for your party.\n- Community Room: Up to 8 players can gather and play! Play with interactive props, score goals at basketball games, or challenge your friends to play darts.\n\nWe're constantly working to make Table Party the best place to hang out and have fun with friends in VR.\nThis update is just the beginning, and we can't wait to see what kind of parties you create!\n\n[Join us]. We invite you to join us on the official Discord (https://discord.com/invite/A3GvvMPDKg).", "short_description": "Hello players!\n\nTable Party is a party game in which you can compete by playing 13 types of board games and party games together.\nPlay with your friends& family and enjoy a great and warm time.\n\nIncluded\n\ud83c\udfae10 types of board games: One card, Yacht Dice, Othello, Chess, Checkers, Rummy, Gin Rummy, Yut Nori, Omok, Janggi\n\ud83c\udfae3 types of causal games : Stack Up, Flying Arrow, Whack a Mole"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/tableparty-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "DIVE XR", "support_website_url": null, "website_url": "https://tableparty.world/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "1700921480735423"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOV