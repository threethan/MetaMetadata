ud558\ub294 \ub3cc\uc5f0\ubcc0\uc774 \uad70\ub2e8 '\ud14c\ub77c\ud1a0\ub9c8(Teratoma)'\uc640\uc758 \uae34\uc7a5\uac10 \ub118\uce58\ub294 \uc804\ud22c\ub97c \uacbd\ud5d8\ud574 \ubcf4\uc138\uc694. \n\uac04\ud3b8\ud558\uace0 \uc9c1\uad00\uc801\uc778 \uc870\uc791\ubc95\uacfc VR \uba40\ubbf8 \uc5b5\uc81c\ub97c \uc704\ud574 \uc900\ube44\ub41c \ub2e4\uc591\ud55c \uc2dc\uc2a4\ud15c\uc744 \ud1b5\ud574 \ubaa8\ud0c8\ube14\ub9ac\uce20 VR \ub9cc\uc758 \ub3c5\ud2b9\ud55c \uc138\uacc4\ub97c \ub204\uad6c\ub77c\ub3c4 \uc27d\uac8c \uacbd\ud5d8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\ubaa8\ud0c8\ube14\ub9ac\uce20 VR\uc740 \uc74c\uc131\uc744 \uc81c\uc678\ud55c \ubaa8\ub4e0 \ubd80\ubd84\uc5d0 \ub300\ud574 \ud55c\uae00\uc744 \uc9c0\uc6d0\ud558\uace0 \uc788\uc73c\ubbc0\ub85c, \ud55c\uad6d \uc720\uc800\ubd84\ub4e4\ub3c4 \ud3b8\uc548\ud558\uac8c \uac8c\uc784\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "\ubaa8\ud0c8\ube14\ub9ac\uce20 VR(Mortal Blitz VR)\u2019\uc740 VR(Virtual Reality)\uc744 \uc9c0\uc6d0\ud558\ub294 \uc0c8\ub85c\uc6b4 \uc2a4\ud0c0\uc77c\uc758 VR 1\uc778\uce6d \uac74\uc288\ud305 \uac8c\uc784 \uc785\ub2c8\ub2e4."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrsquare.skonec.com/privacy%20policy%20Skonec_01.htm", "developer_terms_of_service_url": "https://vrsquare.skonec.com/Skonec_Privacy_en.htm", "publisher_name": "Skonec Entertainment", "support_website_url": null, "website_url": "https://www.skonec.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "s