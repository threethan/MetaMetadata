oculuscdn.com/v/t64.5771-25/39003228_177703815249176_1528287960455225088_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0b3lL7jd524Q7kNvgF2nHXy&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB6WQ6VETfvnrIBiJHbUsFb9tTVrDnrI8Fb50Vn99jK3Q&oe=670FB48A"}, {"file_name": "scr_5.png", "id": "808935813774196", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031332_808935817107529_8861221418933832083_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hlQXLxZIGe8Q7kNvgGt6gh7&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCIyDGyBOgQ9vvBzrpAYHVu55kGM7P_j7NVinMhUllgtw&oe=670FB55C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The king is gone", "keywords": [], "long_description": "In this game, you have to run away. Different doors are blocking the way, that need to be unlocked to proceed as fast as possible. Each door will give a different benefit, and a combination of them is the key to succeed .. or fail.\n\nTo open a door, a puzzle is presented, where pieces of a key have to be rotated and merged together to open the door. The further you run, the more difficult the key puzzles become.\n\nThere are three different modes:\n\n* Normal Mode: Score is increasing the more you survive. It decreases the more you stay idle in a room without picking a door. There's a set amount of rooms to complete before reaching the end.\n* Endless Mode: Score increases with each room that is completed. There is no end to the amount of rooms presented.\n* Random Mode: Each door has a specific score as a reward when opened. Rooms and their rewards spawn at random.\n\nThe available benefits from the doors are:\n\n* Green doors: Increase running speed.\n* Purple doors: Increase lock-picking skills, which makes opening new doors easier.\n* Blue doors: Gives extra chances before losing.\n* Brown doors provide no direct benefit, apart from helping complete more rooms.", "short_description": "A puzzle game about running, not because one has somewhere to be, but because one has somewhere they don't want to be."}]}, "developer_name": null, "developer_privacy_policy_url": "https://afloofdev.com/privacy_policy/games/", "developer_terms_of_service_url": null, "publisher_name": "Afloofdev", "support_website_url": null, "website_url": "https://www.afloofdev.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "627777926076182"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031491_1485227315343125_5468368369070362490_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MUaPGNF2n4QQ7kNvgFS5_51&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAjyTfpGvqd36bqhrpOyojH36ZjlebNXmrX54XQ5ool1A&oe=670F94AC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The king is gone", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1686340294, "lastRevision": {"nodes": [{"id": "6481358201916380", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6481358165249717", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "A