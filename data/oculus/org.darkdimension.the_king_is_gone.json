lue doors: Gives extra chances before losing.\n* Brown doors provide no direct benefit, apart from helping complete more rooms.", "short_description": "A puzzle game about running, not because one has somewhere to be, but because one has somewhere they don't want to be."}]}, "developer_name": null, "developer_privacy_policy_url": "https://afloofdev.com/privacy_policy/games/", "developer_terms_of_service_url": null, "publisher_name": "Afloofdev", "support_website_url": null, "website_url": "https://www.afloofdev.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "627777926076182"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "789893479192767"}]}, "baseline_offer": {"id": "789893479192767"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1686340294, "status": "PUBLISHED", "id": "789893479192767"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6573711189347747", "version": "1.3.1"}, "id": "223601190479936", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6481358165249717", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6573711189347747"}, "release_sta