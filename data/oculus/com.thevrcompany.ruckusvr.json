ratives,\u201d choose which character to follow and discover a different path with a simple gaze of your eyes!\n\nA new animated experience from Oscar-winner Robert Stromberg and The Virtual Reality Company."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.thevrcompany.com/privacy-policy", "developer_terms_of_service_url": "https://www.thevrcompany.com/terms-of-use", "publisher_name": "The Virtual Reality Company", "support_website_url": null, "website_url": "http://www.thevrcompany.com/raising-a-rukus", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "ACTION", "EDUCATIONAL", "MOVIE", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "692712931896342"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1211057642334343", "version": "1.0.5f1"}, "id": "417819818582681", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1100532370053538", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1211057642334343"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "417819818582681"}]}, "change_log": "Downlo