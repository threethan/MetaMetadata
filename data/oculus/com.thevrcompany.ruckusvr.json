_1539544386096939_7248369185925890048_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZLcrQsujiUcQ7kNvgHdYmrf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABJcuBGthjMpgrsx4yVLqWB&oh=00_AYDHg4aG5lkhrHasTb_Y8BRMP-clu5VzvfnWTlb8GFY-BA&oe=66F00A94"}, {"file_name": "migrated_image.png", "id": "246754393025091", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162788_1159088237569028_8479258378613293056_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aLidxo2G9k0Q7kNvgFH7v_n&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABJcuBGthjMpgrsx4yVLqWB&oh=00_AYBHlyHtX8gOuBfgooY6dx7W-yxhNO2mDel75TzZBfiUrw&oe=66EFEF66"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Raising A Rukus", "keywords": ["Animated", "Kids", "Dog", "Dinosaur", "Film"], "long_description": "This adventure requires 2.6 GB total.\n\nTwins Amy and Jonas just found a dog- or did he find them? Either way, Rukus has a magical secret \u2013 he\u2019s about to take them to a whole new world. \n\nEqual parts thrilling, breathtaking, and inspiring, Raising a Rukus is an animated adventure like no other. With cutting edge \u201cbranching narratives,\u201d choose which character\u2019s journey you want to follow by a simple gaze with your eyes. \n\nJump right into magical, rollercoaster journey through a prehistoric world! Come along for the ride with Jonas and Amy as the river propels you, dinosaurs chase you, and Rukus delights you!\n\nRaising a Rukus is the first episode of the groundbreaking new franchise from the Academy Award Winning Production Designer of Avatar and the Director of Maleficent.", "short_description": "This adventure requires 2.6 GB total.\n\nRide along with twins Amy and Jonas as they chase their mischievous pet dog, Rukus, through an amazing adventure into a prehistoric world. \n\nWith cutting edge \u201cbranching narratives,\u201d choose which character to follow and discover a different path with a simple gaze of your eyes!\n\nA new animated experience from Oscar-winner Robert Stromberg and The Virtual Reality Company."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.thevrcompany.com/privacy-policy", "developer_terms_of_service_url": "https://www.thevrcompany.com/terms-of-use", "publisher_name": "The Virtual Reality Company", "support_website_url": null, "website_url": "http://www.thevrcompany.com/raising-a-rukus", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "EDUCATIONAL", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1527313400983886"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162680_438420913172078_3370516121437339648_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4RQQF6tXGf4Q7kNvgEBZsR2&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABJcuBGthjMpgrsx4yVLqWB&oh=00_AYDdTQF8YgrXcavVOz0z5guwhDeXp61M1iIJzUNpzS5Dgw&oe=66EFE5BA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Raising A Rukus", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1495691175, "lastRevision": {"nodes": [{"id": "532451033809406", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1100532370053538", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1462812933775224"}, "iarc_email": null, "msrp": null, 