scontent.oculuscdn.com&_nc_gid=Apu1XgBWI8HVpgKBHtvCRi6&oh=00_AYD1JRHEpJnqwdOaOGnj5Zx0kN23JSvTGSwyT5On5gMHVw&oe=66F53FEA"}, {"file_name": "Survr Pc 0.1 Screenshot 2021.12.01 - 21.22.14.75.png", "id": "2228715863949843", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_2228715867283176_7116284285201151182_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qnhz_skK_9wQ7kNvgETo3Pd&_nc_ht=scontent.oculuscdn.com&_nc_gid=Apu1XgBWI8HVpgKBHtvCRi6&oh=00_AYCfCuzZtLF6Sm0onQFFkiGJMEehgW_FdyvJe_cEgUvi4A&oe=66F53A64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Survival Vr Pc 0.7 Screenshot 2021.12.01 - 22.08.39.59.png", "id": "241985528008902", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574723_241985531342235_4127773330918326324_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lOFWiOtdFXYQ7kNvgFdDch0&_nc_ht=scontent.oculuscdn.com&_nc_gid=Apu1XgBWI8HVpgKBHtvCRi6&oh=00_AYCB51Cyxk1ChgmYlXhDmPu5CRJTKu3SIzAe4JMU8pA9Ew&oe=66F54650"}, "display_name": "SurVR", "keywords": [], "long_description": "SurVR is an open world single player game which allow player to get resources by using multiple tools.  After collecting enough of them you can build your own house! Get feeling of real honest hard work.\n\nKey features:\n- Detailed tutorial that gonna help you enter to the SurVR world\n- Intuitive building system dedicated for VR game\n- innovative UI for player backpack\n- gathering resources by own hands\n\nFuture development plan:\n- adding more maps with different enviroments\n- crafting system\n- extending building system\n- player vs monster AI\n- basic human needs :)\n- weather", "short_description": "Virtual reality sandbox survival game allowing player to feel like a real man; cut a tree, build a house!\n\nUse multiple tools like: axe, pickaxe, hammers, saw. Defeat forces of nature (trees or stones) and claim a place in this world for yourself."}]}, "developer_name": "Boomers.IT", "developer_privacy_policy_url": "https://boomersitgame.com/s