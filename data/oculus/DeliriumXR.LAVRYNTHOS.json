946763580", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974583_576033950096913_515331897680576336_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MWXSRnElH3UQ7kNvgGJr_lQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcnY1ytrlF_FBCgw6OYQFbRVXkIi1Tq2PDXSCcNQLxlQ&oe=67669B7D"}, {"file_name": "Lavrynthos_frame5.png", "id": "1985195041655061", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031342_1985195044988394_6013847476032584026_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cb4UI2W0-hkQ7kNvgFyGrVy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOPyf3wFRo3MI2PSU5n_c4gLlQwhZ34EP6mBvVjMSf_Q&oe=6766AC7C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover.png", "id": "751867579832471", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230049_751867583165804_5980597322316914656_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I-XQbxTnovUQ7kNvgH5E16r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXCEzLKVAnb7wcB4Oel1PxlIr2s316346dQvR1BsZfLQ&oe=6766B0FB"}, "display_name": "Lavrynthos", "keywords": [], "long_description": "Lavrynthos places you at the heart of the labyrinth of Crete to tell you the story of the unlikely relationship between the Minotaur and his next meal: a girl named Cora. \n\nA contemporary Greek tragedy paying homage to the cradle of modern dramatic theory while challenging it at the same time. Lavrynthos is a humorous take on a 3000-year-old myth updating it with themes and topics that are relevant in this day and age. \n\nThe narrative makes use of an innovative way of moving the player throughout the story by transforming a 2x2m area into an infinite non-euclidean maze that can shift space and time. \n\nLavrynthos messes up with your sense of direction, space, and balance and can make you get lost inside your own bedroom!\n\nCreated with support of the Venice Biennale College, Lavrythos premiered at Venice Film Festival and in 2022 won the Stereopsia Crystal Owl Award for Best Creative Experience.\n\n\"Lavrynthos Is A Brilliantly Smart Mix Of VR Storytelling And Impossible Spaces On Oculus Quest And PC\" - UploadVR", "short_description": "Lavrynthos places you at the heart of the labyrinth of Crete to tell you the story of the unlikely relationship between the Minotaur and his next meal: a girl named Cora.\n\nA contemporary Greek tragedy paying homage to the cradle of modern dramatic theory while challenging it at the same time.\n\nLavrynthos is a humorous take on a 3000-year-old myth updating it with themes and topics that are relevant in this day and age.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://astreaimmersive.io/lavrynthos-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://astreaimmersive.io/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7214240485329619"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_726347225612574_5149656256161174889_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SmV4oWjL1uYQ7kNvgGjYQSD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAjZP2Kjg_7PMHDVXfpW6Vc9jGIv2Ysyd7Oeo6lrDGivg&oe=6766C45F"}, "is_concept": false, "is_test": false, "is_trial_offer_vali