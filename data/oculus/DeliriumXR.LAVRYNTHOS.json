vrynthos_MiniLandscape.png", "id": "222883710310790", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451778_222883716977456_3556894638211895835_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3xnKV84mBeEQ7kNvgHoSzlD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDeS8PKjQS17lN6TH2WkItlTIv_ppvxRs8-cEV72Chyfg&oe=670902BC"}]}, "id": "757598142945283", "locale": "en_US", "screenshots": [{"file_name": "Lavrynthos_frame1.png", "id": "394374955656481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982484_394374958989814_2166115747908007031_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iGwwT0Mq4tQQ7kNvgEvL2Do&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYQD66yn8qWUkeTu0xEpKggMuoJMPK7ii-b42qBm7hvw&oe=6709061E"}, {"file_name": "Lavrynthos_frame2.png", "id": "439057333893824", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035336_439057337227157_8802760797542213045_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kwls0Zpi_isQ7kNvgGKaeLa&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvTntwNJ5JRsldEUmte9nkHh56QqO_bCH6VY9tOp0m4w&oe=670924C0"}, {"file_name": "Lavrynthos_frame3.png", "id": "1855691141278040", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569446_1855691144611373_3816922827444379030_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7oaVL8PV-Z8Q7kNvgEV4l9V&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPdgoq1mZGzD64PTmT-1LTYFzdGEXa6C7YLubIES8KWw&oe=67091938"}, {"file_name": "Lavrynthos_frame4.png", "id": "576033946763580", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974583_576033950096913_515331897680576336_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UDNHRrXbcIkQ7kNvgHbBnaQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCIW-OU3QEUjOg1SXSPdTEGMj5IJV_IA0rOfKWihSupdQ&oe=670900FD"}, {"file_name": "Lavrynthos_frame5.png", "id": "1985195041655061", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031342_1985195044988394_6013847476032584026_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GcY7HPeeo6YQ7kNvgGJkOUl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1vhim53HJnLPkpKx3qRVvqkOr2DneMwjtmZeloN9BjQ&oe=670911FC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover.png", "id": "751867579832471", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230049_751867583165804_5980597322316914656_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OJcC3krXBUgQ7kNvgErK9ws&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6yiSMMToeh99NgQiAkrEo00xKp6awSEVbsAalSuqMQw&oe=6709167B"}, "display_name": "Lavrynthos", "keywords": [], "long_description": "Lavrynthos places you at the heart of the labyrinth of Crete to tell you the story of the unlikely relationship between the Minotaur and his next meal: a girl named Cora. \n\nA contemporary Greek tragedy paying homage to the cradle of modern dramatic theory while challenging it at the same time. Lavrynthos is a humorous take on a 3000-year-old myth updating it with themes and topics that are relevant in this day and age. \n\nThe narrative makes use of an innovative way of moving the player throughout the story by transforming a 2x2m area into an infinite non-euclidean maze that can shift space and time. \n\nLavrynthos messes up with your sense of direction, space, and balance and can make you get lost inside your own bedroom!\n\nCreated with support of the Venice Biennale College, Lavrythos premiered at Venice Film Festival and in 2022 won the Stereopsia Crystal Owl Award for Best Creative Experience.\n\n\"Lavrynthos Is A Brilliantly Smart Mix Of VR Storytelling And Impossible Spaces On Oculus Quest And PC\" - UploadVR", "short_description": "Lavrynthos places you at the heart of the labyrinth of Crete to tell you the story of the unlikely relationship between the Minotaur and his next meal: a girl named Cora.\n\nA contemporary Greek tragedy paying homage to the cradle of modern dramatic theory while challenging it at the same time.\n\nLavrynthos is a humorous take on a 3000-year-old myth updating it with themes and topics that are relevant in this day and age.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://astreaimmersive.io/lavrynthos-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://astreaimmersive.io/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "661880351198839"}, {"id": "447840929525167"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7214240485329619"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_726347225612574_5149656256161174889_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PseWVroY028Q7kNvgFMbocD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKJHW5yWvBaSzO2lL6ThhMh1P-OrYqCzYe-jrF0-RKGg&oe=670929DF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Lavrynthos", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Family", "id": "661880351198839"}, {"topic_name": "Comedy", "id": "447840929525167"}, {"topic_name": "History", "id": "439804597133915"}], "release_date": 1639540635, "lastRevision": {"nodes": [{"id": "2897842937100575", "release_type": "SCHEDULED", "adminis