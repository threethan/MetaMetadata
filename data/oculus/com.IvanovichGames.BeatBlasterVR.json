_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ulmh4HXZvyMQ7kNvgFANF50&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIosHFbBEUE5V1qMSmFHk4gRq9dkXJCzJEmBISLjfw_g&oe=67221794"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video.png", "id": "4098828203474620", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75435287_4098828213474619_2522357510769576592_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dEMd-PpU7zsQ7kNvgFo72lq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCdikhpMa2qHwM5KJCGaff1qMzHp3gsEv_X8-U2i6hWg&oe=67223490"}, "display_name": "Beat Blaster", "keywords": [], "long_description": "Beat Blaster is a VR game of shooting, running and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge.\n\n30 SONGS & AMBISONIC AUDIO\nEach level introduces a novelty and all the games are different thanks to the intelligent generation of levels. \nAmbisonic sound lets you experience the music in an entirely new way.\n\n4 WAYS OF MOVEMENT\nYou can choose between the classic VR controller, the new 3dRudder, tilting the head or the intuitive and original control based on the movement of the head. \n\nNO MOTION SICKNESS\nBeat Blaster is a VR game with a high-speed component. But all moves in the game are designed without rotating the player, thus minimizing the probability of motion sickness.\n\nEASY RULES\nTo clear a level, you must reach the end of the song without dying. You have a Blaster with infinite ammunition and a single life to dodge or kill all the enemies that will appear to the rhythm of the music.", "short_description": "Beat Blaster is a VR game of shooting, running and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ivanovichgames.com/privacy.html", "developer_terms_of_service_url": "https://www.ivanovichgames.com/privacy.html", "publisher_name": "Ivanovich Games", "support_website_url": "https://www.ivanovichgames.com/web/contact/", "website_url": "https://www.ivanovichgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SHOOTER", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru", "ko", "fr", "it", "es", "zh_CN", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "632383431182646"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1071210174498434"}, {"status": "PUBLISHED", "id": "4080115132010133"}, {"status": "PUBLISHED", "id": "482499126907106"}]}, "baseline_offer": {"id": "4080115132010133"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726254000, "status": "PUBLISHED", "id": "1071210174498434"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8408937012499089", "version": "1.95"}, "id": "529091414735893", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3798510533541783", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8408937012499089"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "52909141