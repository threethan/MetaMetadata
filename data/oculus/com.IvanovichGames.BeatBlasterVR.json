=67221144"}]}, "id": "791202773219863", "locale": "en_US", "screenshots": [{"file_name": "screen1.png", "id": "405361233869706", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_405361237203039_60698209648498584_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r2SOThgDsxwQ7kNvgGAjhxe&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBD6thPAtJRJWxfT_2sf8EMyqnzmHkXs86U_J44gDsiLQ&oe=67223014"}, {"file_name": "screen2.png", "id": "463161948429671", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75361354_463161951763004_8684103955940259383_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jUhcUBDe6FYQ7kNvgHfjhFB&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjwy3poqYgd-6G48Zj3BFaCeLnxZFkSEQ72_NTe7F-ug&oe=672207C9"}, {"file_name": "screen2.png", "id": "2825297704380463", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75348045_2825297707713796_4280977966268630756_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_llevPipfxcQ7kNvgFS3Lti&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfX7jkdMX8RhWakZJ7ZxYwJctwQUAoIL81-isTa5kv3Q&oe=672224B1"}, {"file_name": "screen4.png", "id": "859117427994217", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568729_859117431327550_6758189037787699058_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CwZaTzVZ_CYQ7kNvgHwHbeC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAe_VINZDhOIktteea9bbBnyfJiv4HWVQ03v7hXft9TTg&oe=67220D6D"}, {"file_name": "screen5.png", "id": "511938266443737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269160_511938269777070_1067552805106397481_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ulmh4HXZvyMQ7kNvgFANF50&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIosHFbBEUE5V1qMSmFHk4gRq9dkXJCzJEmBISLjfw_g&oe=67221794"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video.png", "id": "4098828203474620", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75435287_4098828213474619_2522357510769576592_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dEMd-PpU7zsQ7kNvgFo72lq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCdikhpMa2qHwM5KJCGaff1qMzHp3gsEv_X8-U2i6hWg&oe=67223490"}, "display_name": "Beat Blaster", "keywords": [], "long_description": "Beat Blaster is a VR game of shooting, running and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge.\n\n30 SONGS & AMBISONIC AUDIO\nEach level introduces a novelty and all the games are different thanks to the intelligent generation of levels. \nAmbisonic sound lets you experience the music in an entirely new way.\n\n4 WAYS OF MOVEMENT\nYou can choose between the classic VR controller, the new 3dRudder, tilting the head or the intuitive and original control based on the movement of the head. \n\nNO MOTION SICKNESS\nBeat Blaster is a VR game with a high-speed component. But all moves in the game are designed without rotating the player, thus minimizing the probability of motion sickness.\n\nEASY RULES\nTo clear a level, you must reach the end of the song without dying. You have a Blaster with infinite ammunition and a single life to dodge or kill all the enemies that will appear to the rhythm of the music.", "short_description": "Beat Blaster is a VR game of shooting, running and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ivanovichgames.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Ivanovich Games", "support_website_url": "https://www.ivanovichgames.com/web/contact/", "website_url": "https://www.ivanovichgames.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NO