eur Virtuel\u201d.\n", "short_description": "Whether you want:\n- choose or prepare for your next trip, or\n- simply let yourself be transported to the most beautiful places to visit in the world,\n... you're in the right place.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.levoyageurvirtuel.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MBprod", "support_website_url": "http://www.levoyageurvirtuel.com/", "website_url": "http://www.levoyageurvirtuel.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "EXPLORATION", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr_BE", "fr_CA", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "476395747259511"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "361788642035466"}]}, "baseline_offer": {"id": "361788642035466"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1625153820, "status": "PUBLISHED", "id": "361788642035466"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4116198461780955", "version": "4"}, "id": "125334449499691", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3818198528247618", "is_concept": false, "latest_released_binary": {"__typename": "Androi