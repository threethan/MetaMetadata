s7Ym9piuqgMw7KumpeDZa6pTluWjXXfjZ_PlYPg&oe=66E42268"}, {"file_name": "Quest-VT-05.png", "id": "278509010432418", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036685_278509013765751_5310274236062343564_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QOxHF9D4ybEQ7kNvgG0esq7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgwoG1wMT9qcot4tGXgLLnd&oh=00_AYB1XIZiHk_XYSvoGoZ1DuuNwkfqDpMmQS7n7r1qjjQruw&oe=66E420B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtual Traveller-2560x1440.png", "id": "470486867556532", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65395359_470486870889865_3898455474082987970_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wfndz6NsYWgQ7kNvgHoXbTh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgwoG1wMT9qcot4tGXgLLnd&oh=00_AYDwa5vnEvnSajYmGPkmZY7iCaDJ7z_HDjSL37R4yPG1Cg&oe=66E40DBA"}, "display_name": "The Virtual Traveller", "keywords": [], "long_description": "The Virtual Traveller is an application dedicated to travels enthusiasts.\nIt allows you to view selected 360-degree photos from Google Street View and their contributors. The photos are grouped to create travel tours of the most interesting places to visit in the world.\nAerial view Video clips created with Google Maps and Google Earth Studio, connect the visited sites and atmosphere music makes the trip more relaxing and enjoyable.\nOnly one controller is required (left or right) \u2026 your choice.\nset your boundary on the Oculus Quest to stationary, \nA swivel chair makes visits more comfortable.\nEnjoy it and \u201cBon Voyage\u201d.\nNote: Oculus Go version is available under the title: \u201cLe Voyageur Virtuel\u201d.\n", "short_description": "Whether you want:\n- choose or prepare for your next trip, or\n- simply let yourself be transported to the most beautiful places to visit in the world,\n... you're in the right place.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bormic.wixsite.com/website-3/privacy-policy", "developer_terms_of