rh9OSy2kDlCKgJvq&oh=00_AYDcINqCWxbHvQ2d4XiWU22ZfcIX7PrjJBoq-LAKCpUE_g&oe=66E6B846"}, {"file_name": "\u3042\u3084\u304b\u3057_\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c806.png", "id": "833930867524848", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974463_833930870858181_4700514849234738106_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x_mnRZnEBuUQ7kNvgEDyZeU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABCnZy3rh9OSy2kDlCKgJvq&oh=00_AYCl16-EfdU-ZcXFHbH42gq3AzeWwuAayRWmtXeJaBIpEA&oe=66E6B7CB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AYAKASHI KITAN", "keywords": [], "long_description": "\"AYAKASHI KITAN\" is a Japanese-style horror action VR.\n\nIt is an adventure where the shrine maiden and her disciples become a phantom called \"AYAKASHI\", confront the mighty evil spirits that prevail in the city, and save the world.\n\nBy adding an element of exterminating evil spirits to the Japanese-style haunted house, even those who are not good at haunted houses can enjoy it.\n\n\u25c6\u25c6\u25c6\u25c7\u25c7\u25c7\u25c6\u25c6\u25c6\u25c7\u25c7\u25c7\n\nCollaboration with virtual YouTuber Kimino Miya!\n\nLife-sized Kimino Miya is appearing as one of the shrine maiden's disciples! She will have an adventure with you.\n\nAudio and subtitles are not localized.\n", "short_description": "AYAKASHI KITAN is a Japanese-style horror action VR.\n\nIt is an adventure where the shrine maiden and her disciples become a phantom called \"AYAKASHI\", confront the mighty evil spirits that prevail in the city, and save the world.\n\n\nCollaboration with virtual YouTuber Kimino Miya!\n\nLife-sized Kimino Miya is appearing as one of the shrine maiden's disciples! She will have an adventure with you.\n\nAudio and subtitles are not localized."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nsmweb.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "NSM_xRLabo", "support_website_url": null, "webs