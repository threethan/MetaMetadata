cdn.com&oh=00_AYAc9_7id0Z4ZXNDh2VTJ0oSnIJfCMWEKHmeiRchgEy0xg&oe=670CF34B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AYAKASHI KITAN", "keywords": [], "long_description": "\"AYAKASHI KITAN\" is a Japanese-style horror action VR.\n\nIt is an adventure where the shrine maiden and her disciples become a phantom called \"AYAKASHI\", confront the mighty evil spirits that prevail in the city, and save the world.\n\nBy adding an element of exterminating evil spirits to the Japanese-style haunted house, even those who are not good at haunted houses can enjoy it.\n\n\u25c6\u25c6\u25c6\u25c7\u25c7\u25c7\u25c6\u25c6\u25c6\u25c7\u25c7\u25c7\n\nCollaboration with virtual YouTuber Kimino Miya!\n\nLife-sized Kimino Miya is appearing as one of the shrine maiden's disciples! She will have an adventure with you.\n\nAudio and subtitles are not localized.\n", "short_description": "AYAKASHI KITAN is a Japanese-style horror action VR.\n\nIt is an adventure where the shrine maiden and her disciples become a phantom called \"AYAKASHI\", confront the mighty evil spirits that prevail in the city, and save the world.\n\n\nCollaboration with virtual YouTuber Kimino Miya!\n\nLife-sized Kimino Miya is appearing as one of the shrine maiden's disciples! She will have an adventure with you.\n\nAudio and subtitles are not localized."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nsmweb.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "NSM_xRLabo", "support_website_url": null, "website_url": "https://www.nsmweb.com/works/ayakashi-app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_process