s6mx62nhG270dHw&oe=66D6F9CF"}, {"file_name": "output-onlinepngtools (3).png", "id": "926150448772741", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367588_926150452106074_5880994283985636253_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NXwx56MZ8g0Q7kNvgFDw4FL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCl8KHeQk5Nf50Za5il5gj7ij94yOI3OegX4O0nP3bhmQ&oe=66D6E7F2"}, {"file_name": "output-onlinepngtools (4).png", "id": "956914985855188", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982518_956914989188521_2992047081065732885_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DUO183LjKZIQ7kNvgEKnRpC&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-RrAvX8SJvB1x9gULUaJb1C3nsYtOP2UMvGf9o0th_g&oe=66D70EDA"}, {"file_name": "output-onlinepngtools (5).png", "id": "351539274520945", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75439596_351539277854278_4679741185523975855_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7gW9U5YI1osQ7kNvgHcdQNh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCl5SNMqDDQRGMns-rP4ST9-RXwzBJcB3A02foWCboNDA&oe=66D6D894"}, {"file_name": "output-onlinepngtools (6).png", "id": "1101372580989911", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031528_1101372584323244_3612554135083146109_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pOjDB_pFjbUQ7kNvgEK-nOy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjCQeE3bLgtBVaYg_UOUCoqd5jCCGA5cfFOVx8iLWtKA&oe=66D6E9C7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PrimalFear", "keywords": [], "long_description": "Primal Fear is a game that's part of the survival genre, where players must navigate a dangerous environment, gather resources, and fend off threats to survive. It's known for its intense atmosphere, challenging gameplay, and immersive world.\n\nTo play \"Primal Fear,\" you would typically start by creating a character and then exploring the game world. You'll need to gather resources, build shelter, and craft tools and weapons to defend yourself against hostile creatures. T