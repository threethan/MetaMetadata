uluscdn.com&oh=00_AYC5HwSdqLCZ18DtnBx9_Z-o90Z9AC_OxE4mYsqEcAmKpQ&oe=6763F872"}, {"file_name": "output-onlinepngtools (4).png", "id": "956914985855188", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982518_956914989188521_2992047081065732885_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYyi-XtgLK8Q7kNvgGEGwGU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALohRQYHDVKlBn5T0x3o-pm1VO9kMy2jG640lUaouJNw&oe=67641F5A"}, {"file_name": "output-onlinepngtools (5).png", "id": "351539274520945", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439596_351539277854278_4679741185523975855_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ie5cCA3PAWAQ7kNvgHfRbJZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEBoglLb9MEixbF_zz42x2abd5sXD86d_2tuVdhP0VCA&oe=67642154"}, {"file_name": "output-onlinepngtools (6).png", "id": "1101372580989911", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031528_1101372584323244_3612554135083146109_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2uZX6LQb8mUQ7kNvgHQh5NA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqFDbv6VAPhhhAhj9R1OAdurTlvPO1xwB4jVu9Sod86Q&oe=6763FA47"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PrimalFear", "keywords": [], "long_description": "Primal Fear is a game that's part of the survival genre, where players must navigate a dangerous environment, gather resources, and fend off threats to survive. It's known for its intense atmosphere, challenging gameplay, and immersive world.\n\nTo play \"Primal Fear,\" you would typically start by creating a character and then exploring the game world. You'll need to gather resources, build shelter, and craft tools and weapons to defend yourself against hostile creatures. The game often features a day-night cycle, with different dangers and challenges depending on the time of day.\n\nIn terms of scariness, \"Primal Fear\" can be quite intense, especially when facing off against powerful creatures or navigating dark, dangerous areas. The game's immersive atmosphere and challenging gameplay can create a sense of tension and unease, making it a thrilling experience for fans of survival games.", "short_description": "Primal Fear is a game that's part of the survival genre, where players must navigate a dangerous environment, gather resources, and fend off threats to survive. It's known for its intense atmosphere, challenging gameplay, and immersive world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/primal-fear-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "FEAR 1232", "support_website_url": null, "website_url": "https://sites.google.com/view/primal-fear-vr/start", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7529208323808502"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "606811475199187"}, {"status": "PUBLISHED", "id": "910683863983489"}]}, "baseline_offer": {"id": "606811475199187"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733609400, "status": "PUBLISHED", "id": "606811475199187"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9178999195496065", "version": "0.0.30"}, "id": "925115152597040", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primar