BisiRHbPOZh0jD12A&oe=66CB1C4F"}, {"file_name": "output-onlinepngtools (3).png", "id": "926150448772741", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367588_926150452106074_5880994283985636253_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NP15nUfShywQ7kNvgGwfCfa&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1saZ2Rghw9d799bXCVULTJzsC7BG9a-nMF9nePgSZSQ&oe=66CB0A72"}, {"file_name": "output-onlinepngtools (4).png", "id": "956914985855188", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982518_956914989188521_2992047081065732885_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P6tWfGgIVrEQ7kNvgFH7XFU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSrav52b-kQC2qlN7JOFytDUW3_6HN-fffbWhHEQ8uIg&oe=66CAF91A"}, {"file_name": "output-onlinepngtools (5).png", "id": "351539274520945", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75439596_351539277854278_4679741185523975855_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PgeRPoghRnUQ7kNvgFZkfgN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSYbCTmr1-5LQdjpA3aBzjqgxk14LoNtk7Mltw3dMK5A&oe=66CAFB14"}, {"file_name": "output-onlinepngtools (6).png", "id": "1101372580989911", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031528_1101372584323244_3612554135083146109_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HXyMIZvrOd0Q7kNvgES4w45&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQGFXDxdK2x9S2b7O0h9KVt33PHA1BcHRVYusUR-bh0g&oe=66CB0C47"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PrimalFear", "keywords": [], "long_description": "Primal Fear is a game that's part of the survival genre, where players must navigate a dangerous environment, gather resources, and fend off threats to survive. It's known for its intense atmosphere, challenging gameplay, and immersive world.\n\nTo play \"Primal Fear,\" you would typically start by creating a character and then exploring the game world. You'll need to gather resources, build shelter, and craft tools and weapons to defend yourself against hostile creatures. The game often features a day-night cycle, with different dangers and challenges depending on the time of day.\n\nIn terms of scariness, \"Primal Fear\" can be quite intense, especially when facing off against powerful creatures or navigating dark, dangerous areas. The game's immersive atmosphere and challenging gameplay can create a sense of tension and unease, making it a thrilling experience for fans of survival games.", "short_description": "Primal Fear is a game that's part of the survival genre, where players must navigate a dangerous environment, gather resources, and fend off threats to survive. It's known for its intense atmosphere, challenging gameplay, and immersive world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/primal-fear-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "FEAR 1232", "support_website_url": null, "website_url": "https://sites.google.com/view/primal-fear-vr/start", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7529208323808502"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "910683863983489"}]}, "baseline_offer": {"id": "910683863983489"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709752440, "status": "PUBLISHED", "id": "910683863983489"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "bi