sBLW7YMnRPTmZYLSMiw&oe=676FD617"}, {"file_name": "CB Screenshot 02.png", "id": "7985742398145636", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974859_7985742404812302_4671278461729422000_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YH9p0JU4n6kQ7kNvgFGasCa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIBXXeR4h7FlK4SowVVbGzEtsxs8IKBKYH_CGy3jWtXA&oe=676FE48D"}, {"file_name": "CycleBar- Classes.png", "id": "485640274332590", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269591_485640277665923_6852489760100270909_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1sgak3B-wYoQ7kNvgG2C47j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJR7So0h0PM7YvbuNvouznCW3wE4EtZy4fRfxEBKf5mQ&oe=676FEE9C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CB - Cover - Landscape.png", "id": "479642521355102", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974834_479642524688435_7065933209497930161_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jPqG6cpqKYIQ7kNvgHfaHis&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAizHpa73Spo0Tm3d6XIRPE6xV4iNTzngdR1_A6q7vmYg&oe=676FCBC3"}, "display_name": "CycleBar", "keywords": ["fitness", "health", "cycling", "spin", "cardio"], "long_description": "Revitalize your fitness routine with CycleBar on Meta Quest! As the largest spin brand in the U.S., CycleBar delivers an unparalleled indoor cycling experience that combines the thrill of high-energy workouts with the innovation of virtual reality. Whether you're a seasoned cyclist or new to the world of spinning, our app offers a captivating and personalized journey designed to elevate your performance and keep you inspired.\n\n**Key Features:**\n\n- **Immersive VR Rides:** Clip into the first indoor cycling VR app on the Quest and feel the rush of riding with top instructors and fellow cyclists from around the world.\n\n- **Expert Instructors:** Ride alongside professional trainers who motivate and guide you through every pedal stroke, ensuring an engaging and effective workout.\n\n- **Variety of Classes:** Choose from a wide range of rides, including high-intensity interval training (HIIT), endurance rides, themed sessions, and more.\n\n- **Personalized Experience:** Customize your workouts to match your fitness goals, with options to adjust intensity and duration for a tailored ride.\n\nEmbark on an exciting journey to fitness with CycleBar on Meta Quest. Discover the power of movement, connect with a supportive community, and transform your ride into an unforgettable experience. Your adventure starts here\u2014get ready to ride!\n{381239874674871}", "short_description": "CycleBar is the first indoor cycling app on Meta Quest! Rock Your Ride with the largest indoor cycling brand in the U.S. Whether you're a VR enthusiast or a cycling lover, our app offers exhilarating rides led by top instructors, designed to boost your endurance, strength, and motivation. Join a vibrant community, track your progress, and transform your fitness journey with CycleBar's cutting-edge virtual reality experience. Get ready to ride like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xponential.com/privacy-policy", "developer_terms_of_service_url": "https://www.xponential.com/terms-of-use-xplus", "publisher_name": "Litesport", "support_website_url": "https://xpoplus.app.link/e/help", "website_url": "https://xponential.plus/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "suppor