DnbboUhFQ&oe=67519F49"}, {"file_name": "CycleBar- Home.png", "id": "522956006795209", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974853_522956013461875_8093803523125335619_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nMcGpHvpACwQ7kNvgEwXRSN&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBLqBbxz0d-14ayTIkIhk8fErUXmngXUcs35il42cjpYQ&oe=67519FBB"}, {"file_name": "PB-Callibration.png", "id": "1936493886796191", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982629_1936493890129524_3100247740643681336_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FNdjOD6jAuAQ7kNvgEZNZEz&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA9xRoR71pzjBrXEljd37I0kJQeabbXHZnmixLF_rB4ig&oe=67518397"}, {"file_name": "CB Screenshot 02.png", "id": "7985742398145636", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974859_7985742404812302_4671278461729422000_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Cbqy4_hAgwQ7kNvgHhSZ6B&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD_3cvEZJJ7PUDDpyB2b51_JX6GrZmHfPJLNfVWS1nWpw&oe=6751920D"}, {"file_name": "CycleBar- Classes.png", "id": "485640274332590", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75269591_485640277665923_6852489760100270909_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I_zRBMYN39oQ7kNvgHo_Nz4&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDRMz83-eM4MM0m46Va78jjNxgS0WAMBTbjixeWIjsdAg&oe=67519C1C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CB - Cover - Landscape.png", "id": "479642521355102", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974834_479642524688435_7065933209497930161_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lp5zmWGPcyUQ7kNvgHUal7c&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAh1pO-CJ8MvanSVo7suWk2nF4_5Ro5c45M5Zvfh4H4rg&oe=6751B183"}, "display_name": "CycleBar", "keywords": ["fitness", "health", "cycling", "spin", "cardio"], "long_description": "Revitalize your fitness routine with CycleBar on Meta Quest! As the largest spin brand in the U.S., CycleBar delivers an unparalleled indoor cycling experience that combines the thrill of high-energy workouts with the innovation of virtual reality. Whether you're a seasoned cyclist or new to the world of spinning, our app offers a captivating and personalized journey designed to elevate your performance and keep you inspired.\n\n**Key Features:**\n\n- **Immersive VR Rides:** Clip into the first indoor cycling VR app on the Quest and feel the rush of riding with top instructors and fellow cyclists from around the world.\n\n- **Expert Instructors:** Ride alongside professional trainers who motivate and guide you through every pedal stroke, ensuring an engaging and effective workout.\n\n- **Variety of Classes:** Choose from a wide range of rides, including high-intensity interval training (HIIT), endurance rides, themed sessions, and more.\n\n- **Personalized Experience:** Customize your workouts to match your fitness goals, with options to adjust intensity and duration for a tailored ride.\n\nEmbark on an exciting journey to fitness with CycleBar on Meta Quest. Discover the power of movement, connect with a supportive community, and transform your ride into an unforgettable experience. Your adventure starts here\u2014get ready to ride!\n{381239874674871}", "short_description": "CycleBar is the first indoor cycling app on Meta Quest! Rock Your Ride with the largest indoor cycling brand in the U.S. Whether you're a VR enthusiast or a cycling lover, our app offers exhilarating rides led by top instructors, designed to boost your endurance, strength, and motivation. Join a vibrant community, track your progress, and transform your fitness journey with CycleBar's cutting-edge virtual reality experience. Get ready to ride like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xponential.com/privacy-policy", "developer_terms_of_service_url": "https://www.xponential.com