t=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYBg1n1k99_Venn_V6s5WfMazcb-3DFMWZjXH_TDDXoaSQ&oe=66E42E84"}, {"file_name": "Screenshot_5.png", "id": "676451640082240", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974447_676451643415573_3335974289550758280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F6c-bGsr8pgQ7kNvgF3VBuI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYBjVX8bRXFzIK-tAhYXQKm6U7P8jx4j2tOmQM9Gb0trrQ&oe=66E4236F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "1838817966311152", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974573_1838817969644485_116937611574330790_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GIbV-r1b5cAQ7kNvgE8HBX-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYAGZhJOBeyzZXIJCqWqCLw5d9guD1DDJvUEPNpsMorFAA&oe=66E4186C"}, "display_name": "Immerse - Language Learning Reimagined", "keywords": ["Language", "Learning", "Social", "Education", "Travel"], "long_description": "We bring language immersion directly to you. Every week you will participate in immersive experiences where you are exposed to your target language and develop real-life language skills.\n\nAs a member you can choose from three primary types of small group experiences: Lessons, Events, and Conversation Practice. These three experience types work together to provide the benefits of real life language immersion, and then some!\n\nAs an Immerse member you have full access to these weekly small-group experiences facilitated by our expert language guides. Each experience takes place in an interactive 3D world designed to make reaching your fluency goals fun and rewarding.\n\nAlso included in your membership is unlimited access to our social lounges where you can meet and converse with other members of the Immerse community to practice and grow.", "short_description": "Become an Immerse Member to gain full access to our weekly small-group experiences facilitated by one of our expert language guides.\n\nEach experience takes place in an interactive 3D world designed to make reaching your fluency goals fun and rewarding.\n\nAlso included in your membership is unlimited access to our social lounges where you can meet and converse with other members of the Immerse community to practice and grow."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immerse.online/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immerse Inc.", "support_website_url": "https://support.immerse.online/", "website_url": "https://www.immerse.online/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "TRAVEL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "548520973541212"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "413253490869911"}, {"status": "PUBLISHED", "id": "777581120074789"}, {"status": "PUBLISHED", "id": "889835728846245"}]}, "baseline_offer": {"id": "413253490869911"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1659121200, "status": "PUBLISHED", "id": "413253490869911"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7688021321281567", "version": "4.9.3"}, "id": "1150459748661587", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, 