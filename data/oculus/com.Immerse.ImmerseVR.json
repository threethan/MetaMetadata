1"}, {"file_name": "Immerse_OculusPDP_Hero (2).png", "id": "470489582400690", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974774_470489585734023_4890430420498988888_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I21OH6QFnAMQ7kNvgFw6udt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYABysEVPp_Oo9KiGPIKjmgDAv8LIm7yRplMk8Zgzu3wGA&oe=66E40F95"}, {"file_name": "Immerse_OculusPDP_Square (2).png", "id": "283342908162473", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031541_283342911495806_2786750369678500527_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zFU8nd_ua9MQ7kNvgHKV7Jp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYDm0NPHKUDsSI63iglDGZo-dEDt-UCjirG69T88Zdpb8w&oe=66E42DB2"}]}, "id": "409776688766986", "locale": "en_US", "screenshots": [{"file_name": "5 (3).png", "id": "237876545959366", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035430_237876549292699_5291554629393341588_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VBiLtfX7H9kQ7kNvgEXbOrv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYCh_nHs9WWXlP8rl5OkEPtLAgS8GVUnd_OB-2a906nMfg&oe=66E42883"}, {"file_name": "Screenshot (NPC).png", "id": "369410725484047", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_369410728817380_478569888523542266_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i9mgB3Mmj1QQ7kNvgHPSRtp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYBDL1JeZRwqZkYee4lwSm2wdusbyfe90FXy2XDgTkuMqw&oe=66E4288D"}, {"file_name": "Rectangle 239 (1).png", "id": "936461544487398", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974811_936461547820731_5497390448814299256_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hShXt4u0nwUQ7kNvgFC5hvv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYBLxutJr8cP73wl7i_9Q3e9LvPua3GYyrMxj1tCdQuzRg&oe=66E425C5"}, {"file_name": "4 (3).png", "id": "929635508185437", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566685_929635511518770_3778096043796952463_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KAHpeHLXQisQ7kNvgEWAFd-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYAuAr_BhnYgjtsMLw_CQ36JbuVXMjKKkXKmfuALj4oI-g&oe=66E411FB"}, {"file_name": "6 (3).png", "id": "916230113512958", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566692_916230116846291_6707735798027567358_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qQJ4LMIT2MoQ7kNvgEqcFi2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYBuS8UJtiE7QFBbQnGkEADaoKlWEDkYMNNb_xagfKZoIA&oe=66E40B0D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "240749085021765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_240749088355098_8783448519318006081_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Ex89Wd55X4Q7kNvgGqrovZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEi7uzgYd7FvyQVD5gvM6I1&oh=00_AYBFGql9FRczUxh0GuKjzGI04Sf4KG4vALSXELlYgUEY1w&oe=66E42159"}, "display_name": "Immerse - Language Learning", "keywords": ["Spanish", "English", "French", "Language", "Learn"], "long_description": "\ud83d\udd25 Don't just study Spanish, French, or English \u2014 learn how to SPEAK it fluently with coworkers, friends, and family!\n\n\u2764\ufe0f Immerse is the fastest growing immersive language learning platform trusted by thousands of members around the world!\n\n\ud83d\udcaa Get unlimited access to live group classes and AI-powered conversation practice for a fraction of the cost of online tutoring or traveling abroad.\n\n\ud83e\udd11 Subscriptions start as low as $25/mo. Must be 18 or older. \n\n\ud83e\udd73 Start your 14 day free trial today! \n\n\ud83d\udc69\u200d\ud83c\udfeb INSTRUCTOR-LED LESSONS\n\nPractice key language skills in 40-minute small group lessons led by friendly instructors. New lessons available every day! \n\n\ud83d\udc83\ud83d\udd7a\ud83c\udffc COMMUNITY EVENTS\n\nEnjoy connecting with our diverse global community during fun 3-hour events. \n\n\ud83c\udfaf LANGUAGE GAMES \n\nShoot targets, sing karaoke, play basketball, and compete with friends to refine your vocabulary. \n\n\ud83d\udde3 AI-POWERED ROLEPLAYS\n\nBuild your public speaking confidence by practicing with dozens of AI conversation partners located throughout our virtual world. Get as many reps as you need to feel confident in classes.\n\n\ud83d\udcc8 PERSONALIZED DASHBOARD\n\nTrack and review all of your progress in a personalized 3D dashboard. Review your completed tasks, earned points and stamps, and remaining steps to get to the next fluency level.\n\nStart your free 14 day trial today! Cancel anytime. Must be 18 years or older to join.", "short_description": "\ud83d\udd25 Don't just study Spanish, French, or English \u2014 learn how to SPEAK it fluently with coworkers, friends, and family!\n\n\u2764\ufe0f Immerse is the fastest growing immersive language learning platform trusted by thousands of members around the world!\n\n\ud83d\udcaa Get unlimited access to live group classes and AI-powered conversation practice for a fraction of the cost of online tutoring or traveling abroad.\n\n\ud83e\udd11 Subscriptions start as low as $25/mo. Must be 18 or older. \n\n\ud83e\udd73 Start your 14 day free trial today! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immerse.com/legal/privacy-policy", "developer_terms_of_service_url": "https://www.immerse.com/legal/terms", "publisher_name": "Immerse Inc.", "support_website_url": "https://support.immerse.online/", "website_url": "https://www.immerse.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "879473995923081"}, {"id": "726368587961803"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "T