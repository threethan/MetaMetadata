c_ohc=CurFm882CMAQ7kNvgEfeJew&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDEORwF-ex__tGysF82wuXeCQKxOfs8SnON0kHR2QjMw&oe=66D6FABA"}, {"file_name": "Screenshot_3.png", "id": "1064001541138815", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_1064001544472148_949824317606278898_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iHNQ-VaZD8sQ7kNvgEjs_-_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCgIdkz2fxp8Vu2TtStyU_mj0pKZat29V4ioFRe-_fUQ&oe=66D6D922"}, {"file_name": "Screenshot_4.png", "id": "726046605099147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485571_726046608432480_3782664229846755142_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=onNepP9JL6AQ7kNvgGu1VKD&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHW-Ug81gizEakckazG-qMc42a63buPtcD36I21Vp_kw&oe=66D6FF84"}, {"file_name": "Screenshot_5.png", "id": "676451640082240", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974447_676451643415573_3335974289550758280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y2ej7dNKffkQ7kNvgEEL2Vo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHlJDDCaNp7fPoFK0xPCmO_x8FE4l7Mm35rcBf2neCWQ&oe=66D6F46F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "1838817966311152", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974573_1838817969644485_116937611574330790_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8KcIZKu57OQQ7kNvgGbPff8&_nc_ht=scontent.oculuscdn.com&oh=00_AYC1NKq38iDj7LQ8ldMicSLouc3FX1_3LswpHixK_rzgbA&oe=66D6E96C"}, "display_name": "Immerse - Language Learning Reimagined", "keywords": ["Language", "Learning", "Social", "Education", "Travel"], "long_description": "We bring language immersion directly to you. Every week you will participate in immersive experiences where you are exposed to your target language and develop real-life language skills.\n\nAs a member you can choose from three primary types of small group experiences: Lessons, Events, and Conversation Practice. These three experience types work together to provide the benefits of real life language immersion, and then some!\n\nAs an Immerse member you have full access to these weekly small-group experiences facilitated by our expert language guides. Each experience takes place in an interactive 3D world designed to make reaching your fluency goals fun and rewarding.\n\nAlso included in your membership is unlimited access to our social lounges where you can meet and converse with other members of the Immerse community to practice and grow.", "short_description": "Become an Immerse Member to gain full access to our weekly small-group experiences facilitated by one of our expert language guides.\n\nEach experience takes place in an interactive 3D world designed to make reaching your fluency goals fun and rewarding.\n\nAlso included in your membership is unlimited access to our social lounges where you can meet and converse with other members of the Immerse community to practice and grow."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immerse.online/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immerse Inc.", "support_website_url": "https://support.immerse.online/", "website_url": "https://www.immerse.online/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "TRAVEL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "548520973541212"}}]}, "scheduled_offers": {"coun