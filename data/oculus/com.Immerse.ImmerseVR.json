30a3\u30c3\u30af\u3067\u5b8c\u5168\u6ca1\u5165\u578b\u306e\u82f1\u8a9e\u5b66\u7fd2\u3092\u662f\u975e\u3054\u4f53\u9a13\u304f\u3060\u3055\u3044\u3002\n\nImmerse\u3067\u5229\u7528\u3067\u304d\u308b\u5b66\u7fd2\u30b3\u30f3\u30c6\u30f3\u30c4\u3092\u3054\u7d39\u4ecb\u81f4\u3057\u307e\u3059\u3002\n\nLEARN\uff1a\u5b66\u3076\n\u30d7\u30ed\u306e\u8b1b\u5e2b\u306b\u3088\u3063\u3066\u30d5\u30a1\u30b7\u30ea\u30c6\u30fc\u30b7\u30e7\u30f3\u3055\u308c\u308b35\u5206\u306e\u30b0\u30eb\u30fc\u30d7\u30ec\u30c3\u30b9\u30f3\u3067\u3059\u3002\u305d\u308c\u305e\u308c\u306e\u30ec\u30d9\u30eb\u306b\u5408\u3046\u3088\u3046\u30ec\u30d9\u30eb\u5225\u3067\u8a2d\u8a08\u3055\u308c\u3066\u304a\u308a\u3001\u69d8\u3005\u306a\u5b66\u7fd2\u30c8\u30d4\u30c3\u30af\u3092\u5b66\u3076\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\u7d42\u4e86\u5f8c10\u5206\u9593\u306f\u751f\u5f92\u306e\u30d5\u30ea\u30fc\u30c8\u30fc\u30af\u6642\u9593\u3082\u3042\u308a\u3001\u81ea\u5206\u306e\u597d\u304d\u306a\u6642\u9593\u306b\u4e88\u7d04\u53c2\u52a0\u3067\u304d\u307e\u3059\u3002\n\nCONNECT\uff1a\u7e4b\u304c\u308b\n\u4e16\u754c\u4e2d\u304b\u3089\u96c6\u307e\u308b\u5b66\u7fd2\u8005\u3068\u306e\u4ea4\u6d41\u3092\u30e1\u30a4\u30f3\u3068\u3057\u305f\u30a4\u30d9\u30f3\u30c8\u304c\u958b\u50ac\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u3001\u8b1b\u5e2b\u306b\u3088\u308b\u30b5\u30dd\u30fc\u30c8\u3092\u53d7\u3051\u306a\u304c\u3089\u30011\u5206\u3067\u3082\u30011\u6642\u9593\u3067\u3082\u958b\u50ac\u6642\u9593\u4e2d\u306f\u67d4\u8edf\u306b\u53c2\u52a0\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u3001\u4ed6\u306e\u5b66\u7fd2\u8005\u3068\u306e\u9023\u5e2f\u3068\u5354\u529b\u3092\u5968\u52b1\u3059\u308b\u74b0\u5883\u3067\u4ed6\u56fd\u306e\u6587\u5316\u306b\u95a2\u3059\u308b\u6d1e\u5bdf\u3092\u5e83\u3052\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\nPRACTICE\uff1a\u7df4\u7fd2\u3059\u308b\n\u65b0\u3057\u3044\u8a00\u8a9e\u3092\u8a71\u3059\u306e\u306f\u6642\u306b\u306f\u52c7\u6c17\u304c\u3044\u308b\u3053\u3068\u3067\u3059\u3002Immerse\u3067\u306f\u6570\u5341\u306eAI\u30a2\u30d0\u30bf\u30fc\u3068\u30aa\u30fc\u30bb\u30f3\u30c6\u30a3\u30c3\u30af\u306a\u30b7\u30fc\u30f3\u3067\u82f1\u4f1a\u8a71\u306e\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\u3092\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u3053\u308c\u306b\u3088\u308a\u3001\u30ec\u30c3\u30b9\u30f3\u3084\u30a4\u30d9\u30f3\u30c8\u3067\u81ea\u4fe1\u3092\u6301\u3063\u3066\u4eba\u3068\u8a71\u3059\u3053\u3068\u304c\u3067\u304d\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3059\u3002\n\nPLAY\uff1a\u904a\u3076\n\u697d\u3057\u3055\u306f\u8a00\u8a9e\u5b66\u7fd2\u3092\u7d9a\u3051\u308b\u3046\u3048\u3067\u975e\u5e38\u306b\u91cd\u8981\u3067\u3059\u3002Immerse\u3067\u306f\u3001\u30a4\u30f3\u30bf\u30e9\u30af\u30c6\u30a3\u30d6\u306a\u8a00\u8a9e\u5b66\u7fd2\u30b2\u30fc\u30e0\u3092\u7528\u610f\u3057\u3066\u304a\u308a\u3001\u53cb\u4eba\u306b\u306a\u3063\u305f\u5b66\u7fd2\u8005\u3068\u697d\u3057\u304f\u82f1\u8a9e\u529b\u3092\u78e8\u304f\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\nGROW\uff1a\u6210\u9577\u3059\u308b\n\u8a00\u8a9e\u3092\u7fd2\u5f97\u3059\u308b\u306e\u306b\u5fc5\u8981\u306a9\u3064\u306e\u5b66\u7fd2\u30ab\u30c6\u30b4\u30ea\u30fc\u3067\u81ea\u5206\u306e\u5b66\u7fd2\u9032\u6357\u3092\u898b\u3048\u308b\u5316\u3059\u308b\u3053\u3068\u3067\u3001\u81ea\u5206\u306e\u5b66\u7fd2\u9032\u6357\u3092\u78ba\u8a8d\u3057\u3001\u3069\u3053\u307e\u3067\u9032\u3093\u3060\u304b\u3001\u4f55\u304c\u8db3\u308a\u306a\u3044\u304b\u3092\u5e38\u306b\u78ba\u8a8d\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\nImmerse\u306f\u6700\u5927\u6708\u984d5,400\u5186\u3067\u3054\u8cfc\u5165\u9802\u3051\u307e\u3059\u3002\n\u307e\u305a\u306f14\u65e5\u9593\u306e\u7121\u6599\u30c8\u30e9\u30a4\u30a2\u30eb\u3067Immerse\u306e\u5168\u3066\u3092\u597d\u304d\u306a\u3060\u3051\u304a\u8a66\u3057\u304f\u3060\u3055\u3044\u3002", "short_description": "\u82f1\u8a9e\u30924\u500d\u901f\u3067\u4e0a\u9054\u3055\u305b\u307e\u305b\u3093\u304b\uff1f\n\n\u901a\u5e38\u306e\u30aa\u30f