D9"}]}, "id": "1638836363729756", "locale": "en_US", "screenshots": [{"file_name": "tss3.png", "id": "367542506139462", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974848_367542509472795_8146402787939837828_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qfop8S0TBYgQ7kNvgFgLczl&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBIPKIbSr7N4n6Or4g5M-48tsB9zZ5p2GqR_SuH5_UkPg&oe=6772766D"}, {"file_name": "tss2.png", "id": "355176844137770", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75514543_355176847471103_340882097324378907_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hI0gYfPzzIoQ7kNvgGJhuMy&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCQAXZ3gSTWFShwVlSptCn2V8ZRqDi-MFfmNXZT3p8sSQ&oe=67729CEA"}, {"file_name": "tss1.png", "id": "2524319274394316", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75196218_2524319277727649_4669494071344934750_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ac-Yk6xRbGQQ7kNvgHeDhui&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCUW4IxFrp4bImv3CgL2rthXjnhdYGSssY9jzc8oP-wmg&oe=6772845A"}, {"file_name": "tss5.png", "id": "760707645548237", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974746_760707648881570_1069192667380168075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UcPRakcRjZgQ7kNvgHMvp3I&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDxcLqSYRns1YMZEhxtfk49TjIyFsKEylCGV4J4UJviUg&oe=6772742D"}, {"file_name": "s21.png", "id": "541147128406262", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75221322_541147131739595_7049747370601371318_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dhPTtOkCn5wQ7kNvgG_c1Xs&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBVUsVuxo2swimdlZV9GecY-SaRUuvhrlbNRlKh75lKqQ&oe=6772796F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "winterupdateland.png", "id": "2331233400590388", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57570298_2331233403923721_7844197509762393278_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9mxmVoWIKQsQ7kNvgEdP5hV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCk6_5ZngDQANwIfCEbylPpRha0N_AeKvFKxnRdE-q8ow&oe=67726C23"}, "display_name": "Monkey Doo", "keywords": ["free", "multiplayer", "gorilla", "social", "hangout"], "long_description": "# \u2744\ufe0f\u2603\ufe0fWinter Update! \n\n- New **Slide Surfer Gimmick** | Make ice slides and fly in the air! \n- Winter Battle Pass and a brand new Holiday Bundle!\n- Lobby & Bongos have a new Winter theme\n\n=================================================\n\n{8710703832373135}\n**About**\n# Live in the heart of the Bermuda Triangle with all your Monkey friends! Swing on vines, throw doo at your enemies, and climb everything! \n\n- Huge Maps: Explore the Bermuda Jungle, Floating Forests, Ancient Ruins, Lava Chasm, and more\n\n- Unique Gamemodes: Be the first to collect 10 bananas or work together to fend off hordes of crocs -- new modes are coming all the time\n\n- Monkey Apparel: Customize your body color, equip face & head cosmetics, and stylize your doo\n\n- Ruby Mines: Explore a seemingly endless set of tunnels filled with lore, new NPC's, and our Battle Pass! Unlock exclusive rewards like Cosmetics, Doos, Boosters, and more with free and paid rewards! \n\n{2327501694315626}\n\nThemed Cosmetics & Hands-on Fun: Get your hands on... well, Hand cosmetics! Plus, a bunch of wacky, interactive items like things you can eat, press, and shake to your heart's content.\n\nHidden Treasures: Dive into a revamped store experience and hunt for secrets - like a mysterious portal leading to a hidden market. Plus, uncover new secrets via the plane!\n\nJump into the recently installed mining elevator to descend deep into the old ruby mines. Survive the **wrath of Xongo & save the Lost Souls** in Monkey Doo's all new Horror Mode!\n\n{9314948115205875}", "short_description": "\u2744\ufe0f\u2603\ufe0fWinter Update! \n\nLive in the heart of the Bermuda Triangle with all your Monkey friends! Swing on vines, throw doo at your enemies, and climb everything! \n\n- Huge Maps: Explore the Bermuda Jungle, Floating Forests, Ancient Ruins, Lava Chasm, and more\n\n- Unique Gamemodes: Be the first to collect 10 bananas or explore the lost mines and save souls -- new modes are coming all the time!\n\n- Monkey Apparel: Customize your body color, equip face & head cosmetics, and stylize your doo"}]}, "developer_name": "Continuum XR", "developer_privacy_policy_url": "https://www.clique.games/privacy", "developer_terms_of_service_url": "https://www.clique.games/terms", "publisher_name": "Clique Games ", "support_website_url": null, "website_url": "https://www.monkeydoovr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}, {"id": "1990104051447093"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8760599894048010"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57568672_560063643469490_4099036854623523776_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PimE8hCIGcUQ7kNvgHWyZer&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD5Qd-H10gF5x_BwZy05ZFo1hZa2iftyqqGwi9BnEOlBw&oe=677269EF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Monkey Doo", "platform": "ANDROID_6DOF", "context_ca