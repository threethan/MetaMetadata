TA-MW4EcF2PQO1P2NAA&oe=6706695A"}, {"file_name": "tss5.png", "id": "760707645548237", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974746_760707648881570_1069192667380168075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7NT_tCrsrBQQ7kNvgH4Pakc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_BSns-CulgpU748IvXLR0Cow5yylL7kNjhD1NT9TmJQ&oe=6706592D"}, {"file_name": "s21.png", "id": "541147128406262", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221322_541147131739595_7049747370601371318_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lblE8V7t3cIQ7kNvgEg0igz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDamuQnyGIkzyFefkWGunebEil8TYmDdn_RYlYsKuyOVw&oe=67065E6F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mdxrland.png", "id": "903297238362126", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982562_903297241695459_4534376069950516378_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M5pVsVq3-5MQ7kNvgHcTed8&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEEWmxN9-mT76Qj0Do-9xThM7gY44DCa9n_tACZQG4Wg&oe=670651D2"}, "display_name": "Monkey Doo", "keywords": ["free", "multiplayer", "physics", "gorilla", "action"], "long_description": "**Update**\n# \u2620\ufe0f\ud83d\ude28Xongo's Revenge! \n\n- New Battle Pass with Horror Mode Included!\n- Updated Ruby Mine\n- Halloween Exclusive Cosmetics\n\n=========================\n\n**About**\n# Live in the heart of the Bermuda Triangle with all your Monkey friends! Swing on vines, throw doo at your enemies, and climb everything! \n\n- Huge Maps: Explore the Bermuda Jungle, Floating Forests, Ancient Ruins, Lava Chasm, and more\n\n- Unique Gamemodes: Be the first to collect 10 bananas or work together to fend off hordes of crocs -- new modes are coming all the time\n\n- Monkey Apparel: Customize your body color, equip face & head cosmetics, and stylize your doo\n\n- Ruby Mines: Explore a seemingly endless set of tunnels filled with lore, new NPC's, and our Battle Pass! Unlock exclusive rewards like Cosmetics, Doos, Boosters, and more with free and paid rewards! \n\nThemed Cosmetics & Hands-on Fun: Get your hands on... well, new Hand cosmetics! Plus, a bunch of wacky, interactive items like things you can eat, press, and shake to your heart's content.\n\nHidden Treasures: Dive into a revamped store experience and hunt for secrets - like a mysterious portal leading to a hidden market. Plus, uncover new secrets via the plane!\n\n{1046562766872735}\nDeep within long abandoned tunnels of the ruby mines **a howling rings out** -- you decide to dig a little further than you should have...\n\nJump into the recently installed mining elevator to descend deep into the old ruby mines. Survive the **wrath of Xongo & save the Lost Souls** in Monkey Doo's all new Horror Mode!\n\n{872585647855554}\n", "short_description": "\u2620\ufe0f\ud83d\ude28Xongo's Revenge! \n\nLive in the heart of the Bermuda Triangle with all your Monkey friends! Swing on vines, throw doo at your enemies, and climb everything! \n\n- Huge Maps: Explore the Bermuda Jungle, Floating Forests, Ancient Ruins, Lava Chasm, and more\n\n- Unique Gamemodes: Be the first to collect 10 bananas or work together to fend off hordes of crocs -- new modes are coming all the time\n\n- Monkey Apparel: Customize your body color, equip face & head cosmetics, and stylize your doo"}]}, "developer_name": "Continuum XR", "developer_privacy_policy_url": "https://www.clique.games/privacy", "developer_terms_of_service_url": "https://www.clique.games/terms", "publisher_name": "Clique Games ", "support_website_url": null, "website_url": "https://www.monkeydoovr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SP