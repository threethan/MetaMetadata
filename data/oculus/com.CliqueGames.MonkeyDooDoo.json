DI-fDuFL3zqrfGsbt_S0qi5hY6cmoF0a8mbuEYIG7V7g&oe=66ED5CDA"}, {"file_name": "tss5.png", "id": "760707645548237", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974746_760707648881570_1069192667380168075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxapG_4amTsQ7kNvgFTRZKs&_nc_ht=scontent.oculuscdn.com&_nc_gid=A10i8yBhez4W6qmockbmGQ_&oh=00_AYADur1Nz624vQBzcPeXldmLXDhAAHEuJTHFjEOZHDUQig&oe=66ED4CAD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fanmade main.png", "id": "1541830936717423", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974888_1541830940050756_5679735311051651009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V6GMDu4v6xEQ7kNvgFxcAwB&_nc_ht=scontent.oculuscdn.com&_nc_gid=A10i8yBhez4W6qmockbmGQ_&oh=00_AYCu75JaTU5Yl8airKmp_LY8PUeT0EICU88rsoFhRBLeWA&oe=66ED544F"}, "display_name": "Monkey Doo", "keywords": ["free", "multiplayer", "physics", "gorilla", "action"], "long_description": "**Update**\n# \ud83d\udc12\ud83e\udef5Fan Made Update!\n\n- New Battle Pass with community created cosmetics\n- Updated Lobby\n- A few new secrets hidden\n\n=========================\n\n**About**\n# Live in the heart of the Bermuda Triangle with all your Monkey friends! Swing on vines, throw doo at your enemies, and climb everything! \n\n- Huge Maps: Explore the Bermuda Jungle, Floating Forests, Ancient Ruins, Lava Chasm, and more\n\n- Unique Gamemodes: Be the first to collect 10 bananas or work together to fend off hordes of crocs -- new modes are coming all the time\n\n- Monkey Apparel: Customize your body color, equip face & head cosmetics, and stylize your doo\n\n- Ruby Mines: Explore a seemingly endless set of tunnels filled with lore, new NPC's, and our Battle Pass! Unlock exclusive rewards like Cosmetics, Doos, Boosters, and more with free and paid rewards! \n\nThemed Cosmetics & Hands-on Fun: Get your hands on... well, new Hand cosmetics! Plus, a bunch of wacky, interactive items like things you can eat, press, and shake to your heart's content.\n\nHidden Treasures: Dive into a revamped store experience and hunt for secrets - like a mysterious portal leading to a hidden market. Plus, uncover new secrets via the plane!\n\n\n\n{2389444177920444}", "short_description": "\ud83d\udc12\ud83e\udef5Fan Made Update!\n\nLive in the heart of the Bermuda Triangle with all your Monkey friends! Swing on vines, throw doo at your enemies, and climb everything! \n\n- Huge Maps: Explore the Bermuda Jungle, Floating Forests, Ancient Ruins, Lava Chasm, and more\n\n- Unique Gamemodes: Be the first to collect 10 bananas or work together to fend off hordes of crocs -- new modes are coming all the time\n\n- Monkey Apparel: Customize your body color, equip face & head cosmetics, and stylize your doo"}]}, "developer_name": "Continuum XR", "developer_privacy_policy_url": "https://www.clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games ", "support_website_url": null, "website_url": "https://www.monkeydoovr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8052116731563000"}, "review_messages": ["Cubemap has been approved. Please schedule for release!"]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974648_818334276744773_64946916