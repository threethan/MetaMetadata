71-25/38974714_735853188116008_8821336656323190386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x8Z9Kv_hSaoQ7kNvgEInIKb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDobO4whg-4OfrRWl4F6VSRV2Hq5myaL8Jy4iJnpQ125A&oe=66CC6FBC"}]}, "id": "826833256215070", "locale": "en_US", "screenshots": [{"file_name": "2023-12-20 20-05-11.mp4_20231221_153440.260.png", "id": "1123489135485737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974696_1123489138819070_4814063790764227020_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JMqL-Ilca8YQ7kNvgGAbvNw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAD9gotxKVGmNwLbhPh8bMGxsI3Z2SzawW36wfYCyGRxA&oe=66CC6C56"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_162618.267.png", "id": "767350221887629", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031319_767350225220962_6832687444796937320_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HO_9NzIHMJQQ7kNvgE0Fp68&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYnmdy5x0BB6W8Sc2UJ2ynTu6c7TAWhWF8qkl2J3FAbQ&oe=66CC5F35"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_161808.373.png", "id": "1446645249527181", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254874_1446645252860514_1149586531032731776_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9_Jz745_VWcQ7kNvgEm1MLo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRClrfAaqmmhQCt5e9wDcrIA6CiVP6eaF5eWGY1HVDIA&oe=66CC6130"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_161729.348.png", "id": "757777229527750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974494_757777232861083_7138523962493522713_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8piRGOwkLTUQ7kNvgGZv-HN&_nc_ht=scontent.oculuscdn.com&oh=00_AYDk-ydFik1-raT0ab_jvWctQ6szsK90RkB2cv_ePhxWNw&oe=66CC5541"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_162025.726.png", "id": "317870794551802", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_317870797885135_43847752314827549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYh_qd5dkWIQ7kNvgHp5vQl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlBR3lvU44tnkqIfw9UBYuNd581-v7brk-vFzpwtG6Jw&oe=66CC854C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "s2.png", "id": "293807386481345", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75584096_293807389814678_7525229344081857969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5WKQKrxd0b8Q7kNvgHpf1Lb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAH67NWQB6vHBxr901vC9wHEfn5Tw_k_v9mXRE_QkttA&oe=66CC5225"}, "display_name": "VRLegs", "keywords": ["parkour", "free", "platformer", "social", "simulation"], "long_description": "**VRLegs** is the coolest VR parkour game!\n\nImagine you could jump, climb, and run like a superhero in a video game, but it feels super real. That's VRLegs! It's a new VR game that lets you do awesome parkour moves right in your living room.\n\n# How It Works\n\nIn VRLegs, you're not just pushing buttons - your whole body becomes part of the game! Our special technology makes it feel like you're really:\n\n* Running on walls\n* Jumping between buildings\n* Doing crazy flips\n\n# Play with Friends\n\nIt's not just about playing alone. You can:\n\n1. Challenge your friends to super fun games of tag\n2. Team up to beat tough obstacle courses together\n\nThe game has cool maps that look like real places where parkour athletes hang out.\n\n# Cool Stuff You Can Do\n\n* Move like a parkour pro in VR\n* Play tag or work together with your friends\n* Explore awesome city maps that feel real\n* Figure out sneaky ways to win\n* Use cool gadgets like gliders and bombs\n\n---\n\nVRLegs isn't just another game - it's a whole new way to move in VR. \n\n**Ready to feel like a parkour master?**", "short_description": "Jump, flip, and run like a superhero in this awesome VR parkour game! Use your whole body to move through cool city maps, challenge friends to tag, or team up for obstacle courses. With special gadgets and sneaky moves, VRLegs brings parkour thrills right to your living room. Ready to become a parkour master?"