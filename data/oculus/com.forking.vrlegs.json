G&oh=00_AYD4gejHU9DJ-toc5l0oHxiYPWP9gycJ6nEeOgCQ92dyoQ&oe=66EBF941"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_162025.726.png", "id": "317870794551802", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_317870797885135_43847752314827549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ahpYQ61VpdkQ7kNvgESvOvW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYDgpU-WpTt4dzcAKb0oY3pUCckbnAkqWEptgC2xS8UX0w&oe=66EC294C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "s2.png", "id": "293807386481345", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75584096_293807389814678_7525229344081857969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rwM9y9w6qgkQ7kNvgGQXe7P&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYAbC6zMViCSxfO6OQGhpuB0mvMQNZm9PUZw8M1xTB_LIA&oe=66EBF625"}, "display_name": "VRLegs", "keywords": ["parkour", "free", "platformer", "social", "simulation"], "long_description": "**VRLegs** is the coolest VR parkour game!\n\nImagine you could jump, climb, and run like a superhero in a video game, but it feels super real. That's VRLegs! It's a new VR game that lets you do awesome parkour moves right in your living room.\n\n# How It Works\n\nIn VRLegs, you're not just pushing buttons - your whole body becomes part of the game! Our special technology makes it feel like you're really:\n\n* Running on walls\n* Jumping between buildings\n* Doing crazy flips\n\n# Play with Friends\n\nIt's not just about playing alone. You can:\n\n1. Challenge your friends to super fun games of tag\n2. Team up to beat tough obstacle courses together\n\nThe game has cool maps that look like real places where parkour athletes hang out.\n\n# Cool Stuff You Can Do\n\n* Move like a parkour pro in VR\n* Play tag or work together with your friends\n* Explore awesome city maps that feel real\n* Figure out sneaky ways to win\n* Use cool gadgets like gliders and bombs\n\n---\n\nVRLegs isn't just another game - it's a whole new way to move in VR. \n\n**Ready to feel like a parkour master?**", "short_description": "Jump, flip, and run like a superhero in this awesome VR parkour game! Use your whole body to move through cool city maps, challenge friends to tag, or team up for obstacle courses. With special gadgets and sneaky moves, VRLegs brings parkour thrills right to your living room. Ready to become a parkour master?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrlegs.xyz/privacy-policy", "developer_terms_of_service_url": "https://vrlegs.xyz/terms-of-service", "publisher_name": "ForkingVR", "support_website_url": null, "website_url": "https://vrlegs.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7408173579284351"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_3817852245115207_747407265685385896_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qf2T1jsJXA8Q7kNvgH-DWj4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYBBVUrLDX-8x22yLzSVdh08vMqwGp2wAHt-Ixa-mIGwEw&oe=66EC0881"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRLegs", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "co