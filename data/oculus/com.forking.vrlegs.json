", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974714_735853188116008_8821336656323190386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4h2TS6UT2QAQ7kNvgGQXFuq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADtm8YsY7ZzfIB8waAfKZASqydYAJxrwZ1Zggnn7dzCw&oe=670914BC"}]}, "id": "1059253882603099", "locale": "en_US", "screenshots": [{"file_name": "2023-12-20 20-05-11.mp4_20231221_153440.260.png", "id": "1123489135485737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974696_1123489138819070_4814063790764227020_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5sZ8otDGAZMQ7kNvgFGWb1j&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAoSTRwCGP3g-mBmjiDX1_Z0Ap4nFNzmdfvBQWy-N72aQ&oe=67091156"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_162618.267.png", "id": "767350221887629", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031319_767350225220962_6832687444796937320_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6KKOO-KztjkQ7kNvgFQo1l2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAS4ETFYRxQG7s4nLo00gdg6gAWI98syn9XiuNPVocikg&oe=67090435"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_161808.373.png", "id": "1446645249527181", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254874_1446645252860514_1149586531032731776_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y0yFnd13rbUQ7kNvgEcMuya&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAgZHK1JqrGY1UtvU2WvOF_Dq52OO0UcdyPfbzDe_QwHg&oe=67090630"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_161729.348.png", "id": "757777229527750", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974494_757777232861083_7138523962493522713_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VOLEIPkifiQQ7kNvgFo9DPK&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCP5Mm70YdhUlf98vD4Q3hxiKIEb0Kr-EL2GJcXCpIa2Q&oe=6708FA41"}, {"file_name": "2023-12-22 11-41-33.mp4_20231222_162025.726.png", "id": "317870794551802", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974901_317870797885135_43847752314827549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Fx1yHnzJ3EQ7kNvgHiMcr9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCA7-Y8qHllzSLlM12Ru4hsEPYuFd-PEMWz7YFrOtm2w&oe=67092A4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "s2.png", "id": "293807386481345", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75584096_293807389814678_7525229344081857969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CYWKP5swCOwQ7kNvgHi5yDS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjyIbju9Gu_dLs_osAkr2ORO-0LMYIirxy5CitwcJTsA&oe=6708F725"}, "display_name": "VRLegs: Parkour Tag", "keywords": ["parkour", "free", "platformer", "social", "simulation"], "long_description": "**VRLegs** is the coolest VR parkour game! \n\n**Discord**: https://discord.gg/vrlegs\n\nImagine you could jump, climb, and run like a superhero in a video game, but it feels super real. That's VRLegs! It's a new VR game that lets you do awesome parkour moves right in your living room.\n\n# How It Works\n\nIn VRLegs, you're not just pushing buttons - your whole body becomes part of the game! Our special technology makes it feel like you're really:\n\n* Running on walls\n* Jumping between buildings\n* Doing crazy flips\n\n# Play with Friends\n\nIt's not just about playing alone. You can:\n\n1. Challenge your friends to super fun games of tag\n2. Team up to beat tough obstacle courses together\n\nThe game has cool maps that look like real places where parkour athletes hang out.\n\n# Cool Stuff You Can Do\n\n* Move like a parkour pro in VR\n* Play tag or work together with your friends\n* Explore awesome city maps that feel real\n* Figure out sneaky ways to win\n* Use cool gadgets like gliders and bombs\n\n---\n\nVRLegs isn't just another game - it's a whole new way to move in VR. \n\n**Ready to feel like a parkour master?**", "short_description": "Jump, flip, and run like a superhero in this awesome VR parkour game! Use your whole body to move through cool city maps, challenge friends to tag, or team up for obstacle courses. With special gadgets and sneaky moves, VRLegs brings parkour thrills right to your living room. Ready to become a parkour master?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrlegs.xyz/privacy-policy", "developer_terms_of_service_url": "https://vrlegs.xyz/terms-of-service", "publisher_name": "ForkingVR", "support_website_url": null, "website_url": "https://vrlegs.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7748118228623216"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974800_3817852245115207_747407265685385896_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n7ssETCswVgQ7kNvgEmMlZE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD05CiNJHOt9fp_RPF5Xr-XQXvXNheF5obX1UiYjzAM8A&oe=67090981"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRLegs: Parkour Tag", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Simulation", "id": "331529188132278"}], "rele