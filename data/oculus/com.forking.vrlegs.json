08&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03J4Vspsyg0Q7kNvgGFdL_n&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYBdb6a1nPvmmxiR_810dP6lmOBm-33c05afKyuveoy10A&oe=66EC1784"}, {"file_name": "Landscape.png", "id": "677824147318518", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54823267_677824150651851_3688777864047447478_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dhds8rjo9cMQ7kNvgFNtIqW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYD4a1-dnOR2d6aUVuG7KZxrVyH85Fc7B2OJkl-REKmAWg&oe=66EC1E6E"}, {"file_name": "Landscape.png", "id": "329704216222612", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250460_329704219555945_6993099148500521476_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VTgCy_VhcegQ7kNvgHxrrtk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYA5sEEEZnPgJoiJP7jGoGeCaDJ7YtDLGjm0HoB_WB8qPg&oe=66EC2853"}, {"file_name": "Landscape.png", "id": "627211022861814", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031653_627211026195147_859210511188470322_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dQA5yFUvS84Q7kNvgHOOwMZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdcBzbj9HvnwElSdaWzSC3G&oh=00_AYDoHEL1zOhdXRb9g9tqmMGitYjksBklu318Q4Tvy47buA&oe=66EC22A8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VRLegs", "keywords": [], "long_description": "Welcome to \"VRLegs\", where the thrill of parkour meets the immersive world of virtual reality. Step into a realm where your movements are fluid, intuitive, and empowering. Our state-of-the-art locomotion system redefines how you move, jump, and traverse in the VR space, offering an unparalleled sensation of freedom.\n\nChallenge friends or team up in heart-pounding multiplayer tag matches. Navigate complex terrains, leap across buildings, and experience the exhilaration of real-time chases. As you master your environment, you'll discover new strategies, shortcuts, and moves to stay one step ahead or elude capture.\n\nWhether you're a parkour enthusiast or new to the world of VR, \"VRLegs\" promises an adrenaline-pumping experience like no other. Join the revolution, find your rhythm, and let the chase begin!", "short_description": "Unleash parkour prowess in \"VRLegs\"! Dive into multiplayer tag, powered by a groundbreaking VR locomotion system. Feel the rush!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrlegs.xyz/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "ForkingVR", "support_website_url": null, "website_url": "https://vrlegs.xyz/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "6107509056017483"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2058494991169837"}]}, "baseline_offer": {"id": "2058494991169837"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1696433613, "status": "PUBLISHED", "id": "2058494991169837"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7630959127005794", "version": "0.4.2.240913.b"}, "id": "811103900658444", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Appl