447478_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zcd7yBBiQMwQ7kNvgGU-1o8&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDbpWMZl8Y4tHeS2qpYFPzhEdeC1PwEDUb5hITEGDQvvQ&oe=670FB6EE"}, {"file_name": "Landscape.png", "id": "329704216222612", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75250460_329704219555945_6993099148500521476_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HalpTNbfw8MQ7kNvgFikRYB&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA-q-FX76iB06PWRCCXBKPgjxeqOTme7ZmaKFOSwrHMcw&oe=670FC0D3"}, {"file_name": "Landscape.png", "id": "627211022861814", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031653_627211026195147_859210511188470322_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cc8b6nq_F94Q7kNvgEu-OD4&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCPAmmIRfuPCEJcghT2tNAjko2mNNPdxXQT6RzRJHBysA&oe=670FBB28"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VRLegs", "keywords": [], "long_description": "Welcome to \"VRLegs\", where the thrill of parkour meets the immersive world of virtual reality. Step into a realm where your movements are fluid, intuitive, and empowering. Our state-of-the-art locomotion system redefines how you move, jump, and traverse in the VR space, offering an unparalleled sensation of freedom.\n\nChallenge friends or team up in heart-pounding multiplayer tag matches. Navigate complex terrains, leap across buildings, and experience the exhilaration of real-time chases. As you master your environment, you'll discover new strategies, shortcuts, and moves to stay one step ahead or elude capture.\n\nWhether you're a parkour enthusiast or new to the world of VR, \"VRLegs\" promises an adrenaline-pumping experience like no other. Join the revolution, find your rhythm, and let the chase begin!", "short_description": "Unleash parkour prowess in \"VRLegs\"! Dive into multiplayer tag, powered by a groundbreaking VR locomotion system. Feel the rush!"}]}, "developer_name": null, "developer_p