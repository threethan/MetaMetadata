luscdn.com&oh=00_AYCQMF3Z4uQa_Asf2keWu94woQ53izwJ48Bd4J98sFdxeQ&oe=67583125"}, {"file_name": "ss-3.png", "id": "432950273136799", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57566688_432950276470132_6296901410558271266_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d4PaWaVpmhkQ7kNvgFlkZgx&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCV990wEi02-De3M0gRxuu1vJ379pSJAvE5fhuYMDeKZQ&oe=67582535"}, {"file_name": "ss-1.png", "id": "990870309506933", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974746_990870312840266_8219670313969916413_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bM0R-Sr2Fg8Q7kNvgGKGlMi&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCHvHCAtzlgzZC_lIz1XzoucP7EVDGEsasd8RJAIwsk8A&oe=67580FA6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video-thumb.png", "id": "896068849090374", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38984476_896068852423707_6468028910789789512_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JTjhVHgBvo8Q7kNvgHDsn2g&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAtiFESPSgjfZcAwpJMgsTv5I7HZhcEQIxrhs6cuRIwrg&oe=67582354"}, "display_name": "BTI: VR Training", "keywords": [], "long_description": "Key Features:\n\nHands-On Learning: Enhance your hands-on experience with a realistic virtual lab setting, ideal for BTI\u2019s BioSTART and Laboratory Associates Program.\n\nSelf-Paced Learning: Progress through learning modules at your own pace with built-in evaluations, ensuring you develop competencies before advancing.\n\nHaptic Feedback: Feel like you're performing real tasks with tactile feedback from the controllers.\n\nInstructor Monitoring: Instructors can track your progress and practice frequency, ensuring a smooth transition from virtual to real-world competency.\n\nAccessibility: Break down traditional barriers to training, providing more opportunities for underrepresented demographics.\n\nAdult Learning Principles: The program aligns with the principles of adult learning for effective skill development.", "short_description": "BTI VR Training is a cutting-edge training tool for the biotechnical sector, ideal for those entering the biotech industry. It combines practical lab simulations with interactive theoretical lessons, providing a comprehensive learning experience. This application is a key resource for acquiring essential lab skills, serving as a bridge to the dynamic biotech world."}]}, "developer_name": "Capitol Interactive LLC", "developer_privacy_policy_url": "https://www.virtualapprentice.net/privacy-policy/new-portfolio-item-jjw66", "developer_terms_of_service_url": null, "publisher_name": "Virtual Apprentice LLC", "support_website_url": null, "website_url": "http://btiworks.org/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8910066185673239"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982725_1248909029455768_3537695910950216172_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=faHtcFVe5TEQ7kNvgFEWy3W&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBlVLpKijm8b0AiBhffAALejudwxdqJ7yG-ZBr4zAlLVw&oe=675821EB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BTI: VR Training", "platform": "ANDROID_6D