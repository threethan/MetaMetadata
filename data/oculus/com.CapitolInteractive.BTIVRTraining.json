luscdn.com&oh=00_AYBWrDiJ9_l1wBV1sIZlh7pZ9oXnQsdcS-kMBADpKvFR6A&oe=67470DA5"}, {"file_name": "ss-3.png", "id": "432950273136799", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566688_432950276470132_6296901410558271266_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fdTJ19ICjb0Q7kNvgHeoUlW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyNZkDvGs4lD4thzUTzxgnl-bcveCYvzwMZcivdiT1-g&oe=674701B5"}, {"file_name": "ss-1.png", "id": "990870309506933", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974746_990870312840266_8219670313969916413_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c9InCcNhqjwQ7kNvgG0bn77&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZw2ebuYoLZrHEGCSlQEggjGGljX_8FOLYaR26dZVzFw&oe=6746EC26"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video-thumb.png", "id": "896068849090374", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984476_896068852423707_6468028910789789512_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5DnQsYRWNM8Q7kNvgH9JMvT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCn90gZjAvhtagYVD1ojYwybEAXTfGX0gCSyAwJ0hCHGQ&oe=6746FFD4"}, "display_name": "BTI: VR Training", "keywords": [], "long_description": "Key Features:\n\nHands-On Learning: Enhance your hands-on experience with a realistic virtual lab setting, ideal for BTI\u2019s BioSTART and Laboratory Associates Program.\n\nSelf-Paced Learning: Progress through learning modules at your own pace with built-in evaluations, ensuring you develop competencies before advancing.\n\nHaptic Feedback: Feel like you're performing real tasks with tactile feedback from the controllers.\n\nInstructor Monitoring: Instructors can track your progress and practice frequency, ensuring a smooth transition from virtual to real-world competency.\n\nAccessibility: Break down traditional barriers to training, providing more opportunities for underrepresented demographics.\n\nAdult Learning Principles: The program aligns with the principles of adult learning for effective skill development.", "short_description": "BTI VR Training is a cutting-edge training tool for the biotechnical sector, ideal for those entering the biotech industry. It combines practical lab simulations with interactive theoretical lessons, providing a comprehensive learning experience. This application is a key resource for acquiring essential lab skills, serving as a bridge to the dynamic biotech world."}]}, "developer_name": "Capitol Interactive LLC", "developer_privacy_policy_url": "https://www.virtualapprentice.net/privacy-policy/new-portfolio-item-jjw66", "developer_terms_of_service_url": null, "publisher_name": "Virtual Apprentice LLC", "support_website_url": null, "website_url": "http://btiworks.org/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8910066185673239"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982725_1248909029455768_3537695910950216172_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DgYJKSnCJaYQ7kNvgEyS_sT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBp71aijM-K9ctBGd1M7HFfGFRh6KemzEquQWNZIXqrEg&oe=6746FE6B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BTI: VR Training", "platform": "ANDROID_6D