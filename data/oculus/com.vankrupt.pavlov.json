5323364455326831_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wB_asx5NTDkQ7kNvgG8EA5P&_nc_ht=scontent.oculuscdn.com&oh=00_AYDg_YBMNpR_2mn1B64qrqoHJFsgmrxzxAurtZH1Gc8xxA&oe=66D84309"}, {"file_name": "Screenshots_Search&Destroy_7.png", "id": "850111469847781", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931336_850111473181114_8558271006382117957_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ydD8SeIr-JgQ7kNvgELMexs&_nc_ht=scontent.oculuscdn.com&oh=00_AYALbNAbJASLvOMtSktbX1_DeVjBK5uT2S565Z7J-qiGAQ&oe=66D8422D"}, {"file_name": "Screenshots_6.png", "id": "997416164666388", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031626_997416167999721_6433022065639766756_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wetd-3FAWCoQ7kNvgG631Y-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdkVf_-pCuGv65HYSzRw7Ea-qjGgFnJ1xkoSbYjaHW2w&oe=66D843D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pavlov Shack_PreOrder_Teaser_Thumbnail.png", "id": "685913936805545", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035417_685913940138878_383861971411671377_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B7eboVwBAi4Q7kNvgFkNKqQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTW1CHmI8UZ6VBvdo7hSmRVHOIbx779YvP_G5-kyzwOQ&oe=66D84DDA"}, "display_name": "Pavlov: Shack", "keywords": ["Shooter", "FPS", "multiplayer", "pvp", "combat"], "long_description": "Pavlov is a team-based multiplayer VR shooter with realistic weapon handling. Play a variety of game modes with over 65 interactable weapons and attachments in various environments.\n\nTeam up in a match of 5v5 in Search and Destroy, a classic uncompromising competitive game mode where you must attack or defend against a bomb objective.\n\nUse your detective skills to uncover the traitors in a casual murder mystery gameplay with various player roles in TTT.\n\nNeutralize a monster that escaped captivity from the lab by relying on the flashlight attached to your rifle in dark environments in an asymmetrical 1 vs. 9 game.\n\nOperate vehicles such as 4\u00d74s or tanks with intuitive driving controls in a WWII match to defend your homeland in Stalingrad.\n\nBite the bullet, grit your teeth, and queue up.", "short_description": "Multiplayer shooter in VR with realistic weapon mechanics, features 5 vs 5 competitive and social game modes."}]}, "developer_name": "Vankrupt Games", "developer_privacy_policy_url": "http://cdn.pavlov-vr.com/privacy_policy.html", "developer_terms_of_service_url": "https://www.vankrupt.com/eula.html", "publisher_name": "Vankrupt Games", "support_website_url": "http://pavlovwiki.com/index.php/Main_Page", "website_url": "https://www.vankrupt.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "6995572930454302"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "1008660573750242"}, {"status": "PUBLISHED", "id": "355121043798498"}, {"status": "CANCELLED", "id": "864414812080877"}, {"status": "PUBLISHED", "id": "407965601930513"}, {"status": "CANCELLED", "id": "282756094455001"}, {"status": "PUBLISHED", "id": "822837872973193"}, {"status": "CANCELLED", "id": "7066779193403402"}, {"status": "CANCELLED", "id": "1105527547276867"}, {"status": "PUBLISHED", "id": "992981115095509"}, {"status": "PUBLISHED", "id": "844721017197345"}]}, "baseline_offer": {"id": "992981115095509"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1697562000, "status": "PUBLISHED", "id": "1008660573750242"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8463431337001780", "version": "1.0.19"}, "id": "2340091246312543", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8463431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1724968451, "id": "8475962815748632", "version": "1.0.20", "version_code": 1595, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8475838799094367"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8463431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1724960518, "id": "8475414472470133", "version": "1.0.20", "version_code": 1594, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8475284032483177"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8463431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2340091246312543"}]}, "change_log": "Core\n-Added new map Carnival\n-Added MOTD (Message of the Day) \n-Added official standoff mod and maps on mod.io\n-Adjusted van in harbor to be less cheesy\n-Adjusted placing trace range for Aurora Trip Mines so they are less likely to be placed inside walls\n-Fixed issue with hide crate spawn in Autumn that blocked a pathway\n-Fixed an out of bounds exploit in Haguenau\n-Fixed an exploit in Industry\n-Fixed various cosmetic issues with gun skins\n-Fixed cosmetic issue with noticeboard on Harbor\n-Fixed a pixel walk on Harbor\n-Fixed an abusable angle in Harbor\n-Fixed an out of bounds exploit in Harbor\n\nTTT\n-Added font fit mode to player's role for TTT watch.\n-Fixed Set TTTSubtext node not working in all use cases. \n-Adjusted TTT to now get roles in play every round for modders who want to add and remove roles during the game.\n\nMods\n-Added modkit feature to disable a custom Round End SubText if one was set by inputting a blank string \"\" into the SetTTTEndRoundSubText node.\n-Added modkit feature to ignore \"Spawns Roles\" field when adding a TTT Role (Add \"DONOTCHANGE\" to Spawns Roles array).\n-Fixed issue with download counts not working in Mod.io \n", "created_date": 1724799040, "id": "8463431337001780", "version": "1.0.19", "version_code": 1593, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8463300687014845"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8463431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []},