5323364455326831_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QmQMSL8PsvAQ7kNvgF6Hxoi&_nc_ht=scontent.oculuscdn.com&oh=00_AYCl76-0jHo3CWjlFNz1mQ3UhKSlsYTwjZ4fnlonezA9Og&oe=66DEDA89"}, {"file_name": "Screenshots_Search&Destroy_7.png", "id": "850111469847781", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931336_850111473181114_8558271006382117957_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U3RhDzlZN4AQ7kNvgEoR69E&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzkiT1gp-zz9FE_aFFzy3kXTza_4C09TkBYHoYbIlsiQ&oe=66DED9AD"}, {"file_name": "Screenshots_6.png", "id": "997416164666388", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031626_997416167999721_6433022065639766756_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cX8xSQTyrbAQ7kNvgH66Csr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBV5gehqHE7SsDE0ZLbE44FjPAE7n2ZRtLmVX8dVz1WrQ&oe=66DEDB53"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pavlov Shack_PreOrder_Teaser_Thumbnail.png", "id": "685913936805545", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035417_685913940138878_383861971411671377_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fl7xXZ3_Y_sQ7kNvgEyOBdE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCxMCzYJ92QrmG7J7YkzuXGCWBB1kRbk-TFop1OqN6X-g&oe=66DEE55A"}, "display_name": "Pavlov: Shack", "keywords": ["Shooter", "FPS", "multiplayer", "pvp", "combat"], "long_description": "Pavlov is a team-based multiplayer VR shooter with realistic weapon handling. Play a variety of game modes with over 65 interactable weapons and attachments in various environments.\n\nTeam up in a match of 5v5 in Search and Destroy, a classic uncompromising competitive game mode where you must attack or defend against a bomb objective.\n\nUse your detective skills to uncover the traitors in a casual murder mystery gameplay with various player roles in TTT.\n\nNeutralize a monster that escaped captivity from the lab by relying on the flashlight attached to your rifle in dark environments in an asymmetrical 1 vs. 9 game.\n\nOperate vehicles such as 4\u00d74s or tanks with intuitive driving controls in a WWII match to defend your homeland in Stalingrad.\n\nBite the bullet, grit your teeth, and queue up.", "short_description": "Multiplayer shooter in VR with realistic weapon mechanics, features 5 vs 5 competitive and social game modes."}]}, "developer_name": "Vankrupt Games", "developer_privacy_policy_url": "http://cdn.pavlov-vr.com/privacy_policy.html", "developer_terms_of_service_url": "https://www.vankrupt.com/eula.html", "publisher_name": "Vankrupt Games", "support_website_url": "http://pavlovwiki.com/index.php/Main_Page", "website_url": "https://www.vankrupt.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "6995572930454302"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "1008660573750242"}, {"status": "PUBLISHED", "id": "355121043798498"}, {"status": "CANCELLED", "id": "864414812080877"}, {"status": "PUBLISHED", "id": "407965601930513"}, {"status": "CANCELLED", "id": "282756094455001"}, {"status": "PUBLISHED", "id": "822837872973193"}, {"status": "CANCELLED", "id": "7066779193403402"}, {"status": "CANCELLED", "id": "1105527547276867"}, {"status": "PUBLISHED", "id": "992981115095509"}, {"status": "PUBLISHED", "id": "844721017197345"}]}, "baseline_offer": {"id": "992981115095509"}, "is_appr