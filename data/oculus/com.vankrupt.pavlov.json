50111473181114_8558271006382117957_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=elFHjIyvSEoQ7kNvgFtMdop&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAOBucj7WVTjSyPhwSrjBduVtbmZaWGOMcIOTBHLbkcwQ&oe=6762AFAD"}, {"file_name": "Screenshots_6.png", "id": "997416164666388", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031626_997416167999721_6433022065639766756_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=riypd36vdoEQ7kNvgEbd7zE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD920GKgMOJSREI-V_IMhram3WQDardIqMKXKsz9swu-A&oe=6762B153"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pavlov Shack_PreOrder_Teaser_Thumbnail.png", "id": "685913936805545", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035417_685913940138878_383861971411671377_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aU7EFmrNBq0Q7kNvgGiPPaE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBBl6EdJrhCoF80Gfhzve0iQLGp2fC-V0fRoVC5GMWCDw&oe=6762BB5A"}, "display_name": "Pavlov: Shack", "keywords": ["Shooter", "FPS", "multiplayer", "pvp", "combat"], "long_description": "Pavlov is a team-based multiplayer VR shooter with realistic weapon handling. Play a variety of game modes with over 65 interactable weapons and attachments in various environments.\n\nTeam up in a match of 5v5 in Search and Destroy, a classic uncompromising competitive game mode where you must attack or defend against a bomb objective.\n\nUse your detective skills to uncover the traitors in a casual murder mystery gameplay with various player roles in TTT.\n\nNeutralize a monster that escaped captivity from the lab by relying on the flashlight attached to your rifle in dark environments in an asymmetrical 1 vs. 9 game.\n\nOperate vehicles such as 4\u00d74s or tanks with intuitive driving controls in a WWII match to defend your homeland in Stalingrad.\n\nBite the bullet, grit your teeth, and queue up.", "short_description": "Multiplayer shooter in VR with realistic wea