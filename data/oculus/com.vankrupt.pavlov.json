336_850111473181114_8558271006382117957_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=40V4rSYfABEQ7kNvgG6R7Ec&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBydraztgt-7qIRZ6nyOD_JVjbiP4XKMrxOT1bnYKXmkA&oe=673B22AD"}, {"file_name": "Screenshots_6.png", "id": "997416164666388", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031626_997416167999721_6433022065639766756_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8fC8wquVBAEQ7kNvgH89qbr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBnjFVZHa4u97-HRHG8Cx35vnHdl0QJGmss5qIyJ_Lj2g&oe=673B2453"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pavlov Shack_PreOrder_Teaser_Thumbnail.png", "id": "685913936805545", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035417_685913940138878_383861971411671377_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=93YLZ8j-KtAQ7kNvgGZXgwx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmayjnw4zqJm3TVnvHlPylhhwKnwhcEpOFrH9ItdILow&oe=673B2E5A"}, "display_name": "Pavlov: Shack", "keywords": ["Shooter", "FPS", "multiplayer", "pvp", "combat"], "long_description": "Pavlov is a team-based multiplayer VR shooter with realistic weapon handling. Play a variety of game modes with over 65 interactable weapons and attachments in various environments.\n\nTeam up in a match of 5v5 in Search and Destroy, a classic uncompromising competitive game mode where you must attack or defend against a bomb objective.\n\nUse your detective skills to uncover the traitors in a casual murder mystery gameplay with various player roles in TTT.\n\nNeutralize a monster that escaped captivity from the lab by relying on the flashlight attached to your rifle in dark environments in an asymmetrical 1 vs. 9 game.\n\nOperate vehicles such as 4\u00d74s or tanks with intuitive driving controls in a WWII match to defend your homeland in Stalingrad.\n\nBite the bullet, grit your teeth, and queue up.", "short_description": "Multiplayer shooter in VR with realistic weapon mechanics, features 5 vs 5 competitive and social game modes."}]}, "developer_name": "Vankrupt Games", "developer_privacy_policy_url": "http://cdn.pavlov-vr.com/privacy_policy.html", "developer_terms_of_service_url": "https://www.vankrupt.com/eula.html", "publisher_name": "Vankrupt Games", "support_website_url": "http://pavlovwiki.com/index.php/Main_Page", "website_url": "https://www.vankrupt.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "6995572930454302"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "453535054403580"}, {"status": "PUBLISHED", "id": "1008660573750242"}, {"status": "PUBLISHED", "id": "355121043798498"}, {"status": "CANCELLED", "id": "864414812080877"}, {"status": "PUBLISHED", "id": "407965601930513"}, {"status": "CANCELLED", "id": "282756094455001"}, {"status": "PUBLISHED", "id": "822837872973193"}, {"status": "CANCELLED", "id": "7066779193403402"}, {"status": "CANCELLED", "id": "1105527547276867"}, {"status": "PUBLISHED", "id": "992981115095509"}, {"status": "PUBLISHED", "id": "844721017197345"}]}, "baseline_offer": {"id": "992981115095509"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "453535054403580"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8951574891520753", "version": "1.0.21"}, "id": "2340091246312543", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8951574891520753"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731440534, "id": "9040312575980317", "version": "1.0.22", "version_code": 1638, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "9040202005991374"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8951574891520753"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731011712, "id": "9006275236050718", "version": "1.0.22", "version_code": 1637, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "9006151502729758"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8951574891520753"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2340091246312543"}]}, "change_log": "A major change to The Hide and a gaggle of hotfixes. \n\nCore \n-Adjusted collision if you bump into a wall with your muzzle while firing in full auto it will no longer release the trigger  \n-Adjusted bullet penetration physmats on Oilrig\n-Adjusted minor shadow/lighting issues in Carnival\n-Adjusted lighting in Autumn to brighten up the appearance of characters in dark areas slightly\n-Fixed an exploit using burst fire in walls \n-Fixed a playspace exploit\n-Fixed flag texture issue, pixel walk, and spawn issue on Stalingrad\n-Fixed out of bounds exploit on Pinehill\n-Fixed out of bounds exploit on Oilrig\n-Fixed out of bounds exploit on Sand\n-Fixed a floating prop issue on Bridge\n-Fixed an ejected shell issue in drumshotgun \n-Fixed climbable cars in industry garage\n-Fixed OITC and KOTH compatibility for Oilrig\n\nThe Hide\n-Added new objectives: Conquest Disruptors. 1-3 Disruptor objectives may spawn and can be captured in any order by standing in the capture zone. The Hide Monster can contest or revert the capture of any objective by standing in the capture zone. Once all objectives are captured, the monster will take damage over time.\n-Added Gas Grenade (Id: gas). Gas grenades replace smoke grenades in The Hide, they last for 30 seconds and deal damage-over-time while inside the cloud.\n-Adjusted bandage healing from 33 to 66\n-Adjusted bandage healing duration from instant to 3 healing ticks.\n-Adjusted Adrenaline Shot for the monster. Adrenaline shots now give the monster infinite stamina for 7 seconds.\n\nModkit (game client only, modkit update not needed) \n-Added drum magazine variants for modders (ID: ppsh_drum, thompson_drum)\n-Added golden gun to loot spawner table (ID: goldengun and tttgoldengun)", "created_date": 1730307443, "id": "8951574891520753", "version": "1.0.21", "version_code": 1636, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8951490621529180"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8951574891520753"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730247655, "id": "8946796255331950", "version": "1.0.21", "version_code": 1635, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8946782155333360"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8951574891520753"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2340091246312543"}]}, "change_log": "\nCore\n-Adjusted collision if you bump into a wall with your muzzle while firing in full auto it will no longer release the trigger  \n-Adjusted bullet penetration physmats on Oilrig\n-Adjusted minor shadow/lighting issues in Carnival\n-Adjusted lighting in Autumn to brighten up a few dark areas slightly\n-Fixed an exploit using burst fire in walls \n-Fixed a playspace exploit\n-Fixed flag texture issue on Stalingrad\n-Fixed out of bounds exploit on Pinehill\n-Fixed out of bounds exploit on Oilrig\n-Fixed a floating prop issue on Bridge\n-Fixed an ejected shell issue in drumshotgun \n-Fixed climbable cars in industry garage\n-Fixed OITC and KOTH compatibility for Oilrig\n\nThe Hide\n-Added new objectives: Conquest Disruptors. 1-3 Disruptor objectives may spawn and can be captured in any order by standing in the capture zone. The Hide Monster can contest or revert the capture of any objective by standing in the capture zone. Once all objectives are captured The Hide Monster begins to die and this cannot be stopped.\n-Added Gas Grenade (ID: gas). Gas grenades replace smoke grenades in The Hide, they last for 30 seconds and deal damage-over-time while inside the cloud.\n-Adjusted bandage healing from 33 to 66\n-Adjusted bandage healing duration from instant to 3 healing ticks.\n-Adjusted Adrenaline Shot for the monster. Adrenaline shots now give the monster infinite stamina for 7 seconds.\n\nModkit \n-Added drum magazine variants for modders (ID: ppsh_drum, thompson_drum)\n-Added golden gun to loot spawner table (ID: goldengun and tttgoldengun)", "created_date": 1730234983, "id": "8945912285420347", "version": "1.0.21", "version_code": 1634, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8945764658768443"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}