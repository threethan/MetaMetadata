3431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1724960518, "id": "8475414472470133", "version": "1.0.20", "version_code": 1594, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8475284032483177"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8463431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2340091246312543"}]}, "change_log": "Core\n-Added new map Carnival\n-Added MOTD (Message of the Day) \n-Added official standoff mod and maps on mod.io\n-Adjusted van in harbor to be less cheesy\n-Adjusted placing trace range for Aurora Trip Mines so they are less likely to be placed inside walls\n-Fixed issue with hide crate spawn in Autumn that blocked a pathway\n-Fixed an out of bounds exploit in Haguenau\n-Fixed an exploit in Industry\n-Fixed various cosmetic issues with gun skins\n-Fixed cosmetic issue with noticeboard on Harbor\n-Fixed a pixel walk on Harbor\n-Fixed an abusable angle in Harbor\n-Fixed an out of bounds exploit in Harbor\n\nTTT\n-Added font fit mode to player's role for TTT watch.\n-Fixed Set TTTSubtext node not working in all use cases. \n-Adjusted TTT to now get roles in play every round for modders who want to add and remove roles during the game.\n\nMods\n-Added modkit feature to disable a custom Round End SubText if one was set by inputting a blank string \"\" into the SetTTTEndRoundSubText node.\n-Added modkit feature to ignore \"Spawns Roles\" field when adding a TTT Role (Add \"DONOTCHANGE\" to Spawns Roles array).\n-Fixed issue with download counts not working in Mod.io \n", "created_date": 1724799040, "id": "8463431337001780", "version": "1.0.19", "version_code": 1593, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8463300687014845"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2443267419018232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8463431337001780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1724794554, "id": "8463093153702265", "version": "1.0.19", "version_code": 1592, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8462912480386999"}, "asset_files": {"count": 2}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}