c_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0aSzUMrDel8Q7kNvgGSaEtU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANIC9p8Q26ZjDz9cAp0MGMN&oh=00_AYBAQBloPAFkbYteFNj1s1D-CK2i2YtljsN3ABNYH95ihQ&oe=66E436CA"}, "display_name": "Industrial Journey - Thermal Power Plant", "keywords": [], "long_description": "Power Up Your Learning with Our New Thermal Power Plant Module! \n\nElevate your journey on our platform with this immersive add-on. Dive into a virtual Thermal Power Plant, choosing between a guided tour for detailed insights or the freedom of Explore Mode to roam at your will. Witness firsthand the intricate workings of power generation. This module isn't just an addition; it's a gateway to understanding the dynamics of energy like never before.\n\nJoin us in revolutionizing the way engineering is taught. Embrace the power of VR to gain practical, in-depth knowledge in a truly interactive environment. Our VR engineering modules are more than just a learning tool; they are your gateway to mastering engineering concepts through modern technology. \n\nStart your virtual educational adventure today!", "short_description": "Dive into a virtual Thermal Power Plant, choosing between a guided tour for detailed insights or the freedom of Explore Mode to roam at your will.\n\nStart your virtual educational adventure today!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ixrlabs.com/privacy-policy.php", "developer_terms_of_service_url": null, "publisher_name": "IXRLabs", "support_website_url": null, "website_url": "https://www.ixrlabs.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": nu