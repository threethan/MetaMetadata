079_768383064923595_4211140968269354017_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nTiwM_b16YwQ7kNvgEV2Y5o&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBW_ncrH16bC3y9HTwZ83FZmoNX30BlttbDkQKCKPpUYg&oe=672A195D"}, {"file_name": "wagontrippler (2).png", "id": "1114486173017293", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75451785_1114486176350626_6801906375189017759_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cZ0izj-51AcQ7kNvgH8l59O&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAtIabfoolYHuHzbo_B9tH02oZaPpS02yWxcyFfEEhvRw&oe=6729E9A3"}, {"file_name": "TransmissionLine (1) (1).png", "id": "1118306052698207", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982652_1118306056031540_6464141157175375557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=INcaqTsBsgAQ7kNvgF53UDe&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYB3wXRkt6ETRTd1brmZGM759Pn3MrW1QT2h13EOrR-EIQ&oe=672A07FE"}, {"file_name": "ESP (1) (1).png", "id": "964151325246560", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75443244_964151328579893_8461473694159931819_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q2gd_CaDRQ4Q7kNvgEJBoMZ&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCUkeY3c7gUwrm58XPX_fndDZGn1QYauD4LuS6p1Kp98Q&oe=672A21A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "01-Thermal_Power_Plant_Image-01-Cover.png", "id": "710635164302527", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035385_710635167635860_999737385406583038_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iqnFvGrgZ1kQ7kNvgGc8LHZ&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYC6lKx-YjQiBx10y-DjpE3q0e4n_WdeSTCwEdTKoH8BSA&oe=672A164A"}, "display_name": "Industrial Journey - Thermal Power Plant", "keywords": [], "long_description": "Power Up Your Learning with Our New Thermal Power Plant Module! \n\nElevate your journey on our platform with this immersive add-on. Dive into a virtual Thermal Power Plant, choosing between a guided tour for detailed insights or the freedom of Explore Mode to roam at your will. Witness firsthand the intricate workings of power generation. This module isn't just an addition; it's a gateway to understanding the dynamics of energy like never before.\n\nJoin us in revolutionizing the way engineering is taught. Embrace the power of VR to gain practical, in-depth knowledge in a truly interactive environment. Our VR engineering modules are more than just a learning tool; they are your gateway to mastering engineering concepts through modern technology. \n\nStart your virtual educational adventure today!", "short_description": "Dive into a virtual Thermal Power Plant, choosing between a guided tour for detailed insights or the freedom of Explore Mode to roam at your will.\n\nStart your virtual educational adventure today!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ixrlabs.com/privacy-policy.php", "developer_terms_of_service_url": null, "publisher_name": "IXRLabs", "support_website_url": null, "website_url": "https://www.ixrlabs.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7652998188065650"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1423349825007842"}, {"status": "PUBLISHED", "id": "288869297410657"}]}, "baseline_offer": {"id": "1423349825007842"}, "is_ap