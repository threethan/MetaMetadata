82476_1163584147556012_2610006929063235668_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5V-bOfPMfSEQ7kNvgG8JoNb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATbCoTceGYUA1kE92ROUmNLqH_5G8zD0Nhbm4Kgsipug&oe=6749A161"}, "display_name": "Slurpies FREE", "keywords": [], "long_description": "How long can you grow your Space Slurpie? Relax in this free version of the multiplayer arcade game and control a colorful space snake with your hand. Chill out with your friends while collecting as much food as possible. The more you eat, the more the snake grows. Try not to run into other players or all kinds of playful baddies! With a calming Zen mode, multiplayer modifiers, and over 30 solo maps, there is a game mode for everyone to enjoy.", "short_description": "Snake, slither, SLURRPP! Chill out with your friends in this free multiplayer arcade game. Relax as you grow your colorful space snake by eating lots of food and avoiding playful baddies and other players. How long can you grow your Space Slurpie?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/space-slurpies-privacy-policy", "developer_terms_of_service_url": "https://www.starcadearcadellc.com/space-slurpies-eula", "publisher_name": "Starcade Arcade LLC", "support_website_url": "https://www.starcadearcadellc.com/contact", "website_url": "https://www.starcadearcadellc.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_pl