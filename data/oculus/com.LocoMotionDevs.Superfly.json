ri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569446_741318940638773_7544869782679183788_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiLtNrpYFQEQ7kNvgHKKPz2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlFDRONAzGCjPZd6lwMPVURpNxmEKTOS8X6k07KE45OA&oe=67486FBB"}, {"file_name": "screenshot_4.png", "id": "1118138769116631", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295892_1118138772449964_2672723300278990125_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dvMQpRDe0jYQ7kNvgEJrnr0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAGJp2qrBXjBJ93R85sKCcixs4jaAzeqC9kjVnvY7J10Q&oe=6748507F"}, {"file_name": "screenshot_5.png", "id": "376106727904774", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462963_376106731238107_8755515373739147778_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TOoH7orvlpwQ7kNvgFWWCgt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfKkltzwmnrvkECjMFnMbQ9QpJ56tOmH-o-OclHr_2dA&oe=6748473F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "capsule-2560-1440-v5.png", "id": "431320982143609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982698_431320985476942_5789175747859072348_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=60tLMcarcckQ7kNvgEeeKS7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqerzUApNhW0H62fLqSX37DL8znjpD5GY6SBnanuXdNQ&oe=67485B68"}, "display_name": "Superfly", "keywords": [], "long_description": "Superfly is an open-world action sandbox game where you play as a superhero who can switch between eight different movement modes. Discover new forms of locomotion as you experiment with pairs of movement modes and explore the city any way you would like. Use each mode\u2019s unique abilities to fight the army of robots invading the city.\n\nInteract with the tens of thousands of vehicles and dynamic objects that bring life to the city. Fight robotic bosses that have EMP and hacking powers to disable your abilities. Collect gears through exploration and defeating enemies in the Story Mode to unlock even more unique sidegrades for your powers. All objects and abilities are entirely based in the physics engine, leading to emergent gameplay limited only by your creativity.\n\nSuperfly is developed by Loco Motion Devs, check out our website to learn more about the team. Join our community on Discord: https://discord.gg/Ed3E9HP", "short_description": "Superfly is a virtual reality action game where you play as the superhero of your dreams. Mix and match eight unique movement modes to fly through a massive open-world city full of challenges for your movement and combat skills. "}]}, "developer_name": "Loco Motion Devs", "developer_privacy_policy_url": "https://superflyvrgame.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Loco Motion Devs", "support_website_url": "https://superflyvrgame.com/contact", "website_url": "https://superflyvrgame.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1167477183996426"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "411624722005440"}, {"status": "PUBLISHED", "id": "3267691093556164"}]}, "baseline_offer": {"id": "3267691093556164"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "41