06213554_7852994986699292165_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9o5WgxAOo6oQ7kNvgFT6jb1&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYB7BbHbfqBqtNjwqMlMnMUFxbyb2ppUXru1MpVvcOqxUA&oe=678791FD"}, {"file_name": "SomeLevel432.png", "id": "518532486000852", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974608_518532489334185_127543275156800032_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5kymIXhCNJYQ7kNvgG0d9MU&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCuBUeNKdT0lvXpTMINPuwo3WWDsR66dup-CsPMUl1oZw&oe=6787A662"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SomeLevel132679504008316256.png", "id": "127304822825290", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974591_127304826158623_4600186409568997445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mfzr0bT4QxwQ7kNvgHRr4WQ&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC1CfQ1pYmnfXaa7q7x4JDZb9ohpIPfxWysCbo6XBvS0Q&oe=67879E9D"}, "display_name": "Tank Battle", "keywords": [], "long_description": "Tank Battle is the fastest tank game ever. In the game, you have to fight with 50, 100, even 150 tanks. Your tanks must fire enemies and move as fast as possible, avoid enemy's bullets and destroy other tanks. There is no time for thinking in those battles, you have to shoot or be shot, destroy or be destroyed.", "short_description": "Tank Battle is the fastest tank game ever. In the game, you have to fight with 50, 100, even 150 tanks. Your tanks must fire enemies and move as fast as possible, avoid enemy's bullets and destroy other tanks. There is no time for thinking in those battles, you have to shoot or be shot, destroy or be destroyed."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/8b35ed74-fde6-4655-b0e0-1eeda6fe1442", "developer_terms_of_service_url": null, "publisher_name": "Galaxy Lab", "support_website_url": null, "website_url": "https://www.facebook.com/galaxylabgamestud