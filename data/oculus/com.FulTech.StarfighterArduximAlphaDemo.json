_ohc=TnVw8d4Bf8gQ7kNvgFR4dnC&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArLYqZo7EjnjzS_wC-Hyq4N&oh=00_AYAUt349fxE9qSjw9UKae3qrPrd-RwocN8lQ3I9e6q5PfQ&oe=66E6DF4D"}, {"file_name": "migrated_image.png", "id": "624490161665773", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12522273_1010934792335946_558211058_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n6hHysVPt3kQ7kNvgEVWxPQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArLYqZo7EjnjzS_wC-Hyq4N&oh=00_AYA504BXOtncFTAoHNVSEC5Lqv3nqj0GvUTcavlX38xv3A&oe=66E6CC17"}, {"file_name": "migrated_image.png", "id": "208207037081575", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331143_576903365826023_1325273270_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pST9KS3akzIQ7kNvgFm7uui&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArLYqZo7EjnjzS_wC-Hyq4N&oh=00_AYClBcAW8paSZ8OEAmGxhz9LzOKMnK4Dc2VM1h-KKSpzfA&oe=66E6BFB8"}, {"file_name": "migrated_image.png", "id": "146241263349814", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162705_1783656541846212_1882704698_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h4SAme0dKvIQ7kNvgGLa8zT&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArLYqZo7EjnjzS_wC-Hyq4N&oh=00_AYAqVvIuahrcbDLtLj2W46AdUd1A32WnBgXTiaLVG-BkHw&oe=66E6C66F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Starfighter Arduxim Demo", "keywords": ["Starfighter", "Arduxim", "gamepad", "shooter", "space"], "long_description": "Strap into the cockpit of your Arduxim and take on enemy starships in this first-person tactical space shooter. Warp to areas of conflict within the system, take hyper gates to other systems to investigate disappearances, take on enormous capital ships and more.\n\nThis demo contains the first two missions of the campaign, tutorial and practice mode. It also includes the online multiplayer.\n\nThe full game contains a twelve mission campaign, unlocked ship and weapon choices in multiplayer, survival/horde mode, more types of enemies, more environments and more weapons.\n\nStarfight