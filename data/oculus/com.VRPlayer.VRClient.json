dn.com&oh=00_AYDw_h7qS2FoROcX-zlqmGT8HrvQfQhElAkLEhMUhHFBNw&oe=677E796C"}, {"file_name": "com.VRPlayer.VRClient-20211222-160822.png", "id": "2424730230992616", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031589_2424730234325949_3431560064721969007_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Slc35aHIB0Q7kNvgHCOhHT&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCg6yOxLrkBdU2UxYzUJWV5L-fkMmA5AiUtH7AsOBOOJA&oe=677E6F27"}, {"file_name": "\uc601\uc0c1 \uc7ac\uc0dd.png", "id": "1931063227076480", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39035367_1931063230409813_2022527892665532672_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u4v_DiH-wO8Q7kNvgEmpWXd&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYAXKw6TVtHFvnXy-rWcVX-okQCd8VgxJtBujblV4Vrncg&oe=677E617A"}, {"file_name": "com.VRPlayer.VRClient-20211222-160847.png", "id": "399698475280264", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974537_399698478613597_1098849269948342817_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=soFko7egRKEQ7kNvgGPqT_0&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCZ6xJoxK9FGhnTJEro6fdZKg6hspPfa6Amkk31Ef_Cqw&oe=677E749B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\ud2b8\ub808\uc77c\ub7ec \ud45c\uc9c0.png", "id": "923945151828818", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38974635_923945158495484_326985208110092383_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RH1HhZhQHzMQ7kNvgFsxFxf&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYCiRBZu5zlCE8qMjpp09XZOYuYi9kkRicnFSnIWxsc6Aw&oe=677E8027"}, "display_name": "Starflex-VR", "keywords": [], "long_description": "- Global NO 1. K-POP s3D VR Contents Platform\n\n- * It is a platform that you can watch K-POP IDOL's performance through realistic 3D\nVR contents\n\n- * You can enjoy a clear VR contents of 4K quality.\n\n- * As a 3D VR music video content, you can enjoy a video that is clearly different from\nthe existing VR contents.\n\n- * You can enjoy various contents of K-POP groups such as performances, music videos,\nmaking films, fan meetings and V-logs etc.\n\n- * You can watch it through streaming service and download content, so you can enjoy\nvideos seamlessly.\n\n- * VR contents of a new K-POP group are uploaded every week.\n\n- * Not only K-POP but also various genres of performance contents will be uploaded.\n\n- * Starflex-VR provides English, Korean and Japanese language setting.\nOther languages also will be serviced in the future\n\n- * If you add Starflex-VR on your \"Wishlist\", you are able to be received updating\nmessage for a new content continuously.", "short_description": "In this platform, you can enjoy various music of K-POP's top idols realistically with s3D VR. Not only\nK-POP but also drama, movie, fan meeting, making film service will be opened. High quality software\nis provided through Multi-Camera system. Please join us. we'll guide you to VR metaverse platform"}]}, "developer_name": null, "developer_privacy_policy_url": "https://admin.starflexvr.com/privacy.txt", "developer_terms_of_service_url": null, "publisher_name": "Starflex-VR", "support_website_url": null, "website_url": "http://www.starflexvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED", "genres": ["MEDIA_PLAYER", "MUSIC_VIDEO", "MUSIC"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1162243841246565"}}]}, "scheduled_offers": {"count": 0, "node