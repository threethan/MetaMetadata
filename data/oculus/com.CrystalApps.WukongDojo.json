82850157_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iL3eesg2pawQ7kNvgF5B5fF&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj1YrBCBM6Zuh2Mt22cL2Cs&oh=00_AYDuqCXcvVuYVckuC67PC2YmSv1BgwU7-azb0B-i-xmdhw&oe=66E03E4D"}, {"file_name": "image_017_5175.png", "id": "881268370052612", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75314851_881268373385945_6070400854680337175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fbu-EYlqRpQQ7kNvgErFYk7&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj1YrBCBM6Zuh2Mt22cL2Cs&oh=00_AYCK6M_P38eSR76Qe5osxGxLCZFGVIp_1JZRirfbT-aQlA&oe=66E02171"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wukong 16 9.png", "id": "898558298318246", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974482_898558301651579_7851134238691417132_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZNiX-uEZwdIQ7kNvgEiAjPJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj1YrBCBM6Zuh2Mt22cL2Cs&oh=00_AYBlJrMeJUkyP_-CVfHi8k3iT4RbZT0KwfAcGhxMN9GzRQ&oe=66E01EA9"}, "display_name": "The Monkey King: Flying Dojo", "keywords": ["fighting", "combat", "fitness", "wukong", "arcade"], "long_description": "Immerse yourself in the mythological world of \"The Monkey King\". As Sun Wukong, you are called upon to conquer the mystical Dragon Valleys. With your enchanted staff in hand, you'll smash through orbs of power and face off against dragon guardians in this arcade VR adventure.\n\nThe heart of the game lies in mastering your weapon, the Monkey King's magical staff, through intuitive VR controls that make every action feel lifelike. The difficulty escalates as you venture deeper into the valleys, demanding greater skill and agility to overcome the obstacles and enemies that await.\n\nPrepare to unleash the power of the Monkey King and reclaim the Dragon Valleys!", "short_description": "Early Access\nEmbark on an epic journey in \"The Monkey King: Dragon Dojo,\" where ancient China comes alive! Arm yourself with the legendary Ruyi Jingu Bang and smash through mystic orbs to conquer the Dragon Valleys. Are you ready to walk in the footsteps of the Monkey King?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://crystalapps.eu/theMonkeyKing-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Crystal Apps", "support_website_url": null, "website_url": "https://crystalapps.eu/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8865404290155296"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_700179968715159_4571594497632574053_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wMn-dWoZv_MQ7kNvgGEWr5K&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj1YrBCBM6Zuh2Mt22cL2Cs&oh=00_AYA6JY74ClgQWtOexrtpgMnZbp7ErHKiK7uLPmoRsGgRyA&oe=66E042EB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Monkey King: Flying Dojo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1700506464, "lastRevision": {"nodes": [{"id": "129464612685561", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4926570100705421", "is_first_party": false, "enables_in_app_ads": false, "is_concept": fal