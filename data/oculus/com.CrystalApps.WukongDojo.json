ly Access\nEmbark on an epic journey in \"The Monkey King: Dragon Dojo,\" where ancient China comes alive! Arm yourself with the legendary Ruyi Jingu Bang and smash through mystic orbs to conquer the Dragon Valleys. Are you ready to walk in the footsteps of the Monkey King?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://crystalapps.eu/theMonkeyKing-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Crystal Apps", "support_website_url": null, "website_url": "https://crystalapps.eu/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4196727970430043"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1580259882762147"}, {"status": "PUBLISHED", "id": "903600734927445"}, {"status": "PUBLISHED", "id": "316745877770919"}]}, "baseline_offer": {"id": "1580259882762147"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1713211440, "status": "PUBLISHED", "id": "1580259882762147"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7679714868724250", "version": "0.6"}, "id": "353002673143682", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4926570100705421", 