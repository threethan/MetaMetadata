D6CD"}, {"file_name": "image_017_5175.png", "id": "881268370052612", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75314851_881268373385945_6070400854680337175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M_7J9hWsu8IQ7kNvgFQfTjI&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9nq2UN770ix_H6jS4KX2Q-j_Jtm38zxnkrsptyqSqFg&oe=6703B9F1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wukong 16 9.png", "id": "898558298318246", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974482_898558301651579_7851134238691417132_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g3_CrbKYP3oQ7kNvgHyyBoR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpkNHJV0sYF8W0VExdcrgvp2j1mWLZU3br0tUf8zAKDQ&oe=6703B729"}, "display_name": "The Monkey King: Flying Dojo", "keywords": ["fighting", "combat", "fitness", "wukong", "arcade"], "long_description": "Immerse yourself in the mythological world of \"The Monkey King\". As Sun Wukong, you are called upon to conquer the mystical Dragon Valleys. With your enchanted staff in hand, you'll smash through orbs of power and face off against dragon guardians in this arcade VR adventure.\n\nThe heart of the game lies in mastering your weapon, the Monkey King's magical staff, through intuitive VR controls that make every action feel lifelike. The difficulty escalates as you venture deeper into the valleys, demanding greater skill and agility to overcome the obstacles and enemies that await.\n\nPrepare to unleash the power of the Monkey King and reclaim the Dragon Valleys!", "short_description": "Early Access\nEmbark on an epic journey in \"The Monkey King: Dragon Dojo,\" where ancient China comes alive! Arm yourself with the legendary Ruyi Jingu Bang and smash through mystic orbs to conquer the Dragon Valleys. Are you ready to walk in the footsteps of the Monkey King?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://crystalapps.eu/theMonkeyKing-privacy-policy/", "developer_terms_of_service_url