371_4734282725995027800_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fh3o06IRKyIQ7kNvgGWX4to&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYBeu_dsToMoYcDQ59u_2iFw-DU0vCSbfz1aNopUirxS8A&oe=6728A0F8"}]}, "id": "808817514561281", "locale": "en_US", "screenshots": [{"file_name": "MS1.png", "id": "525011490131797", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38974777_525011493465130_6735022974333196929_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1qqZ-L5C-nQQ7kNvgFF15jI&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCR4K7iNlY-WVQqIuUkL6z-ZARSPBJKonLx1wyK-aBhEg&oe=67289E04"}, {"file_name": "MS5.png", "id": "1061700618515245", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982687_1061700621848578_5443810701080429460_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h8WRIMYyzQcQ7kNvgERu_70&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBtlAz2OcS7CGbdQVcqDsfKDxVXkQIjP_UqFum6D4SvLw&oe=6728B4DC"}, {"file_name": "MS20.png", "id": "557252586987652", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031315_557252590320985_5765349197883986967_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RQu9VlcYV0YQ7kNvgEKl5ZX&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDDbqIvPJzt5XTs9ycCEMLvOlGC5zM46mN83ppmhhQVhA&oe=6728B750"}, {"file_name": "MS4.png", "id": "887842599605213", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982535_887842606271879_4811391728730299723_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ctdqYOF0KE4Q7kNvgE_WQuI&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCZznb1dbwDPxrlvaPeIAY1UtKObj8JM2cjZCKxSDl6sQ&oe=6728B40F"}, {"file_name": "MS6.png", "id": "1204233344193460", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39001733_1204233347526793_4988591720325282808_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LVbFHACC_-AQ7kNvgEGHU8i&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDehlA7Twp-O1hVYgtt3-dcSV911bPnecN34-ikpzSGeQ&oe=6728ADBD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MeditationSpaceMovie (0-00-07-05).png", "id": "406700252465051", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/75299163_406700255798384_1813904561674331990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5LXSs4_wgKkQ7kNvgE3sifq&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAPTwMFuWTxp9X9cfrQCGOgxtdST-JkGmp9qCYh8RrHfA&oe=6728A4B1"}, "display_name": "Meditation Space", "keywords": ["breathingsessions", "stressrelief", "audioreactivevisualizer", "meditation", "trippy"], "long_description": "This app offers 4 unique modes designed to enhance your mind-body connection:\n\n1. AUDIO-REACTIVITY:\nPut on your headset, play your favorite music, and let the environment come alive with every beat and sound. Watch as the world around you transforms, shifting as you switch environments on the fly. Simultaneously run your custom breathing algorithm alongside an external audio source to create a deeply personal and harmonious journey that balances breath, sound, and space.\n\n2. BREATHING:\nTake control of your experience by designing your own breathing algorithms. Watch the virtual environment morph and respond to your unique patterns of inhalation and exhalation. Tweak the visuals to match the pace and rhythm of your breath, empowering you to craft the perfect meditative state.\n\n3. MEDITATION:\nTurn off all sounds and immerse yourself in a smooth, calming transformation within the virtual space. Enjoy the serene visual flow as you meditate in silence, allowing the environment\u2019s gentle changes to guide you deeper into relaxation.\n\n4. GAMEMODE:\nImagine your stress manifesting as parasitic enemies that seek to drain energy from your inner core. Eliminate these foes using powerful weapons like long swords or plasma emitters. Collect breathing points, build resilience, and defend your core as you transform stress into empowerment.\n\nTurn on the music, breathe, and embrace the future of meditation.", "short_description": "Transcend your physical self as music shapes the space around you. Sync your breath with the visuals, embrace the calm of silent meditation, or dive into game mode for a seamless mind-body connection.\n\n\u2022 Immersive audio-reactive environments that visualize music and breath in real-time.\n \u2022 Customizable breathing algorithms for a deeply personalized meditation experience.\n \u2022 Gamified stress relief mode.\n \u2022 Avant-garde neon old-fashioned wireframe design aesthetics with a futuristic twist."}]}, "developer_name": null, "developer_privacy_policy_url": "https://stillthisname.com/meditationspace_pp.html", "developer_terms_of_service_url": null, "publisher_name": "Oleksii Boreiko", "support_website_url": null, "website_url": "https://stillthisname.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8647572188622857"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/75488381_487683487481371_4734282725995027800_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fh3o06IRKyIQ7kNvgGWX4to&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYAiY9Hc2O9F790UKnXNNCk4tqKfMX_M38mSiB5XjKoHJw&oe=6728A0F8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meditation Space", "platform": "ANDROID_6DO