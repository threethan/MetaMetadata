0a&_nc_ohc=yiGYGehHEu4Q7kNvgFYsAGx&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACC74UsRFBQjlfdlPLh0Iuu&oh=00_AYAf72PBW5D5_eipbW1Del-TmQ-DckzUCB-2kerVwsY72A&oe=66E432AF"}, {"file_name": "Screenshot (235).png", "id": "5566356190129306", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75330719_5566356196795972_943029460902693255_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GoUokwjJJKUQ7kNvgEF4Btl&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACC74UsRFBQjlfdlPLh0Iuu&oh=00_AYDvrDdGP3pNKL71iyUOVTMHQ14kiihTL9f1599GzigXDg&oe=66E43136"}, {"file_name": "Screenshot (234).png", "id": "1498520150627332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031642_1498520157293998_1139275004459972239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qEk63fbd9S0Q7kNvgF_LiCW&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACC74UsRFBQjlfdlPLh0Iuu&oh=00_AYB64UduDl5uw6GjPDbADYpzxZdxreLIUJCDsK21e0isxw&oe=66E40F8C"}, {"file_name": "Screenshot (249).png", "id": "1341177636710569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974658_1341177640043902_5594173074339684542_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jRCv7AceefQQ7kNvgHQdYFf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACC74UsRFBQjlfdlPLh0Iuu&oh=00_AYBpj468NoZ2gCXaCYDwsI3q7IKunUj8lP6jjdUVxCp--g&oe=66E4328B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1808371306198766", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_1808371309532099_2028891221452154036_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DaU_nbPYI-EQ7kNvgGO6pvo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACC74UsRFBQjlfdlPLh0Iuu&oh=00_AYDTGubaKyo-gZYB4BCgN4lCQmXO8_QP3sN94lBQXE0hhg&oe=66E40EAC"}, "display_name": "Eyeliens & Heroes", "keywords": [], "long_description": "In an unspecified future, the cute and bored aliens decide to enjoy their time in the most ancient game ever: the fight!\nThanks to their advanced technologies they not only create an innovative arena but choose, through a careful selection, characters who have distinguished themselves for their peculiar characteristics throughout the history of the Worlds.\n\nThis is how our extraterrestrials, thanks to capsules that allow the opening of space-time portals, captured our future fighters just one step away from the apex of their life.\n\nThe unsuspecting characters will thus find themselves facing each other on moving platforms, using different weapons and objects. Anything could be useful!\nThe platforms, full of equipment, move closer to each other, until they touch. At that point each weapon is no longer useful, you can only count on the strength of your fists and your agility.\n\nThanks to the experience, the fighters will also be able to unlock different skills, which when needed could turn the tide of the duel.\n\nAre you ready to fight alongside our heroes?", "short_description": "In an unspecified future, the cute and bored aliens decide to enjoy their time in the most ancient game ever: the fight!\nThanks to their advanced technologies they not only create an innovative arena but choose, through a careful selection, characters who have distinguished themselves for their peculiar characteristics throughout the history of the Worlds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.eyeliensheroes.com/documents/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Floaty S.r.l.", "support_website_url": null, "website_url": "https://www.eyeliensheroes.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_