&oh=00_AYCuq9q_BHCjxDAgGDI9Eb28_PVv4qLwtbC3FHGdBJb4dA&oe=6718EEAF"}, {"file_name": "Screenshot (235).png", "id": "5566356190129306", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75330719_5566356196795972_943029460902693255_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KTXCWyo5uSYQ7kNvgGEFwFl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4MsVdIgP_D9xu7iqrbhBRBsiShDib5hzQ8r-jydt3TQ&oe=6718ED36"}, {"file_name": "Screenshot (234).png", "id": "1498520150627332", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031642_1498520157293998_1139275004459972239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q9pONhjhe4wQ7kNvgHMxt9m&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMCR4XTw8FPnrzTNe2Qo5_ZD4_liYT0ys9HmDHY5YBTQ&oe=6718CB8C"}, {"file_name": "Screenshot (249).png", "id": "1341177636710569", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974658_1341177640043902_5594173074339684542_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=428x6jygsn8Q7kNvgGdhz4e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrwQFzzojJrhb8wdriNeLW4hIn59Pgziu5Pgc2oFOLtA&oe=6718EE8B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1808371306198766", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569479_1808371309532099_2028891221452154036_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=33ZnATKsdfsQ7kNvgELqYCO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoBHLKk9-QuMBx4F8LC5HUa3YLiklnBXWviCLdiFVUxA&oe=6718CAAC"}, "display_name": "Eyeliens & Heroes", "keywords": [], "long_description": "In an unspecified future, the cute and bored aliens decide to enjoy their time in the most ancient game ever: the fight!\nThanks to their advanced technologies they not only create an innovative arena but choose, through a careful selection, characters who have distinguished themselves for their peculiar characteristics throughout the history of the Worlds.\n\nThis is how our extraterrestrials, thanks to capsules that allow the opening of space-time portals, captured our future fighters just one step away from the apex of their life.\n\nThe unsuspecting characters will thus find themselves facing each other on moving platforms, using different weapons and objects. Anything could be useful!\nThe platforms, full of equipment, move closer to each other, until they touch. At that point each weapon is no longer useful, you can only count on the strength of your fists and your agility.\n\nThanks to the experience, the fighters will also be able to unlock different skills, which when needed could turn the tide of the duel.\n\nAre you ready to fight alongside our heroes?", "short_description": "In an unspecified future, the cute and bored aliens decide to enjoy their time in the most ancient game ever: the fight!\nThanks to their advanced technologies they not only create an innovative arena but choose, through a careful selection, characters who have distinguished themselves for their peculiar characteristics throughout the history of the Worlds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.eyeliensheroes.com/documents/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Floaty S.r.l.", "support_website_url": null, "website_url": "https://www.eyeliensheroes.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "suppo