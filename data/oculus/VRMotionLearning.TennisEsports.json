t=scontent-iad3-1.oculuscdn.com&oh=00_AYAJS4dFIX2G_RBKKJzFiy7-kOcy-MPuoHJvbrPGpaz1dg&oe=6735D66C"}, {"file_name": "Screenshot_04_2560x1440.png", "id": "1036825203629132", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035375_1036825206962465_949064599507623688_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ukJwf6Tq1HIQ7kNvgHTGnRN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6Yt3isfL7slluxc1Skn4IragmnEI4_AJh5evYZKlgwQ&oe=6735FAB3"}, {"file_name": "Screenshot_06_2560x1440.png", "id": "1101030910492213", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974448_1101030917158879_5334321293078676495_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k7yTIeMo3-gQ7kNvgHtqmfk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRXnmLa8I8p0j5hd5tnifOX9xP4mY1IT3KmzjJlCqu0A&oe=6735C772"}, {"file_name": "Screenshot_03_2560x1440.png", "id": "1351735028667744", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031372_1351735032001077_7246146035196325895_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVuJDA8C5rIQ7kNvgGDm5Wx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBEFXp-Z6UH_0E0Wo9vCa5VNJRsTQk-93GlApTSaekJpA&oe=6735D3D4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage_2560x1440.png", "id": "1477754659328730", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_1477754662662063_6596429464770896767_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NyahH59hXZ0Q7kNvgFfack0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-ALLrPJ9xKcosw9f8eZJ6kin0hsN2E_0nUhnw-y5zzw&oe=6735DB62"}, "display_name": "Tennis Esports", "keywords": [], "long_description": "Tennis Esports simulates and feels like real tennis for both tennis players, gamers and fans to enjoy Tennis in the VR Metaverse.\n\nJoin our global community and leaderboard. Play live matches, arcade target games in any stadium you can imagine or even play against yourself with MirrorPlay\u00a9.\n\nPractice your virtual and physical game from beginner to advanced tutorials, real time technique analysis or receive coaching in VR.\n\nEnhance your experience and use the Tennis Racquet VR\u00a9, a 3D printed racquet handle that is weighted like a tennis racquet and become the best in the world in the Tennis Esports Pro Tour!\n\nTennis Esports gets everybody active and playing tennis from virtually anywhere!\nSimply download the app to join the Tennis Metaverse today!\n\nWant to chat with others? Got an idea for a new court? Tell the developers directly by going to our Discord server:\n https://discord.gg/nM7ecSjf", "short_description": "Tennis Esports simulates and feels like real tennis for both tennis players, gamers and fans to enjoy Tennis in the VR Metaverse.\n\nJoin our global community and play live matches, arcade target games in any stadium you can imagine or even play against yourself with MirrorPlay\u00a9.\n\nPractice your virtual and physical game from beginner to advanced tutorials, or climb the rankings on the global leaderboards! \n\nJoin the Tennis Metaverse today with Tennis Esports!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tennis-esports.com/privacy-policy", "developer_terms_of_service_url": "https://tennis-esports.com/legal", "publisher_name": "VR Motion Learning", "support_website_url": "https://www.tennis-esports.com/contacts", "website_url": "https://tennis-esports.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SPORTS", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TO