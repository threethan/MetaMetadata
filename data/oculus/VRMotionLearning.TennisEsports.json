_2560x1440.png", "id": "1101030910492213", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974448_1101030917158879_5334321293078676495_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OZSYw7GmVfwQ7kNvgG3gCae&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCPMX6PIfWk8A7AaWdXqWLrosLH4br2djqyq1FeLYRFg&oe=673C5EF2"}, {"file_name": "Screenshot_03_2560x1440.png", "id": "1351735028667744", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031372_1351735032001077_7246146035196325895_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7A-GJn-bPr0Q7kNvgG-_6EQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAbhTmF3jpofi9NDpc2sG5x2qucC20J6lALMMu_N-8Jag&oe=673C6B54"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage_2560x1440.png", "id": "1477754659328730", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_1477754662662063_6596429464770896767_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9brB6knHhR0Q7kNvgFbezqc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQ4_7V6azjxpMwDXqtmzoaqIGejTXnuRTienvs6dk4jQ&oe=673C72E2"}, "display_name": "Tennis Esports", "keywords": [], "long_description": "Tennis Esports simulates and feels like real tennis for both tennis players, gamers and fans to enjoy Tennis in the VR Metaverse.\n\nJoin our global community and leaderboard. Play live matches, arcade target games in any stadium you can imagine or even play against yourself with MirrorPlay\u00a9.\n\nPractice your virtual and physical game from beginner to advanced tutorials, real time technique analysis or receive coaching in VR.\n\nEnhance your experience and use the Tennis Racquet VR\u00a9, a 3D printed racquet handle that is weighted like a tennis racquet and become the best in the world in the Tennis Esports Pro Tour!\n\nTennis Esports gets everybody active and playing tennis from virtually anywhere!\nSimply download the app to join the Tennis Metaverse today!\n\nWant to chat with others? Got an idea for a new court? Tell the developers directly by going to our Discord server:\n https://discord.gg/nM7ecSjf", "short_description": "Tennis Esports simulates and feels like real tennis for both tennis players, gamers and fans to enjoy Tennis in the VR Metaverse.\n\nJoin our global community and play live matches, arcade target games in any stadium you can imagine or even play against yourself with MirrorPlay\u00a9.\n\nPractice your virtual and physical game from beginner to advanced tutorials, or climb the rankings on the global leaderboards! \n\nJoin the Tennis Metaverse today with Tennis Esports!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tennis-esports.com/privacy-policy", "developer_terms_of_service_url": "https://tennis-esports.com/legal", "publisher_name": "VR Motion Learning", "support_website_url": "https://www.tennis-esports.com/contacts", "website_url": "https://tennis-esports.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SPORTS", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "549900073412151"}}]}, "scheduled_offers": {"count": 18, "nodes": [{"status": "PUBLISHED", "id": "521690484000837"}, {"status": "CANCELLED", "id": "930659678822761"}, {"status": "PUBLISHED", "id": "834287584824208"}, {"status": "PUBLISHED", "id": "902688718132529"}, {"status": "PUBLISHED", "id": "359245393282211"}, {"statu