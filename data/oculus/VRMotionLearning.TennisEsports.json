Binary", "id": "8358314757629456"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731589503, "id": "8363411033786495", "version": "2024.11.1a_411141340_null", "version_code": 411141340, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4872542182873415", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8358314757629456"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731587636, "id": "8363280603799538", "version": "2024.11.0a_411141309_FIR-1940", "version_code": 411141309, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4872542182873415", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8358314757629456"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "553256016211576"}]}, "change_log": "Dear Friends of Tennis,\n\nGet ready for our biggest update yet, setting a new standard in virtual tennis with cutting-edge gameplay mechanics and breathtaking visuals! \nThis major update brings a wealth of new content, improvements, and bug fixes. Here\u2019s a summary of the most exciting changes:\n\n### General\n- Tennis Esports is now free to download, packed with a variety of new features.\n- Unlock the full experience with the **Tennis Esports Premium Addon**, **Techzone BH**, and **Techzone FH**.\n- Our loyal existing users will receive the Premium Addon automatically.\n\n### New Features\n\n1. Social Clubs (SC): A place to gather, chat, and have fun with up to 10 players.\n   - Socialize in a relaxed environment\n   - Challenge other players to matches\n   - Enjoy mini-games like **BreakEmAll** and **The Tennis Wall**\n   - Casual play on the SC court with up to 4 players\n   - Join as a spectator if the SC is full or for a smoother experience on slower connections\n\n2. Avatar Customizer\n   - Create a personalized avatar in your profile\n   - Customize with up to 100 outfit options\n   - Choose from a wide selection of ready-to-use outfits\n   - Select your preferred racket\n\n3. Shop\n   - Purchase all add-ons directly in the game\n   - Buy coins to make your avatar truly unique\n\n4. Quick Login\n   - Access your accounts with one-click login if you have multiple TE accounts on your device\n   - Easily recover a lost account by requesting a key from our support team\n\n### Improvements\n- Significant performance enhancements throughout the app for a smoother experience\n\nEnjoy this exciting new update and elevate your virtual tennis experience!\n\nYour Tennis Esports Team", "created_date": 1731509502, "id": "8358314757629456", "version": "2024.11.0", "version_code": 411131531, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4872542182873415", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8358314757629456"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731505754, "id": "8358066517654280", "version": "2024.11.0"