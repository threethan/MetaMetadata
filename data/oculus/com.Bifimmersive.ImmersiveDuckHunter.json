474_1936477727543198878_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hgOESTI1Rs0Q7kNvgFSy1Lz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtnJSCuiAoFlGvk7GL4WMVf1o15jYvxZce92DAkGkuOw&oe=6755776D"}, {"file_name": "Screenshot3.png", "id": "924614879081235", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031620_924614882414568_16106495592767255_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z31akHnxesMQ7kNvgE3718j&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAA5mD5ILvL1we7D6c9Ocz6dyR4INsy6ksiHfwWdr0n6w&oe=675573F5"}, {"file_name": "Screenshot4.png", "id": "905589457499249", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974780_905589460832582_6130027779617320049_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ulgKUGZal0Q7kNvgFs3niX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKImzZLsmcSdfDHCrJ9M8bxJOtfnsb06Nqz7qRQeKh2Q&oe=67559C5D"}, {"file_name": "Screenshot5.png", "id": "249968624781202", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_249968628114535_9072172207420643207_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9s2GyaAxqx8Q7kNvgGmP2q1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVSakzjrIfekcP8TLJxwjAtrfunJy7-weH1AcS9AAtfA&oe=67557068"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage.png", "id": "741490427881556", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982705_741490431214889_2929165475552190295_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F81VtbO0o5YQ7kNvgE7i8e7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4c4lxgQE1pdZ1iM0qklsC2LsfecDv6EuF58C59xqrUA&oe=675591C2"}, "display_name": "Virtual Duck Hunt", "keywords": [], "long_description": "Immerse Yourself in Nostalgia with Virtual Duck Hunt!\n\nRelive the retro excitement of the legendary 1984 Duck Hunt in an entirely new way through virtual reality. This version of the classic transports you into an immersive world where ducks soar through the sky with breathtaking vitality.\n\nKey Features:\n\n\ud83e\udd86 Virtual Hunting: Armed with your rifle, aim precisely and shoot at ducks flying across a stunning landscape, offering an unparalleled experience.\n\n\ud83c\udf1f Modern Graphics: High-resolution graphics plunge you into an updated version of the classic game while preserving the retro magic that captivated players for decades.\n\n\ud83d\udd79\ufe0f Remastered Retro Controls: Dive into nostalgia with the iconic classic console rifle remastered in virtual reality. Use virtual reality controllers for a natural and responsive gaming experience that faithfully reproduces the sensation of holding the authentic accessory from that era in your hands.\n\nNote: No ducks were harmed in the making of this game! In fact, they're thrilled to be back and are playing along. Rest assured, these ducks are just pretending\u2014they don't actually meet their feathery end in the game. It's all in good fun and nostalgia!\n\nHow to Play:\n\nPut on your VR headset, grab your rifle, and get ready to dive into a duck hunting adventure that redefines retro fun. The challenge is set, the hunt is on \u2013 are you ready to become the master of virtual hunting?", "short_description": "Immerse Yourself in Nostalgia with Virtual Duck Hunt!\n\nRelive the retro excitement of the legendary 1984 Duck Hunt in an entirely new way through virtual reality. "}]}, "developer_name": "Fr\u00e9d\u00e9ric Peeters", "developer_privacy_policy_url": "https://sites.google.com/view/bifimmersive/accueil/duck-hunt-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bifimmersive Games", "support_website_url": null, "website_url": "https://sites.google.com/view/bifimmersive", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6258640284239609"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "7107521912672361"}]}, "baseline_offer": {"id": "7107521912672361"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1705509700, "status": "PUBLISHED", "id": "7107521912672361"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7610007635769527", "version": "0.3"}, "id": "895711495291491", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6258640254239612", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7610007635769527"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "895711495291491"}]}, "change_log": "\ufffd Big Update for Virtual Duck Hunt! \ufffd\n\nHunters, get your rifles ready! Here are the new features:\n\n\ufffd Meta Global Leaderboard: Your score is now ranked globally! Compete with your friends and climb to the top of the leaderboard.\n\n\ufffd Anti-cheat: Be careful! Getting too close to the ducks is no longer an option! Keep your distance; a good hunter always respects their prey! Do so at your own risk!\n\n\ufffd Rebalanced Game Speed: With faster bullets and slightly slower ducks, you\u2019ll finally be able to reach levels never seen before!\n\n\ufffd The Golden Duck: Smarter than ever, this precious duck will stay further away from players, making the hunt much more challenging. Catch it if you can!\n\n\ufffd Don\u2019t Shoot the Dog: Uh-oh, bad news for those who aim at their loyal companion! The punishment will be swift!\n\n\ufffd Epic Soundtrack: Over 160 songs to accompany your sessions, from rock to classical to electro. It\u2019s time to hunt with style!\n\nHappy hunting, and may the best shooter win! \ufffd\ufffd", "created_date": 1727734217, "id": "7610007635769527", "version": "0.3", "version_code": 32, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6258640254239612", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7610007635769527"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "895711495291491"}]}, "change_log": "Improved sound volume management and added new songs", "created_date": 1724964794, "id": "7368437603259866", "version": "0.3", "version_code": 31, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6258640254239612", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7610007635769527"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "895711495291491"}]}, "change_log": "\ufffd New Update Available! \ufffd\n\nDear Hunters,\n\nI am thrilled to announce the release of the latest update for Virtual Duck Hunt! This update brings a series of enhancements and innovations to make your gaming experience even more immersive and entertaining!\n\n\ufffd New Golden Duck: Get ready to encounter the Golden Duck! Rare but lucrative, this duck is surely worth a lot of points. Keep your eyes peeled and be ready to react! Don't miss out on it!\n\n\ufffd AI-generated Music: Immerse yourself in a unique sonic experience with our brand-new AI-generated music feature! Dozens of songs in all styles, created by an AI, will accompany you throughout your duck hunting adventure. Whether you prefer rock, country, rap, metal, or classical, you'll find the perfect music to set the mood for your journey. It's a stunning technological feat that will add an entirely new dimension to your gaming experience.\n\n\ufffd Enhanced Scoring System: For a fairer competition, we have improved our scoring system to avoid multiple entries for the same player. Now, you can also more easily find your best score displayed on the sheets hanging on the wall behind you. It will be highlighted.\n\n\ufffd New Restart Option: If the hunt doesn't go as planned, you now have the option to restart the game! Turn around and shoot the floating game cartridge for a second chance to become the top hunter.\n\n\ufffd Increased Bullet Speed: To give you a boost, we have slightly increased the speed of the bullet. It's our little secret to help you refine your accuracy and achieve even higher scores. Don't tell the ducks!\n\nUpdate your game now to discover all these new features! I hope these additions will provide you with an even more exciting and rewarding gaming experience.\n\nHappy hunting!\n\nBifimmersive", "created_date": 1714081317, "id": "6716181891818777", "version": "0.3", "version_code": 30, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6258640254239612", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7610007635769527"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "895711495291491"}]}, "change_log": "\ufffd The Left-Handed Update \ufffd\ufffd\n\nCalling all lefties and duck hunters! We've just rolled out a brand new feature allowing you to to switch your gun hand with ease. No more sticking to the right, it's time for lefties to shine! \ufffd Plus, we added a bonus when our trusty pooch fetches a duck \u2013 extra points for teamwork! \ufffd Get your trigger fingers ready, and let\u2019s create some quack-tastic memories together !", "created_date": 1709245212, "id": "6492691827501119", "version": "0.3", "version_code": 29, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6258640254239612", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7610007635769527"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "895711495291491"}]}, "change_log": "We have reached one thousand nostalgics hunters !!! \nTo celebrate that:\n- Introduction of the bonus level (Surprise!)\n- Bonus points if you don't use all your munitions\n- A shot without ammunition will make the mocking ducks leave immediately (which means you no longer have to wait for the end of the timer)\n-The wall leaderboard can now display 100 players. Take advantage of the new features to add your name to the list !", "created_date": 1708035206, "id": "6436757416427894", "version": "0.3", "version_code": 28, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}