ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKImzZLsmcSdfDHCrJ9M8bxJOtfnsb06Nqz7qRQeKh2Q&oe=67559C5D"}, {"file_name": "Screenshot5.png", "id": "249968624781202", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_249968628114535_9072172207420643207_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9s2GyaAxqx8Q7kNvgGmP2q1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVSakzjrIfekcP8TLJxwjAtrfunJy7-weH1AcS9AAtfA&oe=67557068"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage.png", "id": "741490427881556", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982705_741490431214889_2929165475552190295_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F81VtbO0o5YQ7kNvgE7i8e7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4c4lxgQE1pdZ1iM0qklsC2LsfecDv6EuF58C59xqrUA&oe=675591C2"}, "display_name": "Virtual Duck Hunt", "keywords": [], "long_description": "Immerse Yourself in Nostalgia with Virtual Duck Hunt!\n\nRelive the retro excitement of the legendary 1984 Duck Hunt in an entirely new way through virtual reality. This version of the classic transports you into an immersive world where ducks soar through the sky with breathtaking vitality.\n\nKey Features:\n\n\ud83e\udd86 Virtual Hunting: Armed with your rifle, aim precisely and shoot at ducks flying across a stunning landscape, offering an unparalleled experience.\n\n\ud83c\udf1f Modern Graphics: High-resolution graphics plunge you into an updated version of the classic game while preserving the retro magic that captivated players for decades.\n\n\ud83d\udd79\ufe0f Remastered Retro Controls: Dive into nostalgia with the iconic classic console rifle remastered in virtual reality. Use virtual reality controllers for a natural and responsive gaming experience that faithfully reproduces the sensation of holding the authentic accessory from that era in your hands.\n\nNote: No ducks were harmed in the making of this game! In fact, they're thrilled to be back and are playing along. Rest assured, these ducks are just pretending\u2014they don't actually meet their feathery end in the game. It's all in good fun and nostalgia!\n\nHow to Play:\n\nPut on your VR headset, grab your rifle, and get ready to dive into a duck hunting adventure that redefines retro fun. The challenge is set, the hunt is on \u2013 are you ready to become the master of virtual hunting?", "short_description": "Immerse Yourself in Nostalgia with Virtual Duck Hunt!\n\nRelive the retro excitement of the legendary 1984 Duck Hunt in an entirely new way through virtual reality. "}]}, "developer_name": "Fr\u00e9d\u00e9ric Peeters", "developer_privacy_policy_url": "https://sites.google.com/view/bifimmersive/accueil/duck-hunt-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bifimmersive Games", "support_website_url": null, "website_url": "https://sites.google.com/view/bifimmersive", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6258640284239609"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031643_1414590475932225_2001525446229688257_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rONqLYDRglkQ7kNvgFMUC7S&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIiqB8PWiKjAP7LQ5At5TQB_BugNKvuqcagn-aBKPJoQ&oe=67556EF3"}, "is_