cription": "Turn your fantasies into reality! In King Of Hell, you can cast magics, build towers, summon allies, and\nmuch more!"}]}, "developer_name": "Mimic.Land", "developer_privacy_policy_url": "https://mimic.land/king-of-hell-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mimic.Land", "support_website_url": null, "website_url": "https://mimic.land/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "HORROR"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2081682428648541"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5238790419545744", "version": "0.1.3.3"}, "id": "3039262642961901", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3973848876039911", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5238790419545744"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3039262642961901"}]}, "change_log": "- Basic Tutorial added with placeholder videos, but useful\n- Level 2 Updat