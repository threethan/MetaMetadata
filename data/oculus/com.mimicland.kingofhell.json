oe=66FD3EA6"}, {"file_name": "01.png", "id": "187757353264667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035305_187757359931333_8961427923975664833_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fawrwIbO3BYQ7kNvgEXxzgC&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9kH2y6ilLWlcLmEqdMMD15btEsZt17FOBmX9I3wAryw&oe=66FD2F7C"}, {"file_name": "03.png", "id": "513502790085658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974802_513502793418991_1839170041872327793_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j7-LHLsJqZgQ7kNvgEWi-z6&_nc_ht=scontent.oculuscdn.com&oh=00_AYANmdk4YaZRo1izYlLWd-z7WU0cT9hzouHrln1phCa0DQ&oe=66FD46DB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "490046042212849", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75495672_490046045546182_8844279482184451647_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xtVTOQ7_UIcQ7kNvgEuLWRy&_nc_ht=scontent.oculuscdn.com&oh=00_AYABkDxtjEsmXe7dUo8RxGK6S91JEv7xl0vmksvG110-rQ&oe=66FD1D4E"}, "display_name": "King Of Hell - Prototype Version", "keywords": [], "long_description": "This is a prototype game, this price is a symbolic value to help developers upgrade the game, add more levels, and help us complete this game. Thanks for believing us! (We recommend using hand tracking)\n\nKing of Hell is a first-person tower defense game. In this game, you can help your towers to protect your door to block enemies invade your captured floor and HQ where you have your plans to dominate the hell.\n\nHow many floors you dominate, more close you going to be a King Of Hell\n\nYou need to use hand movements to cast magic, your abilities and memory define casting speed and your success. This is not easy! But I believe in your abilities!", "short_description": "Turn your fantasies into reality! In King Of Hell, you can cast magics, build towers, summon allies, and\nmuch more!"}]}, "developer_name": "Mimic.Land", "developer_privacy_policy_url": "https://mimic.lan