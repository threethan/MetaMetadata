243_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HM3LM31SoIYQ7kNvgGOEwX9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhnyPFOcPIu9SDzRLRltxFR1E_XrseATFV1F7ZcKX5og&oe=67387A27"}, {"file_name": "hero_cover_3000_900.png", "id": "2795029047378188", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001675_2795029054044854_6201403723789628443_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dgsKdcwUmV8Q7kNvgHoIS8A&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJnYXmpk-rX2oklq-CEMTRajNrtQQmu3eoRdP4mLUMKw&oe=67387A63"}, {"file_name": "logo_transparent_redh_6504x1440.png", "id": "282589839950905", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572755_282589843284238_4646065632454573569_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QpT11RKGIzgQ7kNvgFUw3bd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_FFOVmT4hrpAt1dWq4S3UT-DnzgxFY1-2ucxR-KtXpQ&oe=67388808"}, {"file_name": "cover_square_1440_1440.png", "id": "234927958346755", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982489_234927961680088_7612509194532183140_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7eHfDaK0CV0Q7kNvgFRobk1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvZS67Ry7ZemrvKUF8PikQYUeethjxsv861vB7f1Bjzw&oe=67388B99"}, {"file_name": "client_icon.png", "id": "211356347350831", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031567_211356360684163_6127640084187903517_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ukD2KiT_VJYQ7kNvgH_PGCT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAegr-r79TQSs0oG84_Khw0JRolwYvVNU2Z7U1ga4lcbQ&oe=67389841"}]}, "id": "918360652309217", "locale": "de_DE", "screenshots": [{"file_name": "screenshot_corridor_02_2560.png", "id": "460492951762387", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982602_460492955095720_5328579535663617985_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sQLyjRrF27cQ7kNvgHcScW4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsZk_9wTzMfjk6JP0vh2TeEfYT2s2Sjd8qh6F7vVYxnA&oe=67386C3D"}, {"file_name": "screenshot_drive_2560.png", "id": "2063938133771622", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982701_2063938137104955_3133826701772656538_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QVEzSdri1J4Q7kNvgFAsgK2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCI9zmUP07EpWyuB7YIGbB0H3qjdIRqNctNIxdc77aUYw&oe=67386BB1"}, {"file_name": "screenshot_bridge_2560.png", "id": "3826569787390016", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982489_3826569797390015_4877790269651091056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ekb1Eree1vcQ7kNvgEaiQmE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSHpqWUIuO2Wj4dZWG1rdaYmpH4eetokYJWS5qu-vkwQ&oe=67389A5E"}, {"file_name": "screenshot_inventory_02_2560.png", "id": "709150336432782", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003263_709150339766115_4380515829977501858_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Tuhq0F392IQ7kNvgFfTuX8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD1kd5YNMicK1rbwqAH9U2E_vHrh4f4gTsToSGop8OVWA&oe=673894CB"}, {"file_name": "screenshot_terminal_2560.png", "id": "5063904923682746", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031451_5063904930349412_8881434085334990049_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3CcxhOdo51IQ7kNvgHuDe8q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxLIpuIeOS_ejo9tH5XO8XPPLy3tj_BN6HU-2mqZGLUw&oe=67388CAC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_final_cover_2560x1440.png", "id": "526835674950172", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974907_526835678283505_2690197330565865513_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SNuyuegRX4gQ7kNvgHVk4FI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBveDwCEPQk2RufQJMDktvKkGrlVLioVU5lcTR40PrCBw&oe=673892CA"}, "display_name": "Cosmodread", "keywords": ["Weltraum", "survival", "horror", "roguelike"], "long_description": "Ein VR Survival Horror Roguelike.\n\nDu bist gefangen in einem zerst\u00f6rten Raumschiff, in dem schreckliche Gesch\u00f6pfe ihr Unwesen treiben. Erkunde, \u00fcberlebe und finde den Weg zur\u00fcck zur Erde. Cosmodread begeistert mit dichter, spannender und immersiver Atmosph\u00e4re, die dich die Welt au\u00dferhalb deines Headsets vergessen lassen wird.\n\nERKUNDE: \nSuche Ressourcen und finde den Weg nach Hause. Bei jedem Versuch spielst du in einem neuen, prozedural generierten Level. Alle R\u00e4ume, G\u00e4nge, Gegenst\u00e4nde und Gefahren sind zuf\u00e4llig angeordnet, was zu verschiedenen emergenten Situationen f\u00fchren kann.\n\n\u00dcBERLEBE: \n\u00d6ffne T\u00fcren, Schubladen und Schr\u00e4nke und durchsuche sie nach Wertsachen. Sammle grundlegende Ressourcen und stelle Waffen und Ausr\u00fcstung her, um dich gegen Feinde und andere Gefahren zur Wehr setzen zu k\u00f6nnen.\n\nK\u00c4MPFE: \nSuche Schutz hinter Deckung und schie\u00dfe mit deiner Armbrust auf Feinde - oder locke sie in eine Falle. Aber denk dran: Munition ist knapp!", "short_description": "Cosmodread ist ein VR Survival Horror Roguelike, in dem du aus einem zerst\u00f6rten Raumschiff voller Monster fliehen musst. Allein in einer feindlichen Welt musst du erkunden, \u00fcberleben und den Weg zur\u00fcck zur Erde finden."}, {"images": {"nodes": [{"file_name": "cover_portrait_1008_1440.png", "id": "2581435788815403", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974448_2581435792148736_1460695546949600188_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IfeD75YeE50Q7kNvgFuSTPX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHht2ktQOrW7jHk4x-k5ozSIw6vHXXEsprrVGuaF-cgw&oe=6738850D"}, {"file_name": "client_icon.png", "id": "1094488024311463", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982448_1094488027644796_8130263775351557426_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3sxS9wb0ClIQ7kNvgFVLiIu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjg--hkjY5Nvmim09u4kfs5ZD-BPPPLmJUNV53au2QUQ&oe=67386BA5"}, {"file_name": "cover_square_1440_1440.png", "id": "820663705192180", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036610_820663708525513_7319497454622777871_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LCMgycY1jWMQ7kNvgGdIB1c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAoNyLS-IdfCkiXDfDkqojkD0BPAOu9DeeCqvSp0BHVPQ&oe=6738923B"}, {"file_name": "mini_landscape_1080_360.png", "id": "781622489375762", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982600_781622492709095_8836844215015734308_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BkqO3IwTXT4Q7kNvgEfPfFx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASjolKqAXr7A1S9YggLf6vyOD4pGsceEb84lgYxCZENg&oe=67389C1E"}, {"file_name": "logo_transparent_redh_6504x1440.png", "id": "186642176568617", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035347_186642183235283_9088169405343944123_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KY8W7OAO_yQQ7kNvgGKMTZC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFPzEIMcUV9vYy8S02HOjMoVjdT0WUrnkiSjMMZQCd5A&oe=6738770F"}, {"file_name": "cover_landscape_2560_1440.png", "id": "181742443718939", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001679_181742447052272_6745259859016128513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-dKFmoKA1X8Q7kNvgH7Xaut&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBguyckD1EX2z5yj9lS6d_W3SlPx1i7MMywfRb92F4oUw&oe=67386D97"}, {"file_name": "hero_cover_3000_900.png", "id": "138484238050393", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001723_138484241383726_15761525726097730_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6CuLC2K1qoUQ7kNvgH2ALRH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpVK_stbhGn0OT4DjF0hiyLnq6DPmx_6kTe8kmMaua9g&oe=67389CCC"}]}, "id": "757899468149439", "locale": "fr_FR", "screenshots": [{"file_name": "screenshot_corridor_02_2560.png", "id": "280486876931183", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003274_280486880264516_2249786041795145295_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rxm8Jdcnw3EQ7kNvgENNLW5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAatNop5eO-90jNrsfy9m_Co09vuaXSYOwn_L_8p81CYg&oe=67387792"}, {"file_name": "screenshot_drive_2560.png", "id": "176129947350849", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035441_176129950684182_6476022098761049156_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zzspNvcl-8MQ7kNvgGZVnQj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXi1Yjq5iGgeuH06J6M4HUyT5f_uYHF_0pAXvNZqoWpA&oe=67387468"}, {"file_name": "screenshot_bridge_2560.png", "id": "430028158213133", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86636482_430028164879799_7274905112938442994_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VjPYeGFbP-cQ7kNvgHg96K9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB2awE2NGLsjEoeE1rk5ZrNZvFDZDv210bPjQXZNHbvLQ&oe=67389649"}, {"file_name": "screenshot_inventory_02_2560.png", "id": "133441401982767", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003263_133441405316100_5089056926788738384_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CEuopd_oBbMQ7kNvgGfob3S&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3d32W3AsjjMgVdacvzxHDoc9NOrjYoCCe7B-TChXiHg&oe=67389880"}, {"file_name": "screenshot_terminal_2560.png", "id": "2883157741929216", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003228_2883157745262549_5240486857056400895_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AClEsTIv-oIQ7kNvgGWGHdH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFKX7hfeluUO8u4c0th7Dl1nv5A6t2qNpZI2ZibmG7KA&oe=67387AA7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_final_cover_2560x1440.png", "id": "339519677312615", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982471_339519680645948_292282871969641868_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kzq55xgv2pcQ7kNvgHO9Ugb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNLJfRZ1FRH_PNFwiBXEs_fBa4u-hgp48V9sMEFGie6w&oe=67386B24"}, "display_name": "Cosmodread", "keywords": ["espace", "horreur", "survie", "roguelike", "dungeon"], "long_description": "Un roguelike d'horreur et de survie en VR\n\nPris au pi\u00e8ge dans un vaisseau spatial \u00e0 la d\u00e9rive et plein d'horreurs, explorez et essayez de survivre jusqu'\u00e0 ce que vous trouviez le chemin vers la s\u00e9curit\u00e9 de la Terre. Cosmodread vous enveloppe dans une atmosph\u00e8re si vivante, tendue et immersive qu'elle vous fera oublier le monde r\u00e9el.\n\nEXPLOREZ\nRecherchez des ressources et retrouvez le chemin \u00e0 votre maison. Dans chaque jeu, vous jouerez dans de nouveaux sc\u00e9narios g\u00e9n\u00e9r\u00e9s de mani\u00e8re proc\u00e9durale dans lesquels les pi\u00e8ces, les couloirs, les objets et les obstacles changeront de position au hasard, et vous ferez l'exp\u00e9rience de diff\u00e9rentes situations \u00e9mergentes. Vous ne saurez jamais exactement ce qui vous attend derri\u00e8re la porte voisine.\n\nSURVIVEZ\nInteragissez avec l'environnement avec vos propres mains. Ouvrez les portes, les tiroirs et les armoires et fouillez dans leur contenu. Collectez des ressources et cr\u00e9ez des armes et des outils pour faire face aux ennemis et aux obstacles.", "short_description": "Cosmodread est un roguelike d'horreur et de survie en r\u00e9alit\u00e9 virtuelle dans lequel vous devrez vous \u00e9chapper d'un vaisseau spatial \u00e0 la d\u00e9rive et plein de cauchemars. Perdu dans un univers hostile, explorez et tentez de survivre jusqu'\u00e0 ce que vous trouviez le chemin vers la s\u00e9curit\u00e9 de la Terre."}, {"images": {"nodes": [{"file_name": "hero_cover_3000_900.png", "id": "2926947970880231", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974503_2926947977546897_960016588059614092_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GinIb3-lIvwQ7kNvgFp5wjB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvri4_ZR8s8UVOXwmckxpVJ6OaYHytWJoc7nCHXzWRtA&oe=67386744"}, {"file_name": "cover_square_1440_1440.png", "id": "2765103627152197", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031634_2765103633818863_4778213413615325736_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r7uKh2LcV4QQ7kNvgHRwF7j&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAu0k8dNGkJF12zIz45Hwj_7L6nEkWmhTMNOuSGtRiAyQ&oe=67388F5E"}, {"file_name": "logo_transparent_redh_6504x1440.png", "id": "820059071911776", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86610712_820059078578442_2960031635955588047_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9CpMV5c6EFYQ7kNvgGJP7gq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCr1GQahoieE0ARiX3EFzOTEA64WBaLRluVF4hhIsTN3g&oe=67388405"}, {"file_name": "cover_landscape_2560_1440.png", "id": "467002557769515", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031442_467002561102848_2751627463359311677_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=auMetZACTj8Q7kNvgGIh2L3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5vCBHCRcWbQBuF5UdbiIrKtt8hJRJrbbtuypw5UWvPw&oe=6738986A"}, {"file_name": "client_icon.png", "id": "447444016445394", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974538_447444019778727_2047571762408174424_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Ve0N4yt07AQ7kNvgGPIIs7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDucLULHrHMHF3jFtT7HAQKP7x6eihnVgoMiENyZpabIw&oe=6738779C"}, {"file_name": "cover_portrait_1008_1440.png", "id": "432067671239247", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982448_432067674572580_1971623972276369314_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oQyibywS35gQ7kNvgFXof5a&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-yp8nP5q8k8rx7pHu-wPNP4foeTaxURkaChIc3brZTQ&oe=6738689E"}, {"file_name": "mini_landscape_1080_360.png", "id": "427755901771824", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982701_427755905105157_4880152747839038613_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7fynnWILXuIQ7kNvgFZlLDk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbxYDGDKbibRgeIb9Q99fu6BLZp3w3bSaD3GkOJEJzJQ&oe=673876D8"}]}, "id": "411094670167827", "locale": "es_ES", "screenshots": [{"file_name": "screenshot_corridor_02_2560.png", "id": "282036383486092", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031606_282036386819425_1808319102062740162_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=swkMFoQRlVwQ7kNvgEtl1f-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmHTOo00wbSMnpjo8PB2QLkjfUgF1Q0UNF6_DvRo5qbQ&oe=67388587"}, {"file_name": "screenshot_drive_2560.png", "id": "251675699764873", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984472_251675706431539_3176051378228541686_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sD8e29JcemAQ7kNvgEN_e1O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAggWHstLAfBHd5XZmVKMNp0JPSZ0u-2BGtdNaH-ZZSww&oe=67388C57"}, {"file_name": "screenshot_bridge_2560.png", "id": "158040722817983", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031567_158040729484649_5479092896147384744_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FgVvtQXq1NYQ7kNvgGQYoUU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM7_4UOUpdDUZpAaiCJ-QLXCmhgJCNbT3RKTS4SBpihw&oe=673873C5"}, {"file_name": "screenshot_inventory_02_2560.png", "id": "1084509202029683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031318_1084509205363016_5123388851053624878_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-fSmxrQdURsQ7kNvgG-2Ivx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXms8VgbPF1gHoGMVn1y5HVkk_346I9fcF7aOwsjvWOw&oe=673878EC"}, {"file_name": "screenshot_terminal_2560.png", "id": "1048919022183207", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974909_1048919032183206_6669237814697690505_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2MpZp8YLHSUQ7kNvgFJXERd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_7kRz9KNGWdDDs-56ela8kBUd6-BE17_ZDLvQT8mEgg&oe=6738978B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_final_cover_2560x1440.png", "id": "248221883580811", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001717_248221890247477_5560023770818138682_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C7sP5tAL7vUQ7kNvgGEJmfk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsc9a_Hn70a4cOnacN8jUF34I8gCtOEgSf9eHeivBoXg&oe=67389643"}, "display_name": "Cosmodread", "keywords": ["espacio", "terror", "supervivencia", "roguelike", "dungeon"], "long_description": "Un roguelike de terror y supervivencia en VR\n\nAtrapado en una nave espacial a la deriva y repleta de horrores, explora y sobrevive hasta encontrar el camino de regreso a la seguridad de la Tierra. Cosmodread te envuelve en una atm\u00f3sfera tan viva, tensa e inmersiva que te har\u00e1 olvidar el mundo real.\n\nEXPLORA\nBusca recursos y encuentra el camino a casa. En cada partida jugar\u00e1s en nuevos mapas generados proceduralmente en los que las habitaciones, pasillos, objetos y obst\u00e1culos cambiar\u00e1n de posici\u00f3n de forma aleatoria, y vivir\u00e1s diferentes situaciones emergentes. Nunca sabr\u00e1s lo que te espera detr\u00e1s de la siguiente puerta.\n\nSOBREVIVE\nInteract\u00faa con el entorno con tus propias manos. Abre puertas, cajones y armarios y hurga en su contenido. Obt\u00e9n recursos b\u00e1sicos y crea armas y herramientas para lidiar con enemigos y obst\u00e1culos.\n\nLUCHA\nAg\u00e1chate y ponte a cubierto para disparar a los enemigos con tu ballesta o ti\u00e9ndeles una trampa. Pero recuerda, \u00a1la munici\u00f3n escasea!", "short_description": "Cosmodread es un roguelike de terror y supervivencia en VR en el que tendr\u00e1s que escapar de una nave espacial a la deriva y llena de pesadillas. Perdido en un universo hostil, explora e intenta sobrevivir hasta encontrar el camino de regreso a la seguridad de la Tierra."}, {"images": {"nodes": [{"file_name": "logo_transparent_redh_6504x1440.png", "id": "3879135495478233", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75488382_3879135498811566_2686572986721642207_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vi56uBg0VmkQ7kNvgE3uURG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-UOawM-zPeO5facW2GV_BMuS-wyXzM3fLjQ4SHEn2mw&oe=6738903E"}, {"file_name": "cover_portrait_1008_1440.png", "id": "834803280584457", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031587_834803283917790_7672487982639575803_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ElwQ6aklQZQQ7kNvgGQjBos&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqyypTHep-0R6cqGdRO_xpt1q-kSVsGp7-omxWKXLk5A&oe=6738944A"}, {"file_name": "cover_landscape_2560_1440.png", "id": "1367187886962089", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86662329_1367187890295422_7273309200526519194_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hCqr6dIDy3EQ7kNvgFJg9a_&_nc_zt=3&_nc_ht=scontent-iad