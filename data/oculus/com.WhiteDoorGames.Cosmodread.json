.oculuscdn.com&oh=00_AYASE-CoKMmU40DbqCbIM2TVxVox1LUNhJxYjO8NS592zg&oe=67386790"}, {"file_name": "screenshot_drive_2560.png", "id": "472946910394280", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974538_472946913727613_2248992318204865202_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_gtyIOUuGxAQ7kNvgG3IXi8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBWumUfsf838XDC27V-NstcP4EgSbUdEIMu8afw14THHw&oe=67388A96"}, {"file_name": "screenshot_bridge_2560.png", "id": "249040270025518", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_249040273358851_7084475388674703690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n2mC5jXqLIsQ7kNvgE9lbOf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjk5yB93a1-y3TCmPVPyhY5pKkbIkyUcgdx-UOogpYrg&oe=673885F7"}, {"file_name": "screenshot_inventory_02_2560.png", "id": "838366913409221", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572923_838366916742554_2960999131960416276_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZbsGp0Y6tfMQ7kNvgFHQiZC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsm4G-76eLlE9Hs6DOHlvCds6TJ_hF4BV5uG26W3kCvA&oe=6738801E"}, {"file_name": "screenshot_terminal_2560.png", "id": "260075935520261", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375755_260075942186927_625588291690178965_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nhUFHBc366AQ7kNvgGqwsn0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAS56M_OLcECJEAboQ9e2gsXKIH_ZRWBW3vtamlah1Opg&oe=67389A0C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_final_cover_2560x1440.png", "id": "264219468424749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982535_264219471758082_997212140826597774_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WawnYk30As0Q7kNvgHNL18k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARvEnW5Qm7IFbhOtg6OK9H_erJgXHFtrG1tceUZJssgA&oe=6738758B"}, "display_name": "Cosmodread", "keywords": ["space", "horror", "survival", "roguelike", "dungeon"], "long_description": "A VR survival horror roguelike.\n\nTrapped in a dying spaceship filled with horrors, you must explore, survive, and find your way back to the safety of Earth. Cosmodread features a rich, tense and immersive atmosphere that will make you forget about the world outside the headset.\n\nEXPLORE: \nSearch for resources and find a way home. Every run will have you play in a new procedurally generated layout, with random positions for rooms, corridors, items and hazards, and different emergent situations. You\u2019ll never quite know what\u2019s behind the next door.\n\nSURVIVE: \nUse your own hands to interact with the environment. Open doors, drawers and lockers and rummage through their contents. Collect basic resources, and craft weapons and equipment to deal with both enemies and hazards.\n\nFIGHT: \nCrouch behind cover and shoot at enemies with your crossbow, or set a trap for them to walk into. But remember: ammo is scarce!", "short_description": "Cosmodread is a VR survival horror roguelike about escaping a dying spaceship filled with nightmares. Stranded in a hostile universe, you must explore, survive, and find your way back to the safety of Earth."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.whitedoorgames.com/privacy.html", "developer_terms_of_service_url": "http://www.whitedoorgames.com/tos.html", "publisher_name": "White Door Games", "support_website_url": "http://www.cosmodread.com/contact/", "website_url": "http://www.cosmodread.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": 