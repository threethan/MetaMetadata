01691_3813560198758624_3697929219805734152_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8lXmVl3eYdcQ7kNvgFzVZy8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGd02Z54_pGhgPOkrt8vUG2&oh=00_AYCZXphTWI1eEaX0uSFk9SaSb3Y9-671qa6_pFUjNaS8TA&oe=66F53FD6"}, {"file_name": "vlcsnap-2021-03-01-15h23m34s811.png", "id": "774992679776878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982720_774992683110211_8478148152978643142_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDGEoe4COOYQ7kNvgFg0Fn-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGd02Z54_pGhgPOkrt8vUG2&oh=00_AYAzWR8MadhJoekU0j1cYSEx_6r6GpGvBCdjZn4gDib6hw&oe=66F546A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SportModeLandscapeCover.png", "id": "1250535798673645", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_1250535802006978_4125075686671892505_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kaSgCvCHPiMQ7kNvgGDQAA5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGd02Z54_pGhgPOkrt8vUG2&oh=00_AYCHVXU_HT0yUBzyabRFDxgp0cscpesgL9UL4lOal-mBiA&oe=66F54A6A"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit.\n\nSport Mode is currently in Early Access with a Sandbox mode where you have access to Creator Mode, a button press away from spawning and manipulating a variety of weapons, NPCs, and props. Also available is an Arena mode where you fight off waves of enemies for the highest score.\n\nComing soon is a Puzzle mode where you have to solve physics-driven puzzles in the fastest time possible.\n\nLeaderboards will be coming later so you can compete with your friends.", "short_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/66a59856-d21f-498c-