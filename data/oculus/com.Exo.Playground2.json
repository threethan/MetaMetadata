3T9UcYYQ7kNvgHX9-Fq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDS8HWICumlEu7WFKJ551kg22BqwcaG6zDsdauodZRm-w&oe=6714E313"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscapePNG.png", "id": "654708479777123", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035446_654708483110456_7702099847216412787_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jhXbV3j3ZdkQ7kNvgHke4CR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUn6guZdWyi7WUU6mxzdvXDDvjyL71eAFVDRoPHTt-MQ&oe=6714DA2D"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Turn on Sport Mode to take it to the next level of VR physics interaction where your creativity is the limit.\n\nKEY FEATURES\nPhysics Driven - Realistic physics to create a visceral connection between you and the virtual world.\nArena Mode - Fight off waves of enemies for the highest score.\nSandbox Mode - A button press away from spawning and manipulating a variety of weapons, NPCs, and props.\nSandbox Modifiers - Customize the experience to your liking with customizable strength and speed, dismemberment, oil splatter, time stop, a jetpack, and much more.\nComing Soon - New levels, modes, weapons, tools, props, modifiers, and vehicles will be added over time.", "short_description": "Turn on Sport Mode to take it to the next level of VR physics interaction where your creativity is the limit, the successor to Physics Playground."}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtuaport.org/2022/01/13/sport-mode-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Virtuaport", "support_website_url": null, "website_url": "https://virtuaport.org/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type