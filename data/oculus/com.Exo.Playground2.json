25/39001691_3813560198758624_3697929219805734152_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ooIh62lLh8Q7kNvgEf1_FY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJauydR30Wdl-btv9JAs16D&oh=00_AYA4MarmKEy8UzNh6MT7HDgVH472vH-fh0NOU6N2ijQCkg&oe=66D59BD6"}, {"file_name": "vlcsnap-2021-03-01-15h23m34s811.png", "id": "774992679776878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982720_774992683110211_8478148152978643142_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oNJIeIk7XaAQ7kNvgEISlar&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJauydR30Wdl-btv9JAs16D&oh=00_AYAEsVcdPzmoTDaXJ2P7u7vF_0G6KbWYWTsJObelxi3Y8A&oe=66D5A2A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SportModeLandscapeCover.png", "id": "1250535798673645", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_1250535802006978_4125075686671892505_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P3qs5Kv_pFwQ7kNvgG9Phso&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJauydR30Wdl-btv9JAs16D&oh=00_AYDzOSUbTvoR_84r7jb_CfOG5FvUj9rdK11J0ijIL0gCQA&oe=66D5A66A"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit.\n\nSport Mode is currently in Early Access with a Sandbox mode where you have access to Creator Mode, a button press away from spawning and manipulating a variety of weapons, NPCs, and props. Also available is an Arena mode where you fight off waves of enemies for the highest score.\n\nComing soon is a Puzzle mode where you have to solve physics-driven puzzles in the fastest time possible.\n\nLeaderboards will be coming later so you can compete with your friends.", "short_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/66a59856-d21f