dWA&oe=67499FD6"}, {"file_name": "vlcsnap-2021-03-01-15h23m34s811.png", "id": "774992679776878", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982720_774992683110211_8478148152978643142_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I9qMk31E6ZsQ7kNvgE4mTuq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnt69vKyY1MJILbILxOMwlshZI2CZOh8yqaNW_HB55zQ&oe=6749A6A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SportModeLandscapeCover.png", "id": "1250535798673645", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974827_1250535802006978_4125075686671892505_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5BY2qkPNdqkQ7kNvgHf-mxh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB50keaCNEFjdau-kaD-4dA0aB6KJ3m-OEl3EfEH3dBZQ&oe=6749AA6A"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit.\n\nSport Mode is currently in Early Access with a Sandbox mode where you have access to Creator Mode, a button press away from spawning and manipulating a variety of weapons, NPCs, and props. Also available is an Arena mode where you fight off waves of enemies for the highest score.\n\nComing soon is a Puzzle mode where you have to solve physics-driven puzzles in the fastest time possible.\n\nLeaderboards will be coming later so you can compete with your friends.", "short_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/66a59856-d21f-498c-b476-4a2e483f7460", "developer_terms_of_service_url": null, "publisher_name": "Virtuaport", "support_website_url": null, "website_url": "https://beyondinfiniti.itch.io/theplayground", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_