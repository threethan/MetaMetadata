6712702406593", "version": "0.7.2", "version_code": 94, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3695210323890200", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7276712702406593"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "245952403734586"}]}, "change_log": "IMPROVED\n- Added option in NPC spawn menu to use original Dummy NPC model.\n- Improved menu interaction while moving midair.\n\nFIXED\n- Banana gun stutter on grab and ungrab.", "created_date": 1707852345, "id": "7237476662996864", "version": "0.7.1", "version_code": 93, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3695210323890200", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7276712702406593"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "245952403734586"}]}, "change_log": "NEW\n- Weapon: Banana Gun.\n- Weapon: Grenade.\n\nIMPROVED\n- Optimized player rig, ragdoll physics, player model, and user interface.\n- Enabled Super Resolution on Quest.\n- Increased Resolution on Quest 3.\n- Added new difficulty option. (Hard is now harder)\n- Added smooth rotation speed and snap rotation degrees options.\n- Added option to reset settings.\n- Hand poses for all interactables.\n- Updated to Unity 2021 LTS and Oculus Integration SDK v57.\