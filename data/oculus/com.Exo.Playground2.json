-7&_nc_sid=6e7a0a&_nc_ohc=fWpWnNMAJkwQ7kNvgHBeUcM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCT7yM8mpLR9X69sE5aagoWG62b06G4vovE4B-YUWXOow&oe=6707BBA7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SportModeLandscapeCover.png", "id": "1250535798673645", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974827_1250535802006978_4125075686671892505_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ALlAn6G1kYsQ7kNvgF72W_l&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0tCrQxFiuGYEEF27J4j0dmAdiEtwTioNyun9HaLHrag&oe=6707BF6A"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit.\n\nSport Mode is currently in Early Access with a Sandbox mode where you have access to Creator Mode, a button press away from spawning and manipulating a variety of weapons, NPCs, and props. Also available is an Arena mode where you fight off waves of enemies for the highest score.\n\nComing soon is a Puzzle mode where you have to solve physics-driven puzzles in the fastest time possible.\n\nLeaderboards will be coming later so you can compete with your friends.", "short_description": "Successor to the hugely popular Physics Playground, Sport Mode takes it to the next level in a game where your creativity is the limit."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/66a59856-d21f-498c-b476-4a2e483f7460", "developer_terms_of_service_url": null, "publisher_name": "Virtuaport", "support_website_url": null, "website_url": "https://beyondinfiniti.itch.io/theplayground", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_conne