43997709_948417936123075_8773380777805429200_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pkCyOHUux1wQ7kNvgGg8TXf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJauydR30Wdl-btv9JAs16D&oh=00_AYBRqiA4i0XUXwlxw6N80-PHnw9Vca6Ywk_WK4V1bu1lww&oe=66D59B13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscapePNG.png", "id": "654708479777123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035446_654708483110456_7702099847216412787_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K4h_yLP-ayAQ7kNvgFXg_Gx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJauydR30Wdl-btv9JAs16D&oh=00_AYDi4OhseBWvS7VvrHE8U1LmfJJCznHh48HEiMgbqGFP2g&oe=66D5922D"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Turn on Sport Mode to take it to the next level of VR physics interaction where your creativity is the limit.\n\nKEY FEATURES\nPhysics Driven - Realistic physics to create a visceral connection between you and the virtual world.\nArena Mode - Fight off waves of enemies for the highest score.\nSandbox Mode - A button press away from spawning and manipulating a variety of weapons, NPCs, and props.\nSandbox Modifiers - Customize the experience to your liking with customizable strength and speed, dismemberment, oil splatter, time stop, a jetpack, and much more.\nComing Soon - New levels, modes, weapons, tools, props, modifiers, and vehicles will be added over time.", "short_description": "Turn on Sport Mode to take it to the next level of VR physics interaction where your creativity is the limit, the successor to Physics Playground."}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtuaport.org/2022/01/13/sport-mode-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Virtuaport", "support_website_url": null, "website_url": "https://virtuaport.org/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "conte