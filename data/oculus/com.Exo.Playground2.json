Q1b5_P4Q7kNvgEzVDTh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBeCP-3Yn1dwWUCksYEsurKROJSKkHbchhc8HrkxQwDLQ&oe=676FDA93"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscapePNG.png", "id": "654708479777123", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035446_654708483110456_7702099847216412787_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qoSNFdH5nhAQ7kNvgEYggbd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5icEMATATNKrllyxRrA4K3IWQrAO0FzaInrsgXac4wA&oe=676FD1AD"}, "display_name": "Sport Mode", "keywords": [], "long_description": "Turn on Sport Mode to take it to the next level of VR physics interaction where your creativity is the limit.\n\nKEY FEATURES\nPhysics Driven - Realistic physics to create a visceral connection between you and the virtual world.\nArena Mode - Fight off waves of enemies for the highest score.\nSandbox Mode - A button press away from spawning and manipulating a variety of weapons, NPCs, and props.\nSandbox Modifiers - Customize the experience to your liking with customizable strength and speed, dismemberment, oil splatter, time stop, a jetpack, and much more.\nComing Soon - New levels, modes, weapons, tools, props, modifiers, and vehicles will be added over time.", "short_description": "Turn on Sport Mode to take it to the next level of VR physics interaction where your creativity is the limit, the successor to Physics Playground."}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtuaport.org/2022/01/13/sport-mode-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Virtuaport", "support_website_url": null, "website_url": "https://virtuaport.org/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1990104051447093"}, {"id": "459781504968480"}], "external_subscription_typ