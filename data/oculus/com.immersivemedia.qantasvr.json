9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCfeDZ81xjSqM6pTOIvTQwIamQyQFODNyQ-KoN-7oUiQ&oe=66D70AE3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Qantas VR", "keywords": ["VirtualReality", "VR", "Tourism", "Qantas", "Flight"], "long_description": "The Qantas VR app will virtually transport you to Qantas destinations and unique Qantas experiences.\n \nWith Qantas VR you can:\n \n1. Escape to Qantas destinations: scuba dive the Great Barrier Reef, climb the Sydney Harbour Bridge, relax on a sunset river cruise in Kakadu and explore water holes in the Australian outback.\n2. Access unique Qantas experiences: fly with the pilots in the cockpit of a Qantas aircraft and experience the Qantas A380 take-off, approach and land in front of where you stand.\n3. Travel with Qantas: experience flying with Qantas as it lands at Hamilton Island airport and take a tour of the Los Angeles International First Lounge.\n \nStay up-to-date with new content through push notifications.", "short_description": "\t\nEnjoy Qantas destinations and unique Qantas experiences in virtual reality."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.qantas.com/travel/airlines/privacy/global/en", "developer_terms_of_service_url": "http://www.qantas.com/travel/airlines/terms-of-use/global/en", "publisher_name": "Qantas", "support_website_url": null, "website_url": "http://www.qantas.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes