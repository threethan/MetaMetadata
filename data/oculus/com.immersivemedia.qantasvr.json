ng aerial views from a helicopter over the iconic heart shaped reef, and sail to the magnificent Whitehaven Beach on a yacht. Produced by Rapid VR powered by im360 for Qantas and Hamilton Island.", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Rapid VR", "support_website_url": null, "website_url": "http://www.rapidvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": [], "has_in_app_ads": false, "internet_connection": null, "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": [], "id": "4557992604310742"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "849116155163540"}]}, "baseline_offer": {"id": "849116155163540"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1438153200, "status": "PUBLISHED", "id": "849116155163540"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1441619562555072", "version": "2.0"}, "id": "1689012081333237", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "977671432283223", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1441619562555072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1583476331, "id": "3081905938526418", "version": "3.1", "version_code": 28, "release_status": "RELEASED", "status": "APPROVED", "bin