4Mvz141Ow&oe=67431802"}, {"file_name": "migrated_image.png", "id": "832913600518737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162787_1002569349776061_1824829146_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_1e4LwGdasQ7kNvgHZ9FML&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPnCSr3LkWlf1QlXFgX1xmsPha3EQrb65hiMJbqR7FQQ&oe=674325E3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Qantas VR", "keywords": ["VirtualReality", "VR", "Tourism", "Qantas", "Flight"], "long_description": "The Qantas VR app will virtually transport you to Qantas destinations and unique Qantas experiences.\n \nWith Qantas VR you can:\n \n1. Escape to Qantas destinations: scuba dive the Great Barrier Reef, climb the Sydney Harbour Bridge, relax on a sunset river cruise in Kakadu and explore water holes in the Australian outback.\n2. Access unique Qantas experiences: fly with the pilots in the cockpit of a Qantas aircraft and experience the Qantas A380 take-off, approach and land in front of where you stand.\n3. Travel with Qantas: experience flying with Qantas as it lands at Hamilton Island airport and take a tour of the Los Angeles International First Lounge.\n \nStay up-to-date with new content through push notifications.", "short_description": "\t\nEnjoy Qantas destinations and unique Qantas experiences in virtual reality."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.qantas.com/travel/airlines/privacy/global/en", "developer_terms_of_service_url": "http://www.qantas.com/travel/airlines/terms-of-use/global/en", "publisher_name": "Qantas", "support_website_url": null, "website_url": "http://www.qantas.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play