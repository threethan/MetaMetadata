tps://scontent.oculuscdn.com/v/t64.5771-25/38974657_1610022679798255_7525519431071150803_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d-P1wOqi5isQ7kNvgGHkRHP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AanR4EfgsRt_RU3lrjEK_rj&oh=00_AYDaOY1sWR55DoPNSyazG3YcCZuS8BbLYBwgix2I6Vr7ZA&oe=66E7FF85"}, {"file_name": "shot34.png", "id": "886872056567213", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974828_886872059900546_8861963412351067565_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CKJs-0dVoKQQ7kNvgFyNkLr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AanR4EfgsRt_RU3lrjEK_rj&oh=00_AYB8LXEIu-KWyR6q1EAodplJ9MxbyVRVgOPwDh7BPSCsOA&oe=66E83172"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape3.png", "id": "786866776676088", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_786866780009421_3311280814611894890_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JQfNdDgukIAQ7kNvgGWR2wk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AanR4EfgsRt_RU3lrjEK_rj&oh=00_AYCaqot79-C_A1AxaEH_-nfN1vg-6ISbdXXNGFqz3-zfkw&oe=66E80D20"}, "display_name": "Secret History of Mongolia Volume 3", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "