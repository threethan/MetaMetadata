://scontent.oculuscdn.com/v/t64.5771-25/38974828_886872059900546_8861963412351067565_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DzGJ0Vj_Vj0Q7kNvgHcdsMe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBa_um15pIMKwVIjmUaOyE65pwuZ2FCQarVAs38GDTQnA&oe=66FBF7F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape3.png", "id": "786866776676088", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_786866780009421_3311280814611894890_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kyrAvo4BhHoQ7kNvgGfO0ev&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhfgOYHTE9h78jFUagnRRSQuK78ROZcU-9Z5ehm5FN_A&oe=66FBD3A0"}, "display_name": "Secret History of Mongolia Volume 3", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id"