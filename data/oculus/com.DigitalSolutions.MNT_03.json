9"}, {"file_name": "shot35.png", "id": "1149411006085890", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203627_1149411009419223_7153070405956595124_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PLZvI1FTpO4Q7kNvgEm6RgB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDzKdH0jvtUQ4ztu1QlC5y-fgSsAn1a33gyXNg2IUnVoA&oe=67713591"}, {"file_name": "shot33.png", "id": "1610022676464922", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974657_1610022679798255_7525519431071150803_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L_-xbiXPqIcQ7kNvgEmxnfi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCs5-Qibpdj0I3M59YbW9Kwr6JfF5AHLSYJ_0uqhM6I2w&oe=67711B85"}, {"file_name": "shot34.png", "id": "886872056567213", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974828_886872059900546_8861963412351067565_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WnHtfMe1DTAQ7kNvgG9nD0P&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfovs_Le6_r4pVIXHcF2P1k6iJ1Q5q72Uw0nAblu6-6w&oe=67714D72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape3.png", "id": "786866776676088", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984445_786866780009421_3311280814611894890_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ifb7WqODaKgQ7kNvgHk4qsq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuq26utxB5Ott41zDSJQqZR51NB8I1E-0n7x_TxBZyWQ&oe=67712920"}, "display_name": "Secret History of Mongolia Volume 3", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["mn"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7143309339120384"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1399657957336029"}]}, "baseline_offer": {"id": "1399657957336029"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709751660, "status": "PUBLISHED", "id": "1399657957336029"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7143324852452166", "version": "1.0"}, "id": "432517745874561", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename