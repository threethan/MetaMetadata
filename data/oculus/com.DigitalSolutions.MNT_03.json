n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gxpJR9_VxysQ7kNvgHMf-fN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_Ceiuv8Wr5TXJbnu8v3u1y5yEPD1NCK8EmTL39CVXnQ&oe=672F3085"}, {"file_name": "shot34.png", "id": "886872056567213", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974828_886872059900546_8861963412351067565_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B03uPM-wzLgQ7kNvgEUEgIj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyZjPZzhR94Vgnjv8aE9SRpPor_Y4TtjbylkCMOhpx7A&oe=672F6272"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape3.png", "id": "786866776676088", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984445_786866780009421_3311280814611894890_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2BJ7n_fj1bYQ7kNvgFSg-xM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhgG1iMvqVsA9Akm8IB6_5NVmLwZzvZf3XDsIcqit1TQ&oe=672F3E20"}, "display_name": "Secret History of Mongolia Volume 3", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_servi