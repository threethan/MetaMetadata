oculuscdn.com&oh=00_AYBxfQMVLn4NN0jaa6FupHXA1AGNWXPLHXVeK_EWjf5gAA&oe=672B6E07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Thumbnail_2560x1440.png", "id": "1153806465691503", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974889_1153806469024836_1097286036149770514_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FShDOoI1FpUQ7kNvgHt4Km6&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCQMQhguTW64Q6UYCPwEH9MvL99wUtGuKRCwpCDFqGBIQ&oe=672B5E6E"}, "display_name": "You Can't Scare Me", "keywords": ["horror", "multiplayer", "ghost", "scare", "halloween"], "long_description": "Scare or be scared in You Can't Scare Me - the haunted house where you can frighten your friends!  Set scary traps or transform into terrible monsters to try and scare the living daylights out of your friends.  If they scream, you win!\n\n{381388348345743}\n\n{384188387868754}\n\nExplore lots of creepy levels to find hidden treasures. Set scary traps to frighten your friends - and get points if they scream!  Stay invisible and set up creepy encounters all around them - or appear in front of them as a terrifying monster at a dramatic moment to make them really flip their lid!\n\n{483833087857292}\n\nCan you freak out your friend enough to reduce them to a shadow of their former selves? Can your friend keep their cool long enough to find the hidden keys and escape the horrible nightmare you\u2019ve crafted for them??\n\nFind out - in You Can\u2019t Scare Me!\n\n{856883466101016}\n\nFeatures:\n- Multiplayer Mode - Play with up to 4 friends online\n- Single Player Mode - Play against the computer\n- Party Mode - Set up a level, and pass the headset to a friend to play it\n- 8 freaky levels including an abandoned theme park, cabin in the woods, liminal spaces, and more\n- 8 bone-chilling costumes\n- 50 scare traps, from unnerving to positively horrifying\n\n{1076219030601901}", "short_description": "Scare or be scared in You Can't Scare Me - the haunted house game where you can frighten your friends!  Set scary traps or transform into terrible monsters to try and scare the living daylights out of your friends.  If they scream, you win!"}]}, "developer_name": "LunaBeat", "developer_privacy_policy_url": "https://www.youcantscaremevr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "LunaBeat", "support_website_url": null, "website_url": "http://youcantscaremevr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "6491117364320448"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "891477842462283"}]}, "baseline_offer": {"id": "891477842462283"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728579601, "status": "PUBLISHED", "id": "891477842462283"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8191431504289017", "version": "1.075"}, "id": "271092885808485", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6491117354320449", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8191431504289017"}, "release_status": "REL