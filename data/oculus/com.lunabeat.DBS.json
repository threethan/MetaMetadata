5/38974695_527420192998809_6011633309619611238_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QNEdn3EbxOsQ7kNvgH5o7qG&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCatJxyOlfXtqdMhMZ9vgZZC627SISYHU632mEBE-WKow&oe=672B52E7"}, {"file_name": "costumes-in-mirror.png", "id": "353243557882999", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982527_353243561216332_2826148493853865665_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=inGUzUOyo90Q7kNvgEHK4W8&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAkTVzQke6i28AEz2omBHf_k4xrbp37UVuGPjm4MTHvNA&oe=672B3FF6"}, {"file_name": "liminal-chase.png", "id": "1153198059101863", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75580059_1153198062435196_6562438275284531368_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NsY7PMq2gl8Q7kNvgHXwfEm&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBxfQMVLn4NN0jaa6FupHXA1AGNWXPLHXVeK_EWjf5gAA&oe=672B6E07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Thumbnail_2560x1440.png", "id": "1153806465691503", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974889_1153806469024836_1097286036149770514_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FShDOoI1FpUQ7kNvgHt4Km6&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCQMQhguTW64Q6UYCPwEH9MvL99wUtGuKRCwpCDFqGBIQ&oe=672B5E6E"}, "display_name": "You Can't Scare Me", "keywords": ["horror", "multiplayer", "ghost", "scare", "halloween"], "long_description": "You Can\u2019t Scare Me is a Halloween party game- meet up with friends to try to scare them, and if they scream, you get a point! It\u2019s either a jump scare or a laugh riot, but either way it\u2019s a fang-tastic time!\n\nThere are 2 teams:\nHaunters try to scare the Haunted using scare traps and costumes- they can see and hear everyone.\nHaunted collects keys and tries not to scream- they can hear the Haunters but can't see them unless they appear as a monster!\n\nThe 50 scare traps have a wide variety of monsters, sounds & special effects- with lots of common fears!\n\nHaunt 8 levels- a mansion, a cemetery, a hospital, a fair & more. Play a small map for a fast scare, or a big one for a mega match. Each has an unlockable costume for multiplayer!\n\nMultiplayer is the most exciting- summon your Meta friends to play. When facing off against humans, you never know what's coming next!\nSingle player lets you play a random trap layout- use it to study the maps so you\u2019ll know the best spots to place traps.\nParty mode lets you place traps, then pass the headset to a friend to play.\n\nFrom our players:\n\u201cIf you are looking for a social VR game that blends horror with fun, [this] is a fantastic choice that offers hours of scary (and hilarious) moments.\u201d\nBlake\n\n\u201cThis one is endless fun because with LIVE scarers... it can never become predictable.  We had great fun in this game, and spent hours in there scaring each other.\u201d\nmuggito\n\n\"Even if you are not easily scared this game can be a great laugh with friends.\"\nSandwich", "short_description": "You Can\u2019t Scare Me is a social Halloween party game- meet up with friends to try to scare them, and if they scream, you get a point! It\u2019s either a jump scare or a laugh riot, but either way it\u2019s a fang-tastic time!"}]}, "developer_name": "LunaBeat", "developer_privacy_policy_url": "https://www.youcantscaremevr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "LunaBeat", "support_website_url": null, "website_url": "http://youcantscaremevr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb"