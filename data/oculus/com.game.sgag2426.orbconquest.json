pjjyG3H7wjZkENL1BtKF1qL1o79cDcJkytkLkNQaQ&oe=677BAD2E"}, {"file_name": "ss3.png", "id": "1952004381931095", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75298472_1952004385264428_8213665801664121384_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=va81wxiXj7oQ7kNvgF2dwDd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCj-hUmJxoKKI6596BDtMsv6WzVzYnvvA57P5zhi7UVBA&oe=677BCB2C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7841830009239208", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035410_7841830012572541_6800934679758716826_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uYMoBMGfNxIQ7kNvgHvuUmn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBHV0FdQG7LLlx8uH6w9qKTrXGqC-Hh5yH8MfJVz1hzCw&oe=677BBF53"}, "display_name": "Orb Conquest", "keywords": [], "long_description": "Orb Conquest: The Ultimate VR Experience\n\nDive into the exhilarating world of \"Orb Conquest,\" a cutting-edge VR game that challenges your precision, reflexes, and strategic thinking. Set in a futuristic realm where you control dynamic spheres, your mission is to navigate these spheres through intricate tracks and lines, overcoming a series of increasingly complex obstacles and challenges.\nGameplay Overview\n\nIn \"Orb Conquest,\" players are transported to a visually stunning, high-tech environment filled with neon-lit paths and mesmerizing graphics. The game mechanics are designed to test and enhance your coordination and problem-solving skills. Each level presents a unique maze-like track, teeming with hurdles that require quick thinking and precise movements to overcome.\nKey Features\n\n    Dynamic Spheres: Master the control of highly responsive spheres, each with unique attributes and abilities that you can unlock and upgrade as you progress.\n\n    Intricate Tracks: Navigate through a variety of complex and beautifully designed tracks. Each track offers different challenges, from narrow passages to moving barriers and beyond.", "short_description": "Orb Conquest: The Ultimate VR Experience\n\nDive into the exhilarating world of \"Orb Conquest,\" a cutting-edge VR game that challenges your precision, reflexes, and strategic thinking. Set in a futuristic realm where you control dynamic spheres, your mission is to navigate these spheres through intricate tracks and lines, overcoming a series of increasingly complex obstacles and challenges."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/orbconquest/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "SGag2426 Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/orbconquest", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7663735853751867"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035302_2743255765840335_7010018682360357414_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IcHtqDsKpvgQ7kNvgGzolkF&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAu7C26JdTU50Bg3U23YoGyQlh-7jUNR7FSBp8BvfKp-g&oe=677BD984"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Orb Conquest", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, 