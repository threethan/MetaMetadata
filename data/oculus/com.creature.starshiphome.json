2219"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8542987032404679", "version": "1.0.1000"}, "id": "943492023322591", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5959677854068956", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8542987032404679"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "943492023322591"}]}, "change_log": "V1.0.1000\n\n- Added Mixed Reality Info page, trouble shooter and advanced MR tools to help recover items that have drifted out of reach due to external Quest system tracking issues. Please be aware that Quest tracking relies on good lighting and we have been seeing worse tracking performance in dimly lit rooms.\n- Fixed potential Progression Blocker when the transmission from Jeff is not accepted after tuning the fourth plant\n- Fixed potential Progression Blocker when the game is saved after a dream, restarted and then the player staying on the start screen for too long, potentially missing an incoming transmission\n- Improved trail VFX of the lander capsule / B.O.T. when going to/coming back from planets\n- Improved fog of war VFX of planet scanning\n- Improved depressurization VFX of Airlock and Storage\n- Added Chapter Selection when starting a new game from the save slot management page\n- Removed mysterious orb in Echoshroom dream\n- Added extra helper text to windows to indicate they can also be placed on ceilings and floors", "created_date": 1728534210, "id": "8542987032404679", "version": "1.0.1000", "version_code": 1000, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"coun