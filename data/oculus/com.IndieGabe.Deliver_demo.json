 coming soon!", "short_description": "Deliver That Pizza is an escape room style puzzle game (demo version). Your task is to deliver a pizza to the last location of the day, which proves to be a bit difficult with all the puzzles the customer has set up for you."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ihol.hu/Unity_deliver_that_pizza/", "developer_terms_of_service_url": null, "publisher_name": "IndieGabe", "support_website_url": null, "website_url": "https://ihol.hu/IndieGabe/deliverthatpizza.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9152096598150873"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031639_2720681558106349_8348091299655026798_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dMAOonfKAnQQ7kNvgHecao-&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC3ASBHOy8zQ35z0mRlTnYFWB85gFANvnVGOLPYQyzOkQ&oe=670BCA16"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Deliver That Pizza - Puzzle Game - Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1728327060, "lastRevision": {"nodes": [{