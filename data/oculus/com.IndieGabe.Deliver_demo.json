440.png", "id": "1600439497484683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982594_1600439500818016_957516808003693458_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y8A7T61bfTIQ7kNvgH5e1g4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZguRt_O8NUZGnGU_iin753G8aApIhHV7EGw8uaFdkOA&oe=673B0E76"}, "display_name": "Deliver That Pizza - Puzzle Game - Demo", "keywords": ["Puzzle", "Demo", "Escape", "Pizza", "Game"], "long_description": "Deliver That Pizza is an escape room style puzzle game with a comforting, but slightly liminal atmosphere.\nYou are playing as an unfortunate pizza delivery worker, whose only task left for the day is to deliver one last pizza. The overly cautious customer has set up some puzzles for you, which makes the task a bit difficult, but you take on the challenge (for the money).\nSolve the puzzles and travel through the rooms to complete your mission!\nThis is the demo level, the full game is coming soon!", "short_description": "Deliver That Pizza is an escape room style puzzle game (demo version). Your task is to deliver a pizza to the last location of the day, which proves to be a bit difficult with all the puzzles the customer has set up for you."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ihol.hu/Unity_deliver_that_pizza/", "developer_terms_of_service_url": null, "publisher_name": "IndieGabe", "support_website_url": null, "website_url": "https://ihol.hu/IndieGabe/deliverthatpizza.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices"