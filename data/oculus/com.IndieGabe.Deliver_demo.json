mplete your mission!\nThis is the demo level, the full game is coming soon!", "short_description": "Deliver That Pizza is an escape room style puzzle game (demo version). Your task is to deliver a pizza to the last location of the day, which proves to be a bit difficult with all the puzzles the customer has set up for you."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ihol.hu/Unity_deliver_that_pizza/", "developer_terms_of_service_url": null, "publisher_name": "IndieGabe", "support_website_url": null, "website_url": "https://ihol.hu/IndieGabe/deliverthatpizza.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9152096598150873"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "752268953690661"}]}, "baseline_offer": {"id": "752268953690661"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728327060, "status": "PUBLISHED", "id": "752268953690661"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9706398732720654", "version": "1.4"}, "id": "1470592480309071", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9152096594817540", "is_concept": false, "latest_release