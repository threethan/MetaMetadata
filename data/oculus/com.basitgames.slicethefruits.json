 fruits\n- 4 different special fruits\n- 4 different objects \nto get higher scores by playing with it over and over again!\n\nA game that will relieve your stress, try it right now!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.basit.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "basit games", "support_website_url": null, "website_url": "https://www.basit.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6660818427360719"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "751143133640695"}, {"status": "PUBLISHED", "id": "896121852097388"}]}, "baseline_offer": {"id": "751143133640695"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709252820, "status": "PUBLISHED", "id": "751143133640695"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6769206713188556", "version": "5.0"}, "id": "1324499918269547", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6660818417360720", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6769206713188556"}, "release_status": "RELEASED