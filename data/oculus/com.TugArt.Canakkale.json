_ss03.png", "id": "1711088526298384", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75458095_1711088529631717_4448506239535102920_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdfrWGYfRQYQ7kNvgEdOiwb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCb6Rp3vDfd7ZX61-MMNxADDb4_wCu08o9wfNXUN-kw_A&oe=66CC4E2C"}, {"file_name": "canakkale_ss02.png", "id": "2567846246742352", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982491_2567846250075685_3541509908160374818_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ss7xCVwfBtYQ7kNvgHgkhGO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfCsSwBAPEDQRJAdu3uceu00dipss8EtxXZMrSvZ_1Ag&oe=66CC69C3"}, {"file_name": "canakkale_coverartLangdcape.png", "id": "480053061059801", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575347_480053064393134_5287664772453005647_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o3Zg1lE_0vYQ7kNvgFpCO5l&_nc_ht=scontent.oculuscdn.com&oh=00_AYC0D9uo6HcfplE3arT91nRCC3oTFtE-6k6Z0jjjij45pg&oe=66CC7895"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "canakkale_ss01.png", "id": "1586372271907172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_1586372275240505_535416603869243383_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Et7erIeMlGgQ7kNvgH-hyIj&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4JJb9UDI2CI_cKdaCzAWTJwMOuMVb28i8GuMDHvlphw&oe=66CC50AA"}, "display_name": "\u00c7anakkale", "keywords": [], "long_description": "This is a shooting game where you fight as an Ottoman soldier (captain) and defend the Ottoman lines at the coasts of \u00c7anakkale in the World War 1 using your double revolver which you reload and shoot them realistically against the soldiers of the Great Britain Empire and defend your home. ", "short_description": "Defend the lines in \u00c7anakkale in WW1"}, {"images": {"nodes": []}, "id": "1475327520018007", "locale": "tr_TR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u00c7anakkale", "keywords": [], "l