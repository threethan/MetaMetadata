hots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u00c7anakkale", "keywords": [], "long_description": "Bu oyunda 1915 \u00c7anakkale kara sava\u015flar\u0131nda Osmanl\u0131 saflar\u0131nda \u00e7arp\u0131\u015fan bir t\u00fcrk subay\u0131'n\u0131 (y\u00fczba\u015f\u0131) oynayacaks\u0131n. Elindeki \u00e7ift revolver tabancalar\u0131 ile askerlerinin daima arkas\u0131nda duran kahraman y\u00fczba\u015f\u0131, d\u00fc\u015fmana ge\u00e7it vermemeli. Ger\u00e7ek\u00e7i bir sava\u015f sim\u00fclasyonu ile silah kullanma ve ni\u015fan alma becerilerini test edecek ve geli\u015ftirecektir. ", "short_description": "Birinci D\u00fcnya Sava\u015f\u0131'nda \u00c7anakkale cephesini savunmaya haz\u0131r m\u0131s\u0131n? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://karamuyo.wordpress.com/tug-art-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Tu\u011frul \u00d6z\u015fahin", "support_website_url": null, "website_url": "https://karamuyo.wordpress.com/canakkale/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7537006983063655"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1200886837818362"}, {"status": "PUBLISHED", "id": "787752800228621"}, {"status": "PUBLISHED", "id": "773887571580528"}]}, "basel