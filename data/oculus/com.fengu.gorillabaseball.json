4760272141_7440778279650100119_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MU0yslLR2cwQ7kNvgG4kfjH&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAMBDYMfXPPdDY8fZg6MXorzUb3bNSwy6OZvLZB63-gbQ&oe=6728BDB8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "999376692187220", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982616_999376695520553_717075058959448374_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iMVwNnjtB2kQ7kNvgE9blYT&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDU3GD9EZNdm2ovk2XqiTOO1nSGdAIo0ynR33wg_IXARg&oe=6728C227"}, "display_name": "Gorilla Baseball - Baseball Sport Game", "keywords": ["BASEBALL", "SPORT", "GAME", "GORILLA", "MONKEY"], "long_description": "This is an interesting VR sports competitive game. You play as a gorilla.\n\nThe locomotion is inspired by Gorilla Tag. You can run, jump, and control the ball using only your hands. The rules are same to baseball.\n\nBesides baseball, there are also many other modes, such as soccer, American football and crossbow.\n\nThis game is free, and you can play with other players.", "short_description": "You can play baseball as a gorilla with others!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://web.manyatang.com/gorilla_baseball/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Fengu Studio", "support_website_url": null, "website_url": "http://web.manyatang.com/gorilla_baseball", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"]