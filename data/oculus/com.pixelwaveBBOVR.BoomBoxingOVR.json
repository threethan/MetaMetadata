nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YlnNcpIYNvEQ7kNvgFiEAHI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWDeQttQiUXN3WDVh_Ebu53&oh=00_AYC4LD5JbwfzG6dxisJiLwmLKCQtCbQlZwj4TMhsBojfJw&oe=66F2B62A"}, {"file_name": "migrated_image.png", "id": "141608053895673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448923_581655878700103_6047995121696243712_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TWqCTF-5pIgQ7kNvgG6z-gJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWDeQttQiUXN3WDVh_Ebu53&oh=00_AYBVHGMpqOBHqpFps1YRa0VcFKPm0pZczQFIGc-fYXaqsA&oe=66F2AFC2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boom Boxing ", "keywords": ["boxing", "firstperson", "fighting", "fight", "arena"], "long_description": "Boom Boxing VR is the FIRST & FREE knockout boxing experience on the Oculus GearVR.\nBoom Boxing VR will take you directly on the boxing arena and let you fight 1st person perspective in a VIRTUAL REALITY environment. \n\nBoom Boxing VR offers fighting game fans an adrenaline pumping world of boxing action. Polished animation and stunning 3D graphics bring the real boxing experience to your BRAIN and MIND, Just looking at the opponents hit point controls make jab, hook,and uppercut feel natural and fun. No more sit and play for Fitness lovers.\n\n\u2605 HOW TO PLAY\u2605 \n\n--- Just looking /gaze at the opponents body part like face or abdomen, This will immediately trigger auto generated  controls to make jab, hook,and uppercut which is natural and fun with your body and head movement!\n\n--- Example: If you look at the right side of face the right jab/hook,punch will trigger, Same for Left side, Abdomen, etc.\n\n--- Move your Body, Head left and right, This will help your attack to be more precise.\n\n", "short_description": "CHALLENGE YOURSELF IN VR BOXING ARENA."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.deepbrain.xyz/boom_boxing", "developer_terms_of_service_url": "http://www.deepbrain.xyz/boom_boxing", "pub