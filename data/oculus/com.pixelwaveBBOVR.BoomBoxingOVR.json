8590016071824572416_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IMHd9ZIrdJwQ7kNvgF_pKYK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWDeQttQiUXN3WDVh_Ebu53&oh=00_AYD4Fh1YFE0NIUA2FvPAEJznkE38cr6vV_KCHXUkTTYOPw&oe=66F2AFD7"}, {"file_name": "migrated_image.png", "id": "229380541449149", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162711_217728998731516_8992962541961347072_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wmjprJfToaoQ7kNvgFh9Eyj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWDeQttQiUXN3WDVh_Ebu53&oh=00_AYBr-Gk9BwArprzyMdLrNLV-fPARYulfkRelTY6cvHsMPw&oe=66F29B94"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "new Store Cover Art 2560x1440px.png", "id": "608268022842749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139031_608268026176082_3293314857385852928_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-wyd3dRPHEQ7kNvgEAKeu2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWDeQttQiUXN3WDVh_Ebu53&oh=00_AYCZbV4sua_DKa6gPEo66GKUY4r3u3Q0BWG4HPu0Z6COeg&oe=66F2B646"}, "display_name": "Boom Boxing", "keywords": ["boxing", "firstperson", "fighting", "fight", "arena"], "long_description": "Boom Boxing VR is the FIRST knockout boxing experience on the Oculus GearVR.\nBoom Boxing VR will take you directly on the boxing arena and let you fight 1st person perspective in a VIRTUAL REALITY environment. \n\nBoom Boxing VR offers fighting game fans an adrenaline pumping world of boxing action. Polished animation and stunning 3D graphics bring the real boxing experience \n\n\u2605 HOW TO PLAY\u2605 \n\nUse all four corners of Touchpad Swipe for different attack actions. \nYou can Increase skill by swiping from All eight directions with new GearVR 2017 release, or combine any two swipes in a single blow to your opponent.", "short_description": "CHALLENGE YOURSELF IN VR BOXING ARENA."}]}, "developer_name": null, "developer_privacy_policy_url": "http://deepbrain.xyz/boom_boxing/privacy-policy.html", "developer_terms_of_service_url": "http://deepbrai