: null, "display_name": "Atlas VR", "keywords": ["space", "education", "planets", "edutainment", "earth"], "long_description": "VR has the potential to dramatically shift how teachers teach, but more importantly, how learners learn. Atlas VR educational game will take players into an immersive Virtual Reality experience where they can learn about both our planet Earth and the surrounding planets and solar system in an enjoyable and engaging experience. \n\nThe focus of the game will primarily centre on the Earth including its structure, atmosphere, topology, day and night cycle and the ozone layer. Players will also have the opportunity to learn about the Moon, the other planets in our solar system, Satellites, the Asteroid belt and the Sun.", "short_description": "Atlas VR takes explorers to space in this edutainment experience. \nLearn about our planet Earth and beyond via a fully narrated interactive \"hotspot\" system.\nPut your knowledge to the test in Quiz mode where you will be competing to get the gold medal!\nEnter Explore mode to view all planet visualisations and interactions."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.virtualarts.co.uk/privacy-policy", "developer_terms_of_service_url": "https://www.virtualarts.co.uk/privacypolicy", "publisher_name": "Virtual Arts Limited", "support_website_url": "https://www.virtualarts.co.uk/", "website_url": "https://www.virtualarts.co.uk/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices