ZhywHgqbdavJ_ip&oh=00_AYB6exCPguihAkDCQWvJxVXbQDECn6SBaCMyQV8uKOqZ3Q&oe=66E2E3DE"}, {"file_name": "nightfall screenshot 2.png", "id": "1497879470857351", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001672_1497879474190684_2876899868746329028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LdMwUwZCpAEQ7kNvgFava1f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwDUHpb-ZhywHgqbdavJ_ip&oh=00_AYADpt66iqg5mNJBaw9aoS5UploMUaJRQGtryh8wR2Qrrw&oe=66E2B92F"}, {"file_name": "nightfall screenshot 5.png", "id": "388945917321262", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031338_388945920654595_4821277616870504580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3_p0ww2DfLgQ7kNvgGYBAhh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwDUHpb-ZhywHgqbdavJ_ip&oh=00_AYB9flBQvXa8OdaJrrTpa5ocnxi8y580Hf21f1p0rMYOvw&oe=66E2E5D8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Nightfall VR", "keywords": ["nightfall", "vr", "applab", "ape", "gorilla"], "long_description": "Welcome to NIGHTFALL VR!\n\nThis is one of my first official larger projects.\nI plan on Implenting a TON of community ideas, for that join our discord.\n\nDrop some down in our DISCORD: https://discord.gg/CNr4H6P9R7\nCheck out our privacy policy for any concerns, if any concerns pop up, please send over a message to my email: darkifiedd@gmail.com\n\nI've spent approximately 4-6 months alone learning how to use unity, on a previous game that I had named \"Ape City\", on top of another 6 months put into gelada + grand highlands..\n\nThis game is basically the re-embarkment of GELADA and Unreleased Grand Highlands!\n\nWith the help of Malex (developer of Just Chimpin + Grenade Game) (who is also the coder) we managed to develop the game you currently know as \"NIGHTFALL VR\"\n\nThank you all, seriously, it means a lot.\n\nAlso P.S. \nWatch out for \"big john\"...", "short_description": "Welcome to NIGHTFALL VR!\n\nAny ideas will be credited in a little secret compartment in-game!\n\nDrop some down in our DISCORD: https://discord.gg/CNr4H6P9R7\n\nCheck out our privacy policy for any concerns, if any concerns pop up, please send over a message to my email: darkifiedd@gmail.com\n\nThis game is basically the re-embarkment of GELADA and Unreleased Grand Highlands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/nightfall-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "robbedauthor", "support_website_url": null, "website_url": "https://sites.google.com/view/nightfall-vr/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7352166158219718"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974850_1688109111954730_4543412926231650288_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yAVYz7gOfogQ7kNvgEZ9UeY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwDUHpb-ZhywHgqbdavJ_ip&oh=00_AYBoEQNSYHqitV8qu_0cfFAzhBHNwV5ymXLfYORfJ7RNdQ&oe=66E2CD59"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Nightfall VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Horror", "id": "411892083130028"}], "release_date":