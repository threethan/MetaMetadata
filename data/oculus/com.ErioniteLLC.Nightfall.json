9R7\n\nCheck out our privacy policy for any concerns, if any concerns pop up, please send over a message to my email: darkifiedd@gmail.com\n\nThis game is basically the re-embarkment of GELADA and Unreleased Grand Highlands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/nightfall-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "robbedauthor", "support_website_url": null, "website_url": "https://sites.google.com/view/nightfall-vr/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7352166158219718"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1989782878121079"}]}, "baseline_offer": {"id": "1989782878121079"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725570060, "status": "PUBLISHED", "id": "1989782878121079"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7404948002941533", "version": "3.5"}, "id": "26195932403383413", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7234556166647385", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "