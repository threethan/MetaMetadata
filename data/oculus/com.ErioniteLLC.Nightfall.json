=AN2dfcTsDqEPgAUN8o44RdW&oh=00_AYBhGehpgdggOS5afujKMx1XzhSecYxZMgb-4P_SvyuHXw&oe=66E58224"}, {"file_name": "nightfall screenshot 3.png", "id": "1065599051793145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003255_1065599055126478_5756926247023560827_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YUOTJlQ0ExYQ7kNvgEjXD6a&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN2dfcTsDqEPgAUN8o44RdW&oh=00_AYDLm2TnhDMdWQQMokWPG9GXpS-GixptM5slXhZGLHNN5g&oe=66E586DE"}, {"file_name": "nightfall screenshot 2.png", "id": "1497879470857351", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001672_1497879474190684_2876899868746329028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F2db6gaY6uYQ7kNvgF8emBw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN2dfcTsDqEPgAUN8o44RdW&oh=00_AYC-j9p32BYLQSNOay4VjGYkmGm2h5g6xfyLrJWxtNGXVQ&oe=66E55C2F"}, {"file_name": "nightfall screenshot 5.png", "id": "388945917321262", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031338_388945920654595_4821277616870504580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2KNGTQ4LuWoQ7kNvgG3nGWx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN2dfcTsDqEPgAUN8o44RdW&oh=00_AYCJeImDhOInVynAPUvIA6CfNN-8jHOHmp4t49vxxWl0Dw&oe=66E588D8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Nightfall VR", "keywords": ["nightfall", "vr", "applab", "ape", "gorilla"], "long_description": "Welcome to NIGHTFALL VR!\n\nThis is one of my first official larger projects.\nI plan on Implenting a TON of community ideas, for that join our discord.\n\nDrop some down in our DISCORD: https://discord.gg/CNr4H6P9R7\nCheck out our privacy policy for any concerns, if any concerns pop up, please send over a message to my email: darkifiedd@gmail.com\n\nI've spent approximately 4-6 months alone learning how to use unity, on a previous game that I had named \"Ape City\", on top of another 6 months put into gelada + grand highlands..\n\nThis game is basically the re-embarkment of GELADA and Unreleased Grand Highlands!\n\nWith the help of Malex (developer of Just Chimpin + Grenade Game) (who is also the coder) we managed to develop the game you currently know as \"NIGHTFALL VR\"\n\nThank you all, seriously, it means a lot.\n\nAlso P.S. \nWatch out for \"big john\"...", "short_description": "Welcome to NIGHTFALL VR!\n\nAny ideas will be credited in a little secret compartment in-game!\n\nDrop some down in our DISCORD: https://discord.gg/CNr4H6P9R7\n\nCheck out our privacy policy for any concerns, if any concerns pop up, please send over a message to my email: darkifiedd@gmail.com\n\nThis game is basically the re-embarkment of GELADA and Unreleased Grand Highlands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/nightfall-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "robbedauthor", "support_website_url": null, "website_url": "https://sites.google.com/view/nightfall-vr/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7352166158219718"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1989782878121079"}]}, "baseline_offer": {"id": "1989782878121079"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725570060, "status": "PUBLISHED", "id": "1989782878121079"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "