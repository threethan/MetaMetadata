_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982580_145041237629625_498631781817361731_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oQMnOpH-xQ0Q7kNvgGjAvl8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYDoQS_WlyswUIU3s8NrKzdLaD6ylviWknBVqLVjq3InKg&oe=66E8151D"}]}, "id": "698780072087118", "locale": "en_US", "screenshots": [{"file_name": "1-1920x1080.png", "id": "803649134572389", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031619_803649137905722_170842031963031386_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p0xsjs-hks0Q7kNvgGbPgyb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYALji4DE2wlmVGKyK8DkwOzEDBGEly3SPmAONict0NUUw&oe=66E8234A"}, {"file_name": "3-1920x1080.png", "id": "6579688432070611", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035399_6579688435403944_6734398833906805652_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvhsmdtNpdsQ7kNvgF1FluQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYDPmFoHigoUlGSfSqGvwSceUxuA2NQUWU1-9S9YuUX8tg&oe=66E81DAC"}, {"file_name": "5-1920x1080.png", "id": "994754088540604", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334061_994754091873937_780412884863557905_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XyhJRel7TdIQ7kNvgHPQvf8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYDMD6YMO3hNue_79iw2AHFd2UuyeZ7GZjGkJ47WY3KFdA&oe=66E821D9"}, {"file_name": "4-1920x1080.png", "id": "1469036003906062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031532_1469036007239395_8124749733482704612_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRPZDyeWZK0Q7kNvgEa8eHI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYCnPL6PFxQfInEu3WpSOk30ILd0rgIbJvHvPE1bLkzkOA&oe=66E7FC34"}, {"file_name": "7-1920x1080.png", "id": "1495932617907053", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974792_1495932621240386_2241871267103140926_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BudZMS5BNdsQ7kNvgG3o73U&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYCLy3nwc6ff7i48K-n41uIbTy50QQbnG7U7IAXKXkEKAQ&oe=66E80F14"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lCMIn8MLDRYQ7kNvgFshYyt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYDS3QScaRDlACYMuPiBTHnkH4rE1rYxKB5qW2thLSpcLA&oe=66E82186"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Embark on an exhilarating journey through history with Dogfight Elite, a thrilling combat simulator set against the monumental backdrop of World War I and II.\n\nBecome the master of the skies in Dogfight Elite. Commandeer the cockpit of a warplane, spearhead a tank into battle, or bravely face the enemy on foot as a resilient soldier. The battlefield has never felt this real and the stakes this high.\n\nTest your mettle in solo play, navigating through meticulously designed training missions that escalate to adrenaline-charged, full-scale aerial dogfights against relentless enemy combatants.\n\nWhile Dogfight Elite is free-to-play, opting for a subscription unlocks a treasure trove of exclusive benefits. Take to the skies or the battlefield with premium airplanes, tanks, and specially-crafted weapons, and embark on captivating, subscriber-only missions.\n\n\nMoreover, subscribing allows you instant access to our servers and priority queuing, ensuring that your historic battles remain uninterrupted. Experience the past like never before with Dogfight Elite - the battlefield is waiting for you.\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]}, "developer_name": "Joaquin Grech", "developer_privacy_policy_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "developer_terms_of_service_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "publisher_name": "Joaquin grech", "support_website_url": null, "website_url": "https://www.dogfightelite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "pt", "en", "pt_BR", "it", "fr", "es", "zh_TW", "ja", "zh_CN", "nl"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "685358710135517"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036664_1059383164590707_2819260594449385590_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6CH27j5btjIQ7kNvgEq44VG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZI7Ca66DVCo5_yCyOs1fTA&oh=00_AYAOknxnQcZBXpv-at08qdPp4u0c_z4dIxqOQ3l2VEOdLQ&oe=66E80586"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dogfight Elite", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2