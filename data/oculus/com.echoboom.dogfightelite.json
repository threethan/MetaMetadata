31_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3yr-QmJ6zwQQ7kNvgGnbVF7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAe82fuCgwln4dKBD1Q-85Lk9VfWmQr1Bfu_i0Qxda9A&oe=670A5C1D"}]}, "id": "698780072087118", "locale": "en_US", "screenshots": [{"file_name": "1-1920x1080.png", "id": "803649134572389", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031619_803649137905722_170842031963031386_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I2RSq7SpjbQQ7kNvgFAawgk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcqh3FRazv-L1gae1U3TiA9ZMeQvc3d-ycL49d_Xl6uQ&oe=670A6A4A"}, {"file_name": "3-1920x1080.png", "id": "6579688432070611", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035399_6579688435403944_6734398833906805652_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oXlz91tPAFgQ7kNvgGQfQMd&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhKnS2aBlOBPhfZr-C5kfuBDFH8fprtrHzNfeh7vFNBw&oe=670A64AC"}, {"file_name": "5-1920x1080.png", "id": "994754088540604", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75334061_994754091873937_780412884863557905_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8VkjKUFYBdwQ7kNvgGnvlLb&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3KWT-u0P0g_p58WGKy14hdnMmyOMnuCz1KIpy3ephAQ&oe=670A68D9"}, {"file_name": "4-1920x1080.png", "id": "1469036003906062", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031532_1469036007239395_8124749733482704612_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WCAqrb460usQ7kNvgEpJ7GP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDySKdGXNk944ZXxLi1YJE6VFuiQPow9ueELI5HjRBNUA&oe=670A7B74"}, {"file_name": "7-1920x1080.png", "id": "1495932617907053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974792_1495932621240386_2241871267103140926_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JlXqd8VhCvwQ7kNvgEVUuzI&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYxA58jMWEiY5hLtux53njZh-TzcMv3sebw2e-MRcsjw&oe=670A5614"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u5f4PAv9CnkQ7kNvgGQvLqk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQA3Blh7chgsKgHoHI3VztSc3RtjOhO292RL23W4zLrA&oe=670A6886"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Embark on an exhilarating journey through history with Dogfight Elite, a thrilling combat simulator set against the monumental backdrop of World War I and II.\n\nBecome the master of the skies in Dogfight Elite. Commandeer the cockpit of a warplane, spearhead a tank into battle, or bravely face the enemy on foot as a resilient soldier. The battlefield has never felt this real and the stakes this high.\n\nTest your mettle in solo play, navigating through meticulously designed training missions that escalate to adrenaline-charged, full-scale aerial dogfights against relentless enemy combatants.\n\nWhile Dogfight Elite is free-to-play, opting for a subscription unlocks a treasure trove of exclusive benefits. Take to the skies or the battlefield with premium airplanes, tanks, and specially-crafted weapons, and embark on captivating, subscriber-only missions.\n\n\nMoreover, subscribing allows you instant access to our servers and priority queuing, ensuring that your historic battles remain uninterrupted. Experience the past like never before with Dogfight Elite - the battlefield is waiting for you.\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]}, "developer_name": "Joaquin Grech", "developer_privacy_policy_url": "https://www.dogfightelite.com/index.php/forum/4-