zC_D&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYAFC1EAque0f_eEcSQengl9L9XW0h5dj_Rd95wqr_BrDg&oe=66EE92A1"}, {"file_name": "oculus1-2208-1242.png", "id": "293792798916275", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974782_293792802249608_7936629733027416788_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vSo1xDJfGj8Q7kNvgFmgeZF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYBBs8aTGMltbLvy8H1z8k5sYjn-PBJ0ra9PtzngDfQCzQ&oe=66EEAE87"}, {"file_name": "oculus8-2208-1242.png", "id": "472321097432652", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974560_472321100765985_4905042618142418142_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5JIPWLuej14Q7kNvgG-OXtn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYDhF02ePZLt--3VnIjJbjQO8VQwpaQHgQcm815rerBKCw&oe=66EEA633"}, {"file_name": "oculus9-2208-1242.png", "id": "1002688936932771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984470_1002688946932770_784443334179831915_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_nyoEpS6vsQ7kNvgGzkWkM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYBGSzaOUBIAR6wK38pRce9t3fPOl1O3CeS_ScDm9UJSog&oe=66EEBD57"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVTLcxZCuBQQ7kNvgGSynS_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYA368EApH704AHalpONS9hqVcm3k6401vecVwR-LeK8JQ&oe=66EEB906"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Dogfight Elite is a World War I and World War II massive combat airplane simulator.\n\nIn Dogfight Elite you can fly an airplane, drive a tank or jump out of the plane and defend your position as a soldier.\n\nYou can also play alone and fly through training levels all the way up to full-blown dogfights against enemy planes.\n\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]}, "developer_name": "Joaquin Grech", "developer_privacy_policy_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "developer_terms_of_service_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "publisher_name": "Joaquin grech", "support_website_url": null, "website_url": "https://www.dogfightelite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "pt", "en", "pt_BR", "it", "fr", "es", "zh_TW", "ja", "zh_CN", "nl"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "942353629979707"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "2997853187152412"}, {"status": "PUBLISHED", "id": "722531825428163"}, {"status": "PUBLISHED", "id": "3081813985407251"}, {"status": "PUBLISHED", "id": "2472800792922118"}, {"status": "PUBLISHED", "id": "3080095578951979"}]}, "baseline_offer": {"id": "3080095578951979"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1635287100, "status": "PUBLISHED", "id": "2997853187152412"}]}, "liveChannel": {"node