31_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZTEeskGaW8YQ7kNvgGao92h&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYD5WtiHmh9wNxFwR1IL2NKo72oP7J9kOQs0B5uVO6zQPg&oe=670BAD9D"}]}, "id": "698780072087118", "locale": "en_US", "screenshots": [{"file_name": "1-1920x1080.png", "id": "803649134572389", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031619_803649137905722_170842031963031386_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O9dZRJCL1QIQ7kNvgFohp7e&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCdHXUnGybRmxsPlhHkNQQME6fnm1799xC-GuwUkj1Z7w&oe=670BBBCA"}, {"file_name": "3-1920x1080.png", "id": "6579688432070611", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035399_6579688435403944_6734398833906805652_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Shdc9e5OLEUQ7kNvgF6xP9O&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDyVrhmj5a5ZUUiFsCi-w-fYhXQGcckPA7jrxA5zEgyow&oe=670BB62C"}, {"file_name": "5-1920x1080.png", "id": "994754088540604", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75334061_994754091873937_780412884863557905_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tNpO3P8yLJsQ7kNvgGsFdiH&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAytJHNtAXibCHKTo_txp4nw0_VNifzEC6OPg0oFlXedQ&oe=670BBA59"}, {"file_name": "4-1920x1080.png", "id": "1469036003906062", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031532_1469036007239395_8124749733482704612_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9GJS0Iev4kQ7kNvgEo0DV_&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBbK6AZoDvAY1JnUopfNowOZMMeu65hL7utEn3pOE-NLw&oe=670BCCF4"}, {"file_name": "7-1920x1080.png", "id": "1495932617907053", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974792_1495932621240386_2241871267103140926_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JlXqd8VhCvwQ7kNvgFvJDWL&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBlG03jQlEk-2quMh2p8B9C3ZMtPDngsiwI0JiNlZ6qaQ&oe=670BA794"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-8cJiRfXIJ4Q7kNvgGL015C&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDU_NrV3FS1AV7OVW8uLhIYzWPTXPdiG6Nuh3rjbbR5ZQ&oe=670BBA06"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Embark on an exhilarating journey through history with Dogfight Elite, a thrilling combat simulator set against the monumental backdrop of World War I and II.\n\nBecome the master of the skies in Dogfight Elite. Commandeer the cockpit of a warplane, spearhead a tank into battle, or bravely face the enemy on foot as a resilient soldier. The battlefield has never felt this real and the stakes this high.\n\nTest your mettle in solo play, navigating through meticulously designed training missions that escalate to adrenaline-charged, full-scale aerial dogfights against relentless enemy combatants.\n\nWhile Dogfight Elite is free-to-play, opting for a subscription unlocks a treasure trove of exclusive benefits. Take to the skies or the battlefield with premium airplanes, tanks, and specially-crafted weapons, and embark on captivating, subscriber-only missions.\n\n\nMoreover, subscribing allows you instant access to our servers and priority queuing, ensuring that your historic battles remain uninterrupted. Experience the past like never before with Dogfight Elite - the battlefield is waiting for you.\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]}, "developer_name": "Joaquin Grech", "developer_privacy_policy_url": "https://www.dogfightelite.com/index.php/forum/4-