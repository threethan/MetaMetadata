e7a0a&_nc_ohc=WrQtKN6QQ_cQ7kNvgHDLrUT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYAFip_1RNESBd7n3AyQWPEkKdYhzIegjGiM-W9BuawGcg&oe=66EEA694"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVTLcxZCuBQQ7kNvgGSynS_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYA368EApH704AHalpONS9hqVcm3k6401vecVwR-LeK8JQ&oe=66EEB906"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Embark on an exhilarating journey through history with Dogfight Elite, a thrilling combat simulator set against the monumental backdrop of World War I and II.\n\nBecome the master of the skies in Dogfight Elite. Commandeer the cockpit of a warplane, spearhead a tank into battle, or bravely face the enemy on foot as a resilient soldier. The battlefield has never felt this real and the stakes this high.\n\nTest your mettle in solo play, navigating through meticulously designed training missions that escalate to adrenaline-charged, full-scale aerial dogfights against relentless enemy combatants.\n\nWhile Dogfight Elite is free-to-play, opting for a subscription unlocks a treasure trove of exclusive benefits. Take to the skies or the battlefield with premium airplanes, tanks, and specially-crafted weapons, and embark on captivating, subscriber-only missions.\n\n\nMoreover, subscribing allows you instant access to our servers and priority queuing, ensuring that your historic battles remain uninterrupted. Experience the past like never before with Dogfight Elite - the battlefield is waiting for you.\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]}, "developer_name": "Joaquin Grech", "developer_privacy_policy_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "developer_terms_of_service_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "publisher_name": "Joaquin grech", "support_website_url": null, "website_url": "https://www.dogfightelite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "pt", "en", "pt_BR", "it", "fr", "es", "zh_TW", "ja", "zh_CN", "nl"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "685358710135517"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036664_1059383164590707_2819260594449385590_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zajwkl_jJ4cQ7kNvgGkBj15&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVcZMRR6m3wu3lBCnhpaZCq&oh=00_AYATjI6KaYGHXqIqOsnEDeuHZowrsbb_yeAeicoMHXipcw&oe=66EE9D06"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dogfight Elite", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427