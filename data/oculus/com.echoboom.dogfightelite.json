/t64.5771-25/38982580_145041237629625_498631781817361731_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WWKw5ciFcZYQ7kNvgHbhuyB&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAqdKvFJbxGRUqPK1iCpOpJ99lNErwGBMPNe3jG27v8tA&oe=6786491D"}]}, "id": "698780072087118", "locale": "en_US", "screenshots": [{"file_name": "1-1920x1080.png", "id": "803649134572389", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031619_803649137905722_170842031963031386_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vvZYFgl45FUQ7kNvgE3uexK&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBJxarWYAO25jnKW4ZFkTn0oUnsh2Ce_PsUNpmgLYLw2w&oe=6786574A"}, {"file_name": "3-1920x1080.png", "id": "6579688432070611", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035399_6579688435403944_6734398833906805652_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dUBCQ9B469IQ7kNvgHfEZjZ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAJriqa8K_igHGeylBphqP-X_vcgHzNVTPZYPruD02zrw&oe=678651AC"}, {"file_name": "5-1920x1080.png", "id": "994754088540604", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75334061_994754091873937_780412884863557905_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=utfjkjFOJ8wQ7kNvgGsPFD5&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCDgRxarpkhz8_iUNGhPtA8PcbY6iAJbm8ypPgOL5FKuw&oe=678655D9"}, {"file_name": "4-1920x1080.png", "id": "1469036003906062", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031532_1469036007239395_8124749733482704612_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nGB6dpxPUfcQ7kNvgFqx3Tc&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDkCfy4qbrtIjVDOYbVRfdNQtYyFdkFaH2TFwqEKJbcww&oe=67866874"}, {"file_name": "7-1920x1080.png", "id": "1495932617907053", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974792_1495932621240386_2241871267103140926_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zX0RHOUf-UgQ7kNvgEgOekU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCikMKycuJVhp8oSgy-CLpDMNNX2Y_l2zobPHtVo-snWA&oe=67864314"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m1ZbvOYrU3MQ7kNvgFM-jw3&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCXK_SglWrF1Avms7b-DrE4FPFUMgUGVIPJ01QHOCdF6w&oe=67865586"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Embark on an exhilarating journey through history with Dogfight Elite, a thrilling combat simulator set against the monumental backdrop of World War I and II.\n\nBecome the master of the skies in Dogfight Elite. Commandeer the cockpit of a warplane, spearhead a tank into battle, or bravely face the enemy on foot as a resilient soldier. The battlefield has never felt this real and the stakes this high.\n\nTest your mettle in solo play, navigating through meticulously designed training missions that escalate to adrenaline-charged, full-scale aerial dogfights against relentless enemy combatants.\n\nWhile Dogfight Elite is free-to-play, opting for a subscription unlocks a treasure trove of exclusive benefits. Take to the skies or the battlefield with premium airplanes, tanks, and specially-crafted weapons, and embark on captivating, subscriber-only missions.\n\n\nMoreover, subscribing allows you instant access to our servers and priority queuing, ensuring that your historic battles remain uninterrupted. Experience the past like never before with Dogfight Elite - the battlefield is waiting for you.\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]},