ontent.oculuscdn.com&oh=00_AYBRh6qRmuv1wA9WMstp3kWE_Vg4OVmHm8tssl4CWerWqQ&oe=66D1AB9D"}]}, "id": "698780072087118", "locale": "en_US", "screenshots": [{"file_name": "1-1920x1080.png", "id": "803649134572389", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031619_803649137905722_170842031963031386_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7uACT3hbB_MQ7kNvgERlAz4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlaXPh2-J7tX15K-nxdQpIN_QP7hIGfcXToEGPQ4-u2A&oe=66D1B9CA"}, {"file_name": "3-1920x1080.png", "id": "6579688432070611", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035399_6579688435403944_6734398833906805652_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g6WMk_jrt-wQ7kNvgG_hsn5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBOoXfU9upq2FVr5iHHQJ85nv_-j3K4QNkCU6hSU1rEjw&oe=66D1B42C"}, {"file_name": "5-1920x1080.png", "id": "994754088540604", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334061_994754091873937_780412884863557905_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-6c9bpIE-sQ7kNvgFsk1i1&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3yEMhTCATaT7ezLILNLwO-R-HKlOASqhh01o5rDsKPw&oe=66D1B859"}, {"file_name": "4-1920x1080.png", "id": "1469036003906062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031532_1469036007239395_8124749733482704612_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=glyRelOABIQQ7kNvgHUdIlI&_nc_ht=scontent.oculuscdn.com&oh=00_AYDAq0-WvUUdXGX6enC5JilW1jUBTDLTkhHJqJFgbQYQHA&oe=66D192B4"}, {"file_name": "7-1920x1080.png", "id": "1495932617907053", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974792_1495932621240386_2241871267103140926_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kGZeus9TBQ4Q7kNvgF7O1tI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCr0g57OfFZvEtNbj0zHc_ctzJtP_KOdwLIqDX99YXRaw&oe=66D1A594"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage2560.png", "id": "1171525093276710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982681_1171525096610043_1669834911006050355_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OT90gvtqFvoQ7kNvgGqGKGP&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnAPU0u1xMFPtjVloETkbP3Ni9nUgLlXVtBSTzWUekmA&oe=66D1B806"}, "display_name": "Dogfight Elite", "keywords": [], "long_description": "Embark on an exhilarating journey through history with Dogfight Elite, a thrilling combat simulator set against the monumental backdrop of World War I and II.\n\nBecome the master of the skies in Dogfight Elite. Commandeer the cockpit of a warplane, spearhead a tank into battle, or bravely face the enemy on foot as a resilient soldier. The battlefield has never felt this real and the stakes this high.\n\nTest your mettle in solo play, navigating through meticulously designed training missions that escalate to adrenaline-charged, full-scale aerial dogfights against relentless enemy combatants.\n\nWhile Dogfight Elite is free-to-play, opting for a subscription unlocks a treasure trove of exclusive benefits. Take to the skies or the battlefield with premium airplanes, tanks, and specially-crafted weapons, and embark on captivating, subscriber-only missions.\n\n\nMoreover, subscribing allows you instant access to our servers and priority queuing, ensuring that your historic battles remain uninterrupted. Experience the past like never before with Dogfight Elite - the battlefield is waiting for you.\n\nIf you have any requests/complaints please visit www.dogfightelite.com forums.\nI keep track of all requests and complaints and fix them on each release. Write the details or contact me on the website. I will read your posts and fix it asap!", "short_description": "Online massive airplane combats against real pilots, tanks, and foot soldiers."}]}, "developer_name": "Joaquin Grech", "developer_privacy_policy_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-terms-of-use", "developer_terms_of_service_url": "https://www.dogfightelite.com/index.php/forum/4-announcements/1058-privacy-policy-and-te