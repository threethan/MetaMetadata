e_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207242_461701129401563_8672844182522431488_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hSYd15ogTYEQ7kNvgGqaWkM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVYXEI5ItqlvlzzBvlT9vbqRUzMg5Zn0okbSu1uw-Gxg&oe=67695808"}]}, "id": "280734714282447", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "814339426521486", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974812_814339429854819_6369558032204571690_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D9AkNO1TjpcQ7kNvgFBqPLI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7PEyUdtR_24oKzx_4Glvn-jbYx_5g06P884UDDfxRHA&oe=676938E2"}, {"file_name": "2.png", "id": "502647738253174", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974653_502647741586507_5004657426589419612_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3C367X9RErsQ7kNvgGKMJ-t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4NbNzzPd1BZsZZ4a3aqfFVCeSDa7DN92qPsnimeng-g&oe=676967F3"}, {"file_name": "3.png", "id": "3272109159694171", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422391_3272109163027504_5744939719503962374_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z_QJ_kmBsVUQ7kNvgFwJKsY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdZL3H1pt5iYtxZTDAqPnDZBW0qzxFtFQ_abMWKMm3JQ&oe=6769432B"}, {"file_name": "4.png", "id": "1076538199676004", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75234365_1076538203009337_4076126856633674673_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oFkGuU8VteQQ7kNvgGUDYw6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDq8b927mIhzx7xwdpnD2H_rueydJSwz2yErM9SSHwfjA&oe=67693DBD"}, {"file_name": "5.png", "id": "664149641982555", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974554_664149645315888_1329152045526098657_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aNu3dw9blz4Q7kNvgGfr-LL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCuNPpnvt18YCIlrr6v4RD6jNhEop9pGOHCbIGnUXCqyA&oe=67696767"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Touchly Volumetric VR Video Player", "keywords": [], "long_description": "Touchly is the next evolution of the VR video player. Turn videos into volumetric, immersive experiences.\n\nIt features:\n- Virtual hands that react to the video environment.\n- Six-degrees-of-freedom playback: Reduce eye strain and move freely with position tracking.\n- Passthrough mode: Bring videos to your reality. Hologram-like.\n- Play in most of the common layouts (180/360/Flat in Stereo/Mono) and formats (mp4, avi, mkv, mov, webm).\n\nOther features include:\n- Local streaming: With our new server app Touchly Cast.\n- Hand tracking support.\n- TactGlove support for haptics.\n- Advanced settings: Rotation, position, color adjustment, depth adjustments, etc.\n- Depth and Color matting for passthrough.\n- Watch local or remote files with streaming.\n- Customizable hands.\n\nImportant note: To watch videos in volumetric mode, they need to be converted first with Touchly Renderer (touchly.app/renderer). Only a couple of demo videos are included in the app.", "short_description": "Touchly is the next evolution of the VR video player.\nWith its own volumetric video format, it makes it possible to:\n\n-Boost inmersion with virtual hands that react to the video environment, haptic feedback included.\n-Watch in six-degrees-of-freedom: Reduce eye strain and move freely with position tracking.\n-Passthrough mode: Bring videos to your reality.\n\nOn top of that, Touchly supports most of the common VR layouts (180/360/Flat in Stereo/Mono)."}]}, "developer_name": "Touchly", "developer_privacy_policy_url": "https://touchly.app/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Touchly", "support_website_url": null, "website_url": "http://touchly.app/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [],