, "video_trailer_thumbnail": null, "display_name": "Touchly Volumetric VR Video Player", "keywords": [], "long_description": "Touchly is the next evolution of the VR video player.\nWith its own volumetric video format, it makes it possible to:\n\n-Boost inmersion with virtual hands that react to the video environment, haptic feedback included.\n-Watch in six-degrees-of-freedom: Reduce eye strain and move freely with position tracking.\n-Passthrough mode: Bring videos to your reality.\n\nOn top of that Touchly supports most of the common layouts (180/360/Flat in Stereo/Mono) and formats (mp4, avi, mkv, mov, webm).\n\nImportant note: To watch videos in volumetric mode, they need to be converted first with Touchly Renderer (touchly.app/renderer). Only a couple of demo videos are included in the app.", "short_description": "Touchly is the next evolution of the VR video player.\nWith its own volumetric video format, it makes it possible to:\n\n-Boost inmersion with virtual hands that react to the video environment, haptic feedback included.\n-Watch in six-degrees-of-freedom: Reduce eye strain and move freely with position tracking.\n-Passthrough mode: Bring videos to your reality.\n\nOn top of that, Touchly supports most of the common VR layouts (180/360/Flat in Stereo/Mono)."}]}, "developer_name": "Touchly", "developer_privacy_policy_url": "https://touchly.app/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Touchly", "support_website_url": null, "website_url": "http://touchly.app/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported