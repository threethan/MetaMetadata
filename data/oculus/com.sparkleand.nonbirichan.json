 enjoy a relaxed and unhurried experience. There are six different spaces available, each with its own unique ambiance. (The number of spaces is expected to increase in the future.) These spaces encompass various settings, such as a crackling campfire or a tranquil rain environment. There are no time constraints, allowing you to spend as much time as you like in each space. To exit a space, simply press the home button located within each area to return to the main menu. Now, please have a wonderful time enjoying this app.", "short_description": "This app provides a space to soothe busy individuals and those pressed for time. Please enjoy a leisurely time in a comfortable environment with calming ambiance and sound."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sparkleand.store/vr-privacy-policy", "developer_terms_of_service_url": "https://www.sparkleand.store/terms-and-conditions", "publisher_name": "Sparkle and, Inc.", "support_website_url": null, "website_url": "https://www.sparkleand.store/nonbiri-relax", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "549438580565712"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2707824242693667"}]}, "baseline_offer": {"id": "2707824242693667"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1689174869, "status": "PUBLISHED", "id": "2707824242693667"}]