_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=30rMMX5A2_4Q7kNvgGTB8X3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNqAE2ZpO0_wJ1slk89kQsTXf_t2z1YsoNDeBA_lCVLw&oe=674C6859"}, {"file_name": "58099b58f6d88f0c541e27d0243e2bbe (1) (1).png", "id": "1996087570748583", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569430_1996087577415249_311313702587003460_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ZkpetQleR8Q7kNvgG2FM9a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTGLCSFmCjezoSahGsOzVsFucQhT1dQXgRk31bJr0adA&oe=674C5536"}, {"file_name": "3de8fa5f86cd447476c4c61a962dcd7d (1) (1).png", "id": "602798271942533", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031456_602798278609199_2456997631010076673_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zt-3oNMoX6EQ7kNvgFdxe3Q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCXuSLMfbt5zOWmsmc7fXDaRUSE_pyV2N6J_-bHhZfgEw&oe=674C329E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u540d\u79f0\u672a\u8a2d\u5b9a\u306e\u30c7\u30b6\u30a4\u30f3 (1) (1).png", "id": "266362419322952", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982674_266362422656285_7956766679824628207_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c3njgk5LYMEQ7kNvgF4RSXP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBAMo4i3U8toXuHigoF4pEphOf49N3yDs3vlcz3qyOew&oe=674C6864"}, "display_name": "Nonbiri Relax", "keywords": [], "long_description": "\"Nonbiri\" in Japanese translates to \"spending leisurely\" or \"taking it easy.\" As the name suggests, this app allows you to enjoy a relaxed and unhurried experience. There are six different spaces available, each with its own unique ambiance. (The number of spaces is expected to increase in the future.) These spaces encompass various settings, such as a crackling campfire or a tranquil rain environment. There are no time constraints, allowing you to spend as much time as you like in each space. To exit a space, simply press the home button located within each area to return to the main menu. Now, please have a wonderful time enjoying this app.", "short_description": "This app provides a space to soothe busy individuals and those pressed for time. Please enjoy a leisurely time in a comfortable environment with calming ambiance and sound."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sparkleand.store/vr-privacy-policy", "developer_terms_of_service_url": "https://www.sparkleand.store/terms-and-conditions", "publisher_name": "Sparkle and, Inc.", "support_website_url": null, "website_url": "https://www.sparkleand.store/nonbiri-relax", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "549438580565712"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974844_640477658014680_8429518960066707207_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=14ZKnjLPKV8Q7kNvgFU17MI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnnqMWvBgAxxJlFQxo2twCEgl2Z9Kza0zj_fxFmfYSBA&oe=674C4021"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Nonbiri Relax", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}], "releas