e control over your journey into VR and make StartVR your hub for the the best virtual content.\n\nPlayback supports DLNA, web streaming, AND local files too\nCompletely customizable: adjust every element for your unique preferences\nPlayer is free for all users\n\nDownload our free VR player for streaming the best VR from your favorite websites. Be immersed and enjoy 8K, 3D, 180 experience with StartVR.\n\nPlease send questions and feedback to support@startvr.io", "short_description": "Start Loving Virtual Reality! Download our new, free VR Video Player and enjoy immersive VR videos with StartVR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://startvr.io/privacy-policy.php", "developer_terms_of_service_url": null, "publisher_name": "StartVR", "support_website_url": null, "website_url": "https://startvr.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27359847220297047"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "911063764222366"}]}, "baseline_offer": {"id": "911063764222366"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729521180, "status": "PUBLISHED", "id": "911063764222366"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27783104164638