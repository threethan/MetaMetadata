974460_447713071666467_6974512133300380019_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5P-X4PeOI28Q7kNvgGL4srb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAcnjtWHotKi_QGjcCBkfliklWDBZLceTBFi46kCap36Q&oe=67333178"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "StartVR Streaming Video Player", "keywords": ["VR", "Player", "Entertainment", "Streaming"], "long_description": "Start loving virtual reality! Welcome to the immersive experience that is StartVR. This comprehensive VR video player works seamlessly with leading VR headsets.  With intuitive design and navigation, get the most from the VR content you love.\n\nYou'll have advanced playback features at your fingertips and engaging options such as passthrough menu, hand tracking and more. Take control over your journey into VR and make StartVR your hub for the the best virtual content.\n\nPlayback supports web streaming, AND local files too\nCompletely customizable: adjust every element for your unique preferences\nPlayer is free for all users\n\nDownload our free VR player for streaming the best VR from your favorite websites. Be immersed and enjoy 8K, 3D, 180 experience with StartVR.\n\nPlease send questions and feedback to support@startvr.io", "short_description": "Start Loving Virtual Reality! Download our new, free VR Video Player and enjoy immersive VR videos with StartVR Streaming Video Player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://startvr.io/privacy-policy.php", "developer_terms_of_service_url": null, "publisher_name": "StartVR", "support_website_url": null, "website_url": "https://startvr.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_M