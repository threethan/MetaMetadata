09724", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984467_543972025143057_5163642652238093882_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=46Cr4eXg8dcQ7kNvgEbNM6p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_bLlVuofBn-E8LKpuej6-ZBlocNSmmerAANeNQtFFOQ&oe=676E769A"}]}, "id": "549018184667481", "locale": "en_US", "screenshots": [{"file_name": "squatalgo-screenshots.001.png", "id": "1257737221828133", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031553_1257737225161466_6229836395132126708_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CeIbYSvcBOIQ7kNvgEItdTJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfr7MDF6TycSn-KJAUGdaMm4jGIVn3MZuJE4ppHzqtxA&oe=676E9D1F"}, {"file_name": "squatalgo-screenshots.007.png", "id": "542549011916562", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982660_542549015249895_3970411905852128113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=63YATn0MbrkQ7kNvgEMFJsf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7-HJgyJZjYSasXhhHFA67Ph_nEgMoWH5nniMcLoET3Q&oe=676E81D0"}, {"file_name": "squatalgo-screenshots.004.png", "id": "1911988715945325", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974788_1911988719278658_1659128526670207704_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiPAjFq2EWIQ7kNvgFfUKGJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAnnqTDLwov9ZrwuxNJRmzaYmClRwFWsaKQRb2A0zfLQ&oe=676EA3F2"}, {"file_name": "squatalgo-screenshots.003.png", "id": "890314119286508", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569433_890314122619841_5475700559104861154_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FXYvp5YYqSEQ7kNvgElExjB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBdTHJB5CLD9M1ERAKFjXj0tuA2rox3fU0KP7USYTJjQ&oe=676E9BB7"}, {"file_name": "squatalgo-screenshots.006.png", "id": "871350718518281", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982447_871350721851614_4619199838300267297_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ljsChuB4AYQ7kNvgHpFlos&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDC_9UxUPZ-rE1kOblGgd-21KajKFGJhKQXU76q0RNlUQ&oe=676E7BE0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "squatalgo-cover.002.png", "id": "885874123742544", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974503_885874127075877_5158945807031488383_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9h2OiDFWf8QQ7kNvgHjcanL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfBuXuTFZ-o77rohUJeUU1hrfKTcy1RQpQF-MX1P6LcA&oe=676EA14B"}, "display_name": "Fit Fight XR: Squat Strike", "keywords": ["fitness", "roguelike", "exercise", "workout", "bodycombat"], "long_description": "Power up your leg day with Fit Fight XR: Squat Strike! This immersive MR/VR roguelite fitness game transforms every squat, lunge, and hop into powerful attacks against epic enemies. Experience a full-throttle leg workout that's as fun as it is effective. Track your progress, earn rewards, and stay motivated as you level up your fitness journey. Fit Fight XR: Squat Strike turns exercise into an exciting adventure!\n\ud83e\uddb5 Leg-Focused Workouts: Squats, lunges, hops, and more to strengthen and tone your legs.\n\ud83c\udfae Gamified Fitness Combat: Engage in dynamic battles where your exercises transform into powerful attacks against enemies.\n\u2728 Unique Upgrades: Unlock different attacks each game, ensuring no two workouts are the same.\n\ud83d\udcc8 Progress Tracking: Monitor stats, and watch your fitness improve.\n\ud83c\udd95 Regular Updates: Fresh challenges and enemies added frequently to keep workouts exciting.\n\ud83d\ude0e MR & VR Modes: Choose between Mixed Reality and Virtual Reality for immersive gameplay.\n\ud83c\udfb5 Energetic Soundtrack: Pumping music to keep you moving and motivated.", "short_description": "Power up your leg day with Fit Fight XR: Squat Strike! This immersive MR/VR roguelite fitness game transforms every squat, lunge, and hop into powerful attacks against epic enemies. Experience a full-throttle leg workout that's as fun as it is effective. Fit Fight XR: Squat Strike turns exercise into an exciting adventure!\n\ud83e\uddb5 Leg-Focused Workouts\n\ud83c\udfae Gamified Fitness Combat\n\u2728 Unique Upgrades\n\ud83d\udcc8 Progress Tracking\n\ud83c\udd95 Regular Updates\n\ud83d\ude0e MR & VR Modes\n\ud83c\udfb5 Energetic Soundtrack"}]}, "developer_name": "Clarke Plumo", "developer_privacy_policy_url": "https://squathero.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Clarke Plumo", "support_website_url": null, "website_url": "https://squathero.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8929203583804394"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984467_543972025143057_5163642652238093882_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=46Cr4eXg8dcQ7kNvgEbNM6p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCOXG1TsKkiGI8cjsI_EP8IlmkN-IMh7y8PdrIWvmZC1w&oe=676E769A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Fit Fight XR: Squat Strike", "platform": "ANDROID_6DOF", "context_category": {"context_category"