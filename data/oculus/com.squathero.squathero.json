283674570469547_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZ9IZBatilcQ7kNvgHDoCOm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8N1_GhkT3eaOqtvVchR4P8NopXDUfSdy12vqwZRFMuw&oe=676E95DB"}, {"file_name": "squatalgo-cover-square.001.png", "id": "1511748273034350", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031437_1511748276367683_386070966891456230_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=81ACBkgsUL8Q7kNvgFO1tON&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHtbI0JUunNDJ7E4RWtcw-MwGoihzQxRQbPCuTDV2Pkw&oe=676E9843"}, {"file_name": "squatalgo-cover.001.png", "id": "1075101843962670", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982472_1075101847296003_7071109424866286831_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gi4MYBp0_jAQ7kNvgFxiitU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfQdr9NJGEzKpKWFQLHY5c5SCUuKhny_Vqm_GAYTrqvg&oe=676E834E"}, {"file_name": "squatalgo-cover-square.001.png", "id": "1067104901828749", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984444_1067104905162082_7174323460960401104_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nuzf3C2DFJYQ7kNvgEktiPg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3V-fqxchPnqLbjr43bpGJ1A2la4oXFw8tCP3YeulYmg&oe=676E7A40"}]}, "id": "593959008770678", "locale": "en_US", "screenshots": [{"file_name": "squatalgo-screenshots.002.png", "id": "894525618846287", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001703_894525622179620_1191092182876755522_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYy8uzHSzjYQ7kNvgEFfn00&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3WfAmbA5WicFAsQ4zVIkvo_00DSGs7MAVddOmZ5bPjQ&oe=676E9637"}, {"file_name": "squatalgo-screenshots.003.png", "id": "890314119286508", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569433_890314122619841_5475700559104861154_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FXYvp5YYqSEQ7kNvgElExjB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBdTHJB5CLD9M1ERAKFjXj0tuA2rox3fU0KP7USYTJjQ&oe=676E9BB7"}, {"file_name": "squatalgo-screenshots.001.png", "id": "1257737221828133", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031553_1257737225161466_6229836395132126708_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CeIbYSvcBOIQ7kNvgEItdTJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfr7MDF6TycSn-KJAUGdaMm4jGIVn3MZuJE4ppHzqtxA&oe=676E9D1F"}, {"file_name": "squatalgo-screenshots.005.png", "id": "857371739856487", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031533_857371743189820_4863153210978740636_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t0A6TdKDc4kQ7kNvgH1Piur&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYfCPbIbMXDXHyZKSYYYsn-7OpWq9pwZBfURh8c6TE5Q&oe=676EA94F"}, {"file_name": "squatalgo-screenshots.004.png", "id": "1911988715945325", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974788_1911988719278658_1659128526670207704_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiPAjFq2EWIQ7kNvgFfUKGJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAnnqTDLwov9ZrwuxNJRmzaYmClRwFWsaKQRb2A0zfLQ&oe=676EA3F2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Squat Algorithm", "keywords": ["squat", "jab", "uppercut", "roguelike", "roguelite"], "long_description": "The Squat Algorithm is an action-packed roguelite fitness game where players use real-life movements to unleash attacks on waves of enemies. By performing jabs, hooks, uppercuts, lateral raises, squats, lunges, hops, and side steps, players fire powerful projectiles. While the movements are challenging, even minimal effort can deliver full damage, making the game accessible yet physically engaging.\n\nPlayers will encounter a variety of enemies, including treants, bats, and wolves. As they progress, they will face massive boss enemies like towering golems and armored giant beetles, which require strategy and agility to defeat.\n\nThroughout the game, players will meet young Elemental Guardians, who bestow special elemental abilities. These powers enhance both attacks and defense, granting effects like Exploding Projectiles, Revenge Damage, Double Strike Chance, and debuffs such as Slow, Blind, or Paralyze. Elemental enhancements can also be applied to leg movements, such as performing dark-element squats or unleashing fire-boosted uppercuts.\n\nWith random enemy waves and evolving elemental abilities, Squat Hero offers a thrilling combination of fitness-based gameplay and strategic upgrades, challenging players to stay active and think on their feet as they battle through increasingly difficult foes.", "short_description": "The Squat Algorithm is a fitness-based roguelite where players use real-life movements like jabs, hooks, squats, and lunges to attack enemies. Players face off against creatures like treants, bats, wolves, and massive bosses like golems and giant beetles. Young Elemental Guardians grant special powers such as Paralyzing projectiles and elemental squats. With random enemy waves and evolving abilities, Squat Hero offers a challenging, action-packed adventure that keeps players active and engaged."}]}, "developer_name": "Clarke Plumo", "developer_privacy_policy_url": "https://squathero.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Clarke Plumo", "support_website_url": null, "website_url": "https://squathero.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_me