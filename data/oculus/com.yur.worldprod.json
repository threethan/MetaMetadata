cdn.com&oh=00_AYB8jUE9awv-Jvrtt0hhpLhw2akLginoJCFxRQSC0bbb0g&oe=6762C1E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Oculus-Launch-Page.png", "id": "3363025077319235", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974491_3363025080652568_2428765954005482018_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lBY56QI_KWcQ7kNvgHu_o4m&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoGNPpUxMdFpTI9oRqXE4T1pcOkSNSMenJD4w2ZpeTbA&oe=6762D123"}, "display_name": "YUR World", "keywords": [], "long_description": "YUR World makes fitness a game. Ignite your imagination and heart rate. Explore new worlds, compete, and map your progress. With YUR's wellness community by your side, you'll never go it alone. Enjoy the journey, not just the destination. \n\nTrack your progress in-game with YUR's virtual watch. A quick glance at your wrist tells you your squat count and calorie burn in real time. Connect to YUR's mobile app to view all of your VR and real life workouts in one place. Get even more detailed wellness insights from YUR's dashboard. Compete against your friends and the YUR community in head-to-head fitness battles and monthly fitness challenges. There\u2019s nothing wrong with a little competition to fuel the fire. \n\nThink you have good reflexes? Work up a sweat and keep your mind sharp with Reaction. Only hit the targets that light up in front of you. In Swap, cool down and concentrate on connecting objects in a row. Barriers will fly towards you to keep you on your toes. In Oddity, wield weapons to destroy the walls around you.\n\nJoin our community at yur.chat! Check out https://yur.wiki/ for quick support or email support@yur.energy", "short_description": "Make Fitness A Game\u2122"}]}, "developer_name": null, "developer_privacy_policy_url": "https://yur.energy/privacy-policy", "developer_terms_of_service_url": "https://www.yur.energy/terms", "publisher_name": "YUR", "support_website_url": "https://yur.chat/", "websi