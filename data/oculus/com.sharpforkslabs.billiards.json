.5771-25/38982585_1292297075424643_580756011528428516_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zS6cPcp8L0cQ7kNvgFU9Eu6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAm1JmzEoQZQPVwyfaocPF01UoxqAvy3QDzBiIDZYE5Wg&oe=6769358D"}, {"file_name": "5s.png", "id": "1995566200961705", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036706_1995566204295038_4606997231843822184_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uvPRiZpXZfcQ7kNvgEIwtJ3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhGbJkazjoB9qbSDdFloWabMIVRlcpF80dg5_OdmmJWA&oe=67695A58"}, {"file_name": "1.png", "id": "499221135883114", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031350_499221139216447_1191498097681527383_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=japwImspt30Q7kNvgE4AzGV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBEFGrsPXevz9fl9_u64-OW-qlhD6RJUFrg3Ydbd83VAw&oe=67693C2E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "16 na 9.png", "id": "9012018012193821", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974813_9012018018860487_9085962782773582973_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VzRyzOSQGcMQ7kNvgH2FATi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgbqHpEG7K16oBIqfmOCBCUvVcRrz3Bh4De0YGbnnUnQ&oe=6769320B"}, "display_name": "8 Ball Pool", "keywords": ["pool", "8ball", "billiards", "games", "multiplayer"], "long_description": "Welcome to the December 2024 Community Update!\n\n- 110,000 Active Users <3 Thank you for Support!\n- Free Trial Play is here, along with new difficulty levels and an Auto Matchmaking System that quickly pairs you with a tailored AI opponent if line takes too long.\n\nSharp Forks is here with a mission to provide you with the most graphically realistic, and intuitive Pool game in the business.\nCrafted around the unique theme of the 1920s. The game integrates advanced physics simulations to deliver high realism in gameplay mechanics, making players feel as if they were physically present in a pool hall.\n\nSome of the planned features include:\n\n- Single Player unlockables, achievements, and Puzzle mode!\n- Online Cooperation Mode.\n- More AI opponents\n- Additional avatars, locations, and utilities.\n- Physics, sounds, and UI improvements.\n- Spectator mode\n\nAnd much more!\n\nStay tuned, and join the 8 Ball Club!", "short_description": "Welcome to the December 2024 Community Update!\n\n- 110,000 Active Users <3 Thank you for Support!\n- Free Trial Play is here, along with new difficulty levels and an Auto Matchmaking System that quickly pairs you with a tailored AI opponent if line takes too long.\n\nPlay now the most realistic VR 8 ball pool game! Engage in thrilling matches against AI opponents or connect with friends around the world for a real-time pool face-off."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sharpforks.com/privacy-policy/", "developer_terms_of_service_url": "https://sharpforks.com/term-of-use/", "publisher_name": "Sharp Forks Labs", "support_website_url": null, "website_url": "https://sharpforks.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SPORTS", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "9463050907056927"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031334_859614622916331_2033