/t64.5771-25/38982585_1292297075424643_580756011528428516_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vVvZTwQXgZEQ7kNvgF660j3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAa18WW-TrmJftgNE_nyCcBvxt5xlaXtqRbO46Apub3Lw&oe=6775130D"}, {"file_name": "5s.png", "id": "1995566200961705", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036706_1995566204295038_4606997231843822184_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CP_C9XaUz74Q7kNvgGiaNnX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDYJPVUqKqOLiKWhJ1p3YiYBrW_wBtwsnpZuBE5DxoWcg&oe=677537D8"}, {"file_name": "1.png", "id": "499221135883114", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031350_499221139216447_1191498097681527383_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GTzVUO7jlOoQ7kNvgEaTbGN&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCR_9U-FOIq8GnFWK9lg32UUSOiLE87olcTVWEz_f7LPw&oe=677519AE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "16 na 9.png", "id": "9012018012193821", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974813_9012018018860487_9085962782773582973_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yUm95CyFshcQ7kNvgGtCUxQ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBdsLWZhSppA-uZBvPWlf_A3lDdi1H0nKBKkfq-QOOECQ&oe=67750F8B"}, "display_name": "8 Ball Pool", "keywords": ["pool", "8ball", "billiards", "games", "multiplayer"], "long_description": "Welcome to the December 2024 Community Update!\n\n- 110,000 Active Users <3 Thank you for Support!\n- Free Trial Play is here, along with new difficulty levels and an Auto Matchmaking System that quickly pairs you with a tailored AI opponent if line takes too long.\n\nSharp Forks is here with a mission to provide you with the most graphically realistic, and intuitive Pool game in the business.\nCrafted around the unique theme of the 1920s. The game integrates advanced physics simulations to deliver high realism in gameplay mechanics, making players feel as if they were physically present in a pool hall.\n\nSome of the planned features include:\n\n- Single Player unlockables, achievements, and Puzzle mode!\n- Online Cooperation Mode.\n- More AI opponents\n- Additional avatars, locations, and utilities.\n- Physics, sounds, and UI improvements.\n- Spectator mode\n\nAnd much more!\n\nStay tuned, and join the 8 Ball Club!", "short_description": "Welcome to the December 2024 Community Update!\n\n- 110,000 Active Users <3 Thank you for Support!\n- Free Trial Play is here, along with new difficulty levels and an Auto Matchmaking System that quickly pairs you with a tailored AI opponent if line takes too long.\n\nPlay now the most realistic VR 8 ball pool game! Engage in thrilling matches against AI opponents or connect with friends around the world for a real-time pool face-off."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sharpforks.com/privacy-policy/", "developer_terms_of_service_url": "https://sharpforks.com/term-of-use/", "publisher_name": "Sharp Forks Labs", "support_website_url": null, "website_url": "https://sharpforks.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SPORTS", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "9463050907056927"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031334_859614622916331_