r": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "585394940421382", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031571_585394943754715_2003614254410517264_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=71kCXTavohsQ7kNvgHShFDE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHNdbHP7iz5T1BqYbMkf-k22h7_epeXX8fgaIHLnUXzw&oe=66CB14C2"}, "display_name": "8 Ball Pool", "keywords": ["pool", "8ball", "billiards", "games", "multiplayer"], "long_description": "Sharp Forks is here with a mission to provide you with the most graphically realistic, and intuitive Pool game in the business.\nCrafted around the unique theme of the 1920s. The game integrates advanced physics simulations to deliver high realism in gameplay mechanics, making players feel as if they were physically present in a pool hall.\n\nSome of the planned features include:\n\n- Single Player unlockables, achievements, and Puzzle mode!\n- Online Cooperation Mode.\n- More AI opponents\n- Additional avatars, locations, and utilities.\n- Physics, sounds, and UI improvements.\n- Spectator mode\n\nAnd much more!\n\nStay tuned, and join the 8 Ball Club!", "short_description": "Play now the most realistic VR 8 ball pool game! Engage in thrilling matches against AI opponents or connect with friends around the world for a real-time pool face-off."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sharpforks.com/privacy-policy/", "developer_terms_of_service_url": "https://sharpforks.com/term-of-use/", "publisher_name": "Sharp Forks Labs", "support_website_url": null, "website_url": "https://sharpforks.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recom