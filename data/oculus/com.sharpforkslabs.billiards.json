cow&oe=66E6DBCF"}, {"file_name": "4.png", "id": "3715940795333360", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031530_3715940798666693_6061603091040249546_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZKf9I1uHeS0Q7kNvgFcLBk6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMMY2YMv9DTkiSl6WmN5ERA&oh=00_AYAZdcbrvQRNDw_8yciWH2SLeS0rGGW8A3bQBrHFwijL-g&oe=66E6B7B4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "585394940421382", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031571_585394943754715_2003614254410517264_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_7WynQg77wgQ7kNvgFc-UFd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMMY2YMv9DTkiSl6WmN5ERA&oh=00_AYCUQXDejlGbe_REspTJMVgk3FvkRNJl7R9L1gv9XWtpvA&oe=66E6C442"}, "display_name": "8 Ball Pool", "keywords": ["pool", "8ball", "billiards", "games", "multiplayer"], "long_description": "Sharp Forks is here with a mission to provide you with the most graphically realistic, and intuitive Pool game in the business.\nCrafted around the unique theme of the 1920s. The game integrates advanced physics simulations to deliver high realism in gameplay mechanics, making players feel as if they were physically present in a pool hall.\n\nSome of the planned features include:\n\n- Single Player unlockables, achievements, and Puzzle mode!\n- Online Cooperation Mode.\n- More AI opponents\n- Additional avatars, locations, and utilities.\n- Physics, sounds, and UI improvements.\n- Spectator mode\n\nAnd much more!\n\nStay tuned, and join the 8 Ball Club!", "short_description": "Play now the most realistic VR 8 ball pool game! Engage in thrilling matches against AI opponents or connect with friends around the world for a real-time pool face-off."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sharpforks.com/privacy-policy/", "developer_terms_of_service_url": "https://sharpforks.com/term-of-use/", "publisher_name": "Sharp Forks Labs", "support_website_url": null, "we