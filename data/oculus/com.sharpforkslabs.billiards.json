7&_nc_sid=6e7a0a&_nc_ohc=X3l9oJDFRsgQ7kNvgHTr9Gk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAYW0WfT3AnX6k8vf__Mig_wT7Hi6p-8OaHBA4fi8tTqw&oe=674081CF"}, {"file_name": "4.png", "id": "3715940795333360", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031530_3715940798666693_6061603091040249546_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=20c8spqeri0Q7kNvgFN9DX_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD3NkZ9CA7sLykBSZIiiW0oNi8_38PXkEpLS2NAhBD8pA&oe=67405DB4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "585394940421382", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031571_585394943754715_2003614254410517264_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8yUkk12utlkQ7kNvgFz_iNH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCSZPL3gGkbrAtb4dwpurzpNbhpManGpOjwD-F0gyMPaA&oe=67406A42"}, "display_name": "8 Ball Pool", "keywords": ["pool", "8ball", "billiards", "games", "multiplayer"], "long_description": "Sharp Forks is here with a mission to provide you with the most graphically realistic, and intuitive Pool game in the business.\nCrafted around the unique theme of the 1920s. The game integrates advanced physics simulations to deliver high realism in gameplay mechanics, making players feel as if they were physically present in a pool hall.\n\nSome of the planned features include:\n\n- Single Player unlockables, achievements, and Puzzle mode!\n- Online Cooperation Mode.\n- More AI opponents\n- Additional avatars, locations, and utilities.\n- Physics, sounds, and UI improvements.\n- Spectator mode\n\nAnd much more!\n\nStay tuned, and join the 8 Ball Club!", "short_description": "Play now the most realistic VR 8 ball pool game! Engage in thrilling matches against AI opponents or connect with friends around the world for a real-time pool face-off."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sharpforks.com/privacy-policy/", "developer_terms_