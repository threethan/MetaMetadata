1738_n.png", "id": "684170859558253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001717_684170866224919_2511472551981085464_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IC_rfsNKf-IQ7kNvgH9WMQn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzNqNczE5GeQolsQNQ1Vo3AzDP1mXLJP9yEpNPpU2nzQ&oe=67431392"}, {"file_name": "39031616_627271722411877_8280770967001283018_n.png", "id": "804903997294488", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974613_804904000627821_3885493636680601422_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5ZlppvKVuV0Q7kNvgEGZ8V0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDmYiU-OFTJFi9PgKdWXVeScPglPDYP5QgdxLuaz8PQw&oe=67432270"}, {"file_name": "Screenshot 6.png", "id": "1168163703907676", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031625_1168163707241009_2978429822660642073_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UC0wuOvCbeMQ7kNvgH9ST9F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDV2YT6XGh4hJ8VUJL8bAM0JhXy0eS4uqNeIC5XDPcakg&oe=6742F9E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39035405_1762648344097881_719329690254704213_n.png", "id": "909014620063554", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036606_909014623396887_1687337753596455958_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jF5cJHzi-W0Q7kNvgGpolq_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB11a5HB6qyd3J1b-VUS1ERu2HZnhZMJwqeejumgeP4ww&oe=6742FADB"}, "display_name": "Noun Town Language Learning", "keywords": ["language", "education", "japanese", "spanish", "learn"], "long_description": "The new way to learn a foreign language!\n\nNoun Town is the world's most advanced language learning software, using immersive gameplay to remove the grind from learning a new language.\n\n\u2714 From beginner to winner\nStart from scratch and build up 1,000+ words and phrases in Japanese, Chinese, Spanish, French, German, and Italian.\n\n\u2714 No grinding, just gaming\nLearn through playing, in a world full of exciting mini-games and interactive lessons.\n\n\u2714 Speak like a native\nInteract with 16 unique characters using speech recognition to nail down tricky pronunciations, removing the anxiety of slipping up when you practice in real life.\n\nIn Noun Town your learning directly impacts the game environment, turning the island into color and unlocking new characters and gameplay modes.", "short_description": "The new way to learn a foreign language!\n\nStart from scratch and build up 1,000+ words and phrases in Japanese, Chinese, Spanish, French, German, and Italian.\n\nUse your learning to progress through fun mini-games, interactive lessons, and voice chat with 16 unique characters in an environment that regains color as your learn."}]}, "developer_name": "realiaXR", "developer_privacy_policy_url": "https://noun.town/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "realiaXR", "support_website_url": null, "website_url": "https://noun.town/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "519745706360662"}}]}, "scheduled_offers": {"count": 24, "nodes": [{"status": "PENDING", "id": "1703555330221412"}, {"status": "PUBLISHED", "id": "484442831307266"}, {"status": "PUBLISHED", "id": "3362378947240173"}, {"status": "PUBLISHED", "id"