.oculuscdn.com/v/t64.5771-25/39031644_353500028696907_6555776314689716224_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x4d2MG-LydAQ7kNvgHjY_3Y&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCrO3JcNaWPBwx3Sc5zTiba-netJwIDy8rnA67lr8fGkw&oe=67124CDD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Puppet Fever", "keywords": ["puppet", "puppetfever", "multiplayer", "party", "coop"], "long_description": "- 500+ Unique English Word Cards with acting tips \n- Hundreds of Puppets and props\n- 3 different Game modes\n- Fun and simple game play, even small kids can guess!\n- Free companion app available on Android, iOS and PC\n- Supports multiplayer for up to 4 people!\n\nYour job as the Puppet Master is simple - make the other players guess the secret Word Card and be as entertaining as possible!\n\nThis is a local multiplayer party game where you take turns acting and watching the puppet show. Connect a phone, tablet or PC using our free companion app.\n\nFind more info at puppetfever.com\n\nYou will:\n- Make up silly sound effects and voices! \n- Take giant leaps of logic!\n- Shout at your friends!\n- Get shouted at by your friends!\n- Have a lot of fun in this fun, casual, puppet party game!", "short_description": "Turn your phone into a stage, step into VR and act like a freak! Become the Puppet Master and play with your friends as they participate through the companion app!"}]}, "developer_name": "Coastalbyte Games", "developer_privacy_policy_url": "http://www.puppetfever.com/privacypolicy", "developer_terms_of_service_url": "http://www.puppetfever.com/eula", "publisher_name": "Coffeestain Publishing", "support_website_url": null, "website_url": "https://www.puppetfever.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NO