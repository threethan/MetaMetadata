wind from a stressful day.", "short_description": "*Discounted price while in Beta. New gameplay, environments, and food are included in the roadmap for the full release.*\n\nEnjoy a delightful delicacy of roasted marshmallow, melted chocolate, and graham cracker as you relax by a warm campfire and listen to the peaceful babble from a nearby brook.\n\nAs the name suggests, S'more Please let's you cook s'mores! The relaxing gamemode included in the beta let's you enjoy yourself as you munch on s'mores and unwind from a stressful day."}]}, "developer_name": "Mischief Game Dev", "developer_privacy_policy_url": "https://mobilemischief.net/smore-please/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mischief Game Dev", "support_website_url": null, "website_url": "https://mobilemischief.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "FOOD", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1258801801364764"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "951027946857524"}, {"status": "PUBLISHED", "id": "1189918508921670"}, {"status": "PUBLISHED", "id": "745166793595998"}, {"status": "PUBLISHED", "id": "6199107353467362"}]}, "baseline_offer": {"id": "6199107353467362"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "951027946857524"}]}, "liveChannel": {