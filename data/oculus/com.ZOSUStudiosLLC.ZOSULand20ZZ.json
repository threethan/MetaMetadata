d screen 1560 1440.png", "id": "708827703856261", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_708827707189594_5981160594616364524_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ik3vbFQitW8Q7kNvgFsJNY3&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah4XYi5HkjDCFpOFwCwVmKJ&oh=00_AYDFWGC8Momb6wrHcGBCCiHtBbZakwN3eaOgLxah7Wen_g&oe=66EBFC7F"}, {"file_name": "sky2b 2560.png", "id": "973128116973938", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294243_973128120307271_225175566556527326_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yhXpDXev-MAQ7kNvgGSGHIS&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah4XYi5HkjDCFpOFwCwVmKJ&oh=00_AYBLjntTLqxFnQwiA6gp-VNC7msZl1MRPLam9HhTewZRSQ&oe=66EC0A23"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen3.png", "id": "458598088952441", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_458598092285774_5159038276755156810_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kYGsUfsj01oQ7kNvgEZm9F1&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah4XYi5HkjDCFpOFwCwVmKJ&oh=00_AYD0rvdJmhSBeYJrYrKBezUthkrJM_wDt-JnJ0NgyzVi7w&oe=66EC0157"}, "display_name": "ZOSULand 20ZZ", "keywords": ["Parkour", "jetpack", "cyberpunk", "Climb"], "long_description": "Zany ZOSULand Experience\n*Timed scoring mode: 2 minutes per level = over 72 minutes of gameplay!*\n*Freeplay mode: no timer / just explore!*\nClimb, fly, grapple over 10 square miles / 28 kilometers of futuristic urban areas in order to save each floating city and the multitude of animals from the invading forces.\n- 27 unique city levels + 9 bonus levels to fly through space \n- Over 250 building types to explore and over 40 types of animals to save\n- Jetpacks allow flight, grapples in each level available, and you can climb almost anything anywhere\n- Destroy robots and dinosaurs\n- Motion Sickness Consideration: all horizontal turning can be done using the right joystick in addition to the direction you are looking, while flying move in direction of hand/jetpack.\n*Additional 5/23/2022 updates: major game mechanics improvements, new random level selector, level end-scenes with score and animal viewing, added multiple songs, added new animal spawns / animations and some random spawns*", "short_description": "-Zany ZOSULand Experience:\n-Climb, fly, grapple over 10 miles / 28 kilometers of futuristic urban areas to save each floating city and the multitude of animals\n- 27 unique city levels + 9 bonus levels\n- Over 250 building types to explore, over 40 types of animals to save\n- Jetpacks allow flight, grapples in each level available, climb almost anything anywhere\n- Destroy robots and dinosaurs"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "DINOSAURS", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7917397071689935"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974764_354505797708247_3720314952415818561_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AvyVZ-o8Xk4Q7kNvgG565zn&_nc_ht=scontent.oculuscdn.c