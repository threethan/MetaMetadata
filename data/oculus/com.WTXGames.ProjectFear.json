ed nightmare."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/wtxgames-studio/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Maxe", "support_website_url": null, "website_url": "https://sites.google.com/view/wtxgames-studio/about", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7077558059023826"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/75549077_904355164802180_5992041054093473321_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AGmeb73sVw4Q7kNvgFoV80H&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCtEQAiK6_FDBQh9OpxUyJ2jFjnDBE39OA6wZOhx7fiIw&oe=677E723C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Project Fear", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Survival", "id": "644354873106712"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1712405220, "lastRevision": {"nodes": [{"id": "7077558092357156", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7077558042357161", "is_first_party": false, "enables_in_app_ads": false, 