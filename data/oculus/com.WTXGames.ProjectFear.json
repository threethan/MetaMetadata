n.com&_nc_gid=AYl46dDUqYBdvY2Mq_zTwCZ&oh=00_AYBzepDKKkQovGKR2peah4T5cb3yjiOUNEZYEavz0_rEoA&oe=66E2C550"}, {"file_name": "Main_Custom..._24.03.2024_12-21-39.png", "id": "3668440253424130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001719_3668440256757463_7911871517630275973_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H6tNdO4IltYQ7kNvgFKQhOq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYl46dDUqYBdvY2Mq_zTwCZ&oh=00_AYD2xvm9bXW2RT7yYdIjf9EIX_kdLtZE6VBhZJYZryV1qQ&oe=66E2C65D"}, {"file_name": "Main_Custom..._24.03.2024_12-21-39.png", "id": "1113854489840046", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251817_1113854493173379_3175713871006889954_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MuIpHceh70gQ7kNvgGdXoat&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYl46dDUqYBdvY2Mq_zTwCZ&oh=00_AYCj1wDJ0OBlrCDEfmvMxXDHtP050scKaD7gN4wH8RgJqw&oe=66E2D1C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Main_Custom..._24.03.2024_12-21-39.png", "id": "787844696584874", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982671_787844699918207_1966340381990108941_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AcjllZkh8ZgQ7kNvgGbfyFa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYl46dDUqYBdvY2Mq_zTwCZ&oh=00_AYCBO-JGcWywoJt79oU_mmVxQ6YrbpQLkradugFZvkVo9A&oe=66E2D0CD"}, "display_name": "Project Fear", "keywords": [], "long_description": "\n\"Project Fear\" is a survival horror game set in a research facility overrun by mutated apes. Inspired by \"Lethal Ape,\" it combines intense action with horror. Players use \"Gorilla Tag\"-like locomotion to swing, climb, and evade the primates. Uncover dark secrets while fighting for survival in this adrenaline-fueled nightmare.", "short_description": "\n\"Project Fear\" is a survival horror game where players navigate a research facility overrun by mutated apes. Inspired by \"Lethal Ape,\" it features intense action and horror. Using the locomotion mechanics of \"Gorilla Tag,\" players swing, climb, and leap to