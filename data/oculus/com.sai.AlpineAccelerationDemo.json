.com/v/t64.5771-25/43931328_1680741342132336_6959581886387487897_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZKdXArmtlesQ7kNvgF_obak&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5kYzFTJqQ7YqhLwTWm6hnjgSJ2icYBEO5cBwQR3yjGQ&oe=6714EC10"}, {"file_name": "sc4.png", "id": "993475191473892", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974923_993475194807225_3690569598887216492_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9kif8WhNcAsQ7kNvgGWABOw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDssjzv_mBuG_GqG5xbiyf4m-YCKQdhsDevMlqBu0LzxA&oe=6714F144"}, {"file_name": "sc5.png", "id": "987583972029611", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334054_987583975362944_6937496998245632233_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c3dUBKSdDyAQ7kNvgElGdJd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPJ__PKYCN6azwbCyzO87-ZBf0f7s2HyNqByu7fzbGCw&oe=67150230"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "movietitle.png", "id": "1090465938024234", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035438_1090465941357567_395500510634337420_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=edM-EPldvxMQ7kNvgGIP9mo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCa3KURZL0xTZX5n--QY3t1ALWMvlSJGCs5Lyeb68Po6g&oe=6714FD3B"}, "display_name": "AlpineAcceleration Demo", "keywords": ["retro", "2Dlike", "Timetrial", "RTA", "WinterSports"], "long_description": "This game is\nThis is a trial version of \"AlpineAcceleration\".\n\nIn the Demo version, you can play stages 1, 2, and 7.\nIf you like it, please purchase the full version!\n\n\nThis game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A b