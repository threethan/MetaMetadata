.com/v/t64.5771-25/43931328_1680741342132336_6959581886387487897_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LZt5d4A4ugsQ7kNvgFjcug9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfmjaLdnVLhsGZt_nF-D1VuMZ7nci0yqaq30gEcf5PEw&oe=6720C990"}, {"file_name": "sc4.png", "id": "993475191473892", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974923_993475194807225_3690569598887216492_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zfSiP2sBW7EQ7kNvgGaKYZH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_NLewVqxma6oeQGKto0BiAoTHXaMw8tZ16g9Dm4oBJQ&oe=6720CEC4"}, {"file_name": "sc5.png", "id": "987583972029611", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334054_987583975362944_6937496998245632233_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9T2Jr0OH0EQQ7kNvgHrmpVt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD55z5e-Cf525OjDU_aSCK6ziyNUx8ZLoV2dagtT94LqA&oe=6720DFB0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "movietitle.png", "id": "1090465938024234", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035438_1090465941357567_395500510634337420_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QnKd8BJ7JvcQ7kNvgHVrrij&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAtyfLHryCvjBGMLMfCOMX0xb49yjlulwt7z55WWbdGHA&oe=6720DABB"}, "display_name": "AlpineAcceleration Demo", "keywords": ["retro", "2Dlike", "Timetrial", "RTA", "WinterSports"], "long_description": "This game is\nThis is a trial version of \"AlpineAcceleration\".\n\nIn the Demo version, you can play stages 1, 2, and 7.\nIf you like it, please purchase the full version!\n\n\nThis game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A b