tps://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982593_437039810663518_2537482891564419474_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6gXpGsl57jgQ7kNvgHSZm3c&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDCE3XI7O-2_t2p8BDLAZIEsOVlhEGLg00xsJuKWle2mQ&oe=67810410"}, {"file_name": "sc3.png", "id": "1680741338799003", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/43931328_1680741342132336_6959581886387487897_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4LLDsXsho_MQ7kNvgH4A3HN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCpcqn0DuiykmOCFQZS0cUJRGRjcBbLNBpTJblPOlmHuw&oe=67810710"}, {"file_name": "sc4.png", "id": "993475191473892", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974923_993475194807225_3690569598887216492_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WEQk3sOgjykQ7kNvgGM8bvD&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCOt_dq2qfmf-srgXQd0g-PVNcOvE84ig-Z5IkRQ6E2rw&oe=67810C44"}, {"file_name": "sc5.png", "id": "987583972029611", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75334054_987583975362944_6937496998245632233_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2uVua9eXjykQ7kNvgEbwAsH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBcqCyKet6kN_RIh6dev7jup5EmGfiWm8Pf66l-F0MOSg&oe=67811D30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "movietitle.png", "id": "1090465938024234", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035438_1090465941357567_395500510634337420_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tq682cAMAKkQ7kNvgFsNz-2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBEt5B9KOBqUi85WAkUmhPKYWRm9sYr2S77G33pwOwjlg&oe=6781183B"}, "display_name": "AlpineAcceleration Demo", "keywords": ["retro", "2Dlike", "Timetrial", "RTA", "WinterSports"], "long_description": "This game is\nThis is a trial version of \"AlpineAcceleration\".\n\nIn the Demo version, you can play stages 1, 2, and 7.\nIf you like it, please purchase the full version!\n\n\nThis game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A button (Jump)", "short_description": "A 2D style snowboarding game is here!\nRide through a total of 9 courses full of speed and thrills!\n\nFeel the speed in your body!\nSimple yet addictive controls!\n\nHow far can you go to beat your time?"}, {"images": {"nodes": []}, "id": "554520517476308", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AlpineAcceleration Demo", "keywords": ["retro", "2Dlike", "\u30bf\u30a4\u30e0\u30c8\u30e9\u30a4\u30a2\u30eb", "RTA", "WinterSports"], "long_description": "\u3053\u306e\u30b2\u30fc\u30e0\u306f\n\u300cAlpineAcceleration\u300d\u306e\u4f53\u9a13\u7248\u3068\u306a\u308a\u307e\u3059\u3002\nDemo\u7248\u3067\u306f\u30b9\u30c6\u30fc\u30b81,2,7\u304c\u30d7\u30ec\u30a4\u53ef\u80fd\u3067\u3059\u3002\n\n\u6c17\u306b\u5165\u3063\u3066\u3044\u305f\u3060\u3051\u305f\u306e\u306a\u3089\u88fd\u54c1\u7248\u306e\u8cfc\u5165\u3092\u304a\u9858\u3044\u3057\u307e\u3059\uff01\n\n\u300cAlpineAcceleration\u300d\u306f\n\u30b9\u30c6\u30fc\u30b8\u304b\u3089\u843d\u3061\u305f\u308a\u3001\u969c\u5bb3\u7269\u306b\u5f53\u305f\u3089\u306a\u3044\u3088\u3046\u3001\n\u30b8\u30e3\u30f3\u30d7\u3092\u99c6\u4f7f\u3057\u306a\u304c\u3089\u30b3\u30fc\u30b9\u306e\u30b4\u30fc\u30eb\u3092\u76ee\u6307\u3059\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u30b8\u30e3\u30f3\u30d7\u306e\u30bf\u30a4\u30df\u30f3\u30b0\u3084\u30b9\u30d4\u30fc\u30c9\u306e\u8abf\u6574\u304c\u9375\u3068\u306a\u308a\u307e\u3059\u3002\n\n\u64cd\u4f5c\u8aac\u660e\nX\u30dc\u30bf\u30f3\u9577\u62bc\u3057/\n\u4e0b\u308a\u5742\u306e\u6642\u3001\u30b9\u30d4\u30fc\u30c9\u30a2\u30c3\u30d7\n\u7