Acceleration\u300d\u306f\n\u30b9\u30c6\u30fc\u30b8\u304b\u3089\u843d\u3061\u305f\u308a\u3001\u969c\u5bb3\u7269\u306b\u5f53\u305f\u3089\u306a\u3044\u3088\u3046\u3001\n\u30b8\u30e3\u30f3\u30d7\u3092\u99c6\u4f7f\u3057\u306a\u304c\u3089\u30b3\u30fc\u30b9\u306e\u30b4\u30fc\u30eb\u3092\u76ee\u6307\u3059\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u30b8\u30e3\u30f3\u30d7\u306e\u30bf\u30a4\u30df\u30f3\u30b0\u3084\u30b9\u30d4\u30fc\u30c9\u306e\u8abf\u6574\u304c\u9375\u3068\u306a\u308a\u307e\u3059\u3002\n\n\u64cd\u4f5c\u8aac\u660e\nX\u30dc\u30bf\u30f3\u9577\u62bc\u3057/\n\u4e0b\u308a\u5742\u306e\u6642\u3001\u30b9\u30d4\u30fc\u30c9\u30a2\u30c3\u30d7\n\u767b\u308a\u5742\u306e\u6642\u3001\u6e1b\u901f\u3092\u6291\u5236\n\nA\u30dc\u30bf\u30f3/\u30b8\u30e3\u30f3\u30d7", "short_description": "2D\u98a8\u30b9\u30ce\u30fc\u30dc\u30fc\u30c9\u30b2\u30fc\u30e0\u304c\u767b\u5834\uff01\n\u30b9\u30d4\u30fc\u30c9\u611f\u3001\u30b9\u30ea\u30eb\u306b\u5bcc\u3093\u3060\u51689\u30b3\u30fc\u30b9\u3092\u99c6\u3051\u629c\u3051\u308d\uff01\n\n\u4f53\u306b\u611f\u3058\u3089\u308c\u308b\u75be\u8d70\u611f\n\u30b7\u30f3\u30d7\u30eb\u306a\u306e\u306b\u7656\u306b\u306a\u308b\u64cd\u4f5c\u611f\uff01\n\n\u3042\u306a\u305f\u306f\u3069\u3053\u307e\u3067\u30bf\u30a4\u30e0\u3092\u7e2e\u3081\u3089\u308c\u308b\uff1f"}, {"images": {"nodes": [{"file_name": "c2.png", "id": "5862959900443111", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/227837669_5862959903776444_4346440912494062966_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4zyWkRLEhhYQ7kNvgFierUl&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBqdmwlsQF2oFiqZ3zPNU4Tf7YwZzvu08ntSkOVMT5j_g&oe=670BA467"}, {"file_name": "haikei1.png", "id": "1418794415450082", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75297580_1418794418783415_1780454929393464769_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C5xHE2UbPh0Q7kNvgFwgzKC&_nc_ht=scontent-fra3-2.oculuscdn.