tent-ams2-1.oculuscdn.com/v/t64.5771-25/38982593_437039810663518_2537482891564419474_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6gXpGsl57jgQ7kNvgHSZm3c&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDCE3XI7O-2_t2p8BDLAZIEsOVlhEGLg00xsJuKWle2mQ&oe=67810410"}, {"file_name": "sc3.png", "id": "1680741338799003", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/43931328_1680741342132336_6959581886387487897_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4LLDsXsho_MQ7kNvgH4A3HN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCpcqn0DuiykmOCFQZS0cUJRGRjcBbLNBpTJblPOlmHuw&oe=67810710"}, {"file_name": "sc4.png", "id": "993475191473892", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974923_993475194807225_3690569598887216492_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WEQk3sOgjykQ7kNvgGM8bvD&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCOt_dq2qfmf-srgXQd0g-PVNcOvE84ig-Z5IkRQ6E2rw&oe=67810C44"}, {"file_name": "sc5.png", "id": "987583972029611", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75334054_987583975362944_6937496998245632233_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2uVua9eXjykQ7kNvgEbwAsH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBcqCyKet6kN_RIh6dev7jup5EmGfiWm8Pf66l-F0MOSg&oe=67811D30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "movietitle.png", "id": "1090465938024234", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035438_1090465941357567_395500510634337420_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tq682cAMAKkQ7kNvgFsNz-2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBEt5B9KOBqUi85WAkUmhPKYWRm9sYr2S77G33pwOwjlg&oe=6781183B"}, "display_name": "AlpineAcceleration Demo", "keywords": [], "long_description": "This game is\nThis is a trial version of \"AlpineAcceleration\".\nIf you like it, please purchase the full version!\n\n\nThis game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A button (Jump)", "short_description": "A 2D style snowboarding game is here!\nRide through a total of 9 courses full of speed and thrills!\n\nFeel the speed in your body!\nSimple yet addictive controls!\n\nHow far can you go to beat your time?"}, {"images": {"nodes": []}, "id": "360073835683028", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AlpineAcceleration Demo", "keywords": [], "long_description": "\u3053\u306e\u30b2\u30fc\u30e0\u306f\n\u300cAlpineAcceleration\u300d\u306e\u4f53\u9a13\u7248\u3068\u306a\u308a\u307e\u3059\u3002\n\u6c17\u306b\u5165\u3063\u3066\u3044\u305f\u3060\u3051\u305f\u306e\u306a\u3089\u88fd\u54c1\u7248\u306e\u8cfc\u5165\u3092\u304a\u9858\u3044\u3057\u307e\u3059\uff01\n\n\u300cAlpineAcceleration\u300d\u306f\n\u30b9\u30c6\u30fc\u30b8\u304b\u3089\u843d\u3061\u305f\u308a\u3001\u969c\u5bb3\u7269\u306b\u5f53\u305f\u3089\u306a\u3044\u3088\u3046\u3001\n\u30b8\u30e3\u30f3\u30d7\u3092\u99c6\u4f7f\u3057\u306a\u304c\u3089\u30b3\u30fc\u30b9\u306e\u30b4\u30fc\u30eb\u3092\u76ee\u6307\u3059\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u30b8\u30e3\u30f3\u30d7\u306e\u30bf\u30a4\u30df\u30f3\u30b0\u3084\u30b9\u30d4\u30fc\u30c9\u306e\u8abf\u6574\u304c\u9375\u3068\u306a\u308a\u307e\u3059\u3002\n\n\u64cd\u4f5c\u8aac\u660e\nX\u30dc\u30bf\u30f3\u9577\u62bc\u3057/\n\u4e0b\u308a\u5742\u306e\u6642\u3001\u30b9\u30d4\u30fc\u30c9\u30a2\u30c3\u30d7\n\u767b\u308a\u5742\u306e\u6642\u3001\u6e1b\u901f\u3092\u6291\u5236\n\nA\u30dc\u30bf\u30f3/\u30b8\u30e3\u30f3\u30d7", "short_description": "2D\u98a8\u30b9\u30ce\u30fc\u30dc\u30fc\u30c9\u30b2\u30fc\u30e0\u304c\u767b\u5834\uff01\n\u30b9\u30d4\u30fc\u30c9\u611f\u3001\u30b9\u30ea\u30eb\u306b\u5bcc\u3093\u3060\u51689\u30b3\u30fc\u30b9\u3092\u99c6\u3051\u629c\u3051\u308d\uff01\n\n\u4f53\u306b\u611f\u3058\u3089\u308c\u308b\u75be\u8d70\u611f\n\u30b7\u30f3\u30d7\u30eb\u306a\u306e\u306b\u7656\u306b\u306a\u308b\u64cd\u4f5c\u611f\uff01\n\n\u3042\u306a\u305f\u306f\u3069\u3053\u307e\u3067\u30bf\u30a4\u30e0\u3092\u7e2e\u3081\u3089\u308c\u308b\uff1f"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2021/06/alpine-acceleration.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2021/06/about-alpine-acceleration.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "ARCADE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "618097406115639"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "352829176503444"}]}, "baseline_offer": {"id": "352829176503444"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1628549880, "status": "PUBLISHED", "id": "352829176503444"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4353821411340612", "version": "1.1"}, "id": "262408401971136", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__t