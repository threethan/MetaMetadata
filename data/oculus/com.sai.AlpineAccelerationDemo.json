c_ohc=vsqOKyPkyC0Q7kNvgE4xTp-&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCIhiXBI37S8UaxC4BH6D2mif4ovlhadOoyHL9m6cZTXw&oe=670BB190"}, {"file_name": "sc4.png", "id": "993475191473892", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974923_993475194807225_3690569598887216492_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VB5tISWj7kYQ7kNvgExZbZs&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC_cD0rITDZXPf91KQiOgeokBpTL-xHBZJtf5j1BNnD-w&oe=670BB6C4"}, {"file_name": "sc5.png", "id": "987583972029611", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75334054_987583975362944_6937496998245632233_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tli1iitesDwQ7kNvgF2MiGk&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCJZ8xBmTwysyk-LepbaOGRvg2FuhnZ5DQz5idpTmsecA&oe=670BC7B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "movietitle.png", "id": "1090465938024234", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39035438_1090465941357567_395500510634337420_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CMbu_q8o9SwQ7kNvgHJsrsg&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBd-MnY1HSE4lpEo5LOtDhT_Ne2deQU-y7FYNb87rPJ-g&oe=670BC2BB"}, "display_name": "AlpineAcceleration Demo", "keywords": ["retro", "2Dlike", "Timetrial", "RTA", "WinterSports"], "long_description": "This game is\nThis is a trial version of \"AlpineAcceleration\".\n\nIn the Demo version, you can play stages 1, 2, and 7.\nIf you like it, please purchase the full version!\n\n\nThis game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A button (Jump)", "short_description": "A 2D style snowboarding game is here!\nRide through a total of 9 courses full of speed and thrills!\n\nFeel