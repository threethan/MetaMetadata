4ZUQ7kNvgGuaHjL&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArUSmNf1PiOG_vxZsUfwYYK&oh=00_AYAA0iUOZqM1OmahrdtAOkGB_KbMXcPRaV9yiIgzD5ajVw&oe=66E42186"}, {"file_name": "Kitchen 4.png", "id": "955492718553044", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982532_955492721886377_3922772517376829483_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jGfKKLWFc48Q7kNvgHiOVCO&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArUSmNf1PiOG_vxZsUfwYYK&oh=00_AYB5AKgngXkdek54PcgtFNjp_4lIkl_d74__FIBCww41fw&oe=66E423F7"}, {"file_name": "Kitchen 5.png", "id": "501423411819139", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203614_501423415152472_7207824434160811920_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p2Gn_tajD0AQ7kNvgF_QYBd&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArUSmNf1PiOG_vxZsUfwYYK&oh=00_AYD6lHTGmF0iGDAxQmedWiyyYD2QNaqyckAt0BIqIO5mrA&oe=66E43DF4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot 2022-09-09 at 13.02.41.png", "id": "611069160667403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982547_611069164000736_3763920721083230472_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=xADS5tyqxVQQ7kNvgGP39Wy&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArUSmNf1PiOG_vxZsUfwYYK&oh=00_AYCaHodYodHyAdHYvzOPRGoBq2BFfkfZHUKHyhSyZgW-PA&oe=66E42316"}, "display_name": "Kitchen Assembly", "keywords": [], "long_description": "This hands-on VR lesson lets the student assemble and install a real kitchen from start to finish. The process consists of 50 steps, divided into multiple stages. The student is able to make use of necessary tools for each step, to consult the instructions tablet, and to ask for hints when not sure what to do next. For repeat processes, the student is aided by an invisible assistant. \n\nStudent will learn about: necessary tools, materials and steps required to assemble a kitchen; how to follow instructions and ask for help; correct and incorrect techniques for different steps; how to use virtual reality to learn real-life skills; recognize the limitations of simulated reality.", "short_description": "This hands-on VR lesson lets the student install a real kitchen from start to finish, virtually. The student will learn about the necessary tools, materials and steps required to assemble a kitchen. Instructions through 50 steps are provided on the in-VR tablet where the student can also ask for hints if needed."}]}, "developer_name": null, "developer_privacy_policy_url": "https://futuclass.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Futuclass OU", "support_website_url": "https://futuclass.com/", "website_url": "https://futuclass.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "et"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "969892187325466"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "944005806596053"}, {"status": "PUBLISHED", "id": "810486117073736"}]}, "baseline_offer": {"id": "810486117073736"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1676451300, "status": "PUBLISHED", "id": "944005806596053"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26936351895978735", "version": "1.3.0-KitchenAssembly-AppLab-Meta-rc-1"}, "id": "577149200759380", "ch