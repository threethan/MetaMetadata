_944447050458431_6532049106550986743_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b6UjEMP39rIQ7kNvgEF_Nwc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0ANO2Immw34n7n9_NQN6dnyZxEthgfdb52fK33x849A&oe=671F7BD8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974645_423425700027459_596301751411659256_n.png", "id": "1580190039214274", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031606_1580190042547607_1882366513070497856_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M3rl3mOOSPEQ7kNvgG0onyh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBY5K8yLMsLzqsa95RlmzlM7bmYNb8fhN23MIAh0PLuoA&oe=671F7DE0"}, "display_name": "Shoreline Flood Explorer: Corte Madera", "keywords": [], "long_description": "Developed by Virtual Planet and the Town of Corte Madera, the Shoreline Flood Explorer: Corte Madera uses U.S. Geological Survey\u2019s CoSMoS data to model flooding impacts under various storm surge and high tide scenarios. This Virtual Reality experience and online tool, featuring immersive storytelling, are part of the Town's Shoreline Adaptation Engagement Effort to share information about flood risk, enabling the community to take informed action.", "short_description": "Developed by Virtual Planet and the Town of Corte Madera, the Shoreline Flood Explorer: Corte Madera uses U.S. Geological Survey\u2019s CoSMoS data to model flooding impacts under various storm surge and high tide scenarios. This Virtual Reality experience and online tool, featuring immersive storytelling, are part of the Town's Shoreline Adaptation Engagement Effort to share information about flood risk, enabling the community to take informed action."}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtualplanet.tech/privacy-policy-app", "developer_terms_of_service_url": null, "publisher_name": "Virtual Planet Technologies LLC", "support_website_url": null, "website_url": "https://virtualplanet.tech/", "category": null, "comfort_r