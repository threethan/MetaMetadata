locale": "ko_KR", "screenshots": [{"file_name": "[\ud06c\uae30\ubcc0\ud658]256PUTTZZLE_RAW_IMAGE_9.png", "id": "721657889513339", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982585_721657896180005_4137105840934493152_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OS3tfsQpMIQQ7kNvgElcrZh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDsjTchuy2jwJjD0gHlHFLe-TTftZuLzkcfAZUefjoeKw&oe=66D2EC4E"}, {"file_name": "[\ud06c\uae30\ubcc0\ud658]256image (15).png", "id": "537173618346286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580058_537173621679619_66989633460995887_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C8Oz8_b_7gEQ7kNvgEgh5Oe&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlrqS-K2n8Wu9gevcHJ2otInMuMGbq31wwI86JYmgtPw&oe=66D30531"}, {"file_name": "[\ud06c\uae30\ubcc0\ud658]256image (16).png", "id": "3019389525031126", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974896_3019389528364459_1517837238301323323_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7DBjH0h5zCwQ7kNvgGQrzzx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUpus2BL91Wabl02ChHEmrMzf-F9YtHm0gFbR0edWLkA&oe=66D31367"}, {"file_name": "[\ud06c\uae30\ubcc0\ud658]256PUTTZZLE_RAW_IMAGE_8.png", "id": "6454805404536743", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608432_6454805407870076_5711029051175966736_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eFCBN7wSuY8Q7kNvgGdiQv_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBOjcvEU7RN7ioBWJTIx9iW7vx0TtWKuIaNhHlQtuD9AQ&oe=66D30D8A"}, {"file_name": "[\ud06c\uae30\ubcc0\ud658]256image (14).png", "id": "698930758344026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196217_698930761677359_1728489252207395838_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tGhgn7_v5icQ7kNvgF2tFMP&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNz4X0kbodpcr0kXd05i62UeWZriff0mYEtoAZ6HfHyg&oe=66D30217"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "25601440.png", "id": "894630858246355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036686_894630861579688_2255977523475639005_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q_F7pRb6t2kQ7kNvgG8DNPD&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8J7x3hSwoQDEXTeVq-dItQCUHzEsM7lHNbrpdQZ1GXw&oe=66D30CD9"}, "display_name": "PUTTZZLE", "keywords": [], "long_description": "\ub2f9\uc2e0\uc5d0\uac8c \uc8fc\uc5b4\uc9c4 \uc2a4\ud2f1 \ud55c \uc790\ub8e8\uc640 \ubb34\uac70\uc6b4 \uacf5\uc774 \uc788\uc2b5\ub2c8\ub2e4.\n\uadf8\ub9ac\uace0 \uc800 \uba40\ub9ac \uacf5\uc744 \ub123\uc744 \uc218 \uc788\ub294 \ubaa9\ud45c \uc9c0\uc810\uc774 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ub2f9\uc2e0\uc5d0\uac8c \uc8fc\uc5b4\uc9c4 \uacf5\uc744 \ubaa9\ud45c\ub97c \ud5a5\ud574 \ub098\uc544\uac00\uba74 \ub429\ub2c8\ub2e4.\n\uc11c\ub85c \ub2e4\ub978 \uc9c0\ud615, \ubc29\ud574\ubb3c\ub4e4\uc744 \uc774\uc6a9\ud558\uac70\ub098 \ud53c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\uc8fc\uc5b4\uc9c4 \ud69f\uc218\ub97c \uac00\uc9c0\uace0 \ubaa9\ud45c\ub97c \ud5a5\ud574 \uc5b4\ub5a4 \ubc29\ubc95\uc774\ub4e0 \uc0ac\uc6a9\ud574 \ubcf4\uc138\uc694.\n\n[\uc9c1\uad00\uc801\uc778 \uc870\uc791]\n[PUTTZZLE]\uc740 \uc2a4\ud2f1\uc744 \ud718\ub458\ub7ec \uacf5\uc744 \uce58\ub294 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\ub2e4\ub978 \uc870\uc791\ubc29\uc2dd\uc744 \uc694\uad6c\ud558\uc9c0 \uc54a\uae30 \ub54c\ubb38\uc5d0, \ub0a8\ub140\ub178\uc18c \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n[\ub2e8\uc21c\ud568\uc5d0\uc11c \uc624\ub294 \uc7ac\ubbf8]\n\ud50c\ub808\uc774\uc5b4\ub294 \uacf5\uc744 \ubaa9\ud45c\uc5d0 \ub123\ub294\uac83\ub9cc \uc0dd\uac01\ud558\uba74 \ub429\ub2c8\ub2e4.\n\ub2e4\uc591\ud55c \ubc29\ubc95\uc73c\ub85c \uacf5\ub7b5\ud558\uc5ec \ubaa9\ud45c\ub97c \ub2ec\uc131\ud558\ub294 \uac83\uc73c\ub85c \uc131\ucde8\uac10\uc744 \uc5bb\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n[\uc810\uc9c4\uc801 \ub09c\uc774\ub3c4 \uc99d\uac00]\n\uc2a4\ud14c\uc774\uc9c0\uc758 \uc99d\uac00\uc5d0 \ub530\ub77c \ub2e4\uc591\ud55c \uc624\ube0c\uc81d\ud2b8\ub4e4\uc774 \ucd94\uac00\ub429\ub2c8\ub2e4.\n\uc5ec\ub7ec\uac00\uc9c0\ub85c \uc11e\uc5ec\uc788\ub294 \uc624\ube0c\uc81d\ud2b8\ub4e4\uc744 \ub2e4\uc591\ud55c \ubc29\uc2dd\uc73c\ub85c \uc0ac\uc6a9\ud558\uac70\ub098 \ud53c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "\uacf5\uc744 \uccd0\uc11c \ubaa9\ud45c\uc5d0 \ub3c4\ub2ec\ud558\uc138\uc694! "}, {"images": {"nodes": [{"file_name": "2560x1440(center).png", "id": "5859453104114057", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982570_5859453114114056_7153307980094797108_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZzVaH-aiBB4Q7kNvgFuvyjy&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-3wHp_rjqc4hD4V6DTrrldJD3PDItk4LhaYv2tYn-oQ&oe=66D3103E"}, {"file_name": "512512.png", "id": "5432625313526981", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974671_5432625320193647_8093634522063172656_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6WHv_1cN3RkQ7kNvgHqC6wB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLyVhKd-v39y3_ajTaHz2CsW2NTzI4pSZ2YjQq4xSFpg&oe=66D3073A"}, {"file_name": "Puzzle_1080x1440 (1).png", "id": "3450542885267672", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031651_3450542888601005_200028798780483052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H8vx1uK2mZEQ7kNvgEhmJCr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIvQKuddPjcA4BrQ2vWot6HiZAKEoV9MSsUsOHowXCyw&oe=66D30DF3"}, {"file_name": "3000x900(center).png", "id": "3422418134745562", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035430_3422418138078895_7729259882736740377_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0rOhFOxI3eUQ7kNvgE8gzQN&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1-lipcJWkkxM_LA2Sd8jYHZb0m19OstwkALYtBeerOQ&oe=66D2F5FB"}, {"file_name": "1440x1440(mid_center).png", "id": "1137601130247917", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_1137601133581250_9002130188810299527_n.png?_nc_cat=109&ccb=1-7&_nc_sid