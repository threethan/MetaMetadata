 {"file_name": "[\ud06c\uae30\ubcc0\ud658]256image (16).png", "id": "2016085681927337", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984454_2016085685260670_5861501969455355848_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HX9Jtl2-K8oQ7kNvgFMsI6G&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhCtJjObn8hrwH06GgHSyFCHRtQUFisVVuQMpcOJT3dQ&oe=66D2E610"}, {"file_name": "[\ud06c\uae30\ubcc0\ud658]256PUTTZZLE_RAW_IMAGE_8.png", "id": "1174988316468342", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982474_1174988319801675_5356656402935387114_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W5Ck2XNXNXcQ7kNvgF0W53R&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZsyMGXMFZoGGNMFxFUyB4bj_hpI_ZL93fb1pkSCDh2A&oe=66D2EB1C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\ucea1\ucc98_2022_10_28_17_08_12_390.png", "id": "665571025131462", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222944_665571028464795_3967012109877024291_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PYh9zi7bnEIQ7kNvgE3zAUT&_nc_ht=scontent.oculuscdn.com&oh=00_AYAASellRYiDa-sOp8woADfUlsSW2xtYLV-gIJSyu6PMLA&oe=66D300EA"}, "display_name": "PUTTZZLE", "keywords": [], "long_description": "You have only one objective in this game:  Putt your ball into the hole. \nIn order to do so, you will be given two items in this game: a hammer and a heavy ball.\n\nJust putt the ball into the hole to complete each stage. \n-Try to avoid various terrain and obstacles.\n-Try using any method to complete the stage with the number of given opportunities.\n \n[Intuitive controls]\nPUTTZZLE is simple. Just putt the ball into the hole by any means. \n\n[Entertainment from simplicity]\nJust focus on putting the ball into the target.\nCalculate the number of cases to solve each stage. \n\n[Increasing difficulty level]\n[PUTTZLE] is like a puzzle. You will experience more complicated stages as you finish each stage with even more obstacles. \nYou can even utilize obstacles or avoid them to finish the stage.", "short_description": "PUTT YOUR BALL IN IT! "}]}, "developer_name": "Pixelity Gamelab", "developer_privacy_policy_url": "https://pixelitygames.com/privacy-policy/?lang=en", "developer_terms_of_service_url": "https://pixelitygames.com/terms-of-service/", "publisher_name": "Pixelity Games Inc.", "support_website_url": null, "website_url": "https://pixelitygames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "zh_CN", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1697321224016681"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "721355552939864"}]}, "baseline_offer": {"id": "721355552939864"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1679545560, "status": "PUBLISHED", "id": "721355552939864"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6369826359747095", "version": "1.009"}, "id": "1292486504902555", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5891847114211691", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6369826359747095"}, "release_status": "RELEASED"}, "b