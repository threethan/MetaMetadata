_EBafTgiAJLSiWsYeGw&oe=66CC5A8B"}, {"file_name": "2023 Toy Trains screenshot_7 (Kopiowanie).png", "id": "311265114609050", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75356795_311265117942383_4132252106390141864_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zFfilD6zkAkQ7kNvgHHj3CF&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtQ-Ta2iyDsK5R9vZ_x28_6_PMnDQ7Y0nweKiNdxrhPA&oe=66CC7F76"}, {"file_name": "2023 Toy Trains screenshot_6 (Kopiowanie).png", "id": "717005983498254", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036632_717005990164920_6428213977336499984_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wKBbDytgBccQ7kNvgEIPDch&_nc_ht=scontent.oculuscdn.com&oh=00_AYAN3jpWyRor6ZIE4tiAwV0KDrRe_1p_QPM7b_iEvn18GA&oe=66CC7AB8"}, {"file_name": "2023 Toy Trains screenshot_3 (Kopiowanie).png", "id": "637033478520846", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86659796_637033488520845_1241647252826675057_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VY40_kiZF50Q7kNvgHormhh&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvs3pGphQ5KAFaCPiX-M6h05U-6hG31wEAhrZPzGdedg&oe=66CC712F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2023 Something Random - Toy Trains Meta Landscape.png", "id": "627230326172819", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_627230332839485_7318226998435881057_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zHzxODnaTf4Q7kNvgE4WFdb&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8rUmXRlAqc9B7dgxHtO6DLR8XcI-0JI-6GmZsHOKYdA&oe=66CC4EA2"}, "display_name": "Toy Trains", "keywords": [], "long_description": "Create your own railroads, relax and go back to your childhood. Are you ready? Hop on board! \n\nToy Trains is a playful track-building game with a nostalgic yet heartwarming storyline. Use your logic skills and imagination to construct trails and create your own small world. All that while enjoying cozy and relaxing vibes.\n\nRediscover building rails in a modern way. Each map has many possible solutions- you need to stay sharp, but can get as creative as you want!\n\nIn Toy Trains you can:\n\nBe creative - try various options to solve open-ended challenges\n\nExpress yourself - decorate the land in your individual style\n\nPlay with the world itself - splash some water, move the trees or have fun with little Railies!\n\nGo back in time - experience child-like joy and live through a nostalgic storyline\n\nRelax - there is no rush and no stress in the Toy Trains land\n\nImmerse - feel all that and more in the most captivating way - VR!", "short_description": "Let\u2019s play Toy Trains! Bringing back childhood fun in a modern way.\nA playful track-building VR game where you create your own small world and engage in a captivating storyline. It\u2019s all about imagination, creative thinking, having fun and\u2026 trains!"}]}, "developer_name": "Something Random", "developer_privacy_policy_url": "https://somethingrandom.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Something Random", "support_website_url": null, "website_url": "https://somethingrandom.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7130706496952439"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1568399520690534"}, {"status": "PUBLISHED", "id": "1290381162345162"}, {"status": "PUBLISHE