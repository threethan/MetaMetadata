_IqUozYqsebxyoV4jmQJdJP5F7oeSg&oe=67431D05"}, {"file_name": "SS5.png", "id": "1283473125438380", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43997713_1283473128771713_1287480329321943965_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPp5xmUs2OUQ7kNvgH0EAjo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAzmUMF_nZHM88nDZzthvM21CfEFQll7B7kpw_EGzSHpw&oe=67431CA7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "387279186391744", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/227814956_387279189725077_1445232967153819591_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sH_NRJasBXAQ7kNvgHldqVf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSclOtViF-VGot-wqdnpz-yP5ew5StSDnqu_XxqwEUSA&oe=67430881"}, "display_name": "X\uff08\u30ab\u30a4\uff09-\u5c01\u4f53\u5f0fX-", "keywords": [], "long_description": "\u548c\u98a8\u30b3\u30de\u30f3\u30c9\u578b\u30a2\u30af\u30b7\u30e7\u30f3\u30b2\u30fc\u30e0\u3002\n\u4e8c\u4eba\u306e\u5f0f\u3092\u6307\u63ee\u3057\u3066\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002\n\u5408\u4f53\u653b\u6483\u306f\u723d\u5feb\u3067\u3059\u3002\n\u5996(\u3042\u3084\u304b\u3057)\u5947\u8b5a\u3001\u305c\u3072\u4f53\u9a13\u3057\u3066\u304f\u3060\u3055\u3044 !\n\n\u2022 \u64cd\u4f5c\u65b9\u6cd5\n\u30cf\u30f3\u30c9\u30c8\u30e9\u30c3\u30ad\u30f3\u30b0\u5c02\u7528\u3067\u3059\u3002\n\u79fb\u52d5\u306f\u81ea\u52d5\u3067\u3059\u3002\n\u30b3\u30de\u30f3\u30c9\u30dc\u30bf\u30f3\u5f62\u5f0f\u3067\u3059\u304c\u3001\u4e00\u90e8\u30b8\u30a7\u30b9\u30c1\u30e3\u30fc\u306b\u3088\u308b\u64cd\u4f5c\u3082\u3042\u308a\u307e\u3059\u3002\n1.\u638c\u3092\u4e0a\u306b\u5411\u3051\u308b\n   \u305d\u308c\u305e\u308c\u306e\u5f0f\u306e\u30e1\u30cb\u30e5\u30fc\u753b\u9762\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\n   \u6307\u793a\u3057\u305f\u3044\u5185\u5bb9\u306e\u30dc\u30bf\u30f3\u3092\u4eba\u5dee\u3057\u6307\u3067\u62bc\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n2.\u4e21\u624b\u3092\u30d1\u30fc\u306b\u3057\u3066\u524d\u65b9\u306b\u5411\u3051\u308b\n   \u30a2\u30a4\u30c6\u30e0\u304c\u51fa\u73fe\u3057\u3066\u308b\u5834\u5408\u3001\u56de\u53ce\u3067\u304d\u307e\u3059\u3002\n3.\u4e21\u624b\u306e\u638c\u3092\u4e0a\u306b\u5411\u3051\u305f\u72b6\u614b\u3067\u62f3\u3092\u63e1\u308a\u529b\u3092\u305f\u3081\u308b\n   \u546a\u7b26\u3092\u6301\u3063\u3066\u3044\u308b\u5834\u5408\u3001\u5408\u4f53\u653b\u6483\u304c\u4f7f\u3048\u307e\u3059\u3002\n\n\u2022 \u30b2\u30fc\u30e0\u306e\u9032\u3081\u65b9\n1.\u30b9\u30bf\u30fc\u30c8\n   [\u958b\u59cb]\u30dc\u30bf\u30f3 -> [\u6700\u521d\u304b\u3089]\u30dc\u30bf\u30f3\u3092\u4eba\u5dee\u3057\u6307\u3067\u62bc\u3057\u3066\u30b9\u30bf\u30fc\u30c8\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n   ([\u958b\u59cb]\u30dc\u30bf\u30f3 -> [\u6226\u95d8\u304b\u3089]\u30dc\u30bf\u30f3\u3092\u9078\u3076\u3068\u30aa\u30fc\u30d7\u30cb\u30f3\u30b0\u3092\u30b9\u30ad\u30c3\u30d7\u3067\u304d\u307e\u3059\u3002)\n2.\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\n   \u79fb\u52d5\u306f\u81ea\u52d5\u3067\u3059\u3002\n   \u4e8c\u4eba\u306e\u5f0f\u3092\u6307\u63ee\u3057\u3066\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002\n3.\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\n   \u5f0f\u304c\u4e8c\u4eba\u5171\u5012\u308c\u308b\u3068\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\u3067\u3059\u3002\n4.\u30af\u30ea\u30a2\n   \u30dc\u30b9\u3092\u5012\u305b\u3070\u30b2\u30fc\u30e0\u30af\u30ea\u30a2\u3067\u3059\u3002\n\n\u2022 \u30b9\u30c8\u30fc\u30ea\u30fc\n948\u5e74(\u5929\u66a62\u5e74)7\u6708\u67d0\u65e5\u3002\u4eac\u306e\u4e00\u89d2\u306b\u3042\u308b\u793e\u306b\u3066\u3002\n\u305d\u306e\u65e5\u306e\u591c\u306f\u3001\u666e\u6bb5\u3068\u305d\u3046\u5909\u308f\u308a\u306a\u304b\u3063\u305f\u3002\n\u3068\u3066\u3082\u7a4f\u3084\u304b\u306a\u7a7a\u6c17\u304c\u6d41\u308c\u3066\u3044\u305f\u3002\n\u5f0f\u306e\u4e00\u4eba\u30fb\u672a\u685c(\u30df\u30aa)\u306f\u7e01\u5074\u3067\u597d\u7269\u306e\u7518\u6817\u5b50\u3092\u982c\u5f35\u308a\u3001\n\u3082\u3046\u4e00\u4eba\u306e\u5f0f\u30fb\u4ee4\u685c(\u30ec\u30aa)\u3082\u307e\u305f\u3001\u305d\u306e\u96a3\u3067\u5927\u597d\u304d\u306a\u524a\u308a\u6c37\u306b\u820c\u9f13\u3092\u3046\u3063\u3066\u3044\u305f\u3002\n\u3053\u306e\u3068\u3053\u308d\u9b3c\u306f\u5927\u4eba\u3057\u304f\u3001\u4eac\u5207\u3063\u3066\u306e\u9670\u967d\u5e2b\u3067\u3042\u308b\u4e3b\u4eba\u516c\u3082\u5b89\u5835\u3057\u3066\u4e8c\u4eba\u3092\u898b\u3066\u3044\u305f\u3002\n\u305d\u308c\u306f\u6cb9\u65ad\u3060\u3063\u305f\u306e\u304b\u3002\n\u793e\u306e\u5ead\u306b\u4e00\u5339\u3001\u8ff7\u3044\u8fbc\u3093\u3067\u3044\u308b\u5b58\u5728\u306b\u3001\u6c17\u304c\u4ed8\u3044\u305f\u6642\u306b\u306f\u9045\u304b\u3063\u305f\u3002\n\u30fb\u30fb\u30fb\u72d0 ?\n\u96f7\u6483\u304c\u8972\u3046\u3002\n\u666e\u6bb5\u81ea\u5206\u304c\u5f97\u610f\u3068\u3059\u308b\u8853\u3060\u3002\n\u300c\u306a\u306b ! ? \u300d\u300c\u4e3b(\u3042\u308b\u3058)\u69d8 ! \u300d\n\u6700\u5f8c\u306b\u805e\u3053\u3048\u305f\u306e\u306f\u3001\u4fe1\u983c\u3059\u308b\u5f0f\u795e\u305f\u3061\u306e\u58f0\u3060\u3063\u305f\u3002\n\u5927\u4e08\u592b\u3002\u541b\u305f\u3061\u306b\u4efb\u305b\u305f\u3002\n\u4e3b\u4eba\u516c\u306e\u610f\u8b58\u306f\u9759\u304b\u306b\u9060\u306e\u3044\u3066\u3044\u3063\u305f\u3002\u3002", "short_description": "\u548c\u98a8\u30b3\u30de\u30f3\u30c9\u578b\u30a2\u30af\u30b7\u30e7\u30f3\u30b2\u30fc\u30e0\u3002\n\u4e8c\u4eba\u306e\u5f0f\u3092\u6307\u63ee\u3057\u3066\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002\n\u5408\u4f53\u653b\u6483\u306f\u723d\u5feb\u3067\u3059\u3002\n\u5996(\u3042\u3084\u304b\u3057)\u5947\u8b5a\u3001\u305c\u3072\u4f53\u9a13\u3057\u3066\u304f\u3060\u3055\u3044 !"}, {"images": {"nodes": [{"file_name": "HX_CA_YE.png", "id": "8560463794051245", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974913_8560463797384578_1222115922495257013_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYwokkRk5YkQ7kNvgHiKSHB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBije22KqzSK8RFsY004X5sR