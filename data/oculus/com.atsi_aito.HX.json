001\u4e00\u90e8\u30b8\u30a7\u30b9\u30c1\u30e3\u30fc\u306b\u3088\u308b\u64cd\u4f5c\u3082\u3042\u308a\u307e\u3059\u3002\n1.\u638c\u3092\u4e0a\u306b\u5411\u3051\u308b\n   \u305d\u308c\u305e\u308c\u306e\u5f0f\u306e\u30e1\u30cb\u30e5\u30fc\u753b\u9762\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\n   \u6307\u793a\u3057\u305f\u3044\u5185\u5bb9\u306e\u30dc\u30bf\u30f3\u3092\u4eba\u5dee\u3057\u6307\u3067\u62bc\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n2.\u4e21\u624b\u3092\u30d1\u30fc\u306b\u3057\u3066\u524d\u65b9\u306b\u5411\u3051\u308b\n   \u30a2\u30a4\u30c6\u30e0\u304c\u51fa\u73fe\u3057\u3066\u308b\u5834\u5408\u3001\u56de\u53ce\u3067\u304d\u307e\u3059\u3002\n3.\u4e21\u624b\u306e\u638c\u3092\u4e0a\u306b\u5411\u3051\u305f\u72b6\u614b\u3067\u62f3\u3092\u63e1\u308a\u529b\u3092\u305f\u3081\u308b\n   \u546a\u7b26\u3092\u6301\u3063\u3066\u3044\u308b\u5834\u5408\u3001\u5408\u4f53\u653b\u6483\u304c\u4f7f\u3048\u307e\u3059\u3002\n\n\u2022 \u30b2\u30fc\u30e0\u306e\u9032\u3081\u65b9\n1.\u30b9\u30bf\u30fc\u30c8\n   [\u958b\u59cb]\u30dc\u30bf\u30f3 -> [\u6700\u521d\u304b\u3089]\u30dc\u30bf\u30f3\u3092\u4eba\u5dee\u3057\u6307\u3067\u62bc\u3057\u3066\u30b9\u30bf\u30fc\u30c8\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n   ([\u958b\u59cb]\u30dc\u30bf\u30f3 -> [\u6226\u95d8\u304b\u3089]\u30dc\u30bf\u30f3\u3092\u9078\u3076\u3068\u30aa\u30fc\u30d7\u30cb\u30f3\u30b0\u3092\u30b9\u30ad\u30c3\u30d7\u3067\u304d\u307e\u3059\u3002)\n2.\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\n   \u79fb\u52d5\u306f\u81ea\u52d5\u3067\u3059\u3002\n   \u4e8c\u4eba\u306e\u5f0f\u3092\u6307\u63ee\u3057\u3066\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002\n3.\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\n   \u5f0f\u304c\u4e8c\u4eba\u5171\u5012\u308c\u308b\u3068\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\u3067\u3059\u3002\n4.\u30af\u30ea\u30a2\n   \u30dc\u30b9\u3092\u5012\u305b\u3070\u30b2\u30fc\u30e0\u30af\u30ea\u30a2\u3067\u3059\u3002\n\n\u2022 \u30b9\u30c8\u30fc\u30ea\u30fc\n948\u5e74(\u5929\u66a62\u5e74)7\u6708\u67d0\u65e5\u30