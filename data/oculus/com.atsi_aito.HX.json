\u30d1\u30fc\u306b\u3057\u3066\u524d\u65b9\u306b\u5411\u3051\u308b\n   \u30a2\u30a4\u30c6\u30e0\u304c\u51fa\u73fe\u3057\u3066\u308b\u5834\u5408\u3001\u56de\u53ce\u3067\u304d\u307e\u3059\u3002\n3.\u4e21\u624b\u306e\u638c\u3092\u4e0a\u306b\u5411\u3051\u305f\u72b6\u614b\u3067\u62f3\u3092\u63e1\u308a\u529b\u3092\u305f\u3081\u308b\n   \u546a\u7b26\u3092\u6301\u3063\u3066\u3044\u308b\u5834\u5408\u3001\u5408\u4f53\u653b\u6483\u304c\u4f7f\u3048\u307e\u3059\u3002\n\n\u2022 \u30b2\u30fc\u30e0\u306e\u9032\u3081\u65b9\n1.\u30b9\u30bf\u30fc\u30c8\n   [\u958b\u59cb]\u30dc\u30bf\u30f3 -> [\u6700\u521d\u304b\u3089]\u30dc\u30bf\u30f3\u3092\u4eba\u5dee\u3057\u6307\u3067\u62bc\u3057\u3066\u30b9\u30bf\u30fc\u30c8\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n   ([\u958b\u59cb]\u30dc\u30bf\u30f3 -> [\u6226\u95d8\u304b\u3089]\u30dc\u30bf\u30f3\u3092\u9078\u3076\u3068\u30aa\u30fc\u30d7\u30cb\u30f3\u30b0\u3092\u30b9\u30ad\u30c3\u30d7\u3067\u304d\u307e\u3059\u3002)\n2.\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\n   \u79fb\u52d5\u306f\u81ea\u52d5\u3067\u3059\u3002\n   \u4e8c\u4eba\u306e\u5f0f\u3092\u6307\u63ee\u3057\u3066\u9032\u3081\u3066\u3044\u304d\u307e\u3059\u3002\n3.\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\n   \u5f0f\u304c\u4e8c\u4eba\u5171\u5012\u308c\u308b\u3068\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\u3067\u3059\u3002\n4.\u30af\u30ea\u30a2\n   \u30dc\u30b9\u3092\u5012\u305b\u3070\u30b2\u30fc\u30e0\u30af\u30ea\u30a2\u3067\u3059\u3002\n\n\u2022 \u30b9\u30c8\u30fc\u30ea\u30fc\n948\u5e74(\u5929\u66a62\u5e74)7\u6708\u67d0\u65e5\u3002\u4eac\u306e\u4e00\u89d2\u306b\u3042\u308b\u793e\u306b\u3066\u3002\n\u305d\u306e\u65e5\u306e\u591c\u306f\u3001\u666e\u6bb5\u3068\u305d\u3046\u5909\u308f\u308a\u306a\u304b\u3063\u305f\u3002\n\u3068\u3066\u3082\u7a4f\u3084\u304b\u306a\u7a7a\u6c17\u304c\u6d41\u308c\u3066\u3044\u305f\u3002\n\u5f0f\u306e\u4e00\u4eba\u30fb\u672a\u685c(\u30df\u30aa)\u306f\u7e01\u5074\u3067\u597d\u7269\u306e\u7518\u6817\u5b50\u3092\u982c\u5f35\u308a\u3001\n\u3082\u3046\u4e00\u4eba\u306e\u5