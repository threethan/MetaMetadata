me": "SS4.png", "id": "557067342277247", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982601_557067345610580_2643583288745186122_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EeWkA00aM-0Q7kNvgHUcjl7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwuwBYLBz09V44X558FXVq4&oh=00_AYD6amRt4qqViuHawCYrMVomDneo43-Nxd90fQBTAp875A&oe=66E82B24"}, {"file_name": "SS5.png", "id": "2986662874985687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_2986662878319020_5099916742723345427_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fI50q5jb2XQQ7kNvgG_EVhP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwuwBYLBz09V44X558FXVq4&oh=00_AYCBGpM7woRNohZp8pBqbptpS0PTcTDeiv0rQ8uDsR72Pg&oe=66E81DE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "238958778249444", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982614_238958781582777_7266351533833194001_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=emzunuw8uyEQ7kNvgE7yHif&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwuwBYLBz09V44X558FXVq4&oh=00_AYAzg62VI114erKJomw09w5B1XMKpWLjz0x3F0SamSlDSQ&oe=66E827A6"}, "display_name": "X\uff08Kai\uff09-HouteishikiX-", "keywords": [], "long_description": "Japanese-style command-type action game.\nYou will command the two Shikigami.\nThe coalescing attack is exhilarating.\nPlease experience the Youkai tale!\n\n\u2022 Method of operation\nFor hand tracking only.\nThe move is automatic.\nAlthough it is a command button format, some operations are also performed by gestures:\n1.Turn your palm up\nThe menu screen for each Shikigami is displayed.\n2.Turn both hands forward(Both hands are Paper)\nIf the item appears, you can collect it.\n3.Hold your fist with the palms of both hands facing up and accumulate power\nIf you have a Ofuda-item, you can use the combined attack.\n\n\u2022 How to proceed with the game\n1.Start\nPress the[Start]button -> [Beginning]button with your index finger to start.\n(You can skip the opening by selecting the[Start]button -> [Battle]button)\n2.GamePlay\nOnce started, the move is automatic.\nWe will command the two Shikigami.\n3.GameOver\nIf both Shikigami are defeated, the game is over.\n4.GameClear\nThe game is cleared when the boss is defeated.", "short_description": "Japanese-style command-type action game.\nYou will command the two Shikigami.\nThe coalescing attack is exhilarating.\nPlease experience the Youkai tale!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/houteishikix", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "638430234145733"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_993883524488210_2780652711164647889_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tKUK9u0FqvMQ7kNvgFHVd2v&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwuwBYLBz09V44X558FXVq4&oh=00_AYD-H_o1EqRAZLe4hVzPZf0iJzdzVDpPFzlhwBMU4UO3Lg&oe=66E82D56"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "X\uff08Kai\uff09-HouteishikiX-", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1637190390, "lastRevision": {"nodes": [{"id": "553494935958392", "release_type": 