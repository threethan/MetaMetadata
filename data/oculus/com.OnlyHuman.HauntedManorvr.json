24047140_8069668517731985338_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QNJWW3sRMicQ7kNvgHLt6xc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANafTY3Meu9JRPEAdxv8XIg&oh=00_AYB4DLvjPMsIEDxpxqJxumY9KHrGnH92mH5CeqQeEUq5uQ&oe=66E18F6A"}, {"file_name": "12504788_1921243957920437_1890310536847949824_n.png", "id": "998293180993537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974685_998293184326870_6021562107788072745_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=29nQeI6FcW0Q7kNvgFD4P0D&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANafTY3Meu9JRPEAdxv8XIg&oh=00_AYC6y5E0Qy-IAvpKAoc7pCnAse17n55n35zWNIhXsDk2fA&oe=66E17228"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Secret of Harrow Manor", "keywords": [], "long_description": "Inspired by classic survival horror gameplay, you find yourself in an abandoned mansion infested with zombies. To survive and progress, you'll need to search the area for weapons, healing items, and keys.\n\nFeatures:\n-4 interconnected levels filled with monsters and items\n-A co-op multiplayer mode with random enemy and item spawn locations\n-A carefully crafted inventory system, watch your ammo so you don't get caught by surprise!", "short_description": "Search an abandoned property filled with zombies, weapons, and locked doors."}]}, "developer_name": null, "developer_privacy_policy_url": "https://termsfeed.com/privacy-policy/65bcf3a588602f2deb936a9f5489403a", "developer_terms_of_service_url": "https://termsfeed.com/terms-service/aab7178afd09470fc468a3e7fb404ffd", "publisher_name": "Only Human Studios", "support_website_url": null, "website_url": "http://www.onlyhumanstudios.net/secret-of-harrow-manor", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_gra