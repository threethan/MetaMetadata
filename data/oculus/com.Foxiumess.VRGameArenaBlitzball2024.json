1", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568677_714496174095074_8687706310137870318_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9hMSPFjnRvMQ7kNvgFfMfLl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_qwKy9ccqKcmF5-PXDWmaFK-JE08uQ5LcPuCovinQ1w&oe=67680821"}, {"file_name": "com.Foxiumess.VRGameArenaBlitzba.png", "id": "809414887743404", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031653_809414891076737_5169557338444859473_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VwBA8-VDNsoQ7kNvgH4ynGh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAB7VwSrGmTHWh0FSpaM8JLb0k93i8433OB2LYIPS28GQ&oe=6767EA5A"}, {"file_name": "com.Foxiumess.VRGameArenaBlitzba (1).png", "id": "433048902640095", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001676_433048905973428_6300093401786778216_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9YR8-wPawx4Q7kNvgFGrKPz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9j_DTS8xeLb_f4Vufg_HMUlDrxD9g0uup5UPPit6fBg&oe=6767E94B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "kiji foto.png", "id": "1352686432066947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75514545_1352686442066946_3260931878111429490_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qHqY5gyuIQEQ7kNvgFqT4xb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBoLBpKFoFTpyf1i4kL7hMxk20lcSEP_aEgG-eLYbyx7A&oe=6767F6CE"}, "display_name": "Arena \u00a5 Blitz", "keywords": [], "long_description": "\"Get ready for the epic challenge of Arena Blitz, where you'll face not one, but two AI opponents, along with a formidable goalkeeper! In this unique battle, you're the sole defender of your goal and tasked with scoring goals against a double threat. However, beware of the journey ahead, as the game is still in development and may encounter some bugs along the way. Utilize cunning and skill to overcome opposing defenses, dribble past the goalkeeper, and score spectacular goals. Conquer victory in this intense showdown and become the champion of Arena Blitz!\"", "short_description": "Game inspired by the underwater sport called Blitzball."}]}, "developer_name": null, "developer_privacy_policy_url": "https://foxiumess.wixsite.com/arena---blitz", "developer_terms_of_service_url": null, "publisher_name": "Foxiumess", "support_website_url": null, "website_url": "https://foxiumess.wixsite.com/arena---blitz", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7534327056606081"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1824791001338679"}, {"status": "PUBLISHED", "id": "1536705280246883"}]}, "baseline_offer": {"id": "1824791001338679"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1716240060, "status": "PUBLISHED", "id": "1824791001338679"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7534354996603287", "version": "1"}, "id": "1091339825409454", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7534327046606082", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7534354996603287"}, "release_status": "RELEASED"}, "binary_release_