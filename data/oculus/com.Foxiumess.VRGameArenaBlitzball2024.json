8687706310137870318_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABjEcSoDO6gQ7kNvgEIK31N&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6g3yfXFvbxZvVYsDUw9SusVLa_row2mbERB2INysaVw&oe=670E6221"}, {"file_name": "com.Foxiumess.VRGameArenaBlitzba.png", "id": "809414887743404", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031653_809414891076737_5169557338444859473_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uBG5LaekfdUQ7kNvgGHFs3i&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrqRzLL7Ofch2EZQ-oUe-MIKg-zH93UbU5YS-VnvdsJg&oe=670E445A"}, {"file_name": "com.Foxiumess.VRGameArenaBlitzba (1).png", "id": "433048902640095", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001676_433048905973428_6300093401786778216_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QlQ9A1JU5VgQ7kNvgGiRkjH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFVMCRha6MaWm67EMxhsbTSAIehsFz2V97EvGSPDZkDA&oe=670E434B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "kiji foto.png", "id": "1352686432066947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75514545_1352686442066946_3260931878111429490_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R7_xnLrDIhwQ7kNvgErnU1a&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrCbzfPE-ijajPw7RdxsB10zIBCy_hDnt3ttIsNWd5ag&oe=670E50CE"}, "display_name": "Arena \u00a5 Blitz", "keywords": [], "long_description": "\"Get ready for the epic challenge of Arena Blitz, where you'll face not one, but two AI opponents, along with a formidable goalkeeper! In this unique battle, you're the sole defender of your goal and tasked with scoring goals against a double threat. However, beware of the journey ahead, as the game is still in development and may encounter some bugs along the way. Utilize cunning and skill to overcome opposing defenses, dribble past the goalkeeper, and score spectacular goals. Conquer victory in this intense showdown and become the champion of Arena Blitz!\"", "short_description": "Game inspired by