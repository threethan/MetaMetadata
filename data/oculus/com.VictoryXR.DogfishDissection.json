reen_3840x2160_2019-12-02_15-49-47.png", "id": "281061263541872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974631_281061266875205_7254659065876499638_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdBGkW0l6PoQ7kNvgGLROPx&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATosC_UK-jZ_dGJdVJCxJJn&oh=00_AYAcgMVvHC9LFWLx_nQAzMKYHkZih6_ydh1pwBzlSoBKqA&oe=66F54BB8"}, {"file_name": "screen_3840x2160_2019-12-02_15-52-45.png", "id": "2968625460047474", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003281_2968625463380807_1303566356059562836_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZumJCder6xMQ7kNvgH1GmGq&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATosC_UK-jZ_dGJdVJCxJJn&oh=00_AYACQkiNW3sFX57TOLHBGeu0y-TGTipSQDLp6eELzFqUqQ&oe=66F52D51"}, {"file_name": "screen_3840x2160_2019-12-02_15-50-56.png", "id": "272057371142026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_272057374475359_905158201368232535_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rtntIcSTQ90Q7kNvgEKLUR3&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATosC_UK-jZ_dGJdVJCxJJn&oh=00_AYBHqLuwkfmGPjnSkNSpaYzYpP09nLqDahEMptlIdDQ5UQ&oe=66F559EE"}, {"file_name": "screen_3840x2160_2019-12-02_15-48-56.png", "id": "5179772605398058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031449_5179772608731391_6735295695570050880_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DUSC4QWFABgQ7kNvgEoVxol&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATosC_UK-jZ_dGJdVJCxJJn&oh=00_AYBmSfOgJ0CKo4k4u50j8PkY0iJeU66REho0LDQpDxAyoA&oe=66F54DCE"}, {"file_name": "screen_3840x2160_2019-12-02_15-55-57.png", "id": "858192835037450", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003245_858192838370783_4517972656687566193_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m3FK4WLDQ6QQ7kNvgHVBBrG&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATosC_UK-jZ_dGJdVJCxJJn&oh=00_AYChfJUq-F2GiqU-Pn1BXbs3lNN7glVOJj4_UgHC6x_9uA&oe=66F541E0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-12-02_15-50-56.png", "id": "245067367253838", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974558_245067370587171_3803449818666952260_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D1C4XNkj_fAQ7kNvgFjpKXL&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATosC_UK-jZ_dGJdVJCxJJn&oh=00_AYABBd6xqMWf84H4yRQQNx1TMHkNcSLHU0USfY55i3LDbw&oe=66F557D9"}, "display_name": "Dissection Simulator: Shark Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual shark dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality shark dissection in Dissection Simulator: Dogfish Edition. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual shark dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality shark dissection in Dissection Simulator: Dogfish Edition. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_n