reen_3840x2160_2019-12-02_15-49-47.png", "id": "281061263541872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974631_281061266875205_7254659065876499638_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdBGkW0l6PoQ7kNvgFm2U3c&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aifu9vy35ePesIcvTu-Pmdg&oh=00_AYD-nbWCQL2GjOl2q449s6JWgYFpdOfVMAhBZeWVQOFdlg&oe=66F2A8B8"}, {"file_name": "screen_3840x2160_2019-12-02_15-52-45.png", "id": "2968625460047474", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003281_2968625463380807_1303566356059562836_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=22-f6Tg5jb4Q7kNvgGdeNaG&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aifu9vy35ePesIcvTu-Pmdg&oh=00_AYBSXvj3_dpjPTjC9PzfDUg6lWSmUe3vKZ22CtDUbHwi3A&oe=66F28A51"}, {"file_name": "screen_3840x2160_2019-12-02_15-50-56.png", "id": "272057371142026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_272057374475359_905158201368232535_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z2aHWOVefBQQ7kNvgH7aoEd&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aifu9vy35ePesIcvTu-Pmdg&oh=00_AYCLWPHeMv_qLn5L7wD6Xv5lFjlQq-CXJ6Ki662XuaHr4w&oe=66F2B6EE"}, {"file_name": "screen_3840x2160_2019-12-02_15-48-56.png", "id": "5179772605398058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031449_5179772608731391_6735295695570050880_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jTQ5tafzY8MQ7kNvgHV9N9e&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aifu9vy35ePesIcvTu-Pmdg&oh=00_AYBrtbARkh-NfXi9mqqe0T7iit81xouTCEkYawGu2dprtQ&oe=66F2AACE"}, {"file_name": "screen_3840x2160_2019-12-02_15-55-57.png", "id": "858192835037450", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003245_858192838370783_4517972656687566193_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m3FK4WLDQ6QQ7kNvgGlaJx0&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aifu9vy35ePesIcvTu-Pmdg&oh=00_AYDivZX1Cd4CrA7AMEQ2pb7eNqtr_Q4DRZ_7EI4GU5abFw&oe=66F29EE0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-12-02_15-50-56.png", "id": "245067367253838", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974558_245067370587171_3803449818666952260_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pTTApaC6dbMQ7kNvgECdxlt&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aifu9vy35ePesIcvTu-Pmdg&oh=00_AYBHz0nSGDF3zRCU_0fVeolipy7tCdTYGIHFTGcdYR4aEg&oe=66F2B4D9"}, "display_name": "Dissection Simulator: Shark Edition", "keywords": [], "long_description": "VictoryXR\u2019s virtual shark dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality shark dissection in Dissection Simulator: Dogfish Edition. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections, without the safety and ethical implications.", "short_description": "VictoryXR\u2019s virtual shark dissection software is a hands-on opportunity experienced through the power of VR. Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality shark dissection in Dissection Simulator: Dogfish Edition. Learn the fundamentals of dogfish anatomy through its various systems in our fully immersive VR experience using Carolina Biological\u2019s expert curricula and process."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_n