ontent.oculuscdn.com&_nc_gid=A00quopZ61w9eALKGVyPrmi&oh=00_AYDIsfvbec7PtWQfpC5bh6ipbfZk7TtcojSEwdZ7Heg6LQ&oe=66EFEF57"}, {"file_name": "Back9Board_2K_PNG.png", "id": "262169482485579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569440_262169485818912_8878709059878914615_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D96uS8ssTw0Q7kNvgEPOUGj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A00quopZ61w9eALKGVyPrmi&oh=00_AYAySr5Bis9c4cJN_Gk3x4F_VgS6Y75sGYiC1xNIf3oQBg&oe=66F00538"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DiscBenders_CoverArt_16-9_2K_PNG.png", "id": "610076236830296", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_610076240163629_3637108208520596054_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ggwrg40VknQQ7kNvgGX0sZg&_nc_ht=scontent.oculuscdn.com&_nc_gid=A00quopZ61w9eALKGVyPrmi&oh=00_AYDqxXKmVkxZS_bWuw6FWrkxAtrU7cfZY3-g1KBKZRg6kQ&oe=66EFFF79"}, "display_name": "Disc Benders: Ace Run", "keywords": [], "long_description": "Disc Benders is the ultimate Disc Golf simulator | Hone your disc throwing skills in challenging courses and relaxing environments\n\nNow boasts four full courses, with over 45+ holes to play, five unique disc types to choose from, and two game modes: Free Play & Career Mode\n\nReview your course play at the post-game review board, with career stats that carry across play sessions, and visualizations of your throws for your round.\n\nBend alongside up to 4 of your friends (and others) as you keep score and socialize on the course.\n\nFreshly designed 9-hole course 'Dream Drop Bends' will test your ability to throw flexes and high elevation shots, with pro-level distances\n\n\n*WARNING: Game is no longer in development - Experience is a finished product*", "short_description": "Disc Benders is the ultimate Disc Golf simulator | Hone your disc throwing skills in challenging courses and relaxing environments"}]}, "developer_name": "Free Fall Studios", "developer_privacy_policy_url": "https://f