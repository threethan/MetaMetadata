cdn.com/v/t64.5771-25/38974757_397940084266380_9025072984481595392_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ae7FG6SyIwIQ7kNvgGSXXiY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDua2YDQx66keJNkmXVbDH6lwfApaq27P0UveIqNgFI6Q&oe=66FD2150"}, {"file_name": "migrated_image.png", "id": "208354003589968", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974884_2197361837011411_1867865703478984704_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w1CPV4bX7tsQ7kNvgE7_lzk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRkzxBf2Xmsac9gDsPv7LHHA6txuVU94I7kvUS2VS4Wg&oe=66FD3BFD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "765132785210196", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031465_765132788543529_2616402040080852547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YYokZtKew6YQ7kNvgFOUmZb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoKPzV36k4Rq3-bG-Kes3as-HYgESG1JFuAFarCyu5PA&oe=66FD1F51"}, "display_name": "Spice & Wolf VR", "keywords": ["VR", "anime", "SpiceAndWolf", "animation", "casual"], "long_description": "In order to achieve our dreams of entering the 2nd dimension, we will be working together with the original creators of Spice and Wolf to create a VR animation.\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d...\n\n-Story-\nKraft Lawrence is a traveling merchant who meets Holo, a beautiful woman who can transform into a wolf. \nAs they travel together they face many hardships, such as having to walk in the rain.\nIn order to avoid the sudden downpour, Holo and Lawrence take shelter in an old, abandoned water mill in the woods.\nThey huddle around a small fire and enjoy a slightly strange but relaxing time together.\nYou are able to share that time together with them.\n\nProduction Staff\nScenario: Isuna Hasekura\nCharacter Design: Ju Ayakura\nHolo\u2019s CV: Ami Koshimizu\nKraft Lawrence\u2019s CV: Jun Fukuyama", "short_descrip