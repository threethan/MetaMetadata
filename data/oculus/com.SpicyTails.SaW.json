DBBua-PmNr5hyhlQotA8mpjbvX7FZ-Vw&oe=6706658C"}, {"file_name": "migrated_image.png", "id": "224667652251737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974757_397940084266380_9025072984481595392_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=718nccH9K9oQ7kNvgHv-37W&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGCf-xLfIxlG3pdudFwuLlI7iCrRwB6FoVpdIatwvmZQ&oe=67065BD0"}, {"file_name": "migrated_image.png", "id": "208354003589968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974884_2197361837011411_1867865703478984704_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kR8teuNLlVgQ7kNvgG_4Uco&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAKHNVTR8-S6p_W_xjvAfVwRDOYtUU4GBGmHwEPdWdvmQ&oe=6706767D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "765132785210196", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031465_765132788543529_2616402040080852547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E8jYqqSsQQIQ7kNvgGgKk7h&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhWV2Sk_GG4rDJvMEpu53Ji1sX3ddXNwzL4IMq7hxNWA&oe=670659D1"}, "display_name": "Spice & Wolf VR", "keywords": ["VR", "anime", "SpiceAndWolf", "animation", "casual"], "long_description": "In order to achieve our dreams of entering the 2nd dimension, we will be working together with the original creators of Spice and Wolf to create a VR animation.\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d...\n\n-Story-\nKraft Lawrence is a traveling merchant who meets Holo, a beautiful woman who can transform into a wolf. \nAs they travel together they face many hardships, such as having to walk in the rain.\nIn order to avoid the sudden downpour, Holo and Lawrence take shelter in an old, abandoned water mill in the woods.\nThey huddle around a small fire and enjoy a slightly strange but relaxing time together.\nYou are able to share that time together with them.\n\nProduction Staff\nScenario: Isuna Hasekura\nCharacter Design: Ju Ayakura\nHolo\u2019s CV: Ami Koshimizu\nKraft Lawrence\u2019s CV: Jun Fukuyama", "short_description": "In order to achieve our dreams of entering the 2nd dimension, we will be making the popular light novel Spice and Wolf into a VR animation!\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d..."}, {"images": {"nodes": [{"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "1312770182747556", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569486_1312770186080889_6983067482496557378_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tWne6h-oAmgQ7kNvgE99O5-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVrpgwsdCQjUl0ZGMjpuspS_oVTaRN2hPCt4AMxKKDWA&oe=670683EE"}, {"file_name": "icon.png", "id": "1046890023048682", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974570_1046890026382015_5326259503890084427_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BcCI34B5dq0Q7kNvgGVXXcZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCc1yAW283nI6L9T1TuCvMvZKhxzLqjDtgF5fFJS2LUrg&oe=67065AA5"}, {"file_name": "38974776_311154146462238_1507323402505945088_n.png", "id": "922949202756842", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86795866_922949206090175_5400235612385493202_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PbT5MZRxM88Q7kNvgEIUmMC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDMdXqwbXkBX7ZB7pQ9ycXdhVE4vHq2sc4JSDTrZA34cw&oe=6706619B"}, {"file_name": "SAWVR_LOGO-01.png", "id": "913191853516787", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974653_913191856850120_3912966461662244200_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tROnt1B-mzQQ7kNvgF6jJFr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsr4EhdgGogB