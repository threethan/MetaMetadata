62166418108_1196811268598530048_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=607joPaKltAQ7kNvgF0qxbl&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIhi5L32qsx2_zCBmZO5U-eK8Iap5730l0Hs7vnq99Jw&oe=66FD1D26"}, {"file_name": "migrated_image.png", "id": "230535518134710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974576_1767770779989221_8287228342109732864_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tV-kuaWNAIIQ7kNvgGlPyuK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBN8rQpcereVgMB6SW_8nl7SB-siYT8YOREGexEnA4FfA&oe=66FD2B0C"}, {"file_name": "migrated_image.png", "id": "202167121053517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031407_658680041244802_5284501359834431488_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8I7BcqKuzMgQ7kNvgE-Ygh6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDk6CtlLjAIQ0i46_Q-KE9wOX0-l9LezJOqwVzbbb9xbw&oe=66FD47BA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/KMNgMe", "id": "789478568120580", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974836_789478571453913_7693851358599839744_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IwHlMeGfq4wQ7kNvgEiCgr3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCo5lp47dXuVFrbKGBhC39_uD0_rgNaquzfOl0diswRJQ&oe=66FD24C8"}, "display_name": "Spice & Wolf VR", "keywords": ["VR", "anime", "SpiceAndWolf", "animation", "casual"], "long_description": "In order to achieve our dreams of entering the 2nd dimension, we will be working together with the original creators of Spice and Wolf to create a VR animation.\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d...\n\n-Story-\nKraft Lawrence is a traveling merchant who meets Holo, a beautiful woman who can transform into a wolf. \nAs they travel together they face many hardships, such as having to walk in the rain.\nIn order to avoid the sudden downpour, Holo and Lawrence take shelter in an old, abandoned water mill in the woods.\nThey huddle around a small fire and enjoy a slightly strange but relaxing time together.\nYou are able to share that time together with them.\n\nProduction Staff\nScenario: Isuna Hasekura\nCharacter Design: Ju Ayakura\nHolo\u2019s CV: Ami Koshimizu\nKraft Lawrence\u2019s CV: Jun Fukuyama", "short_description": "In order to achieve our dreams of entering the 2nd dimension, we will be making the popular light novel Spice and Wolf into a VR animation!\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d..."}]}, "developer_name": "SpicyTails", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "SpicyTails", "support_website_url": null, "website_url": "http://spicy-tails.net/saw-vr/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "EXPERIENCE_360_NON_GAME", "MOVIE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "zh_TW", "zh_CN"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3006817202871861"}}]}, "scheduled_offers": {"count": 14, "nodes": [{"status": "PUBLISHED", "id": "780231129417773"}, {"status": "PUBLISHED", "id": "300658991269175"}, {"status": "PUBLISHED", "id": "773604656547726"}, {"status": "PUBLISHED", "id": "2775780575992536"}, {"status": "PUBLISHED", "id": "337555236877639"}, {"status": "PUBLISHED", "id": "991829724512959"}, {"status": "PUBLISHED", "id": "260778085352805"}, {"status": "PUBLISHED", "id": "616269065777417"}, {"status": "PUBLISHED", "id": "324173038861787"}, {"status": "PUBLISHED", "id": "2347420208884508"}, {"status": "PUBLISHED", "id": "3454170381272107"