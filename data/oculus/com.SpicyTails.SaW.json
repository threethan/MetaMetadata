YAPzPJC2hkwQ7kNvgFQ31cW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdoBLEB9fWUKuBYTyeVt3XdQKC7D0p728w0HjwdgUZ0A&oe=6773D20C"}, {"file_name": "migrated_image.png", "id": "224667652251737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974757_397940084266380_9025072984481595392_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w-U3SwMI6EcQ7kNvgHstBQa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5-38PAzGcKul-pRzcNKcZQFM0hBzqJYGIeVCe9zo7sw&oe=6773C850"}, {"file_name": "migrated_image.png", "id": "208354003589968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974884_2197361837011411_1867865703478984704_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HLsBRpHSurcQ7kNvgG6VbUt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5WYrQUcswpkMi0vm9ec14MY5_r_IRM0UUolTi6FbDqQ&oe=6773E2FD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "765132785210196", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031465_765132788543529_2616402040080852547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QBDfGEfHrWIQ7kNvgF_-wE7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBboT8Tm9qsKTF4Nm3C-zgH8sqFyJFSk0vgt8gBlCJPCw&oe=6773C651"}, "display_name": "Spice & Wolf VR", "keywords": ["VR", "anime", "SpiceAndWolf", "animation", "casual"], "long_description": "In order to achieve our dreams of entering the 2nd dimension, we will be working together with the original creators of Spice and Wolf to create a VR animation.\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d...\n\n-Story-\nKraft Lawrence is a traveling merchant who meets Holo, a beautiful woman who can transform into a wolf. \nAs they travel together they face many hardships, such as having to walk in the rain.\nIn order to avoid the sudden downpour, Holo and Lawrence take shelter in an old, abandoned water mill in the woods.\nThey huddle around a small fire and enjoy a slightly strange but relaxing time together.\nYou are able to share that time together with them.\n\nProduction Staff\nScenario: Isuna Hasekura\nCharacter Design: Ju Ayakura\nHolo\u2019s CV: Ami Koshimizu\nKraft Lawrence\u2019s CV: Jun Fukuyama", "short_description": "In order to achieve our dreams of entering the 2nd dimension, we will be making the popular light novel Spice and Wolf into a VR animation!\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d..."}, {"images": {"nodes": [{"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "1312770182747556", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569486_1312770186080889_6983067482496557378_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxlTaQ6AbVMQ7kNvgEVP_Ua&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDkPHVUYSjy1uvzH0AQK8Z0j8LwFDaWUe8ZGnR2hBulkQ&oe=6773F06E"}, {"file_name": "icon.png", "id": "1046890023048682", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974570_1046890026382015_5326259503890084427_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NOWzQvwhtTgQ7kNvgEddmeW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPXtDpQUWcLV5KnRrFZF6SpvC_ezPRcan3bRKfNpuUqw&oe=6773C725"}, {"file_name": "38974776_311154146462238_1507323402505945088_n.png", "id": "922949202756842", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86795866_922949206090175_5400235612385493202_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_YYvN83OBEEQ7kNvgFMS6_x&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDw2XaLHVDe56tN59gOnVg5j4ifxQwb4wNA6zQ6e2hFcg&oe=6773CE1B"}, {"file_name": "SAWVR_LOGO-01.png", "id": "913191853516787", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974653_913191856850120_391296