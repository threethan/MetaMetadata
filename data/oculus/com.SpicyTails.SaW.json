WcL8fokfTU4Q7kNvgFoeYyA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3txZpg3UhiFRTF3GRd2EuqXL0VeeZK56OAechas8ctw&oe=6765518C"}, {"file_name": "migrated_image.png", "id": "224667652251737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974757_397940084266380_9025072984481595392_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kT9bOD2eZLMQ7kNvgFXstW9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBu19KSG6TmqdxGRocpFv52-JHvY8IzPy-XVYA9j5X6sA&oe=676547D0"}, {"file_name": "migrated_image.png", "id": "208354003589968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974884_2197361837011411_1867865703478984704_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cnfQW3uYW5sQ7kNvgHJc_52&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3NW30IZO1ODhie3Oh2IUxS5v09ngKbrr0C-b2G_HXVw&oe=6765627D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "765132785210196", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031465_765132788543529_2616402040080852547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lySicbBA26gQ7kNvgG6R1a4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXq7vYXV1NaPfBnz7JUpJ08U4jnuvcANgPf0RgGyOPKw&oe=676545D1"}, "display_name": "Spice & Wolf VR", "keywords": ["VR", "anime", "SpiceAndWolf", "animation", "casual"], "long_description": "In order to achieve our dreams of entering the 2nd dimension, we will be working together with the original creators of Spice and Wolf to create a VR animation.\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d...\n\n-Story-\nKraft Lawrence is a traveling merchant who meets Holo, a beautiful woman who can transform into a wolf. \nAs they travel together they face many hardships, such as having to walk in the rain.\nIn order to avoid the sudden downpour, Holo and Lawrence take shelter in an old, abandoned water mill in the woods.\nThey huddle around a small fire and enjoy a slightly strange but relaxing time together.\nYou are able to share that time together with them.\n\nProduction Staff\nScenario: Isuna Hasekura\nCharacter Design: Ju Ayakura\nHolo\u2019s CV: Ami Koshimizu\nKraft Lawrence\u2019s CV: Jun Fukuyama", "short_description": "In order to achieve our dreams of entering the 2nd dimension, we will be making the popular light novel Spice and Wolf into a VR animation!\nAnime will evolve from something that is \u201cseen\u201d to something that is \u201cexperienced\u201d..."}, {"images": {"nodes": [{"file_name": "38974506_630672060677635_989032446013997056_n.png", "id": "1312770182747556", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569486_1312770186080889_6983067482496557378_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYTxiMm9TwgQ7kNvgHjKL5E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCc_dY7H-aG20D0KWdlUklwDSX5AijXrBbFK70sUG_gQQ&oe=67656FEE"}, {"file_name": "icon.png", "id": "1046890023048682", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974570_1046890026382015_5326259503890084427_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OngaNNT8k3oQ7kNvgEaBp0i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC24QetPkDP-8y7SI5mmJ5MT-YpztLIlHMzs1ZDL71nPQ&oe=676546A5"}, {"file_name": "38974776_311154146462238_1507323402505945088_n.png", "id": "922949202756842", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86795866_922949206090175_5400235612385493202_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=juRIvyKbGiEQ7kNvgHrW_vs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb_p_EyWC4MW1BN0bW8sLFNb61olCNeC5_MP5r8ksFGQ&oe=67654D9B"}, {"file_name": "SAWVR_LOGO-01.png", "id": "913191853516787", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974653_913191856850120_391296