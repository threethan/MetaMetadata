3965590565835", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162707_296278514144469_5417572885617180672_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2pIPvyDEZ1sQ7kNvgHVvj7p&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbDnk1qN2K4mwVlNux0msyCCe648ahKtBfg_oollawRQ&oe=671CE0D3"}, {"file_name": "migrated_image.png", "id": "665495477545400", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162678_248589058943932_6432253690911916032_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3UDi5ULMmEIQ7kNvgG7Q1NJ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD7aE63U_1FjMnpK3jm0zmj0vQZTtZa-9BF5On4u_MDRw&oe=671CCC93"}, {"file_name": "migrated_image.png", "id": "228474928558084", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162722_422669094755764_1068909186928082944_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5dBWTE94V_YQ7kNvgH2bsDz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4DphkASqaBeZ1TnKwthoGDO7mHTHf8o0d9RBPoHkofQ&oe=671CEAC8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "290752898047398", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162688_290752901380731_8942995012698767360_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LMcJO6hVa-gQ7kNvgHhrEtq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWxfWfngNHrbHqgdyYBrsGLvTKAVlMNfIujAHP42bwNA&oe=671CD36B"}, "display_name": "Sneaky", "keywords": ["sneaky", "puzzle", "lowpoly", "maze", "casual"], "long_description": "<Sneaky> is a bird's eye perspective VR maze game. In the game you have to be careful to avoid the evil forces on the island killing you, and at the same time try to break through the barriers and rescue your imprisoned companions. The vigilant enemies are in your way, but taking use of the terrain and various powerful items, every problem will be solved. To explore the desert islands!\nCharacteristics: \n1\uff0eBe alert to the island guard! You need to be careful at every step forward\n2\uff0eThere are rich and varied maze missions. Try to find another way to the end!\n3\uff0eThe landscape is simple and elegant, bringing you some peaceful time in the journey!", "short_description": "<Sneaky> is a bird's eye perspective VR maze game. In the game you have to be careful to avoid the evil forces on the island killing you, and at the same time try to break through the barriers and rescue your imprisoned companions. The vigilant enemies are in your way, but taking use of the terrain and various powerful items, every problem will be solved. To explore the desert islands!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.chesstar.cn/", "developer_terms_of_service_url": "http://www.chesstar.cn/", "publisher_name": "http://www.chesstar.cn", "support_website_url": null, "website_url": "http://www.chesstar.cn/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "468608011482347"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162718_1468171579869976_1108243755850268672_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3hYbtZ_ySCcQ7kNvgGo1cG9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHDlZR50fnit1yELdCd2pSVHAF9WifqEta0TdNwI4FlA&oe=671CC1FF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sneaky", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1495670359, "lastRevision": {"node