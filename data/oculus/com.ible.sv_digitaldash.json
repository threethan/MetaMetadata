DMmA&oe=67013DCB"}, {"file_name": "SV_Screenshot3.png", "id": "462378159750983", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031485_462378163084316_1334916599839023230_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BLDJARfBEf0Q7kNvgGeGHna&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBzi1WqVdFekif8nLGaqf-aWysKinsoWxXHoOds_DtYjg&oe=67011434"}, {"file_name": "SV_Screenshot4.png", "id": "866886172003122", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982569_866886175336455_6155373467454423320_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vYZDTVlJZqMQ7kNvgG-1mHH&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBUvgDF_jmpOHmLXTkng1vEfnqZwLhCevQMoM8ykciqFA&oe=6701190E"}, {"file_name": "SV_Screenshot5.png", "id": "433016206306621", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75520122_433016209639954_9164212316618340278_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pO0xkRCgVTgQ7kNvgEZxp7o&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYADiyZ45VrugMs_UqIGkIK2GjVPUYgJcHaAHNSImN-ijA&oe=6701324C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SVPACER_TrailerCover.png", "id": "871533014798840", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974698_871533018132173_5103942000170232074_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CEkRfYAYi4AQ7kNvgF3lG7V&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDezTVUyNEcyKRIHg-71G_kgacsMd0CzfMj7c0dQiirhQ&oe=67012111"}, "display_name": "Sportvida : CyberDash", "keywords": [], "long_description": "Sportvida : CyberDash is a sports adventure game set in a virtual digital world. Players take on the role of a brave vanguard, progressing through a dazzling digital realm, dodging walls, and using various techniques to destroy obstacles. Your goal is to reach the endpoint in the shortest possible time.\n\nGame Features:\n\n1.Virtual Digital World: Immerse yourself in a digital world filled with stunning       visual effects and dynamic obstacles.\n\n2.Multiple Destruction Techniques:\n   \u25cf Ramming: Smash through walls with powerful impacts.\n   \u25cf Slashing: Precisely cut through obstacles using digital blades.\n   \u25cf Punching: Break through oncoming walls with your fists.\n\n3.Continuous Sprinting: The game experience focuses on continuous forward   movement and acceleration, challenging your reflexes and decision-making skills.\n\n4.Dodging and Destroying: Combine dodging and destroying gameplay, requiring players to flexibly navigate and break through various obstacles to find the best path forward.\n\n5.Speed Challenge: Reach the endpoint in the shortest time possible, pushing your limits and competing with players worldwide for the top rankings.\n\nGame Objective:\nNavigate through the dazzling digital world and reach the endpoint as quickly as possible. Maintain high speed by skillfully dodging and destroying obstacles, experiencing the thrill of extreme sports.\n\nGet ready to take on the challenge and become the hero of the virtual world in Sportvida : CyberDash !", "short_description": "Sportvida : CyberDash is a sports adventure game set in a virtual digital world. Players take on the role of a brave vanguard, progressing through a dazzling digital realm, dodging walls, and using various techniques to destroy obstacles. Your goal is to reach the endpoint in the shortest possible time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sportvida.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "ible Technology Inc", "support_website_url": null, "website_url": "https://www.sportvida.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "939033889924114"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "