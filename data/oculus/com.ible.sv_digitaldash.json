12219"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SV_Cover Landscape.png", "id": "859152336283387", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974774_859152339616720_4037340922013628393_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4qcjIWGTXIEQ7kNvgFT824G&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYADrR_tHsJ-8qCQwLYjvrqwDEAkcr11YwfMmhlQYXjpOw&oe=67013BF8"}, "display_name": "Sportvida | CyberDash", "keywords": [], "long_description": "**Sportvida | CyberDash** is a rhythm parkour game set in a virtual digital world. \nPlayers take on the role of a brave vanguard, progressing through a dazzling digital realm filled with stunning visual effects and dynamic obstacles. \nYour goal is to reach the endpoint in the shortest possible time.\n\n# Game Features:\n**Exercise Entertainment**\n\nThrough carefully designed fun exercise combinations and realistic virtual environments, \nSPORTVIDA ensures that you no longer see exercise as a tedious task but as an adventure full of surprises and a sense of achievement.\n\n**Continuous Sprint**\n\nThe game experience focuses on continuous forward movement and acceleration, \nchallenging your reflexes and decision-making skills.\n\n**Agile Dodging**\n\nCombining dodging and destruction gameplay, \nplayers must flexibly respond to various obstacles and find the best path forward.\n\n**Satisfying Strikes**\n\n- Ramming: Smash through walls with powerful impacts. \n- Slashing: Precisely cut through obstacles using digital blades. \n- Punching: Break through oncoming walls with your fists.\n\n**Fitness Challenge**\n\nReach the endpoint in the shortest time possible, challenge your limits,\nand compete with players worldwide for rankings.\n\n# Game Objective:\nNavigate through the dazzling digital world and reach the endpoint as quickly as possible. Maintain high speed by skillfully dodging and destroying obstacles, experiencing the thrill of extreme sports.\n\nGet ready to take on the challenge and become the hero of the virtual world in Sportvida | CyberDash !", "short_description": "Sportvida | CyberDash is a rhythm parkour game set in a virtual digital world. \nPlayers take on the role of a brave vanguard, progressing through a dazzling digital realm filled with stunning visual effects and dynamic obstacles. \nYour goal is to reach the endpoint in the shortest possible time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sportvida.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "ible Technology Inc", "support_website_url": null, "website_url": "https://www.sportvida.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "939033889924114"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8551209804924091"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031584_1203262484152637_982812643034605625_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ashZcCZtJMQ7kNvgEEAmjF&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA0tv-Rac5kqIPc4Kj4Ym7B318mcMqYzcTEfeGaZz427w&oe=67012B58"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sportvida | CyberDash", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports"