ntent-iad3-1.oculuscdn.com/v/t64.5771-25/38984476_1623336311936768_4579386831986542039_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jRkHIcWadaEQ7kNvgGN_sR3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8eVo_W1DFju_OWEp5YxiwX5dhPnzInPyzZmUteb_-PQ&oe=67486390"}, {"file_name": "sh2.png", "id": "538324701889906", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982711_538324705223239_7853823666700274979_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ePX5wnSPqgcQ7kNvgF3q9AN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBxs896bTqOpc5nOsSA299UKkSl6fcA-1RFgW2snzAlzA&oe=674865F1"}, {"file_name": "Image Sequence_076_0010.png", "id": "859568305918092", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031632_859568309251425_4660778685400477094_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=76DlM67xGQMQ7kNvgHbTzFx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALY2sAwsK1KxSbaRojxiWtF7HWaQyq1TNbLEcdqZLjZg&oe=67484061"}, {"file_name": "SV_Screenshot2 (1).png", "id": "1148557006372070", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75282159_1148557009705403_1143557554426813611_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=juCe5O7unRAQ7kNvgFE_4X9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAPhab_UClHJnIEJ8HZXmIsiR6vZT3tjGbt4EjnuwUpyg&oe=674850F3"}, {"file_name": "SV_Screenshot1 (1).png", "id": "1535180903764699", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035332_1535180907098032_2038736985194175303_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WxITrLIbvS4Q7kNvgGlpa4w&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASvq7_ut23LF9vK0EfsHEqjdzMhWFAm-uDspVFXadgvw&oe=67486534"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SV_Cover Landscape.png", "id": "1567291747234705", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035430_1567291750568038_8776096201539886521_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hDtrfVxYWLUQ7kNvgFomuXv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3Bia1crwpKuQy0kY_R6gazdt8mm_r-kqxtJ8jx7Vjxw&oe=674858CE"}, "display_name": "Sportvida | CyberDash", "keywords": ["SPORTVIDA", "CyberDash", "StressRelief", "Strikes", "Fitness"], "long_description": "**\u300aSportvida | CyberDash\u300b** is a **VR running game** that blends **stress relief** with **thrilling challenges**. Set in a high-speed, futuristic world of light and technology, you'll sprint, dodge, and break through obstacles, offering an unparalleled sense of release. Whether you\u2019re **punching\ud83e\udd4a**, **slashing\u2694\ufe0f**, or **ramming\ud83d\udca8**, every action is designed to relieve stress while testing your reflexes and physical limits.\n{1448016712548567}\n\nIn this dazzling future world, your mission is to reach the finish line as quickly as possible, smashing through anything in your way. With stunning visuals and high-energy sound, **\u300aSportvida | CyberDash\u300b is not just about exercise\u2014it\u2019s an exhilarating experience that lets you challenge yourself while unwinding in a fast-paced, visually stunning environment.**\n\n{1571254043766200}\n# \ud83c\udfc3\u200d\u2642\ufe0fStress-Free Running: \n\nIn the light-speed world of SPORTVIDA, run freely and smash through obstacles! It\u2019s the ultimate way to relieve stress, **challenging yourself while enjoying the thrill of high-speed excitement.**\n{526426523432725}\n\n\n# \ud83d\udca5Thrilling Strikes: \nThree strike modes: punching, slashing, and ramming. Choose your rhythm, strike with precision, and create **a unique and exhilarating dash-strike experience.**\n{852356926880711}\n\n# \ud83d\udcaaCasual Fitness: \nSweat it out in-game and make fitness fun! **Remember to warm up before starting, grab your towel, and get ready for an exciting workout challenge!**\n{1058218389022781}", "short_description": "\u300aSportvida | CyberDash\u300b is a VR running game that combines stress relief with thrilling action. Sprint through futuristic worlds while punching, slashing, and ramming obstacles. Race to the finish, dodge challenges, and break through barriers in a visually stunning, fast-paced environment!"}, {"images": {"nodes": [{"file_name": "Frame 30913.png", "id": "1277295686630336", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404388_1277295689963669_2981014058267765201_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-xdsw2RznhYQ7kNvgGgZQjN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCK3taocjFHXriccR7sMtMAB70oYQsP4FWefRNstxjISg&oe=67486F5A"}, {"file_name": "Frame 30912_2.png", "id": "381128348398142", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031452_381128358398141_8508833564469700824_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m9hkHLEEHHoQ7kNvgHW2ph1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKTxt_epUdah_sllDbeopV3nVedhu20U3xfrGWL-JnbA&oe=67485EB6"}]}, "id": "449191351137441", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Sportvida | CyberDash", "keywords": ["Sportvida", "CyberDash", "\u7d13\u58d3", "\u6253\u64ca", "\u5065\u8eab"], "long_description": "**\u300aSportvida | CyberDash\u300b**\u662f\u4e00\u6b3e\u5e36\u7d66\u4f60**\u6975\u81f4\u7d13\u58d3**\u8207**\u6311\u6230**\u7684**VR\u8dd1\u6b65\u904a\u6232**\u3002\u5728\u9019\u500b\u5145\u6eff\u5149\u901f\u8207\u79d1\u6280\u611f\u7684\u4e16\u754c\u4e2d\uff0c\u73a9\u5bb6\u5c07\u7f6e\u8eab\u65bc\u4e00\u5834\u7dca\u5f35\u523a\u6fc0\u7684\u5192\u96aa\u65c5\u7a0b\u3002\u900f\u904e\u885d\u523a\u3001\u9583\u907f\u8207\u6253\u64ca\u969c\u7919\u7269\uff0c\u9ad4\u9a57\u524d\u6240\u672a\u6709\u7684\u66a2\u5feb\u611f\u3002\u7121\u8ad6\u662f**\u62f3\u64ca**\ud83e\udd4a\u3001**\u780d\u64ca**\u2694\ufe0f\u9084\u662f**\u649e\u64ca**\ud83d\udca8\uff0c\u6bcf\u4e00\u7a2e\u6253\u64ca\u65b9\u5f0f\u90fd\u8b93\u4f60\u91cb\u653e\u58d3\u529b\uff0c\u540c\u6642\u6311\u6230\u4f60\u7684\u53cd\u61c9\u529b\u8207\u9ad4\u80fd\u6975\u9650\u3002\n\n\u5728\u9019\u500b\u70ab\u76ee\u58ef\u9e97\u7684\u672a\u4f86\u4e16\u754c\u88e1\uff0c\u4f60\u7684\u4efb\u52d9\u5c31\u662f\u5728\u6700\u77ed\u7684\u6642\u9593\u5167\u885d\u5411\u7d42\u9ede\uff0c\u4e26\u64ca\u788e\u4e00\u5207\u963b\u64cb\u4f60\u524d\u9032\u7684\u969c\u7919\u7269\u3002\u5149\u5f71\u4ea4\u932f\u7684\u8996\u89ba\u6548\u679c\u642d\u914d\u7dca\u5f35\u523a\u6fc0\u7684\u97f3\u6548\uff0c\u8b93\u4f60\u5728\u5954\u8dd1\u7684\u540c\u6642\u611f\u53d7\u5230\u7121\u8207\u502b\u6bd4\u7684\u901f\u5ea6\u8207\u529b\u91cf\u3002**\u9019\u6b3e\u904a\u6232\u4e0d\u50c5\u50c5\u662f\u904b\u52d5\uff0c\u66f4\u662f\u4e00\u5834\u91cb\u653e\u58d3\u529b\u3001\u6311\u6230\u81ea\u6211\u7684\u8996\u89ba\u8207\u9ad4\u80fd\u76db\u5bb4\u3002\u7121\u8ad6\u4f60\u662f\u904b\u52d5\u611b\u597d\u8005\u9084\u662f\u5c0b\u6c42\u7d13\u58d3\u7684\u73a9\u5bb6\uff0c\u90fd\u80fd\u5728\u300aSportvida | CyberDash\u300b\u4e2d\u627e\u5230\u5c6c\u65bc\u4f60\u7684\u7bc0\u594f\u8207\u5feb\u611f\u3002**\n{1839688340186066}\n\n{1277295686630336}\n# \ud83c\udfc3\u200d\u2642\ufe0f\u7d13\u58d3\u8dd1\u6b65\uff1a\n\n\u5728SPORTVIDA\u7684\u5149\u901f\u4e16\u754c\u4e2d\uff0c\u81ea\u7531\u5954\u8dd1\u4e26\u64ca\u788e\u969c\u7919\uff01\u9019\u662f\u6700\u7d42\u6975\u7684\u7d13\u58d3\u65b9\u5f0f\uff0c**\u8b93\u4f60\u4e00\u908a\u6311\u6230\u81ea\u6211\uff0c\u4e00\u908a\u4eab\u53d7\u9ad8\u901f\u7684\u523a\u6fc0\u5feb\u611f\u3002**\n{863209935953053}\n\n\n# \ud83d\udca5\u66a2\u5feb\u6253\u64ca\uff1a\n\u4e09\u7a2e\u6253\u64ca\u6a21\u5f0f\uff1a\u62f3\u64ca\u3001\u780d\u64ca\u3001\u548c\u649e\u64ca\u3002\u9078\u64c7\u4f60\u7684\u7bc0\u594f\uff0c\u7cbe\u6e96\u51fa\u64ca\uff0c**\u5275\u9020\u7368\u7279\u4e14\u4ee4\u4eba\u8208\u596e\u7684\u885d\u523a\u6253\u64ca\u9ad4\u9a57\u3002**\n{1063852668422807}\n\n# \ud83d\udcaa\u4f11\u9592\u5065\u8eab\uff1a\n\u5728\u904a\u6232\u4e2d\u6c57\u6d41\u6d79\u80cc\uff0c\u8b93\u5065\u8eab\u8b8a\u5f97\u5145\u6ef