a0a&_nc_ohc=d9EhSf3rv50Q7kNvgG4SI-3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCF-jfQi-V9rP6TgtisbMuV6LjCgZgoU8tcDGhbX9OTtQ&oe=67486289"}, {"file_name": "SV_Screenshot1.png", "id": "458054600301232", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974679_458054603634565_3722926235789598316_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1gy2aw7Q2ksQ7kNvgGqKvc2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBz4JLpzLBQ2hZPzzuYYhiL9k5J8Vb_jPCSlUjeZ6bqfg&oe=67486ECB"}, {"file_name": "SV_Screenshot3.png", "id": "462378159750983", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031485_462378163084316_1334916599839023230_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q2StT-j1tewQ7kNvgGc9Eks&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATDF3x0Uf8VkNz4eEUau3Rng5NdCQm2p6s4wPwGfgqUw&oe=67484534"}, {"file_name": "SV_Screenshot4.png", "id": "866886172003122", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982569_866886175336455_6155373467454423320_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MNqdhU-nGOIQ7kNvgG_9r2K&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZG7g1xsba_TIXrNqRRiiiGzddPFUzJfuxISvFsZOqhw&oe=67484A0E"}, {"file_name": "SV_Screenshot5.png", "id": "433016206306621", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75520122_433016209639954_9164212316618340278_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5kPp7_kzxv0Q7kNvgGdhmeo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBX74oV9RtXb_Osyvv8oCefiMCv6Hl2KUcJ6nMNv1_e4g&oe=6748634C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SVPACER_TrailerCover.png", "id": "871533014798840", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974698_871533018132173_5103942000170232074_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hY_PXwvYwXMQ7kNvgE1Z5Vt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjVL_yV6L4cVdzv4jnBGOVRqCGAQRec_6PWMI5jOElXg&oe=67485211"}, "display_name": "Sportvida : CyberDash", "keywords": [], "long_description": "Sportvida : CyberDash is a sports adventure game set in a virtual digital world. Players take on the role of a brave vanguard, progressing through a dazzling digital realm, dodging walls, and using various techniques to destroy obstacles. Your goal is to reach the endpoint in the shortest possible time.\n\nGame Features:\n\n1.Virtual Digital World: Immerse yourself in a digital world filled with stunning       visual effects and dynamic obstacles.\n\n2.Multiple Destruction Techniques:\n   \u25cf Ramming: Smash through walls with powerful impacts.\n   \u25cf Slashing: Precisely cut through obstacles using digital blades.\n   \u25cf Punching: Break through oncoming walls with your fists.\n\n3.Continuous Sprinting: The game experience focuses on continuous forward   movement and acceleration, challenging your reflexes and decision-making skills.\n\n4.Dodging and Destroying: Combine dodging and destroying gameplay, requiring players to flexibly navigate and break through various obstacles to find the best path forward.\n\n5.Speed Challenge: Reach the endpoint in the shortest time possible, pushing your limits and competing with players worldwide for the top rankings.\n\nGame Objective:\nNavigate through the dazzling digital world and reach the endpoint as quickly as possible. Maintain high speed by skillfully dodging and destroying obstacles, experiencing the thrill of extreme sports.\n\nGet ready to take on the challenge and become the hero of the virtual world in Sportvida : CyberDash !", "short_description": "Sportvida : CyberDash is a sports adventure game set in a virtual digital world. Players take on the role of a brave vanguard, progressing through a dazzling digital realm, dodging walls, and using various techniques to destroy obstacles. Your goal is to reach the endpoint in the shortest possible time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sportvida.co/privacy", "developer_ter