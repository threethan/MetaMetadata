466_432356661447080_4268334887373267497_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cl4-aLHuiCsQ7kNvgFRomi_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWSQYxWleebPTH9ecXvFua8swcT1jRpz6JepBloWb_eg&oe=66F95147"}, {"file_name": "Virus Popper Screenshot 1.png", "id": "691822208174066", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75593943_691822211507399_5160343457412505239_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F8bauM0ijicQ7kNvgF6-2V0&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAq2ZNgjULHpgP6mP8xe-FlgpTpzDFSfsvtg1f2Oyu6A&oe=66F94472"}, {"file_name": "Virus Popper Screenshot 2.png", "id": "3900206110002557", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462204_3900206116669223_2939705742515996636_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8jflsyq-UxgQ7kNvgGGhWKr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNkDuGvE_cW1JwgD-2YjWs-RsVvi1Jw_Oq_t0k1Ob3OQ&oe=66F92BFB"}, {"file_name": "Virus Popper Screenshot 3.png", "id": "229466398843700", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031641_229466402177033_7346366485002983528_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1D3wjWrGwMIQ7kNvgG7C30U&_nc_ht=scontent.oculuscdn.com&oh=00_AYBD9Z-XpK1Ah9fdxrbQFDMPAPnMbER_S5dlSDEI6swqPw&oe=66F93608"}, {"file_name": "Virus Popper Screenshot 4.png", "id": "408454273562718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974689_408454276896051_641497669645476121_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nQMkR5UmG2QQ7kNvgHYTqL3&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9tYe16fMAuzBypQDhrhZDUG2pkAdR0kjWyyDp9mVWOQ&oe=66F95347"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "261699585473411", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451790_261699588806744_4013495180035481017_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UGbkSl-3hSgQ7kNvgGAw5d4&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5KeTJ8v7ww8xZ0pbxg7mNzkBgUcna68DvjLjf5oMOWQ&oe=66F937A3"}, "display_name": "Virus Popper", "keywords": [], "long_description": "Virus Popper is a fast-paced educational game about personal hygiene. We wanted to make a fun and friendly way to share important messages without adding to the fear and panic in the world right now.\n\nWASH your hands in the sink to get cleansed. POP the virus with powerful disinfectants and sprays. CRUSH filthiness with legendary weapons like the toilet scrubber. AVOID touching publicly used objects like door knobs. PROTECT and avoid touching your face at all costs.\n\nOnly YOU can save the world by practicing safe habits. But how long can you make it without getting infected?", "short_description": "Virus Popper is a fast-paced educational game about personal hygiene. Wash your hands and POP the virus!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/virus-popper-privacy-policy", "developer_terms_of_service_url": "https://www.starcadearcadellc.com/virus-popper-eula", "publisher_name": "Starcade Arcade LLC", "support_website_url": "https://www.starcadearcadellc.com/contact", "website_url": "https://www.starcadearcadellc.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1601433960285088"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "557562488537464"}]}, "baseline_offer": {"id": "557562488537464"}, "is_approved": true, "firstOffer": {"nodes": [{"start