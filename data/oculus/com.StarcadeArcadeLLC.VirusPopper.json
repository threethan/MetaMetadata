-25/39036688_216766970642408_4458337653384959224_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AiIpVVl-eWIQ7kNvgGXSFHF&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBGDBByMvrkR87tVNUtEAzj9OkaghQOhwMADd-F4I8NWg&oe=675D5766"}, {"file_name": "Slurpz Flamethrower.png", "id": "671721130874081", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57569446_671721134207414_8485867793359300654_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qMcfM8SCD-cQ7kNvgFn9yCI&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD9Az5DNEXGIUDnUHfuGu2OpajdUPnw3JIBnmA9O44Yrw&oe=675D821D"}, {"file_name": "Weapon Rack.png", "id": "235432475390967", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031603_235432478724300_19848184152188196_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=obDE0s0jxncQ7kNvgE9ivl3&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDsz-nADQwrYoMVyz_0lhvcCNJJiFfmzbmsi5KURIDXYQ&oe=675D7F24"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "301435921873977", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974526_301435925207310_209559238686540923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pNxGuQg4pIAQ7kNvgHpqCKX&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBgXKGYqWV7blNWB_GJi63FKrJ29YC2jJAMR2QriXbYxg&oe=675D7EB4"}, "display_name": "Virus Popper", "keywords": ["arcade", "rhythm", "rail", "casual", "free"], "long_description": "Greetings Space Traveler, we need you to save the universe again! New virus variants threaten our galaxy. Level up with a new arsenal of weapons to combat these variants. We are equipping you with funky fun weapons like the Vaxcaliber, Vac Bat, and Jazzeroid Rocket Launcher. Explore new worlds and enjoy some newly mastered bangers by DJ Inkers while battling for the survival of the universe.\n\nFor your protection, we are also giving you the option to vaccinate and wear a mask, but both are your choice! It is up to 