 sink to get cleansed. POP the virus with powerful disinfectants and sprays. CRUSH filthiness with legendary weapons like the toilet scrubber. AVOID touching publicly used objects like door knobs. PROTECT and avoid touching your face at all costs.\n\nOnly YOU can save the world by practicing safe habits. But how long can you make it without getting infected?", "short_description": "Virus Popper is a fast-paced educational game about personal hygiene. Wash your hands and POP the virus!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/virus-popper-privacy-policy", "developer_terms_of_service_url": "https://www.starcadearcadellc.com/virus-popper-eula", "publisher_name": "Starcade Arcade LLC", "support_website_url": "https://www.starcadearcadellc.com/contact", "website_url": "https://www.starcadearcadellc.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1601433960285088"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "557562488537464"}]}, "baseline_offer": {"id": "557562488537464"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1615604460, "status": "PUBLISHED", "id": "557562488537464"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7002186766459859", "version": "1.5"}, "id": "270051427842938", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": fals