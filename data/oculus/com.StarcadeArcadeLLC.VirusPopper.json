-25/39036688_216766970642408_4458337653384959224_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OHVrn9Ma188Q7kNvgEHdYcc&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBwiigYsU4S2_BR486856qpko7rE8gcLZDrJdGFUXCn3Q&oe=67878766"}, {"file_name": "Slurpz Flamethrower.png", "id": "671721130874081", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/57569446_671721134207414_8485867793359300654_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5sLl5lcm0FcQ7kNvgGN1Qy9&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBltpbVyH00YUyMRyrrm00lySz8eE9bNofYIRKGKr45Yw&oe=6787B21D"}, {"file_name": "Weapon Rack.png", "id": "235432475390967", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031603_235432478724300_19848184152188196_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=puiX2jUF5HMQ7kNvgERROm1&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAF_xRrWAcpjJa9mN5CV410W01L_pUbiOq794ROoeWqJQ&oe=6787AF24"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "301435921873977", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974526_301435925207310_209559238686540923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nM2_I7hH4wMQ7kNvgG1-Kfd&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBvfhjPsD8zFu67UlYSPYEVn-czMkRKFNPDoEGRfCwdrw&oe=6787AEB4"}, "display_name": "Virus Popper", "keywords": ["arcade", "rhythm", "rail", "casual", "free"], "long_description": "Greetings Space Traveler, we need you to save the universe again! New virus variants threaten our galaxy. Level up with a new arsenal of weapons to combat these variants. We are equipping you with funky fun weapons like the Vaxcaliber, Vac Bat, and Jazzeroid Rocket Launcher. Explore new worlds and enjoy some newly mastered bangers by DJ Inkers while battling for the survival of the universe.\n\nFor your protection, we are also giving you the option to vaccinate and wear a mask, but both are your choice! It is up to 