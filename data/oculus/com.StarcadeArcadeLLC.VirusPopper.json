-25/39036688_216766970642408_4458337653384959224_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qlgQZG5aI3QQ7kNvgFZjO30&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDOLPAIuraIjOmB3QBnvEJNP5r3XFgOwBqrl-A_tvSdog&oe=6780EFE6"}, {"file_name": "Slurpz Flamethrower.png", "id": "671721130874081", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57569446_671721134207414_8485867793359300654_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWxDxqPNIEgQ7kNvgE7D6mV&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBGoMn3uTtvu3j6rn6s_r2B5FMUJY0VWPVH8vszvxLbzg&oe=67811A9D"}, {"file_name": "Weapon Rack.png", "id": "235432475390967", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031603_235432478724300_19848184152188196_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wPDsRoH3COMQ7kNvgH49ZU3&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDXx6qkn0DaBK7MzQum8uH5nMZve-5q4u35PXBHfnRXsg&oe=678117A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "301435921873977", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974526_301435925207310_209559238686540923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8U-J9MOwxQIQ7kNvgFfZbFm&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDhnF5JVSochVNogv9VhMDZcnuAYSuOUxwsbEaG2MixMw&oe=67811734"}, "display_name": "Virus Popper", "keywords": ["arcade", "rhythm", "rail", "casual", "free"], "long_description": "Greetings Space Traveler, we need you to save the universe again! New virus variants threaten our galaxy. Level up with a new arsenal of weapons to combat these variants. We are equipping you with funky fun weapons like the Vaxcaliber, Vac Bat, and Jazzeroid Rocket Launcher. Explore new worlds and enjoy some newly mastered bangers by DJ Inkers while battling for the survival of the universe.\n\nFor your protection, we are also giving you the option to vaccinate and wear a mask, but both are your choice! It is up to 