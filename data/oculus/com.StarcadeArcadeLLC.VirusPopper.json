-25/39036688_216766970642408_4458337653384959224_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qlgQZG5aI3QQ7kNvgHGtvQA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCva6YpW_bA4GdorJExVL0PUEJsNESdwIrWnRE6qUrOLg&oe=678392E6"}, {"file_name": "Slurpz Flamethrower.png", "id": "671721130874081", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569446_671721134207414_8485867793359300654_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PAWERJcsVioQ7kNvgGibOoa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA33K0qnfMrGu00FKztVtyP22GdyQx5AXhqa6XuO87w_g&oe=6783BD9D"}, {"file_name": "Weapon Rack.png", "id": "235432475390967", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031603_235432478724300_19848184152188196_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wPDsRoH3COMQ7kNvgHIXcNE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBN45pWrj9IulMyAczGOWlWNWdZYY-ki73eZ2lfOw7VuA&oe=6783BAA4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "301435921873977", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974526_301435925207310_209559238686540923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KZ2hqNpn9WkQ7kNvgH1sobF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8s0gBAiAKmSyFa8muCjZyn96WkJMmBBa7aX4RoEPWhA&oe=6783BA34"}, "display_name": "Virus Popper", "keywords": ["arcade", "rhythm", "rail", "casual", "free"], "long_description": "Greetings Space Traveler, we need you to save the universe again! New virus variants threaten our galaxy. Level up with a new arsenal of weapons to combat these variants. We are equipping you with funky fun weapons like the Vaxcaliber, Vac Bat, and Jazzeroid Rocket Launcher. Explore new worlds and enjoy some newly mastered bangers by DJ Inkers while battling for the survival of the universe.\n\nFor your protection, we are also giving you the option to vaccinate and wear a mask, but both are your choice! It is up to you to save the party people!\n\nVirus Popper Reopened is FREE and Includes:\n\u25cf  4 New Maps!\n\u25cf  Over 15 funky weapons!\n\u25cf  8 Types of Viruses!\n\u25cf  Progression Unlocks\n\u25cf  Original Virus Popper game mode", "short_description": "Greetings Space Traveler, we need you to save the universe again! New virus variants threaten our galaxy. Level up with a new arsenal of weapons to combat them!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/virus-popper-privacy-policy", "developer_terms_of_service_url": "https://www.starcadearcadellc.com/virus-popper-eula", "publisher_name": "Starcade Arcade LLC", "support_website_url": "https://www.starcadearcadellc.com/contact", "website_url": "https://www.starcadearcadellc.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "28090799863838576"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974653_674633740566921_5950792480057875671_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aOJfMt7HoDwQ7kNvgG-RrGG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2d-3a0vWF0DpIma0MVnL8tdC1L6S2kT2VXrEGgP3FbQ&oe=6783A772"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Virus Popper", "platform": "A