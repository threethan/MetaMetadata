-25/39036688_216766970642408_4458337653384959224_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-NxBajvOHQQ7kNvgHWfsAA&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYA_1LWFzvwlzYUDiwpAjmdmjcKEHPzmOQx09b_dFIspgg&oe=67581166"}, {"file_name": "Slurpz Flamethrower.png", "id": "671721130874081", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57569446_671721134207414_8485867793359300654_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=66C_6ibz2BIQ7kNvgF77a6k&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYA6CVqzz2IwSzpVAiJ3BfYLSj1kHIYfsI48gUs-2wNaqA&oe=67583C1D"}, {"file_name": "Weapon Rack.png", "id": "235432475390967", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031603_235432478724300_19848184152188196_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ptYF0uZmJkwQ7kNvgF2nXWH&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAjfNt0uhFbKNzIr4azoLJlJx32NOuWvA8sg8MNooN8pQ&oe=67583924"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "301435921873977", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974526_301435925207310_209559238686540923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZbCNI4c0o-QQ7kNvgEy1Ekp&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBj2jJ-NvXR-y7rIl3OFD8qhEgwpw_g97pTyu5NWHKAig&oe=675838B4"}, "display_name": "Virus Popper", "keywords": ["arcade", "rhythm", "rail", "casual", "free"], "long_description": "Greetings Space Traveler, we need you to save the universe again! New virus variants threaten our galaxy. Level up with a new arsenal of weapons to combat these variants. We are equipping you with funky fun weapons like the Vaxcaliber, Vac Bat, and Jazzeroid Rocket Launcher. Explore new worlds and enjoy some newly mastered bangers by DJ Inkers while battling for the survival of the universe.\n\nFor your protection, we are also giving you the option to vaccinate and wear a mask, but both are your choice! It is up to 