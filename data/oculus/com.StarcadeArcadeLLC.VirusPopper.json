com/v/t64.5771-25/75451790_261699588806744_4013495180035481017_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WtCo5fSFMHkQ7kNvgEu3m4y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPU-2XgE1HKP-L2bYZRKqpN-N--H7a7DGVbaZhyvD91g&oe=673339A3"}, "display_name": "Virus Popper", "keywords": [], "long_description": "Virus Popper is a fast-paced educational game about personal hygiene. We wanted to make a fun and friendly way to share important messages without adding to the fear and panic in the world right now.\n\nWASH your hands in the sink to get cleansed. POP the virus with powerful disinfectants and sprays. CRUSH filthiness with legendary weapons like the toilet scrubber. AVOID touching publicly used objects like door knobs. PROTECT and avoid touching your face at all costs.\n\nOnly YOU can save the world by practicing safe habits. But how long can you make it without getting infected?", "short_description": "Virus Popper is a fast-paced educational game about personal hygiene. Wash your hands and POP the virus!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/virus-popper-privacy-policy", "developer_terms_of_service_url": "https://www.starcadearcadellc.com/virus-popper-eula", "publisher_name": "Starcade Arcade LLC", "support_website_url": "https://www.starcadearcadellc.com/contact", "website_url": "https://www.starcadearcadellc.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_pl