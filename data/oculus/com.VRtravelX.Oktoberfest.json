ob1H-zA&oe=66F53CC3"}, {"file_name": "20220921_134536.png", "id": "959926015118349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974792_959926018451682_7454046409305224501_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9HYf_8jTpvoQ7kNvgEBrJIU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALe1brGsSluQmsWF3QrQujV&oh=00_AYBakn9UmIFklpua1BxDGgO98dxfaxinhmYT4zO2HAcvvA&oe=66F551AA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Oktoberfest", "keywords": [], "long_description": "This VR Experience is a real visit to the German Octoberfest in Munich in Virtual Reality.\nWolfgang Brehm the official city guide of Munich accompanies you around the Octoberfest and explains you everything.\n\nThere are no simulation all is real. It is a real visit.\n\nYou have never seen this before. \nThis is the ultimate VR Experience ... frameless. \n\nYou get a unique impression of the biggest folk festival in the world. It has been held annually since 1810 on the Theresienwiese in Munich. Experience the most important beer tents (also from inside), the Bavaria (incl. ascent to the head), the Oide Wiesn (traditional festival and shoe platters) and many attractions such as a round trip on the ferris wheel. Let yourself be carried away into the world of Bavarian traditions, Dirndl & Lederhosen, beer tents, Munich\u2019s beer, Bavarian music, beer mugs, shoe platters, chain carousel, giant wheel and many more. The tour starts at the main entrance and shows all the top sights. \n\nSome examples: \n- Along the Wirtsbudenstra\u00dfe with many large beer tents\n- Tent Fischer-Vroni (how\u201dfish on a stick\u201d is made) \n- Hofbr\u00e4u tent (the largest beer tent at the Oktoberfest with space for approx. 10,000 guests) \n- Augustiner-Festhalle (here you can buy beer from the wooden barrel) - Visit of Bavaria (ascent to the head of Bavaria) - K\u00e4fer Wies\u2019n Sch\u00e4nke (where you can meet the celebrities) \n- Oide Wiesn / Traditional festival (shoe platters) \n- Ride with the ferris wheel (great view of the Octoberfest)", "short_description": "Join Wolfgang Brehm - the official city guide of Munich - in a real Virtual Reality tour through the Octoberfest in Munich, Germany. It is a real visit.\nWolfgang accompanies you around the Octoberfest and explains you everything.\n\nYou will have 4 hours to see everything."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrtravelx.net/oktoberfest", "developer_terms_of_service_url": null, "publisher_name": "VRtravelX", "support_website_url": null, "website_url": "https://www.vrtravelx.net/oktoberfest", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2777382702530830"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "827501475629850"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "255678620621671"}]}, "baseline_offer": {"id": "255678620621671"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1692817041, "status": "PUBLISHED", "id": "255678620621671"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6514612981908867", "version": "1.0"}, "id": "1646101772549602", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "65145776185790