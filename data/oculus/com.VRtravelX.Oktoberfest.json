-7&_nc_sid=6e7a0a&_nc_ohc=hMTJs7htNeYQ7kNvgHE5usy&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALe1brGsSluQmsWF3QrQujV&oh=00_AYAQfsSOqbYb3vlIcA1ZPaKg9L5V2Nct35Fmb-J4qcezLw&oe=66F54C63"}, {"file_name": "20220921_115722.png", "id": "812601670358730", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982501_812601673692063_4888023167364672866_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KZ5Z5a6NslEQ7kNvgFQosnJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALe1brGsSluQmsWF3QrQujV&oh=00_AYDjzHbh7qywACTLJVN2lH_vZBuVk4ld1-7_R4YqEsWbRQ&oe=66F52ECD"}, {"file_name": "20220921_124143.png", "id": "2946687445462416", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982488_2946687452129082_8823392805038975644_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rVFmUDHOb64Q7kNvgE13as3&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALe1brGsSluQmsWF3QrQujV&oh=00_AYDpVeaKM0DImmIsob_LVGrxK6A3Vh_du2bCxb1ob1H-zA&oe=66F53CC3"}, {"file_name": "20220921_134536.png", "id": "959926015118349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974792_959926018451682_7454046409305224501_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9HYf_8jTpvoQ7kNvgEBrJIU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALe1brGsSluQmsWF3QrQujV&oh=00_AYBakn9UmIFklpua1BxDGgO98dxfaxinhmYT4zO2HAcvvA&oe=66F551AA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "October Beer Festival Munich Tour with Wolfgang", "keywords": ["Oktoberfest", "Octoberfest", "Munich", "Germany", "travel"], "long_description": "This VR Experience is a real visit to the October Beer Festival Munich Tour with Wolfgang in Virtual Reality.\nWolfgang Brehm the official city guide of Munich accompanies you around the festival and explains you everything.\n\nThere are no simulation all is real. It is a real visit.\n\nYou have never seen this before. \nThis is the ultimate VR Experience ... frameless. \n\nYou get a unique impression of the biggest folk festival in the world. It has been held annually since 1810 on the Theresienwiese in Munich. Experience the most important beer tents (also from inside), the Bavaria (incl. ascent to the head), traditional festival and shoe platters and many attractions such as a round trip on the ferris wheel. Let yourself be carried away into the world of Bavarian traditions, Dirndl & Lederhosen, beer tents, Munich\u2019s beer, Bavarian music, beer mugs, shoe platters, chain carousel, giant wheel and many more. The tour starts at the main entrance and shows all the top sights. \n\nSome examples: \n- Along the Wirtsbudenstra\u00dfe with many large beer tents\n- Tent Fischer-Vroni (how\u201dfish on a stick\u201d is made) \n- Hofbr\u00e4u tent (the largest beer tent at the festival with space for approx. 10,000 guests) \n- Augustiner-Festhalle (here you can buy beer from the wooden barrel) - Visit of Bavaria (ascent to the head of Bavaria) - K\u00e4fer Wies\u2019n Sch\u00e4nke (where you can meet the celebrities) \n- Traditional festival (shoe platters) \n- Ride with the ferris wheel (great view of the festival)\n\n#VRtravelX #VRTravel", "short_description": "VR Travel - Join Wolfgang Brehm - the official city guide of Munich - in a real Virtual Reality tour through the October Beer Festival in Munich, Germany. It is a real visit.\nWolfgang accompanies you around the German Beer Festival and explains you everything.\n\nYou will have 4 hours to see everything."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrtravelx.net/home/October-Beer-Festival-Munich-Tour-with-Wolfgang", "developer_terms_of_service_url": null, "publisher_name": "VRtravelX", "support_website_url": null, "website_url": "https://www.vrtravelx.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2691890164460465"}, {"id": "879473995923081"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_a