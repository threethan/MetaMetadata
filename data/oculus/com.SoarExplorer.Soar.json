h=00_AYB4ilUt_ycsrQ5YIwAs6iAVHlhAuRVNmQkT-X3ONcPqHg&oe=66F69127"}, {"file_name": "003.png", "id": "905535294181732", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031370_905535297515065_791380414200773828_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CNiovi3aHQMQ7kNvgHdAbDD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP3JZoF7_N7S5Qixm8tTieV&oh=00_AYDTzA4bCd27FZOamNiCZlm50KeL98w8CCbEfd-3OoY-CA&oe=66F68A7E"}, {"file_name": "004.png", "id": "342630578637352", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375761_342630581970685_873449314526867776_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WHX-sRON1ikQ7kNvgGMqGgN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP3JZoF7_N7S5Qixm8tTieV&oh=00_AYDOf7YGQmFyqT9G3Q5mpJjwdFx3jOsa5prRtKqxefbr5g&oe=66F6B20F"}, {"file_name": "005.png", "id": "790004473171062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974682_790004476504395_4138722223500656535_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WKHuanSN4w8Q7kNvgEmnlrn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP3JZoF7_N7S5Qixm8tTieV&oh=00_AYAvMrNmB6D1hioBKgQWQbSSRbdon-mphpmyLQ_60hEnTQ&oe=66F6A331"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SOARCoverImageLandscape.png", "id": "661660049251151", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031379_661660052584484_7195760396771876912_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mt6WRukbu0gQ7kNvgH10OPL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP3JZoF7_N7S5Qixm8tTieV&oh=00_AYAKwr_pCxjuid7qnK9BlfTmTgl0qT80OoHgmOQ0OvnfPQ&oe=66F6A4E5"}, "display_name": "SOAR", "keywords": [], "long_description": "Fly with your friends and shoot your enemies!\n\nSOAR allows you to take to the sky, using your body to explore a vast city unlike any seen before on Quest.\n\n**This is our Early Access launch. If you would like help shape the development of SOAR, please feel free to engage with the development team on Discord**\n\nMULTIPLAYER\nCreate or join servers with up to 6 other enlightened individuals to battle across the city in action packed rounds of combat.\n\nFLY\nExperience a locomotion unlike any other in VR with embodied flying, stretch out your arms and soar through the sky!\n\nHAND TRACKING\nBecome fully immersed with hand tracking allowing you to fly and shoot without controllers.\n\nCUSTOMIZE YOUR EXPERIENCE\nPlay with the settings of the game world and create your own unique experiences, invite other players to compete in the ruleset of your server!\n\nUAP DOGFIGHT\nEscape from swarms of UFOs in single player. Shooting, dodging and bashing your way through the invading swarm.\n\nFUTURE ROADMAP\nIn the months following launch, SOAR will be updated with new gameplay modes, new flying types, more avatar customization, discoverable and hidden content and a whole lot more. Stay tuned as we regularly update the game every few weeks.", "short_description": "SOAR delivers on the fantasy of embodied flight in VR. Take to the skies and experience reality as never before. Face off against other players and blast them out of the air whilst discovering all that is hidden within this mysterious world."}]}, "developer_name": null, "developer_privacy_policy_url": "http://soar.game/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Soar Explore Inc", "support_website_url": null, "website_url": "http://soar.game/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SHOOTER", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_mod