105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GlrCU0rM4gQQ7kNvgGgaDnq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8HKSKah2N5DOLKhkDGDnoM&oh=00_AYC6SGULTG1y8i0dlnqv1uzgzb53KXOjUP7sjwpmtxAn4g&oe=66ED6AC7"}, {"file_name": "BeersAndBoomerangs.png", "id": "1283185035815633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575358_1283185039148966_3162988417370070068_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XwSb4PWAnjkQ7kNvgGLOfLq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8HKSKah2N5DOLKhkDGDnoM&oh=00_AYCFP-6BTWYuFaIV37awR38InUp2MIBEwB3kNLIqE4e7bQ&oe=66ED75CE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tRAILERtHUMB.png", "id": "1247212049410434", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75647712_1247212052743767_3164805702378939385_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=109m6usCBkQQ7kNvgEk1tPx&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8HKSKah2N5DOLKhkDGDnoM&oh=00_AYCJkuPHatVDTyw-zboEfuNPxc8baR5Tt7Pgz_58WJhLAQ&oe=66ED5112"}, "display_name": "Beers And Boomerangs Demo", "keywords": [], "long_description": "Check the full game at https://www.oculus.com/experiences/quest/3767842406602776/\n\nKangaroos are trying to steal your beer! Throw boomerangs in VR to survive the wildlife chaos. Cook for your mates, and save your Aussie BBQ!\n\nHave increasingly perilous BBQs where you survive against different animals, in different scenarios and cook different food!\n\nFull game Features:\n\nFully Physics-based interactions\nA campaign mode with 15 levels (6 hours of gameplay)\nAn endless arcade mode (Infinite gameplay, be the highest score!)\nLovely Annoying Australian Fauna\nBeer skins\nBoomerang skins\nVegetarian BBQ alternatives\nNon-Alcoholic drink alternatives\nTons of accessibility options\n", "short_description": "Full game: https://www.oculus.com/experiences/quest/3767842406602776/\n\nThis is a short demo of A Chaotic Survival/Cooking VR game where kangaroos are stealing your beer!\n\nMulti-task between cooking for your mates and assaulting Australian fauna.\nMaster your fully physics-based boomerangs and defend your BBQ\n"}]}, "developer_name": "Witty Platypus", "developer_privacy_policy_url": "https://beersandboomerangs.com/policy", "developer_terms_of_service_url": null, "publisher_name": "Spelkollektivet", "support_website_url": "https://beersandboomerangs.com/", "website_url": "https://beersandboomerangs.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "FOOD"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "210951141624613"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031599_581378576249809_4925083800397028654_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=92qY1n3zUmEQ7kNvgGrG_v6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8HKSKah2N5DOLKhkDGDnoM&oh=00_AYBns76wD9vPVFCVPeRea0eh8Z1Fukf987tciAbN8-09Ow&oe=66ED623F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Beers And Boomerangs Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1635321600, "lastRevision": {"nodes": [{"id": "1495443700818494", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6119653444774535", "is_first_party": false, "enables_in_app_ads": fal