g Australian fauna.\nMaster your fully physics-based boomerangs and defend your BBQ\n"}]}, "developer_name": "Witty Platypus", "developer_privacy_policy_url": "https://beersandboomerangs.com/policy", "developer_terms_of_service_url": null, "publisher_name": "Spelkollektivet", "support_website_url": "https://beersandboomerangs.com/", "website_url": "https://beersandboomerangs.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "FOOD"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "210951141624613"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031599_581378576249809_4925083800397028654_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yCdpEKZhnwAQ7kNvgHrRveN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AACa2HnRoR5PQPmKmA_6CfL&oh=00_AYDzBskToViqqy20hq725F8yE8O9u_N7yeKMgJZBrV3oUA&oe=66EABF3F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Beers And Boomerangs Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1635321600, "lastRevision": {"nodes": [{"id": "1495443700818494", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6119653444774535", "is_first_party": false, "enables_in_app_ads": fal