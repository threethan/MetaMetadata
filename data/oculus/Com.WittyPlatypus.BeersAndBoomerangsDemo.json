8_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4reFBDmC9MkQ7kNvgG20zAV&_nc_ht=scontent.oculuscdn.com&oh=00_AYC4Fpetyt5uvHOC59YnyovJyU1hlbscW30r5CSuV5xgIw&oe=66FBF64E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tRAILERtHUMB.png", "id": "1247212049410434", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75647712_1247212052743767_3164805702378939385_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i2bYwqRpCMAQ7kNvgFK-cq7&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5UFaoglOwsgFgHoYRKk_wkAFuz0ZzcJ9cVmprnvt08w&oe=66FBD192"}, "display_name": "Beers And Boomerangs Demo", "keywords": [], "long_description": "Check the full game at https://www.oculus.com/experiences/quest/3767842406602776/\n\nKangaroos are trying to steal your beer! Throw boomerangs in VR to survive the wildlife chaos. Cook for your mates, and save your Aussie BBQ!\n\nHave increasingly perilous BBQs where you survive against different animals, in different scenarios and cook different food!\n\nFull game Features:\n\nFully Physics-based interactions\nA campaign mode with 15 levels (6 hours of gameplay)\nAn endless arcade mode (Infinite gameplay, be the highest score!)\nLovely Annoying Australian Fauna\nBeer skins\nBoomerang skins\nVegetarian BBQ alternatives\nNon-Alcoholic drink alternatives\nTons of accessibility options\n", "short_description": "Full game: https://www.oculus.com/experiences/quest/3767842406602776/\n\nThis is a short demo of A Chaotic Survival/Cooking VR game where kangaroos are stealing your beer!\n\nMulti-task between cooking for your mates and assaulting Australian fauna.\nMaster your fully physics-based boomerangs and defend your BBQ\n"}]}, "developer_name": "Witty Platypus", "developer_privacy_policy_url": "https://beersandboomerangs.com/policy", "developer_terms_of_service_url": null, "publisher_name": "Spelkollektivet", "support_website_url": "https://beersandboomerangs.com/", "website_url": "https://beersandboomerangs.com/", "category": "GAMES", "comfort_r