m/v/t64.5771-25/38974807_1878083979389858_5266083509574633206_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bS4JM7SlSNoQ7kNvgHhilnC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuFxxvk92-TA2wAKjyKlGAEmxgu1xTaWAiqO9M0rDM0w&oe=6739C4BE"}, {"file_name": "ScreenShot 5.png", "id": "958005615545642", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75278188_958005618878975_1112688403689238812_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5IOrsKg7jL8Q7kNvgG7wt2b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwn-fxgkob1LPoll9QqcMEf4aMojGyWqSy8PXCjM1phw&oe=6739C106"}, {"file_name": "Screenshot 3.png", "id": "1115636012877865", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269592_1115636016211198_1143460225631402822_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hjEj9Sd6PwsQ7kNvgFDgFqZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD918qvyQ0DtYUL7jQfNMrZfay_4vs0mQmmSMbI7ALCYg&oe=6739CD9F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AltLandscape2.png", "id": "1096341991458509", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75588060_1096341998125175_1883949348999816313_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNxRt7yZpksQ7kNvgH8uljS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZudkdQrWxpL6cuOFNkdkr6tmqZGHgeu0GPUDlWv65qA&oe=6739F048"}, "display_name": "The Talent Stealer", "keywords": [], "long_description": "2023 Cinequest Official Finalist and LA Film Awards Winner for VR, The Talent Stealer is a Sci-Fi Action Thriller film presented in the new 8K 180-3D Immersive Format: \nChapter 1 - At a secret facility called The Maxstein Institute, a group of students are controlled and trained to master their special memory-stealing abilities by a shadowy organization with morally ambiguous goals.\nOne student is singled out for her extraordinary power, and finds herself in a fight for her freedom and her sanity from those that wish to control her.\n\nCombining elements of traditional 2D Cinema with the new 3D 180 Immersive format,  viewers can feel like they have truly \"stepped inside\" a Hollywood movie for the very first time... experiencing Cinema standards of lighting, music, sound effects and editing that reaches a new height in VR film storytelling.\n\nThe Talent Stealer is the first 30min Chapter in a series of films coming soon to VR (further Chapter trailer included).\n\n*Spatial Audio Soundtrack Update coming soon!", "short_description": "2023 Cinequest Finalist and LA Film Awards Winner, this is a Sci-Fi Action Thriller film presented in the Immersive 8K 180 format: Chapter1 - At a secret facility called The Maxstein Institute, a group of students are controlled and trained to master their special memory-stealing abilities by a shadowy organization with morally ambiguous goals.\nOne student is singled out for her extraordinary power, and finds herself in a fight for her freedom and her sanity from those that wish to control her."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.realmoonlight.com/#privacy", "developer_terms_of_service_url": null, "publisher_name": "Real Moonlight Studios", "support_website_url": null, "website_url": "http://www.realmoonlight.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1375531562985576"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "925988826