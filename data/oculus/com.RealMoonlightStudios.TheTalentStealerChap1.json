92_1115636016211198_1143460225631402822_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5W_bOIbX9MEQ7kNvgFHMUJr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUuTkvH6gRYIwOl8bh57wv7&oh=00_AYCw5ELUrbWsi5uQLyf_0doJbDrHvY9JAtAOfvC9dmudQA&oe=66DD849F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AltLandscape2.png", "id": "1096341991458509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75588060_1096341998125175_1883949348999816313_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IRndV3dM4fIQ7kNvgEkYs16&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUuTkvH6gRYIwOl8bh57wv7&oh=00_AYD_2uJLEXZ679NU5xcD0PQWUF_Bezgq3I1mcQebv-5WNw&oe=66DD6F08"}, "display_name": "The Talent Stealer", "keywords": [], "long_description": "2023 Cinequest Official FINALIST and LA Film Awards WINNER for VR, The Talent Stealer\u2122 is a spectacular 30min Sci-Fi Action-Thriller presented in the new Immersive Cinema Format (8K 180VR-3D): \n\nCHAPTER I - At a secret facility called The Maxstein Institute, a group of students are controlled and trained to master their special memory-stealing abilities by a shadowy organization with morally ambiguous goals. One student is singled out for her extraordinary power, and finds herself in a fight for her freedom and her sanity from those that wish to control her.\n\nCombining elements of traditional 2D Cinema with the new 3D-180 Immersive Video format,  viewers can feel like they have truly \"stepped inside\" a Hollywood movie for the very first time... experiencing Cinema standards of Lighting, Music, VFX and Editing that reach new heights in VR film storytelling.\n\nThe Talent Stealer is the first Chapter in a series of film Chapters coming soon to VR (further Trailer included!).\n\n*SPATIAL AUDIO SOUNDTRACK UPDATE COMING SOON!*\n\n\n\n\n*Disclaimer - This VR Film has some scenes with flashing lights and may not be suitable for photosensitive viewers.\nThe Talent Stealer\u2122 copyright 2022 all rights reserved.\n\n---AWARDS and COMPETITIONS---\n\n2022 FIVARS (Festival of International Virtual and Augmented Reality Stories) - Toronto \n2023 The Victoria Film Festival - Victoria BC, SPECIAL PRESENTATION\n2023 Barcelona Planet Film Festival -  VR WINNER\n2023 Cinequest - Silicon Valley,, VR FINALIST\n2023 LA Film Awards - VR WINNER\n\n\n", "short_description": "2023 Cinequest Finalist and LA Film Awards Winner, this is a Sci-Fi Action Thriller film presented in the Immersive 8K180 format: Chapter I - At a secret facility called The Maxstein Institute, a group of students are controlled and trained to master their special memory-stealing abilities by a shadowy organization with morally ambiguous goals.\nOne student is singled out for her extraordinary power, and finds herself in a fight for her freedom and her sanity from those that wish to control her."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.realmoonlight.com/#privacy", "developer_terms_of_service_url": null, "publisher_name": "Real Moonlight Studios", "support_website_url": null, "website_url": "http://www.realmoonlight.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2777382702530830"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8864783483537653"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982693_424463976894165_7136656298283267610_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XNhmnS1vlgEQ7kNvgF6YfV