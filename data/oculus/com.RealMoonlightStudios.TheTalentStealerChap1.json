luscdn.com/v/t64.5771-25/38974807_1878083979389858_5266083509574633206_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dX7ptMzIzbwQ7kNvgFFwNmz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChYpsgT4WFPXX6iymCx1pTJ9BYca5HivgGkoLeHi3SkQ&oe=672F38BE"}, {"file_name": "ScreenShot 5.png", "id": "958005615545642", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75278188_958005618878975_1112688403689238812_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xAxUiwjPRY0Q7kNvgFtqM7k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgICwuO0SXddwTxtZXX7qmOaMaflU4Deoju72kAldfzg&oe=672F3506"}, {"file_name": "Screenshot 3.png", "id": "1115636012877865", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269592_1115636016211198_1143460225631402822_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cL4I5-4Z7LQQ7kNvgHu6HTj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZiQHmAFPS_SSrXN3EL7IWJVJS6k3HMfHXGoLDr80mXQ&oe=672F419F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AltLandscape2.png", "id": "1096341991458509", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75588060_1096341998125175_1883949348999816313_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NdA6K_mYRM0Q7kNvgFKM3Js&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjYzXCJV7Ul_5zo_URUuMoQUx3vINXGsXmu9Pa6l2FuA&oe=672F6448"}, "display_name": "The Talent Stealer", "keywords": ["Film", "Movie", "Immersive", "Video", "media"], "long_description": "# THE 1\u02e2\u1d57 SCI-FI NARRATIVE FILM in the NEW IMMERSIVE CINEMA FORMAT (8K 180VR-3D)\n .\n\n\n**The Talent Stealer\u2122 is an Award-Winning & Spectacular Sci-Fi Action-Thriller that achieves NEW LEVELS of Entertainment and Sophistication in VR Filmmaking - with an incredible concept & story in the vein of The Matrix, Inception, X-Men and Nikita:**\n{832273108830730}\n\n.\n\nAt a secret facility called The Maxstein Institute, a group of students are controlled and trained to master their special memory & skill-stealing abilities by a shadowy organization with morally ambiguous goals. One student is singled out for her extraordinary power, and finds herself in a fight for her freedom and sanity from those that wish to control her\n\n**Starring performers Breanna Watkins (The Predator, Sonic) and Jared Payne (The Last of Us Se2)**\n\n.\n{568206852351381}\n{428947983583090}\n\n\n\n\n\n\n- Specially engineered to combine elements of 2D Cinema with the new 3D-180 Immersive Video format, you can truly feel like you have \"stepped inside\" a Hollywood movie for the **VERY FIRST TIME** - experiencing Cinema standards of lighting, music, VFX and editing for a complex narrative story flow and \"little to no\" motion sickness\n\n{594527463011387}\n\n**The Talent Stealer\u2122  (30min) is the first Chapter in a series of Chapters coming soon (further TRAILER included!)**\n\n\n\n*SPATIAL AUDIO upgrade soon\n*Film contains scenes with flashing lights and not suitable for photosensitive viewers\n\nThe Talent Stealer\u2122 copyright 2022\n\n\n.\n\n# AWARDS\n\n**2023 LA Film Awards VR WINNER**\n\n**2023 Cinequest - Silicon Valley VR FINALIST**\n\n**2023 The Victoria Film Festival**\n\n**2022 FIVARS Toronto**\n\n\n\n\n\n\n{543504715064765}\n{447511837972226}\n\n\n\n\n\n\n", "short_description": "2023 Cinequest Finalist and LA Film Awards Winner, this is a Sci-Fi Action Thriller film presented in the Immersive 8K180 format: Chapter I - At a secret facility called The Maxstein Institute, a group of students are controlled and trained to master their special memory-stealing abilities by a shadowy organization with morally ambiguous goals.\nOne student is singled out for her extraordinary power, and finds herself in a fight for her freedom and her sanity from those that wish to control her."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.realmoonlight.com/#privacy", "developer_terms_of_service_url": null, "publisher_name": "Real Moonlight Studios", "support_