nJH2tpnJ1Z&oh=00_AYAps8tx4-ip31yfRSAWD-gU8bEcJ22j4EcZua8mQVdOJw&oe=66E41D3C"}, {"file_name": "L5.png", "id": "1291381601464817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982592_1291381604798150_504386217610830001_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kliTmHNkJTMQ7kNvgFVXcyZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Usb23xgq-ornJH2tpnJ1Z&oh=00_AYA7OVuPASoCK648eqj9DC3TMNnuO4NL7r9sayDg4d-F-A&oe=66E40DD7"}, {"file_name": "L4.png", "id": "675978691030538", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984447_675978694363871_4569307986555874553_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4jvRUMLDI00Q7kNvgEh0l0M&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Usb23xgq-ornJH2tpnJ1Z&oh=00_AYDmon8j-AL7tgu6y6t_y_TNtvsUfuEiAodxvtuQoGYcfQ&oe=66E4350E"}, {"file_name": "L3.png", "id": "1040047633632106", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031376_1040047636965439_3456093016041400068_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5oBzCxxLvQIQ7kNvgGSvYaq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Usb23xgq-ornJH2tpnJ1Z&oh=00_AYCTQsKISK13lo_uw0ckMFXtbAqIiTXksaW0itVZfwdwAw&oe=66E432F7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1066198721021778", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031567_1066198724355111_4955011362448384175_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OrQlXFW6lhEQ7kNvgH6-UoQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Usb23xgq-ornJH2tpnJ1Z&oh=00_AYBZ4_DYVk1Kki2WS2pwxRlKQXVz7T6QdDLF3T2r1pLZqA&oe=66E41E3B"}, "display_name": "Tales of Tsynara Part I", "keywords": [], "long_description": "Become the wizard you always wanted to be. Be the champion of Tsynara, an ancient place created by powerful wizards. They used the key elements of nature: Fire, Water and Air to keep everything uncorrupted and in balance among the realms.\n\nUntil, fallen mage Aldern unleashed a cataclysmic spell, binding the planes in his own chains of energy .\n\nNow, as being the prodigy of Tsynara, travel through the fire plane, collect spells and face the minions of Aldern.\n\nAn original approach for playing a mage character like no other. Fly for exploring, cast spells from each of your hand for eliminating. You will feel the true nature of this notorious plane and lose track of reality.\n\nExplore the corrupted Fire plane controlled by this evil mage's lords and dragons. Face the dragon and feel the real mayhem in it.", "short_description": "Become the wizard you always wanted to be. Explore the corrupted Fire plane controlled by evil mage Aldern's lords and dragons. \n\nAn original approach for playing a mage character like no other. Fly for exploring, cast spells for eliminating. You will feel the true nature of the fire plane and lose track of reality.\n\nEnter the plane and feel the real mayhem in it.\n\n\n\n"}]}, "developer_name": "Beren Studio", "developer_privacy_policy_url": "https://www.tsynara.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Beren Studio", "support_website_url": null, "website_url": "https://tsynara.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2221647054891829"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "689430586565479"}, {"status": "PUBLISHED", "id": "2375462282648370"}]}, "baseline_offer": {"id": "689430586565