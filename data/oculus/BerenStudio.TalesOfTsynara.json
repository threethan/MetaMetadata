aT82&oh=00_AYBlNC8n2qxbo4APRCdeKzcQmqOgqp21lvH9vQoE-K6OjA&oe=66F29DBC"}, {"file_name": "L5.png", "id": "1291381601464817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982592_1291381604798150_504386217610830001_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PGJzpwJ7YeMQ7kNvgHMa0yJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqKO67vWbf_WAI_6qj_aT82&oh=00_AYDoKGZ09mr5uLFId9yb8UORXwiT174yQmXU28FJRv925A&oe=66F28E57"}, {"file_name": "L4.png", "id": "675978691030538", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984447_675978694363871_4569307986555874553_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_O4sIwpIdToQ7kNvgFLIa9i&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqKO67vWbf_WAI_6qj_aT82&oh=00_AYCTlDWQNJzE2wy5mWKn-v5L3AyBVh-9Rky2nhR34EWyLw&oe=66F2B58E"}, {"file_name": "L3.png", "id": "1040047633632106", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031376_1040047636965439_3456093016041400068_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bumkEvzJUIYQ7kNvgGoaZNX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqKO67vWbf_WAI_6qj_aT82&oh=00_AYDCPGskmP0ddQeGyyNnLrJ8wwUuy96TWsXcucwnaq9KOA&oe=66F2B377"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1066198721021778", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031567_1066198724355111_4955011362448384175_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dzE8I8XZ5mcQ7kNvgHKLKsd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqKO67vWbf_WAI_6qj_aT82&oh=00_AYC1cLfqOUrlkVDVV6KVvWu6jzxr3042kVIHr4QxfT0rIQ&oe=66F29EBB"}, "display_name": "Tales of Tsynara Part I", "keywords": [], "long_description": "Become the wizard you always wanted to be. Be the champion of Tsynara, an ancient place created by powerful wizards. They used the key elements of nature: Fire, Water and Air to keep everything uncorrupted and in balance among the realms.\n\nUntil, fallen mage Aldern unleashed a cataclysmic spell, binding the planes in his own chains of energy .\n\nNow, as being the prodigy of Tsynara, travel through the fire plane, collect spells and face the minions of Aldern.\n\nAn original approach for playing a mage character like no other. Fly for exploring, cast spells from each of your hand for eliminating. You will feel the true nature of this notorious plane and lose track of reality.\n\nExplore the corrupted Fire plane controlled by this evil mage's lords and dragons. Face the dragon and feel the real mayhem in it.", "short_description": "Become the wizard you always wanted to be. Explore the corrupted Fire plane controlled by evil mage Aldern's lords and dragons. \n\nAn original approach for playing a mage character like no other. Fly for exploring, cast spells for eliminating. You will feel the true nature of the fire plane and lose track of reality.\n\nEnter the plane and feel the real mayhem in it.\n\n\n\n"}]}, "developer_name": "Beren Studio", "developer_privacy_policy_url": "https://www.tsynara.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Beren Studio", "support_website_url": null, "website_url": "https://tsynara.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2221647054891829"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "689430586565479"}, {"status": "PUBLISHED", "id": "2375462282648370"}]}, "baseline_offer": {"id": "689430586565479"},