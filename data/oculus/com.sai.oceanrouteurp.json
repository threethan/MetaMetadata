876105380887_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8UId2erGi-8Q7kNvgFjbYcf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2R3gKutsAmyU6iNQgNyaFE7xMZsuGEVoDwhgLfiPi0A&oe=6746F251"}, {"file_name": "sc2.png", "id": "606632337371447", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974604_606632340704780_241091325226336088_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QXKbSDRh23cQ7kNvgGRFkf2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8T2EcBXQA1WPdbMSuVwX6knbPbv-SbW95T3wFdXtPlw&oe=6747192A"}, {"file_name": "sc3.png", "id": "1938137916355082", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982552_1938137919688415_7351702325631789169_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GgDi-EVxfLoQ7kNvgGERU0a&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQsK7Jh3NmngcnbfqDKMNvSkqn6PGZrL15XIBo9FmL3A&oe=67470C22"}, {"file_name": "sc4.png", "id": "385047446401879", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568677_385047449735212_1464954907125954336_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3dtB04dFqMMQ7kNvgHOxxCs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjr19mWLkw4s90yWyEwb0KdNKLYWBoBsoJwo2RuCACKg&oe=6746F95C"}, {"file_name": "sc5.png", "id": "320476236543044", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572918_320476239876377_4860331478258876036_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=beupbsqH2a0Q7kNvgE4uKqL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6psS0G2U4wZQeRLuwuljjM2eC4H6aMyrjyokFlW2SmQ&oe=674707D0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "COVER.png", "id": "4980790088603842", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569456_4980790091937175_8848556797338170656_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZoaaDyLSiq4Q7kNvgGixR-j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1EJtnHyiIregxYiPxjHyDY_AWno8JLnF476QyeJq0Gw&oe=6746F48A"}, "display_name": "OceanRoute", "keywords": [], "long_description": "Operation Description\n\nLeft stick (up/down) (vertical rotation of viewpoint)\nRight stick (up/down) (Speed Change)\nLR Trigger(Brightness change)\n\n\nA button \uff08decision / BGM change)\nB button \uff08decision / Description On/Off)\nX or Y Button (BGM volume change)", "short_description": "This app is designed for healing and relaxation.\n\nIn this app, you will experience \"\njust keep running along the Ocean road\".\n\nThis experience,\n which may seem monotonous in some ways, \nmay give your tired brain a break.\n\nIf you have trouble sleeping \nor \nif your brain is tired, try using this app.\n\nThis app also includes a rotating view function so that \nyou can experience the app while lying down."}, {"images": {"nodes": []}, "id": "441300310592732", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ocean Route", "keywords": [], "long_description": "\u64cd\u4f5c\u8aac\u660e\n\nL\u30b9\u30c6\u30a3\u30c3\u30af\uff08\u4e0a\u4e0b\uff09\uff08\u8996\u70b9\u7e26\u56de\u8ee2)\nR\u30b9\u30c6\u30a3\u30c3\u30af\uff08\u4e0a\u4e0b\uff09\uff08\u30b9\u30d4\u30fc\u30c9\u5909\u66f4)\nLR \u30c8\u30ea\u30ac\u30fc(\u660e\u308b\u3055\u5909\u66f4)\nA\u30dc\u30bf\u30f3\uff08\u6c7a\u5b9a/BGM\u5909\u66f4)\nB\u30dc\u30bf\u30f3\uff08\u8aac\u660e\u30aa\u30f3\u30aa\u30d5)\nXorY\u30dc\u30bf\u30f3\uff08BGM \u30dc\u30ea\u30e5\u30fc\u30e0\u5909\u66f4)", "short_description": "\u3053\u306e\u30a2\u30d7\u30ea\u306f\u30d2\u30fc\u30ea\u30f3\u30b0\u3001\u30ea\u30e9\u30c3\u30af\u30b9\u3092\u76ee\u7684\u3068\u3057\u305f\u30a2\u30d7\u30ea\u3067\u3059\u3002\n\n\u3053\u306e\u30a2\u30d7\u30ea\u3067\u306f\n\u300c\u6d77\u306e\u9053\u3092\u305f\u3060\u3072\u305f\u3059\u3089\u8d70\u308a\u7d9a\u3051\u308b\u300d\u3053\u3068\u3092\u4f53\u9a13\u3059\u308b\u3053\u3068\u306b\u306a\u308a\u307e\u3059\u3002\n\u3042\u308b\u610f\u5473\u3001\u5358\u8abf\u306b\u3082\u611f\u3058\u3089\u308c\u308b\u3053\u306e\u4f53\u9a13\u306f\u3001\n\u3042\u306a\u305f\u306e\u75b2\u308c\u305f\u8133\u3092\u4f11\u307e\u305b\u308b\u3053\u3068\u306b\u306a\u308b\u304b\u3082\u3057\u308c\u307e\u305b\u3093\u3002\n\n\u8133\u304c\u75b2\u308c\u305f\u6642\u3001\n\u306a\u304b\u306a\u304b\u5bdd\u4ed8\u3051\u306a\u3044\u3068\u304d\u306a\u3069\u3001\n\u3053\u306e\u30a2\u30d7\u30ea\u3092\u4f7f\u7528\u3057\u3066\u307f\u3066\u304f\u3060\u3055\u3044\u3002\n\n\u307e\u305f\u3001\u3053\u306e\u30a2\u30d7\u30ea\u306f\u5bdd\u305d\u3079\u3063\u305f\u72b6\u614b\u3067\u30a2\u30d7\u30ea\u3092\u4f53\u9a13\u3067\u304d\u308b\u3088\u3046\n\u8996\u754c\u306e\u56de\u8ee2\u6a5f\u80fd\u3082\u5165\u3063\u3066\u3044\u307e\u3059\u3002"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2021/09/ocean-route.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2021/09/about-ocean-route.html", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "813792282757007"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "922198428373259"}]}, "baseline_offer": {"id": "922198428373259"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1633646160, "status": "PUBLISHED", "id": "922198428373259"}]}, "liveChannel": {"nodes": [{"latest_supported_binary"