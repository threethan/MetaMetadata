0_AYD7tOLAen6gg9DUWpMhRaCnb4kwSxaTLXSABnjT4c67DA&oe=66FBEFBF"}, {"file_name": "Screenshot_Side_pose_03.png", "id": "886398413385058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031599_886398416718391_1074446502736338873_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-uCITJkiiRgQ7kNvgH_O-jc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjtGWU-ijHMgwsUlglgkNf449UeVZuT2OfJlFlOdNtbw&oe=66FBE9C1"}, {"file_name": "Screenshot_Side_pose_04.png", "id": "906424294869708", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572945_906424298203041_5240043680899816236_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t-YuMjRb6SMQ7kNvgGYVOKc&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbxEU-vHLqqqcQf9Wt_UdoQgKBIVUmeRlelS4IIm3Rqw&oe=66FBF95E"}, {"file_name": "Screenshot_Side_pose_05.png", "id": "515751047479513", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566677_515751050812846_1462125130731236590_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f8zBFimLOYIQ7kNvgFD0jSx&_nc_ht=scontent.oculuscdn.com&oh=00_AYANf-wSZ_oNeucXc9GjpbNt_yFWE1z9Lq0KbrNMpDAhKg&oe=66FBC7A2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "1250290243014788", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974750_1250290246348121_2726061545124475027_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5EE1RCojTVwQ7kNvgH5Q6c8&_nc_ht=scontent.oculuscdn.com&oh=00_AYD81b8XySRH_JI_zG3f_psDf1yLa-mlyFLxyXkhTtE51w&oe=66FBF435"}, "display_name": "Side Positioning Assistance Simulator", "keywords": ["CNA", "nurse", "nursing", "training", "simulator"], "long_description": "This Siding Positioning Assistance tutorial trains the essential skill of positioning a patient on their side, focusing on comfort and the prevention of pressure ulcers. The tutorial includes preparation, proper technique for turning and positioning, and ensuring patient safety.  \n\n# Learning Objectives: \n- Remember the steps and protocols for positioning a patient on their side. \n- Understand the importance of proper patient positioning for comfort and pressure ulcer prevention. \n- Apply the correct techniques to position a patient on their side safely. \n- Analyze the patient's condition to determine the best approach for positioning. \n- Evaluate their own technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and safe environment for patients through proper positioning. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Master the technique of positioning a patient on their side to ensure comfort and prevent pressure ulcers."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8673710309314573"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974635_4005288749792982_1000365435033069993_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wePsJaj_5L0Q7kNvgG7FyL-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBB79kouDDxYD7u