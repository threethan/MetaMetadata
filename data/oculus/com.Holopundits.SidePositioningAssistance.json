1542520649", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_Side_pose_01.png", "id": "1543073333013490", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035430_1543073336346823_164735258537155003_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lyYmqGJ_E8QQ7kNvgEqf1d3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDs0euJNKNjLmsVMwGqkLP57PIRuvjS8Efko6SF1uBMFg&oe=676FF474"}, {"file_name": "Screenshot_Side_pose_02.png", "id": "1676075492954723", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036603_1676075496288056_912924117455913729_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mjb7wNZ6B58Q7kNvgF5SMdJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWLzK0IwQJeda6pTCR5DDMbCTOGJHixY4rWBJ0SmBUWw&oe=676FCF32"}, {"file_name": "Screenshot_Side_pose_03.png", "id": "8885257094863061", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572929_8885257098196394_9111613396294295479_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KOIwIyoXvFQQ7kNvgFArdIv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC2zF2sgJtcaIErT08QfJxUTWPUQxds_buCxsPlriZT_w&oe=676FE9F2"}, {"file_name": "Screenshot_Side_pose_04.png", "id": "1559761218034380", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036606_1559761221367713_4073625866924653164_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1sIp97y0dbwQ7kNvgGcaZXr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_ckM0AmHrqlvzVrYmr3UjPGiu-qV1BmfDOgEmUOHq0A&oe=676FE88D"}, {"file_name": "Screenshot_Side_pose_05.png", "id": "612362548133459", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974794_612362551466792_2296386789300772526_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wjdLeC7aLgYQ7kNvgHlmTpV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ1acDcPuGnxXOKnCSmzNmsf2d9IhhqlTniNUKx-iMKg&oe=676FE776"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_Side_pose_01.png", "id": "891350839646165", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974853_891350842979498_1892211547634156226_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mvjd5FMbyDYQ7kNvgHMJr3v&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQPJMRva4vAByZ-VIjPT7ZXf-Ozcaye1L9_CM3xfw5ow&oe=676FFAB2"}, "display_name": "Side Positioning Assistance Simulator", "keywords": ["CNA", "nurse", "nursing", "training", "simulator"], "long_description": "This Siding Positioning Assistance tutorial trains the essential skill of positioning a patient on their side, focusing on comfort and the prevention of pressure ulcers. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n# Learning Objectives: \n- Remember the steps and protocols for positioning a patient on their side. \n- Understand the importance of proper patient positioning for comfort and pressure ulcer prevention. \n- Apply the correct techniques to position a patient on their side safely. \n- Analyze the patient's condition to determine the best approach for positioning. \n- Evaluate their own technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and safe environment for patients through proper positioning. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Master the technique of positioning a patient on their side to ensure comfort and prevent pressure ulcers with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9415187055166891"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974783_884170360443184_5776551371865764616_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kxmG5J0IrLwQ7kNvgGAeLX9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB1Z_oaTLIc2tHpv2Kd4fco7ifIp7_b0ywXi55VuB2GxA&oe=676FFD9A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Side Positioning Assistance Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1725630720, "lastRevision": {"nodes": [{"id": "8673710332647904", "release_type": "SCHEDULED", "administrati