t=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oYe9vB1ekhsQ7kNvgGhDWQv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzIyMOy_kn2Q5ecU9FsI0LtLNOQiF7Wwd49g7rQYUQcQ&oe=67695E37"}, {"file_name": "Screenshot_Weighing-in_02.png", "id": "1138938350922293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003271_1138938357588959_8881941000624118508_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4_vmWUKEqDkQ7kNvgGzqxaU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBU4zGMkiTngbGSzh2MCFYhKsl5b0Fa-P_JAdAF6SeiBA&oe=67696976"}, {"file_name": "Screenshot_Weighing-in_03.png", "id": "27939219659056670", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221320_27939219665723336_7544990735924748400_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zrTscJTo-ncQ7kNvgHuf_Z_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGnc0QiIUPC5dihi6WGrjLfCdYr9pO0VRTN3XVR2Fu7w&oe=67693DFF"}, {"file_name": "Screenshot_Weighing-in_04.png", "id": "1288221745859965", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031340_1288221749193298_6235000987628005261_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yGT_XMBLoAUQ7kNvgF6kWZ4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvS-QFCYSigHYzgd1-z7Ojs3xT8R3gNlWGxXFO3cy8EA&oe=67694985"}, {"file_name": "Screenshot_Weighing-in_05.png", "id": "8022341477868749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982501_8022341481202082_3248629264139566495_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mwLvEB6aTrsQ7kNvgH6pZwa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBl4d7oPQAY_xi4sGdM13ZSOSFzy-nhFP1r_8Fznne08w&oe=676967EA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_Weighing-in_04.png", "id": "2888110204687782", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65227368_2888110208021115_3892469596718725049_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8SUarSuXkqsQ7kNvgEOG1EU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDcN7qBPF-s_tNWze9hvlf4rWy6nw_t30dlc8xjOxC59A&oe=67693FDA"}, "display_name": "Weighing-In Simulator", "keywords": ["CNA", "nurse", "nursing", "training", "simulator"], "long_description": "This VR simulation teaches the essential skill of measuring and recording the weight of ambulatory clients. The tutorial includes preparation, proper technique for using a scale, and documentation.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n By the end of this tutorial, participants will be able to: \n- Remember the steps and protocols for measuring and recording weight. \n- Understand the importance of accurate weight measurement for patient health and care planning. \n- Apply the correct techniques to measure and record weight safely and accurately. \n- Analyze any factors that may affect weight measurement and take appropriate actions. \n- Evaluate their own technique to ensure it adheres to best practices and safety standards. \n-Create accurate and reliable documentation for patient records. ", "short_description": "Learn to accurately measure and record the weight of ambulatory clients, ensuring proper documentation and care with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "categ