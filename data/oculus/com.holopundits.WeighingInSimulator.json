t=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lu-hcLRm3VcQ7kNvgFGI-po&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBMQVpphjevThsgEaEE7JCQ5Gq9P77o_3Elz0dLamXuA&oe=676C0137"}, {"file_name": "Screenshot_Weighing-in_02.png", "id": "1138938350922293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003271_1138938357588959_8881941000624118508_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cPklB63eXB4Q7kNvgEk4efj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfn7YI8Sxc_nnQRiHcPUzilztisiMJRFqSOcehxw_hDw&oe=676BD436"}, {"file_name": "Screenshot_Weighing-in_03.png", "id": "27939219659056670", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221320_27939219665723336_7544990735924748400_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hxY19_aOo7MQ7kNvgH_md2X&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmUPk-41khkQyZs6ivW5iK22b9g-XRxXPe2VTzxDno9w&oe=676BE0FF"}, {"file_name": "Screenshot_Weighing-in_04.png", "id": "1288221745859965", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031340_1288221749193298_6235000987628005261_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PSNQwmKgIQ4Q7kNvgGDBDad&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPO_5wkPyqgMaqvBpMbhQqKTmbK7zbPcASsotFHHZ4rg&oe=676BEC85"}, {"file_name": "Screenshot_Weighing-in_05.png", "id": "8022341477868749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982501_8022341481202082_3248629264139566495_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=igOPes3rKCsQ7kNvgGVhHsu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPHiLb8bL2v5EFiDjJcG4OVkyfLk_pTRPMxUhNmAPkFw&oe=676C0AEA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_Weighing-in_04.png", "id": "2888110204687782", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65227368_2888110208021115_3892469596718725049_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8SUarSuXkqsQ7kNvgHGrWHe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJ-hzWMC8bFLB3uJYm8iB1K8SwU_dEWMOLmxB5DWjniA&oe=676BE2DA"}, "display_name": "Weighing-In Simulator", "keywords": ["CNA", "nurse", "nursing", "training", "simulator"], "long_description": "This VR simulation teaches the essential skill of measuring and recording the weight of ambulatory clients. The tutorial includes preparation, proper technique for using a scale, and documentation.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n By the end of this tutorial, participants will be able to: \n- Remember the steps and protocols for measuring and recording weight. \n- Understand the importance of accurate weight measurement for patient health and care planning. \n- Apply the correct techniques to measure and record weight safely and accurately. \n- Analyze any factors that may affect weight measurement and take appropriate actions. \n- Evaluate their own technique to ensure it adheres to best practices and safety standards. \n-Create accurate and reliable documentation for patient records. ", "short_description": "Learn to accurately measure and record the weight of ambulatory clients, ensuring proper documentation and care with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "categ