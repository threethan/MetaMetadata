5_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hESypJQYXs8Q7kNvgHZD-Zn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAv0w42-jVn9sMpEsaC9VyTyzkw6Mx9luYnohk8CUIyyA&oe=66D2F535"}, {"file_name": "screenshot3.png", "id": "1158850501406069", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196217_1158850504739402_8340334527744794105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m5Dkqb0lT38Q7kNvgEuyz0V&_nc_ht=scontent.oculuscdn.com&oh=00_AYCT0VTGTuyRjjKhMrYvdytQQxTZ5vvifAu5PdvK3FBGLw&oe=66D2EF63"}, {"file_name": "screenshot4.png", "id": "478865147737588", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031455_478865151070921_2894074766338485527_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WuNU4IDpkmgQ7kNvgGyR5WX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUIglgovqxufj1RcvGgapX3p7ygp6gotWcekIloXQyUQ&oe=66D2F6C9"}, {"file_name": "screenshot5.png", "id": "613228310803811", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222941_613228314137144_8414086182000211747_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OXFZJsvy3nUQ7kNvgG3XeNM&_nc_ht=scontent.oculuscdn.com&oh=00_AYARssvgwVFsclN9_0YXYRGBOCxlBCEIr0GNO9bUFjhXXQ&oe=66D31073"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cleric and Goblins", "keywords": [], "long_description": "\"Cleric and Goblins\" is a VR action game. Dive into a procedurally generated dungeon and rescue the cleric. The structure of the dungeon changes each time. The only enemies are goblins, but their equipment and personalities vary. If you kill a goblin, you will get the equipped weapon. A variety of weapons with different strengths and characteristics, such as knives, swords, maces, and spears! Dive into the dungeon, kill the goblins, rescue the cleric, and make your way to the exit!\n\nSTORY:\nOne day, you suddenly wake up in a strange forest. When I was stunned, a cleric girl happened to pass by. She will guide you to a nearby town, give you what little money she has and her knife for self-defense and leave. A few days later, you learn that she has been kidnapped by goblins. You take her knife and potion and dive into the dungeon to rescue her.\n\nCOMBAT SYSTEM and PHYSICS:\nThe game employs a combat system that emphasizes realistic physics. The player's hands and weapons interact with the enemy's body. You can shove the enemy's body with heavy weapons and stab them with sharp weapons. Weapon weight and coefficient of friction are important factors. You can also grab and throw enemies or attack them. You can also roll your weapon to the enemy's feet to make them fall. There are multiple ways to defeat an enemy. Let's explore different possibilities, like a real fight.", "short_description": "\"Cleric and Goblins\" is a VR action game. Dive into a procedurally generated dungeon and rescue the cleric. The structure of the dungeon changes each time. The only enemies are goblins, but their equipment and personalities vary. If you kill a goblin, you will get the equipped weapon. A variety of weapons with different strengths and characteristics, such as knives, swords, maces, and spears! Dive into the dungeon, kill the goblins, rescue the cleric, and make your way to the exit!"}, {"images": {"nodes": []}, "id": "560403785511038", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u304f\u308c\u308a\u3063\u304f\u3055\u3093\u306f\u3059\u3050\u30b4\u30d6\u30ea\u30f3\u306b\u3055\u3089\u308f\u308c\u308b", "keywords": [], "long_description": "\u300c\u304f\u308c\u308a\u3063\u304f\u3055\u3093\u306f\u3059\u3050\u30b4\u30d6\u30ea\u30f3\u306b\u3055\u3089\u308f\u308c\u308b\u300d\u306f\u81ea\u52d5\u751f\u6210\u3055\u308c\u305f\u30c0\u30f3\u30b8\u30e7\u30f3\u306b\u98db\u3073\u8fbc\u3093\u3067\u304f\u308c\u308a\u3063\u304f\u3055\u3093\u3092\u6551\u51fa\u3059\u308bVR\u30a2\u30af\u30b7\u30e7\u30f3\u30b2\u30fc\u30e0\u3067\u3059\u3002\u6d1e\u7a9f\u306f\u5165\u308b\u305f\u3073\u306b\u6bce\u56de\u69cb\u9020\u304c\u5909\u308f\u308