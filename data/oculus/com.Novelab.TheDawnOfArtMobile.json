O0deqHB61exFx7URptw&oe=6710EF00"}, {"file_name": "screen 5.png", "id": "1011288603580372", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982685_1011288606913705_6013956803355452003_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_cv9HXy5C8Q7kNvgFYcf2I&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCoOfHb1uJ1yR1nc5C4UM4k2tObW4hxA6rpM-qVYoxD9g&oe=6710E471"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover.png", "id": "245591718024449", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75297578_245591724691115_5395467863842225092_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3u5QZ8VCSPkQ7kNvgHRo4ZU&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAouRZDka_mKIkOYCsaBIbitHjhIEdyOq9-Fb81m5JYtw&oe=6710E96B"}, "display_name": "The Dawn of Art", "keywords": [], "long_description": "Let Daisy Ridley guide you in your discovery of the Chauvet Cave, a Unesco World Heritage Site, considered one the greatest scientific breakthroughs of the 20th century. \n\nOur humanity\u2019s first masterpiece was created 36, 000 years ago in Ard\u00e8che, France. Within Chauvet Cave lies thousands of drawings, enclosed forever. The Dawn of Art is a Virtual Reality experience, including both an immersive film and a virtual visit of the cave that invites you to meet your prehistoric ancestors, the first humans who ventured in a deep subterranean world and left their marks preserved on the walls.\n\nBrought to you by The Public Union for the Management of the Chauvet Cave, in coproduction with Auvergne-Rh\u00f4ne-Alpes Cin\u00e9ma, with support of Google Arts & Culture, R\u00e9gion Auvergne-Rh\u00f4ne-Alpes, D\u00e9partement de l'Ard\u00e8che and Minist\u00e8re de la Culture. Line Production: Atlas V / Novelab", "short_description": "Explore the Chauvet Cave 36,000 years ago, with Daisy Ridley\u2019s voice as your guide. It\u2019s in the Ard\u00e8che gorges, in the south of France, that our ancestors drew humanity\u2019s first masterpieces, giving life to their beliefs.\n"}]}, "developer_name": "Atlas V, Novelab, Google Arts & Culture, SMERGC", "developer_privacy_policy_url": "https://astreaimmersive.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://astreaimmersive.io/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1283811691952063"}, {"id": "661880351198839"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6233468106740843"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1040866977677129"}, {"status": "PUBLISHED", "id": "348434134269333"}, {"status": "PUBLISHED", "id": "598884868634094"}]}, "baseline_offer": {"id": "348434134269333"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1040866977677129"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9290999620972139", "version": "0.97"}, "id": "1590093838158409", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9139584402780329", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9290999620972139"}, "release_status": "RELEASED"}, "binary_release_channels