.com&oh=00_AYCphj9AhL0xqm2VQl2-ubYUYoPiwH9hgYH9AwVq4OYYCw&oe=6756CE80"}, {"file_name": "screen 5.png", "id": "1011288603580372", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982685_1011288606913705_6013956803355452003_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nqwvk_g-3koQ7kNvgG32_Ap&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAwSvBsYqM5CtsKQSpEGRuMKAwHtwU2Q1YF8fWDSd_i6A&oe=6756C3F1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover.png", "id": "245591718024449", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75297578_245591724691115_5395467863842225092_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AquROEYqzqYQ7kNvgF815Lz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA9ryy4Rk3dqSMfSWAyNwgMlgNDplGO31CKxZuiNT_K4g&oe=6756C8EB"}, "display_name": "The Dawn of Art", "keywords": [], "long_description": "Let Daisy Ridley guide you in your discovery of the Chauvet Cave, a Unesco World Heritage Site, considered one the greatest scientific breakthroughs of the 20th century. \n\nOur humanity\u2019s first masterpiece was created 36, 000 years ago in Ard\u00e8che, France. Within Chauvet Cave lies thousands of drawings, enclosed forever. The Dawn of Art is a Virtual Reality experience, including both an immersive film and a virtual visit of the cave that invites you to meet your prehistoric ancestors, the first humans who ventured in a deep subterranean world and left their marks preserved on the walls.\n\nBrought to you by The Public Union for the Management of the Chauvet Cave, in coproduction with Auvergne-Rh\u00f4ne-Alpes Cin\u00e9ma, with support of Google Arts & Culture, R\u00e9gion Auvergne-Rh\u00f4ne-Alpes, D\u00e9partement de l'Ard\u00e8che and Minist\u00e8re de la Culture. Line Production: Atlas V / Novelab", "short_description": "Explore the Chauvet Cave 36,000 years ago, with Daisy Ridley\u2019s voice as your guide. It\u2019s in the Ard\u00e8che gorges, in the south of France, that our ancestors drew humanity\u2019s first masterpieces, giving life to their beliefs.\n"}]}, "developer_name": "Atlas V, Novelab, Google Arts & Culture, SMERGC", "developer_privacy_policy_url": "https://astreaimmersive.io/the-dawn-of-art-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Astrea", "support_website_url": null, "website_url": "https://astreaimmersive.io/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24732695486375969"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75303836_1403739367145851_1674676564143994634_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m0PgFKTSk1AQ7kNvgEoOfeh&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB2Fw2azIY69yvW7obFTuI0Z3_Cb_FIsEKW6SuXdR8WsQ&oe=6756C206"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Dawn of Art", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Travel & Exploration", "id": "726368587961803"}], "release_date": 1684978080, "lastRevision": {"nodes": [{"id": "9139584409446995", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "9139584402780329", "is_first_party": false, "enables_in_app_ads": false