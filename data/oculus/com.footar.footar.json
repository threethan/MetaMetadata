63486781877532_7252278463437505387_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=89ZGjpQjqioQ7kNvgFx5_R_&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAZp4yi37q4q4XyHtjj0oHWd8VKHSpSsiP6q7yZlblZyQ&oe=671250F0"}, {"file_name": "Screenshots2_Meta.png", "id": "451438524391969", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974508_451438527725302_677311732081247733_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03yq_1RycSEQ7kNvgHCIBfr&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCUVjajTeWVob9RV5Aos6pNaiaHWbthaFcLWDmBoI9_Ug&oe=671257D0"}, {"file_name": "Screenshots4_Meta.png", "id": "1210258773545043", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75485578_1210258776878376_2654477617005922571_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HmA2uUGa6IkQ7kNvgGB_nLt&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDdt0WoRd6M1By8R-A63Gi9xe3Sc-atfurQlZY32XNV0Q&oe=67123FF0"}, {"file_name": "Screenshots6_Meta.png", "id": "1189458392371775", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75451788_1189458395705108_2583583656028791790_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gvxlgl7wtDIQ7kNvgEQ5Su6&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYC883mHjiCx92YR00ut5x-iSuXuiM-YkAJXGtSfEvUgCw&oe=671259DE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_2560x1440.png", "id": "1664764224299343", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75507165_1664764227632676_1909328038571156048_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EiLck1zDqIMQ7kNvgHIikLB&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCftlu7MXVSQsj8YAGiW8JgD01CyWvnE5-PJqJhKH6AUw&oe=67123A1D"}, "display_name": "FootAR Sports in 3D", "keywords": [], "long_description": "FootAR: The New Sports StandARd\n\nGamified Augmented Reality Experience\n\nFootAR is not your ordinary sports app\u2014it\u2019s a gamified augmented reality (AR) experience that takes sports fandom to the next level. Imagine interacting with live sports data in real time while immersing yourself in the game through your Meta Quest headset. Let\u2019s dive into the exciting features:\n\nLivescore: Instant access to scores and detailed stats anytime, anywhere.\nPrizes: Earn collectibles as you engage with the game\u2014virtual trophies, exclusive content, and personalized rewards.\nHighlights: Never miss crucial moments with match recaps.\nxGoals: Dive into player performance\u2014chance of scoring based on analytics.\nAnywhere Access: From stadium seats to cozy living rooms, FootAR keeps you connected.\nLobby: Chat with fellow fans in real time and be part of the global sports community.\n\n\nWho Is It For?\n\nSports Fans: Dive into the game like never before.\nTelcos/Broadcasters: Enhance sports coverage with live data overlays.\nBetting Enthusiasts: Make informed decisions.\nSports Clubs: Boost fan engagement.\n\nWhether you\u2019re a die-hard fan, a sports broadcaster, or just someone who loves the thrill of the game, put on your Meta Quest headset and step into the world of FootAR. \ud83c\udfae\ud83d\udd25\n", "short_description": "SPORTS | GAMING | GOAL TRACKING | LIVE SMART STATS\n\nThe cutting-edge XR app that revolutionizes the way sports fans engage with their favorite games. \ud83c\udfc0\u26bd\ud83c\udfbe"}]}, "developer_name": null, "developer_privacy_policy_url": "https://footar.co/privacy-policy", "developer_terms_of_service_url": "https://footar.co/terms-of-use", "publisher_name": "FootAR S.A.", "support_website_url": null, "website_url": "https://footar.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_