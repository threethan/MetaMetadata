luscdn.com/v/t64.5771-25/38982469_553119359987658_7777146618886474293_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LnRxoKJ1t2YQ7kNvgEI7u1H&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBq_N0hx7aI0K2pM6REg9LQXP0JtKq1g5SVZgizkKB9XA&oe=674082F0"}, {"file_name": "2.png", "id": "753386496546494", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974589_753386499879827_5389378148722977105_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AyXdvft_qzkQ7kNvgFC0CGM&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCAg-XPnmqO6Hfn-vwGfdZOkU-ceJOTFIHVTLSXa2cteQ&oe=6740705E"}, {"file_name": "4.png", "id": "850648002610921", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974535_850648005944254_189578036774337945_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pOuiwSkXay0Q7kNvgG7EvYV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCbMpBQFv82ssIWV78LLgrhUHJ710gt_e3Yn930c0X9oA&oe=67406B0C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Archery", "keywords": [], "long_description": "Welcome to the most realistic archery simulation ever crafted. Archery Pro for Oculus brings the precision, discipline, and challenge of Olympic-style archery right into your living space.\n\nMimicking the exact physics and nuances of real-life archery, you'll feel the weight of the bow, the tension of the draw, and the thrill of releasing the arrow. Your Oculus controllers become more than just tools\u2014they become an extension of the archer in you.\n\nArchery Pro has single-player challenges as well as real-time multiplayer PVP. The game can be played casually or competitively. Challenge the world's best archers or just your friends. Full leaderboard and tournaments are available as well as live audio chat.\n\nWhether you're an aspiring Olympian, a seasoned archer, or a newcomer curious about the art of the bow and arrow, Archery Pro for Oculus delivers unparalleled realism. Feel the rush, the focus, and the passion of an Olympic athlete. Step onto the virtual range today and aim for gold!", "short_description": "Fulfill your Archery dreams on the Oculus Quest! Complete single-player challenges. Test your skills against online opponents in PVP mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.archerypro.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "SavySoda", "support_website_url": null, "website_url": "http://www.archerypro.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6636430659799184"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "304783116010993"}, {"status": "PUBLISHED", "id": "565823452304046"}, {"status": "PENDING", "id": "327400649853769"}]}, "baseline_offer": {"id": "565823452304046"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720533600, "status": "PUBLISHED", "id": "304783116010993"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8199173390191562", "version": "0.4.0"}, "id": "3247686158795931", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4441808439261428"