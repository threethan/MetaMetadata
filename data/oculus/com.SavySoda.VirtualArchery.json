9"}, {"file_name": "5.png", "id": "553119323320995", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982469_553119359987658_7777146618886474293_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tZuC4f2SLKIQ7kNvgEgiFPa&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABeSVeKkuHhs6eyb1DU3VbF&oh=00_AYCd9C2dkubcJN2AGhTES9GYJOGjD4K5j0lWhxXG2tep9Q&oe=66E6DCF0"}, {"file_name": "2.png", "id": "753386496546494", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974589_753386499879827_5389378148722977105_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C2q65fnFVjYQ7kNvgF2neuG&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABeSVeKkuHhs6eyb1DU3VbF&oh=00_AYDgCQ8QHG4EyloeYVUWWUgzFXqvZu4_JV0YlLYIx9npEA&oe=66E6CA5E"}, {"file_name": "4.png", "id": "850648002610921", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974535_850648005944254_189578036774337945_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RzwWJldZxrUQ7kNvgGjkOvk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABeSVeKkuHhs6eyb1DU3VbF&oh=00_AYDONlOGPNAIztui3mYBmvSLgUi2-jmHsQ2rQMa9E1CDXQ&oe=66E6C50C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Archery", "keywords": [], "long_description": "Welcome to the most realistic archery simulation ever crafted. Archery Pro for Oculus brings the precision, discipline, and challenge of Olympic-style archery right into your living space.\n\nMimicking the exact physics and nuances of real-life archery, you'll feel the weight of the bow, the tension of the draw, and the thrill of releasing the arrow. Your Oculus controllers become more than just tools\u2014they become an extension of the archer in you.\n\nArchery Pro has single-player challenges as well as real-time multiplayer PVP. The game can be played casually or competitively. Challenge the world's best archers or just your friends. Full leaderboard and tournaments are available as well as live audio chat.\n\nWhether you're an aspiring Olympian, a seasoned archer, or a newcomer curious about the art of the bow and arrow, Archery Pro for Oculus delivers unparalleled realism. Feel the rush, the focus, and the passion of an Olympic athlete. Step onto the virtual range today and aim for gold!", "short_description": "Fulfill your Archery dreams on the Oculus Quest! Complete single-player challenges. Test your skills against online opponents in PVP mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.archerypro.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "SavySoda", "support_website_url": null, "website_url": "http://www.archerypro.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6636430659799184"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "304783116010993"}, {"status": "PUBLISHED", "id": "565823452304046"}, {"status": "PENDING", "id": "327400649853769"}]}, "baseline_offer": {"id": "565823452304046"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720533600, "status": "PUBLISHED", "id": "304783116010993"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7874303412678563", "version": "0.3.2"}, "id": "3247686158795931", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "p