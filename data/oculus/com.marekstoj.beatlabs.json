ontent.oculuscdn.com&oh=00_AYAWjV0kHyJadYYmmnUqF1LWMGJY-BPXX0d-pKI0V5xcig&oe=66D466BC"}, {"file_name": "beat-labs-screenshot-010.png", "id": "1235025214531804", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569438_1235025217865137_1686040102715583454_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6LBomUxSl0Q7kNvgEm7bMi&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZL3rmseUQP0pOQOxNsyMY5qPvSbkS46Z7r1ZjoHQtNg&oe=66D446E5"}, {"file_name": "beat-labs-screenshot-020.png", "id": "3275810719394886", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299163_3275810722728219_730878446377497723_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wrLRnsCyfqMQ7kNvgG2b3Eq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtA6z4vGVqxO8t9_mMdwh-Mui-mRYVTTD15c_A39x15A&oe=66D45282"}, {"file_name": "beat-labs-screenshot-030.png", "id": "749951887210813", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974593_749951890544146_3078300154995647315_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0l0PUmf4FGcQ7kNvgHWcLu0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHvzNg4e0_1j15420WLVguUbF7bKMhaLmxCiO489Tkjw&oe=66D44B52"}, {"file_name": "beat-labs-screenshot-015.png", "id": "3789020674702234", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570301_3789020681368900_1650858440561341903_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=maNuqTjjdQ4Q7kNvgG4n8Dz&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8TEiVv0uRyVJS2HO1OGxII0y4DEJB4Uy0-y4cZ43HTQ&oe=66D440FA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video-cover.png", "id": "884824413657931", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982593_884824416991264_168865580567711985_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D8TTmf9-f34Q7kNvgEn0j3e&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3f04KrWC7LKdLehFMHlbxemFt_kquSbm_tG7jfLYpHg&oe=66D4531B"}, "display_name": "Beat Labs", "keywords": [], "long_description": "Beat Labs is an open, free-to-play and cross-platform **sandbox for rhythm games** in Virtual and Mixed Reality (VR/XR). It\u2019s powered by a database of over 100 000 community-made song beatmaps for Beat Saber.\n\nBeat Labs aims to become something more than Beat Saber though, by providing **a platform for immersive experiences** rather than being a single game. A platform for music and rhythm-based mini-games, powered by content created by us, **the community of players** and AI (Artificial Intelligence).\n\nOne of the biggest selling points of Beat Labs is the **sheer number and variety of songs** the players can choose from. There's tens of thousands of beatmaps (levels) created by Beat Saber community that we tap into.\n\nBeat Labs is **highly customizable** to cater to various players preferences. This includes the ability to choose the type of gameplay, an environment in which the game takes place, custom models of weapons and destructible objects and more.\n\nThe customizations described above are part of what makes Beat Labs an **extensible platform**. The content that the community creates may even introduce novel gameplay mechanics that we haven't yet thought of. This approach is similar to other, highly popular and profitable platforms, like Fortnite, Minecraft or Roblox.", "short_description": "Beat Labs is an open, free-to-play and cross-platform sandbox for rhythm games in Virtual and Mixed Reality (VR/XR). It\u2019s powered by a database of over 100 000 community-made song beatmaps for Beat Saber."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bodymindgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Body Mind Games", "support_website_url": null, "website_url": "https://www.bodymindgames.com/beat-labs", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "ha