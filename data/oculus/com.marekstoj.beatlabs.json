e": "beat-labs-screenshot-030.png", "id": "1891612021358338", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031491_1891612024691671_3361542872804179809_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MHcJNEtLJvkQ7kNvgEIFwfx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfWwSqpy_gR6C_4r4tmUUfz&oh=00_AYClz3txdUPdwYixAonsoSWQPKHIE_OgimRTRXpOH1Si_Q&oe=66EAB5AD"}, {"file_name": "beat-labs-screenshot-040.png", "id": "1559008461322014", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_1559008464655347_8431420671517256308_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qg5SB1fzaMgQ7kNvgFxofSf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfWwSqpy_gR6C_4r4tmUUfz&oh=00_AYBvYp3CX7_tfdSiY0fKq8sIKwHUxs_ICzUjHl5w-BQEzg&oe=66EAC6B9"}, {"file_name": "beat-labs-screenshot-050.png", "id": "1042195607425519", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001697_1042195610758852_106257527618127235_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7TCvJuuXFIcQ7kNvgHaGzjR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfWwSqpy_gR6C_4r4tmUUfz&oh=00_AYB8t-Ppvr3At8Kdj8lmhrGMFt0QfecbgdixhFPK-ZYDZg&oe=66EAB487"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video-cover.png", "id": "884824413657931", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982593_884824416991264_168865580567711985_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Oj1uuh_ep8EQ7kNvgF8_Cqm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfWwSqpy_gR6C_4r4tmUUfz&oh=00_AYDw_AvAnFZZL8OAdAstY_2f4Tk8xdZcd6I3XVO4wqQkew&oe=66EABC9B"}, "display_name": "Beat Labs", "keywords": ["beat", "saber", "rhythm", "fitness", "music"], "long_description": "Beat Labs is an open and cross-platform sandbox for rhythm games in Virtual and Mixed Reality (VR/XR). It\u2019s powered by a database of over 100 000 community-made song beatmaps.\n\nBeat Labs aims to provide **a platform for immersive experiences** rather than being a single game. A platform for music and rhythm-based mini-games, powered by content created by us, **the community of players** and AI (Artificial Intelligence).\n\nOne of the biggest selling points of Beat Labs is the **sheer number and variety of songs** the players can choose from. There's tens of thousands of beatmaps (levels) created by the community that we tap into.\n\nBeat Labs is **highly customizable** to cater to various players preferences. This includes the ability to choose the type of gameplay, an environment in which the game takes place, custom models of weapons and destructible objects and more.\n\nThe customizations described above are part of what makes Beat Labs an **extensible platform**. The content that the community creates may even introduce novel gameplay mechanics that we haven't yet thought of. This approach is similar to other, highly popular and profitable platforms, like Fortnite, Minecraft or Roblox.", "short_description": "Beat Labs is an open and cross-platform sandbox for rhythm games in Virtual and Mixed Reality (VR/XR). It\u2019s powered by a database of over 100 000 community-made song beatmaps."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bodymindgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Body Mind Games", "support_website_url": null, "website_url": "https://www.bodymindgames.com/beat-labs", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USE