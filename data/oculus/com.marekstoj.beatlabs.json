e=66EAAA7A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video-cover.png", "id": "884824413657931", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982593_884824416991264_168865580567711985_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Oj1uuh_ep8EQ7kNvgF8_Cqm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfWwSqpy_gR6C_4r4tmUUfz&oh=00_AYDw_AvAnFZZL8OAdAstY_2f4Tk8xdZcd6I3XVO4wqQkew&oe=66EABC9B"}, "display_name": "Beat Labs", "keywords": [], "long_description": "Beat Labs is an open, free-to-play and cross-platform **sandbox for rhythm games** in Virtual and Mixed Reality (VR/XR). It\u2019s powered by a database of over 100 000 community-made song beatmaps for Beat Saber.\n\nBeat Labs aims to become something more than Beat Saber though, by providing **a platform for immersive experiences** rather than being a single game. A platform for music and rhythm-based mini-games, powered by content created by us, **the community of players** and AI (Artificial Intelligence).\n\nOne of the biggest selling points of Beat Labs is the **sheer number and variety of songs** the players can choose from. There's tens of thousands of beatmaps (levels) created by Beat Saber community that we tap into.\n\nBeat Labs is **highly customizable** to cater to various players preferences. This includes the ability to choose the type of gameplay, an environment in which the game takes place, custom models of weapons and destructible objects and more.\n\nThe customizations described above are part of what makes Beat Labs an **extensible platform**. The content that the community creates may even introduce novel gameplay mechanics that we haven't yet thought of. This approach is similar to other, highly popular and profitable platforms, like Fortnite, Minecraft or Roblox.", "short_description": "Beat Labs is an open, free-to-play and cross-platform sandbox for rhythm games in Virtual and Mixed Reality (VR/XR). It\u2019s powered by a database of over 100 000 community-made song beatmaps for Beat Saber."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bodymindgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Body Mind Games", "support_website_url": null, "website_url": "https://www.bodymindgames.com/beat-labs", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7758623554158209"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1489710478311713"}]}, "baseline_offer": {"id": "1489710478311713"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1717689960, "status": "PUBLISHED", "id": "1489710478311713"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8151448861542341", "version": "0.44"}, "id": "446880161306991", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7758623540824877", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8151448861542341"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "446880161306991"}]}, "change_log": "Deadpool & Wolverine environment with claws and kat