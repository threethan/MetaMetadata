s!", "short_description": "Introducing Pixar Animation Studios\u2019 first VR experience with the visual - and storytelling - magic only Pixar could produce. You and your friends will explore the world of Disney\u2022Pixar's newest film, Coco, in this social VR experience."}]}, "developer_name": "Magnopus, Walt Disney Studios", "developer_privacy_policy_url": "http://www.disneymoviesvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.disneymoviesvr.com/cocovr/termsofuse", "publisher_name": "Walt Disney Studios", "support_website_url": null, "website_url": "http://www.disneymoviesvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EXPLORATION", "MOVIE", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_MX"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4889794377801101"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2371475156211254", "version": "1.0"}, "id": "125088748251493", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2098235286868577", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "2371475156211254"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", 