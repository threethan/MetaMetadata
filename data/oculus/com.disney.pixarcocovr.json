-ams2-1.oculuscdn.com/v/t64.5771-25/11162718_296743914149845_4296246371620487168_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q15iws5b694Q7kNvgFSpMZg&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB1rdaVivuvW4xdJXWsEG5ivdEJq9_Pq5SfoYilFL5SMg&oe=67864B1E"}, {"file_name": "migrated_image.png", "id": "247096786454689", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/11162682_132381304133910_8499134903143628800_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VEjVnG4ZvRUQ7kNvgFPu7tf&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBmqc8hdlNSCfxCaghyp0DE4VRnqXzu-ZiEkqd5f_BK7w&oe=678643A2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coco_video_7.png", "id": "138276410159384", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/11162696_138276413492717_1494748721810767872_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-UwDlc5EccYQ7kNvgFlGNhd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCuHC3c0OTupzQF5Dp19mTzfbB0bNFty3K-h5L95JFaMw&oe=678637AD"}, "display_name": "Coco VR", "keywords": ["Coco", "VR", "Disney", "Pixar", "Oculus"], "long_description": "Coco VR is Pixar\u2019s stunning debut into virtual reality: an adventure into the beautiful Disney-Pixar film, Coco, coming to theaters November 22.  \n\nFollow the magical alebrije into the luminous world of Coco filled with lovable characters and beautiful settings from the film.\n\nFEATURES\n* Meet Miguel, Ceci, and Hector in fascinating locations featured in the movie.\n* Express your uniqueness and rock a new style in Ceci\u2019s costume shop.\n* Take a gondola ride and see the gorgeous city from above.\n* Live a little in the spotlight!  You\u2019re the star alongside of Hector in a musical celebration of Dia de los Muertos!", "short_description": "Introducing Pixar Animation Studios\u2019 first VR experience with the visual - and storytelling - magic only Pixar could produce. You and your friends will explore the world of Disney\u2022Pixar's newest fil