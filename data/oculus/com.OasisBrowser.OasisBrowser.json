"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974756_801860528171751_51630421722202083_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cVGyS_2_dZQQ7kNvgHeC6nc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnIexKbWd184vMEiArH-bF2Et45MAUQ5K_DXGyYDHE-w&oe=67559416"}, "display_name": "Oasis Browser", "keywords": [], "long_description": "Oasis Browser is an application for creating your ideal virtual home. By freely placing browsers in your virtual home, it provides the ultimate browsing experience in your ideal space.\n\nBy using Oasis Browser, you can create your ideal virtual home for various uses.\n* Relaxation Space: Choose your favorite space within it for a rich relaxation experience.\n* Work or Study Efficiency: By placing multiple browsers, you can work in a multi-monitor-like environment.\n* Content Appreciation: Prepare your own theater room to watch movies, play browser games on the big screen, and achieve the best entertainment experience.\n* Interior: Browsers can be arranged like a display or a mural.\n\nFeature\n* Browser: Freely place browsers in your virtual home and explore the world of the internet.\n* Room: Choose the skydome and interior according to your preferences and purposes, and customize your ideal virtual space.\n* Hand Tracking: All operations are performed with hand tracking. All you need is to wear your HMD.\n\nPremium Plan\nBy purchasing the premium plan for $9.9, your use of the virtual home will expand dramatically.\nPremium Plan Features:\n* Multiple Rooms: Create multiple rooms, and switch freely according to your needs.\n* Unlimited Browsers: Open as many browsers as the performance of your device allows(up to 2 for the free plan).\n\nAt present, this application is currently in beta. If you have any feedback, please write a review.", "short_description": "Oasis Browser is an application for creating your ideal virtual home. By allowing you to freely placing browsers within your own virtual home, it provides the ultimate browsing experience in your ideal space."}]}, "developer_name": null, "developer_privacy_policy_url": "https://oasis-browser.com/terms-and-privacypolicy/", "developer_terms_of_service_url": "https://oasis-browser.com/terms-and-privacypolicy/", "publisher_name": "Oasis Browser", "support_website_url": null, "website_url": "https://oasis-browser.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "201040865655851"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "209326951966826"}]}, "baseline_offer": {"id": "209326951966826"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1685572878, "status": "PUBLISHED", "id": "209326951966826"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8626603524094876", "version": "0.7.0"}, "id": "3168409813459717", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6200509186704334", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8626603524094876"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3168409813459717"}]}, "change_log": null, "created_date": 1730511319, "id": "862660