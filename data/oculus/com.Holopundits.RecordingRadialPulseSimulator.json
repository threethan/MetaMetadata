com&_nc_gid=A4VnG6HfppPiXrb6IsLhpaw&oh=00_AYDFaMCAywuScXzftxxNbG8wr6tblL34JtLMtoTsvpTAkA&oe=66CF1918"}, {"file_name": "Recording Radial Pulse Simulator_SS_04.png", "id": "372835092152538", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569457_372835095485871_3124097249015020700_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JApTg6dV4SEQ7kNvgFOOFuP&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4VnG6HfppPiXrb6IsLhpaw&oh=00_AYCO0q5msXPXNICYyFCXzdEkeb3XthV9mtJbTeE8D-UOMg&oe=66CF1B13"}, {"file_name": "Recording Radial Pulse Simulator_SS_05.png", "id": "837151848339615", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931336_837151851672948_3791241212278429846_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T8S_ELkDbNIQ7kNvgF7Swbe&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4VnG6HfppPiXrb6IsLhpaw&oh=00_AYCX9Zwur4YaJp595dT1gDBinA1mWLNPGMlYM96V_gjZwQ&oe=66CF0E27"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "3812821238933502", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982527_3812821242266835_422188521434867194_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ep6AztA54VYQ7kNvgGQuvRw&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4VnG6HfppPiXrb6IsLhpaw&oh=00_AYBD_xfz6e5cCyliEiKnNxwO-nwjcGSN2pQwy76aJu5meg&oe=66CEF40C"}, "display_name": "Recording Radial Pulse Simulator", "keywords": [], "long_description": "This tutorial covers the essential steps for measuring and recording a patient's radial pulse. It includes preparation, locating the pulse, measurement, and documentation. By the end of this tutorial, learners will be able to: \n\nRemember the key steps in recording a radial pulse. \n- Understand the significance of pulse measurement in patient assessment. \n- Apply the correct techniques to ensure accurate pulse recording. \n- Analyze pulse data to detect any irregularities. \n- Evaluate their measurement accuracy and identify areas for improvement. \n- Create precise and thorough patient records based on their findings. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Develop proficiency in accurately recording a patient's radial pulse."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7883067155117351"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "364197709776577"}]}, "baseline_offer": {"id": "364197709776577"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721737160, "status": "PUBLISHED", "id": "364197709776577"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7922250784532321", "version": "1.2"}, "id": "1151833229365865", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7883067125117354", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7922250784532321"}, "release_