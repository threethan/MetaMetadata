7331903502", "locale": "en_US", "screenshots": [{"file_name": "Recording Radial Pulse Simulator_SS_New_01.png", "id": "1312810666293721", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035319_1312810669627054_6323577440254301814_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hEAokFu_bysQ7kNvgH3Fg82&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYClwOZ_EggExHE5N_jFSQoDBb33M8u-LjoKbT2aZWeH6w&oe=6777D23A"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_02.png", "id": "1242305080407013", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/428899349_1242305083740346_6056561133404869363_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ks4SMMjXKE8Q7kNvgEYef9i&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBMbKIjUbh1q5GFXKmSFnwcalijelK2_HswgaSyjFUfGg&oe=6777C8CA"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_03.png", "id": "1222275162169763", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035319_1222275165503096_4932591943436667212_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9C6mVOO3rMkQ7kNvgF_l1Nr&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCeuI3Vpsrj8589pSwBr4wL66WlXHOCgFYLrXuPPQZ1jw&oe=6777E367"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_04.png", "id": "1143987330623293", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982671_1143987333956626_7861259353627830623_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ChdTcl-juVkQ7kNvgEI82hK&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAeqf0s4PkDFla4tA83CWkzoHDOcOO00M2MVSYQm64Ylw&oe=6777E136"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_05.png", "id": "3448173155479451", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75481465_3448173158812784_1710637308707682967_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OGplEYip0T8Q7kNvgE93OQO&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBdTk00ox7gJ8qoaamW0iFV7MWH1atApdVj0Ptfw5T3oA&oe=6777DAE8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Recording Radial Pulse Simulator_SS_New_04.png", "id": "828904825934293", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982563_828904829267626_6877109133281116278_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=raY76gP7_pIQ7kNvgFR0XtU&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAc4DUhYMXeEHE8fnFdTKs1vvZ3Y2BG1Tn8zPhnYo5acg&oe=6777BFC5"}, "display_name": "Recording Radial Pulse Simulator", "keywords": [], "long_description": "This tutorial covers the essential steps for measuring and recording a patient's radial pulse. It includes preparation, locating the pulse, measurement, and documentation. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\nBy the end of this tutorial, learners will be able to: \n- Remember the key steps in recording a radial pulse. \n- Understand the significance of pulse measurement in patient assessment. \n- Apply the correct techniques to ensure accurate pulse recording. \n- Analyze pulse data to detect any irregularities. \n- Evaluate their measurement accuracy and identify areas for improvement. \n- Create precise and thorough patient records based on their findings. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Develop proficiency in accurately recording a patient's radial pulse with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8877640305660026"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974886_1286016192638967_4930232693907094561_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mjlXOqBUihYQ7kNvgF7sSHK&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBBCq3vaRlP_CNaMjPyZJENTW6nV5HI2truQqCnAv3YLA&oe=6777B857"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Recording Radial Pulse Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1721737160, "lastRevision": {"nodes": [{"id": "7883067175117349", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_l