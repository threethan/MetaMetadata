7331903502", "locale": "en_US", "screenshots": [{"file_name": "Recording Radial Pulse Simulator_SS_New_01.png", "id": "1312810666293721", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035319_1312810669627054_6323577440254301814_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5ATtv9gn4y0Q7kNvgGhaIGd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4J_DqDhpzNdGVjfygbbkWXKMuC_MP52A8JaQOxooE8g&oe=676FE93A"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_02.png", "id": "1242305080407013", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/428899349_1242305083740346_6056561133404869363_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJiEXL5NNHIQ7kNvgFtvqHl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDo6GTYSwglQSR_l2DleN32Qz01CvnS1uo2fbqj8y5tPA&oe=676FDFCA"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_03.png", "id": "1222275162169763", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035319_1222275165503096_4932591943436667212_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uubrTdLZwlAQ7kNvgG8CltU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZPpE1_t8FeBkIhazd4pjo6toTtCWWCiC4_tNFkup6nA&oe=676FFA67"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_04.png", "id": "1143987330623293", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982671_1143987333956626_7861259353627830623_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wbcy1vjwihMQ7kNvgE8pSB6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCynsfM1igjTyAmZMVvh4vjAhbz3uL0Rs8wwFgErhKAsA&oe=676FF836"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_05.png", "id": "3448173155479451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75481465_3448173158812784_1710637308707682967_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1LOUpIShqLYQ7kNvgFl_K2Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYClPhVe3ghruu1Uf619kiEsyZn_z7nVS2pN6a8UG02rsw&oe=676FF1E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Recording Radial Pulse Simulator_SS_New_04.png", "id": "828904825934293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982563_828904829267626_6877109133281116278_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wZNkcX_7kjcQ7kNvgENx8pB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCceeSjGsDcVtCAVa4JZ4qTlbqcQ0rcOc7aBU29yTs0Tg&oe=676FD6C5"}, "display_name": "Recording Radial Pulse Simulator", "keywords": [], "long_description": "This tutorial covers the essential steps for measuring and recording a patient's radial pulse. It includes preparation, locating the pulse, measurement, and documentation. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\nBy the end of this tutorial, learners will be able to: \n- Remember the key steps in recording a radial pulse. \n- Understand the significance of pulse measurement in patient assessment. \n- Apply the correct techniques to ensure accurate pulse recording. \n- Analyze pulse data to detect any irregularities. \n- Evaluate their measurement accuracy and identify areas for improvement. \n- Create precise and thorough patient records based on their findings. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Develop proficiency in accurately recording a patient's radial pulse with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8877640305660026"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974886_1286016192638967_4930232693907094561_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-FCBszbR2sMQ7kNvgEHCtEX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD08sWXTe21FmJmHY1VbSIWwkwGZIa_YBsUmluKkM9L9g&oe=676FCF57"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Recording Radial Pulse Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1721737160, "lastRevision": {"nodes": [{"id": "7883067175117349", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_l