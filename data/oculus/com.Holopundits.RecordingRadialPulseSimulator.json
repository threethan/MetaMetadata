?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UW0WIwMgtNoQ7kNvgGHKF2G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAI09Ai82Pc9SLd0emYIZccPqWcSPLw1uYUmbY0RdebWQ&oe=6766AEBA"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_02.png", "id": "1242305080407013", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/428899349_1242305083740346_6056561133404869363_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fp33Gc_2y98Q7kNvgH9GzoL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8yf19MiG0Z5UPTfhRIAPjy38cuul4lZJwdq-OgO-vbQ&oe=6766A54A"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_03.png", "id": "1222275162169763", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035319_1222275165503096_4932591943436667212_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N1CLn7iOWBEQ7kNvgFRJtcT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUboLUhO40wtLbvo5u_eUsxdCZZJG4iTWbNjy9auYHAA&oe=6766BFE7"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_04.png", "id": "1143987330623293", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982671_1143987333956626_7861259353627830623_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DUnkgG4PXG4Q7kNvgEG4X2O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDx33SPhDHPuborlPf3XbQ3LEnUenHUrL1PSoRDWI4zdQ&oe=6766BDB6"}, {"file_name": "Recording Radial Pulse Simulator_SS_New_05.png", "id": "3448173155479451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75481465_3448173158812784_1710637308707682967_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y6B-Q98qAS0Q7kNvgFtKdG4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvUCxdvDIaEOpAPS9DzYzzxzpv_PMn_gUqdEngJfM9Yg&oe=6766B768"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Recording Radial Pulse Simulator_SS_New_04.png", "id": "828904825934293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982563_828904829267626_6877109133281116278_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvN8S8V0GX0Q7kNvgFNZJ4r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC13hG2LgEyS43-lWS2KdWmlV9Week--sPN7OnkKKAcSQ&oe=67669C45"}, "display_name": "Recording Radial Pulse Simulator", "keywords": [], "long_description": "This tutorial covers the essential steps for measuring and recording a patient's radial pulse. It includes preparation, locating the pulse, measurement, and documentation. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\nBy the end of this tutorial, learners will be able to: \n- Remember the key steps in recording a radial pulse. \n- Understand the significance of pulse measurement in patient assessment. \n- Apply the correct techniques to ensure accurate pulse recording. \n- Analyze pulse data to detect any irregularities. \n- Evaluate their measurement accuracy and identify areas for improvement. \n- Create precise and thorough patient records based on their findings. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Develop proficiency in accurately recording a patient's radial pulse with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "http