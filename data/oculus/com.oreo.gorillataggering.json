n.com/v/t64.5771-25/75262745_493428730072455_7925485801200837535_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cULED_qoAB0Q7kNvgGzGK5o&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao0PFMGjRMWd9fUbMlRK2Ap&oh=00_AYAGKoFq5u_quNOE4W3wMHGgszAprSlg6_wPc4LTMO4Pwg&oe=66E953F0"}, {"file_name": "75294240_813224070635456_5457132011633613715_n.png", "id": "3801824810085817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75241695_3801824813419150_2505776974414065966_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tdgIa52KzhcQ7kNvgEbukGC&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao0PFMGjRMWd9fUbMlRK2Ap&oh=00_AYBkZI9z4ddgKeyL3HF2O0Kam349UIETPvqZu88K7YAcPQ&oe=66E97162"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Fast Gorillas 2", "keywords": [], "long_description": "\"Fast Gorillas 2\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity.\nThe objective of Fast Gorillas 2 is simple yet delightful: players use virtual reality tools to create beautiful, glowing art installations throughout the game world.\nThese installations can take the form of intricate patterns, flowing designs, or even abstract masterpieces\u2014all designed to evoke a sense of peace and serenity.", "short_description": "\"Fast Gorillas 2\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity.\nThe objective of Fast Gorillas 2 is simple yet delightful: players use virtual reality tools to create beautiful, glowing art installations throughout the game world."}]}, "developer_name": "oreo ", "developer_privacy_policy_url": "https://sites.google.com/view/fast-gorillas-2/privacy-polic