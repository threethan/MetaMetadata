CtXRG-jE5K6yBw&oe=6763F828"}, {"file_name": "Screen3.png", "id": "676134873887112", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75294245_676134877220445_4583056957830045429_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s_zonC7xTbkQ7kNvgEEf0BV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCSEApKCqbAQcf3o-o1Eu6JnHCs6Pr2tS-UlUekpgQsYg&oe=6763F4DA"}, {"file_name": "Screen4.png", "id": "695718848533854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75485574_695718855200520_1737588928327606534_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EY-B_5DQu5cQ7kNvgELSBW6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfKZP8Jn2uCwNk2cKVlIGzkoLlKBwYTjlW2-HMWLQ8dg&oe=6763EFE5"}, {"file_name": "Screen5.png", "id": "1157321061877632", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86840883_1157321065210965_6574959355805866250_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uhc40GknDEAQ7kNvgEFTb1c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9kaHyqJgK3ifMXSUbsoWNh7zZ3ejhhT5jElIUni3kIA&oe=676403E0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerImage.png", "id": "3242698369329072", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75530714_3242698372662405_5347729674535911183_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMiKhkooBaYQ7kNvgGWNFsM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAh8xRkfJg99do0J88cc8WnK3GBqVCkvkECT1D6IUKCvg&oe=6763EFE7"}, "display_name": "Bible Quest", "keywords": [], "long_description": "Welcome to Bible Quest, an immersive journey through different passages of the bible for believers and unbelievers alike. This game aims to put the users in virtual worlds according to biblical descriptions. The designed environments in this game are not meant to accurately replicate real life but instead a re-imaging of these locations and time to send the user to an unforgettable journey each time. \n\nThe game presents the user with the option to play the mini game in each environment which is a mini quiz on the passage being narrated. The user will have only one shot at the quiz and upon failing will need to restart the passage. \n\nAbout this game: The game will be updated often with more and more passages and added quiz game for the user's leisure and spiritual joy. Users can check monthly on this app for new updates or visit our website.", "short_description": "An immersive virtual journey to different biblical passages with added narration."}]}, "developer_name": "TRAINDZ LLC", "developer_privacy_policy_url": "https://www.traindz.com/biblequest", "developer_terms_of_service_url": null, "publisher_name": "TRAINDZ LLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "659211902279004"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404375_1752116878498648_5651937616097928577_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qKHArQpk3EEQ7kNvgHNilxf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbEnIJ1Ub_e6e_F0gHLhvSvrLKzKLDGK-Jvq7DWaQqQQ&oe=67642013"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bible Quest", "platform": "