d time to send the user to an unforgettable journey each time. \n\nThe game presents the user with the option to play the mini game in each environment which is a mini quiz on the passage being narrated. The user will have only one shot at the quiz and upon failing will need to restart the passage. \n\nAbout this game: The game will be updated often with more and more passages and added quiz game for the user's leisure and spiritual joy. Users can check monthly on this app for new updates or visit our website.", "short_description": "An immersive virtual journey to different biblical passages with added narration."}]}, "developer_name": "TRAINDZ LLC", "developer_privacy_policy_url": "https://www.traindz.com/biblequest", "developer_terms_of_service_url": null, "publisher_name": "TRAINDZ LLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "879473995923081"}, {"id": "687057922013375"}, {"id": "661880351198839"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "659211902279004"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404375_1752116878498648_5651937616097928577_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VH9tPJrEFUIQ7kNvgE67QF8&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_kZPE1WARdgMM41OuAbapt&oh=00_AYB9CjPDzFT6JDnK