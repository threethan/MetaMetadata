", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75294245_676134877220445_4583056957830045429_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zWCqkAJ6V5EQ7kNvgGE0W1q&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvtG_UQdvvleuffaOLZucbd0COXJR2Gi5ICfMCgnXvHA&oe=670A4EDA"}, {"file_name": "Screen4.png", "id": "695718848533854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75485574_695718855200520_1737588928327606534_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ukc7onS_2PIQ7kNvgHvjLFP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBqtiSXHcqFzEnB5MXPPwCfrXA_nJEu0KzoEO-pbv5f8w&oe=670A49E5"}, {"file_name": "Screen5.png", "id": "1157321061877632", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86840883_1157321065210965_6574959355805866250_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=njiHs1yPAeQQ7kNvgH-RQEv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAz9vwAUEG03pBkjMhiQtIYsdVvVuR5pdim773Gjpnycw&oe=670A5DE0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerImage.png", "id": "3242698369329072", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75530714_3242698372662405_5347729674535911183_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OUf4HlH9BnkQ7kNvgFHDSP_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBR8-tr2TrDE0TAY7gWtEFnSuX7-1jKigMrYCA5iD_S8A&oe=670A49E7"}, "display_name": "Bible Quest", "keywords": [], "long_description": "Welcome to Bible Quest, an immersive journey through different passages of the bible for believers and unbelievers alike. This game aims to put the users in virtual worlds according to biblical descriptions. The designed environments in this game are not meant to accurately replicate real life but instead a re-imaging of these locations and time to send the user to an unforgettable journey each time. \n\nThe game presents the user with the option to play the mini game in each environment which is a mini quiz on the passage being narrated. The user will have only one shot at the quiz and upon failing will need to restart the passage. \n\nAbout this game: The game will be updated often with more and more passages and added quiz game for the user's leisure and spiritual joy. Users can check monthly on this app for new updates or visit our website.", "short_description": "An immersive virtual journey to different biblical passages with added narration."}]}, "developer_name": "TRAINDZ LLC", "developer_privacy_policy_url": "https://www.traindz.com/biblequest", "developer_terms_of_service_url": null, "publisher_name": "TRAINDZ LLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "687057922013375"}, {"id": "661880351198839"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DOCUMENTARY_HISTORY", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "659211902279004"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404375_1752116878498648_5651937616097928577_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ac2sRCiASCwQ7kNvgFs0IJb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAXRtvtCSI6KY1HzwnAjV9NmsAH3whBnG7atYEq5nXv-g&oe=670A7A13"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bible Quest", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1669941496, "lastRevi