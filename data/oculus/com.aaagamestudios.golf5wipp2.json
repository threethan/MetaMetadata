, play and practice Golf on an astonishing VR environment. You can practice and compete, to improve your skills not only in the game but also in real life.", "short_description": "Now, during the COVID-19 crisis, we want to support the community and Golf will be FREE, including also 4 clubs and 25 Wipp fees to play all different game modes. When you have the chance to return to your Golf Club, you will feel the results!\n\nGolf 5 WIPP CHAMPIONSHIP 2020 is an amazing brand new way to learn, play and practice Golf on an astonishing VR environment. You can practice and compete, to improve your skills not only in the game but also in real life."}]}, "developer_name": "AAA Gamestudios S.L.", "developer_privacy_policy_url": "https://www.websitepolicies.com/policies/view/sl6SCWmg", "developer_terms_of_service_url": "https://www.websitepolicies.com/policies/view/sl6SCWmg", "publisher_name": "AAA Gamestudios S.L.", "support_website_url": "https://www.aaagamestudios.com/", "website_url": "https://www.aaagamestudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "SIMULATION", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "305815704940243"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974732_835530513620061_9009784185103056896_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jZkiWFzY8voQ7kNvgHYYmp2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAgEfkTpdJgcWvGwyIcj0sEZv7QXmIhsGW