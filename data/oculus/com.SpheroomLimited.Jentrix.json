c_gid=A4ry4M4bhKtwVs7mnNGTAIr&oh=00_AYD1QeyWgq1UjHyT-9hkefjaTzZWQ938jCjTmgvUeg7hug&oe=66DED275"}, {"file_name": "Jenga-32021-05-26_19-22-52-249 !!!.png", "id": "480056643301190", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_480056649967856_4545037340399736900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6xFVz_k-u7oQ7kNvgHaO0Rb&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4ry4M4bhKtwVs7mnNGTAIr&oh=00_AYB6feL_SuY7SdKWcBDUGvG8nydIMbXlkg4kiQ8ZNEa_fw&oe=66DED482"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5bbULkxncwMQ7kNvgFZigvN&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4ry4M4bhKtwVs7mnNGTAIr&oh=00_AYA--EKNP2IdpconjpN5imhP8csoXJ9FJVx7h-0ufD5K8w&oe=66DEC155"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_ur