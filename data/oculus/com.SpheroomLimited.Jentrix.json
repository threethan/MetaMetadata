_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LQMqTP-DCGoQ7kNvgFkP5ey&_nc_ht=scontent.oculuscdn.com&oh=00_AYDubvBRT1hBVEEOCqVof129JllWb0v8BvVPPdRcR8E7JA&oe=66D5920C"}]}, "id": "7234789306595617", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_0_2 png (1).png", "id": "1030641827479041", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031336_1030641830812374_3515232864079702152_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jr_S8qQJeckQ7kNvgEuRIzL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBo4de7BcowMvEsgdTjT8uhb8rNyjXnHorP3iZRsBqSzg&oe=66D5AF41"}, {"file_name": "Screenshot_1_2 png (2).png", "id": "415549079964849", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035466_415549083298182_1856910580083278562_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kOfVQT9ximEQ7kNvgETvqXI&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMh-B_k-uHA1_W2e7COc_tlpJfGfA6CxfJ1WyXho2nSw&oe=66D5B24D"}, {"file_name": "+gm3_3 png (1).png", "id": "3074445359459012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035390_3074445366125678_3578756512971502053_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jZk3mBfLHGAQ7kNvgEY61pG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCpVyqo0HrUYhiSwC9-9ynuLisoa4WpYJURe8y0R7VLjg&oe=66D59844"}, {"file_name": "+gm9_2 png.png", "id": "407956794139390", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_407956797472723_7419472238995283805_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=61YZpTYFe7gQ7kNvgFGpbfS&_nc_ht=scontent.oculuscdn.com&oh=00_AYD83W8tSR_n2WYvzGkY9hcNA4JUcvDfrGVIne7YOfUd6A&oe=66D593C3"}, {"file_name": "+gm1_2 png.png", "id": "317780649745224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_317780653078557_3166335117325876068_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZrM6Y7U51EsQ7kNvgEB-3NG&_nc_ht=scontent.oculuscdn.com&oh=00_AYBB09yKhifP1IzKoir0v6jTPhhJW9uMxvZfzBek32I-bQ&oe=66D59C06"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "1270232313403313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_1270232316736646_1899296244109522719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LbH0A4LQoPIQ7kNvgFlP8FC&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1Hpk_xhORj3wrpSOJs_I77wHqL5JoYbkPRMmSZikp-w&oe=66D5893B"}, "display_name": "Jentrix", "keywords": [], "long_description": "Meet Jentrix! It is inspired by the famous board game and combines the very best of Jenga, match-3 and Tetris. And it\u2019s all packed in Virtual Reality!  \n\nWe are pretty sure you know the classic Jenga, but what if instead of wooden blocks there would be colorful fruit cubes, the towers would grow every second, and crocodiles would try to bite your hands?\n\nJentrix mixes different sets of mechanics from everyone\u2019s favorite games. Jenga provides its well-known look of the tower and tests your physical and mental skills. Match-3 brings its popular 3-in-a-row portion, while Tetris vibes will put you to the edge while the tower grows. \n\nIt\u2019s Jenga you\u2019ve never seen before! \n\n\n", "short_description": "Jentrix is a board arcade VR game with a perfect mix of Jenga, Tetris and match-3 mechanics! Grab, move, collect fruit cubes, don\u2019t get your hands bitten by crocodiles, and remember: don\u2019t let the tower fall! \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spheroom.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://jentrix-vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_