_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LQMqTP-DCGoQ7kNvgGFwOUM&_nc_ht=scontent.oculuscdn.com&oh=00_AYA51c05EoLTUQtSEUACNKPz8EHU9R4g8q2b5R8wNt-yTg&oe=66D6E38C"}]}, "id": "7234789306595617", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_0_2 png (1).png", "id": "1030641827479041", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031336_1030641830812374_3515232864079702152_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jr_S8qQJeckQ7kNvgEEcZ8H&_nc_ht=scontent.oculuscdn.com&oh=00_AYCGDhz4w-YbPXnx8iq4fdVHt9jiq709Mu75IERh-SM09g&oe=66D700C1"}, {"file_name": "Screenshot_1_2 png (2).png", "id": "415549079964849", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035466_415549083298182_1856910580083278562_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tvVFTHCnxZEQ7kNvgGd9osU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSLX2yAv9T4AgT-N795QA56yXwCrmwMGpwvVXxwE9fkQ&oe=66D703CD"}, {"file_name": "+gm3_3 png (1).png", "id": "3074445359459012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035390_3074445366125678_3578756512971502053_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iWaLrAnEeO8Q7kNvgED_1cA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrWG4aGZeCvhILCMVTkq6Ve0E5pyDAyHZ3eY_q5qWd3Q&oe=66D6E9C4"}, {"file_name": "+gm9_2 png.png", "id": "407956794139390", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_407956797472723_7419472238995283805_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=61YZpTYFe7gQ7kNvgHvjBLN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvzXXyrGKW11vyXMNYkfWXfqaO0LwqlXcDxj7FB0-5Cw&oe=66D6E543"}, {"file_name": "+gm1_2 png.png", "id": "317780649745224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_317780653078557_3166335117325876068_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nIakKEAqdo0Q7kNvgFNG5MS&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYwNv1HSXXW2damy-v_ccR_q-mj2gzyFNCBBqT7M5s5Q&oe=66D6ED86"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "1270232313403313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_1270232316736646_1899296244109522719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kl1n1__H0LEQ7kNvgFzeZ4z&_nc_ht=scontent.oculuscdn.com&oh=00_AYBM2lxCDdt1T2s2WZiyVa9Hj05tPhsoICtp8QHST2AgoA&oe=66D6DABB"}, "display_name": "Jentrix", "keywords": [], "long_description": "Meet Jentrix! It is inspired by the famous board game and combines the very best of Jenga, match-3 and Tetris. And it\u2019s all packed in Virtual Reality!  \n\nWe are pretty sure you know the classic Jenga, but what if instead of wooden blocks there would be colorful fruit cubes, the towers would grow every second, and crocodiles would try to bite your hands?\n\nJentrix mixes different sets of mechanics from everyone\u2019s favorite games. Jenga provides its well-known look of the tower and tests your physical and mental skills. Match-3 brings its popular 3-in-a-row portion, while Tetris vibes will put you to the edge while the tower grows. \n\nIt\u2019s Jenga you\u2019ve never seen before! \n\n\n", "short_description": "Jentrix is a board arcade VR game with a perfect mix of Jenga, Tetris and match-3 mechanics! Grab, move, collect fruit cubes, don\u2019t get your hands bitten by crocodiles, and remember: don\u2019t let the tower fall! \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spheroom.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://jentrix-vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_