40_Jentrix.png", "id": "248856327017571", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974909_248856333684237_9122574505715944637_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=269zd0lRDOMQ7kNvgFmY2w3&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYARtJ0cur8ogxyiIdpdVdyF4f7wWxMElg07pijlouQi_g&oe=66F5360C"}]}, "id": "7234789306595617", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_0_2 png (1).png", "id": "1030641827479041", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031336_1030641830812374_3515232864079702152_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1IdebZNhb-sQ7kNvgF_d1t0&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYBit3g6L8_zXJ452qi77PlF9wePnXSvLS912vh7htwQig&oe=66F55341"}, {"file_name": "Screenshot_1_2 png (2).png", "id": "415549079964849", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035466_415549083298182_1856910580083278562_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9mmn2Q9bypkQ7kNvgH6xaCB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYC26Jpov1a9g-lH6j-4HlozzxUtiJ1UxGYwaw_FTrQlhQ&oe=66F5564D"}, {"file_name": "+gm3_3 png (1).png", "id": "3074445359459012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035390_3074445366125678_3578756512971502053_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJtFkeKznucQ7kNvgFzUPCP&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYA0iSeCgabn8vM0GeMS1bJJRKmU-23DmuxEFVOakF-Vpg&oe=66F53C44"}, {"file_name": "+gm9_2 png.png", "id": "407956794139390", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_407956797472723_7419472238995283805_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LokvZ2F3TqoQ7kNvgHbdvoC&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYB0m29H9vORjlP-uokN3YJhnKP3JXzLPjcbbytfTDaxIQ&oe=66F537C3"}, {"file_name": "+gm1_2 png.png", "id": "317780649745224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_317780653078557_3166335117325876068_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cy0Ycl-YL7gQ7kNvgHhlJnC&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYChzEGwLoBerUI_4SCG2A0IU08WPTSmHk2ZEZnyVbhkoQ&oe=66F54006"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "1270232313403313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_1270232316736646_1899296244109522719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uF6pR3Khl_MQ7kNvgHvaBZn&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYBjSN15TK9Xl5be7cQtLXKFz-ae7agHFPXmasIwpQWMWg&oe=66F5657B"}, "display_name": "Jentrix", "keywords": [], "long_description": "Meet Jentrix! It is inspired by the famous board game and combines the very best of Jenga, match-3 and Tetris. And it\u2019s all packed in Virtual Reality!  \n\nWe are pretty sure you know the classic Jenga, but what if instead of wooden blocks there would be colorful fruit cubes, the towers would grow every second, and crocodiles would try to bite your hands?\n\nJentrix mixes different sets of mechanics from everyone\u2019s favorite games. Jenga provides its well-known look of the tower and tests your physical and mental skills. Match-3 brings its popular 3-in-a-row portion, while Tetris vibes will put you to the edge while the tower grows. \n\nIt\u2019s Jenga you\u2019ve never seen before! \n\n\n", "short_description": "Jentrix is a board arcade VR game with a perfect mix of Jenga, Tetris and match-3 mechanics! Grab, move, collect fruit cubes, don\u2019t get your hands bitten by crocodiles, and remember: don\u2019t let the tower fall! \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spheroom.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://jentrix-vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_t