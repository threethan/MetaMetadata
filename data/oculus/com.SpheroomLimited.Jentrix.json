uluscdn.com/v/t64.5771-25/38974591_340796314289339_3856514537879339752_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pH2ePvCiKEgQ7kNvgExuxFB&_nc_ht=scontent.oculuscdn.com&oh=00_AYANhYJnoGmHau04V_Kez-0Oo9GNGpNnlWtafRLoCztNWw&oe=66EEC0B8"}, {"file_name": "Jenga-32021-05-26_19-27-30-300 !!!.png", "id": "928918761278546", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974865_928918764611879_8657517853225842211_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABMjy2MGJ4IQ7kNvgFX2qj7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCQ1w2PHg-2zeChu-Wgt_1QPy0BJCjZhYxBXwpQrYNZgA&oe=66EE9221"}, {"file_name": "Jenga-32021-05-26_19-21-16-405 !!!.png", "id": "351439373265359", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_351439376598692_2615050184241726496_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jx3qrkFyWEsQ7kNvgEzs0s0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbzFF6ezRvr7xnVVWOBFmzfC267Z1PD16CsNbtAdjzHQ&oe=66EE9F28"}, {"file_name": "Jenga-32021-05-26_19-28-50-872 !!!.png", "id": "229929018517769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974573_229929021851102_7235332517207929736_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NU1oNoTYwXoQ7kNvgFi-XEI&_nc_ht=scontent.oculuscdn.com&oh=00_AYD-tGfhcdEHn-dIjINbvhGAmUoza74W0_4LTbMNQXhR7Q&oe=66EEA475"}, {"file_name": "Jenga-32021-05-26_19-22-52-249 !!!.png", "id": "480056643301190", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_480056649967856_4545037340399736900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lk2H5Q2p_GMQ7kNvgGu83iJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUZaxEMXAcecBP6BdSThzNs_EfT6r_fpF93gknAm7M7Q&oe=66EEA682"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ttjhTKUFoFMQ7kNvgHV3u5x&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCb4lann0XOkk_-dg8FgQPFHeFhrTPv4x6_NrgFTci9w&oe=66EE9355"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://arcadia-vr.com/en", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "639469383950546"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "bi