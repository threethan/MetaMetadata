ri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_1270232316736646_1899296244109522719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uuLhTR-KZn8Q7kNvgHk7f4I&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0KfeWNUKMIi3vJYBqGhb8syJ4a76q4IciLzGVOiWI7A&oe=66DC20BB"}, "display_name": "Jentrix", "keywords": [], "long_description": "Meet Jentrix! It is inspired by the famous board game and combines the very best of Jenga, match-3 and Tetris. And it\u2019s all packed in Virtual Reality!  \n\nWe are pretty sure you know the classic Jenga, but what if instead of wooden blocks there would be colorful fruit cubes, the towers would grow every second, and crocodiles would try to bite your hands?\n\nJentrix mixes different sets of mechanics from everyone\u2019s favorite games. Jenga provides its well-known look of the tower and tests your physical and mental skills. Match-3 brings its popular 3-in-a-row portion, while Tetris vibes will put you to the edge while the tower grows. \n\nIt\u2019s Jenga you\u2019ve never seen before! \n\n\n", "short_description": "Jentrix is a board arcade VR game with a perfect mix of Jenga, Tetris and match-3 mechanics! Grab, move, collect fruit cubes, don\u2019t get your hands bitten by crocodiles, and remember: don\u2019t let the tower fall! \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spheroom.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://jentrix-vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_