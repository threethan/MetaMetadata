Q7kNvgElLMFz&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYA2fyNNgzsh6SQb6ZCpjsTetYtZvfI0shibhoVybYm_BQ&oe=66F53BF5"}, {"file_name": "Jenga-32021-05-26_19-22-52-249 !!!.png", "id": "480056643301190", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_480056649967856_4545037340399736900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tEF1b3fi7n0Q7kNvgHpmRgN&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYCHHc1p9H2Hm1jI8r9EuEX9KgiiPdKp7CqMLf-JU6beCQ&oe=66F53E02"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9N3YNSO5ovcQ7kNvgHoZyKq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Afn88Nz_alXel0lQ3XHjAWy&oh=00_AYAqKpsebocoX7o2wWX41bz4-3YNvytcJqALKkgMLaOvnA&oe=66F56315"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMIT