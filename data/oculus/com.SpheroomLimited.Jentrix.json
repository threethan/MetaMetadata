00_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kU3eHhLqfXoQ7kNvgGNpIUd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAB8jo1VaoFChseGCTxJjdCmjUJxoyCxTftsGl3a3253g&oe=6718D682"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dD06eFvhWqQQ7kNvgGcQZou&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBiW7dh7EBgB9DELKqxOXbyPjQf3ZF_FK18XX5Jj5ZGbQ&oe=6718FB95"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://arcadia-vr.com/en", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": false, 