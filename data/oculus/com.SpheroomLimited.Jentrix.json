v/t64.5771-25/38974573_229929021851102_7235332517207929736_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h0PTtL1HMhQQ7kNvgGzt4FB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDnaHg4zbYvVSPfWQT0EzS4ui2NxxFOeH4aCfQ_egBUBg&oe=678640F5"}, {"file_name": "Jenga-32021-05-26_19-22-52-249 !!!.png", "id": "480056643301190", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974499_480056649967856_4545037340399736900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZudeVMtogO0Q7kNvgGncJxF&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDWO51XLShzZT9PThRsC3P4fqG3Hgmy9745JRhl72dW8A&oe=67864302"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-2hAFajjcicQ7kNvgEYbKEQ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBXgsqsrE1tUdfo_Sg8EijKZ39T6Wi5rwmK_hANH28ZvQ&oe=67866815"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-P