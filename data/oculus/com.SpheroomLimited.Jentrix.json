An10S0HCJF4Fbmppoqv60Rx&oh=00_AYC73mIh_MkOVfOWslbMySjT8Yw2YDLZHn8-bENdakCaSw&oe=66EC0175"}, {"file_name": "Jenga-32021-05-26_19-22-52-249 !!!.png", "id": "480056643301190", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_480056649967856_4545037340399736900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kX0iJIhDU9gQ7kNvgFnKTqr&_nc_ht=scontent.oculuscdn.com&_nc_gid=An10S0HCJF4Fbmppoqv60Rx&oh=00_AYAsLP3s2AmDqu2uBy9sOhjMddcj9kw0ayJFNFel8s0I8A&oe=66EC0382"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ttjhTKUFoFMQ7kNvgFi6suS&_nc_ht=scontent.oculuscdn.com&_nc_gid=An10S0HCJF4Fbmppoqv60Rx&oh=00_AYDDhYx9yX698C9NO4KfqYb8VcY6E8tdo76XKY_uJ5ZX7g&oe=66EC2895"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "h