40_Jentrix.png", "id": "248856327017571", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974909_248856333684237_9122574505715944637_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3PUO5kAimXsQ7kNvgGkbEzi&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYBxYjiI3ELe0n2771FP45A4tnIN3UDQ59iWIePMKCNuXg&oe=66EAAA0C"}]}, "id": "7234789306595617", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_0_2 png (1).png", "id": "1030641827479041", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031336_1030641830812374_3515232864079702152_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nvJJsJZ5rKAQ7kNvgG-PzWg&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYDaiSdXxMZ8gtxwVgjywyYoDIcoRylEMG60ej30_tPQzA&oe=66EAC741"}, {"file_name": "Screenshot_1_2 png (2).png", "id": "415549079964849", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035466_415549083298182_1856910580083278562_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jOnLnNwvU_EQ7kNvgEmYITt&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYBaTQVGeGWVUoB-dJaUdjhUW4luG6POCufxRTP8stfpcA&oe=66EACA4D"}, {"file_name": "+gm3_3 png (1).png", "id": "3074445359459012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035390_3074445366125678_3578756512971502053_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OO0jF1dPu6cQ7kNvgFGbi71&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYC4SiiA3IUxotERGWpdwwHxTNUERv84s_vYs4f4ZmaIkg&oe=66EAB044"}, {"file_name": "+gm9_2 png.png", "id": "407956794139390", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_407956797472723_7419472238995283805_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHwB9PdIpRYQ7kNvgHBH-ik&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYDzrXyoGy7wIKUpxJyK7wd_IbRuKikYZIrSbrMrthN7fw&oe=66EAABC3"}, {"file_name": "+gm1_2 png.png", "id": "317780649745224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_317780653078557_3166335117325876068_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gzyGH0ga7PAQ7kNvgEvMK6t&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYAdDCULZqGMKGXBgLws9cQNMCFoxD_lbRdfw3sQKvkvkQ&oe=66EAB406"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "1270232313403313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_1270232316736646_1899296244109522719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SPzEXIGMqiwQ7kNvgGWfRZv&_nc_ht=scontent.oculuscdn.com&_nc_gid=APU7XW0iqZEMVIjZishoi1U&oh=00_AYBVtEXfR9pneGIQLP9d__Zdz3eO1Osl4kH_YEIhilo-kg&oe=66EAA13B"}, "display_name": "Jentrix", "keywords": [], "long_description": "Meet Jentrix! It is inspired by the famous board game and combines the very best of Jenga, match-3 and Tetris. And it\u2019s all packed in Virtual Reality!  \n\nWe are pretty sure you know the classic Jenga, but what if instead of wooden blocks there would be colorful fruit cubes, the towers would grow every second, and crocodiles would try to bite your hands?\n\nJentrix mixes different sets of mechanics from everyone\u2019s favorite games. Jenga provides its well-known look of the tower and tests your physical and mental skills. Match-3 brings its popular 3-in-a-row portion, while Tetris vibes will put you to the edge while the tower grows. \n\nIt\u2019s Jenga you\u2019ve never seen before! \n\n\n", "short_description": "Jentrix is a board arcade VR game with a perfect mix of Jenga, Tetris and match-3 mechanics! Grab, move, collect fruit cubes, don\u2019t get your hands bitten by crocodiles, and remember: don\u2019t let the tower fall! \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spheroom.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "SPHEROOM LIMITED", "support_website_url": null, "website_url": "https://jentrix-vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_t