v/t64.5771-25/38974573_229929021851102_7235332517207929736_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h0PTtL1HMhQQ7kNvgEXki5H&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDd_ppthzIYS1rPUfM7KUHHlv_CxA0ioxFn71Is9PwR6Q&oe=67879275"}, {"file_name": "Jenga-32021-05-26_19-22-52-249 !!!.png", "id": "480056643301190", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974499_480056649967856_4545037340399736900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZudeVMtogO0Q7kNvgHWxJPg&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDo_5z5UpECa4CEXb7vWgP6X23B_99BxfN7isKggxnSFQ&oe=67879482"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_2560_1440_Jentrix.png", "id": "470414117374817", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974591_470414120708150_1454389544219201507_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-2hAFajjcicQ7kNvgHZ5KIq&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD_T5eM8rYmF2MHJ4ajHNb74kgXmUTk4Yd-IGUb_qvVJA&oe=6787B995"}, "display_name": "Jentrix", "keywords": [], "long_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics.\n\nIn Jentricks you have to travel across colorful locations and dismantle cube fruit towers just like in the classic Jenga. But everything is not so simple \u2013 the fruits fall down and form a high tower. Move the fruits, rearrange them, collect \"Three in a row\" and they will disappear!\n\nYour goal is to prevent the tower from growing to its limit or falling apart. Jentricks offers 6 levels of difficulty in each location, after passing which a passage to the next one opens.\n\nFalling fruits and fragile towers make Jentricks a unique and unforgettable VR adventure!", "short_description": "Jentricks is a Virtual Reality board game that combines the best of Jenga and Match 3 mechanics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadia-vr.com/pdf/Privacy-P