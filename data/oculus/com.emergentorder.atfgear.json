d3-2.oculuscdn.com/v/t64.5771-25/11162822_564878257031270_2143839424_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=52PWZNGfuHQQ7kNvgEPtVV3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAl0t1SAnpL1L8UOYD3UMAT75vJ3F28mANZ_U0YczRWnQ&oe=6709299C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "284509491931159", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12386359_284509495264492_691678239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P8CCZVPm_OoQ7kNvgEL9Znh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDRf3l8dt43Rg_7rN5UgEQgudvBu9qgiXnarl5EXYXoA&oe=6708F8F2"}, "display_name": "At the Fork VR", "keywords": ["animals", "farms", "video"], "long_description": "Download At the Fork VR and experience a unique 360-degree tour of the farms and enclosures featured in the critically-acclaimed documentary film AT THE FORK.\n\nChoose to tour the world of animal farming with filmmaker Lisa Versaci, or explore on your own and visit the farms and enclosures that chickens, pigs, and cows call home. \n\nAT THE FORK- In theaters July 2016. \n\nStarring: John Papola, Lisa Versaci, Dr. Temple Grandin, Wayne Pacelle - CEO Humane Society of the United States, Terry Branstad - Governor of Iowa, John Mackey - co-CEO and co-founder Whole Foods Market, Mark Bittman \u2013 author and former New York Times columnist.\n\nFilmmaker and omnivore John Papola, together with his vegetarian wife Lisa, offers up a timely, unbiased look at how farm animals are raised for our consumption.\n\nVisit www.AtTheForkFilm.com to learn more.", "short_description": "Experience animal farming in 360-degree virtual reality with At the Fork VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://emergentorder.com/", "developer_terms_of_service_url": "http://emergentorder.com/", "publisher_name": "Emergent Order", "support_website_url": null, "website_url": "http://attheforkfilm.com/app/", "category": "ENTERTAINMENT", "comfort_rating": "COM