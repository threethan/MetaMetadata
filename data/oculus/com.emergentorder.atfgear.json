order.com/", "developer_terms_of_service_url": "http://emergentorder.com/", "publisher_name": "Emergent Order", "support_website_url": null, "website_url": "http://attheforkfilm.com/app/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EXPLORATION", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "486427632951158"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386282_1770890926510966_700213528_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wf6i-QHPUzMQ7kNvgGWFXEx&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArK5djAO3lADd-SYu-2e5mQ&oh=00_AYB4C2P9JyZ_fB_t7mQqbnpJ02J1Q6UdL2fr8B8_hW1gxA&oe=66DC3E87"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "At the Fork VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1475650800, "lastRevision": {"nodes": [{"id": "940373056088455", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1100747383337483", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2669708136633101", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386282_1770890926510966_700213528_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e