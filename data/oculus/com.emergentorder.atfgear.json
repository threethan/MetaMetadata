777B2FA"}, {"file_name": "migrated_image.png", "id": "540649460180625", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/11162822_564878257031270_2143839424_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qz5mba0ux9wQ7kNvgEv1fHp&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCH_tbbKjSaPO0aaclxMau4oufCblXFuwMBWCajvS7BDQ&oe=6777E79C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "284509491931159", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/12386359_284509495264492_691678239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OrgNZuU28m0Q7kNvgH8OzB9&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBiUmiJNP-ka3YX3Pf1hbp2RfY7cyEu2EoY4v4FIoRR4g&oe=6777B6F2"}, "display_name": "At the Fork VR", "keywords": ["animals", "farms", "video"], "long_description": "Download At the Fork VR and experience a unique 360-degree tour of the farms and enclosures featured in the critically-acclaimed documentary film AT THE FORK.\n\nChoose to tour the world of animal farming with filmmaker Lisa Versaci, or explore on your own and visit the farms and enclosures that chickens, pigs, and cows call home. \n\nAT THE FORK- In theaters July 2016. \n\nStarring: John Papola, Lisa Versaci, Dr. Temple Grandin, Wayne Pacelle - CEO Humane Society of the United States, Terry Branstad - Governor of Iowa, John Mackey - co-CEO and co-founder Whole Foods Market, Mark Bittman \u2013 author and former New York Times columnist.\n\nFilmmaker and omnivore John Papola, together with his vegetarian wife Lisa, offers up a timely, unbiased look at how farm animals are raised for our consumption.\n\nVisit www.AtTheForkFilm.com to learn more.", "short_description": "Experience animal farming in 360-degree virtual reality with At the Fork VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://emergentorder.com/", "developer_terms_of_service_url": "http://emergentorder.com/", "publisher_name": "Emergent Order", "support_we