&_nc_sid=6e7a0a&_nc_ohc=4eTMGE0zr_IQ7kNvgEU2s6y&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBP-4DcdXi4JggwJIRyz9M1O9jrM3n2wknXhC4a7gCqoA&oe=670A4D14"}, {"file_name": "Screenshot_05.png", "id": "450618218032241", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974758_450618224698907_2586425522301018588_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=abmUtU_ailgQ7kNvgFzB0Dn&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQWoQx-cA2EeJqgAIAULCFexgBU0fxPWsWYpvAmW9LWQ&oe=670A452F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JumpWorldDemo_Cover_Landscape.png", "id": "829238639374154", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031648_829238642707487_3875648698900524646_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wkFbY4PyLzIQ7kNvgGEoMyJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFxtQQF-bncTd5Izf9PDoe8nAUKdT2t-8B72FA0vUmpA&oe=670A6700"}, "display_name": "Jump World Demo", "keywords": [], "long_description": "**RUN, JUMP, PUNCH & SMASH** your way through 40+ levels and dungeons in this retro-themed VR platformer & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover.\n\n**In this demo, play all 5 levels of World 1 including the Final Dungeon.**\n\n**How To Play:**\n\n  - Movement - Left & Right Thumbsticks\n  - Jump - A Button or Click Right Thumbstick\n  - Run - Click Left Thumbstick\n  - Ground Smash - While in Air (Press either Trigger)\n\n**Want to play the (Early Access) version?**\n\n**https://ninjaplayground.itch.io/jump-world**", "short_description": "RUN, JUMP, PUNCH & SMASH your way through 40+ levels and dungeons in this retro-themed VR platformer & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ninjaplayground.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "