 & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ninjaplayground.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Ludus Vision", "support_website_url": null, "website_url": "http://www.ninjaplayground.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8570288309699520"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86615253_1891030458058960_1864862734017159519_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FtC9UjEbeIkQ7kNvgGLfbVb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB_uHCQG7g7UchpsVK_nNZgV5SmO0PsekNuMrxc8uupjA&oe=67769057"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Jump World Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1727825280, "lastRevision": {"nodes": [{"id": "8543249625736722", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8543249592403392", "is_first_party": false, "enables_in_app_ads"