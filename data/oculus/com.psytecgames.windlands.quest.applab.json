.png", "id": "1090492288121647", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001679_1090492291454980_1699773610790998509_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MqXK6lCqXTkQ7kNvgGnhC2_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDxRzCGnbrBawCKa5cMCEdsRUblfq0emlMCRUy2oorigA&oe=6707D3C8"}, {"file_name": "Shot7.png", "id": "3199378776829446", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031606_3199378780162779_5060366934851430716_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3GDKpEV9a0Q7kNvgH_c54i&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBc1CBy-iII-QIZ9K7ZVpWGuWxLk-ZldPDG1ml9bL7SaQ&oe=6707C6C3"}, {"file_name": "Shot2.png", "id": "190886022820159", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031384_190886026153492_5602294892850524805_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VkI8juDqnMAQ7kNvgH3-WLt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-7W9Ged879BOL8TqLzEtfg8o2TpMk0eUg3vIlSyHd4Q&oe=6707D8D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560_1440_Oculus1.png", "id": "1138853546573929", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001717_1138853549907262_6485199567914041408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ANSvmeyE2pIQ7kNvgEOYLuL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1WrdRYDPBpfB0ZryEiKE2hDkfVsgUzK7DWDwy75ajHQ&oe=6707BCFB"}, "display_name": "Windlands", "keywords": [], "long_description": "A first-person grappling hook exploration game.\n\nSoar through the ruins of a fallen civilization and discover the secrets of the ancient world.\n\nIt appeals to those who want to explore the breathtaking vistas at a relaxing pace, while the challenging routes attract gamers who like to master the skill of soaring through the towering environments at top speed.\n\nGameplay Features\n\n* Designed and built for Virtual Reality First.\n* Grappling Hooks Focused Movement.\n* Variety of expansive levels that reward exploration.\n* Multiple routes provide a range of optional challenges.\n* Optional Skill based Speed Runs and Time Trials\n* Goal Driven Gameplay with Easy (Hook Anything), Normal and Hard Modes.", "short_description": "A first-person grappling hook exploration game. Soar through the ruins of a fallen civilization and discover the secrets of the ancient world."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.windlands.com/privacy", "developer_terms_of_service_url": "http://www.windlands.com/terms", "publisher_name": "Psytec Games Ltd", "support_website_url": "http://support.psytecgames.com/", "website_url": "http://www.windlands.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1032252467326287"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "977886560554603"}, {"status": "PUBLISHED", "id": "931814445296307"}, {"status": "PUBLISHED", "id": "1552018481796940"}, {"status": "CANCELLED", "id": "731508029195642"}, {"status": "PUBLISHED", "id": "1140175524013578"}, {"status": "PUBLISHED", "id": "1455619811686980"}, {"status": "PUBLISHED", "id": "938729270663910"}, {"status": "PUBLISHED", "id": "7232021290180196"}, {"status": "PUBLISHED", "id": "1117127149288636"}, {"status": "CANCELLED", "id": "826347152635179"}, {"status": "PUBLISHED", "id": "218383824627983"}]}, "baseline_offer": {"id": "938729270663910"}, "is_approved"