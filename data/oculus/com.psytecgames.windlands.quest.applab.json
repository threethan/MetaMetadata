\nGameplay Features\n\n* Designed and built for Virtual Reality First.\n* Grappling Hooks Focused Movement.\n* Variety of expansive levels that reward exploration.\n* Multiple routes provide a range of optional challenges.\n* Optional Skill based Speed Runs and Time Trials\n* Goal Driven Gameplay with Easy (Hook Anything), Normal and Hard Modes.", "short_description": "A first-person grappling hook exploration game. Soar through the ruins of a fallen civilization and discover the secrets of the ancient world."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.windlands.com/privacy", "developer_terms_of_service_url": "http://www.windlands.com/terms", "publisher_name": "Psytec Games Ltd", "support_website_url": "http://support.psytecgames.com/", "website_url": "http://www.windlands.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1032252467326287"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "977886560554603"}, {"status": "PUBLISHED", "id": "931814445296307"}, {"status": "PUBLISHED", "id": "1552018481796940"}, {"status": "CANCELLED", "id": "731508029195642"}, {"status": "PUBLISHED", "id": "1140175524013578"}, {"status": "PUBLISHED", "id": "1455619811686980"}, {"status": "PUBLISHED", "id": "938729270663910"}, {"status": "PUBLISHED", "id": "7232021290180196"}, {"status": "PUBLISHED", "id": "1117127149288636"}, {"status": "CANCELLED", "id": "82634715263