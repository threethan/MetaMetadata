&_nc_sid=6e7a0a&_nc_ohc=HSLzKEdg6LQQ7kNvgG2TmjC&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCi-XT9HFFv-TnoEQ7UGT93NE6qelWOUEb4B9o4odWXkA&oe=675EAFBB"}, {"file_name": "Shot7.png", "id": "202858265856017", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031616_202858269189350_5996826288572325252_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=igjQjoESBy4Q7kNvgGlwPCo&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAQ6azlcjfcKkvxtUO6cTYabroLBCN-cbcbvilGS1cV-w&oe=675EBF14"}, {"file_name": "Shot8.png", "id": "952950959039117", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982706_952950962372450_6385585660614713996_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YugBy_T7zP4Q7kNvgGRfvkZ&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCX0KAeyUxzTru8wwbmaroVy8GIg7Ui7VclOrLllk91fg&oe=675EBC01"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560_1440_Oculus1.png", "id": "1138853546573929", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39001717_1138853549907262_6485199567914041408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CkBU6ZKu6y8Q7kNvgEcf85G&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAWy0lOCrgcqulN1Ctj6p6k5QZWcSz9ZInWs9rLa_VRTw&oe=675EBFFB"}, "display_name": "Windlands", "keywords": ["grapple", "parkour", "swing", "hooks", "explore"], "long_description": "A first-person grappling hook exploration game.\n\nSoar through the ruins of a fallen civilization and discover the secrets of the ancient world.\n\nIt appeals to those who want to explore the breathtaking vistas at a relaxing pace, while the challenging routes attract gamers who like to master the skill of soaring through the towering environments at top speed.\n\n{423280110561253}\n\nGameplay Features\n\n* Designed and built for Virtual Reality First.\n* Grappling Hooks Focused Movement.\n* Variety of expansive levels that reward exploration.\n* Multiple routes provide a range of optional challenges.\n* Optional Skill based Speed Runs and Time Trials\n* Goal Driven Gameplay with Easy (Hook Anything), Normal and Hard Modes.\n\n{1506211596983092}", "short_description": "A first-person grappling hook exploration game. Soar through the ruins of a fallen civilization and discover the secrets of the ancient world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.psytecgames.com/privacy", "developer_terms_of_service_url": "https://www.psytecgames.com/terms/", "publisher_name": "Psytec Games Ltd", "support_website_url": "https://www.psytecgames.com/support", "website_url": "http://www.windlands.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9057720034259324"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75371511_911137843504188_919678588120103141_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3wHFPOBlMsAQ7kNvgG4bOHg&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYA2gqD2X1vVITyijZV6UmRbUttYfglHa-W_L4hhPPLTmw&oe=675EABAA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Windlands", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}], "release_dat