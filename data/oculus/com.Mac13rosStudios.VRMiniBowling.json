scontent.oculuscdn.com&_nc_gid=A2FHqjg-JKvANUhh_hkrrFY&oh=00_AYAENnG7CfyK6mEI-4L1MAn92K_rpChHi8BCHeVeMvr_Ag&oe=66E19510"}, {"file_name": "migrated_image.png", "id": "1058829561169535", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974540_1006289679517978_5227941115902033920_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hmLYHpdPZSMQ7kNvgGqJBRo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2FHqjg-JKvANUhh_hkrrFY&oh=00_AYBYuBGf6veTEUN5N2q6LZGWiDwhCPanT4gl_7W7jK3rRg&oe=66E174DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/i2ZxAs", "id": "1942050162769488", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974630_1942050166102821_87777359024881664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4IFLa1T8VHUQ7kNvgGZKLuq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2FHqjg-JKvANUhh_hkrrFY&oh=00_AYB5fXl6AfzHqj-8bZvG9syhKa0YABMHa2EZ87CKon-rDA&oe=66E186C4"}, "display_name": "VR Mini Bowling", "keywords": ["Bowling", "Golf", "Mini", "Sports", "VR"], "long_description": "Welcome to the world of Mini Bowling!  In this VR game bowling meets mini golf to create a totally new experience!\n\nKey Features:\n- 3 Scoring Modes\n- 3 courses with 10 unique lanes each\n- Traditional bowling lane with realistic physics (spin, oil patterns)!\n- Personal best statistics for each lane and scoring mode\n- Customizable sound effects\n- Customizable skin colors\n- Anti-gravity pins\n- Throw force multiplier\n\nStandard Mode:\nIn this game mode, normal bowling rules apply.  Try to get the highest score possible!\n\nStroke Play Mode:\nThis mode will put your skills to the test! The goal is to knock down all of the pins in as few throws as possible.\n\nRush Play Mode:\nSpeed is the key in this mode.  Knock down all of the pins as quickly as possible!  You get unlimited throws in this mode so fire away!\n\nTraditional Mode:\nFeel like changing it up and playing a regular game of bowling? You can! Put spin on the ball to curve it down the lane, and even change the oil 