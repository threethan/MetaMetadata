_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974520_2108497442794402_5140899081048031232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lXLYFRVKlAkQ7kNvgFJXE4T&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYCSyZhaBhVj6u3CbntnWnSGEGVeLIVR7p6lAqMg--JBrw&oe=66E6C049"}, {"file_name": "migrated_image.png", "id": "163101011440234", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974697_557422874723749_9104150401917124608_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KpoiKrATRFYQ7kNvgGPt-dN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYDq40XkvgmsH8ngWjbobqglF8uAfZQoZvPeMzYMURWZrQ&oe=66E6B988"}]}, "id": "855843161580985", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "2690610834493039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031495_1988275744600311_3639791960803246080_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E1JUgeSvYrcQ7kNvgGMwf_p&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYCX6fy1hJdxAw1CJFb3j2bGV3-C_AVGCovIcH6ilgGlaQ&oe=66E6D63B"}, {"file_name": "migrated_image.png", "id": "604215537102483", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974789_2188846638101021_7248977413424545792_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VTSNTDSC2n8Q7kNvgF0mjGM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYDx7Dj666yuQNn_zA2W1NQx71ZMOVgU6w6CEIpZnXmRiA&oe=66E6C723"}, {"file_name": "migrated_image.png", "id": "1499896166856585", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_352706941958280_5977639524413472768_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jSVyOsIDqbQQ7kNvgEkk8Kb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYBEWx4MO68FuH7Xw7KhoqPTDAZmjt2C9MzPPYgWfXcVoA&oe=66E6DD1D"}, {"file_name": "migrated_image.png", "id": "529130371347788", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982655_758654184498252_4588748805712642048_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MLljUkES78cQ7kNvgH_2Ywa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYAAkudgEJxId86CktEaXCYWVqycvHBZWZp-Sve-aq0m-w&oe=66E6DB10"}, {"file_name": "migrated_image.png", "id": "146428790027337", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974540_1006289679517978_5227941115902033920_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zMMfEu_DDx0Q7kNvgHlUMWG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZxkkiZ7EjNMvlGruu66BuB&oh=00_AYB23VDZMCg2nTLQcPcaTpZk7ACRh9q_m174BKpYioWpAw&oe=66E6BADC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Mini Bowling", "keywords": ["Bowling", "Golf", "Mini", "Sports", "VR"], "long_description": "Welcome to the world of Mini Bowling!  In this VR game bowling meets mini golf to create a totally new experience!\n\nKey Features:\n- 3 Scoring Modes\n- 3 courses with 10 unique lanes each\n- Traditional bowling lane with realistic physics (spin, oil patterns)!\n- 24 bowling balls to choose from (16 unlockable)\n- Customizable sound effects\n- Customizable pin colors\n- Anti-gravity pins\n- Throw force multiplier\n\nStandard Mode:\nIn this game mode, normal bowling rules apply.  Try to get the highest score possible!\n\nStroke Play Mode:\nThis mode will put your skills to the test! The goal is to knock down all of the pins in as few throws as possible.\n\nRush Play Mode:\nSpeed is the key in this mode.  Knock down all of the pins as quickly as possible!  You get unlimited throws in this mode so fire away!\n\nTraditional Mode:\nFeel like changing it up and playing a regular game of bowling? You can! Put spin on the ball to curve it down the lane, and even change the oil pattern on the lane!", "short_description": "Welcome to the world of Mini Bowling!  In this VR game bowling meets mini golf to create a totally new experience!"}]}, "developer_name": "Brian Macumber", "developer_privacy_policy_url": "https: