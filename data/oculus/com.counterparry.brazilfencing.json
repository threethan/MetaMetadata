702_2154022891650928_5406795738181765858_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DAQ6L2EIxSwQ7kNvgHSJb_y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTEJqQSKPbaxK4D-Ye9-fhXhUbuQjS5o89KveBeefxBQ&oe=676C0116"}, {"file_name": "ReleaseScreenshot5.png", "id": "1213561989637350", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974531_1213561992970683_1845508366569867310_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mYin2OSw1fsQ7kNvgHFjT-v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1lDOQj5sqcIH_KFPUp5K9tNTPY9hNJLeRHGSd7JY2yg&oe=676BD699"}, {"file_name": "ReleaseScreenshot6.png", "id": "3458630831095027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974740_3458630834428360_4621810464157570933_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OG9a-VqnCz8Q7kNvgGfppNM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDze5HKuNs3-aiC54PpXPlx9-mIxZ77tns4nMLR9UAEfg&oe=676BF6A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "900495181837608", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974816_900495185170941_9018293698527672932_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h7C2Y-mbdLQQ7kNvgFFIjKv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQF0ebiQcUcljgBz68iEg-lPKXubkYbKVNoFGRGBfoww&oe=676BFFCF"}, "display_name": "Brazil Fencing Club", "keywords": [], "long_description": "You were hoping to get in some foil fencing practice tonight. Unfortunately, your club is closed tonight...\n\nBut you have another option. You could fence with the Brazil Fencing Club, located in the exotic lands of Brazil. What? South America? No... This Brazil is located in the foil fencing capital of the world: Indiana.\n\nWelcome to Brazil Indiana's Fencing Club, We never close. We have fencers practicing at our club 24-hours a day and 365 days a year. Anyone anywhere can fence with this club. No long car trips necessary. This is because our club only exists in virtual reality! Hope you will join us at practice today.\n\nThe Brazil Fencing Club has nine hoosier foil fencers ready to challenge you. Test your fencing skill and see if it holds up against these wacky fencers. Use actual real world fencing skills (like beat attacks, disengages, parry ripostes and more) in a virtual reality game that closely simulates actual real world foil fencing.", "short_description": "The Brazil Fencing Club has nine hoosier foil fencers ready to challenge you. Test your fencing skill and see if it holds up against these wacky fencers. Use actual real world fencing skills in a virtual reality game that closely simulates actual real world foil fencing."}]}, "developer_name": null, "developer_privacy_policy_url": "http://brazilfencingclub.darkdire.com/#privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Counterparry", "support_website_url": null, "website_url": "http://brazilfencingclub.darkdire.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7806972622670406"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1473235066892526"}, {"status": "PUBLISHED", "id": "483765297639158"}]}, "baseline_offer": {"id": "1473235066892526"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723890920, "status": "PUBLISHED", "id": "1473235066892526"}]}, "liveChannel": {"nodes": [{"latest