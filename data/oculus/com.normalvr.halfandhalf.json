culuscdn.com/v/t64.5771-25/38982567_947921238877623_7393278208512098304_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yy2GSx6iC6IQ7kNvgE9YWkP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8j89IIx9a285xn5WyoMc4Egn8NJvtfCG7qIRvmQbTUg&oe=673DBF62"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Half + Half", "keywords": ["multiplayer", "locomotion", "voice", "chat", "chill"], "long_description": "Half + Half is a multiplayer game about fun & connection. The game includes five unique multiplayer spaces that are designed to help you connect with people you know, and also to connect with people you don\u2019t, even if only for a short while.\n\nSwim in the ocean. Glide through clouds. Play human tetris with friends, or Hide & Seek where hiders are two inches tall, and seekers are as tall as buildings.\n\nEvery space in Half + Half is designed to be fun, but also to make you look as ridiculous as possible in real life. Half + Half is made to be fun for you, but also fun for everyone in the same room.", "short_description": "Half + Half is a multiplayer game about fun & connection. Glide or Swim through open-ended spaces. Play human tetris with friends, or Hide & Seek where you\u2019re two inches tall."}]}, "developer_name": "Normal", "developer_privacy_policy_url": "https://nock.game/privacypolicy", "developer_terms_of_service_url": "https://normcore.io/legal/termsofservice", "publisher_name": "Normal", "support_website_url": "https://halfandhalf.fun/", "website_url": "https://halfandhalf.fun/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "EXPLORATION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null,