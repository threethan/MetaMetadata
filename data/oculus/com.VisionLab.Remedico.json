jwMtGLtua-8_taC6HHgQ&oe=6756DADB"}, {"file_name": "2.png", "id": "293856093003583", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974732_293856096336916_8147012357638648287_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AfgyBRe7L5cQ7kNvgGifGzP&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAcGgkbg-omNymGwIm4kDbx8BNgjdXJWUQTajzNnzy5qw&oe=6756D0A8"}, {"file_name": "1.png", "id": "890263038838997", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86627655_890263042172330_7777520844351752578_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PtAHhE86Q2gQ7kNvgGRlssj&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCRRVK_T-n8j29Y6UIzTO8aYK4l1m7N2W8PyFn_rdEjnA&oe=6756F2A2"}, {"file_name": "0.png", "id": "725793556094097", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974575_725793559427430_8275926473934160577_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MV_Dv5yudHsQ7kNvgHMQLkS&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB4mV7jcPNPLhAGlWn5XMCdm6lh8k-CEbW9Q2kFRjF4YA&oe=6756DEE6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art 16-9.png", "id": "726622369351307", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/43997718_726622372684640_2299835366958838159_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BUPvJ4rihPYQ7kNvgESjsvw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDHTNeOhslJcCaRdSolPULuh2Xy6jQJ383YLLQKCz8jvA&oe=6756E110"}, "display_name": "Dentaverse\u2122 by Remedico", "keywords": [], "long_description": "Dentaverse by Remedico integrates AR and VR technologies to facilitate immersive learning in dentistry. \n\nThe app is designed to assist students, dental professionals, and patients in understanding various dental conditions and treatment procedures. It provides virtual scenarios for common dental issues like cavities, tooth loss, root canals and other treatments, and methods for teeth or smile restoration.\n\nFeatures:\n- Interactive 3D model of a human jaw for exploring dental scenarios.\n- A range of standard teeth restoration scenarios is available to all users.\n- Integration with Remedico EMR software for personalized patient-specific scenarios, aiding in visualizing treatment options.\n- Dentaverse by Remedico aims to enhance dental education and patient engagement through its immersive and interactive virtual environment.", "short_description": "\"Dentaverse\u2122: Revolutionizing dentistry with a collaborative, data-driven VR Platform for clinics and students.\""}]}, "developer_name": "Remedico", "developer_privacy_policy_url": "https://remedico.app/terms-of-use/#appendix-a", "developer_terms_of_service_url": "https://remedico.app/terms-of-use/", "publisher_name": "Remedico", "support_website_url": "https://remedico.app/", "website_url": "https://remedico.app/#dentaverse", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6883085311804767"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1331522674422136"}]}, "baseline_offer": {"id": "1331522674422136"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709758380, "status": "PUBLISHED", "id": "1331522674422136"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8709680299145250", "version": "0.2.6"}, "i