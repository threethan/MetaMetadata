4850_2607465399642933_8436342643835854733_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4SvYflsJwzUQ7kNvgFqkIdD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC--M79l2Z_2pgWetyVg7TZH--uTpkEDj2JqI-u5MO65Q&oe=6752CA85"}, {"file_name": "3.png", "id": "1358318868470511", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221321_1358318871803844_3771128047448443236_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u4zmXWFkHTgQ7kNvgHLfeAB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQ_6MgQI_v3lx2x5fEBlp3X8Vy_3YGQsTHMOee84KO-Q&oe=6752CF74"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-06-13-12h06m23s327.png", "id": "3765160013743225", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031411_3765160017076558_252250190670567978_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=70373eyfMUEQ7kNvgE0lPCq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDWRfU8XOinho_Us5-U-6GQ2GutflukBvvvxjVlMXp2hw&oe=6752D05F"}, "display_name": "Dentaverse\u00ae by Remedico\u00ae", "keywords": [], "long_description": "Dentaverse by Remedico integrates AR and VR technologies to facilitate immersive learning in dentistry. \n\nThe app is designed to assist students, dental professionals, and patients in understanding various dental conditions and treatment procedures. It provides virtual scenarios for common dental issues like cavities, tooth loss, root canals and other treatments, and methods for teeth or smile restoration.\n\nFeatures:\n- Interactive 3D model of a human jaw for exploring dental scenarios.\n- A range of standard teeth restoration scenarios is available to all users.\n- Integration with Remedico EMR software for personalized patient-specific scenarios, aiding in visualizing treatment options.\n- Dentaverse by Remedico aims to enhance dental education and patient engagement through its immersive and interactive virtual environment.", "short_description": "Dentaverse offers a cutting-edge VR experience for dental clinics, enabling dentists to preview STL and OBJ models with patients in a shared virtual environment. This powerful tool enhances patient understanding of treatments through immersive 3D visualization. Ideal for innovative clinics and practitioners, it streamlines communication and elevates the standard of patient care."}]}, "developer_name": "Remedico", "developer_privacy_policy_url": "https://remedico.app/terms-of-use/#appendix-a", "developer_terms_of_service_url": "https://remedico.app/terms-of-use/", "publisher_name": "Remedico", "support_website_url": "https://remedico.app/", "website_url": "https://remedico.app/#dentaverse", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP", "MULTI_USER"], "id": "8705149092931704"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75272215_1596628877629980_7684927048397764472_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ctnhlsYtzoQ7kNvgFcT1A1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAhMGdr_-FGw1lTd_K08um9klxDRIY_qaKe0S6D5gn5pQ&oe=6752EBA9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dentaverse\u00ae by Remedico\u00ae", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_top