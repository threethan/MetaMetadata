ctive 3D model of a human jaw for exploring dental scenarios.\n- A range of standard teeth restoration scenarios is available to all users.\n- Integration with Remedico EMR software for personalized patient-specific scenarios, aiding in visualizing treatment options.\n- Dentaverse by Remedico aims to enhance dental education and patient engagement through its immersive and interactive virtual environment.", "short_description": "\"Dentaverse\u2122: Revolutionizing dentistry with a collaborative, data-driven VR Platform for clinics and students.\""}]}, "developer_name": "Remedico", "developer_privacy_policy_url": "https://remedico.app/terms-of-use/#appendix-a", "developer_terms_of_service_url": "https://remedico.app/terms-of-use/", "publisher_name": "Remedico", "support_website_url": "https://remedico.app/", "website_url": "https://remedico.app/#dentaverse", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6883085311804767"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1331522674422136"}]}, "baseline_offer": {"id": "1331522674422136"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709758380, "status": "PUBLISHED", "id": "1331522674422136"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8709680299145250", "v