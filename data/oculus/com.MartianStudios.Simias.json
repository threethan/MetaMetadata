0a&_nc_ohc=IkA8d4Of7t8Q7kNvgF_nsKx&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqBd7E35h6B7S4C5r6ZOlvs9OPrtzPko8P1HRaKGtcbg&oe=66E6CDDE"}, {"file_name": "ss 4 (1).png", "id": "296872926576387", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556799_296872929909720_2530382331299367251_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xCIRTHJPk5YQ7kNvgEwa7of&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3AuQdNeo4K9at2MFpydOWd-eQ7P84pRMdXMJGeCuOng&oe=66E6BC65"}, {"file_name": "ss 5 (1).png", "id": "734103245536069", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031436_734103248869402_2840764284079857548_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Er333Tck8wQ7kNvgGRUNKA&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_qyerrnv4YzhwstpUH_Y5CCOmw02in_PlZ2bWaAAeiA&oe=66E6C82B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnail (1).png", "id": "941361177369533", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982583_941361180702866_4912768721670633582_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AFgc74dJge8Q7kNvgGge3IR&_nc_ht=scontent.oculuscdn.com&oh=00_AYCr41xnxKAf_P0I3MG-tS7K4lJl0AuqrApb9eteluGTeQ&oe=66E6B2C0"}, "display_name": "Simias", "keywords": [], "long_description": "Navigate through the labyrinthine corridors, leaping, swinging, and scrambling across the vast network of rooms while avoiding lurking dangers and strange entities. Utilize your monkey's agility and Gorilla Tag-inspired movement to outmaneuver obstacles and outsmart any threats that stand in your way.\nAs you progress deeper into the Backrooms, menacing creatures that will test your wit and agility at every turn.\nCan you guide your monkey through the endless corridors of the Backrooms, evade the dangers that lurk within, and ultimately find your way back to the real world? It's time to embark on an unforgettable adventure filled with monkeying around and heart-pounding excitement in \"Simiasg\"!", "short_description": "In \"Simias\" players find themselves in a surreal and endless maze of interconnected rooms known as the Backrooms, filled with eerie lighting and mysterious ambiance. However, there's a twist - you're not alone! You control a mischievous monkey equipped with the locomotion mechanics of Gorilla Tag."}]}, "developer_name": "FLUG", "developer_privacy_policy_url": "https://www.termsfeed.com/live/97e20b00-0e31-4d6d-869c-50f3aac9a83b", "developer_terms_of_service_url": null, "publisher_name": "Martian Studios", "support_website_url": null, "website_url": "https://simias.my.canva.site/about", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7154476474605857"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1147216456690403"}]}, "baseline_offer": {"id": "1147216456690403"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711177200, "status": "PUBLISHED", "id": "1147216456690403"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7224586987594805", "version": "5"}, "id": "1111536739878743", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7154476471272524", "is_concept": false, "latest_released_binary": {"__ty