ver obstacles and outsmart any threats that stand in your way.\nAs you progress deeper into the Backrooms, menacing creatures that will test your wit and agility at every turn.\nCan you guide your monkey through the endless corridors of the Backrooms, evade the dangers that lurk within, and ultimately find your way back to the real world? It's time to embark on an unforgettable adventure filled with monkeying around and heart-pounding excitement in \"Simiasg\"!", "short_description": "In \"Simias\" players find themselves in a surreal and endless maze of interconnected rooms known as the Backrooms, filled with eerie lighting and mysterious ambiance. However, there's a twist - you're not alone! You control a mischievous monkey equipped with the locomotion mechanics of Gorilla Tag."}]}, "developer_name": "FLUG", "developer_privacy_policy_url": "https://www.termsfeed.com/live/97e20b00-0e31-4d6d-869c-50f3aac9a83b", "developer_terms_of_service_url": null, "publisher_name": "Martian Studios", "support_website_url": null, "website_url": "https://simias.my.canva.site/about", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7154476474605857"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1147216456690403"}]}, "baseline_offer": {"id": "1147216456690403"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711177200, "status": "PUBLISHED", "id