RaA&oe=66ED4A40"}, "display_name": "Simias", "keywords": [], "long_description": "Navigate through the labyrinthine corridors, leaping, swinging, and scrambling across the vast network of rooms while avoiding lurking dangers and strange entities. Utilize your monkey's agility and Gorilla Tag-inspired movement to outmaneuver obstacles and outsmart any threats that stand in your way.\nAs you progress deeper into the Backrooms, menacing creatures that will test your wit and agility at every turn.\nCan you guide your monkey through the endless corridors of the Backrooms, evade the dangers that lurk within, and ultimately find your way back to the real world? It's time to embark on an unforgettable adventure filled with monkeying around and heart-pounding excitement in \"Simiasg\"!", "short_description": "In \"Simias\" players find themselves in a surreal and endless maze of interconnected rooms known as the Backrooms, filled with eerie lighting and mysterious ambiance. However, there's a twist - you're not alone! You control a mischievous monkey equipped with the locomotion mechanics of Gorilla Tag."}]}, "developer_name": "FLUG", "developer_privacy_policy_url": "https://www.termsfeed.com/live/97e20b00-0e31-4d6d-869c-50f3aac9a83b", "developer_terms_of_service_url": null, "publisher_name": "Martian Studios", "support_website_url": null, "website_url": "https://simias.my.canva.site/about", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE