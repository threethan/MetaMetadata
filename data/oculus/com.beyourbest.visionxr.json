QqoPgn3DeJHtJNBByte&oh=00_AYCP6oH176QruzN5nUMJnvqhSIf-VJ70ZdrLzXnAP6DDGA&oe=66ED4735"}, {"file_name": "2021_8_26_14_18_19_537.png", "id": "301405778616276", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_301405781949609_347936537591304936_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qfN5eyIJ6s8Q7kNvgELq-ut&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABijQqoPgn3DeJHtJNBByte&oh=00_AYBVLlc4HMHKlFHcNzlDSKbsS2QS_dSxkkc70g1z5I65aw&oe=66ED448B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "byb_landscape_2560x1440.png", "id": "1648517615520174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210889_1648517618853507_2007437631331052425_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17g_XMNtm0QQ7kNvgFmZ1al&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABijQqoPgn3DeJHtJNBByte&oh=00_AYByT1Y9X30kmiNcQug9IEloV1bFCcPxYT8gafg3p3viGA&oe=66ED53ED"}, "display_name": "Be Your Best", "keywords": [], "long_description": "To gain an edge over your competition in football, it's essential to put in high-quality extra repetitions. Training that lets you replicate situations you meet on the field is key to maximizing your time and potential.\n\nWith Be Your Best, you can train perception & decision-making via real football match simulations, which is the same principle used for training airplane pilots, military personnel, and other high-performance professionals who need to react quickly and accurately to new information.", "short_description": "Build for professional footballers, Be Your Best provides a soccer training system based on real-world situations specially designed to improve the cognitive performance of players on and off the pitch. "}]}, "developer_name": "Be Your Best", "developer_privacy_policy_url": "https://www.beyourbest.com/privacy", "developer_terms_of_service_url": "https://www.beyourbest.com/terms", "publisher_name": "Be Your Best", "support_website_url": "https://www.beyourbest.com/contact", "website_url": "https://www.beyourbest.co