-roPVs9jgracpco9mAB&oh=00_AYDur8p2NaUsxK8-JJ6R7fEaOeVsWwTISSnTpkPlogmxpw&oe=66EBF5B5"}, {"file_name": "2021_8_26_14_18_19_537.png", "id": "301405778616276", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_301405781949609_347936537591304936_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qfN5eyIJ6s8Q7kNvgHli3X5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAt-roPVs9jgracpco9mAB&oh=00_AYDvr-MfVaxaJc4OT4LDzkjs7awhj6TcVrKnVq3rNtrNEA&oe=66EBF30B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "byb_landscape_2560x1440.png", "id": "1648517615520174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210889_1648517618853507_2007437631331052425_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17g_XMNtm0QQ7kNvgFVBM3_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAt-roPVs9jgracpco9mAB&oh=00_AYAOON-AqNGp0HbCI14sh62Ll5yxDTQrKVFuJWKWycxz-A&oe=66EC026D"}, "display_name": "Be Your Best", "keywords": [], "long_description": "To gain an edge over your competition in football, it's essential to put in high-quality extra repetitions. Training that lets you replicate situations you meet on the field is key to maximizing your time and potential.\n\nWith Be Your Best, you can train perception & decision-making via real football match simulations, which is the same principle used for training airplane pilots, military personnel, and other high-performance professionals who need to react quickly and accurately to new information.", "short_description": "Build for professional footballers, Be Your Best provides a soccer training system based on real-world situations specially designed to improve the cognitive performance of players on and off the pitch. "}]}, "developer_name": "Be Your Best", "developer_privacy_policy_url": "https://www.beyourbest.com/privacy", "developer_terms_of_service_url": "https://www.beyourbest.com/terms", "publisher_name": "Be Your Best", "support_website_url": "https://www.beyourbest.com/contact", "website_url": "https://www.beyourbest.co