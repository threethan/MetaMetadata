1-25/75540505_608629280748457_5412722113693250152_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vDYK-2qVUfAQ7kNvgGZSz8-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAt-roPVs9jgracpco9mAB&oh=00_AYCl3fHOu8eDnw06ahlv-O-XRic3kwudHyaH4095lbfFag&oe=66EC19E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "byb_landscape_2560x1440.png", "id": "1648517615520174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210889_1648517618853507_2007437631331052425_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17g_XMNtm0QQ7kNvgFVBM3_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAt-roPVs9jgracpco9mAB&oh=00_AYAOON-AqNGp0HbCI14sh62Ll5yxDTQrKVFuJWKWycxz-A&oe=66EC026D"}, "display_name": "Be Your Best", "keywords": [], "long_description": "With access to hundreds of moments from professional games, you take to the virtual pitch, putting yourself in the boots of one 11 aside player. Scan the pitch at the right moments, make the correct passing decisions, and react to regular awareness tests, as you work to improve your vision by replicating situations from real games.\n\nWhether you're looking to fit in more training hours from home, stay sharp when injured, or gain an advantage going into your next game, Be Your Best is designed for all players, both professional and amateur.\n\nBe Your Best is a professional training tool and not a game. Improving your performance takes consistent practice and dedication over time.", "short_description": "*Paid subscription is required\n\nSo you want to improve your vision and decision making on the pitch? Improve your off the ball movement and gain an edge over the competition? With Be Your Best, you can train perception & decision-making via real football match simulations."}]}, "developer_name": "Be Your Best", "developer_privacy_policy_url": "https://www.beyourbest.com/privacy", "developer_terms_of_service_url": "https://www.beyourbest.com/terms", "publisher_name": "Be Your Best", "support_website_url": "https://www.beyourbest.com/