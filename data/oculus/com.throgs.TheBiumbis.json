ailer": null, "video_trailer_thumbnail": null, "display_name": "The Biumbis", "keywords": ["family", "kids", "casual", "toon", "fun"], "long_description": "Story\n\nLong ago, in a very, very distant world. A race of little creatures, the Biumbis, lived in harmony with nature, spending their days playing in the woods.\n\nUnwittingly, while a group of young Biumbis were racing in the bark of one of the giant forest trees, the clumsiest of them hit against a branch making one of the enormous fruit fell down from the top and release a dark being that begin to contaminate their world.\n\nOverview\n\nThe Biumbis it's a fun and inmersive game where the player will control a Biumbi with his head and try to defeat all the enemies between him and the magical seeds at the end of each stage.\n\nGameplay\n\nHead movement controls character's flight.\nBeware of toxic drops and obstacles.\nShoot using Tap button on GearVR.", "short_description": "The Biumbis it's a fun and inmersive game where the player will control a Biumbi with his head and try to defeat all the enemies between him and the magical seeds at the end of each stage."}]}, "developer_name": "3OGS", "developer_privacy_policy_url": "http://www.3ogs.com.ar/", "developer_terms_of_service_url": "http://www.3ogs.com.ar/", "publisher_name": "3OGS", "support_website_url": null, "website_url": "http://www.3ogs.com.ar/sites/the-biumbis/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"],