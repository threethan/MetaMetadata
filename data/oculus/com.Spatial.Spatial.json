0827", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404372_2849646318597493_7750170330449046171_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HaLl5srEXHEQ7kNvgHLvI5O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB1--KmjhLD6_5AuiReE1NcpCbbsrEO6ckxSnHIyGhBAw&oe=6745C4A3"}, {"file_name": "image-4-PNG24.png", "id": "329465291535638", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476598_329465294868971_915099151972390857_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8G8mjqH9sXUQ7kNvgEynEgP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvzZKIDU5iFX8o0_Kpf5QM91DTyCbbxXONCIAW8ubz3g&oe=6745A453"}, {"file_name": "quest7-PNG24.png", "id": "349757816030660", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031308_349757819363993_6809272252006383934_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-R0fhKCbccQ7kNvgFwaJiP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdWwDk062rjon_DKRjuhmP4h2yt12rHXtUSNtpwIzpog&oe=6745A4C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "REVISED_2560x1440.png", "id": "637109270552510", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974447_637109273885843_2049905708003950599_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DAcSsqOof-MQ7kNvgH1jGtP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBswCJM_b65nBzJQNH3bu8UJfSXP6xpDWWM_9f_CPeCnA&oe=6745BD7E"}, "display_name": "Spatial", "keywords": ["Free", "Virtualdesktop", "Productivity", "Collaboration", "Meeting"], "long_description": "How work should be.\n\nSpatial brings people together for hangouts, immersive presentations, team planning, product reviews, & brainstorms.\n\nDuring a time when collaboration feels disconnected, unclear, and inefficient, Spatial enables you to - \n\nSIT NEXT TO EACH OTHER FROM ACROSS THE WORLD\n- Create your lifelike 3D avatar from a selfie in seconds\n- Your avatar talks, moves, and interacts, mirroring in-person collaborative sessions\n\nMAKE YOUR ROOM IS YOUR MONITOR, YOUR HANDS ARE YOUR MOUSE\n- Fill your room with information, defying the limits of your 2D screen\n- Enjoy beautiful immersive 3D environments \n- Express and share ideas w/ whiteboarding, notes, & photo/3D model search \n\nUSE ALL YOUR FAVORITE TOOLS\n- In-app browser + screen sharing\n- Seamlessly upload many 2D/3D file types \n- Integrate with Slack, Google Drive, and more\n\nJOIN FROM ANY DEVICE\n- VR + AR (Quest, Nreal, HoloLens, Magic Leap)\n- Mobile (iOS + Android) & Web", "short_description": "Spatial brings people together for hangouts, immersive presentations, team planning, product reviews, & brainstorms.\n\nAdd Spatial to your wishlist, and get notified when the app is released! \n\nSpatial enables you to:\n\n- Sit next to each other from across the world by creating a lifelike avatar from a selfie in seconds\n- Fill your room with  2D/3D content, including screen share, browser, sticky notes and whiteboarding\n- Integrate with tools like Slack or Google\n- Join from VR, AR, Web, & Mobile"}]}, "developer_name": "Spatial", "developer_privacy_policy_url": "https://spatial.io/privacy", "developer_terms_of_service_url": "https://spatial.io/terms/", "publisher_name": "Spatial", "support_website_url": "https://support.spatial.io/", "website_url": "https://spatial.io/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "SOCIAL", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": []