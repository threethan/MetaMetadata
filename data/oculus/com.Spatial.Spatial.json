0827", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75404372_2849646318597493_7750170330449046171_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HL0abigCVYcQ7kNvgEkRqLF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD1yGyRjFxXJD0yJwQSQUCSySWiv8BVqo-HonWqP2e__w&oe=67753AA3"}, {"file_name": "image-4-PNG24.png", "id": "329465291535638", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75476598_329465294868971_915099151972390857_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XjHfgnJJG28Q7kNvgGN3wjP&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDBTkJ0nvn_A1zO7dsFCtebStvtzrACKRjdqep_97xnFQ&oe=67751A53"}, {"file_name": "quest7-PNG24.png", "id": "349757816030660", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031308_349757819363993_6809272252006383934_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cLjDxlmLVC8Q7kNvgGcLWt-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA4nnkfH-RQ6Pykf0YMFyZ3gcMeP2cALesAUAbsSJdl6A&oe=67751AC5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "REVISED_2560x1440.png", "id": "637109270552510", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974447_637109273885843_2049905708003950599_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WShlkzuST2YQ7kNvgE3nd_k&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCkJ6dXboyuj_5UAcjiWDNPbJMAX-yZz0igaWZI9zbFug&oe=6775337E"}, "display_name": "Spatial", "keywords": ["Free", "Virtualdesktop", "Productivity", "Collaboration", "Meeting"], "long_description": "How work should be.\n\nSpatial brings people together for hangouts, immersive presentations, team planning, product reviews, & brainstorms.\n\nDuring a time when collaboration feels disconnected, unclear, and inefficient, Spatial enables you to - \n\nSIT NEXT TO EACH OTHER FROM ACROSS THE WORLD\n- Create your lifelike 3D avatar from a selfie in seconds\n- Your avatar talks, moves, and interacts, mirroring in-person collaborative sessions\n\nMAKE YOUR ROOM IS YOUR MONITOR, YOUR HANDS ARE YOUR MOUSE\n- Fill your room with information, defying the limits of your 2D screen\n- Enjoy beautiful immersive 3D environments \n- Express and share ideas w/ whiteboarding, notes, & photo/3D model search \n\nUSE ALL YOUR FAVORITE TOOLS\n- In-app browser + screen sharing\n- Seamlessly upload many 2D/3D file types \n- Integrate with Slack, Google Drive, and more\n\nJOIN FROM ANY DEVICE\n- VR + AR (Quest, Nreal, HoloLens, Magic Leap)\n- Mobile (iOS + Android) & Web", "short_description": "Spatial brings people together for hangouts, immersive presentations, team planning, product reviews, & brainstorms.\n\nAdd Spatial to your wishlist, and get notified when the app is released! \n\nSpatial enables you to:\n\n- Sit next to each other from across the world by creating a lifelike avatar from a selfie in seconds\n- Fill your room with  2D/3D content, including screen share, browser, sticky notes and whiteboarding\n- Integrate with tools like Slack or Google\n- Join from VR, AR, Web, & Mobile"}]}, "developer_name": "Spatial", "developer_privacy_policy_url": "https://spatial.io/privacy", "developer_terms_of_service_url": "https://spatial.io/terms/", "publisher_name": "Spatial", "support_website_url": "https://support.spatial.io/", "website_url": "https://spatial.io/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "SOCIAL", "UTILITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [],