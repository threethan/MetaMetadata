3356440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sBcCd4X9YnYQ7kNvgGo190Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTbX0tVn3wk0OPw1-eykkAtuHACDCTo8W9xZegsDy6MA&oe=66E57B20"}, {"file_name": "screenshot3.png", "id": "745478767179432", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334055_745478770512765_4130080974674156149_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MldKaXjkIVgQ7kNvgF1ow7d&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3EKMN-kGC01P3dAjvBvpZFmyY8rk23Bnf6sojUzSZJg&oe=66E55DF8"}, {"file_name": "screenshot5.png", "id": "1369658387220437", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982530_1369658390553770_8269861637153540105_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hrp-Ow16cVUQ7kNvgH-WR05&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrjQOYG95djet0dDkkl8VpH4YO5_6PMsM1spprG76eew&oe=66E57C1F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_2560.png", "id": "3192341571071620", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982615_3192341574404953_4886379686102680430_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0DKeifot9pMQ7kNvgFl1pjB&_nc_ht=scontent.oculuscdn.com&oh=00_AYC25511Uo0r58LRGyeEpD-aVj9XFU-nYaValWjSMS5kpQ&oe=66E58545"}, "display_name": "Mushroom Pin", "keywords": [], "long_description": "Mushroom Pin is a relaxing but challenging puzzle game. It's the first VR game I made by my own.\n\nThe gameplay is very simple, you just need to pick up the mushroom pins and put them in the correct sockets according to the rules of the level. But the puzzles of the levels are often very challenging, and you need to think carefully.\n\nFeatures:\n- 64 challenging levels of 8 puzzle types\n- Relaxing and casual playing atmosphere\n- Full hand tracking support\n- Passthrough mode support", "short_description": "Mushroom Pin is a relaxing but challenging puzzle game. It's the first VR game I made by my own.\n\nThe gameplay is very simple, you just need to pick up the mushroom pins and put them in the correct sockets according to the rules of the level. But the puzzles of the levels are often very challenging, and you need to think carefully.\n\nFeatures:\n- 64 challenging levels of 8 puzzle types\n- Relaxing and casual playing atmosphere\n- Full hand tracking support\n- Passthrough mode support"}]}, "developer_name": "Fish Chain Games", "developer_privacy_policy_url": "https://www.fishchaingames.com/mushroom-pin-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fish Chain Games", "support_website_url": null, "website_url": "https://www.fishchaingames.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "893497591936265"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196221_951717229175494_55430622116710856_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HiEbBzfQh1wQ7kNvgEnMQba&_nc_ht=scontent.oculuscdn.com&oh=00_AYCG1xEqpdoksN_HSnSWoecmQwTDKxDEZo1-7ejGp2NhKA&oe=66E58DF1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mushroom Pin", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release