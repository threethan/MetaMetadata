dn.com&oh=00_AYAHK_g4NDmMSZ_a0bYQraX1MmCTZ07JtTHdONSp5yoRCQ&oe=670A6D8C"}, {"file_name": "screenshot5.png", "id": "6344180715603637", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240096_6344180722270303_2280466348805839774_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Jm5L01Z3csQ7kNvgHSyE_A&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAoNBzFZR2a3i4T8RqlCNx6xbzy09B8Q-9ci3OB9RKs8Q&oe=670A5252"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u8611\u83c7\u9489", "keywords": [], "long_description": "\u8611\u83c7\u9489\u662f\u4e00\u6b3e\u8f7b\u677e\u4f46\u5177\u6709\u6311\u6218\u6027\u7684\u89e3\u8c1c\u6e38\u620f\u3002\u5b83\u662f\u6211\u72ec\u7acb\u5236\u4f5c\u7684\u7b2c\u4e00\u6b3eVR\u6e38\u620f\u3002\n\n\u6e38\u620f\u7684\u73a9\u6cd5\u975e\u5e38\u7b80\u5355\uff0c\u53ea\u9700\u8981\u62ff\u8d77\u8611\u83c7\u9489\uff0c\u6839\u636e\u5173\u5361\u7684\u89c4\u5219\uff0c\u653e\u5728\u6b63\u786e\u7684\u63d2\u5b54\u4e2d\u5373\u53ef\u3002\u4f46\u662f\u5173\u5361\u7684\u8c1c\u9898\u5f80\u5f80\u5f88\u6709\u6311\u6218\u6027\uff0c\u9700\u8981\u9759\u4e0b\u5fc3\u6765\u601d\u8003\u3002\n\n\u7279\u8272\uff1a\n- 8\u79cd\u7c7b\u578b\u517164\u4e2a\u5bcc\u6709\u6311\u6218\u6027\u7684\u5173\u5361\n- \u8f7b\u677e\u4f11\u95f2\u7684\u6e38\u73a9\u6c1b\u56f4\n- \u5b8c\u6574\u7684\u624b\u90e8\u8ffd\u8e2a\u64cd\u4f5c\n- \u652f\u6301\u5207\u6362\u900f\u89c6\u6a21\u5f0f", "short_description": "\u8611\u83c7\u9489\u662f\u4e00\u6b3e\u8f7b\u677e\u4f46\u5177\u6709\u6311\u6218\u6027\u7684\u89e3\u8c1c\u6e38\u620f\u3002\u5b83\u662f\u6211\u72ec\u7acb\u5236\u4f5c\u7684\u7b2c\u4e00\u6b3eVR\u6e38\u620f\u3002\n\n\u6e38\u620f\u7684\u73a9\u6cd5\u975e\u5e38\u7b80\u5355\uff0c\u53ea\u9700\u8981\u62ff\u8d77\u8611\u83c7\u9489\uff0c\u6839\u636e\u5173\u5361\u7684\u89c4\u5219\uff0c\u653e\u5728\u6b63\u786e\u7684\u63d2\u5b54\u4e2d\u5373\u53ef\u3002\u4f46\u662f\u5173\u5361\u7684\u8c1c\u9898\u5f80\u5f80\u5f88\u6709\u6311\u6218\u6027\uff0c\u9700\u8981\u9759\u4e0b\u5fc3\u6765\u601d\u8003\u3002\n\n\u7075\u611f\u6765\u81ea\u4e8e\u6211\u513f\u5b50\u7684\u4e00\u6b3e\u73a9\u5177\uff0c\u540d\u5b57\u5c31\u53eb\u8611\u83c7\u9489\u3002\u5728\u4e00\u5757\u5c0f\u5c0f\u7684\u6728\u677f\u4e0a\uff0c\u6839\u636e\u5361\u7247\u56fe\u6848\uff0c\u63d2\u5165\u4e00\u4e9b\u53ef\u7231\u7684\u8611\u83c7\u9489\uff0c\u7b80\u5355\u53c8\u6709\u8da3\uff0c\u6211\u975e\u5e38\u559c\u6b22\u3002\n\n\u7279\u8272\uff1a\n- 8\u79cd\u7c7b\u578b\u517164\u4e2a\u5bcc\u6709\u6311\u6218\u6027\u7684\u5173\u5361\n- \u8f7b\u677e\u4f11\u95f2\u7684\u6e38\u73a9\u6c1b\u56f4\n- \u5b8c\u6574\u7684\u624b\u90e8\u8ffd\u8e2a\u64cd\u4f5c\n- \u652f\u6301\u5207\u6362\u900f\u89c6\u6a21\u5f0f"}, {"images": {"nodes": [{"file_name": "Mushroom_Title_512.png", "id": "1888248971520471", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974882_1888248974853804_9198063522672682120_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QGWO--mnbq0Q7kNvgGq3ZmO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDix-JTpCTl_koRc8z4ERxh4WCUckgRQJovb7tyH8340Q&oe=670A6847"}, {"file_name": "Hero Cover 3000_900.png", "id": "1225414884767025", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982607_1225414888100358_648412328182447220_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Abazbb-S0-YQ7kNvgHcuFwz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUm5oY9m9sJyL6fdqpeuZvupi5o32v3-dkmFXm4_TSBw&oe=670A7A36"}, {"file_name": "Square 1440_1440.png", "id": "951717225842161", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196221_951717229175494_55430622116710856_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gxxSn_6Gd-wQ7kNvgGKhgtr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3gvIOW5VjF5-GAg4rD1xbxTT83eqkJSdf-i5ibMiRpg&oe=670A77F1"}, {"file_name": "Portrait 1008_1440.png", "id": "558792842889327", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75