CBUzv9qALvyT-hhX-H30vJoJTm_tUndM8yjdngEVQ&oe=6750348C"}]}, "id": "345012587471050", "locale": "en_US", "screenshots": [{"file_name": "Claw_Jump.png", "id": "643126803683256", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982532_643126807016589_3506943865281698401_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpm3n91V7HwQ7kNvgEy1wbH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBEZDAmujMc2D--QbMndc5ThhCQmRI2iTXqU461XHuzyw&oe=67505704"}, {"file_name": "Overview.png", "id": "393096889170914", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031355_393096892504247_7361868852065376136_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-JCVvsx2fr8Q7kNvgEMdp51&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB898qnoJHd51XxjCqclSgtZoGG37bXWO604MWJ6tF30Q&oe=675058ED"}, {"file_name": "Flying_NPC.png", "id": "677536776772662", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_677536780105995_8276486090699885808_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ntG3Qp9jQrUQ7kNvgGM3VoR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBPoeDxjHNz74ATczigTD1XI2x5Qn_lB1HdI9tc2-ir1g&oe=67502C45"}, {"file_name": "Claw_Ring.png", "id": "677409200346071", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031308_677409203679404_8062215116938574621_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QqLTO6SD_iIQ7kNvgGGCZdT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-CtFPdgdv6CBigpeFf-GBbbCKbGppRvJaHjBKO0Qjog&oe=67504FAA"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2A8B0nc90joQ7kNvgEpe4Bi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBvHVPDmh6m3QRLAQZSocdduR1GbIDBYod7-S2vJDYeXQ&oe=675027DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LsvPXnSnAuQQ7kNvgHQAmE6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBiRkH2s94j_gtkrzud1m9tMPcwlCRkyZUgEbUiSeMt_w&oe=67502A52"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nomorerainbows.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Squido Studio", "support_website_url": "http://discord.squidostudio.com/", "website_url": "https://nomorerainbows.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres