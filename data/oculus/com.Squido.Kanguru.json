6a1dGpacior8fEo4xvIBVtWQ3jDWo27N43zALAhrg&oe=6722100C"}]}, "id": "345012587471050", "locale": "en_US", "screenshots": [{"file_name": "Claw_Jump.png", "id": "643126803683256", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982532_643126807016589_3506943865281698401_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tOvIL9Xj4HoQ7kNvgFVq--3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlf1vEDzF0BUxwrepNF3yhNjJaGttSQf8d8uqESpT9bg&oe=67223284"}, {"file_name": "Overview.png", "id": "393096889170914", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031355_393096892504247_7361868852065376136_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j29A47hfP_8Q7kNvgH3RHx3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBr_1OcOaHj9PwEAtK5k7K_E8H3KBzH06rOA0T19RBapg&oe=6722346D"}, {"file_name": "Flying_NPC.png", "id": "677536776772662", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_677536780105995_8276486090699885808_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8T2EuEXPvokQ7kNvgGzcIF1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDab8eeHG-OqUC_S9-K3RVeW0P6NM7docvW2W5qc-dHzQ&oe=672207C5"}, {"file_name": "Claw_Ring.png", "id": "677409200346071", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031308_677409203679404_8062215116938574621_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uTI7Cm_4LQgQ7kNvgE8_qKh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNYfciycGsbGgBl9aqkyjarhmwB5OP75d6wt81QEK76g&oe=67222B2A"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Pbodo2bPOoQ7kNvgGJDyGV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5bYm-dEogHeCK3zq4yEEHQcULR_XqIrLdDfsBVqr8hg&oe=6722035A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZAhEwyyUumYQ7kNvgGw-Ebf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfmRDByBmy1Zm4iqyMiUUtzkDMNrlvFU52uscJfeiC6A&oe=672205D2"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nomorerainbows.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Squido Studio", "support_website_url": "http://discord.squidostudio.com/", "website_url": "https://nomorerainbows.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres