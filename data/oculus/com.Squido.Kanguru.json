R6_mdbjzDyHc4_TEwF5G-pFBHihnEwjUM1xEDeSyw&oe=675C120C"}]}, "id": "345012587471050", "locale": "en_US", "screenshots": [{"file_name": "Claw_Jump.png", "id": "643126803683256", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982532_643126807016589_3506943865281698401_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vx-oG6ML-NQQ7kNvgFb7m2x&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwhRZljVUVogLL5DUdlI8M814qGhXKr8Cp_1Tj6aYscA&oe=675C3484"}, {"file_name": "Overview.png", "id": "393096889170914", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031355_393096892504247_7361868852065376136_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hzcENWeX6GwQ7kNvgExvlIo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcv7mxRtalMqhUzBXP5ctToaPA_TY-BVLTIut1Qa7V1g&oe=675C366D"}, {"file_name": "Flying_NPC.png", "id": "677536776772662", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_677536780105995_8276486090699885808_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iNBuUplLhPkQ7kNvgHLkEHE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRHzFKkBrI6bO3_PlBaCO9qLK0Xvr_fck-F5Sf1IWp3A&oe=675C09C5"}, {"file_name": "Claw_Ring.png", "id": "677409200346071", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031308_677409203679404_8062215116938574621_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwZa_x9Me4sQ7kNvgGdnyIp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6R3-ySGtv1-oYaXL4YzawCWrJePJxv7ewVxmA1qwIFA&oe=675C2D2A"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4oZBYwtLVikQ7kNvgE3VM2z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkQPLcQJJNZ9Xl1EjK8yM9DzfC4dfbNkAU_rUhJ3m7ww&oe=675C055A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=idAU-SOlfpIQ7kNvgE88Rhr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMJZ733WMqRymgUb6x7uZKzzibb6XdVyDCRXU_Bdg-AQ&oe=675C07D2"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nomorerainbows.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Squido Studio", "support_website_url": "http://discord.squidostudio.com/", "website_url": "https://nomorerainbows.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres