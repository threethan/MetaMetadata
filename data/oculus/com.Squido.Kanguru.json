K4L4sE5e_M&oh=00_AYDOQ0VufEhHJIOQ5FPZ1XWOTbTMC4FG5y270jzbn0JhUQ&oe=66D9A8AA"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l6-AhRAL4DgQ7kNvgHBRhu6&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADpVTnzypyLp5K4L4sE5e_M&oh=00_AYCXVTpWMLMFkhIVKWAhVNMoNCaG_FF4GK-LJDh5FRpbFg&oe=66D980DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cwYJLY-MwBgQ7kNvgFKHNeu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADpVTnzypyLp5K4L4sE5e_M&oh=00_AYDQGq6OYqCXZn2EIvXzq5dWVFmcrYVA85Ru_Ie6ICCveg&oe=66D98352"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nomorerainbows.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Squido Studio", "support_website_url": "http://discord.squidostudio.com/", "website_url": "https://nomorerainbows.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3191804004426977"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1460383761060060"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1651154400, "status": "PUBLISHED", "id": "1460383761060060"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6933907313290453", "version": "0.1.98"}, "id": "120179386652353", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4317356281612249", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6933907313290453"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "120179386652353"}]}, "change_log": null, "created_date": 1686935438, "id": "6