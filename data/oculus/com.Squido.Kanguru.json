j-B2&oh=00_AYB7ZsJhmvxdwJKKYIdOfGVDPMb9PcKWJSKRgmVg6qpZ2Q&oe=66ED6F2A"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m2EeyGW29JUQ7kNvgHuUhKJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN8M2ZhXnI_R7KD0FnMj-B2&oh=00_AYC6sGBDQHjRX3L4A5oqXzsfqvHmtseGRlNmjtElVAYKPQ&oe=66ED475A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sTBInTxaKjQQ7kNvgF1U8_b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN8M2ZhXnI_R7KD0FnMj-B2&oh=00_AYAFtYAS37gYAYfA99x3lENbU5tP_u288BilA0F7YlBTDg&oe=66ED49D2"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to r