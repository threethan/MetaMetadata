g", "id": "643126803683256", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982532_643126807016589_3506943865281698401_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KfIoWo2vQDcQ7kNvgF_YbMl&_nc_ht=scontent.oculuscdn.com&oh=00_AYARcpjZFKr2PYL_aUJqjo7sgj_U6I81WjaxTEZcMao0TA&oe=66FE9A04"}, {"file_name": "Overview.png", "id": "393096889170914", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_393096892504247_7361868852065376136_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3haNwbeVsVcQ7kNvgFimUF5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlLV7eyKJ4PWp6W9YACvvvgAHkQyEqmZXYEXI66y2NrQ&oe=66FE9BED"}, {"file_name": "Flying_NPC.png", "id": "677536776772662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003281_677536780105995_8276486090699885808_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HJd00Y02C3YQ7kNvgHI1D07&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9bVY2C3o1nFK_0VUorO6aZdpUF5Pg9khBhYRUppPNng&oe=66FE6F45"}, {"file_name": "Claw_Ring.png", "id": "677409200346071", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031308_677409203679404_8062215116938574621_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_6ayRe_wCywQ7kNvgEmCALt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwW5_2ZMUH8YMRgZT0Ny461-ZNJDWhZJb58mtvKzRqbw&oe=66FE92AA"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aI3Ixvr_grQQ7kNvgHgjbIh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBFTUnsBBYCEEZ5wj2kQLCPSH7Opx5yQNgQAJaeWNU9w&oe=66FE6ADA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=prw5uD1LWcUQ7kNvgGliXLj&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7JUMI1-hD9qR9RE7Oy2bq7YhMA2mJiGACJk0tc-3ezg&oe=66FE6D52"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nomorerainbows.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Squido Studio", "support_website_url": "http://discord.squidostudio.com/", "website_url": "https://nomorerainbows.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_T