g", "id": "643126803683256", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982532_643126807016589_3506943865281698401_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HXWfiisRz6cQ7kNvgEW8At-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdMlgl8NkEYDJNz469oG9f6c_74LFmX8JqVGWVBV0joA&oe=66F16B04"}, {"file_name": "Overview.png", "id": "393096889170914", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_393096892504247_7361868852065376136_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ejm7ZphTl9IQ7kNvgH5X5Wc&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMjKeQX68rs-te6TRoxXptTlLDWpU1IFbTipmZYreApA&oe=66F16CED"}, {"file_name": "Flying_NPC.png", "id": "677536776772662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003281_677536780105995_8276486090699885808_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JFULG6gz0lwQ7kNvgFm_zSt&_nc_ht=scontent.oculuscdn.com&oh=00_AYCX3lVStFRwW5dL7MQdNMwojTxaf7JR4-_3nuCuDBuc7Q&oe=66F14045"}, {"file_name": "Claw_Ring.png", "id": "677409200346071", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031308_677409203679404_8062215116938574621_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9_yQhZIGV_MQ7kNvgECcxLB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtoZTGcgG5STN2p5rlUkhprrQ9gBdzDHe1SuqEG10XwQ&oe=66F163AA"}, {"file_name": "World_2.png", "id": "4828566163930498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_4828566167263831_2140245688094234532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lH5Pe-ackd8Q7kNvgGLv5IM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBM8cSguHATJNEld2_fW5NJWTnBQ7WGsa4OX-WrTzLSGw&oe=66F13BDA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscap.png", "id": "1128638934555987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_1128638937889320_8176621081020433459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zB_1UBlXrMQ7kNvgE2x2FW&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhx8Tn5O9vsOiZkI0fAhADnO7OKSdTzHnvAjWbzzyVTg&oe=66F13E52"}, "display_name": "No More Rainbows Beta", "keywords": [], "long_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld.\n\nYou play as The Beast. \n\nSince time immemorial you have served as Warden of the Underworld, passing the eternities in a peaceful slumber.\n\nYou are suddenly awoken by joyful melodies piercing the warm darkness. The ashen air now reeks of tulip perfume. The once burning magma floor tiles now feel lush and fresh under your claws. The shrines desecrated with childish chalk drawings festooned with smiley faces.\n\nUsing an arm based locomotion method, you must spring forth into this fantastical virtual reality platforming world and reclaim your home!\n\nIn the full release:\n\n- Full story mode\n- 3 additional explorable worlds \n- Leadboards\n- Epic boss fights\n- Additional game modes (Infinite Mode)\n-", "short_description": "No More Rainbows brings the fun of a classic platformer to VR. Use the intuitive locomotion mechanics to run, jump, and climb using only your hands. Rampage through dozens of colorful worlds to reclaim your desecrated Underworld."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nomorerainbows.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Squido Studio", "support_website_url": "http://discord.squidostudio.com/", "website_url": "https://nomorerainbows.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_T