her -> Dual throwing is way better now!\n- Make \\\"drinks lost display\\\" transparent when the player is nearby\n- Improve menu buttons so you don't have to aim as much\n\nBug Fixes:\n- Fix snag and burger bug where the burger keeps on grilling outside of the grill\n- Fix tinyroo not being properly grilled when \"ragdoll mode\" was on", "created_date": 1670071660, "id": "5663874056999592", "version": "1.0.1", "version_code": 60, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3767842406602776", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6828328083887511"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "477031763478596"}]}, "change_log": null, "created_date": 1668637940, "id": "5616787351708263", "version": "1.0.0c", "version_code": 59, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3767842406602776", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6828328083887511"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "477031763478596"}]}, "change_log": null, "created_date": 1668451394, "id": "5610797028973962", "version": "1.0.0b", "version_code": 58, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols":