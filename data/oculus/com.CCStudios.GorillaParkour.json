nt-iad3-2.oculuscdn.com/v/t64.5771-25/39031558_866034428421888_2996539302196038088_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_IdD5FqOpGYQ7kNvgGhHt-8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsHmhEuf8ocqQKuTB5rQpqCA33xWkVSZcIdRO20v5eHA&oe=676E7D62"}, {"file_name": "screenshot1.png", "id": "1645694089334667", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974786_1645694092668000_4335120269076523447_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rm3wsWErr8MQ7kNvgFPeZe8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDMWiznsNEkDRkCHZUD009xU3bko5qPHIwvxE71WdfBLQ&oe=676E95B9"}, {"file_name": "screenshot2.png", "id": "496497906625917", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031364_496497909959250_8898685234514677884_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i-_FF_c2DUAQ7kNvgHxDJv1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDI7s8batA0evpGd2TN89MMoAWZYokc5d0gtrPkERh09g&oe=676E9A14"}, {"file_name": "screenshot3.png", "id": "1624567738120688", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974860_1624567741454021_2419708564114392230_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w8WP-XCyZ3sQ7kNvgFufW7F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBiTw7yfZWiQZhAB53r6XiGahTVV4ywcIs4RQvi80HH1g&oe=676EAA90"}, {"file_name": "screenshot5.png", "id": "1603260166920494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031511_1603260170253827_5523770924919723512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QVFEx9GaqtwQ7kNvgHIFIYI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLjbAd_9Whz0sN8d-gfDoA1VOS_IPSnmqpUrj-nN7JYg&oe=676EA760"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gorilla Parkour VR", "keywords": ["gorilla", "fangame"], "long_description": "Gorilla Parkour VR is an awesome hangout place to chill with friends or meet new ones, race your friends in the Tricky Taiga or drip yourself out with the cosmetics. An action social game, truly the best experience over any vr game! Mindlessly stare at a wall or bang your head into a mirror, make sure not to fall in the Tricky Taiga as you will need to waddle all the way back to the first obstacle. Limited time cosmetics show up occasionally so make sure to grab them or they might never come back. So that's the story of Gorilla Parkour, full of monkes slamming their heads into walls and dripping them selfs out with cosmetics. Download now on the Meta Quest Store for Quest 2, Pro and 3.", "short_description": "Gorilla Parkour VR, a parkour game based around the Gorilla Locomotion. Breeze through the obstacles and climb along the tree at the end of the Tricky Taiga, More maps coming soon. Tired of being bald monke? Come to the shop to pick up some drip like the First Week sale or the other amazing shop cosmetics like goggles and party hats. Download now on AppLab! (soon main store)"}]}, "developer_name": "CC Studios", "developer_privacy_policy_url": "https://sites.google.com/view/gorillaparkour/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Canyons at CC Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/gorillaparkour/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8609107822456175"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "i