c_ohc=L9D2t2ppCIEQ7kNvgFWRhIu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxJdy3M2Sszb3noo9u-tA-yuE8VbWhKm0ZqitNAhz2vQ&oe=6720B4E2"}, {"file_name": "screenshot1.png", "id": "1645694089334667", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974786_1645694092668000_4335120269076523447_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R9wrgF4W_54Q7kNvgGhzE8F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5DCXyDtgnQ-j_m7MrM7Iw6ocIENyD1Ejk97GPrLUN9A&oe=6720CD39"}, {"file_name": "screenshot2.png", "id": "496497906625917", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031364_496497909959250_8898685234514677884_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8xGuGVP5jmkQ7kNvgE8L5FS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeST3AZ7pdU9o-TjsHBn03vUzGVV9xvPGd_TgE-OnTTg&oe=6720D194"}, {"file_name": "screenshot3.png", "id": "1624567738120688", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974860_1624567741454021_2419708564114392230_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L9hdg0R8EzQQ7kNvgFJsqw5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCntpdl4gsKYi0x6ObOu8Ht9JmwsQmKtKvhDH3L0Ejoew&oe=6720E210"}, {"file_name": "screenshot5.png", "id": "1603260166920494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031511_1603260170253827_5523770924919723512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FErjujIkEY8Q7kNvgEfMdqk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwAxKurJoOBXFDS7L2YCtqE_qN_jjXGhjSt8Jkmw63sg&oe=6720DEE0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gorilla Parkour VR", "keywords": ["gorilla", "fangame"], "long_description": "Gorilla Parkour VR is an awesome hangout place to chill with friends or meet new ones, race your friends in the Tricky Taiga or drip yourself out with the cosmetics. An action social game, truly the best experience over any vr game! Mindlessly stare at a wall or bang your head into a mirror, make sure not to fall in the Tricky Taiga as you will need to waddle all the way back to the first obstacle. Limited time cosmetics show up occasionally so make sure to grab them or they might never come back. So that's the story of Gorilla Parkour, full of monkes slamming their heads into walls and dripping them selfs out with cosmetics. Download now on the Meta Quest Store for Quest 2, Pro and 3.", "short_description": "Gorilla Parkour VR, a parkour game based around the Gorilla Locomotion. Breeze through the obstacles and climb along the tree at the end of the Tricky Taiga, More maps coming soon. Tired of being bald monke? Come to the shop to pick up some drip like the First Week sale or the other amazing shop cosmetics like goggles and party hats. Download now on AppLab! (soon main store)"}]}, "developer_name": "CC Studios", "developer_privacy_policy_url": "https://sites.google.com/view/gorillaparkour/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Canyons at CC Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/gorillaparkour/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8609107822456175"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "519326720737345"}]}, "baseline_offer": {"id": "519326720737345"}, "is_approved": true, "firstOffer": {"nodes": [{"start_