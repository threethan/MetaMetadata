t=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zrvUWQW1RgMQ7kNvgFMAe1n&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCQAS5gYMlXt-VoODkiyiWyeNaNEp_gI6M40LPTZSZztQ&oe=67026262"}, {"file_name": "screenshot1.png", "id": "1645694089334667", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974786_1645694092668000_4335120269076523447_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U70pyImMvOwQ7kNvgE6LTIl&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDBN_wHjaK9OIsc9Q4AgQfQAhgRy6ueITX2PMgQoNlYoQ&oe=67027AB9"}, {"file_name": "screenshot2.png", "id": "496497906625917", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031364_496497909959250_8898685234514677884_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fZ7G0hQSs58Q7kNvgE2MVr9&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD6CWm8gdy6bRrBgQflx2m5iMu5_7Fczd8ngT92sMdRbQ&oe=67027F14"}, {"file_name": "screenshot3.png", "id": "1624567738120688", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974860_1624567741454021_2419708564114392230_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LlY5mWZz_UIQ7kNvgHUOzPn&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCzPIYyAPLTp3BKjWyHpJrJy2-aughr_EyLmxbLitGfxg&oe=67028F90"}, {"file_name": "screenshot5.png", "id": "1603260166920494", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031511_1603260170253827_5523770924919723512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABP0ZCtVTUgQ7kNvgELFCsG&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBpw8c2REX5ZmeWYOWRmPsi3vusfKQUy4sqosOJ2dntcg&oe=67028C60"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gorilla Parkour VR", "keywords": ["gorilla", "fangame"], "long_description": "Gorilla Parkour VR is an awesome hangout place to chill with friends or meet new ones, race your friends in the Tricky Taiga or drip yourself out with the cosmetics. An action social game, truly the best experience over any vr game! Mindlessly stare at a wall or bang your head into a mirror, make sure not to fall in the Tricky Taiga as you will need to waddle all the way back to the first obstacle. Limited time cosmetics show up occasionally so make sure to grab them or they might never come back. So that's the story of Gorilla Parkour, full of monkes slamming their heads into walls and dripping them selfs out with cosmetics. Download now on the Meta Quest Store for Quest 2, Pro and 3.", "short_description": "Gorilla Parkour VR, a parkour game based around the Gorilla Locomotion. Breeze through the obstacles and climb along the tree at the end of the Tricky Taiga, More maps coming soon. Tired of being bald monke? Come to the shop to pick up some drip like the First Week sale or the other amazing shop cosmetics like goggles and party hats. Download now on AppLab! (soon main store)"}]}, "developer_name": "CC Studios", "developer_privacy_policy_url": "https://sites.google.com/view/gorillaparkour/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Canyons at CC Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/gorillaparkour/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8609107822456175"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "519326720737345"}]}, "baseline_offer": {"id": "519326720737345"}, "is_approved"