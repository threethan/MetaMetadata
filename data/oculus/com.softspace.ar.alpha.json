ithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4586808061416562", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8481227775307885"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731598370, "id": "8482661171831212", "version": "2025.01", "version_code": 200, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4586808061416562", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8481227775307885"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1671794493161072"}]}, "change_log": "For complete release notes, please visit \u2192 docs.soft.space\n\n# Softspace v2024.42\n\n## Bug Fixes\n\n- Fixed: web browser item scale was being set incorrectly upon creation.\n- Fixed: image files uploaded to Dropbox contained extraneous bytes, increasing their file size.\n\n## Improvements\n\n- Recent firmware updates allow the Quest 3\u2019s GPU to run at higher clock speeds. Softspace now uses a noticeably higher super-sampling rate to harness this additional performance headroom.\n- Visual improvements to settings UI panels (account, workspaces, etc.).\n\n## Known Issues\n\n- The Dropbox authentication can expire, preventing the Dropbox import and export features from working. If this happens, please unlink Dropbox from the Account settings pages and relink.\n- Speech-to-text button occasionally stops working, requiring an app restart.\n- Workspaces with large numbers of content items can cause low framerates.\n- Browsing websites with heavy scripts or 3D rendering can cause frame drops.\n- Scrolling in the web browser can sometimes target the incorrect part of the page.", "created_date": 1731578520, "id": "8481227775307885", "version": "2024.42.1", "version_code": 99, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4586808061416562", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8481227775307885"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1671794493161072"}]}, "change_log": "For complete release notes, please visit \u2192 docs.soft.space\n\n# Softspace v2024.42\n\n## Bug Fixes\n\n- Web browser scale was being set incorrectly upon creation.\n\n## Improvements\n\n- Recent firmware updates allow the Quest 3\u2019s GPU to run at higher clock speeds. Softspace now uses a noticeably higher super-sampling rate to harness this additional performance headroom.\n- Visual improvements to settings UI (account, workspaces, etc.).\n\n## Known Issues\n\n- The Dropbox authentication can expire, preventing the Dropbox import and export features from working. If this happens, please unlink Dropbox from the Account settings pages and relink.\n- Speech-to-text button occasionally stops working, requiring an app restart.\n- Workspaces with large numbers of content items can cause low framerates.\n- Browsing websites with heavy scripts or 3D rendering can cause frame drops.\n- Scrolling in the web browser can sometimes target the incorrect part of the page.", "created_date": 1731523050, "id": "8477714202325909", "version": "2024.42", "version_code": 98, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4586808061416562", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8481227775307885"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1671794493161072"}]}, "change_log": "For complete release notes, please visit \u2192 docs.soft.space\n\n# Softspace v2024.41\n\n## Improvements\n\n- Updated AI API authentication.\n\n## Known Issues\n\n- The Dropbox authentication can expire, preventing the Dropbox import and export features from working. If this happens, please unlink Dropbox from the Account settings pages and relink.\n- Speech-to-text button occasionally stops working, requiring an app restart.\n- Workspaces with large numbers of content items can cause low framerates.\n- Browsing websites with heavy scripts or 3D rendering can cause frame drops.\n- Scrolling in the web browser can sometimes target the incorrect part of the page.", "created_date": 1728983126, "id": "8297730260324305", "version": "2024.41", "version_code": 97, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}