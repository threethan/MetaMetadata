n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IOxqca5Z_uoQ7kNvgHkJDFz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnBt7jyMBX5lpm2z_YkxOaSTHfEZJ25vgX6XnofeXrfQ&oe=673DC73E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover - Landscape.png", "id": "150318821368420", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86631740_150318824701753_5302826073747154445_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQ8J7C1waIMQ7kNvgE34lcH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnoIGTNLsG6F_4U6WcyUNdravSuQdqKwMxO32JS__a8Q&oe=673DB5BF"}, "display_name": "Softspace", "keywords": [], "long_description": "Softspace is an intuitive AR workspace where you lay out and organize notes, images, and websites. Connect related concepts, search the web for inspiration, and even get creative suggestions from our AI. This powerful productivity and creativity tool helps you develop the ideas at the heart of your best work.\n\nTo get started, visit \u2192 docs.soft.space/start\n\nFeatures:\n\n\u2022 Fast, intuitive UI for manipulating objects in 3D\n\u2022 Work with text, images, and web bookmarks (more soon)\n\u2022 Create topics to group and organize your ideas\n\u2022 Built-in web browser with image-saving function\n\u2022 AI-powered answers, topic suggestions, and clustering\n\u2022 Import from and export to Dropbox\n\nFor more info, visit \u2192 www.soft.space", "short_description": "Softspace is an intuitive AR workspace where you lay out and organize notes, images, and websites. Connect related concepts, search the web for inspiration, and even get creative suggestions from our AI. This powerful productivity and creativity tool helps you develop the ideas at the heart of your best work."}]}, "developer_name": null, "developer_privacy_policy_url": "https://soft.space/privacy", "developer_terms_of_service_url": "https://soft.space/terms", "publisher_name": "Softspace Inc.", "support_website_url": null, "website_url": "https://ww