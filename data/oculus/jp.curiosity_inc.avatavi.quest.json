mage_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984472_424671189959355_5481744604892435792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huTOQ0g53WkQ7kNvgGG2Lmi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDGXpmo0wV68WBwjRHG605tT5Ow0nHuijshXfZYXuRU4Q&oe=672222E6"}]}, "id": "1673690730132198", "locale": "en_US", "screenshots": [{"file_name": "AVATAVI_Image_01.png", "id": "1564484904280772", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65396053_1564484907614105_2146834528703634378_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q9gTecfTosgQ7kNvgHjZbh6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAq4C8FP85BiLvgbzohc8EWhlq_MSHGUsjZBabX8N5tLQ&oe=67221EE3"}, {"file_name": "AVATAVI_Image_02.png", "id": "508654828765404", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031348_508654832098737_7115507040446806876_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xb_QEOtFPuUQ7kNvgGDvCvK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsifL6z4ssqaMsr8ryQP_3Ggj5mNl_gH_AEnY-RehIIw&oe=67221181"}, {"file_name": "AVATAVI_Image_03.png", "id": "1854403625060439", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203614_1854403628393772_3682524425465415967_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A2JLgik-ZUAQ7kNvgFk1DWG&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAG2uys48hUioF-C7HxXvwKGAWogEiTX19gfXxgSM5Ndw&oe=67221E7A"}, {"file_name": "AVATAVI_Image_04.png", "id": "494124203566963", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/229198953_494124206900296_3058497728771996828_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=plQykGRNYZIQ7kNvgGGEUfC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC639qCw1CESN1gGcNSrvQBbmU-s08wwxFZ-0lVlCEHig&oe=67220EFD"}, {"file_name": "AVATAVI_Image_05.png", "id": "1229368271813217", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031566_1229368275146550_3021007392769947934_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-qEvViMG3sIQ7kNvgH_RECr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCX8jcjL_mq-YHlPhbnRxMKOSFWuMuPcHp7Ld8x5sqEig&oe=67221008"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AVATAVI -Play with Your Avatar", "keywords": [], "long_description": "The theme of AVATAVI is \"Adventure in the real world with your favorite avatar\"!\nIt is an AR application that allows you to make your own miniature avatar or favorite character appear in the real world and go on adventures together!\n\n[ How to play ]\nLet's take a walk in the real world!\nThe stage is the real world! Let's play by wandering around the real world using the move cursor.\n\nLet's make them dance!\nBy default, there are 6 types of motions such as dances and poses set.\n\nLet's change the size!\nSwipe with two fingers to increase or decrease the size of your avatar.\n\nTake photos and videos!\nTake photos and videos with your avatar to record your precious memories.\n\n[ About adding avatars ]\nAVATAVI does not have a character generation function. Instead, it has a function to easily add your favorite character CG created by various external services or by yourself.\n\nSearch and add from external services!\nAVATAVI is integrated with Sketchfab and VRoid Hub, the world's largest 3D model sharing platform, and you can search for and add avatars published by creators around the world.\n\nAdd your own avatar!\nYou can upload your own avatar to a cloud service such as Dropbox or Google Drive and paste the URL, or add a file saved on your device to use as your own avatar.\n\nExample of how to create an avatar\n- Modeling by yourself using 3DCG software\n-Scan your entire body in a 3D studio.\n\n*Please check the official website as we are constantly updating the formats that can be added.", "short_description": "Snap Avatar in Real World!"}, {"images": {"nodes": [{"file_name": "AVATAVI_logo_1440x1440.png", "id": "7277926652328507", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984460_7277926658995173_7144167082499857577_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jy0MLgdBBeAQ7kNvgHxZIwZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmrw5gM6hxpOScnT5ENg1yQEB1Pkv-FlQO7OjHeAOQ0A&oe=67223124"}, {"file_name": "AVATAVI_CoverArt_1008x1440.png", "id": "2201350546881836", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974734_2201350550215169_3080362978855455118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2QdO_QD8XycQ7kNvgG0q_SW&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJpoYTPqAhu31wCoj6lbczqjhBjHkgDy5zes6zTpywpw&oe=672234F2"}, {"file_name": "AVATAVI_CoverArt_1440x1440.png", "id": "1200101820953672", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570304_1200101824287005_847677145276628162_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XT0wfR3eQBEQ7kNvgFIQALv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJbUCLoWV4YMrvXuD-rm9dbYWn8RGFa1HyeNYqVNfxgw&oe=67221A2E"}, {"file_name": "AVATAVI_CoverArt_1080x360.png", "id": "1114970006620439", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035412_1114970009953772_745032646611463408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oMK4BofdP2kQ7kNvgHbdSS1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzt404xR-014vAiM49ivrNK33MG8sUX-XQzECPt_Djdg&oe=6721FF5B"}, {"file_name": "AVATAVI_CoverArt_2560x1440.png", "id": "772341254414039", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974581_772341257747372_131496815946174222_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yJ3P0STWddoQ7kNvgG01kaW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8yA3iZMtSG-PTf1EoOcERhMrvAh9-XKZh5IlJ7OEDnw&oe=6722217D"}, {"file_name": "AVATAVI_icon_512x512.png", "id": "752006683662941", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/3903