92_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uB2_I72lIQAQ7kNvgHR_COC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAg-UislCngE_tawlDLNwVju16MJE1Y1_dz_45vBFxqXQ&oe=67753166"}]}, "id": "2772686912871922", "locale": "en_US", "screenshots": [{"file_name": "AVATAVI_Image_01_2560x1440.png", "id": "1384699642158145", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035472_1384699645491478_5061233769957495895_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RbUuLFAfvGgQ7kNvgFrNe7r&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCEc5eLYNMb-eIK5dwZ1Ia_ZKPmJ_O5Hyy6g2Oi2PMyNw&oe=67751AFD"}, {"file_name": "AVATAVI_Image_02_2560x1440.png", "id": "3556389721243854", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982601_3556389724577187_5748101669367679050_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NxukCNDxIccQ7kNvgHECngJ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBMaVpZxcZUgm7XT4Jsf8pjM9Srip58eXphvR6ER611VQ&oe=677520B7"}, {"file_name": "AVATAVI_Image_03_2560x1440.png", "id": "373629872307488", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035347_373629875640821_806414370495622717_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tjHvDyKnFHAQ7kNvgGATbnI&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBfooU6ia3Ac_DoEOfPHnK1VwTa78OJeNP1bvgNDZx3uQ&oe=67753429"}, {"file_name": "AVATAVI_Image_04_2560x1440.png", "id": "425819040025391", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031419_425819043358724_1465067981975189427_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rha2_VNjl2gQ7kNvgEer3OS&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAy9KxHSn9lpfmIN2BtcGsCkE0XPlZMGSBy5js5dTq9zw&oe=67751066"}, {"file_name": "AVATAVI_CoverArt_2560x1440.png", "id": "6943284979133359", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75286675_6943284982466692_5896843589462956105_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mR2Srd-tc0EQ7kNvgFSviS8&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDLzJpj1nbG6S-WIsoCf-NqJcIbsUx5qwqaFTto0vX2PA&oe=67751AF6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AVATAVI -Play with Your Avatar", "keywords": [], "long_description": "The theme of AVATAVI is \"Adventure in the real world with your favorite avatar\"!\nIt is an AR application that allows you to make your own miniature avatar or favorite character appear in the real world and go on adventures together!\n\n[ How to play ]\nLet's take a walk in the real world!\nThe stage is the real world! Let's play by wandering around the real world using the move cursor.\n\nLet's make them dance!\nBy default, there are 6 types of motions such as dances and poses set.\n\nLet's change the size!\nSwipe with two fingers to increase or decrease the size of your avatar.\n\nTake photos and videos!\nTake photos and videos with your avatar to record your precious memories.\n\n[ About adding avatars ]\nAVATAVI does not have a character generation function. Instead, it has a function to easily add your favorite character CG created by various external services or by yourself.\n\nSearch and add from external services!\nAVATAVI is integrated with Sketchfab and VRoid Hub, the world's largest 3D model sharing platform, and you can search for and add avatars published by creators around the world.\n\nAdd your own avatar!\nYou can upload your own avatar to a cloud service such as Dropbox or Google Drive and paste the URL, or add a file saved on your device to use as your own avatar.\n\nExample of how to create an avatar\n- Modeling by yourself using 3DCG software\n-Scan your entire body in a 3D studio.\n\n*Please check the official website as we are constantly updating the formats that can be added.", "short_description": "Snap Avatar in Real World!"}, {"images": {"nodes": [{"file_name": "AVATAVI_logo_1440x1440.png", "id": "7277926652328507", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984460_7277926658995173_7144167082499857577_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bE4eTJdVLAwQ7kNvgFxyyDV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDH5qAXW8yDdQ5o4DGVftY3SIGBJoZU_K80yllraS5yJQ&oe=67753FA4"}, {"file_name": "AVATAVI_CoverArt_1008x1440.png", "id": "2201350546881836", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974734_2201350550215169_3080362978855455118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_tKzEE3Wib4Q7kNvgElQzds&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCIzIxzVD5n0k9pbdipePpJz17dlEdCp5zOc0VapEBZoA&oe=67754372"}, {"file_name": "AVATAVI_CoverArt_1440x1440.png", "id": "1200101820953672", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57570304_1200101824287005_847677145276628162_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ba_CJJyLx1cQ7kNvgF1jajL&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCDpSDEMhJzNoCRbHV-zh5jUcvUa618rJS0fhL--rWN0Q&oe=677528AE"}, {"file_name": "AVATAVI_CoverArt_1080x360.png", "id": "1114970006620439", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035412_1114970009953772_745032646611463408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hNnF4bS2bikQ7kNvgEwijDE&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB1IKBiGqgkBWbQ5_2OHgApgTWas7o3bSxYRjLsb1dpGA&oe=67750DDB"}, {"file_name": "AVATAVI_CoverArt_2560x1440.png", "id": "772341254414039", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974581_772341257747372_131496815946174222_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fyBPG8nzo2QQ7kNvgGIA23R&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCgBj0e0j9S85mhnja-ENLTHJl3CHxxXd_GyBiaSAfKBw&oe=67752FFD"}, {"file_name": "AVATAVI_icon_512x512.png", "id": "752006683662941", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v