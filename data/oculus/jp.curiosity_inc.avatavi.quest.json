792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOVl4RQq-U8Q7kNvgFnDBI5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIQEHhNgCk2zm186zdrf_BXQwn6iex2wfafxdQx5X35Q&oe=675C24E6"}]}, "id": "2772686912871922", "locale": "en_US", "screenshots": [{"file_name": "AVATAVI_Image_01_2560x1440.png", "id": "1384699642158145", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035472_1384699645491478_5061233769957495895_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tJqGbxqGhYAQ7kNvgHRB8j9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwslPAHRvR10KddQyF5l-h5ijB1bze7NzS9oKiNsoMKg&oe=675C0E7D"}, {"file_name": "AVATAVI_Image_02_2560x1440.png", "id": "3556389721243854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982601_3556389724577187_5748101669367679050_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NZ4QalySn_cQ7kNvgEGD1FV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB83n2sE7fzyyE2TtCvIUQv1mQs4sWHyIVMeyz5tGBS6A&oe=675C1437"}, {"file_name": "AVATAVI_Image_03_2560x1440.png", "id": "373629872307488", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035347_373629875640821_806414370495622717_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lhDA44obyaAQ7kNvgFjLbD8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnHGkkFPcPJ79H_HxCLzCo2dudMyY55HPfrR9aQDgtJg&oe=675C27A9"}, {"file_name": "AVATAVI_Image_04_2560x1440.png", "id": "425819040025391", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031419_425819043358724_1465067981975189427_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4Z1vGTltnD8Q7kNvgF9enBc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlwGX88C7ZhyY3e6nD_91jciiNa2I7XSxsUqulQ8ZMWA&oe=675C03E6"}, {"file_name": "AVATAVI_CoverArt_2560x1440.png", "id": "6943284979133359", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75286675_6943284982466692_5896843589462956105_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HABMbH18tOkQ7kNvgF5sU3Q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0BPADpuypOF1OfKjx3Ed_FIZ6V4BuRPw0skOaNDu1dA&oe=675C0E76"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AVATAVI -Play with Your Avatar", "keywords": [], "long_description": "The theme of AVATAVI is \"Adventure in the real world with your favorite avatar\"!\nIt is an AR application that allows you to make your own miniature avatar or favorite character appear in the real world and go on adventures together!\n\n[ How to play ]\nLet's take a walk in the real world!\nThe stage is the real world! Let's play by wandering around the real world using the move cursor.\n\nLet's make them dance!\nBy default, there are 6 types of motions such as dances and poses set.\n\nLet's change the size!\nSwipe with two fingers to increase or decrease the size of your avatar.\n\nTake photos and videos!\nTake photos and videos with your avatar to record your precious memories.\n\n[ About adding avatars ]\nAVATAVI does not have a character generation function. Instead, it has a function to easily add your favorite character CG created by various external services or by yourself.\n\nSearch and add from external services!\nAVATAVI is integrated with Sketchfab and VRoid Hub, the world's largest 3D model sharing platform, and you can search for and add avatars published by creators around the world.\n\nAdd your own avatar!\nYou can upload your own avatar to a cloud service such as Dropbox or Google Drive and paste the URL, or add a file saved on your device to use as your own avatar.\n\nExample of how to create an avatar\n- Modeling by yourself using 3DCG software\n-Scan your entire body in a 3D studio.\n\n*Please check the official website as we are constantly updating the formats that can be added.", "short_description": "Snap Avatar in Real World!"}, {"images": {"nodes": [{"file_name": "AVATAVI_logo_1440x1440.png", "id": "7277926652328507", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984460_7277926658995173_7144167082499857577_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=myyeuMCAHAgQ7kNvgHquKjl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0yZPIUdtuVrtkExdH_Q1wNVn0QcBu5hLSWKUkNsyRXw&oe=675C3324"}, {"file_name": "AVATAVI_CoverArt_1008x1440.png", "id": "2201350546881836", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974734_2201350550215169_3080362978855455118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHaF4GUIobEQ7kNvgFE36wv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8awzGTxdvDS0WYUnV5cEfN6QR94s7I-El5WfKLsD56g&oe=675C36F2"}, {"file_name": "AVATAVI_CoverArt_1440x1440.png", "id": "1200101820953672", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570304_1200101824287005_847677145276628162_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o2nEZEGG88MQ7kNvgGNpss8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJIz9ssgwdBvPvFXfhHYoc7RRd67gPf0h1owKNQvjFRQ&oe=675C1C2E"}, {"file_name": "AVATAVI_CoverArt_1080x360.png", "id": "1114970006620439", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035412_1114970009953772_745032646611463408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gxeqHTN3Jf0Q7kNvgFphKbX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxfHqmF4IsVQp4obVMUg2radWBDUn1YUG3MtPVTxLp5A&oe=675C399B"}, {"file_name": "AVATAVI_CoverArt_2560x1440.png", "id": "772341254414039", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974581_772341257747372_131496815946174222_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QDzkIlhn_tYQ7kNvgECwe6r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDec3ZSnKf3R-a4dF-lru2JV7IRD_KWO72xoODanKOfUw&oe=675C237D"}, {"file_name": "AVATAVI_icon_512x512.png", "id": "752006683662941", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/