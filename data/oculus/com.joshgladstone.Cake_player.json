KdyKycA&oe=671B929C"}, {"file_name": "screenshot1.png", "id": "832022182110945", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982636_832022185444278_4077727963505576850_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=drtgVrIW4_gQ7kNvgFkdX4E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCgW_Jl7us91tYgn4kKA0TSLa54qxSB39M7DJSUngmqdw&oe=671B6F0D"}, {"file_name": "screenshot2.png", "id": "1483098042628617", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001678_1483098045961950_6737643376951868181_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n9SHz7WAVywQ7kNvgHapFvP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHUNW1E6qcEYmlXtvNf_CPrMGf3-KyoXndSaHLwV04HA&oe=671B7BA9"}, {"file_name": "screenshot3.png", "id": "7617556931656270", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75371504_7617556938322936_1020464584732649606_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GTHTPaZhYz8Q7kNvgHr9AR2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPJh5lTljXCzCNudmMS9vZrmdBvNnDD8MlpsSEXrzQ6w&oe=671B6FE7"}, {"file_name": "screenshot5.png", "id": "1159226328848603", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974845_1159226332181936_7508469070715327871_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oZMqZbpWPxkQ7kNvgG0ukiI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMOWa4azgV8o4HRhVrxcXFbhfwFGbrPongtjn2C3Y1YA&oe=671B7300"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CakePlayerTrailer.png", "id": "1659453028131798", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031367_1659453031465131_7452527225029025688_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J99z3o3wJh8Q7kNvgHqM1kc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBudlLkk_5hTglk887Wk650vZXNlLifRzXz1SMzbl5uJw&oe=671B9D53"}, "display_name": "Cake Player: Light Field Video", "keywords": [], "long_description": "**Cake_player** is the only way to view the delicious futuristic media format 'Light Field Layered Depth Video', packing up to eight layers of gooey volumetric goodness into a delicious treat you can view in all six glorious degrees of freedom!\n\n**Key Features:**\n- **Exclusive 6DoF technology:** Cake_player is the **ONLY** way to view video from experimental Light Field camera arrays, allowing you to move around and view movies from multiple angles.\n- **Layered Depth Video:** The latest in occlusion-free 6DoF viewing, also allows for reflections and transparency!\n- **Passthrough Mixed-Reality:** Watch volumetric videos in your own room. Put a portal on your wall to another place!\n\nPrepare your appetite for **Cake Player**, the only Light Field Layered Depth Video player. Try a slice of the future of movies today!\n\n**(May only work in the United States due to video hosting issues)**", "short_description": "Prepare your appetite for Cake Player, the only way to view Light Field Layered Depth Light Video -- a layer cake of gooey volumetric goodness that allows for occlusion free 6DoF viewing with some view-dependent effects such as transparency and reflection. Try a slice of the future of movies today!\n\n(May only work in the United States due to video hosting issues)"}]}, "developer_name": "Josh Gladstone", "developer_privacy_policy_url": "http://joshgladstone.com/cake_player_privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Josh Gladstone", "support_website_url": null, "website_url": "http://joshgladstone.com/cake_player.html", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "541611600222565"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languag