Q7kNvgHs-JL3&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCnr_1RlmTAUeiaHOdGB0N9OOhViwtu2SJK5qOL9edLCA&oe=67407608"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "1117457400073080", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75294243_1117457403406413_5659793005043177339_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nrFshzSL_qUQ7kNvgFfKOuf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBJb0yLaHMegyiJbrkZKY5FtjVCckQiuRIZxegve_dS9Q&oe=67406F79"}, "display_name": "Kaiju Battle Simulator", "keywords": ["Kaiju", "Battle", "Physics", "Mecha", "Action"], "long_description": "Finally you can pilot a giant mech, battling mighty Kaijus to the death using physics, fists and rocket hammers in VR!\n\n0.2.4 - Release Notes\n\nPerformance\n* Improved performance and stability on Quest 2\n* Removed very small buildings from map\n* Disabled shadows (for now)\n\nGameplay\n* Revamped magnetic grab continuously pull objects towards you (no longer requires pull gesture)\n* Added holstered items to hologram display\n* Added sprinting (swing arms while walking to activate)\n\nMisc\n* Extended mech upper arm mesh to close empty gap\n\nKaiju\n* Fixed Moby only attacking with one arm, fixed look angle limits to stop him breaking his own neck trying to look at player\n\n*Please note: This is early-access experimental prototype, future updates will bring new features, improvements and other cool stuff*", "short_description": "Finally you can pilot a giant mech, battling mighty Kaijus to the death using physics, fists and rocket hammers in VR!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://twolivesleft.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Two Lives Left", "support_website_url": null, "website_url": "https://twolivesleft.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "con