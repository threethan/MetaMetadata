7kNvgEuW4Fu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAopib8hl47gWM3DeNyMKtrsrTI9nN7IViqNME7hv7TrA&oe=67431908"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "1117457400073080", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294243_1117457403406413_5659793005043177339_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4d5aF0cR3UIQ7kNvgHh9k7o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAN-lkXmT1TCut8C8jHzSXnWh7m5xbVZm4gdyzcYIfrjA&oe=67431279"}, "display_name": "Kaiju Battle Simulator", "keywords": ["Kaiju", "Battle", "Physics", "Mecha", "Action"], "long_description": "Finally you can pilot a giant mech, battling mighty Kaijus to the death using physics, fists and rocket hammers in VR!\n\n0.2.6 - Release Notes\n\nGameplay\n* Dismemberment for Snapjaw (coming soon for Moby)\n* Improved damage effects on Kaiju\n* Added day/night environment options\n* Spawning Kaiju now more reliable and attempts to prevent Kaiju from spawning inside each other\n* Added spawn code for dagger (left / up / right)\n* Note: Code for rocket hammer is (up / down / up / down)\n* Mech strength lowered slightly (tweaks menu coming soon to allow this to be customised by the user)\n\nExperimental\n* Arms can be reattached but this is unreliable and buggy at the moment (improvements to come)\n\n\n*Please note: This is early-access experimental prototype, future updates will bring new features, improvements and other cool stuff*", "short_description": "Finally you can pilot a giant mech, battling mighty Kaijus to the death using physics, fists and rocket hammers in VR!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://twolivesleft.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Two Lives Left", "support_website_url": null, "website_url": "https://twolivesleft.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "27