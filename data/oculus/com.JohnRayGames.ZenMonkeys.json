OQ&oe=66E02867"}, "display_name": "Zen Monkeys", "keywords": [], "long_description": "The first rule of Zen is \"Do One Thing At A Time\".  Zen Monkeys is a Zen-like playground to quiet your mind, relax, and hang.  Build chains of Zen Monkeys in a peaceful and serene environment that is fun and calm.\n\nZen Monkeys is a simple straight forward experience in VR.  A peaceful place to chill, climb, and hang.\n\nZen-Monkeys features:\n\n- Unlimited Physics Based Zen Monkeys: Use as many as you'd like!\n\n- A completely climbable set of Monkey Bars to hang your Zen Monkeys.\n\n- Dual-wield squirt guns to shoot down the chains you've created.\n\nZen Monkeys is a fun and relaxing getaway from school, work, chores or anything.  So release your Zen!", "short_description": "The first rule of Zen is \"Do One Thing At A Time\".  Zen Monkeys is a Zen-like playground to quiet your mind, relax, and hang.  Build chains of Zen Monkeys in a peaceful and serene environment that is fun and calm."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/zen-monkeys", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5143270472461161"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "8394592914