g", "id": "135270848523813", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974831_135270855190479_8178654673969510538_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HPnCrpoq-agQ7kNvgFETnmY&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYB5QjsQurcSpClGEitXrv2NQh4DyPnRPWeS99d_kXGt6w&oe=66F28C2F"}]}, "id": "3590060621322941", "locale": "en_US", "screenshots": [{"file_name": "pong_doublegun.png", "id": "279766223516951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974805_279766226850284_8551070913219359109_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jQkcYAGpsxQQ7kNvgGrI6RB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYAG-jD1NvOR2J3qGRDITbNOuP61eHrcw-czNW3AVD1Wfg&oe=66F28BD3"}, {"file_name": "pong_magneto-paddle.png", "id": "256632556136117", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_256632559469450_7588006548735395373_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EKBMEk1eE7AQ7kNvgGnFJ_7&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYDFgN-kGPWVNvmfCWIG8rW4Bv5lxiLczTbkwEzj7IoyoQ&oe=66F29996"}, {"file_name": "pong_magneto.png", "id": "441042917125774", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_441042920459107_6965789285775475705_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8u8eL-TV10oQ7kNvgG-3WVc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYD-rLhvuGWw40WRHsuh-h9b7O0EA306f1kJJd08fFynQQ&oe=66F2B7E3"}, {"file_name": "pong_playing_dual_paddle.png", "id": "742994326359394", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_742994329692727_99870647304979003_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CJlnrtVTPDkQ7kNvgGYeZfC&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYAGFpacbfpizLLh2lTGPFXY2G-WP2mFWgOQliy6i63F4w&oe=66F2B8DA"}, {"file_name": "pong_doublepaddle.png", "id": "1240184833067745", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572928_1240184836401078_2658798679411300089_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1kkuWCVSgxMQ7kNvgEKXY9j&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYAode3AMl4-SZM8qhhAos_YgmGUte8MuO9P_lpmoLw-gQ&oe=66F2BA34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pong_cover_landscape.png", "id": "933708114135474", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974838_933708117468807_6856193097951590791_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ocvlLgrWXcMQ7kNvgFOmTSj&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYAqlR7n3I1PkVaTQdJW6nqYm1O_ez260XPgknKaLNjGgg&oe=66F2AA6F"}, "display_name": "Brick Buster Reimagined", "keywords": [], "long_description": "Unleash the Retro Fun in VR: Brick Buster Reimagined!\nRediscover the classic paddle game with a virtual reality twist! Immerse yourself in an engaging world where nostalgia meets cutting-edge technology. Swing powerful paddles and obliterate bricks in a fully immersive 360-degree environment, offering limitless gameplay possibilities.\nExperience non-stop action with balls featuring built-in assistance, ensuring they return to you every time. Enhance your gameplay with exciting power-ups, such as the pistol and magneto, or create massive blast radiuses by swinging hard at the balls.\nDodge obstacles like mines by leaning, crouching, and avoiding them in real-time. With VR reflecting your every move, you'll need agility and strategy to master Brick Buster Reimagined. Get ready for a thrilling fusion of retro charm and modern technology as this classic game gets an incredible upgrade. Don't just play \u2013 live the ultimate arcade experience!", "short_description": "Brick Buster Reimagined: VR Retro Gaming at its Best!\nExperience classic arcade fun like never before in our immersive VR game! Break bricks with powerful paddles, dodge obstacles, and use game-changing power-ups for non-stop action. Enjoy a fusion of nostalgic charm and cutting-edge technology in a fully interactive 360-degree environment. Don't just play, live the ultimate arcade adventure in VR!\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.haimistudios.com/#privacy", "developer_terms_of_service_url": null, "publisher_name": "Haimi Studios", "support_website_url": null, "website_url": "https://www.haimistudios.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8462847220412048"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031340_487152885645422_4319118445617806487_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z5YHDzKK6aMQ7kNvgHdW4CN&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANZrwTg7Qsh4BM3mQq7-H58&oh=00_AYBninDwQ_oE8-Jj7dW2eyo7W_eQB1S4g2Su9rkueyEocg&oe=66F2A1C7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Brick Buster Reimagined", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1621378740, "lastRevision": {"nodes": [{"id": "134533101854718", "