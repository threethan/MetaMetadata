e7a0a&_nc_ohc=jYD-u1DGewsQ7kNvgGQw6aB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAY987Z889EYZ865kbsKxvV8uiu9dIfdsJWU9FySiFX2g&oe=67374834"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pong_cover_landscape.png", "id": "933708114135474", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974838_933708117468807_6856193097951590791_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SlnUviFgoYoQ7kNvgGa_I2T&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNc3glUM2q3rgr07AnUDb3d8U1fJQhow8LjsazZaw7tA&oe=6737386F"}, "display_name": "Brick Buster Reimagined", "keywords": [], "long_description": "Unleash the Retro Fun in VR: Brick Buster Reimagined!\nRediscover the classic paddle game with a virtual reality twist! Immerse yourself in an engaging world where nostalgia meets cutting-edge technology. Swing powerful paddles and obliterate bricks in a fully immersive 360-degree environment, offering limitless gameplay possibilities.\nExperience non-stop action with balls featuring built-in assistance, ensuring they return to you every time. Enhance your gameplay with exciting power-ups, such as the pistol and magneto, or create massive blast radiuses by swinging hard at the balls.\nDodge obstacles like mines by leaning, crouching, and avoiding them in real-time. With VR reflecting your every move, you'll need agility and strategy to master Brick Buster Reimagined. Get ready for a thrilling fusion of retro charm and modern technology as this classic game gets an incredible upgrade. Don't just play \u2013 live the ultimate arcade experience!", "short_description": "Brick Buster Reimagined: VR Retro Gaming at its Best!\nExperience classic arcade fun like never before in our immersive VR game! Break bricks with powerful paddles, dodge obstacles, and use game-changing power-ups for non-stop action. Enjoy a fusion of nostalgic charm and cutting-edge technology in a fully interactive 360-degree environment. Don't just play, live the ultimate arcade adventure in VR!\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.haimistudios.com/#privacy", "developer_terms_of_service_url": null, "publisher_name": "Haimi Studios", "support_website_url": null, "website_url": "https://www.haimistudios.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8462847220412048"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031340_487152885645422_4319118445617806487_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OylQ2KZvEVYQ7kNvgH7IcY4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-1j8hjxaSIh2OSSJgZZi3FijKkIIJjeXdY1-sT68cew&oe=67372FC7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Brick Buster Reimagined", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1621378740, "lastRevision": {"nodes": [{"id": "134533101854718", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4413706078659536", "is_first_party": false, "enables_in_app_ads": false,