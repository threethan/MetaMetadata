20721877470_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yVO9GnS_qLgQ7kNvgGHvPMA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEk_s4esfqoLk9pj0TOXCX1oRvrmLImKuFtkD-yM-oww&oe=672760DF"}, {"file_name": "SC5.png", "id": "330266375380947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75297583_330266378714280_2169586506143080293_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QKdn4G2DyO0Q7kNvgH2hypR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_KqT69JqRyt4gCAVAsfFq2rvh38kUM-GnnVz5zxV0ng&oe=67274BF0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverHorizontal.png", "id": "174747777965659", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86610706_174747781298992_3265066533625714073_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EWgFlcvbpE4Q7kNvgG1ixGD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDo_jMcTip_S7hpFDxYiCXLpAwKkWDe3xzZT8raelj9Ow&oe=67275C47"}, "display_name": "BlackCarbon", "keywords": [], "long_description": "An ecological catastrophe. Everything is black carbon. Is that all? There it is, a single plant fights and survives successfully \u2026 Which plant is it? How did it survive? Let\u2019s see here, let\u2019s get closer to it \u2026 However, it runs away \u2026 Runs away from me, away from the human, runs away to survive\u2026 Will it? Or maybe the plant that resists, that flees, is a symbol of life? The elixir of life? Hope for the future? Demonstration of the power of nature, survival \u2026 I am a being that has also survived the ecological catastrophe, which tries to attract the eluding tree, I am \u00dcbermensch, above death, above every devastation and catastrophe. Can we work together to rebuild the world which technology has destroyed? I try to approach the tree that is distrustfully fleeing, to cultivate and make our common future better.", "short_description": "An ecological catastrophe. Everything is black carbon. Is that all? There it is, a single plant fights and survives successfully \u2026 Which plant is it? How did it survive? Let\u2019s see here, let\u2019s get closer to it \u2026 "}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtualunit.org/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VirutalUnit", "support_website_url": null, "website_url": "https://virtualunit.org/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "422138876354863"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75289919_408961153657537_141216155446776872_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ff5Jmk4xfR8Q7kNvgE-_9CL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQBGHni2vW1r0FCA1ACN-FHGJOoh9CHCBsO6qFD6oU-A&oe=67274F59"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BlackCarbon", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1631046798, "lastRevision": {"nodes": [{"id": "119373170370104", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4188524877934961", "is_first