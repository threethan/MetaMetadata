1iv-kg&oe=66FFCCCC"}, "display_name": "Trash Gun", "keywords": [], "long_description": "TRASH GUN\n\nWelcome to the Space Sanitation Department - Trash Gun division!\n\nTrash Gun is a virtual reality fast paced, dual wield arcade shooter that challenges players to use their quick trigger fingers and sharp brain to get the highest score possible blowing up large debris. \n\nYou are an employee of the Trash Gun Division! Armed with your Trash Guns, you must quickly and efficiently destroy the large debris that is hurtling toward you.  You must quickly identify your target, select the proper color laser, take aim and BOOM!\n\nStay aware of your guns and the lasers they are firing.  It is easy to get over taken if you don't stay sharp. \n\nSo clock in for your shift and start shooting!!", "short_description": "Fast Paced Dual Wield VR Shooter"}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://sites.google.com/view/trash-gun-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "625468155217095"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1175952306999096"}, {"status": "PUBLISHED", "id": "751141063677402"}, {"status": "PUBLISHED", "id": "96852761