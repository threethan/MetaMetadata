03AD17"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "412710949999089", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003281_412710953332422_5619285024999579378_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6GqTuKVz2jwQ7kNvgGakTAh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1iXTvpX2p5bS1GJiTIY3tI0LAfJOzCT2bmd5M2Z8h6g&oe=6703C14C"}, "display_name": "Trash Gun", "keywords": [], "long_description": "TRASH GUN\n\nWelcome to the Space Sanitation Department - Trash Gun division!\n\nTrash Gun is a virtual reality fast paced, dual wield arcade shooter that challenges players to use their quick trigger fingers and sharp brain to get the highest score possible blowing up large debris. \n\nYou are an employee of the Trash Gun Division! Armed with your Trash Guns, you must quickly and efficiently destroy the large debris that is hurtling toward you.  You must quickly identify your target, select the proper color laser, take aim and BOOM!\n\nStay aware of your guns and the lasers they are firing.  It is easy to get over taken if you don't stay sharp. \n\nSo clock in for your shift and start shooting!!", "short_description": "Fast Paced Dual Wield VR Shooter"}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://sites.google.com/view/trash-gun-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["