ng", "id": "993384798916656", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566687_993384802249989_8686519486774586562_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c0nRe5k9FtYQ7kNvgHSIVON&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3yp0HL3LysD6nB1v1j2QGq&oh=00_AYC02hErR1Tt0AjkF29Gk2QqdVACDEXgC9cuIXgyoowpjQ&oe=66EE941D"}, "display_name": "TRASH GUN: Join the Space Sanitation Squad!", "keywords": ["puzzle", "space", "wave", "zen", "shooting"], "long_description": "Welcome to the Space Sanitation Department - Trash Gun division!\n\nTrash Gun is a fast-paced, dual-wield arcade shooter in VR that tests your quick trigger fingers and sharp mind. As an employee of the Trash Gun Division, you\u2019re armed with Trash Guns to swiftly and efficiently obliterate large debris hurtling toward you. Identify your target, choose the correct color laser, take aim, and BOOM!\n\nQuick Reflexes Required: Stay alert and avoid getting overwhelmed with trash.\n\nStrategic Shooting: Select the right color laser for each target.\n\nHigh Scores: Aim for the highest score by being fast and accurate.\n\nClock in for your shift and start blasting debris in Trash Gun!", "short_description": "Welcome to the Space Sanitation Department - Trash Gun division!\n\nTrash Gun is a fast-paced, dual-wield arcade shooter in VR that tests your quick trigger fingers and sharp mind. As an employee of the Trash Gun Division, you\u2019re armed with Trash Guns to swiftly and efficiently obliterate large debris hurtling toward you. Identify your target, choose the correct color laser, take aim, and BOOM!"}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/trash-gun", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id