R_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269587_543363334123667_2969517022805385034_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fg5L7ph9CzUQ7kNvgHNB6Gj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtpwnAsVxg-otvyoPzXcL-Cr87moC5QtBj_yinJ3Q_ow&oe=66CB040B"}]}, "id": "8436748396396141", "locale": "en_US", "screenshots": [{"file_name": "Timberman-VR-screen2.png", "id": "448448550427839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982466_448448553761172_8324552055304418423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cH20kpYT3wUQ7kNvgHNJr9o&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnCsMERFZXM6-dnbVmz5aCbVKxLfIzjKFAB3vA40MpkQ&oe=66CB25F2"}, {"file_name": "Timberman-VR-screen9.png", "id": "791930118490552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572754_791930131823884_4317281742019350634_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SZvrlcLb0IQQ7kNvgFp5mSD&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjivXUb6HgtlwwZrFZqA5bislJDo2n8ILc2ddTaobyLQ&oe=66CB0AA8"}, {"file_name": "Timberman-VR-screen4.png", "id": "568847841445523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572754_568847844778856_1557055665675211780_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DPMDrMs2dDgQ7kNvgGLnau7&_nc_ht=scontent.oculuscdn.com&oh=00_AYC2Sa77EAHrJr4m6-8BktDarkfk2Zg8If5j2csEuGGDLA&oe=66CAFDFA"}, {"file_name": "Timberman-VR-screen8.png", "id": "3040081799616454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974448_3040081802949787_8907978113858572011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fUaV5rcmBC4Q7kNvgHvDAv8&_nc_ht=scontent.oculuscdn.com&oh=00_AYB1uhsUWVZns_7vHFISPJ0V3aSX0JaooqLZ3Nh5kLksFw&oe=66CB2565"}, {"file_name": "Timberman-VR-screen10.png", "id": "1741233212896683", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001661_1741233216230016_8192747994358993307_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lu4efJANTDQQ7kNvgGivDuw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqz7Q2ajX_7GSBPeq3UziTjjjUVW-2SjyYlp0x94T2IA&oe=66CB239C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman_VR_2560x1440.png", "id": "774477733842113", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031640_774477737175446_8889361905058736722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Rzk0QvEH_kQ7kNvgFVZ4gs&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWXK7Ib0foZwmtox2Y2_E37h_Oi9xQ-j556UzIku0epQ&oe=66CAF97C"}, "display_name": "TimberMan", "keywords": [], "long_description": "Grab your axe and chop down some trees while avoiding the branches. Sounds simple enough, but this doesn\u2019t mean you\u2019re in for an easy task. Show off both your speed and accuracy. Prove your reflexes and steady arm by always cutting tree trunks from the correct side.\nBecome a true master of your trade by setting records and unlocking new tools. Use your hard-earned points to buy new axes that not only make you look stylish against the cloud of shavings and splinters, but also give you some special bonuses.\nKeep a cool head and use your best judgement even in the midst of the busiest logging operation: it\u2019s not just branches that will get in your way. Look out for all the different types of obstacles and wildlife, such as squirrels and wasp nests. Act quickly, be precise, and stay alert!\n", "short_description": "Timberman, the devilishly addictive retro-style arcade video game goes 3D and beyond. It\u2019s now available in VR! Take a deep dive into a game that is easy to learn but not-so-easy to master. Discover whole heaps of fun in a brand new type of reality - a virtual reality!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "GameFormatic", "support_website_url": null, "website_url": "https://gameformatic.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}