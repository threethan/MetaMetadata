&_nc_ohc=YKrS8ZRFtsUQ7kNvgGNjVTh&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCze_y681zP1hQOo0vwius4_26cuH1pBW6NH6AkaFkjMg&oe=6724B09D"}, {"file_name": "timberman oculus 1.png", "id": "659269792563427", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974775_659269799230093_4054628554830474981_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3yL9Dz47PKUQ7kNvgG9xzVX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB9vriPIUTFecPyXzPEsMf30Or6RaOO1II_kuGbugAYgQ&oe=6724C951"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman-cover-art-landscape-2560x1440.png", "id": "483864953922650", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982666_483864957255983_1110412221969612588_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qt9CI4LwqTgQ7kNvgGNYoag&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYATf9CDqFgQpTRudEbJkQdEanlwYk73KYSqAVr6NvVDXg&oe=6724B93A"}, "display_name": "Timberman VR", "keywords": [], "long_description": "Keep a cool head and your best judgment. Use your axe and chop down some trees while avoiding branches. It sounds simple enough, but that doesn't mean it's an easy task. Set records and unlock new tools - axes, machetes, and hammers, which are not only stylish but also give you some special bonus. Become a true champion!\n\n-easy to learn, hard to master\n-4 maps (autumn, winter, spring, halloween)\n-15 levels campaign\n-shop and use new unique tools\n axes (stone age axe, tomahawk, bat)\n machetes (futuristic, viking, candy)\n hammers (meat hammer, shark, thor)\n-compete with others and beat the record on the global leaderboard\n-achievements\n-tons of fun", "short_description": "A devilishly addictive retro arcade video game that goes into 3D and beyond. TimberMan VR is a simple game whose charm lies in its lack of storyline, while the advantage - is in your skill set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "develope