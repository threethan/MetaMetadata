&_nc_ohc=2BglAMmEtdUQ7kNvgF7Ab8N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAvx2Y7AN4kEMXUTF7ckLgPVrQrNNrC9bXESUg90WcZ9w&oe=6748491D"}, {"file_name": "timberman oculus 1.png", "id": "659269792563427", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974775_659269799230093_4054628554830474981_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wSgP7r5QVIcQ7kNvgH-NJcr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDn9384e0BGXclw7F5ZThT18IhWMv7pbYo5TxoMArGrxw&oe=674861D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman-cover-art-landscape-2560x1440.png", "id": "483864953922650", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_483864957255983_1110412221969612588_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yDwXq8KzCGgQ7kNvgELvSlt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9rX2Ij1EPul3LtvkJQGUj7k1d4Lc7vBTLHAI1SJb3Fg&oe=674851BA"}, "display_name": "Timberman VR", "keywords": [], "long_description": "Keep a cool head and your best judgment. Use your axe and chop down some trees while avoiding branches. It sounds simple enough, but that doesn't mean it's an easy task. Set records and unlock new tools - axes, machetes, and hammers, which are not only stylish but also give you some special bonus. Become a true champion!\n\n-easy to learn, hard to master\n-4 maps (autumn, winter, spring, halloween)\n-15 levels campaign\n-shop and use new unique tools\n axes (stone age axe, tomahawk, bat)\n machetes (futuristic, viking, candy)\n hammers (meat hammer, shark, thor)\n-compete with others and beat the record on the global leaderboard\n-achievements\n-tons of fun", "short_description": "A devilishly addictive retro arcade video game that goes into 3D and beyond. TimberMan VR is a simple game whose charm lies in its lack of storyline, while the advantage - is in your skill set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "develope