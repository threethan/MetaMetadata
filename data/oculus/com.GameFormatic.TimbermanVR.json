oculuscdn.com/v/t64.5771-25/38974448_3040081802949787_8907978113858572011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ove_1KZSXVUQ7kNvgHgSVtQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAh_8rddD3z4nm7IBTWpo-QU4HcIDH8gTkGORC-GAmFzA&oe=6714F965"}, {"file_name": "Timberman-VR-screen10.png", "id": "1741233212896683", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001661_1741233216230016_8192747994358993307_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lqEsCZdETaQQ7kNvgGFavId&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC87yk0oZJyRO8qjM5-ESBS5NiRK3m_Pm_R-zs0FEpKFw&oe=6714F79C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman_VR_2560x1440.png", "id": "774477733842113", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031640_774477737175446_8889361905058736722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JWZzxlEXvocQ7kNvgGu0Ocx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChNTFddNsvaaPOVt5AFR6eg77_ceNmDAMH9r-t3Rgocw&oe=671505BC"}, "display_name": "TimberMan", "keywords": [], "long_description": "Grab your axe and chop down some trees while avoiding the branches. Sounds simple enough, but this doesn\u2019t mean you\u2019re in for an easy task. Show off both your speed and accuracy. Prove your reflexes and steady arm by always cutting tree trunks from the correct side.\nBecome a true master of your trade by setting records and unlocking new tools. Use your hard-earned points to buy new axes that not only make you look stylish against the cloud of shavings and splinters, but also give you some special bonuses.\nKeep a cool head and use your best judgement even in the midst of the busiest logging operation: it\u2019s not just branches that will get in your way. Look out for all the different types of obstacles and wildlife, such as squirrels and wasp nests. Act quickly, be precise, and stay alert!\n", "short_description": "Timberman, the devilishly addictive retro-style arcade video game goes 3D and beyond. It\u2019s now available in VR! Take a deep dive into a game that is easy to learn but not-so-easy to master. Discover whole heaps of fun in a brand new type of reality - a virtual reality!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "GameFormatic", "support_website_url": null, "website_url": "https://gameformatic.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "433281972350128"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2729260777215524"}, {"status": "PUBLISHED", "id": "3472834729706430"}]}, "baseline_offer": {"id": "2729260777215524"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1681429560, "status": "PUBLISHED", "id": "2729260777215524"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5720318548085269", "version": "1.0"}, "id": "415865840440071", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5109535729163557", "is_concept": false, "latest_released