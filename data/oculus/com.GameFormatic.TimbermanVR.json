R_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269587_543363334123667_2969517022805385034_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h3CqsviTbZgQ7kNvgEg_qgb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEr_P_6juaJ7T-36YuXiXb4-zvsLJ80QArqbQL73ZfNw&oe=66DAD60B"}]}, "id": "8436748396396141", "locale": "en_US", "screenshots": [{"file_name": "Timberman-VR-screen2.png", "id": "448448550427839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982466_448448553761172_8324552055304418423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFgplUEMm70Q7kNvgFIOQno&_nc_ht=scontent.oculuscdn.com&oh=00_AYAmvQ5Qbv52C5EM5WmyPgL0he4kQGFMm8oScSQkd7Su-A&oe=66DAF7F2"}, {"file_name": "Timberman-VR-screen9.png", "id": "791930118490552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572754_791930131823884_4317281742019350634_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CIMHUbxLEX0Q7kNvgEyP27N&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUpMhAB46lqQgeC1ZTXg7p_7Onsf7g20E8fgOwvGBsgQ&oe=66DADCA8"}, {"file_name": "Timberman-VR-screen4.png", "id": "568847841445523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572754_568847844778856_1557055665675211780_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Ao5hkN2oQgQ7kNvgFdZetP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwR-YW7VsJwEZ1-5ruqLakz1eQCmeSsYGfTIKMHWn-sw&oe=66DACFFA"}, {"file_name": "Timberman-VR-screen8.png", "id": "3040081799616454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974448_3040081802949787_8907978113858572011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WFILrUJq46sQ7kNvgGoHeMD&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLu2oS19Y_VZvtfO8flGhP3FcGUjm-2cjDiplWU4ShpA&oe=66DAF765"}, {"file_name": "Timberman-VR-screen10.png", "id": "1741233212896683", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001661_1741233216230016_8192747994358993307_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z-z5n5Cfg8oQ7kNvgExIQzc&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7FKyJqNwNvb6VRGvgFyq6-6BifnWl-WgxpEeGTqbdnA&oe=66DAF59C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman_VR_2560x1440.png", "id": "774477733842113", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031640_774477737175446_8889361905058736722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FpKHnkKn-mAQ7kNvgGrZEoO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvXGwnNxRa8VHXpzUjq8AEpIbSOYYnWXCd7zzTwrF2pg&oe=66DB03BC"}, "display_name": "TimberMan", "keywords": [], "long_description": "Grab your axe and chop down some trees while avoiding the branches. Sounds simple enough, but this doesn\u2019t mean you\u2019re in for an easy task. Show off both your speed and accuracy. Prove your reflexes and steady arm by always cutting tree trunks from the correct side.\nBecome a true master of your trade by setting records and unlocking new tools. Use your hard-earned points to buy new axes that not only make you look stylish against the cloud of shavings and splinters, but also give you some special bonuses.\nKeep a cool head and use your best judgement even in the midst of the busiest logging operation: it\u2019s not just branches that will get in your way. Look out for all the different types of obstacles and wildlife, such as squirrels and wasp nests. Act quickly, be precise, and stay alert!\n", "short_description": "Timberman, the devilishly addictive retro-style arcade video game goes 3D and beyond. It\u2019s now available in VR! Take a deep dive into a game that is easy to learn but not-so-easy to master. Discover whole heaps of fun in a brand new type of reality - a virtual reality!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "GameFormatic", "support_website_url": null, "website_url": "https://gameformatic.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}