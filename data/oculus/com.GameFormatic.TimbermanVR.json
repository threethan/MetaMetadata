65_3143867504116024348_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o21JjIwe5aIQ7kNvgFk6Isc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDE9AE5KSo0kWxPMDJaJDpriN9d-b5Pp5bp0XMz-Qh1w&oe=670681DF"}, {"file_name": "logo1k-oculus.png", "id": "542808441121578", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036607_542808444454911_3733266633886934568_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fKgK9wehhRkQ7kNvgFobvaK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDWzVJpnDzX6krCc1L5wYBdtLCDIsHJf7oaQdszXbyS9A&oe=67065699"}]}, "id": "167416309175592", "locale": "en_US", "screenshots": [{"file_name": "Timberman-VR-screen8.png", "id": "3040081799616454", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974448_3040081802949787_8907978113858572011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_sgTAqxiGVUQ7kNvgGYCZ2z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgfPG-cjNBjcjWTDbJUD--rRCpUIM-vBY2jjIx7qQs0Q&oe=670678E5"}, {"file_name": "Timberman-VR-screen2.png", "id": "448448550427839", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982466_448448553761172_8324552055304418423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6s-1TlGxjtUQ7kNvgF0XJeA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsyfGetzJwhPXiEr7z47-Vbbe53gMiIn1Fpp7nnBGPsA&oe=67067972"}, {"file_name": "Timberman-VR-screen9.png", "id": "791930118490552", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572754_791930131823884_4317281742019350634_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dPmC-QZhKgYQ7kNvgFIWUnZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPSwqycWvMq1mxW2gIfmNY6ZCPme_nURdROxi0l58FhA&oe=67065E28"}, {"file_name": "timberman oculus 2.png", "id": "922756862187083", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75394635_922756865520416_4395742096745057328_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m0k4DpVy04gQ7kNvgGOa_Ec&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0QcIyuGoU9LPGN528WMOyGYSY0yz8V5uhucEBrZGUnQ&oe=67065E1D"}, {"file_name": "timberman oculus 1.png", "id": "659269792563427", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974775_659269799230093_4054628554830474981_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MZnFYNSCla0Q7kNvgHcCOt2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtdtsUgnQtnFo67y30FB-ghn_R0mpevIHDiTDyypwHaA&oe=670676D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman-cover-art-landscape-2560x1440.png", "id": "483864953922650", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_483864957255983_1110412221969612588_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kmLgrrjBoLgQ7kNvgFuc2vB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhgL-phFJqDHSB2su-22nq12AZaBSxNBcfZHJYw-QUig&oe=670666BA"}, "display_name": "Timberman VR", "keywords": [], "long_description": "Keep a cool head and your best judgment. Use your axe and chop down some trees while avoiding branches. It sounds simple enough, but that doesn't mean it's an easy task. Set records and unlock new tools - axes, machetes, and hammers, which are not only stylish but also give you some special bonus. Become a true champion!\n\n-easy to learn, hard to master\n-4 maps (autumn, winter, spring, halloween)\n-15 levels campaign\n-shop and use new unique tools\n axes (stone age axe, tomahawk, bat)\n machetes (futuristic, viking, candy)\n hammers (meat hammer, shark, thor)\n-compete with others and beat the record on the global leaderboard\n-achievements\n-tons of fun", "short_description": "A devilishly addictive retro arcade video game that goes into 3D and beyond. TimberMan VR is a simple game whose charm lies in its lack of storyline, while the advantage - is in your skill set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "GameFormatic", "support_website_url": null, "website_url": "https:/