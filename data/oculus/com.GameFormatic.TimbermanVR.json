65_3143867504116024348_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=noiWxBqevuQQ7kNvgEBoFqr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDriRhZ3JEPYWtQE4NbT4Doa96liBtCxq8QVapESzhQrw&oe=670A765F"}, {"file_name": "logo1k-oculus.png", "id": "542808441121578", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036607_542808444454911_3733266633886934568_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k4OwoBOtvcwQ7kNvgGFryEQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDodIiGGet_odWOGWVrj7Hh2SB0DpXk6_5u3wgPJvXc5w&oe=670A4B19"}]}, "id": "167416309175592", "locale": "en_US", "screenshots": [{"file_name": "Timberman-VR-screen8.png", "id": "3040081799616454", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974448_3040081802949787_8907978113858572011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4vO6K1_bFwoQ7kNvgHs2Tzq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDGBnszn3YiyPkBPBxY6210DFzNDi36irhZSr-NEx6sg&oe=670A6D65"}, {"file_name": "Timberman-VR-screen2.png", "id": "448448550427839", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982466_448448553761172_8324552055304418423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lI0TV6yov20Q7kNvgEmMHaE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPswN7i6uVMUAA5WnHAVU7l02wfakITZtQa-2m1f_QIw&oe=670A6DF2"}, {"file_name": "Timberman-VR-screen9.png", "id": "791930118490552", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572754_791930131823884_4317281742019350634_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EsL2VMssBiMQ7kNvgGK5laD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1lBqfoUuA407fF9HqrAuOtJ_pHp7OPTrXDVXydSpnWQ&oe=670A52A8"}, {"file_name": "timberman oculus 2.png", "id": "922756862187083", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75394635_922756865520416_4395742096745057328_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R7xDmBwwbcoQ7kNvgEglQTf&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiqTV8sabRNajTCBFqW9FEFhG-u8mRTeKcINDcVUo1uQ&oe=670A529D"}, {"file_name": "timberman oculus 1.png", "id": "659269792563427", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974775_659269799230093_4054628554830474981_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JilNOQ1YY2cQ7kNvgHNy6Lk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkvsuvwO_drwSvJ7uoQ-qyFjEkr4Bfo-MrhYR3ruMiBA&oe=670A6B51"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Timberman-cover-art-landscape-2560x1440.png", "id": "483864953922650", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_483864957255983_1110412221969612588_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1pWhfOXwFM8Q7kNvgF_WBeV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACxPOqLnxfQRcDeUH8j7QK1Q15GW324xMfAo3wYVdM5g&oe=670A5B3A"}, "display_name": "Timberman VR", "keywords": [], "long_description": "Keep a cool head and your best judgment. Use your axe and chop down some trees while avoiding branches. It sounds simple enough, but that doesn't mean it's an easy task. Set records and unlock new tools - axes, machetes, and hammers, which are not only stylish but also give you some special bonus. Become a true champion!\n\n-easy to learn, hard to master\n-4 maps (autumn, winter, spring, halloween)\n-15 levels campaign\n-shop and use new unique tools\n axes (stone age axe, tomahawk, bat)\n machetes (futuristic, viking, candy)\n hammers (meat hammer, shark, thor)\n-compete with others and beat the record on the global leaderboard\n-achievements\n-tons of fun", "short_description": "A devilishly addictive retro arcade video game that goes into 3D and beyond. TimberMan VR is a simple game whose charm lies in its lack of storyline, while the advantage - is in your skill set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "GameFormatic", "support_website_url": null, "website_url": "https:/