https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036602_243585652000211_899556208890795274_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=ToeYi2SyHJMQ7kNvgEhTmmW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOb-SrUo7nlJUh3QAE6N8gKtodazqpMonqtf2DOgNKtw&oe=676A99A2"}, {"file_name": "EarthQyest.png", "id": "3512913448957611", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031395_3512913452290944_8432013420749195897_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4U0mDnYyDtcQ7kNvgFfIpD0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVmRC3zGNC7nUngTAiVf_ZqgPo6s97qTbQrxitabe91w&oe=676A8781"}, {"file_name": "EarthQyest.png", "id": "834517198252006", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003282_834517204918672_5256638514144330387_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TcWOdNXgTW8Q7kNvgHXfxHJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSp-Rc8PuI2qOo5eyLbmFT9-gkU2NLx8RUad1GHSi_QQ&oe=676A9DBD"}, {"file_name": "EarthQyest.png", "id": "1723712434760725", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031546_1723712438094058_2534245311378872057_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=04Xbli6hhBcQ7kNvgEYTKOD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAmA_Qvg_GP542LugM8xtcNhQmk9IWHA8PG-QeOC0TOQ&oe=676A9185"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "EarthQyest.png", "id": "1078756446490659", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982454_1078756449823992_493302951635196042_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SqPzGTpZjCMQ7kNvgHOFN1M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABY_T-q3emD4FiU1tFbkrzgnyyF-6NQMzJcO-WXdUpAg&oe=676A91E9"}, "display_name": "EarthQuest", "keywords": [], "long_description": "Quest 2 Game made in Unity with the Cesium Package using the Google Earth Photogrammetry 3d Tiles.\n\n---------------------------------------------\nUPDATE v10 !! : hopefully the MOST STABLE and the Update that Simplified the Flight Controlling Mechanic the Most, v10 is meant to finalize the heavy game development for a month or two, however, fixes and improvements will still come if there are any needs for it. this Update adds Controller SUPPORT!!! basically the rest is self explanatory, the update also fixes a bug that due to the collider removal and raycast to prevent going through mesh, even if the Earth's Mesh was not visible in Space, it was still there, so the raycast stopped Player Movement when trying to go down, this was Fortunately FIXED!,\n\nv10.2: the Controllers are now Able to Type on Keyboard to Search and Teleport to a specific Place on Earth, and fixed a bug where the space bar touch collider was small,\n\nv10.3: when you pressed on some specific ui buttons, the code gave an error and every other ui stopped working since they had the same script. this was fixed. 3d Earth Generation to have better quality and faster performance, also loading faster and in larger quantity, we'll have to know if that's the case, if not we'll have to redo the changes in v10.4 :/, another improvement was that flight speed adjustment based on altitude was not efficient, and sometimes caused teleporting instead of flying smoothly, fixed !\nhttps://youtu.be/6s-jkai4_mA\n---------------------", "short_description": "geography teaching hand tracking passthrough VR app/game on Quest 2 Quest Pro, and Quest 3"}]}, "developer_name": "Bowie/Electrum", "developer_privacy_policy_url": "https://docs.google.com/document/d/1rfelQCihEG-gjgHBpxfy5Kd52Y2-Vj9LTwpGWsoWFZ0/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1vkc-TWH53X4qPwdf9J-erq8Pl_xvB_sYFUK2jHG94TY/edit?usp=sharing", "publisher_name": "Bowie/Electrum", "support_website_url": null, "website_url": "https://drive.google.com/drive/folders/1ZXJHOoHOgvJ6mK5_gHPoqyyQy8B6IKGn?usp=drive_link", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1703886060119133"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1197247534802870"}, {"status": "PUBLISHED", "id": "1218595455967648"}, {"status": "PUBLISHED", "id": "966363545148360"}, {"status": "PUBLISHED", "id": "865031525282969"}]}, "baseline_offer": {"id": "1197247534802870"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722030957, "status": "PUBLISHED", "id": "1197247534802870"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8625182897611367", "version": "4250"}, "id": "997411404840848", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8625182897611367"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "-\nv42.50 is here !\n\n# Street View improvements\n- Optimized Street View system, allowing fastest possible loading times on any type of Street View Imagery\n\n- Slightly smoother performance when a panorama is first being loaded\n\n# Introducing Featured Locations !\n\n- Renamed \u2018`Saved Locations`\u2019 to \u2018`Bookmarks`\u2019\n\n- Enjoy 25 featured breathtaking places, highlighted on the first 1-4 pages of \u2018`Bookmarks`\u2019.   |   Note: these will only take your unoccupied slots\n\n- Saving to an occupied slot will now ask for confirmation, seamlessly preventing accidentally replacing it\n\n# Additional \n\n- Safely allocated slightly more memory for loading 3D Maps\n\n- Maximum AI recording time should no longer limit longer recordings, it is now extended from 30s to 80s\n\n**Let me know** if there are any issues, big OR small - ( contact.earthquest.site )", "created_date": 1734545800, "id": "8625182897611367", "version": "4250", "version_code": 4250, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8625182897611367"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "--\nv42 is finally here !\n\nThis is an interesting one.\n\n- As previously announced, Personal API is no longer available, the functionality can still be functional but it is removed from the interface and is no longer recommended. For more details see <http://faq.earthquest.site>\n\n# Big Hub Menu Redesign \n\n- The API interface is gone, so we\u2019re taking advantage of this opportunity to improve the overall simplicity & design.\n\nA new feature / option was also introduced in v42, which is\n\n- Display Refresh Rate, offering control over battery consumption & GPU performance.\n\n\u2014Available in the Hub Settings Menu\n\n\u2014\u2014\u2014\n# Auto-adjusting Controller Cursor visibility !\n\n- The Controller Selection Cursors will now fade away when too far away from UI, keeping the experience free from distractions and resulting in a much more seamless, immersive and satisfying experience !\n\n- Smoothly integrated and fully adaptive to Keyboard / Menu states\n\n# Other Improvements\n\n- The How to Play interface will now only show the input scheme and reminder of how to use when first loading in, keeping everything simple and easy to understand.\n\n- Perfectly balanced sun intensity & warm-shade strength at horizon\n\nLet me know if there are any issues, big OR small - ( contact.earthquest.site )", "created_date": 1734093879, "id": "8594279550701702", "version": "4200", "version_code": 4200, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8625182897611367"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "-\nv41 is RELEASED !\n\nDidn't expect it so soon did ya ?\n\n# AI Controller Hotkey\n\n- Effortlessly use AI with no countdown or menu interaction !\n\n- Properly integrated, cannot be accidentally triggered, and offers introductory visual explanation on how to use\n\n# AI Improvements\n\n- AI Visualization now utilizes 3.29x more resolution ( 228% more quality )\n\n- AI can now properly visualize your perspective in Space\n\n- Fixed seeing Markdown Syntax ( ** ) in AI responses\n\n- If the AI usage limit every few hours wasn\u2019t already generous, now it\u2019s even higher / harder to reach !\n\n# Additional\n\n- A considerate amount of polishing, behavior refinement for better reliability, and bug fixes.\n\n- Wind will no longer be heard when flying with Flight Speed 0.1x \n\n- Careful small refinements made to Thumbstick Smooth Rotation, preventing accidentally turning when the Thumbstick is tilted very slightly. Additionally resulting in more responsive 'Thumbstick Flight Input Mode' controls.\n\n- FINALLY Solved the rare, mysterious crash that happened immediately after loading in.\n\n- Improved Street View nearby 360 detection and usage\n\nLet me know if there are any issues, big OR small ( contact.earthquest.site )", "created_date": 1733692011, "id": "8568992346563756", "version": "4106", "version_code": 4106, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8625182897611367"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "-\nv41 is RELEASED !\n\nDidn't expect it so soon did ya ?\n\n# AI Controller Hotkey\n\n- Effortlessly use AI with no countdown or menu interaction !\n\n- Properly integrated, cannot be accidentally triggered, and offers introductory visual explanation on how to use\n\n# AI Improvements\n\n- AI Visualization now utilizes 3.29x more resolution ( 228% more quality )\n\n- AI can now properly visualize your perspective in Space\n\n- Fixed seeing Markdown Syntax ( ** ) in AI responses\n\n- If the AI usage limit every few hours wasn\u2019t already generous, now it\u2019s even higher / harder to reach !\n\n# Additional\n\n- A considerate amount of polishing, behavior refinement for better reliability, and bug fixes.\n\n- Wind will no longer be heard when flying with Flight Speed 0.1x \n\n- Careful small refinements made to Thumbstick Smooth Rotation, preventing accidentally turning when the Thumbstick is tilted very slightly. Additionally resulting in more responsive 'Thumbstick Flight Input Mode' controls.\n\n- FINALLY Solved the rare, mysterious crash that happened immediately after loading in.\n\n- Improved Street View nearby 360 detection and usage\n\nLet me know if there are any issues, big OR small ( contact.earthquest.site )", "created_date": 1733605821, "id": "8563568893772768", "version": "4105", "version_code": 4105, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8625182897611367"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "-\nv41 is RELEASED !\n\nDidn't expect it so soon did ya ?\n\n# AI Controller Hotkey\n\n- Effortlessly use AI with no countdown or menu interaction !\n\n- Properly integrated, cannot be accidentally triggered, and offers introductory visual explanation on how to use\n\n# AI Improvements\n\n- AI Visualization now utilizes 3.29x more resolution ( 228% more quality )\n\n- AI can now properly visualize your perspective in Space\n\n- Fixed seeing Markdown Syntax ( ** ) in AI responses\n\n- If the AI usage limit every few hours wasn\u2019t already generous, now it\u2019s even higher / harder to reach !\n\n# Additional\n\n- A considerate amount of polishing, behavior refinement for better reliability, and bug fixes.\n\n- Wind will no longer be heard when flying with Flight Speed 0.1x \n\n- Careful small refinements made to Thumbstick Smooth Rotation, preventing accidentally turning when the Thumbstick is tilted very slightly. Additionally resulting in more responsive 'Thumbstick Flight Input Mode' controls.\n\n- FINALLY Solved the rare, mysterious crash that happened immediately after loading in.  ( I'm 95% sure it's fixed, if it ever happens to you again, let me know - contact.earthquest.site )\n\n- Improved Street View nearby 360 detection and usage\n\nLet me know if there are any issues, big OR small ( contact.earthquest.site )", "created_date": 1733114817, "id": "8532688910194100", "version": "4104", "version_code": 4104, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}