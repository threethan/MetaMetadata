LVxk8e5iHUVA&oe=66EAB857"}, {"file_name": "EarthQyest.png", "id": "243585648666878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036602_243585652000211_899556208890795274_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=nckeS-3RLtIQ7kNvgHg1IzA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEg66Suh6mYA41H6x4KWKtf&oh=00_AYA4Acf3S4Rn_Rbp8sFy_3SF_j6GRqZm-fnor5dlqJk4jw&oe=66EAB822"}, {"file_name": "EarthQyest.png", "id": "3512913448957611", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031395_3512913452290944_8432013420749195897_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KY3t34bxEUsQ7kNvgH8coMp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEg66Suh6mYA41H6x4KWKtf&oh=00_AYC90kRdfvHWQuOtSGhhWyAFrhZtXo4v2XtLQcAnqWz9YQ&oe=66EAA601"}, {"file_name": "EarthQyest.png", "id": "834517198252006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_834517204918672_5256638514144330387_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3ULA1yBdHAQQ7kNvgEbhJPb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEg66Suh6mYA41H6x4KWKtf&oh=00_AYDIqL5TgOkNa1tSJUabJlm3ZQ52PoQB8RFMHzEEZDJ7gw&oe=66EABC3D"}, {"file_name": "EarthQyest.png", "id": "1723712434760725", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031546_1723712438094058_2534245311378872057_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PZoBitBBSnQQ7kNvgHhoBtZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEg66Suh6mYA41H6x4KWKtf&oh=00_AYDMKxbN1rqbNO1BqYwpCR8vYriphimEcXXZtkWRqyH2jg&oe=66EAB005"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "EarthQyest.png", "id": "1078756446490659", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982454_1078756449823992_493302951635196042_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m_ZGRuNB1xwQ7kNvgFW2RgJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEg66Suh6mYA41H6x4KWKtf&oh=00_AYCQzyYmczgTzPcStJjyZ6IJ4VSPzNiOH1NH2C3tGpxrdw&oe=66EAB069"}, "display_name": "EarthQuest", "keywords": [], "long_description": "Quest 2 Game made in Unity with the Cesium Package using the Google Earth Photogrammetry 3d Tiles.\n\n---------------------------------------------\nUPDATE v10 !! : hopefully the MOST STABLE and the Update that Simplified the Flight Controlling Mechanic the Most, v10 is meant to finalize the heavy game development for a month or two, however, fixes and improvements will still come if there are any needs for it. this Update adds Controller SUPPORT!!! basically the rest is self explanatory, the update also fixes a bug that due to the collider removal and raycast to prevent going through mesh, even if the Earth's Mesh was not visible in Space, it was still there, so the raycast stopped Player Movement when trying to go down, this was Fortunately FIXED!,\n\nv10.2: the Controllers are now Able to Type on Keyboard to Search and Teleport to a specific Place on Earth, and fixed a bug where the space bar touch collider was small,\n\nv10.3: when you pressed on some specific ui buttons, the code gave an error and every other ui stopped working since they had the same script. this was fixed. 3d Earth Generation to have better quality and faster performance, also loading faster and in larger quantity, we'll have to know if that's the case, if not we'll have to redo the changes in v10.4 :/, another improvement was that flight speed adjustment based on altitude was not efficient, and sometimes caused teleporting instead of flying smoothly, fixed !\nhttps://youtu.be/6s-jkai4_mA\n---------------------", "short_description": "geography teaching hand tracking passthrough VR app/game on Quest 2 Quest Pro, and Quest 3"}]}, "developer_name": "Bowie/Electrum", "developer_privacy_policy_url": "https://docs.google.com/document/d/1rfelQCihEG-gjgHBpxfy5Kd52Y2-Vj9LTwpGWsoWFZ0/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1vkc-TWH53X4qPwdf9J-erq8Pl_xvB_sYFUK2jHG94TY/edit?usp=sharing", "publisher_name": "Bowie/Electrum", "support_website_url": null, "website_url": "https://drive.google.com/drive/folders/1ZXJHOoHOgvJ6mK5_gHPoqyyQy8B6IKGn?usp=drive_link", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1703886060119133"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1197247534802870"}, {"status": "PUBLISHED", "id": "1218595455967648"}, {"status": "PUBLISHED", "id": "966363545148360"}, {"status": "PUBLISHED", "id": "865031525282969"}]}, "baseline_offer": {"id": "1197247534802870"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722030957, "status": "PUBLISHED", "id": "1197247534802870"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7884621471667517", "version": "3420"}, "id": "997411404840848", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7884621471667517"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "---\nv34.20 is LIVE !!\n\n- Street View now supports different levels of quality !\n( 4k, 8k ) \nThis allows users with slower internet speeds enjoy fast & responsive Street View !\n\n- Slightly improved Menu Mini-Map readability\n\n---\nv34.02 is RELEASED !!\n\nThe powerful new 'Random Destination' feature is now even more powerful !\n\nThe function should now always send the user to a 3D Destination \ud83e\udd73\n\nAnd not to worry, the size of available locations is still massive compared to the previous list, with destinations well over a DOZEN !\n\n\ud83c\udf81\n---\nv34.03 is out\n\nBugfix Update\n\n- Fixed 'Random Destination' coordinates not working in other system languages\n\n- Fixed Teleportation not applying \"close-to-the-ground\" altitude when using some system languages other than English\n\n- Fixed pasting coordinates on the 'Search for Place' not working in other system languages\n---", "created_date": 1725038819, "id": "7884621471667517", "version": "3420", "version_code": 3420, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6320120764784270", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7884621471667517"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "997411404840848"}]}, "change_log": "v34.02 is RELEASED !!\n\nThe powerful new 'Random Destination' feature is now even more powerful !\n\nThe function should now always send the user to a 3D Destination \ud83e\udd73\n\nAnd not to worry, the size of available locations is still massive compared to the previous list, with destinations well over a DOZEN !\n\n\ud83c\udf81\n-\nv34.03 is out\n\nBugfix Update\n\n- Fixed 'Random Destination' coordinates not working in other system languages\n\n- Fixed Teleportation not applying \"close-to-the-ground\" altitude when using some system languages other t