D"}, {"file_name": "left.png", "id": "364983066674532", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001694_364983073341198_90455057601841915_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uDibRa1gjA0Q7kNvgEUyByF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABFGRZvPhpwz9zF4LhuMZMgUOgyDfa_pw_tY1u3ihb-A&oe=676AB4EE"}]}, "id": "410594481991800", "locale": "en_US", "screenshots": [{"file_name": "sunrise.png", "id": "821850043101192", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982588_821850046434525_6955644783253356043_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sLC84Laj4DAQ7kNvgGfjwJL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTMCBhQKZflNsREcaANwSqnwk3jVaWUY33Bsck5kz-bg&oe=676AAC2A"}, {"file_name": "Street View.png", "id": "503098719342555", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982613_503098726009221_4326602383393809797_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hj-FWuLn2aUQ7kNvgFnies0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmmzQp0pnFM5ArX8YybReuJtluwCHGMoNhHagMEEUPsg&oe=676AA3D1"}, {"file_name": "2A04ACB8-7052-4CCE-94D0-4CFF1078F28A.png", "id": "1455297745178744", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031612_1455297748512077_5889558274029638453_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6GiShstpr04Q7kNvgGeKKrs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAm6FJ_ECCNfqjiGciMbT83FXcB5nm_Fk9c42QW3FwPqQ&oe=676A83F5"}, {"file_name": "Untitled.png", "id": "235470705815303", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036632_235470709148636_6910459092682480867_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o3UAiBE3fZYQ7kNvgEOGr5f&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_Rc24p_cJi8TEJLEWTZ2SHaNnCxcLcNWCzasfyvlA4g&oe=676A8FAE"}, {"file_name": "Untitled.png", "id": "213076734929981", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982454_213076741596647_3961372732687478760_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LA6u9H-XfmgQ7kNvgHfL-mh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA9UrcqLI7qh3X8rbM9uwti8a6LeqzoVIuaFiq5_nH4Iw&oe=676A9A40"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled15.png", "id": "533743952653806", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031480_533743955987139_1131654148368741799_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RH6ope-AD0oQ7kNvgGIeU4w&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgufJGUJqe9kcQt-PJlzZbrXrWfZvbr6vWLHyYwlAxFQ&oe=676A8B9D"}, "display_name": "EarthQuest", "keywords": ["earth", "fly", "travel", "explore", "world"], "long_description": "**3D Coverage Everywhere**\n\n- Almost every recognizable city on earth is available in True 3D, even my tiny hometown in a poor side of Romania is covered, so you are likely able to visit your own street in Immersive 3D\n\n**Street View**\n\n- Best UNCOMPRESSED 8k Quality on the market, with every street 360 and community panorama on Earth\n\n**Multiplayer**\n\n- Explore alongside your friends\n\n**ChatGPT Integration: The AI companion can**\n\n- Naturally respond in YOUR OWN Language\n- Visualize & understand your surroundings on Earth for any educational purpose or to simply give fun facts\n- Teleport you anywhere on earth when asked\n- .. and much more\n\n**Realistic Graphics**\n\n- Real Life Inspired Lighting based on the Customizable Day/Night Cycle\n- Realistic, Reactive Fog Option\n\n**Hand Tracking**\n\n- Fly like a Superhero by pointing your index finger\n- Rotate by doing a \"Steering\" gesture with your own hands\n\n**Terrain Quality**\n\n- The 3D Map Quality can go much further than anything else out there and achieve realistic 3D by pushing the map quality to extreme detail with the best possible performance\n\n**Comfort Settings**\n\n- Comfort Options ( Snap Turning / Flight Vignette ) to prevent Motion Sickness\n- Flight Input Remapping ( Flight Controls Range from Simple to Complex Cinematic Movement )\n\n**Google Maps Integration**\n\n- Smart / manual zoom based on altitude\n- Paired with the compass for body orientation\n- Full Google Maps functionality on the Map Window feature\n\n**.. out of space, check \"earthquest.site\" ..**", "short_description": "The ENTIRE Earth in True 3D, and every 360 on the planet in 8k - ( The Best 3D & Street View Quality on the Market )\n\u2014\u2014\u2014\nfor more info, see:\nearthquest.site"}]}, "developer_name": "Boe", "developer_privacy_policy_url": "https://sites.google.com/view/earthquestvr/home/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/earthquestvr/home/terms-of-service", "publisher_name": "Boe", "support_website_url": "https://sites.google.com/view/earthquestvr/home/contact", "website_url": "http://earthquest.site/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "8449235891872736"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974502_893732726065225_3115626794753589888_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mbtfBdsyRBsQ7kNvgFGHm9H&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYByNBgdhJldt1vtNVcapX-tVBSf2X8ne8DQTD7U0F1C6Q&oe=676A835A"}, "is_conc