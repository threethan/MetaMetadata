uscdn.com/v/t64.5771-25/39003248_2982367321976120_6082228924115533256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9fsHqqRtDWQQ7kNvgHzS72g&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNy4xDIkLX2nG3r4paycRPAQvqWt4caxoGI5z6ce7lkA&oe=66DAF5B7"}, {"file_name": "Screenshot_Share.png", "id": "968399644007415", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001709_968399647340748_3160433986936116016_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0uC0mSBEv6cQ7kNvgGChESV&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-ZW1qTsoovMk0qKVqiJ5LVB2z6Qtq1S5_KaoNeim0Ew&oe=66DAE340"}, {"file_name": "Screenshot_Lobby.png", "id": "481603273147560", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_481603276480893_5906789078601183314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6405onEZtaoQ7kNvgGbbKAw&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsNWGTqB7_jPwo3SGQl61Wnx05rTKZJOz2Bgzb3FDo4A&oe=66DAE120"}, {"file_name": "Screenshot_Main.png", "id": "164213662266814", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982483_164213665600147_4962820737619881413_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJL8RFkJrm8Q7kNvgF579Ec&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIIoTxo85iUFqKO6cE0iLRK7AB-8jpIrW-9pPL8mlWlA&oe=66DAEAF3"}, {"file_name": "screen22.png", "id": "135280078630419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982471_135280081963752_7879474874150208488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ui6GA9kKI_gQ7kNvgHc2O3l&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFhvU8FV5M1abWrDdKrgbNUzb-9CgTfarKURtNWybOig&oe=66DACC44"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7phmtjI0lggQ7kNvgH1JAxM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiVYDiLck1myLYAI2qabrevtEhQUumJ1g9o9q43VgDIw&oe=66DAE797"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"