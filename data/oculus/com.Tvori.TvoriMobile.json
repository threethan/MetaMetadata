hc=JZYBHpWp2t4Q7kNvgG044dQ&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAunVthmlVyaDS2gPMbqmLwG9kWzAVfFC8Qu314GFzWpg&oe=6728AFF1"}]}, "id": "456611128786952", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_health (1).png", "id": "2982367318642787", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39003248_2982367321976120_6082228924115533256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uafGCqOa3I0Q7kNvgGI0VO7&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCPFjJhOPYjKyQy66dVnSgiU2I7xng1i7u4ZFi-hmLQCA&oe=6728BE37"}, {"file_name": "Screenshot_Share.png", "id": "968399644007415", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39001709_968399647340748_3160433986936116016_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q35LA9kRqqcQ7kNvgECmsHQ&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBcExySHwFazx_F7xSl_0cOCMl60tMBX8PsLr3GjnE7rw&oe=6728ABC0"}, {"file_name": "Screenshot_Lobby.png", "id": "481603273147560", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38984460_481603276480893_5906789078601183314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wC5MvZzYsl4Q7kNvgEPHLUp&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYBf9MckSU6qAWYvQCm2xBzkAVkRF9XyzKJuuj3vbGhHoQ&oe=6728A9A0"}, {"file_name": "Screenshot_Main.png", "id": "164213662266814", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982483_164213665600147_4962820737619881413_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZqhbXRNzNGoQ7kNvgF9E_oj&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDxp4nLpbiOtJrRKDzU44up0HUHgJjAwpQyDBuxfN9Big&oe=6728B373"}, {"file_name": "screen22.png", "id": "135280078630419", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982471_135280081963752_7879474874150208488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LrhCMX04ZbQQ7kNvgGFdByx&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDkkMB-9n4mZljHHqjoJYoKC1NDbYDnScb1wy6QYqh9Ow&oe=6728CD04"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eAV8WEuCh0IQ7kNvgFjIbnr&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYC-f_KsGGujnUy19612a5e_CbF1l4rq2PnxJO9uFIxorQ&oe=6728B017"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["U