uscdn.com/v/t64.5771-25/39003248_2982367321976120_6082228924115533256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SLSkXR709cQQ7kNvgHajB9x&_nc_ht=scontent.oculuscdn.com&oh=00_AYCk_o4FAtptm34UDq7Q3ZT6M52te0Ug23tPrg2fp67XxQ&oe=66E03BB7"}, {"file_name": "Screenshot_Share.png", "id": "968399644007415", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001709_968399647340748_3160433986936116016_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-lRMruTRIQQ7kNvgHFbwDJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYLHm2zdPko8nU6dSsYsDe9jRbf872onFhwWx_X21lyQ&oe=66E02940"}, {"file_name": "Screenshot_Lobby.png", "id": "481603273147560", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_481603276480893_5906789078601183314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m090z45pbZoQ7kNvgG0-Mkc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBDUmIHE5cxQxbOHJlGNHmENFhILq2Ahpr-MsmSt_WLUQ&oe=66E02720"}, {"file_name": "Screenshot_Main.png", "id": "164213662266814", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982483_164213665600147_4962820737619881413_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nv8P-HjUfbsQ7kNvgE4vpQH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFqHcQulH4LlDcp98oM73Gy5wKr4NJVcmZjx0q71A0XA&oe=66E030F3"}, {"file_name": "screen22.png", "id": "135280078630419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982471_135280081963752_7879474874150208488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LifXbmiw16MQ7kNvgHJzV68&_nc_ht=scontent.oculuscdn.com&oh=00_AYANmTiMTznYgdZoiuBI3C3_YgNzBlgZIKwW-xe0C-KQfA&oe=66E01244"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tcNiV9OwxVYQ7kNvgFtYYzx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvYYNAoIx1K5dQtXnPbxN3qrAn5RUqapcHKJwbPPFfOQ&oe=66E02D97"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"