S4VAb2D2tzxumbsKpnsg&oe=66E42573"}, {"file_name": "screen22.png", "id": "135280078630419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982471_135280081963752_7879474874150208488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMS8_2SuLRAQ7kNvgG3mK_O&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwMsOjm7lRtDKJhbGp-ggKF&oh=00_AYDZ7oXl2MEi2qaVjUH1FZF4KiFI138RCc83s2q1Zt0HAA&oe=66E43F04"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fq8Wtm0NN9kQ7kNvgGsq-bD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwMsOjm7lRtDKJhbGp-ggKF&oh=00_AYDWfDmHdhfQ5AaGJUUQCoXoHDPfr2DC0AaY3WBhxen1ng&oe=66E42217"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "461613842324795"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2578422155787638"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1623363060, "status": "PUBLISHED", "id": "2578422155787638"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4456708174384020", "version": "0.0.1.2293"}, "id": "552912642342001", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3823105514410959", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4456708174384020"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1639042103, "id": "4551653911556112", "version": "0.0.1.2500", "version_code": 2500, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": nu