iler_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0yh8slVvT34Q7kNvgFhs-dl&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAJxMdFlErMNOb2PYzftdHevXQtkaAYqtY9LxI2cee2nQ&oe=67767897"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "P