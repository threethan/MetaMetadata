com/v/t64.5771-25/39003248_2982367321976120_6082228924115533256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UTBUx6COB3MQ7kNvgFMhN6W&_nc_ht=scontent.oculuscdn.com&oh=00_AYAe1SiLHDyNczM1cFqYYfxmuUV6J4BnnOh1UA7rIiFVFQ&oe=66F94837"}, {"file_name": "Screenshot_Share.png", "id": "968399644007415", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001709_968399647340748_3160433986936116016_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PtTJP9_GeR8Q7kNvgE4nXpn&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1jrNwlPWTaGbW-Vh6Bu6RFDd76j4nJUWC4u21WYRXlg&oe=66F935C0"}, {"file_name": "Screenshot_Lobby.png", "id": "481603273147560", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_481603276480893_5906789078601183314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJ2rWf-o5GUQ7kNvgEkeqKD&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9U29__OcHGiNXmj0u8F1RwrJWAUiXGR20XXhMm6cYpA&oe=66F933A0"}, {"file_name": "Screenshot_Main.png", "id": "164213662266814", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982483_164213665600147_4962820737619881413_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJyrvrYIhiQQ7kNvgEaPFb1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBxClFY7YY5LqYznM-PYvJaIpgaXkwduq0mZPBpLw_MPg&oe=66F93D73"}, {"file_name": "screen22.png", "id": "135280078630419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982471_135280081963752_7879474874150208488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=51oCGxLbNfYQ7kNvgHc_Z6i&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMYTQpC2oBnUkQiq9XnueS5jh8WnJeg9otVe-JXv4MZg&oe=66F95704"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PA3qSnvZkWAQ7kNvgEXLBZV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZVXhYdebaGAdewVeeIKRTtS6jPguW5lwKMa2GM1XMRQ&oe=66F93A17"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SIN