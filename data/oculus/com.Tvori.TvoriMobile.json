2-Dp2cvdTsQ7kNvgFeZJJ3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDv5yqc8mVTjl5-NGllroqn5Y8FaAdp8UG9ORy_4Bwibw&oe=670BAEF1"}]}, "id": "456611128786952", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_health (1).png", "id": "2982367318642787", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39003248_2982367321976120_6082228924115533256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WQPoI9IuSbgQ7kNvgEBR1RE&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCuou3k5XM8HKqw-UA3yAef3lfSy-nCSfo_Pc7wZZMoqw&oe=670BBD37"}, {"file_name": "Screenshot_Share.png", "id": "968399644007415", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39001709_968399647340748_3160433986936116016_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lk-gYG3GuD0Q7kNvgGd-9m9&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBqIJQ8VgmEIDxXXK8QMyi51QlJYv_WWZ0s-4fQk8iE-g&oe=670BAAC0"}, {"file_name": "Screenshot_Lobby.png", "id": "481603273147560", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38984460_481603276480893_5906789078601183314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g6h5Fvhm36AQ7kNvgFC2ICo&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDvNUWHQO_24Zoq-floAk9aUsfDf0wmdT-VjoFy7J_0BA&oe=670BA8A0"}, {"file_name": "Screenshot_Main.png", "id": "164213662266814", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982483_164213665600147_4962820737619881413_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KoO4JTvmyq8Q7kNvgFfZoGJ&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD7icSgV75J0nhi7PJo-ZBvOpRxBAgq6YjATZjSA22suw&oe=670BB273"}, {"file_name": "screen22.png", "id": "135280078630419", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982471_135280081963752_7879474874150208488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pMJ5Tiq3bsIQ7kNvgGkvNdq&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAJA-meYKkaNiNQAjOCVPXUfTlRkXQRbe3enkuLzGslbg&oe=670BCC04"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "216671373458668", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001675_216671376792001_5001614293237078003_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-On92olV950Q7kNvgH5_m6x&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAKDBaYXKx2-t8Cy-LZeNHP2F4NHP7kvYojwnIrm_GDDw&oe=670BAF17"}, "display_name": "Tvori", "keywords": [], "long_description": "Tvori is a VR design tool for spatial experiences. With the term spatial experiences, we refer to VR and AR applications (from gaming and entertainment to productivity and training) as well as real-world products and services where space and user flows are crucial (e.g. the check-in process at the airport, design for smart home features, etc). Nowadays designers, product owners, and customers/users gather around the table to ideate and share a common vision by sketching storyboards, creating cardboards prototypes, and embodying the whole experience to come up with a vision and test hypothesis before developers or engineers resources are involved in the process. That is what Tvori is about\u2026 but without the limitations of the physical world.\nIn Tvori you can pick a premade scene as a canvas for your creation (a house, a shop floor, an autonomous car) or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color", "short_description": "Tvori makes collaboration smooth & easy to prototype interfaces, products, and design amazing experiences for XR, and the real world"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "http://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": false,