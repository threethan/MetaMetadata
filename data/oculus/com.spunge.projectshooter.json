_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gHTxv0RVPjkQ7kNvgEdu_KJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBE4pIVorLp7MsjJEpbLrwbHZfk2_vl8NDpBe3HS9F6VA&oe=673DC7A6"}, {"file_name": "SS_05.png", "id": "436791489046081", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75458093_436791492379414_5121335469237927541_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ZgOJXLdS7YQ7kNvgEjUKjF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1N2S8trxNeKVA4JqpdG--fcla8VM08aQmXDRP2wvPNw&oe=673DCCD6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt.png", "id": "436413708928922", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75308616_436413712262255_8416282731314707269_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8X_v0ztlxl0Q7kNvgH8WyV8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZ3QldxZjQwPUIGPvz7zYqTk7ExdzJ_5tgKsq4e2hRDA&oe=673DB605"}, "display_name": "Dead Second", "keywords": [], "long_description": "Dead Second is an **ACTION ARCADE COVER SHOOTER** featuring the 'Dead Second' time reaction system with high fidelity impact physics reactions. Experience Intense shoot outs and gunplay unlike any game before it!\n\n{464062559550450}\n\nYou are a member of the **C.S.F** (Chronos Strike Force) a top secret agency that employs a small time dilation technology called the **TEMPORAL OVERDRIVE** developed from back engineered U.A.P recoveries. The device is synergised with the adrenal receptors of a **C.S.F** Agent\u2019s brain granting them superhuman reflexes.\n\nGovernments have fallen into disarray, Corporations and Private Military Contractors rule the streets.\u200b Take on a series of **ASSIGNMENTS** and make them pay!\u200b\n\n{1879711489118656}\n\nThe **DEAD SECOND** is a time reaction system. Defeating an enemy momentarily slows time giving you a chance to dodge incoming enemy fire and acquire your next target. Chaining a quick succession of takedowns boosts your Score, Time & Accuracy points. Charge up your **TEMPORAL OVERDRIVE** and dominate your adversaries.\n\nProgress through the Ranks and unlock additional Guns & Cosmetics on your way to the top of the Leaderboards.\n\n{1547388299453306}", "short_description": "Dead Second is an Action Arcade Cover Shooter that puts you in intense, visceral shooting experiences unlike any game before it. Featuring the 'Dead Second' reaction system and high fidelity impact physics reactions."}]}, "developer_name": null, "developer_privacy_policy_url": "https://spungegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Spunge Games Pty Ltd", "support_website_url": null, "website_url": "https://spungegames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8211964808887063"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031434_1230762924905829_1719363201011882207_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jvglJDOZFqQQ7kNvgEH-FCT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-qlGdOfbMbScN2kAN_oXrARYbbSZp8w6pk2qwXbctCA&oe=673DC2B8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dead Second", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2