ntent-iad3-1.oculuscdn.com&oh=00_AYB8OxZUBlCcCR4IbHZK_q4k1ZOK3pm1WofbGFAjNUQe2w&oe=6741D9E5"}, {"file_name": "screenshot_210929_153616.png", "id": "886279205649250", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974689_886279208982583_2641015147114541280_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l-gyD-LFPpEQ7kNvgFqCtXW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRbZp8ZwoQdUCGdeMzn94BvKc56zJH0vhlUK2qSmEsCg&oe=6741D677"}, {"file_name": "screenshot_210929_160218.png", "id": "462595531587384", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974721_462595534920717_2761138321998607786_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hW-2F4JVhDsQ7kNvgG5TC8v&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDyWxLXXzoaulW9moojOp-TxF2q5V_YHSMSvzugqADyQg&oe=6741B970"}, {"file_name": "screenshot_210929_162512.png", "id": "4293029084147194", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974655_4293029087480527_1726804184140780160_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2MjInbq5D-EQ7kNvgFqYj43&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDzWZ8365vX24YQXMESYx6PAwqH3oPrHFIoCX6djfJR8A&oe=6741C7D0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Dead Second", "keywords": [], "long_description": "You're a righteous 'GUN FOR HIRE' taking care of the CORRUPT and WICKED throughout the city.\u200b\n\nGovernments have fallen into disarray, Corporations and Private Military Contractors rule the streets.\u200b\n\nTake on a series of 'ASSIGNMENTS' and make them pay!\u200b\n\nThe 'DEAD SECOND' is a bullet time reaction system. \u200b\n\nDefeating an enemy activates a momentary bullet time slow motion giving you a chance to dodge incoming enemy fire. Chaining a quick succession of takedowns  boosts your Score, Time & Accuracy points.\n\nProgress through the Ranks and unlock additional Guns & Cosmetics on your way to the top of the Leaderboards.", "short_description": "Dead Second is an Action Arcade Cover Shooter that aims to put you in an intense, visceral shooting experience unlike any game before it. Featuring the 'Dead Second' reaction system and high fidelity impact physics reactions."}]}, "developer_name": null, "developer_privacy_policy_url": "https://spungegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Spunge Games Pty Ltd", "support_website_url": null, "website_url": "https://spungegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "262141079380639"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PENDING", "id": "923908289712135"}, {"status": "PUBLISHED", "id": "1694199307792602"}, {"status": "PUBLISHED", "id": "326940617171151"}, {"status": "PUBLISHED", "id": "501480835885033"}, {"status": "PUBLISHED", "id": "1166914754525471"}, {"status": "PUBLISHED", "id": "1780457738972996"}, {"status": "PUBLISHED", "id": "298625512177415"}, {"status": "PUBLISHED", "id": "1059821361640202"}, {"status": "PUBLISHED", "id": "894699801247660"}]}, "baseline_offer": {"id": "1166914754525471"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "923908289712135"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7800769906673224", "ve