/t64.5771-25/38974844_885491292326569_7953368478185561247_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=inoPo10lnZwQ7kNvgEFaxtH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6SeKNAK_MPxZbv-2zEW4YR&oh=00_AYAYE_elZJPxZgIc2zeen60Yl8uLgMd4FyDbeR83g8TkHw&oe=66E5842D"}, {"file_name": "screenshot_210929_140514.png", "id": "561106588286985", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974878_561106591620318_2207553728136055722_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8MbRqk7j88sQ7kNvgGbfMUL&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6SeKNAK_MPxZbv-2zEW4YR&oh=00_AYCZUOxHSWkaV5LzYZTfywp9-6ozlB_bHd3b6cNtjBnwNA&oe=66E558A5"}, {"file_name": "screenshot_210929_153616.png", "id": "886279205649250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974689_886279208982583_2641015147114541280_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=puh8xfHFvTwQ7kNvgGo8ny5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6SeKNAK_MPxZbv-2zEW4YR&oh=00_AYAbPWuvi1ZuTeQqF9R1CSI24-Iey4LT80E3Ae4RegUyGw&oe=66E58D77"}, {"file_name": "screenshot_210929_160218.png", "id": "462595531587384", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974721_462595534920717_2761138321998607786_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R_ODOYKs1mIQ7kNvgHOjCL0&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6SeKNAK_MPxZbv-2zEW4YR&oh=00_AYDGPMl6o7PhwVXOys-c5q77W-fw0J9EygLqvDTXoeK-Ng&oe=66E57070"}, {"file_name": "screenshot_210929_162512.png", "id": "4293029084147194", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974655_4293029087480527_1726804184140780160_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9cYbF40kB1oQ7kNvgHrEvGs&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6SeKNAK_MPxZbv-2zEW4YR&oh=00_AYBxJQdpkramwBQspMzBXfKZUmvGgVpbdgs2tbeE2iAZkQ&oe=66E57ED0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Dead Second", "keywords": [], "long_description": "You're a righteous 'GUN FOR HIRE' taking care of the CORRUPT and WICKED throughout the city.\u200b\n\nGovernments have fallen into disarray, Corporations and Private Military Contractors rule the streets.\u200b\n\nTake on a series of 'ASSIGNMENTS' and make them pay!\u200b\n\nThe 'DEAD SECOND' is a bullet time reaction system. \u200b\n\nDefeating an enemy activates a momentary bullet time slow motion giving you a chance to dodge incoming enemy fire. Chaining a quick succession of takedowns  boosts your Score, Time & Accuracy points.\n\nProgress through the Ranks and unlock additional Guns & Cosmetics on your way to the top of the Leaderboards.", "short_description": "Dead Second is an Action Arcade Cover Shooter that aims to put you in an intense, visceral shooting experience unlike any game before it. Featuring the 'Dead Second' reaction system and high fidelity impact physics reactions."}]}, "developer_name": null, "developer_privacy_policy_url": "https://spungegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Spunge Games Pty Ltd", "support_website_url": null, "website_url": "https://spungegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "262141079380639"}}]}, "scheduled_offers": {"count": 7, "nodes": [{"status": "PUBLISHED", "id": "326940617171151"}, {"status": "PUBLISHED", "id": "501480835885033"}, {"status": "PUBLISHED", "id": "1166914754525471"}, {"status": "PUBLISHED", "id": "1780457738972996"}, {"status": "PUBLISHED", "id": "298625512177415"}, {"status": "PUBLISHED", "id": "1059821361640202"}, {"