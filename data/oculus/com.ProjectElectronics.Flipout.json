564254615_8045405914863045185_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xTW0YMDQuUgQ7kNvgEWyTWF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDIPOQiXTBDHluAGKnmJMXVzp2ofirI1dsgweMN946GvQ&oe=671E3DA5"}]}, "id": "647194463657468", "locale": "en_US", "screenshots": [{"file_name": "img5.png", "id": "1206084816812491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974515_1206084820145824_4693059391567665423_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=boK5HmYUE_cQ7kNvgHU6wlz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGcNPbSsRODoZMU5EhrLVj0wNZITnQmCmQPCQaZxRhnw&oe=671E33AF"}, {"file_name": "img3.png", "id": "762785074866907", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269160_762785081533573_4272442251747871416_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iUAMKj12YdYQ7kNvgFHg3lz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBq85dANFYTn2ZeMErTXQo5269b4eP5byQqF2YSmhTCow&oe=671E2629"}, {"file_name": "img2.png", "id": "1329917460870554", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86796156_1329917464203887_7727613662632523403_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CmYExcLptYUQ7kNvgEhK2Gw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCN57jGn4PkIbD11S9nf8ogpjf_tVORPi4DP_5OEkwm1g&oe=671E0C53"}, {"file_name": "img1.png", "id": "437829765017369", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982678_437829768350702_7450192307433430568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qmJyrz1zQPAQ7kNvgGMkbiw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAS9d_3YUtTB21Nskt5NbplPmNqadj0moDdLwKqVXmVTg&oe=671E1FE9"}, {"file_name": "img4.png", "id": "273094728354774", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297580_273094731688107_4722023891126031790_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=40zUQtvzRbAQ7kNvgH-5qUC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD45uzeslaTY7c47Ky_3c4VyZ83qhtsKVj-YV0V0aHZdw&oe=671E3363"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "766101374549787", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86655525_766101381216453_7286659792955350348_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1WOSeH4ZqLsQ7kNvgGXnLLC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFeGGm4liSKjsCk81lYtaCpPgyJFUSAxSPMFpzwSAmQA&oe=671E1F3A"}, "display_name": "Flipout", "keywords": [], "long_description": "Butterfly, backstroke, or freestyle! Swim around just like a real turtle, no buttons or joysticks required! Play on your own or join your fellow turtles in a public or private game. Enjoy anything from showing off your tricks on the diving board to exploring hidden treasures!\n\nThere are currently three unique game modes:\n\nTurtle Ball: An underwater game of two-team dodgeball. Hit turtles on the other team to switch them to your own team. Last team standing wins!\n\nZones: A game where turtles race to randomly safe zones that spawn randomly around the ocean. Anyone too slow will be frozen and can slow down unfrozen turtles.\n\nCasual: Hang out with other turtles with no rules!", "short_description": "Butterfly, backstroke, or freestyle! Swim around just like a real turtle, no buttons or joysticks required! Swim, race, and explore a variety of online game modes such as Turtle Ball and Zones!"}]}, "developer_name": "Sam Baker", "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vRZ6WRuSkydWmWjnSH_ttrPy8Pfc38pH3io71892Yx0OAxIVu_UUdDMmJY1SmgyiGxPbcyYZKiaWJJp/pub", "developer_terms_of_service_url": null, "publisher_name": "Sam Baker", "support_website_url": null, "website_url": "https://www.tiktok.com/@projectelectronics", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "SOCIAL"], "has_in_ap