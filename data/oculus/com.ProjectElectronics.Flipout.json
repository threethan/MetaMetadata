uluscdn.com&_nc_gid=AgKyHebNVv9Zk3EBPGCYxf8&oh=00_AYBNoi-PmCI9UN4PXB4ZnB27tgJmBznxey3atRDLrcUHZQ&oe=66D30DE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "766101374549787", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86655525_766101381216453_7286659792955350348_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UMqXhBJNIPAQ7kNvgEekFc2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgKyHebNVv9Zk3EBPGCYxf8&oh=00_AYBmg_bPZf7ht7uaWQXW3uBoirCXNfPXMNFtbNFWZLrKPw&oe=66D2F9BA"}, "display_name": "Flipout", "keywords": [], "long_description": "Butterfly, backstroke, or freestyle! Swim around just like a real turtle, no buttons or joysticks required! Play on your own or join your fellow turtles in a public or private game. Enjoy anything from showing off your tricks on the diving board to exploring hidden treasures!\n\nThere are currently three unique game modes:\n\nTurtle Ball: An underwater game of two-team dodgeball. Hit turtles on the other team to switch them to your own team. Last team standing wins!\n\nZones: A game where turtles race to randomly safe zones that spawn randomly around the ocean. Anyone too slow will be frozen and can slow down unfrozen turtles.\n\nCasual: Hang out with other turtles with no rules!", "short_description": "Butterfly, backstroke, or freestyle! Swim around just like a real turtle, no buttons or joysticks required! Swim, race, and explore a variety of online game modes such as Turtle Ball and Zones!"}]}, "developer_name": "Sam Baker", "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vRZ6WRuSkydWmWjnSH_ttrPy8Pfc38pH3io71892Yx0OAxIVu_UUdDMmJY1SmgyiGxPbcyYZKiaWJJp/pub", "developer_terms_of_service_url": null, "publisher_name": "Sam Baker", "support_website_url": null, "website_url": "https://www.tiktok.com/@projectelectronics", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_typ