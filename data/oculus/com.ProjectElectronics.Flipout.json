bF9F_0CngvDuQQA&oe=66EAC8E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "766101374549787", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86655525_766101381216453_7286659792955350348_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X4_mNB0VEPoQ7kNvgF4AVGD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJlyHOakToGdtm9NF6yaaxc&oh=00_AYAk1jUsjBI9q-Q2JHPUYVPbKLeVbfTK9ojg7xnx1-Epig&oe=66EAB4BA"}, "display_name": "Flipout", "keywords": [], "long_description": "Butterfly, backstroke, or freestyle! Swim around using your own two hands, no buttons or joysticks. Play on your own or join your fellow turtles in a public or private game. Enjoy anything from showing off your tricks on the diving board to exploring hidden treasures. When a safe-zone appears deep in the ocean, the race is on! The last turtle to the safe zone will be out of the race. But don't forget about these fallen players just yet! If they tag you, you will lose your speed. So swim fast!", "short_description": "Swim, race, and explore, with friends. Last one too the safe zone is out! And watch out for other turtles trying to slow you down!"}]}, "developer_name": "Sam Baker", "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vRZ6WRuSkydWmWjnSH_ttrPy8Pfc38pH3io71892Yx0OAxIVu_UUdDMmJY1SmgyiGxPbcyYZKiaWJJp/pub", "developer_terms_of_service_url": null, "publisher_name": "Sam Baker", "support_website_url": null, "website_url": "https://www.tiktok.com/@projectelectronics", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported