564254615_8045405914863045185_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tG2hCRSD9lgQ7kNvgFRnjQg&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDa15XktdVnbTZqNWviy-wTJ7Dw38jnUni2gJuFHgKVPg&oe=67729DA5"}]}, "id": "647194463657468", "locale": "en_US", "screenshots": [{"file_name": "img5.png", "id": "1206084816812491", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974515_1206084820145824_4693059391567665423_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6XbtRRuNhYoQ7kNvgFC1XKk&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAIkOV-mKCXEoNGqSBZME_0J8RReI0a3rDfuaHZw8nZ2w&oe=677293AF"}, {"file_name": "img3.png", "id": "762785074866907", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75269160_762785081533573_4272442251747871416_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q24mPQSYkE8Q7kNvgEDgEUj&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCNFwOr0R5A29-w0gx6vE148HLvm5hUJO5ztUcB_TjNNQ&oe=67728629"}, {"file_name": "img2.png", "id": "1329917460870554", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86796156_1329917464203887_7727613662632523403_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MyW6hH_7l_cQ7kNvgHfiazu&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD7VGWQwmmrZ7HtPr4ajl669oQMIyJgZK7d7xFiSTtBRQ&oe=67726C53"}, {"file_name": "img1.png", "id": "437829765017369", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982678_437829768350702_7450192307433430568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBOOxgohmjIQ7kNvgF2Uh75&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCexCOJUoLBRc8aCf8XsnhNNkTtYHoUNUeH0Co3bDCOAg&oe=67727FE9"}, {"file_name": "img4.png", "id": "273094728354774", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75297580_273094731688107_4722023891126031790_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ohqoSgnE5kQ7kNvgESuY59&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCnvfGUherifsX1WMGl3Y2ugPaVGYtiqiXrHd_n0wjY5Q&oe=67729363"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "766101374549787", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86655525_766101381216453_7286659792955350348_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DVzS0HHR77sQ7kNvgGUbQLH&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAo1flagaAwGZ9_UzXIMnXMzzvP6e9qU6Vt_4lpyzoTWw&oe=67727F3A"}, "display_name": "Flipout", "keywords": [], "long_description": "Butterfly, backstroke, or freestyle! Swim around just like a real turtle, no buttons or joysticks required! Play on your own or join your fellow turtles in a public or private game. Enjoy anything from showing off your tricks on the diving board to exploring hidden treasures!\n\nThere are currently three unique game modes:\n\nTurtle Ball: An underwater game of two-team dodgeball. Hit turtles on the other team to switch them to your own team. Last team standing wins!\n\nZones: A game where turtles race to randomly safe zones that spawn randomly around the ocean. Anyone too slow will be frozen and can slow down unfrozen turtles.\n\nCasual: Hang out with other turtles with no rules!", "short_description": "Butterfly, backstroke, or freestyle! Swim around just like a real turtle, no buttons or joysticks required! Swim, race, and explore a variety of online game modes such as Turtle Ball and Zones!"}]}, "developer_name": "Sam Baker", "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vRZ6WRuSkydWmWjnSH_ttrPy8Pfc38pH3io71892Yx0OAxIVu_UUdDMmJY1SmgyiGxPbcyYZKiaWJJp/pub", "developer_terms_of_service_url": null, "publisher_name": "Sam Baker", "support_website_url": null, "website_url": "https://www.tiktok.com/@projectelectronics", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "1023770785722696"}], "external_subscri