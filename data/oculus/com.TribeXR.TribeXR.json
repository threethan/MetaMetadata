936_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lKR_5QimcsgQ7kNvgGLpKcS&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0dHK73U6x9lbwDY6F7pSRBe-dVnxXeYqhSq2t41s6ew&oe=66CB13C5"}, {"file_name": "migrated_image.png", "id": "668950950533568", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974832_291692688170754_2429816836485808128_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JDOvKgl8tx8Q7kNvgEdT7VD&_nc_ht=scontent.oculuscdn.com&oh=00_AYAc5-RHULcKrN1o81kKKcFeCTnLvK4D3s7W7aMwaAB0kg&oe=66CB1992"}, {"file_name": "migrated_image.png", "id": "731863730680116", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974495_1470589263082650_6368686439764328448_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hAw5tRsyVhEQ7kNvgH4W8KQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDs06sGBe3hFB_q8pyKHwe3M-xnryKCdBYpUUy-O9jraA&oe=66CB172B"}, {"file_name": "migrated_image.png", "id": "220366849050746", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_707742899670916_7295427879867777024_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jvrmEXZx0YkQ7kNvgEqhaXa&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbArZyEeSIM0eTyuVKK1MIMpwlmzfUBvu3l3MWY6nFxQ&oe=66CB0C4B"}, {"file_name": "migrated_image.png", "id": "654641102019922", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974685_413211822650152_1417785566451204096_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=76KPDPIiX1QQ7kNvgFwTyaf&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_fOADoE7z-BXx8AHy-0WEj9oHVs8w0mZKGlp44Gqf7g&oe=66CB3086"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TribeXR DJ School", "keywords": ["Education", "Learning", "DJ", "Music"], "long_description": "Hello DJ. Welcome to your VR DJ tool. \n\nTribe XR features a fully functioning pro-style CDJ mix deck. Upload your own music and refine your own unique sound.\n\nGain access to learning resources such as video tutorials, interactive tutorials and a free 1-on-1 intro class. \n\nTurn things up a notch with 1-on-1 mentor classes with professional DJ's with our new VR mentor program (beta)\n\nPerform for friends and the world with native live-streaming integrations. We'll help you set up your own VR live-mix show with real-time support. You can even request to play a live set on Tribe XR\u2019s radio show.\n\nJoin our Discord channel and have direct access to the Tribe XR team, mentors and a passionate community of music enthusiasts.\n\nPlease note: This is an early access app and we are adding new features and refinements week by week. We only support Windows 10 at this time.", "short_description": "Hello DJ. Welcome to your VR DJ tool. \n\nTribe XR features a fully functioning pro-style CDJ mix deck. Upload your own music and refine your own unique sound."}]}, "developer_name": "Tribe XR Inc", "developer_privacy_policy_url": "https://www.dropbox.com/s/sw8jva5kswf857u/Tribe%20VR%20Privacy%20Policy%2012142017.pdf?dl=0", "developer_terms_of_service_url": "https://www.dropbox.com/s/sw8jva5kswf857u/Tribe%20VR%20Privacy%20Policy%2012142017.pdf?dl=0", "publisher_name": "Tribe XR Inc", "support_website_url": "https://discordapp.com/invite/qdhNs2U", "website_url": "https://www.tribexr.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "MUSIC", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "339262744724400"}}]}, "scheduled_offers": {"count": 26, "nodes": [{"status": "PUBLISHED", "id": "3014142328645998"}, {"status": "PENDING", "id": "7