7kNvgHyxkqB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOm8ffXzVBWGrDKJfM_aB6DA_-fxsj1UyU4zXmNGltxQ&oe=672DECCB"}, {"file_name": "migrated_image.png", "id": "654641102019922", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974685_413211822650152_1417785566451204096_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zlhayVOQt1IQ7kNvgHXU_UN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-GHq6R7kj2X-g7qlKZm6JVhUP6EW_ADVtwyGQQeDQow&oe=672E1106"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TribeXR DJ School", "keywords": ["Education", "Learning", "DJ", "Music"], "long_description": "Hello DJ. Welcome to your VR DJ tool. \n\nTribe XR features a fully functioning pro-style CDJ mix deck. Upload your own music and refine your own unique sound.\n\nGain access to learning resources such as video tutorials, interactive tutorials and a free 1-on-1 intro class. \n\nTurn things up a notch with 1-on-1 mentor classes with professional DJ's with our new VR mentor program (beta)\n\nPerform for friends and the world with native live-streaming integrations. We'll help you set up your own VR live-mix show with real-time support. You can even request to play a live set on Tribe XR\u2019s radio show.\n\nJoin our Discord channel and have direct access to the Tribe XR team, mentors and a passionate community of music enthusiasts.\n\nPlease note: This is an early access app and we are adding new features and refinements week by week. We only support Windows 10 at this time.", "short_description": "Hello DJ. Welcome to your VR DJ tool. \n\nTribe XR features a fully functioning pro-style CDJ mix deck. Upload your own music and refine your own unique sound."}]}, "developer_name": "Tribe XR Inc", "developer_privacy_policy_url": "https://www.dropbox.com/s/sw8jva5kswf857u/Tribe%20VR%20Privacy%20Policy%2012142017.pdf?dl=0", "developer_terms_of_service_url": "https://www.dropbox.com/s/sw8jva5kswf857u/Tribe%20VR%20Privacy%20Policy%20121420