.oculuscdn.com/v/t64.5771-25/38974495_1470589263082650_6368686439764328448_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wdAQ2cMyoXQQ7kNvgH4XYlD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBx3k8DTQLCdl7QyV8SaXmQDuVeTbikJRau3emh6NVvdg&oe=6752E1AB"}, {"file_name": "migrated_image.png", "id": "220366849050746", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974499_707742899670916_7295427879867777024_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eA10IgrQoUQQ7kNvgEKv2wk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVvxK9AAgRMSsmpkfoZQErZlnddg8KdTPmoD8vJ50_vA&oe=6752D6CB"}, {"file_name": "migrated_image.png", "id": "654641102019922", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974685_413211822650152_1417785566451204096_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lZumCqxEdo8Q7kNvgF4dzYO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArhTaXnBKPkwfcqijs9keFs-7nnU0Ph7an6huwJG7RXA&oe=6752FB06"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TribeXR DJ School", "keywords": ["Education", "Learning", "DJ", "Music"], "long_description": "Hello DJ. Welcome to your VR DJ tool. \n\nTribe XR features a fully functioning pro-style CDJ mix deck. Upload your own music and refine your own unique sound.\n\nGain access to learning resources such as video tutorials, interactive tutorials and a free 1-on-1 intro class. \n\nTurn things up a notch with 1-on-1 mentor classes with professional DJ's with our new VR mentor program (beta)\n\nPerform for friends and the world with native live-streaming integrations. We'll help you set up your own VR live-mix show with real-time support. You can even request to play a live set on Tribe XR\u2019s radio show.\n\nJoin our Discord channel and have direct access to the Tribe XR team, mentors and a passionate community of music enthusiasts.\n\nPlease note: This is an early access app and we are adding new features and refinements week by week. We only support Windows 10 at this time.", "short_description": "Hello DJ. Welcome to your VR DJ tool. \n\nTribe XR features a fully functioning pro-style CDJ mix deck. Upload your own music and refine your own unique sound."}]}, "developer_name": "Tribe XR Inc", "developer_privacy_policy_url": "https://www.dropbox.com/s/sw8jva5kswf857u/Tribe%20VR%20Privacy%20Policy%2012142017.pdf?dl=0", "developer_terms_of_service_url": "https://www.dropbox.com/s/sw8jva5kswf857u/Tribe%20VR%20Privacy%20Policy%2012142017.pdf?dl=0", "publisher_name": "Tribe XR Inc", "support_website_url": "https://discordapp.com/invite/qdhNs2U", "website_url": "https://www.tribexr.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "MUSIC", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "339262744724400"}}]}, "scheduled_offers": {"count": 26, "nodes": [{"status": "PUBLISHED", "id": "3014142328645998"}, {"status": "PENDING", "id": "760782288837801"}, {"status": "PUBLISHED", "id": "957646781352001"}, {"status": "PUBLISHED", "id": "1219107918498057"}, {"status": "PUBLISHED", "id": "745827156360977"}, {"status": "PUBLISHED", "id": "687392419899300"}, {"status": "PENDING", "id": "585880056405287"}, {"status": "PUBLISHED", "id": "571696628060672"}, {"status": "PUBLISHED", "id": "375660166987436"}, {"status": "PUBLISHED", "id": "608194589717773"}, {"status": "PENDING", "id": "11794971