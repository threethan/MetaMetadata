9031336_444598163838088_4348018161578664004_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y26qaDk31CgQ7kNvgEtdzHg&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAassIdhYBBbFS0zRFYFcjeyiEpVyGubujemA48DkfHQQ&oe=6724AA7C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "lodato-lounge.png", "id": "448983836893557", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031337_448983840226890_3233550713018161968_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V0uvBvNpxKQQ7kNvgHU3pyU&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB-dpY1VH9dEVqu_zSCg2l7qElk-jasfd30J30MQIGAQA&oe=6724C2B8"}, "display_name": "Tribe XR | \u30d0\u30fc\u30c1\u30e3\u30eb\u3067DJ", "keywords": [], "long_description": "\u30d0\u30fc\u30c1\u30e3\u30ebDJ\u306b\u306a\u308d\u3046: \u30af\u30e9\u30d6\u6a19\u6e96\u306e\u30d1\u30a4\u30aa\u30cb\u30a2DJ\u6a5f\u6750\u3067\u7df4\u7fd2\u3002DJ\u30a4\u30f3\u30b9\u30c8\u30e9\u30af\u30bf\u30fc\u306b\u3088\u308b\u30ec\u30c3\u30b9\u30f3\u3092\u53d7\u3051\u308b\u3002\u30de\u30b9\u30bf\u30fc\u30af\u30e9\u30b9\u306b\u53c2\u52a0\u3002\u4e16\u754c\u4e2d\u306eDJ\u3068\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u30e4\u30fc\u30bb\u30c3\u30b7\u30e7\u30f3\u3092\u30d7\u30ec\u30a4\u3002\u4e16\u754c\u4e2d\u306e\u30aa\u30fc\u30c7\u30a3\u30a8\u30f3\u30b9\u306b\u5411\u3051\u3066\u6f14\u594f\u3002\n\nTribe XR\u306f\u97f3\u697d\u306e\u7121\u9650\u306e\u5275\u9020\u6027\u3092\u63d0\u4f9b\u3057\u307e\u3059\n\n- CDJ-3000\u30c7\u30c3\u30ad\u3068DJM-900NXS2\u30df\u30ad\u30b5\u30fc\u3092\u542b\u3080\u516c\u5f0f\u30d1\u30a4\u30aa\u30cb\u30a2DJ\u6a5f\u6750\n- DJ Hapa\u3001\u5225\u540d\u300cDJ\u30b3\u30fc\u30c1\u300d\u306b\u3088\u308b\u6ca1\u5165\u578b\u30c1\u30e5\u30fc\u30c8\u30ea\u30a2\u30eb\u3068\u6bce\u9031\u306e\u30de\u30b9\u30bf\u30fc\u30af\u30e9\u30b9\n- Soundcloud Go\u3092\u4f7f\u7528\u3057\u3066\u3001\u81ea\u5206\u306e\u97f3\u697d\u3092\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u3057\u3001\u6570\u767e\u4e07\u306e\u30c8\u30e9\u30c3\u30af\u306b\u30a2\u30af\u30bb\u30b9\n- \u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u30e1\u30f3\u30d0\u30fc\u306e\u30eb\u30fc\u30e0\u306b\u53c2\u52a0\u3057\u3066\u3001\u65b0\u3057\u3044\u97f3\u697d\u3092\u767a\u898b\n- \u30e9\u30a4\u30d6\u30b9\u30c8\u30ea\u30fc\u30df\u30f3\u30b0\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u3067\u6f14\u594f\n- Altspace\u3068Sansar\u3067\u6bce\u9031\u958b\u50ac\u3055\u308c\u308b\u30a4\u30d9\u30f3\u30c8\u3067\u30d1\u30fc\u30c6\u30a3\u30fc\u306b\u53c2\u52a0\n\n\u3055\u3042\u3001Tribe Plus\u306e\u30aa\u30d7\u30b7\u30e7\u30f3\u306e\u30e1\u30f3\u30d0\u30fc\u30b7\u30c3\u30d7\uff08$4.99/\u6708\uff09\u3067DJ\u30b9\u30ad\u30eb\u3092\u6b21\u306e\u30ec\u30d9\u30eb\u306b\u5f15\u304d\u4e0a\u3052\u307e\u3057\u3087\u3046\u3002\u30e1\u30f3\u30d0\u30fc\u30b7\u30c3\u30d7\u306b\u3088\u308a\u3001\u73fe\u5728\u306e\u3059\u3079\u3066\u306eTribe DLC\uff08\u74b0\u5883\u3001\u30b9\u30ad\u30eb\u3001\u97f3\u697d\uff09\u3001\u9650\u5b9a\u30ec\u30c3\u30b9\u30f3\u3068\u9ad8\u5ea6\u306a\u30de\u30b9\u30bf\u30fc\u30af\u30e9\u30b9\u3001\u304a\u3088\u3073\u7d4c\u9a13\u8c4a\u5bcc\u306aDJ\u30e1\u30f3\u30bf\u30fc\u306b\u3088\u308b\u512a\u5148\u7684\u306a\u30e9\u30a4\u30d6\u30b5\u30dd\u30fc\u30c8\u306b\u30a2\u30af\u30bb\u30b9\u53ef\u80fd\u3067\u3059\u3002\n\nDiscord\uff08www.tribexr.chat\uff09\u306e\u4f1a\u8a71\u306b\u53c2\u52a0\u3002\u4eca\u3059\u3050DJ\u306e\u65c5\u3092\u59cb\u3081\u3088\u3046\uff01", "short_description": "\u30d0\u30fc\u30c1\u30e3\u30ebDJ\u306b\u306a\u308d\u3046: \u30af\u30e9\u30d6\u6a19\u6e96\u306e\u30d1\u30a4\u30aa\u30cb\u30a2DJ\u6a5f\u6750\u3067\u7df4\u7fd2\u3002DJ\u30a4\u30f3\u30b9\u30c8\u30e9\u30af\u30bf\u30fc\u306b\u3088\u308b\u30ec\u30c3\u30b9\u30f3\u3092\u53d7\u3051\u308b\u3002\u30de\u30b9\u30bf\u30fc\u30af\u30e9\u30b9\u306b\u53c2\u52a0\u3002\u4e16\u754c\u4e2d\u306eDJ\u3068\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u30e4\u30fc\u30bb\u30c3\u30b7\u30e7\u30f3\u3092\u30d7\u30ec\u30a4\u3002\u4e16\u754c\u4e2d\u306e\u30aa\u30fc\u30c7\u30a3\u30a8\u30f3\u30b9\u306b\u5411\u3051\u3066\u6f