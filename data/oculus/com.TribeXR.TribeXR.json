5382789861834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_dISvJcu7SQQ7kNvgESd1iU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCyzQ0xk3D8MZXONxB6MlQlfVOq1BhAHG8P6lCqTdq0Q&oe=67236341"}, {"file_name": "pioneer 4 decks back view.png", "id": "139101134767652", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974634_139101138100985_5389864266480074781_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RyAhSu0yGpwQ7kNvgFAMbRW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCO-cLnemAsHh7AYuwNdNG0hnHpervkmb5haEZUEAEf7A&oe=67235F72"}, {"file_name": "Pioneer Promo Trailer 4 (Time 0_00_40;10).png", "id": "760455537892993", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001728_760455541226326_7584349665419219214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xzjxAJ4u5EUQ7kNvgEhq4fn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfJt9zmMnThCYiPP90qdgDRlt2_RyLRmx4SLfNQpNTVQ&oe=67236087"}, {"file_name": "lessons menu.png", "id": "572196314734291", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982512_572196321400957_2125003273257883232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NYiIKMUcmzYQ7kNvgHX32Lm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3ICASAbHo6PX7lne3v18Tk5lcVycW7kQ_vIhGZ_gnsA&oe=67237DCF"}, {"file_name": "Vinyl_OneDeck_Record_1.png", "id": "241240560836984", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982483_241240570836983_4041723412206166416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XSvtPaq8CxAQ7kNvgHaWDrl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCiyFLZz0M9SAqS0AOViKipTRDZIMOcJg2ksWX4TioCKA&oe=672370E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "6245316808924812", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982694_6245316812258145_9171284627882694461_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qfKt9cfDbIQQ7kNvgG8MBDU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4dHygQQMolJ0uIPIDD98ChmBYqcE4YfykBC5m9Q_cCw&oe=6723576D"}, "display_name": "Tribe XR | DJ Academy", "keywords": ["Social", "Casual", "DJ", "Music", "Free"], "long_description": "Become a DJ! Play on official Pioneer DJ equipment. Learn from the masters at the Pete Tong DJ Academy. Join daily workshops. Connect with the community. Perform to the world.\n\nSubscribe for your free 7-day trial:\n- Play on official Pioneer DJ equipment\n- Learn from the masters at the Pete Tong DJ Academy.\n- Load your own music - including via Dropbox\n- Access tracks from Beatport, Monstercat, TIDAL & Soundcloud Go+\n- Join live workshops - more than 30 per week\n- Level up your skills with game mode tutorials\n- Livestream to Twitch directly from your Meta Quest\n- Join multiplayer rooms and jam together\n\nIf you decide to cancel, no worries, you can keep mixing with a free, limited version of Tribe.\n- Play with the starter decks\n- Mix up to 5 tracks per session\n- Join multiplayer sessions\n- Continue learning with the 5 day DJ challenge\nYou can always re-subscribe when you\u2019re ready.\n\nJoin the community on Discord | discord.gg/tribexr\n\nStart your DJ journey today!", "short_description": "Become a DJ! Play on official Pioneer DJ equipment. Learn from the masters at the Pete Tong DJ Academy. Join daily workshops. Connect with the community. Perform to the world.\n\nSubscribe for your free 7-day trial:\n- Play on official Pioneer DJ equipment\n- Learn from the masters at the Pete Tong DJ Academy\n- Load your own music - including via Dropbox\n- Access tracks from Beatport, Monstercat & Soundcloud Go+\n- Join live workshops & multiplayer rooms\n- Livestream to Twitch\n- Cancel anytime"}]}, "developer_name": "Tribe XR Inc", "developer_privacy_policy_url": "https://www.tribexr.com/privacy-policy", "developer_terms_of_service_url": "https://www.tribexr.com/terms-of-service", "publisher_name": "Tribe XR Inc", "support_website_url": null, "website_url": "https://www.tribexr.com/", "catego