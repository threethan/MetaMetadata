o Trailer 4 (Time 0_00_40;10).png", "id": "760455537892993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001728_760455541226326_7584349665419219214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H-0d7wkIXGMQ7kNvgH_tDC3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKrWsVNlZxgKsYfJdGBZVYMwzISIls8RsjBui7QSdbnA&oe=66E56A07"}, {"file_name": "lessons menu.png", "id": "572196314734291", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_572196321400957_2125003273257883232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2jvI9TwlvyYQ7kNvgFrYvlT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtW-ypv-b0l0nVs3Qap1ksg_t5ml29VVoxtZaV8XAlBg&oe=66E5874F"}, {"file_name": "Vinyl_OneDeck_Record_1.png", "id": "241240560836984", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982483_241240570836983_4041723412206166416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zwXBvmUq92UQ7kNvgEXSZdQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsGod3173jSq08lEQ7Sbf0Uxy1KPqlYXtdWFvx2ibJfQ&oe=66E57A64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "6245316808924812", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982694_6245316812258145_9171284627882694461_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YmkpnFD8hp4Q7kNvgGdoB01&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwNIQTXMDpCQsOhgeFR2XB8b8ReEurRniHOLV6C19dwA&oe=66E560ED"}, "display_name": "Tribe XR | DJ Academy", "keywords": ["Social", "Casual", "DJ", "Music", "Free"], "long_description": "Become a DJ! Play on official Pioneer DJ equipment. Learn from the masters at the Pete Tong DJ Academy. Join daily workshops. Connect with the community. Perform to the world.\n\nSubscribe for your free 7-day trial:\n- Play on official Pioneer DJ equipment\n- Learn from the masters at the Pete Tong DJ Academy.\n- Load your own music - including via Dropbox\n- Access tracks from Beatport, Monstercat, TIDAL & Soundcloud Go+\n- Join live workshops - more than 30 per week\n- Level up your skills with game mode tutorials\n- Livestream to Twitch directly from your Meta Quest\n- Join multiplayer rooms and jam together\n\nIf you decide to cancel, no worries, you can keep mixing with a free, limited version of Tribe.\n- Play with the starter decks\n- Mix up to 5 tracks per session\n- Join multiplayer sessions\n- Continue learning with the 5 day DJ challenge\nYou can always re-subscribe when you\u2019re ready.\n\nJoin the community on Discord | discord.gg/tribexr\n\nStart your DJ journey today!", "short_description": "Become a DJ! Play on official Pioneer DJ equipment. Learn from the masters at the Pete Tong DJ Academy. Join daily workshops. Connect with the community. Perform to the world.\n\nSubscribe for your free 7-day trial:\n- Play on official Pioneer DJ equipment\n- Learn from the masters at the Pete Tong DJ Academy\n- Load your own music - including via Dropbox\n- Access tracks from Beatport, Monstercat & Soundcloud Go+\n- Join live workshops & multiplayer rooms\n- Livestream to Twitch\n- Cancel anytime"}]}, "developer_name": "Tribe XR Inc", "developer_privacy_policy_url": "https://www.tribexr.com/privacy-policy", "developer_terms_of_service_url": "https://www.tribexr.com/terms-of-service", "publisher_name": "Tribe XR Inc", "support_website_url": null, "website_url": "https://www.tribexr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "MUSIC", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "de", "fr", "zh_CN", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "