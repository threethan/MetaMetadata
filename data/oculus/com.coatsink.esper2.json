uluscdn.com/v/t64.5771-25/12138956_943674482388488_1585284624_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dXQagjUhk9UQ7kNvgGKu2-5&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhnzBXcescFS4Q7mVqMj0MuGxXgzT1XHSWMPYnSwao2Q&oe=6713A667"}, {"file_name": "migrated_image.png", "id": "2621831821470831", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12138906_509470305893641_385075339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VybtOT4_sPgQ7kNvgFyyMy6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfGRPrt3Xivq9Jq-znJ5HDc7hO8VbEKO4ANGvFQhGkCA&oe=6713ACBA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Esper 2", "keywords": [], "long_description": "Have you ever dreamed about moving things with your mind? What would you do with such power? Here's what we would do.\n\nEsper 2 is a game about using telekinetic powers to solve puzzles.\n\nReprising your role from the previous game, take up your new job as an agent of ESPR, an organization set up to deal with the recent outbreak of telekinetic powers among citizens.\n\nTravel to exotic locations; solve puzzles, discover secrets, stop villainous plots, and fall unconscious, multiple times.\n\nWith an All-star cast, interact with a dynamic array of new characters, voiced by notable actors, NickFrost, Lara Pulver, and Sean Pertwee, who join Eric Meyers, the esteemed vocal talent from the original game.\n\nSolve a wide range of unique and intuitive puzzles, while trying not to aggravate the game's characters, because they'll let you know if you do.\n\nGood luck.", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Coatsink Software", "support_website_url": null, "website_url": "http://esper2.coatsink.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["PUZZLE