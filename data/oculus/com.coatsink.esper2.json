_ohc=FOhfbMPcF24Q7kNvgFiOiI9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdlURdN0fKoIIM-xZv9_w8&oh=00_AYA3uNAq3xb3CoKLmPfIBFef5-CRagf32tr4AkHJ9OBHWA&oe=66F29458"}, {"file_name": "migrated_image.png", "id": "317970062496183", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138956_943674482388488_1585284624_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=azI7LszjmGUQ7kNvgEvzFaX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdlURdN0fKoIIM-xZv9_w8&oh=00_AYBMoEmw2Fq-PeHQp5vP6cfac_iPDyr7t_xSlSBCbJ_ujQ&oe=66F2B0E7"}, {"file_name": "migrated_image.png", "id": "2621831821470831", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138906_509470305893641_385075339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2xKh-hVQlMAQ7kNvgGGQlgO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdlURdN0fKoIIM-xZv9_w8&oh=00_AYBh8t8oPhiciUuxzslTKknK1GR7SLArC4GwtPTtKv0GUA&oe=66F2B73A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Esper 2", "keywords": [], "long_description": "Have you ever dreamed about moving things with your mind? What would you do with such power? Here's what we would do.\n\nEsper 2 is a game about using telekinetic powers to solve puzzles.\n\nReprising your role from the previous game, take up your new job as an agent of ESPR, an organization set up to deal with the recent outbreak of telekinetic powers among citizens.\n\nTravel to exotic locations; solve puzzles, discover secrets, stop villainous plots, and fall unconscious, multiple times.\n\nWith an All-star cast, interact with a dynamic array of new characters, voiced by notable actors, NickFrost, Lara Pulver, and Sean Pertwee, who join Eric Meyers, the esteemed vocal talent from the original game.\n\nSolve a wide range of unique and intuitive puzzles, while trying not to aggravate the game's characters, because they'll let you know if you do.\n\nGood luck.", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publishe