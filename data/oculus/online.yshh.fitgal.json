3002_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d1R7MAzVYSwQ7kNvgEe9mTr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAG_gGp50ccg-hX1izp7Wof0A53Z9eJXC_Mj5hTRvvw3Q&oe=676FF77A"}, {"file_name": "Shot_240528_173013_1440p.png", "id": "1901433086934619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974706_1901433090267952_1508572176858237032_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAjuoKWQFZUQ7kNvgH0QhEK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAy4mD3-q4tQUrFEYfpIzy4DClI6Uq2Rh1stn2a9wn7kg&oe=676FDDB4"}, {"file_name": "Shot_240528_173051_1440.png", "id": "1198065611361609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974774_1198065614694942_7118646447602808120_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XAblCNNuE2gQ7kNvgG9OOrx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDG917Kd7CZcEMgB8uQnU4geJvUcdkHMMPvWmm4liSZZg&oe=676FDFBE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Home.en.png", "id": "576049255038215", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982501_576049258371548_1112830279062405790_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gm4Zke4wNcgQ7kNvgF7cwsr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEFoiKINj31sc2jwah0mjUN93XgT3pMlYuIMJmjHggHw&oe=676FD275"}, "display_name": "Fitness GAL", "keywords": [], "long_description": "\"Fitness GAL - Sweat for Better World\" is a VR application that blends boxing, music aerobics, and character development. Players become aspiring top boxers, working with a charming coach to tackle challenges and chase their dreams.\n\n## Game Features:\nBoxing and Music Aerobics Fusion:\nThis unique combination lets players punch to the rhythm, enjoy aerobic fitness, and promote weight loss.\n\n## Track Fitness Progress:\nA built-in fitness log lets players record their workout results and plans, tracking progress and staying motivated.\n\n## Charming Coach Guidance:\nPlayers receive guidance from a beautiful boxing coach who helps improve techniques and offers encouragement.\n\n## Challenges and Growth:\nCompleting challenges and tasks enhances boxing skills and fitness, helping players grow into top boxers, win matches, and earn honors.\n\n## Future Updates:\nFuture versions will introduce player vs. player and virtual character challenges, allowing competitive duels to determine the strongest boxer. Various modes, including training, character development, and competition, will cater to diverse player preferences.\n\n## Conclusion:\n\"Fitness GAL - Sweat for Better World\" is a VR app that helps players exercise and learn boxing techniques while embarking on a dream-filled adventure. Work with your charming coach to pursue your dreams and become a true boxing champion!", "short_description": "\"Fitness GAL - Sweat for Better World\" is a VR APP combining boxing, music aerobics and character development. It aims to help beginners exercise and learn boxing skills. \n\nThe current version allows custom uploading songs to the Music directory to create courses. \nSupports both VR and MR modes."}, {"images": {"nodes": [{"file_name": "\u5faa\u73af\u80cc\u666f3000x900.2.png", "id": "4016305178606734", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001725_4016305181940067_862577479802112960_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yypFYBfCOX8Q7kNvgFDTYGh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQ1tGiT5vnFAlkyCdMPcdDxhKU4bvHubt2nphE8wsAbg&oe=676FD4C5"}, {"file_name": "AppIcon2.png", "id": "4012771179002357", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001733_4012771182335690_8085606912754985253_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FQVuR5mBG1AQ7kNvgFgFrZj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCnC8yRxFp7xdFFsw4_hLZ6t6cPeCvXV2tVs0wAhXW5bQ&oe=676FF7C8"}, {"file_name": "\u5ba3\u4f20\u56fe 2560x1440.CN.png", "id": "3749184908682237", "im