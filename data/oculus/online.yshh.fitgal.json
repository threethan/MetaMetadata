n.com/v/t64.5771-25/39031454_1337645897399338_1180166269757474775_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KVFgyJWr0eEQ7kNvgFSG3M-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBRHeDNrcgsFoYd1w6jO4t0GftqKfVc_2QnzlzDFJsMnQ&oe=67712E0B"}, {"file_name": "Shot_240528_172351_1440p.png", "id": "1131546951404500", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982534_1131546954737833_7839765282699873002_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jp-r3-M2FQ4Q7kNvgEEfPi7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfp1whP-H_Eah5T7dLkhTma4HoyCoPKHBHUOWw9Jskcg&oe=677148FA"}, {"file_name": "Shot_240528_173013_1440p.png", "id": "1901433086934619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974706_1901433090267952_1508572176858237032_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAjuoKWQFZUQ7kNvgHy54cf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVkd5kdU9dVZkf63B8U-AbPqRqJEZ6rCLi89pUAvmjig&oe=67712F34"}, {"file_name": "Shot_240528_173051_1440.png", "id": "1198065611361609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974774_1198065614694942_7118646447602808120_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XAblCNNuE2gQ7kNvgHu-L6G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXeUiYaOdRX5MAK6pNNh4V0T1qFlRHnuIrG_BswJ_OoA&oe=6771313E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Shot_240528_172326_1440p.png", "id": "484070057483737", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75222940_484070060817070_368588685870034517_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EaI2QckCY68Q7kNvgF3Yt00&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDpuiPSWzCeXbisLFqOw7BqhUvixSkQFDLFNmRfpxkjGA&oe=67712525"}, "display_name": "Fitness GAL - Sweat for Better World", "keywords": [], "long_description": "\"Fitness GAL - Sweat for Better World\" is a VR application that blends boxing, music aerobics, and character development. Players become aspiring top boxers, working with a charming coach to tackle challenges and chase their dreams.\n\n## Game Features:\nBoxing and Music Aerobics Fusion:\nThis unique combination lets players punch to the rhythm, enjoy aerobic fitness, and promote weight loss.\n\n## Track Fitness Progress:\nA built-in fitness log lets players record their workout results and plans, tracking progress and staying motivated.\n\n## Charming Coach Guidance:\nPlayers receive guidance from a beautiful boxing coach who helps improve techniques and offers encouragement.\n\n## Challenges and Growth:\nCompleting challenges and tasks enhances boxing skills and fitness, helping players grow into top boxers, win matches, and earn honors.\n\n## Future Updates:\nFuture versions will introduce player vs. player and virtual character challenges, allowing competitive duels to determine the strongest boxer. Various modes, including training, character development, and competition, will cater to diverse player preferences.\n\n## Conclusion:\n\"Fitness GAL - Sweat for Better World\" is a VR app that helps players exercise and learn boxing techniques while embarking on a dream-filled adventure. Work with your charming coach to pursue your dreams and become a true boxing champion!", "short_description": "Currently only available in Chinese version\n\n\"Fitness GAL - Sweat for Better World\" is a VR app that combines boxing, music aerobics, and character development, designed for beginners to exercise and learn boxing techniques. Train with a cute coach, follow the rhythm of the music, and enjoy the fun of working out. Whether you're a beginner or an experienced practitioner, you can find challenges that suit you.\n\nThe current version is an [Early Preview], offering three introductory courses and s"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.yshh.online/FitnessGAL_PrivacyPolicy_CN.htm", "developer_terms_of_service_url": null, "publisher_name": "Unity", "support_website_url": null, "webs