file_name": "Shot_240528_173051_1440.png", "id": "1198065611361609", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974774_1198065614694942_7118646447602808120_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y9xFxgPWMqIQ7kNvgEFzrGh&_nc_ht=scontent.oculuscdn.com&oh=00_AYBF8XPp5XZL-WMutJ6oogmEgIkgKNNC9ZtnIDdRwTGXMQ&oe=66D8433E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Shot_240528_172326_1440p.png", "id": "484070057483737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222940_484070060817070_368588685870034517_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CHlZECAoDbMQ7kNvgFHzs2A&_nc_ht=scontent.oculuscdn.com&oh=00_AYBibrxuPK1in5adH42JZnrkqd-q9u4hJQOL5qFXYmxOLQ&oe=66D83725"}, "display_name": "Fitness GAL - Sweat for Better World", "keywords": [], "long_description": "\"Fitness GAL - Sweat for Better World\" is a VR application that blends boxing, music aerobics, and character development. Players become aspiring top boxers, working with a charming coach to tackle challenges and chase their dreams.\n\n## Game Features:\nBoxing and Music Aerobics Fusion:\nThis unique combination lets players punch to the rhythm, enjoy aerobic fitness, and promote weight loss.\n\n## Track Fitness Progress:\nA built-in fitness log lets players record their workout results and plans, tracking progress and staying motivated.\n\n## Charming Coach Guidance:\nPlayers receive guidance from a beautiful boxing coach who helps improve techniques and offers encouragement.\n\n## Challenges and Growth:\nCompleting challenges and tasks enhances boxing skills and fitness, helping players grow into top boxers, win matches, and earn honors.\n\n## Future Updates:\nFuture versions will introduce player vs. player and virtual character challenges, allowing competitive duels to determine the strongest boxer. Various modes, including training, character development, and competition, will cater to diverse player preferences.\n\n## Conclusion:\n\"Fitness GAL - Sweat for Better World\" is a VR app that helps players exercise and learn boxing techniques while embarking on a dream-filled adventure. Work with your charming coach to pursue your dreams and become a true boxing champion!", "short_description": "Currently only available in Chinese version\n\n\"Fitness GAL - Sweat for Better World\" is a VR app that combines boxing, music aerobics, and character development, designed for beginners to exercise and learn boxing techniques. Train with a cute coach, follow the rhythm of the music, and enjoy the fun of working out. Whether you're a beginner or an experienced practitioner, you can find challenges that suit you.\n\nThe current version is an [Early Preview], offering three introductory courses and s"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.yshh.online/FitnessGAL_PrivacyPolicy_CN.htm", "developer_terms_of_service_url": null, "publisher_name": "Unity", "support_website_url": null, "website_url": "http://www.yshh.online/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["zh_CN"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7686131908132575"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "442597755161150"}]}, "baseline_offer": {"id": "442597755161150"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718234878, "status": "PUBLISHED", "i