ame": "Shot_240528_172351_1440p.png", "id": "3596989780518393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974905_3596989783851726_5129173124705318676_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TqOzQF7xE9YQ7kNvgGCH4aJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBL0g26uArGjU93ZsH6ca_QxoHgm9h4Ww8EgkelWrhk9w&oe=66D8318A"}, {"file_name": "Shot_240528_173051_1440.png", "id": "387013851023062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035376_387013854356395_5730230868591453623_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g_lB3vmilaUQ7kNvgF38dq4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXc9dUMCidtwkiF81krPZQbvub9gzE4-2lX-yA2uKGtA&oe=66D830C6"}, {"file_name": "Shot_240528_173013_1440p.png", "id": "973604117592626", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982616_973604120925959_8720242712649891432_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TM-aHFuwqIMQ7kNvgGCr7ZK&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtq9fsCNM3YwOMgPOiPl28Ra1AtAx4kaXz0yplsklXgA&oe=66D84029"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Shot_240528_172439_1440p.png", "id": "1008686340816812", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75280981_1008686344150145_1004010568402398125_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nADP4bIUot0Q7kNvgH-X3wq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmpmYLbYIJkJ9uq5KoE1csIMNrw7ZEj8RfCnprdp20fw&oe=66D857EC"}, "display_name": "Fitness GAL - \u4e3a\u7f8e\u597d\u4e16\u754c\u732e\u4e0a\u6c57\u6c34", "keywords": [], "long_description": "\u300eFitness GAL - \u4e3a\u7f8e\u597d\u4e16\u754c\u732e\u4e0a\u6c57\u6c34\u300f\u662f\u4e00\u6b3e\u7ed3\u5408\u4e86\u62f3\u51fb\u8fd0\u52a8\u3001\u97f3\u4e50\u6709\u6c27\u4e0e\u89d2\u8272\u517b\u6210\u7684VR\u5e94\u7528\u7a0b\u5e8f\u3002\u5728\u8fd9\u4e2a\u865a\u62df\u4e16\u754c\u91cc\uff0c\u73a9\u5bb6\u5c06\u626e\u6f14\u4e00\u4f4d\u6e34\u671b\u6210\u4e3a\u9876\u5c16\u62f3\u51fb\u624b\u7684\u9009\u624b\uff0c\u4e0e\u7f8e\u5c11\u5973\u6559\u7ec3\u4e00\u8d77\uff0c\u8fbe\u6210\u5404\u79cd\u6311\u6218\uff0c\u8ffd\u9010\u68a6\u60f3\u7684\u6545\u4e8b\u3002\n\n\u6e38\u620f\u7279\u8272\uff1a\n\n\u62f3\u51fb\u4e0e\u97f3\u4e50\u6709\u6c27\u7684\u5b8c\u7f8e\u7ed3\u5408\uff1a\u72ec\u7279\u5730\u5c06\u62f3\u51fb\u8fd0\u52a8\u4e0e\u97f3\u4e50\u6709\u6c27\u76f8\u7ed3\u5408\uff0c\u8ba9\u73a9\u5bb6\u5728\u8ddf\u968f\u97f3\u4e50\u7684\u8282\u594f\u4e2d\uff0c\u6325\u821e\u62f3\u5934\uff0c\u91ca\u653e\u6fc0\u60c5\uff0c\u4eab\u53d7\u6709\u6c27\u5065\u8eab\u7684\u4e50\u8da3\uff0c\u4fc3\u8fdb\u51cf\u80a5\u71c3\u8102\u3002\n\n\u8bb0\u5f55\u8fd0\u52a8\u6210\u679c\uff1a\u6e38\u620f\u5185\u7f6e\u8fd0\u52a8\u65e5\u5fd7\u529f\u80fd\uff0c\u73a9\u5bb6\u53ef\u4ee5\u968f\u65f6\u8bb0\u5f55\u81ea\u5df1\u7684\u8fd0\u52a8\u6210\u679c\u548c\u5065\u8eab\u8ba1\u5212\uff0c\u76d1\u7763\u81ea\u5df1\u7684\u5065\u8eab\u8fdb\u5ea6\uff0c\u6fc0\u52b1\u81ea\u5df1\u575a\u6301\u953b\u70bc\u3002\n\n\u7f8e\u5c11\u5973\u6559\u7ec3\u7684\u6307\u5bfc\uff1a\u5728\u6e38\u620f\u4e2d\uff0c\u73a9\u5bb6\u5c06\u9047\u5230\u7f8e\u8c8c\u52a8\u4eba\u7684\u62f3\u51fb\u6559\u7ec3\uff0c\u5979\u5c06\u6210\u4e3a\u4f60\u7684\u826f\u5e08\u76ca\u53cb\uff0c\u6307\u5bfc\u4f60\u8fdb\u884c\u5404\u79cd\u62f3\u51fb\u52a8\u4f5c\u548c\u8bad\u7ec3\uff0c\u4e0d\u4ec5\u63d0\u9ad8\u6280\u672f\u6c34\u5e73\uff0c\u8fd8\u4e3a\u4f60\u52a0\u6cb9\u9f13\u52b2\u3002\n\n\u6311\u6218\u4e0e\u6210\u957f\uff1a\u901a\u8fc7\u5b8c\u6210\u5404\u79cd\u6311\u6218\u548c\u4efb\u52a1\uff0c\u73a9\u5bb6\u53ef\u4ee5\u4e0d\u65ad\u63d0\u5347\u81ea\u5df1\u7684\u62f3\u51fb\u6280\u80fd\u548c\u8eab\u4f53\u7d20\u8d28\uff0c\u9010\u6b65\u6210\u957f\u4e3a\u4e00\u540d\u9876\u5c16\u7684\u62f3\u51fb\u624b\uff0c\u8d62\u5f97\u6bd4\u8d5b\u548c\u8363\u8a89\u3002\n\n\u540e\u671f\u7248\u672c\u66f4\u65b0\uff1a\n\n\u5728\u6e38\u620f\u7684\u540e\u671f\u7248\u672c\u4e2d\uff0c\u6211\u4eec\u5c06\u589e\u52a0\u73a9\u5bb6\u95f4\u4e0e\u865a\u62df\u89d2\u8272\u7684\u6311\u6218\uff0c\u8ba9\u73a9\u5bb6\u53ef\u4ee5\u4e0e\u5176\u4ed6\u73a9\u5bb6\u5c55\u5f00\u523a\u6fc0\u7684\u5bf9\u51b3\uff0c\u5171\u540c\u7ade\u4e89\u6210\u4e3a\u6700\u5f3a\u7684\u62f3\u51fb\u624b\uff01\n\n\u6e38\u620f\u540e\u7eed\u4f1a\u62e5\u6709\u4e30\u5bcc\u591a\u6837\u7684\u6e38\u620f\u6a21\u5f0f\uff0c\u5305\u62ec\u8bad\u7ec3\u6a21\u5f0f\u3001\u89d2\u8272\u517b\u6210\u3001\u6bd4\u8d5b\u6a21\u5f0f\u7b49\uff0c\u6ee1\u8db3\u4e0d\u540c\u73a9\u5bb6\u7684\u9700\u6c42\u548c\u559c\u597d\u3002\n\n\u7ed3\u8bed\uff1a\n\n\u300eFitness GAL - \u4e3a\u7f8e\u597d\u4e16\u754c\u732e\u4e0a\u6c57\u6c34\u300f\u4e0d\u4ec5\u662f\u4e00\u6b3e\u80fd\u591f\u5e2e\u52a9\u73a9\u5bb6\u953b\u70bc\u8eab\u4f53\u3001\u5b66\u4e60\u62f3\u51fb\u6280\u5de7\u7684VR\u5e94\u7528\u7a0b\u5e8f\uff0c\u66f4\u662f\u4e00\u573a\u5145\u6ee1\u68a6\u60f3\u4e0e\u6311\u6218\u7684\u5192\u9669\u4e4b\u65c5\u3002\u5728\u8fd9\u91cc\uff0c\u4f60\u5c06\u4e0e\u7f8e\u5c11\u5973\u6559\u7ec3\u4e00\u8d77\uff0c\u5171\u540c\u52aa\u529b\uff0c\u8ffd\u9010\u68a6\u60f3\uff0c\u6210\u4e3a\u4e00\u540d\u771f\u6b63\u7684\u62f3\u51fb\u51a0\u519b\uff01", "short_description": "\u300eFitness GAL - \u4e3a\u7f8e\u597d\u4e16\u754c\u732e\u4e0a\u6c57\u6c34\u300f\u662f\u4e00\u6b3e\u7ed3\u5408\u4e86\u62f3\u51fb\u8fd0\u52a8\u3001\u97f3\u4e50\u6709\u6c27\u4e0e\u89d2\u8272\u517b\u6210\u7684VR APP\uff0c\u65e8\u5728\u521d\u5b66\u8005\u953b\u70bc\u8eab\u4f53\u3001\u5b66\u4e60\u62f3\u51fb\u6280\u5de7\u3002\u4e0e\u7f8e\u5c11\u5973\u6559\u7ec3\u4e00\u8d77\uff0c\u8ddf\u968f\u97f3\u4e50\u8282\u594f\uff0c\u4eab\u53d7\u8fd0\u52a8\u4e50\u8da3\u3002\u65e0\u8bba\u60a8\u662f\u521d\u5b66\u8005\u8fd8\u662f\u6709\u7ecf\u9a8c\u8005\uff0c\u90fd\u80fd\u5728\u6b64\u627e\u5230\u9002\u5408\u81ea\u5df1\u7684\u6311\u6218\u3002\n\u5f53\u524d\u7248\u672c\u4e3a[\u5148\u884c\u9884\u89c8\u7248]\uff0c\u63d0\u4f9b\u4e09\u8282\u5165\u95e8\u8bfe\u7a0b\uff0c\u652f\u6301VR\u624b\u67c4\u4e0e\u624b\u52bf\u8bc6\u522b\u4e24\u79cd\u8f93\u5165\u6a21\u5f0f\u3002"}, {"images": {"nodes": [{"file_name": "\u5ba3\u4f20\u56fe 1008x1440_EN.png", "id": "2194243844260822", "image_type": "APP_IMG_COVER_