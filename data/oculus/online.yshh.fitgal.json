n.com/v/t64.5771-25/39031454_1337645897399338_1180166269757474775_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KVFgyJWr0eEQ7kNvgGGADID&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDY3oNUykFhoBky1SfaOnkYJpVQzof7l9aCy3PCByXTuw&oe=676FDC8B"}, {"file_name": "Shot_240528_172351_1440p.png", "id": "1131546951404500", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982534_1131546954737833_7839765282699873002_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d1R7MAzVYSwQ7kNvgEe9mTr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAG_gGp50ccg-hX1izp7Wof0A53Z9eJXC_Mj5hTRvvw3Q&oe=676FF77A"}, {"file_name": "Shot_240528_173013_1440p.png", "id": "1901433086934619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974706_1901433090267952_1508572176858237032_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAjuoKWQFZUQ7kNvgH0QhEK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAy4mD3-q4tQUrFEYfpIzy4DClI6Uq2Rh1stn2a9wn7kg&oe=676FDDB4"}, {"file_name": "Shot_240528_173051_1440.png", "id": "1198065611361609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974774_1198065614694942_7118646447602808120_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XAblCNNuE2gQ7kNvgG9OOrx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDG917Kd7CZcEMgB8uQnU4geJvUcdkHMMPvWmm4liSZZg&oe=676FDFBE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Shot_240528_172326_1440p.png", "id": "484070057483737", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75222940_484070060817070_368588685870034517_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EaI2QckCY68Q7kNvgGagsy2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAPkN0ighL1hCgFORFmM9LNqbZq-uOIYqRQ3IpT7YRuuA&oe=676FD3A5"}, "display_name": "Fitness GAL - Sweat for Better World", "keywords": [], "long_description": "\"Fitness GAL - Sweat for Better World\" is a VR application that blends boxing, music aerobics, and character development. Players become aspiring top boxers, working with a charming coach to tackle challenges and chase their dreams.\n\n## Game Features:\nBoxing and Music Aerobics Fusion:\nThis unique combination lets players punch to the rhythm, enjoy aerobic fitness, and promote weight loss.\n\n## Track Fitness Progress:\nA built-in fitness log lets players record their workout results and plans, tracking progress and staying motivated.\n\n## Charming Coach Guidance:\nPlayers receive guidance from a beautiful boxing coach who helps improve techniques and offers encouragement.\n\n## Challenges and Growth:\nCompleting challenges and tasks enhances boxing skills and fitness, helping players grow into top boxers, win matches, and earn honors.\n\n## Future Updates:\nFuture versions will introduce player vs. player and virtual character challenges, allowing competitive duels to determine the strongest boxer. Various modes, including training, character development, and competition, will cater to diverse player preferences.\n\n## Conclusion:\n\"Fitness GAL - Sweat for Better World\" is a VR app that helps players exercise and learn boxing techniques while embarking on a dream-filled adventure. Work with your charming coach to pursue your dreams and become a true boxing champion!", "short_description": "Currently only available in Chinese version\n\n\"Fitness GAL - Sweat for Better World\" is a VR app that combines boxing, music aerobics, and character development, designed for beginners to exercise and learn boxing techniques. Train with a cute coach, follow the rhythm of the music, and enjoy the fun of working out. Whether you're a beginner or an experienced practitioner, you can find challenges that suit you.\n\nThe current version is an [Early Preview], offering three introductory courses and s"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.yshh.online/FitnessGAL_PrivacyPolicy_CN.htm", "developer_terms_of_service_url": null, "publisher_name": "Unity", "support_website_url": null, "webs