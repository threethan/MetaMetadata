875983960914099_8227713871906043994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p8w-ThncE3wQ7kNvgGdRuTo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxrc9fNKt3bTlwS0JeDDgsaSchRT6r0G2jZthIlmGmnA&oe=67484FAC"}, {"file_name": "\u5927\u5c4f\u4e2d\u6253\u5f00-2.png", "id": "1074932140364575", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982614_1074932143697908_8640490028585238856_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Br0fHvFiEWAQ7kNvgEi84tn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLmOG3wQDv5zbJCDrVjFzn8CSeAHJBGpiIfgeDUqxsvA&oe=6748544D"}, {"file_name": "\u5927\u5c4f-\u56fe\u6807hover.png", "id": "303826915992796", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982520_303826919326129_8457695805905389916_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kKBAwVxFJtUQ7kNvgF2hjbh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDz_Pt6_Y5zAJzR4mbGHTO15ePujI4P02rB9SEgXDcxNA&oe=67485AF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Frame 173.png", "id": "2322942504568305", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001703_2322942507901638_5394063600685763621_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UpQOGU9HGQ4Q7kNvgFV73Bs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBMXKjAkx4ohvJP0tQz2w1hJIoHH31nYE4SzAN8xVS6gA&oe=67484435"}, "display_name": "SuperScreen", "keywords": [], "long_description": "Super Screen offers VR users a unique and immersive viewing experience. This application creates virtual environments such as cinemas and classrooms within VR, offering users a mixed reality (MR) experience that blends the virtual and real worlds. It supports various video formats including 2D, 3D, 180-degree, and 360-degree videos, and can play videos in resolutions up to 8K, ensuring an ultimate visual experience. Users can also conveniently share media files from computers within the same local area network to their VR devices. Currently, the video formats are limited to mp4 and mkv, but more types are being developed for future versions.\n\nA notable feature of Super Screen is its multi-platform support, including PC operating systems like Windows and Mac, allowing users to stream video content from their PCs to the big screen in their VR device. This cross-platform capability makes Super Screen suitable not just for entertainment purposes, like watching movies, but also for educational and business environments, such as virtual classrooms and meeting rooms. In education, it offers students a more immersive learning experience; in business, it can be used for virtual meetings, providing a more interactive and immersive meeting experience. Streaming support for the Linux platform is currently under development and will be available in future versions.", "short_description": "SuperScreen builds a cinema virtual environment and a see-through MR experience that combines reality and reality for a movie-watching experience. It supports 3D, 360, and up to 8K format videos, and supports PC computer streaming such as win and mac."}]}, "developer_name": null, "developer_privacy_policy_url": "https://raw.githubusercontent.com/liuw086/SuperScreen/main/privacy-statement", "developer_terms_of_service_url": null, "publisher_name": "liuwei", "support_website_url": null, "website_url": "https://github.com/liuw086/SuperScreen/tree/main", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_