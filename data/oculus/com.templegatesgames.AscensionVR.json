3_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aYacMRoVQNIQ7kNvgFr58f4&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0OYrQS_5ODD-MTa7zw8oKuWktq7vRnFkcUbAoXeVkQg&oe=6705157E"}, {"file_name": "migrated_image.png", "id": "251733212657737", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12386279_287057284982048_905990527_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3YfrZy60-8YQ7kNvgGdJfq_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAw0n5rfVdQd4h3XLfuBHNA06h_ATt_2CErOwfjC83jIw&oe=67050AFC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ascension VR", "keywords": ["boardgame", "card", "board", "multiplayer", "voice"], "long_description": "**Now updated with the War of Shadows expansion and support for characters with motion controls!  Come try out the expansion with the devs, Tuesday nights at 8pm Pacific.**\n\nAscension is a fast-paced deck building game that\u2019s quick to learn and packed with endless hours of replay value.  Play online or single player in this VR adaptation of the award winning favorite that will appeal to fans of board games, trading card games and non-gamers alike.\n\nAscension VR includes:\n52 Heroes, Constructs & Monsters \nNetwork Multiplayer across VR platforms \nGear & Rift support \nSingle player AI mode \nSocial VR features: spatialized chat, lip and animation sync", "short_description": "**Now updated with the War of Shadows expansion and support for characters with motion controls!  Come try out the expansion with the devs, Tuesday nights at 8pm Pacific.**\n\nAscension is a fast-paced deck building game that\u2019s quick to learn and packed with endless hours of replay value.  Play online or single player in this VR adaptation of the award winning favorite that will appeal to fans of board games, trading card games and non-gamers alike."}]}, "developer_name": null, "developer_privacy_policy_url": "http://templegatesgames.com/", "developer_terms_of_service_url": "http://templegatesgames.com