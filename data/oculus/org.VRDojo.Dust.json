": "en_US", "screenshots": [{"file_name": "DUST_Alpha_Map_reveal.png", "id": "946838407381962", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974568_946838410715295_4605092288085427501_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lj52vL0AJVkQ7kNvgGpc7l1&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA2dfOg_R1tiHAqguRXH2VRkwjXafVlB3ylTSMwden2ZQ&oe=6777D608"}, {"file_name": "DUST_Alpha_Arrow.png", "id": "603813355662720", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75280978_603813358996053_8705308256577121568_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H0UoavlVoAYQ7kNvgFMRWLc&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCkE_DHtobHCDDhzYQiBZXQ9T-oh8Nd35XiM9AP_OPPCQ&oe=6777B5EF"}, {"file_name": "DUST_Alpha_Sniped.png", "id": "1368685544326150", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57569428_1368685547659483_2639635302756690768_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PwETMrKprdkQ7kNvgFArmT6&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYApvUF64O0bq1IhzBaY_nOMoXEndjBzLS2npsYf871Wdg&oe=6777CC1B"}, {"file_name": "DUST_Alpha_Golem_Smash_2.png", "id": "889499496707930", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982634_889499500041263_4621669010438390533_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dr3V1U8tE-MQ7kNvgH47ITx&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBd_pG6lQxtTrQ6722K2YIeApf7E-a8qbKPBjjlHq8N9g&oe=6777DCF2"}, {"file_name": "DUST_Alpha_Hero.png", "id": "1111164846705121", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75462960_1111164850038454_5456801198877194132_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dVJYqDAtURQQ7kNvgG-dPXi&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBxMzDLxjqMT1V9bkkrSOU43KVFCHKL003f-MCNBZWuXw&oe=6777E59F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DustVirtualCombat_TrailerCoverImage.png", "id": "1107099640792286", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031511_1107099644125619_2126474495119274274_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQEo_gwdyfcQ7kNvgHGTwjy&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC6YaMWs4Ti_2f5U6MxH__kszGJXgEJ1v8LjvqILbyHcg&oe=6777B84C"}, "display_name": "DUST", "keywords": ["moba", "pvp", "multiplayer", "social", "competitive"], "long_description": "DUST: Virtual Combat collects all VR playstyles into one virtual world where players can gather and compete as their favorite VR characters. Built on top of a custom networking system, DUST is the only multiplayer VR game designed from the ground up to be fun, fair, and fluid even when the most intense players are battling it out from opposite sides of the planet. \n\nEach playable class is a mix of unique VR locomotion and combat styles players will recognize from across the VR world:\n\n- Gorilla Arm locomotion\n- Joystick locomotion\n- Arms-as-wings Flying locomotion\n- Rocket-thruster-hands Flying locomotion\n- Climbing locomotion\n- Grapple-swinging locomotion\n- and more...\n\nDUST is currently in early alpha and changes often, but it is free-to-play and always will be. ", "short_description": "Your favorite VR playstyles all together in one arena! Fly, Climb, Punch, Shoot, and hang out with friends on any VR headset from anywhere in the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrdojo.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRdojo", "support_website_url": "https://vrdojo.games/", "website_url": "https://vrdojo.games/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommende