a0a&_nc_ohc=WdlkeQBwsi0Q7kNvgEvAiKd&_nc_ht=scontent.oculuscdn.com&_nc_gid=APQRBAmBY4YafGkJRHa6aGa&oh=00_AYCLTmOCEm46riTo5DsWFvm652PGcTWV6Gh_SCmU97pGhQ&oe=66E030D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage.png", "id": "329906959922286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982463_329906963255619_7712697472951754893_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rmJlShVnKOYQ7kNvgF_pgHF&_nc_ht=scontent.oculuscdn.com&_nc_gid=APQRBAmBY4YafGkJRHa6aGa&oh=00_AYA7InNWXGCsilkhdWbELMaVV6BPUxQ_Vsf5MYrs033awA&oe=66E018D2"}, "display_name": "DUST", "keywords": [], "long_description": "Dust: Virtual Combat collects all VR playstyles into one virtual world where players can gather and compete as their favorite VR characters. Built on top of a custom networking system, Dust is the only multiplayer VR game designed from the ground up to be fun, fair, and fluid even when the most intense players are battling it out from opposite sides of the planet. \n\nEach playable class is a mix of unique VR locomotion and combat styles players will recognize from across the VR world:\n\n- Gorilla Arm locomotion\n- Joystick locomotion\n- Arms-as-wings Flying locomotion\n- Rocket-thruster-hands Flying locomotion\n- Climbing locomotion\n- Grapple-swinging locomotion\n- and more...\n\nDust is currently in early alpha and changes often, but it is free-to-play and always will be. ", "short_description": "Your favorite VR playstyles all together in one arena! Fly, Climb, Punch, Shoot, and hang out with friends on any VR headset from anywhere in the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/6c95d009-9ea3-4f5f-8e9b-dddd23b48474", "developer_terms_of_service_url": null, "publisher_name": "VRdojo", "support_website_url": "https://vrdojo.games/", "website_url": "https://vrdojo.games/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "274332603592