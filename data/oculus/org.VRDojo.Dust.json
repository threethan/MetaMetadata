55_4371258920540769142_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ochK5DLmkqIQ7kNvgEw-_DW&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJp5g0ZXNOgn60MVbbxU_foSZZGHVgOn2lrF6spI2PWQ&oe=671B93FB"}, {"file_name": "KoboldDuel.png", "id": "2715987315247588", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031509_2715987318580921_8375437897008456541_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yFKFejGnBRoQ7kNvgH0b_rr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgw_2EdmMQa9_1cdXQM58WFjexLxYca3_bNAv7CqyI4Q&oe=671B8F77"}, {"file_name": "Screenshot.png", "id": "1097120078314158", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031543_1097120081647491_1395570085237423607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eHEC8MAfOVsQ7kNvgHkNQkt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC2EjEtKvgSeUDebMmxyCREAqZAYlnCjHppOwIBZjJ5FA&oe=671B7BCC"}, {"file_name": "SeraphTeleport.png", "id": "534250162584714", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031619_534250165918047_7423314261961062318_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-CKQndUfkaIQ7kNvgH60dGe&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDd_aQ5EQyv5VpiCcF5-Gu5GjNFVBBE5W9WS2_s8YmUw&oe=671B7077"}, {"file_name": "KoboldDrone.png", "id": "1710373033142097", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982566_1710373036475430_276193280060863730_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HWidJsmLq6UQ7kNvgGRHh92&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVygizNgr1r5DqY817XfpEuvFweIezq_vphT6KT0iDbw&oe=671B9F32"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage.png", "id": "329906959922286", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982463_329906963255619_7712697472951754893_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kNOHB0RE3OgQ7kNvgHbROlp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDaxdY2SlxOLwGbmtJblar-KW-WnbsliZTijSenJLxTQQ&oe=671B6C52"}, "display_name": "DUST", "keywords": ["moba", "pvp", "multiplayer", "social", "competitive"], "long_description": "DUST: Virtual Combat collects all VR playstyles into one virtual world where players can gather and compete as their favorite VR characters. Built on top of a custom networking system, DUST is the only multiplayer VR game designed from the ground up to be fun, fair, and fluid even when the most intense players are battling it out from opposite sides of the planet. \n\nEach playable class is a mix of unique VR locomotion and combat styles players will recognize from across the VR world:\n\n- Gorilla Arm locomotion\n- Joystick locomotion\n- Arms-as-wings Flying locomotion\n- Rocket-thruster-hands Flying locomotion\n- Climbing locomotion\n- Grapple-swinging locomotion\n- and more...\n\nDUST is currently in early alpha and changes often, but it is free-to-play and always will be. ", "short_description": "Your favorite VR playstyles all together in one arena! Fly, Climb, Punch, Shoot, and hang out with friends on any VR headset from anywhere in the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrdojo.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRdojo", "support_website_url": "https://vrdojo.games/", "website_url": "https://vrdojo.games/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1436351953220286"}, {"id": "889588098232891"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes":