cC7HnkBLB_juYVhtdNx11I2WEsQ&oe=6712459B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2.0.png", "id": "788822639382373", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982478_788822642715706_3307117894535482169_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EB7503j2DDwQ7kNvgHHscMm&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBxXy1kbFX8AyIOCwtHavjnjce4et_J6JIM24X0Fx9KuQ&oe=67124850"}, "display_name": "MainlyMonkey's", "keywords": [], "long_description": "This is MainlyMonkeys, In this game using your hands are the key to play. Inside the game you have a option to play with others or with specific friend's. There are many maps to come, there is a boss fight to be seen sooner or later, There is P.V.P, Zero Gravity, Lil Place, Shop, and the MM EL. Here you can customize your character and even collect secretly hidden items and achievements. In the MM EL or as its told... Anyways the MM EL did create a few cool thing's. in Lil Place you turn small because of TROBITES which makes the map fun to play in. In Zero Gravity you have NG(nogravity) Which means once you enter you can fly, jump, or even hop around the ZeroG map. In P.V.P you are given boxing gloves to fight with.", "short_description": "In MainlyMonkeys you move with your hands and can explore the game and secrets that beholds in it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/5bf4d162-45a6-4486-af0c-d18a8d5f9272", "developer_terms_of_service_url": null, "publisher_name": "ARVTXR", "support_website_url": null, "website_url": "https://sites.google.com/view/mainlymonkeys-official-site/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_a