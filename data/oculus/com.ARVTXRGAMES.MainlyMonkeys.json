974867_845660097442489_5748881110912663846_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zuguzpVm_bgQ7kNvgEcP4dZ&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBjYt0ep_JyCinfW_twAnHfXrrWpCAMYz3jDmFNqSWlqA&oe=670BBF1C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MM Again.png", "id": "859118488977989", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035373_859118492311322_2608266553342984800_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0VUBNelUNr4Q7kNvgFcTuWM&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCIYihQjwq0z1dI6DCV3zvOtXaXPJXuabGiWySnoudbMw&oe=670BC0ED"}, "display_name": "MainlyMonkey's", "keywords": [], "long_description": "Welcome to MainlyMonkey's! Here use both hands to discover what's beyond the Monkey World! But also realize there's items you can collet, Find and finish quests, and customize you're character to the many options in the MonkeyMall. Not only that there are also much more to this game, Play tag and find new friends. but remember If you do encounter a bad Monkey that is Toxic, Abusing Glitches, Report them! That's it for these for now You must discover what's more to come beyond the Monkey World Now.", "short_description": "Welcome to MainlyMonkey's! Here use both hands to discover what's beyond the Monkey World!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/5bf4d162-45a6-4486-af0c-d18a8d5f9272", "developer_terms_of_service_url": null, "publisher_name": "ARVTXR", "support_website_url": null, "website_url": "https://sites.google.com/view/mainlymonkeys-official-site/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_are