ontent.oculuscdn.com&_nc_gid=A3-xClfF_U58s0eq580L_QT&oh=00_AYA9O01TZ1YLxezDtvgl179ULFdmBh3f93bdpBFrsMNe6w&oe=66F3F4D9"}, {"file_name": "MainlyMonkey_Custom..._01.04.2024_16-59-23.png", "id": "404459338990088", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569448_404459342323421_8862532095845458246_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sb3akyws0LcQ7kNvgE1Pm97&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3-xClfF_U58s0eq580L_QT&oh=00_AYAJMTVWLj3Z8pROshVYUZV4Y-lKIxmydQVvW4Ikl07HfA&oe=66F3F31B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2.0.png", "id": "788822639382373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_788822642715706_3307117894535482169_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_RJhv42TnLMQ7kNvgFh8D73&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3-xClfF_U58s0eq580L_QT&oh=00_AYC0h7FA50hmu8W7eDLHIBwZ6De_blSgDAzgzo_4IMv3Ug&oe=66F3F5D0"}, "display_name": "MainlyMonkey's", "keywords": [], "long_description": "This is MainlyMonkeys, In this game using your hands are the key to play. Inside the game you have a option to play with others or with specific friend's. There are many maps to come, there is a boss fight to be seen sooner or later, There is P.V.P, Zero Gravity, Lil Place, Shop, and the MM EL. Here you can customize your character and even collect secretly hidden items and achievements. In the MM EL or as its told... Anyways the MM EL did create a few cool thing's. in Lil Place you turn small because of TROBITES which makes the map fun to play in. In Zero Gravity you have NG(nogravity) Which means once you enter you can fly, jump, or even hop around the ZeroG map. In P.V.P you are given boxing gloves to fight with.", "short_description": "In MainlyMonkeys you move with your hands and can explore the game and secrets that beholds in it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/5bf4d162-45a6-4486-af0c-d18a8d5f9272", "developer_terms_of_se