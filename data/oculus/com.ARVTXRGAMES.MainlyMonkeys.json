ontent.oculuscdn.com&_nc_gid=AHGbngpC2yUeYt_KIcA7Bjh&oh=00_AYAnHGFGgQCJGrk2hOAqXGUrkZ0jPMQOnN5STxcSJ7gH3w&oe=66ED5D59"}, {"file_name": "MainlyMonkey_Custom..._01.04.2024_16-59-23.png", "id": "404459338990088", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569448_404459342323421_8862532095845458246_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DA81DTbF_w0Q7kNvgHycfz6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHGbngpC2yUeYt_KIcA7Bjh&oh=00_AYD0NuGQor45I0g19k85TA-ch2SrBSrGFvQ9JDtDUg4ixA&oe=66ED5B9B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2.0.png", "id": "788822639382373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_788822642715706_3307117894535482169_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6XS5GmeQ82sQ7kNvgEpT3pI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHGbngpC2yUeYt_KIcA7Bjh&oh=00_AYDmRc79DPRHXJA2W-J4NRQ9c6zCO1oTdu4N1m5wI5TuAg&oe=66ED5E50"}, "display_name": "MainlyMonkey's", "keywords": [], "long_description": "This is MainlyMonkeys, In this game using your hands are the key to play. Inside the game you have a option to play with others or with specific friend's. There are many maps to come, there is a boss fight to be seen sooner or later, There is P.V.P, Zero Gravity, Lil Place, Shop, and the MM EL. Here you can customize your character and even collect secretly hidden items and achievements. In the MM EL or as its told... Anyways the MM EL did create a few cool thing's. in Lil Place you turn small because of TROBITES which makes the map fun to play in. In Zero Gravity you have NG(nogravity) Which means once you enter you can fly, jump, or even hop around the ZeroG map. In P.V.P you are given boxing gloves to fight with.", "short_description": "In MainlyMonkeys you move with your hands and can explore the game and secrets that beholds in it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/5bf4d162-45a6-4486-af0c-d18a8d5f9272", "developer_terms_of_se