_ht=scontent.oculuscdn.com&_nc_gid=At_HNNbYfIxcheTx-8zxQ9r&oh=00_AYCenW09H4DVr8RUoYY1qFvtagqIDnEE3TO5x9OIIlmHLA&oe=66E422D9"}, {"file_name": "MainlyMonkey_Custom..._01.04.2024_16-59-23.png", "id": "404459338990088", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569448_404459342323421_8862532095845458246_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5MM6G3_jtd4Q7kNvgHnmemK&_nc_ht=scontent.oculuscdn.com&_nc_gid=At_HNNbYfIxcheTx-8zxQ9r&oh=00_AYA4UgG6AAlwhj2B1lH8GSdbrrQUnGJdg5jqScKClyEFlA&oe=66E4211B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2.0.png", "id": "788822639382373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_788822642715706_3307117894535482169_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O6oRtO71HGkQ7kNvgGizoRh&_nc_ht=scontent.oculuscdn.com&_nc_gid=At_HNNbYfIxcheTx-8zxQ9r&oh=00_AYA1voP4lPz4HcsaiJWfO6wnGiOlS689YnS1z0-NgbdSRg&oe=66E423D0"}, "display_name": "MainlyMonkey's", "keywords": [], "long_description": "This is MainlyMonkeys, In this game using your hands are the key to play. Inside the game you have a option to play with others or with specific friend's. There are many maps to come, there is a boss fight to be seen sooner or later, There is P.V.P, Zero Gravity, Lil Place, Shop, and the MM EL. Here you can customize your character and even collect secretly hidden items and achievements. In the MM EL or as its told... Anyways the MM EL did create a few cool thing's. in Lil Place you turn small because of TROBITES which makes the map fun to play in. In Zero Gravity you have NG(nogravity) Which means once you enter you can fly, jump, or even hop around the ZeroG map. In P.V.P you are given boxing gloves to fight with.", "short_description": "In MainlyMonkeys you move with your hands and can explore the game and secrets that beholds in it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/5bf4d162-45a6-4486-af0c-d18a8d5f9272", "developer_terms