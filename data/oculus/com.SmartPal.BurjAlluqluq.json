062f\u064a\u062f (6).png", "id": "6959937680783794", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982528_6959937687450460_6360036768832887368_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2LlDI8rstBcQ7kNvgEWfz_N&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCcJiLIsbYWw3Xmc3jF3KJCbtzqslt1eC0cfvnKK5QG4w&oe=675EB77A"}, {"file_name": "\u0645\u0634\u0631\u0648\u0639 \u062c\u062f\u064a\u062f (8).png", "id": "7123642154339640", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031588_7123642161006306_5989344257473976232_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jtk1TJeZooMQ7kNvgE-LV7H&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYASZNWh0bzk27F_fqwQ3bFMcJxHPlisqfB-_1ZhFi_C6Q&oe=675ED3D8"}, {"file_name": "\u0645\u0634\u0631\u0648\u0639 \u062c\u062f\u064a\u062f (7).png", "id": "642462347959839", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75422394_642462351293172_770772060691426654_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wU0J7StgDU4Q7kNvgEWRSGW&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDC9HT0sVft6_vDkgSdPHnOFFUHUP3ZAAF3Q_yxoHfFog&oe=675EB358"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Burj Alluqluq", "keywords": [], "long_description": "Dive into a virtual exploration of one of Jerusalem's most significant historical landmarks with the \"Burj Al-Luqluq VR\" app. This immersive virtual reality experience transports you directly into the heart of Burj Al-Luqluq, allowing you to wander through its ancient architecture and uncover the layers of history that have shaped this iconic site. Through a carefully curated interactive tour, users can engage with the rich cultural and historical narratives of Burj Al-Luqluq, learning about its significance in Jerusalem's storied past.\n\nThe app features detailed reconstructions of the site, enriched with historical facts and stories that bring the past to life. Whether you're a history enthusiast, a cultural explorer, or simply looking for a unique virtual reality experience, \"Burj Al-Luqluq VR\" offers a captivating journey through time. Experience the beauty of Jerusalem's heritage from a new perspective, exploring the intricacies of Burj Al-Luqluq's architecture and the historical events that have unfolded within its walls.", "short_description": "Discover the depths of history and culture at Burj Al-Luqluq with our unique virtual reality app. \"Burj Al-Luqluq VR\" offers an interactive tour that takes you on a historical journey inside one of Jerusalem's most prominent landmarks, providing an immersive opportunity to explore its rich heritage and ancient stories."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/burj-alluqluq-vr", "developer_terms_of_service_url": null, "publisher_name": "Mohammad Salah", "support_website_url": null, "website_url": "https://www.burjalluqluq.org/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ar"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7008152152637718"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/57569455_426961373201543_3146222373028051682_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1VuOY-JgR9gQ7kNvgGTVA3q&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYD2xbbf8_asdzVQ-hcqqubQPwxdqR04wwp5w_Kh2z_CZg&oe=675EDDB1"}, "is_concept": false, "is_test": false, "is_t