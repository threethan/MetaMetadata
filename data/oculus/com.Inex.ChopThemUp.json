cb=1-7&_nc_sid=6e7a0a&_nc_ohc=waHtHU1NACMQ7kNvgGy-o4E&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOu76r1XtAKiejh5th4agc7&oh=00_AYC3r8Tt-TmueK61FehECzu7krC4chKwPAoGXIcW0wb-qg&oe=66ED77C8"}, {"file_name": "sc1.png", "id": "1356534795222765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_1356534801889431_228841040873018553_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hyFqBkAw2XAQ7kNvgGqqdYA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOu76r1XtAKiejh5th4agc7&oh=00_AYBqCPFhpHDhouU-MP3RHIhrLE7WQ2xzNunD80Q4R9NDMA&oe=66ED72C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc2.png", "id": "414552960941034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86615893_414552964274367_5891673864145207075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gtv13b0tsw8Q7kNvgGP-R5k&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOu76r1XtAKiejh5th4agc7&oh=00_AYAhW_vRWxWb6B8VCOSTMAt7iQ-_DrxeCU57t224d7ftWQ&oe=66ED6CF8"}, "display_name": "Katana", "keywords": [], "long_description": "Your objective is clear: slash your way through hordes of agile and cunning foes as they approach from all directions. With precise motion tracking and intuitive controls, you'll feel the power of every slash as you cut down your adversaries in breathtakingly realistic environments.\n\nUnleash your inner ninja and test your reflexes, speed, and precision in this high-energy VR game. \"Katana\" offers challenging levels, formidable boss battles, and a variety of different enemy types to keep you on your toes. As you progress, you'll unlock new abilities and upgrades for your katana, allowing you to become an even more formidable force.", "short_description": "Step into the heart-pounding world of \"Katana,\" a thrilling virtual reality game that puts you in the shoes of a skilled ninja warrior. Armed with a razor-sharp katana sword, you'll face off against waves of relentless enemy ninjas in an immersive and action-packed experience."}]}, "developer_name": null, "developer_privacy_poli