on-packed experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://onetwoplay.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "OneTwoPlay BV", "support_website_url": null, "website_url": "https://onetwoplay.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7593019457396467"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "336301066066210"}]}, "baseline_offer": {"id": "336301066066210"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711389480, "status": "PUBLISHED", "id": "336301066066210"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7573723545992725", "version": "0.7"}, "id": "1110759843635551", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7031038496927902", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7573723545992725"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1110759843635551"}]}, "change_log": null, "created_date": 1710892608, "id": "7573723545992725", "version": "0.7", "version_code": 7, "releas