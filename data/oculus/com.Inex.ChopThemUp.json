-1.oculuscdn.com&oh=00_AYDTfMrHGNX6hBSc6mj7TLnzJb-rA2rL0eBfncXqOBVCvQ&oe=6756EFC8"}, {"file_name": "sc1.png", "id": "1356534795222765", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031344_1356534801889431_228841040873018553_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QefPm2paMPYQ7kNvgG1jWlE&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDxlCSmDDbQCdBSgyqOyHuT-H7iFAF-AdhGKFbPEOd9ug&oe=6756EAC8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc2.png", "id": "414552960941034", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86615893_414552964274367_5891673864145207075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-K1rU3DM9SUQ7kNvgHvo5VX&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDyopEJuctsbrPw0S4gWSXnWgHcbXglgZhXr45nBoCzSQ&oe=6756E4F8"}, "display_name": "Katana", "keywords": [], "long_description": "Your objective is clear: slash your way through hordes of agile and cunning foes as they approach from all directions. With precise motion tracking and intuitive controls, you'll feel the power of every slash as you cut down your adversaries in breathtakingly realistic environments.\n\nUnleash your inner ninja and test your reflexes, speed, and precision in this high-energy VR game. \"Katana\" offers challenging levels, formidable boss battles, and a variety of different enemy types to keep you on your toes. As you progress, you'll unlock new abilities and upgrades for your katana, allowing you to become an even more formidable force.", "short_description": "Step into the heart-pounding world of \"Katana,\" a thrilling virtual reality game that puts you in the shoes of a skilled ninja warrior. Armed with a razor-sharp katana sword, you'll face off against waves of relentless enemy ninjas in an immersive and action-packed experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://onetwoplay.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "OneTwoPlay BV