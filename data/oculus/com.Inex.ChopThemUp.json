cb=1-7&_nc_sid=6e7a0a&_nc_ohc=VGkcMtxZ_OUQ7kNvgF4s9Z-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUb5ai-p1bjUSYvr4tDDDCR&oh=00_AYAAXRXj8fxbCkkbfAfbGFZa4k6b4s9giG8xxvwUJheEzA&oe=66EAD4C8"}, {"file_name": "sc1.png", "id": "1356534795222765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_1356534801889431_228841040873018553_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VADvGiQ_33oQ7kNvgH55T4x&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUb5ai-p1bjUSYvr4tDDDCR&oh=00_AYA676kfETJg5x4fhqjyBIOuGZAKF9jTE2U8DUXp_K8UOw&oe=66EACFC8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc2.png", "id": "414552960941034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86615893_414552964274367_5891673864145207075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gtv13b0tsw8Q7kNvgEQoZhO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUb5ai-p1bjUSYvr4tDDDCR&oh=00_AYDoHIRy5FGn3Og4o8vJDc4jkwA0MecPS2jJTeHen4DcQQ&oe=66EAC9F8"}, "display_name": "Katana", "keywords": [], "long_description": "Your objective is clear: slash your way through hordes of agile and cunning foes as they approach from all directions. With precise motion tracking and intuitive controls, you'll feel the power of every slash as you cut down your adversaries in breathtakingly realistic environments.\n\nUnleash your inner ninja and test your reflexes, speed, and precision in this high-energy VR game. \"Katana\" offers challenging levels, formidable boss battles, and a variety of different enemy types to keep you on your toes. As you progress, you'll unlock new abilities and upgrades for your katana, allowing you to become an even more formidable force.", "short_description": "Step into the heart-pounding world of \"Katana,\" a thrilling virtual reality game that puts you in the shoes of a skilled ninja warrior. Armed with a razor-sharp katana sword, you'll face off against waves of relentless enemy ninjas in an immersive and action-packed experience."}]}, "developer_name": null, "developer_privacy_poli