25/75236135_1747744255725069_4473964218104072760_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HpRWZi7JTfQQ7kNvgEnsmM0&_nc_ht=scontent.oculuscdn.com&_nc_gid=An-ZKiA5-VlnanBi9DGgYCY&oh=00_AYAbpy9mTmDdnhwSST7KpPHdDqGvbLzuD6E1q236yfbB8Q&oe=66F2BDC8"}, {"file_name": "sc1.png", "id": "1356534795222765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_1356534801889431_228841040873018553_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Xv5v01ZnxUQ7kNvgGSRsq5&_nc_ht=scontent.oculuscdn.com&_nc_gid=An-ZKiA5-VlnanBi9DGgYCY&oh=00_AYBTmNiNN7Uz8xzm6nfi0sy4qjmhWbO1n2fgY9CuyesSXA&oe=66F2B8C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc2.png", "id": "414552960941034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86615893_414552964274367_5891673864145207075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2gFD-jRz7w8Q7kNvgHjS6XN&_nc_ht=scontent.oculuscdn.com&_nc_gid=An-ZKiA5-VlnanBi9DGgYCY&oh=00_AYAFOkyTf4BNGdqYydveMN3TFvkeaqYkcE8OSse4wjoLAw&oe=66F2B2F8"}, "display_name": "Katana", "keywords": [], "long_description": "Your objective is clear: slash your way through hordes of agile and cunning foes as they approach from all directions. With precise motion tracking and intuitive controls, you'll feel the power of every slash as you cut down your adversaries in breathtakingly realistic environments.\n\nUnleash your inner ninja and test your reflexes, speed, and precision in this high-energy VR game. \"Katana\" offers challenging levels, formidable boss battles, and a variety of different enemy types to keep you on your toes. As you progress, you'll unlock new abilities and upgrades for your katana, allowing you to become an even more formidable force.", "short_description": "Step into the heart-pounding world of \"Katana,\" a thrilling virtual reality game that puts you in the shoes of a skilled ninja warrior. Armed with a razor-sharp katana sword, you'll face off against waves of relentless enemy ninjas in an immersive and action-packed experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://onetwoplay.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "OneTwoPlay BV", "support_website_url": null, "website_url": "https://onetwoplay.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7593019457396467"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "336301066066210"}]}, "baseline_offer": {"id": "336301066066210"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711389480, "status": "PUBLISHED", "id": "336301066066210"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7573723545992725", "version": "0.7"}, "id": "1110759843635551", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7031038496927902", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7573723545992725"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1110759843635551"}]}, "change_log": null, "created_date": 1710892608, "id": "7573723545992725", "version": "0.7", "version_code": 7, "release_stat