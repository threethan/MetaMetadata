cb=1-7&_nc_sid=6e7a0a&_nc_ohc=HpRWZi7JTfQQ7kNvgEnsmM0&_nc_ht=scontent.oculuscdn.com&_nc_gid=An-ZKiA5-VlnanBi9DGgYCY&oh=00_AYAbpy9mTmDdnhwSST7KpPHdDqGvbLzuD6E1q236yfbB8Q&oe=66F2BDC8"}, {"file_name": "sc1.png", "id": "1356534795222765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_1356534801889431_228841040873018553_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Xv5v01ZnxUQ7kNvgGSRsq5&_nc_ht=scontent.oculuscdn.com&_nc_gid=An-ZKiA5-VlnanBi9DGgYCY&oh=00_AYBTmNiNN7Uz8xzm6nfi0sy4qjmhWbO1n2fgY9CuyesSXA&oe=66F2B8C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc2.png", "id": "414552960941034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86615893_414552964274367_5891673864145207075_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2gFD-jRz7w8Q7kNvgHjS6XN&_nc_ht=scontent.oculuscdn.com&_nc_gid=An-ZKiA5-VlnanBi9DGgYCY&oh=00_AYAFOkyTf4BNGdqYydveMN3TFvkeaqYkcE8OSse4wjoLAw&oe=66F2B2F8"}, "display_name": "Katana", "keywords": [], "long_description": "Your objective is clear: slash your way through hordes of agile and cunning foes as they approach from all directions. With precise motion tracking and intuitive controls, you'll feel the power of every slash as you cut down your adversaries in breathtakingly realistic environments.\n\nUnleash your inner ninja and test your reflexes, speed, and precision in this high-energy VR game. \"Katana\" offers challenging levels, formidable boss battles, and a variety of different enemy types to keep you on your toes. As you progress, you'll unlock new abilities and upgrades for your katana, allowing you to become an even more formidable force.", "short_description": "Step into the heart-pounding world of \"Katana,\" a thrilling virtual reality game that puts you in the shoes of a skilled ninja warrior. Armed with a razor-sharp katana sword, you'll face off against waves of relentless enemy ninjas in an immersive and action-packed experience."}]}, "developer_name": null, "developer_privacy_poli