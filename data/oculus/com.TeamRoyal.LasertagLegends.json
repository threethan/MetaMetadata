99743486950565_6130487559359328668_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sNXcCNTA7vAQ7kNvgGonQpo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLgt8xr671YFdefxQ2lHtntoCGL0NADKLzIfG2pURp2g&oe=672CA869"}, {"file_name": "screen_2560x1440_2022-11-08_09-05-12.png", "id": "659080015876849", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75556277_659080019210182_5078018327460835281_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UJoDQG3bJ5cQ7kNvgHrmxlW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3xbIMPLZvSbM3vrpE7Y8tYy19nEGB1sh3wx19priGsw&oe=672C9F50"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video pic.png", "id": "1148834179328242", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003247_1148834182661575_6463776573512271020_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H76YkhXA-qQQ7kNvgFD4hBD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgPRz8tboiy5qLYnsVIdNUAtrb-MGQ7sylXpJ_M5RWZQ&oe=672C9260"}, "display_name": "Lasertag Legends", "keywords": [], "long_description": "Lasertag Legends is a multiplayer lasertag game.\n\nThe action takes place in a colorful, neon lit lasertag arena sometime in the near future.\n\nChoose a team, get in the arena and start fragging! \n\nEach frag helps push your team up the league table. \n\nAt the end of the season, one team will be crowned champions of the Royal Lasertag League.\n\nLasertag Legends features 3 main modes:\n\nMultiplayer Modes:\n- The Main Stage: Battle it out against other players in the Lasertag Legends Arena \n\n- The Cube: Practice your aim by battling against other players in a small map\n\nSingleplayer Mode: \n- Dino Hunt: Survive against a vicious hoard of holographic dinosaurs \n\nNeed a break? Head to the lobby to hang out, watch a concert, change your tagger or check out your stats.\n\nThe game places a focus on teams instead of individual stats. Choose from one of 20 lasertag teams. Once you choose a team, all your frags contribute to your team's overall score. In the lobby, you can see the league table and where each team stands. At the end of the season, one team will be crowned champions.\n\nSee you in the arena.\n\n\n\n\n\n", "short_description": "Live. Laugh. Lasertag."}]}, "developer_name": null, "developer_privacy_policy_url": "https://lasertaglegends.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Team Royal Games", "support_website_url": "https://lasertaglegends.com/support", "website_url": "https://lasertaglegends.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "805863247185221"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5742369049133882", "version": "1.2"}, "id": "2086892191473910", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5350443918326399", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5742369049133882"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}