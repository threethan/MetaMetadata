individual stats. Choose from one of 20 lasertag teams. Once you choose a team, all your frags contribute to your team's overall score. In the lobby, you can see the league table and where each team stands. At the end of the season, one team will be crowned champions.\n\nSee you in the arena.\n\n\n\n\n\n", "short_description": "Live. Laugh. Lasertag."}]}, "developer_name": null, "developer_privacy_policy_url": "https://lasertaglegends.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Team Royal Games", "support_website_url": "https://lasertaglegends.com/support", "website_url": "https://lasertaglegends.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "805863247185221"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5742369049133882", "version": "1.2"}, "id": "2086892191473910", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5350443918326399", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "i