55_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YPWeyafBzZoQ7kNvgFBrz-Z&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCQgVdD2H9Gam5d3HgdJETAMK8AGOjn3zIgp2XM4GPzeQ&oe=6756DE88"}, {"file_name": "sc5.png", "id": "1011253722948824", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003236_1011253726282157_2148070375117618506_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4HQyApHeEvsQ7kNvgFRNjFe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCPw_22QrAR2RKMLsDZWxPFSvhI73HeL9uuMyM5vm4AZQ&oe=6756E064"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "moviesamne.png", "id": "535025714214922", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031467_535025717548255_397353940266345826_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DN_97Mbmx2AQ7kNvgH9LC3k&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCklglGVMl3ODGljWDsfl5FhrdIcRVQNLB7m0porpjYRQ&oe=6756D44C"}, "display_name": "AlpineAcceleration", "keywords": ["retro", "2Dlike", "Timetrial", "RTA", "WinterSports"], "long_description": "This game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A button (Jump)", "short_description": "A 2D style snowboarding game is here!\nRide through a total of 9 courses full of speed and thrills!\n\nFeel the speed in your body!\nSimple yet addictive controls!\n\nHow far can you go to beat your time?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2021/06/alpine-acceleration.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2021/06/about-alpine-acceleration.html", "category": "GAMES", "comfor