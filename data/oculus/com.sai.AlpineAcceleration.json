JW83SPnTugQ7kNvgFiLtVf&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBFFL-3gcItFSzy5LI43UokQjo1WRLnDMJKZYlPw74sOQ&oe=6707C664"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AlpineAcceleration", "keywords": [], "long_description": "This game is\nThe goal of the game is to avoid falling off the stage and hitting obstacles.\nUse jumping to reach the goal of the course.\n\nThe key is to adjust the timing and speed of your jumps!\n\nGame Controls\nOculus Touch X button Hold\n(When you're going downhill / Speed Up)\n(On the way up the hill / Reduced deceleration)\n\nOculus Touch A button (Jump)", "short_description": "A 2D style snowboarding game is here!\nRide through a total of 9 courses full of speed and thrills!\n\nFeel the speed in your body!\nSimple yet addictive controls!\n\nHow far can you go to beat your time?"}, {"images": {"nodes": []}, "id": "233736371655120", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Alpine Acceleration", "keywords": [], "long_description": "\u3053\u306e\u30b2\u30fc\u30e0\u306f\n\u30b9\u30c6\u30fc\u30b8\u304b\u3089\u843d\u3061\u305f\u308a\u3001\u969c\u5bb3\u7269\u306b\u5f53\u305f\u3089\u306a\u3044\u3088\u3046\u3001\n\u30b8\u30e3\u30f3\u30d7\u3092\u99c6\u4f7f\u3057\u306a\u304c\u3089\u30b3\u30fc\u30b9\u306e\u30b4\u30fc\u30eb\u3092\u76ee\u6307\u3059\u30b2\u30fc\u30e0\u3067\u3059\u3002\n\n\u30b8\u30e3\u30f3\u30d7\u306e\u30bf\u30a4\u30df\u30f3\u30b0\u3084\u30b9\u30d4\u30fc\u30c9\u306e\u8abf\u6574\u304c\u9375\u3068\u306a\u308a\u307e\u3059\u3002\n\n\u64cd\u4f5c\u8aac\u660e\nX\u30dc\u30bf\u30f3\u9577\u62bc\u3057/\n\u4e0b\u308a\u5742\u306e\u6642\u3001\u30b9\u30d4\u30fc\u30c9\u30a2\u30c3\u30d7\n\u767b\u308a\u5742\u306e\u6642\u3001\u6e1b\u901f\u3092\u6291\u5236\n\nA\u30dc\u30bf\u30f3/\u30b8\u30e3\u30f3\u30d7", "short_description": "2D\u98a8\u30b9\u30ce\u30fc\u30dc\u30fc\u30c9\u30b2\u30fc\u30e0\u304c\u767b\u5834\uff01\n\u30b9\u30d4\u30fc\u30c9\u611f\u3001\u30b9\u30ea\u30eb\u306b\u5bcc\u3093\u3060\u51689\u30b3\u30fc\u30b9\u3092\u99c6\u3051\u629c\u3051\u308d\uff01\n\n\u4f53\u306b\u611f\u3058\u3089\u308c\u308b\u75be\u8d70\u611f\n\u30b7\u30f3\u30d7\u30eb\u306a\u306e\u306b\u7656\u306b\u306a\u308b\u64cd\u4f5c\u611f\uff01\n\n\u3042\u306a\u305f\u306f\u3069\u3053\u307e\u3067\u30bf\u30a4\u30e0\u3092\u7e2e\u3081\u3089\u308c\u308b\uff1f"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2021/06/alpine-acceleration.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2021/06/about-alpine-acceleration.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "675029020171932"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2015248805662095"}, {"status": "PUBLISHED", "id": "200546485356121"}]}, "baseline_offer": {"id": "200546485356121"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "2015248805662095"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4236903096388935", "version": "1.1"}, "id": "326394692459082", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary",