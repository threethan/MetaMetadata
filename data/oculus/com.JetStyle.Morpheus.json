ds of hosting VR events. We provide the headsets, the virtual spaces, the events programming and you bring your team and your needs. Our spaces are purpose built for business,  with a concierge service, one-on-one onboarding, in-person support and guidance for each user. Enterprise level security, privacy and safety are key goals and our pool of facilitators work together to continually refine best practices for our corporate clients.", "short_description": "VR experiences for your team and your business"}]}, "developer_name": null, "developer_privacy_policy_url": "https://morpheusxr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "MorpheusXR", "support_website_url": null, "website_url": "https://morpheusxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "REQUIRED", "genres": ["PRODUCTIVITY", "SOCIAL", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "2106960316146096"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "471851484540358"}]}, "baseline_offer": {"id": "471851484540358"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1644573600, "status": "PUBLISHED", "id": "471851484540358"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6299708693457138", "version": "5.1.0"}, "id": "243785053862170", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {