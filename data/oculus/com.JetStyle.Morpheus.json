om&oh=00_AYD2dGmI4KyGglrPEWVyCS0ffvIe__noGskeKmmINBjyZA&oe=6746F720"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=07fQLV7H9EwQ7kNvgHz4ThX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCr5iXexn9VTvX1oVu57h28w-gypnelNQeHg-D3vmDe8A&oe=674702EC"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wgZMK8gqjKMQ7kNvgFDssCH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwEL91nn1TwS3hK0Xuw5oepV-e-wUwuQe5mf3LCX3QMg&oe=6746EC6D"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KszJuVRmdV4Q7kNvgHVM3Z5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEG09ePyUMwypEWSTpZRHKLnA33N3U-0vVLwHUA0HySg&oe=67470D44"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxTjKi6bz8IQ7kNvgFwMgSf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCjQa9h2A8bRTWBA89eHMch24x59hSK9rR05pn3tWJvQA&oe=6746ED04"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your han