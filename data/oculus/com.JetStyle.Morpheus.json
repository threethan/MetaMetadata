//scontent.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oUYxLGCY8Y8Q7kNvgHi7r07&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyY0NXmSagLbxH0BjA_hclwPxoj2N2B8NVQnaPHhbGNQ&oe=66FE69ED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RCCmHu2CAAsQ7kNvgFOU5nc&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjrIrYUsfJ6Ggf606xQV8PFtTh5VA6jB_QecwD7n2JFA&oe=66FE8AC4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQQFtrmqfqQQ7kNvgEXAEpo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPOCBggeQIIngq0U_IQ9p2Dl1nN4jOVPIK9BozrG1kug&oe=66FE6A84"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hands of hosting VR events. We provide the headsets, the virtual spaces, the events programming and you bring your team and your needs. Our spaces are purpose built for business,  with a concierge service, one-on-one onboarding, in-person support and guidance for each user. Enterprise level security, privacy and safety are key goals and our pool of facilitators work together to continually refine best practices for our corporate clients.", "short_description": "VR experiences for your team and your business"}]}, "developer_name": null, "developer_privacy_poli