/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uhXoX5me1MsQ7kNvgGsIO7S&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCV_7-wqOYraN3ObmUGI2MLHrTZ3SJkwAjSx_buDEEfaw&oe=6706696C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LX1rnOpsXcwQ7kNvgEKTh3U&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCjSn_f-jT2yd-B6Sqpi1cTvDfp-h3_YrtzQ6VSg6PnKA&oe=670652ED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MOsXj5VV8KQQ7kNvgFqMv1a&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD6AQfmU_UazsS53to4kwmKRhuxiXXS51fAnnTqB-jcaA&oe=670673C4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o4l9tWac6Z4Q7kNvgHqoymT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAl2R6lcgE3_v3t2uc-76Jm-OeibJNvPK0PGBYoXbr3bg&oe=67065384"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hands of hosting VR events. We provide the headsets, the virtual spaces, the events programming and you bring your team and your needs. Our spaces are purpose built for business,  with a concierge service, one-on-on