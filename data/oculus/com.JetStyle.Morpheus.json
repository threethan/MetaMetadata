om&oh=00_AYCa8OT6QlDO1d9z9quzc4bCPamoTemVFtKBN90RtgMfQQ&oe=672601A0"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uqp7KDO2AGUQ7kNvgF9lW9m&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDNgifmY9RFpDglReiLO9TcngzVf9qVWbl6IjBnlxmvng&oe=67260D6C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MmU-4ChQqJ8Q7kNvgHFl8xI&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBQvVNV4uBnt6Jc5JesdUL59U3Zpg9pdZuX7I9VM-jw-A&oe=67262F2D"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yesh_m6OYeoQ7kNvgECfuCp&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBmqPyIB2URvQptkpXKiiAWoxi1orNjVF-g_stBUYl2XA&oe=672617C4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ihHmD8BSEbAQ7kNvgHmTxN5&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBinGqyiBUwjfdFwDE7yW6MClmVnRDVZNSYU6KGpc2wgQ&oe=67262FC4"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your han