m&oh=00_AYDoe__0n-xdwcT6doUTxzk5cvtEpX7VKtchUNpLpXTP_Q&oe=67863F20"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wslx9wk35P4Q7kNvgEKXZEH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDcSlEWaUGfeAu0-3YxXURHK8q-yAxcU3s0QuEbTRepoQ&oe=67864AEC"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5vDK-W9QpbUQ7kNvgH04HLt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCoiAryUX5noVV4_OCPc8UzR3JmxEBuq2wLKNOUXoQLRQ&oe=6786346D"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gfL1KZjSvNMQ7kNvgGPhioa&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYByyqA1oD9y_KOUXTlasGteZD6ZCk-IZ7TtkPYvQkertg&oe=67865544"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XDYpn8ZpXiAQ7kNvgExCiK4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBn4gIW2NRns0gvN8zYaVT0TU_SjUtI0LGnE90EVAsIdw&oe=67863504"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hand