euslogo1440.png", "id": "4381354645317823", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/43931340_4381354651984489_6688161474822571266_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k3KHGDHE0icQ7kNvgHroTWs&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBhpb02r01Y0_FlV4vJ4oMs0-bMPwPQTx2UIDdON7IkWQ&oe=670BB688"}, {"file_name": "morpheuslogo2.png", "id": "585959812755274", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39003271_585959816088607_8218629155258212490_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7hNo8gG9oAQ7kNvgF8i0-F&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDVYmbd9SPmgA6JJpiqzllngP8VdC3b8T5SKoSe_73ySw&oe=670BB317"}, {"file_name": "morpheushero.png", "id": "569058951069663", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/43931338_569058954402996_4168205111694436770_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pa6bqiioCuMQ7kNvgERbJ5z&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCBBN844grn2OVe_B5EWZ2iyvpmfXZOhjjbeWVCVOQomg&oe=670BC4B0"}, {"file_name": "morpheuscoverart.png", "id": "358101742730705", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982697_358101746064038_9136843446802658828_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PHWD0JHZuCgQ7kNvgE0J7PT&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA32_bs_F2KpJGZGBbXTadFOSfMqowqeBvr5N2tpo0ghw&oe=670B9661"}]}, "id": "958196314970140", "locale": "en_US", "screenshots": [{"file_name": "screenshot1.png", "id": "197650609106934", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031488_197650612440267_7407106582024370382_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=39kqgAPmSNAQ7kNvgGjXC4h&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCkB2TqzgxHKRnY6yc1kwAgUinXLGvAWqTA8hrxzeTB8Q&oe=670BA3A0"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xLh0OUoKVCoQ7kNvgFJxjje&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCTxkcLbu5IdG1T_I2mXYrOVzPvE09vwLO7VD58yz6x6w&oe=670BAF6C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1mGwMvu2LdUQ7kNvgF7j5RG&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBejW_VXBIFcw0t8evZhGcN7rVBNQ9BzhQ280KYuKDqzQ&oe=670B98ED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B1Q_7ZzArxkQ7kNvgHWWhPD&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDQvoK5cVbZCFv3QDHMaLt0WHo9G9f2uL5xSMu-nxM4IA&oe=670BB9C4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TpZTSz_ILH4Q7kNvgEKJhrm&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBqC67lFV_Gtu8hZCseh2AzNJdVxLn595xn4CINEguS6A&oe=670B9984"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hands of hosting VR events. We provide the headsets, the virtual spaces, the events programming and you bring your team and your needs. Our spaces are purpose built for business,  with a concierge service,