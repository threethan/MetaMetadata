/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fhZ2-kvy1ZsQ7kNvgFcNtUW&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCxW6vjDIMdqAgIucThrxy9bDMhpDp60Ti8q0c-HXBN0Q&oe=6701236C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oUYxLGCY8Y8Q7kNvgG4XC50&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCXrXq_PGHfw6v9yPeFJGHaF6KavD4SnjGN8qDrcZMvGg&oe=67010CED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RCCmHu2CAAsQ7kNvgEmoVY9&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAufalFN9bBI0DvMQTteUHf5TwufaftNRbg-Z9IdvOjbg&oe=67012DC4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2bkHzNG077cQ7kNvgHep_fp&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCeGmU8fswq3cbMIoUe9rkZWd1TO-YEeFWOZX6UY39x7w&oe=67010D84"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hands of hosting VR events. We provide the headsets, the virtual spaces, the events programming and you bring your team and your needs. Our spaces are purpose built for business,  with a concierge service, one-on-on