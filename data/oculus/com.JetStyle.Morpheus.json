om&oh=00_AYDeNd9B_jyekdaK5625I-QZCJ4FoAn9OT6r1vwUBppX3A&oe=67405FA0"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6VDJLaHGacUQ7kNvgHEy9Ur&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDezTYOlofT3HV17wQXjJmHpz3YRRSjPbB8eIT46xqrdw&oe=67406B6C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uqyu-kJlQpcQ7kNvgFSzjNU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCRR2HSOmk2jYxbqOoJPbFcvUUmL4qIswKAbL97lLdDgg&oe=674054ED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pmTgSrc253EQ7kNvgF18RHw&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCX0tJXlvWobMlKMFVbyCQOmitDCJZhNIqAGupVJFyLrw&oe=674075C4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dUCdNkRvXMYQ7kNvgF70eck&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAc7ySrSPxyQM_mUlFepaPkiLnlLsK0W7_IEUikySZcZQ&oe=67405584"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your han