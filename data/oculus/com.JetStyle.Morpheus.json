m&oh=00_AYBjTPuWzaCr97Pmz4rESu_K_x-CHGb36qdvp9smayFa9Q&oe=67751BA0"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nfQwGVYcScgQ7kNvgENWxuL&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYClJ68fcP4WZA0rfmjmmd4JyWFXjyPy-PVCBL79yqbKxA&oe=6775276C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O1tgPvPsqy4Q7kNvgGLMOmq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDhDh56JAKIbYHZ-ZPX4K11Apfd0dpokVgWZ3DYJevByg&oe=677510ED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ddeXUk_PRu8Q7kNvgEACysC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDWtP_xB83dwOMDVQfdgjQKunXvi3hpe_3Ph9QyxkWmvQ&oe=677531C4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-qzFb-feboYQ7kNvgF8qs9z&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBlIY9CqQ2SScLSkLc6SSzg8tl_RNfNlSFyeTOC8TTeAA&oe=67751184"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hand