, "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1O7RkvH7jcQ7kNvgEWCabX&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-uezW2D-k9z7ErcIMRhCPc_05G5eLrYYshIaZmZKp6A&oe=66D6DCED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ijEKHGhUVHEQ7kNvgGG3D4C&_nc_ht=scontent.oculuscdn.com&oh=00_AYDA00g9dMhd_2rvIOm7edqg8A-PUOV2V6FljHLN1E17Ug&oe=66D6FDC4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XXQn4GclA0EQ7kNvgH-9EbD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCM9Rrj035KmdO0EESoGMFLXesZWFUtj8iD1Q0QMnHpsw&oe=66D6DD84"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hands of hosting VR events. We provide the headsets, the virtual spaces, the events programming and you bring your team and your needs. Our spaces are purpose built for business,  with a concierge service, one-on-one onboarding, in-person support and guidance for each user. Enterprise level security, privacy and safety are key goals and our pool of facilitators work together to continually refine best practices for our corporate clients.", "short_description": "VR experiences for your team and your business"}]}, "developer_name": null, "develo