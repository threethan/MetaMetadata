om&oh=00_AYDpqYDXkvtVl9jmAEyPk3KTkFC6GifqhAzOwqhQTLslnA&oe=674848A0"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=07fQLV7H9EwQ7kNvgEDP9zd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4DQkdkleLlzHFUHRrqZryRzm8KYFj2zJtY7EG5L3B1w&oe=6748546C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wgZMK8gqjKMQ7kNvgHALFvu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZAXy1BWWNMnSypyFuMvHhu1Z-OCJ4DsO_w65slmnIKA&oe=67483DED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KszJuVRmdV4Q7kNvgHDny5g&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6IKZMlb09NVdb3sOQ_Gs4sV74x4CXr1c5j3ry8Ohfsg&oe=67485EC4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bZ28Xq5alygQ7kNvgG6vIQz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBu_CR1n1dNd1TYSSC9SckHgKow6mtNFpMfrtriM7J8ww&oe=67483E84"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your han