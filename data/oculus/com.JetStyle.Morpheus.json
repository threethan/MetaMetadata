m&oh=00_AYBjIv1talHNpB3DIR-ejf1RWJL3Rrye6vA8CYBxwHIpuw&oe=675D60A0"}, {"file_name": "screenshot2.png", "id": "466323234518599", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031488_466323237851932_6168193435466365773_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bjVx7uecDdAQ7kNvgGetvGt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYATsZvjAZMLGyXoWh-CWN31AMbDdsyIEHKdLf9qBbzeGQ&oe=675D6C6C"}, {"file_name": "screenshot3.png", "id": "420114569461053", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75223478_420114572794386_8490846598187330088_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SmFMuMess4wQ7kNvgFNGvYF&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBoPWlh-pppU1c08ihTA1GFy6d0KJqGL0mzD7ID9nXfTw&oe=675D55ED"}, {"file_name": "screenshot4.png", "id": "356550846259828", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974644_356550849593161_592175657038128343_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DM1Eoa695VMQ7kNvgF61sm5&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC6VGDI0U2CJdOFHopsZ-miUA3-1gtMxPTO_QefjH96ow&oe=675D76C4"}, {"file_name": "screenshot5.png", "id": "934251887300214", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86867711_934251890633547_9187071607599104577_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cq6SxdHtkqUQ7kNvgEPFwC9&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBM_86WHFuprhS2u5Gr0KFEJ7B2kNFEkKXMalGOCsrMdw&oe=675D5684"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Morpheus Experiences", "keywords": [], "long_description": "MORPHEUS BRINGS YOUR DISTRIBUTED TEAM TO VR. Remote teams today need to find new ways to create community and culture. We are a facilitated experience provider for remote teams. We provide team-building, skills development, wellness, co-creation opportunities, presentation spaces and fun to help teams bond and succeed together.\n\nOur focus is on turnkey solutions, taking the work off your hand