: "White Hole", "keywords": [], "long_description": "Build and customize your own ship as you want with a multitude of components that will completely change how you deal with all the situations encountered in this unexplored part of the void. You can meet a lot of adversity in the universe and you will need to fight your way out, negotiate with the different powers ruling the place to make the most of the situation, solve some deadly enigmas and decrypt mysteries to learn about the most hidden galaxy\u2019s secrets. Will the Earth survive its ordeal or will it get destroyed once and for all ? That\u2019s all up to you !\n\nWhite Hole uses the guardian system to build your ship, you need to use a roomscale guardian in order to play the game.", "short_description": "A shadow lurks deep in space, getting closer and closer to planet Earth. If you want to rescue your homeworld, you must forge your own ship and go explore the infinite universe to discover ancient civilizations and unearth the clues that will help you find out how to fight this new evil."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fenrir-corp.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Fenrir-Corp", "support_website_url": "https://www.fenrir-corp.com/", "website_url": "https://www.fenrir-corp.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SC