771-25/39031451_320305559424032_5759138822827985931_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Y_yINhINXwQ7kNvgElts6o&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYClkhSp7VG0AWX20sY2CPITftrXO-iFvOf3ytTCXgjEZg&oe=671A3329"}, {"file_name": "38984475_931659873963284_4303518404514143104_n.png", "id": "2114216422048702", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39036613_2114216425382035_652078182666856291_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6G8qDHCw3hoQ7kNvgHI1Yyg&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBG2K_Vt6jaT_6MkodLBsmnUEp05fSvHnfBBEzueoE4fQ&oe=671A26AC"}, {"file_name": "38982527_1130598050629170_8037208711461131580_n.png", "id": "712430046130321", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39001663_712430049463654_1391127670088407973_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FSA0_yJAbNoQ7kNvgFuPIuu&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDKoTpGNhxS8JQ2P1Ikxofqt1MHCxgkKAvvf5f-ad-xbw&oe=671A38C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cov$.png", "id": "481432056345302", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39031331_481432059678635_8968693732856012714_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qCfNDmguebgQ7kNvgFZliZa&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDPHqRbaaUxG8fFmpZoQARPAa8LHbRyDaPQB6rOoqLUAA&oe=671A445F"}, "display_name": "White Hole", "keywords": [], "long_description": "Build and customize your own ship as you want with a multitude of components that will completely change how you deal with all the situations encountered in this unexplored part of the void. You can meet a lot of adversity in the universe and you will need to fight your way out, negotiate with the different powers ruling the place to make the most of the situation, solve some deadly enigmas and decrypt mysteries to learn about the most hidden galaxy\u2019s secrets. Will the Earth survive its ordeal or will it get destroyed once and for all ? That\u2019s all up to you !\n\nWhite Hole uses the guardian system to build your ship, you need to use a roomscale guardian in order to play the game.", "short_description": "A shadow lurks deep in space, getting closer and closer to planet Earth. If you want to rescue your homeworld, you must forge your own ship and go explore the infinite universe to discover ancient civilizations and unearth the clues that will help you find out how to fight this new evil."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fenrir-corp.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Fenrir-Corp", "support_website_url": "https://www.fenrir-corp.com/", "website_url": "https://www.fenrir-corp.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "657030605716557"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/57566688_475359850125633_3932505188133226947_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Isw9UJo5AYAQ7kNvgHIp8qP&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAmpFRrT6FvMbzEDaaegqxB616TVZYR5nO93V-512VZsw&oe=671A1B62"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "White Hole", "platform": "ANDROID_6DOF", "co