771-25/39031451_320305559424032_5759138822827985931_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eEHLdpb_QToQ7kNvgFdLT9p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAniiXcmkqJ2UUuCCVBpOYtRHOW2ulvt5SlPxReIbWySA&oe=673F1D29"}, {"file_name": "38984475_931659873963284_4303518404514143104_n.png", "id": "2114216422048702", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036613_2114216425382035_652078182666856291_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KITuau7STUkQ7kNvgEEK5-V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4sgMkoQZ1PGPghp0cssk55ZcIj1Nain_cfpKBPbwn4A&oe=673F10AC"}, {"file_name": "38982527_1130598050629170_8037208711461131580_n.png", "id": "712430046130321", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001663_712430049463654_1391127670088407973_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yP-mEy4kgcYQ7kNvgHAHoDP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAoGhiKDkEpr2I1I0p65tmmJ4RJgEBaX-rk83AqlaZmLA&oe=673F22C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cov$.png", "id": "481432056345302", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031331_481432059678635_8968693732856012714_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-QgOFYVJEVsQ7kNvgE8W4Mu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKz1mTnSh9Qeo2zA0YlR2KTiwO9QJfeO9RuS0XtXeg3Q&oe=673F2E5F"}, "display_name": "White Hole", "keywords": [], "long_description": "Build and customize your own ship as you want with a multitude of components that will completely change how you deal with all the situations encountered in this unexplored part of the void. You can meet a lot of adversity in the universe and you will need to fight your way out, negotiate with the different powers ruling the place to make the most of the situation, solve some deadly enigmas and decrypt mysteries to learn about the most hidden galaxy\u2019s secrets. Will the Earth survive its ordeal or will it get destroyed once and for all ? That\u2019s all up to you !\n\nWhite Hole uses the guardian system to build your ship, you need to use a roomscale guardian in order to play the game.", "short_description": "A shadow lurks deep in space, getting closer and closer to planet Earth. If you want to rescue your homeworld, you must forge your own ship and go explore the infinite universe to discover ancient civilizations and unearth the clues that will help you find out how to fight this new evil."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fenrir-corp.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Fenrir-Corp", "support_website_url": "https://www.fenrir-corp.com/", "website_url": "https://www.fenrir-corp.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "657030605716557"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566688_475359850125633_3932505188133226947_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GQ_V0rJncuYQ7kNvgGUUB6r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_f1dCP1rcDd2jwxYifI3jI4Bw8WgrqcZ80BhCLjYDTg&oe=673F0562"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "White Hole", "plat