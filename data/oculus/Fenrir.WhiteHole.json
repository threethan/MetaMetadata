o use a roomscale guardian in order to play the game.", "short_description": "A shadow lurks deep in space, getting closer and closer to planet Earth. If you want to rescue your homeworld, you must forge your own ship and go explore the infinite universe to discover ancient civilizations and unearth the clues that will help you find out how to fight this new evil."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fenrir-corp.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Fenrir-Corp", "support_website_url": "https://www.fenrir-corp.com/", "website_url": "https://www.fenrir-corp.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "657030605716557"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566688_475359850125633_3932505188133226947_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KpVLXJEsPfoQ7kNvgHynqm2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhab8eRESWDKfXtC_pnqJ1hRoBGkgYnYV_ZL0vPj9dFg&oe=6708F7E2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "White Hole", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1616197096, "lastRevision": {"nodes": [{"id": "417314542912019", 