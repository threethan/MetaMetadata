ow Archery. Visit the Archery Range, various Battle Arenas, Hunting with Friends, and More. Experience realistically simulated bow and arrow physics and impact sound fx from the Archery Range. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.backyardarcherygame.com/Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "MISSING GAME STUDIO, ltd.", "support_website_url": null, "website_url": "https://www.backyardarcherygame.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SHOOTER", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1876375705905278"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "971016943573868"}]}, "baseline_offer": {"id": "971016943573868"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1653019140, "status": "PUBLISHED", "id": "971016943573868"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8454776351218162", "version": "1.0"}, "id": "4790236134391675", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5276470422382120", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8454776351218162"}, "release_status": "RELEASED"}, "binary_release_ch