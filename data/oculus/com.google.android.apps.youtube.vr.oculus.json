hing for YouTube content with your voice and social communication", "short_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside"}]}, "developer_name": "Google LLC", "developer_privacy_policy_url": "https://support.google.com/youtube/answer/7671399?hl=en", "developer_terms_of_service_url": "https://www.youtube.com/static?template=terms", "publisher_name": "Google LLC", "support_website_url": null, "website_url": "https://www.youtube.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPERIENCE_360_NON_GAME", "MOVIE", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "342812797850561"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "246017572788808"}, {"status": "PUBLISHED", "id": "1930617233897992"}, {"status": "PUBLISHED", "id": "1465206833578825"}]}, "baseline_offer": {"id": "246017572788808"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1533142800, "status": "PUBLISHED", "id": "246017572788808"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3816581331803439", "version": "1.32.31"}, "id": "1940101649396838", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isApp