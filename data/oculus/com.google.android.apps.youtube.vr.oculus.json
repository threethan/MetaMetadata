Movies", "Shows", "TV", "Live"], "long_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside. \n\nExperience YouTube like never before\n\u2022 Explore every video on YouTube, from 3D 360 videos to standard rectangular videos\n\u2022 Get the full, signed-in experience that lets you view subscriptions, playlists, watch history and more\n\u2022 Choose to co-watch videos with others, talk about them live, and enjoy a shared experience all in the same virtual room\n\nSee and hear it all\n\u2022 Immerse yourself in full 360-degree videos that put you at the center of the action\n\u2022 Experience spatial audio, where depth and distance play a role depending on where you look\n\u2022 Switch between voice and keyboard controls to browse and search with ease\n\n\nPermission Notice\n\u2022 Microphone: Needed to allow searching for YouTube content with your voice and social communication", "short_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside"}]}, "developer_name": "Google LLC", "developer_privacy_policy_url": "https://support.google.com/youtube/answer/7671399?hl=en", "developer_terms_of_service_url": "https://www.youtube.com/static?template=terms", "publisher_name": "Google LLC", "support_website_url": null, "website_url": "https://www.youtube.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["CASUAL", "EXPERIENCE_360_NON_GAME", "MOVIE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD_VIA_TOUCH", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "275917671310632"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2055628267881344"}]}, "baseline_offer": {"id": "2055628267881344"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1557965785, "status": "PUBLISHED", "id": "2055628267881344"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8335211799924747", "version": "1.60.18"}, "id": "545256815955045", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2002317119880945", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8335211799924747"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "545256815955045"}]}, "change_log": null, "created_date": 1728500932, "id": "8335211799924747", "version": "1.60.18", "version_code": 16018000, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2002317119880945", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8335211799924747"}, "release_status": "RELEASED"}, "binary