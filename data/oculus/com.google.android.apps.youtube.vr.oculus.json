file_name": "migrated_image.png", "id": "2828383720561063", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386401_190339441614383_6342659427576840192_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PctgtstfemsQ7kNvgHhkP-i&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArKoDP8H-5G5YAqTSiL1WZw&oh=00_AYBUUqLgBOnateRdqIBX-QMnxdoJESVX2aiiNH7V1pRUfg&oe=66DC4009"}, {"file_name": "migrated_image.png", "id": "138789750885094", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331069_1692938717459161_6286521335979966464_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2euU4n039MQQ7kNvgFwLSFU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArKoDP8H-5G5YAqTSiL1WZw&oh=00_AYB-WU8KLuUKrbbOH0pIeM038LMQWRyBsxLCsBLYnVT3xQ&oe=66DC2BD1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Thumbnail.png", "id": "173833590106093", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410407_173833593439426_6561057990592430080_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lHOx6sAoKdgQ7kNvgGP1Zbc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArKoDP8H-5G5YAqTSiL1WZw&oh=00_AYB9Sn6F-AyLNxRtFtIUc7hyCYzvakt3XYofDdVkonGlkA&oe=66DC3B4B"}, "display_name": "YouTube VR", "keywords": ["Video", "Movies", "Shows", "TV", "Live"], "long_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside. \n\nExperience YouTube like never before\n\u2022 Explore every video on YouTube, from 3D 360 videos to standard rectangular videos\n\u2022 Get the full, signed-in experience that lets you view subscriptions, playlists, watch history and more\n\u2022 Choose to co-watch videos with others, talk about them live, and enjoy a shared experience all in the same virtual room\n\nSee and hear it all\n\u2022 Immerse yourself in full 360-degree videos that put you at the center of the action\n\u2022 Experience spatial audio, where depth and distance play a role depending on where you look\n\u2022 Switch between voice and keyboard controls to browse and search with ease\n\n\nPermission Notice\n\u2022 Microphone: Needed to allow searching for YouTube content with your voice and social communication", "short_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside"}]}, "developer_name": "Google LLC", "developer_privacy_policy_url": "https://support.google.com/youtube/answer/7671399?hl=en", "developer_terms_of_service_url": "https://www.youtube.com/static?template=terms", "publisher_name": "Google LLC", "support_website_url": null, "website_url": "https://www.youtube.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPERIENCE_360_NON_GAME", "MOVIE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "342812797850561"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "246017572788808"}, {"status": "PUBLISHED", "id": "1930617233897992"}, {"status": "PUBLISHED", "id": "1465206833578825"}]}, "baseline_offer": {"id": "246017572788808"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1533142800, "status": "PUBLISHED", "id": "246017572788808"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_result