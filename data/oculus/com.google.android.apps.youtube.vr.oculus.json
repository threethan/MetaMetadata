ge.png", "id": "548539665777374", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974704_2696190260421539_975749735665106944_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VbsdlpScpsoQ7kNvgE0SOu_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpavl5FqDseMlsPAiuGTngmMfGHFIpSYk6emhBxnIG5w&oe=6745C454"}, {"file_name": "migrated_image.png", "id": "169984557299590", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974642_302293960429105_60598410838802432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2zxaJVelCd0Q7kNvgGkWUuk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhNV6zdT617vyKFXy1x1_KFKPYDmpRZ0GLfsSm0iOE3A&oe=6745C833"}, {"file_name": "migrated_image.png", "id": "203725571041915", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031419_378855902902202_2923253023394234368_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ly8GPaUEmiUQ7kNvgHg8W4N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaLC38QydkmTBYj5bmSdxXaV8_s8OY8B9W7w1kNZ0sdQ&oe=6745AD7B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/TunwOS", "id": "2122998087992373", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974626_2122998091325706_4820008635411202048_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7QthZ3WX_psQ7kNvgEjV_OS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJyIm4F-Bim7N8RLiuceVdlDiv-miVRbG4erT-vo50NA&oe=67459903"}, "display_name": "YouTube VR", "keywords": ["Video", "Movies", "Shows", "TV", "Live"], "long_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside. \n\nExperience YouTube like never before\n\u2022 Explore every video on YouTube, from 3D 360 videos to standard rectangular videos\n\u2022 Get the full, signed-in experience that lets you view subscriptions, playlists, watch history and more\n\u2022 Choose to co-watch videos with others, talk about them live, and enjoy a shared experience all in the same virtual room\n\nSee and hear it all\n\u2022 Immerse yourself in full 360-degree videos that put you at the center of the action\n\u2022 Experience spatial audio, where depth and distance play a role depending on where you look\n\u2022 Switch between voice and keyboard controls to browse and search with ease\n\n\nPermission Notice\n\u2022 Microphone: Needed to allow searching for YouTube content with your voice and social communication", "short_description": "Experience your favorite YouTube channels, videos and creators in virtual reality.\n\nThe YouTube VR app turns every video on the platform into your own virtual reality experience and reimagines YouTube as a 3D world you can explore from the inside"}]}, "developer_name": "Google LLC", "developer_privacy_policy_url": "https://support.google.com/youtube/answer/7671399?hl=en", "developer_terms_of_service_url": "https://www.youtube.com/static?template=terms", "publisher_name": "Google LLC", "support_website_url": null, "website_url": "https://www.youtube.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["CASUAL", "EXPERIENCE_360_NON_GAME", "MOVIE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD_VIA_TOUCH", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "275917671310632"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"statu