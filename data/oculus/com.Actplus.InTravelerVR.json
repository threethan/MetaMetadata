-2.oculuscdn.com/v/t64.5771-25/38974862_3950716541917525_3547774517994781167_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b9d-3ojPQ9UQ7kNvgE4VoOw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB4DCV1ajdZy-MvPlCMn3CwrHTdouxxmFzxLyhljVfiGQ&oe=6771192C"}, {"file_name": "8 - Screenshots 5.png", "id": "370328769349564", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974756_370328772682897_2472159522260645793_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0JU9LYssNmkQ7kNvgHVE1Yr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA41QT8VoN53saoLyAlC60z1OT1D117BEUios5fq8bhBA&oe=67713EE7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "InTraveler VR", "keywords": ["Detective", "Intraveler", "Milo", "Mental", "Wellness"], "long_description": "InTraveler VR is a story-driven adventure game set in mind-bending worlds inside the minds of people suffering from mental weaknesses. Experiencing a new dimension of worlds from their perspectives, solving intriguing puzzles as you traverse their story.\n\nGuided by an InTraveler, detective Milo, to travel through Inner worlds saving those trapped inside their own worlds. Follow in Milo\u2019s footsteps as you discover clues and secrets of each unique character, untangle the mystery of one\u2019s mindscape.\n\n**2 Game modes**\n\nStory mode \u2013 Experience the story of Intraveler VR.\n\nArcade mode \u2013 Choose and play chapter-specific minigames of your choice.\n", "short_description": "InTraveler VR is a story-driven adventure game set in mind-bending worlds inside the minds of people suffering from mental weaknesses. Experiencing a new dimension of worlds from their perspectives, solving intriguing puzzles as you traverse their story.\nGuided by an InTraveler, detective Milo, to travel through Inner worlds saving those trapped inside their own worlds. Follow in Milo\u2019s footsteps as you discover clues and secrets of each unique character, untangle the mystery of one\u2019s mindscape."}, {"images": {"nodes": [{"file_name": "7 - PDP Art (product details page).png", "id": "8086078954778417", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031578_8086078958111750_6065740976657399250_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3vAy_6HfqIQ7kNvgEa-0sC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZ1dV5jwV-9FCJRCzaHkPecondMB4Os8ChVP-xysq6KA&oe=67712B50"}, {"file_name": "5 - Cover Art \u2013 Portrait.png", "id": "1196994604748735", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031639_1196994608082068_1180372112004557971_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QiMSAd1mNUwQ7kNvgEOVoNz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2tqMR6447RdqlxyC8FfykMAe_VO_Gc7aG8lO1G1Ucfw&oe=67714B0E"}, {"file_name": "3 - Cover Art \u2013 Landscape.png", "id": "1196806104922163", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982510_1196806108255496_4600979568657765668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lNlDUR6U1_EQ7kNvgGkzyVq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDYTeaKFXOKRGlgq1ng1w171eR1i0GWVRvyWKlq69-bWA&oe=6771218D"}, {"file_name": "2 - Icon 3.png", "id": "1037645074405423", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036671_1037645081072089_7472962019283868741_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N8HZX5lu8eMQ7kNvgEyueFy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDu0XUnAjxPZ2DaeqRWOaLP3e3SMCf_VebPD-3GdIIRpQ&oe=677145C8"}, {"file_name": "6 - Cover Art \u2013 Mini Landscape.png", "id": "815301317342914", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036644_815301320676247_7671440973420642809_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E_61QRxUf94Q7kNvgE3uPoi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00