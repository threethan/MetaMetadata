-2.oculuscdn.com/v/t64.5771-25/38974862_3950716541917525_3547774517994781167_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V4sJcqYJHlUQ7kNvgFEFJpr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbCHELdjznhmkFunJRHT9dBpmWuKragS81wuDmGAB8bA&oe=67432CEC"}, {"file_name": "8 - Screenshots 5.png", "id": "370328769349564", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974756_370328772682897_2472159522260645793_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c9YFFnDw2nUQ7kNvgEkc8ZS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDP3PLRXRIE29Y9FdD_tt4mXPPXWvZAkqqFUc4b1Dloww&oe=67431A67"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "InTraveler VR", "keywords": ["Detective", "Intraveler", "Milo", "Mental", "Wellness"], "long_description": "InTraveler VR is a story-driven adventure game set in mind-bending worlds inside the minds of people suffering from mental weaknesses. Experiencing a new dimension of worlds from their perspectives, solving intriguing puzzles as you traverse their story.\n\nGuided by an InTraveler, detective Milo, to travel through Inner worlds saving those trapped inside their own worlds. Follow in Milo\u2019s footsteps as you discover clues and secrets of each unique character, untangle the mystery of one\u2019s mindscape.\n\n**2 Game modes**\n\nStory mode \u2013 Experience the story of Intraveler VR.\n\nArcade mode \u2013 Choose and play chapter-specific minigames of your choice.\n", "short_description": "InTraveler VR is a story-driven adventure game set in mind-bending worlds inside the minds of people suffering from mental weaknesses. Experiencing a new dimension of worlds from their perspectives, solving intriguing puzzles as you traverse their story.\nGuided by an InTraveler, detective Milo, to travel through Inner worlds saving those trapped inside their own worlds. Follow in Milo\u2019s footsteps as you discover clues and secrets of each unique character, untangle the mystery of one\u2019s mindscape."}, {"images": {"nodes": [{"file_name": "7 - PDP Art (product details page).png", "id": "8086078954778417", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031578_8086078958111750_6065740976657399250_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i50Nl38RI8cQ7kNvgEiHQyx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjrAPIoCuIvfzZaM47hMTt0jA0BG1tbbcwNul7InyCIQ&oe=674306D0"}, {"file_name": "5 - Cover Art \u2013 Portrait.png", "id": "1196994604748735", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031639_1196994608082068_1180372112004557971_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Qs5iU1VFAYQ7kNvgEaTkD1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAysLMpAHjpSHBQOviY2imrEWteXsuFTR4IAHmeWPosoA&oe=6743268E"}, {"file_name": "3 - Cover Art \u2013 Landscape.png", "id": "1196806104922163", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982510_1196806108255496_4600979568657765668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W3Ku7HSx6JoQ7kNvgEsunxn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBr4F6pfFcvbnV6mWGyRBBgGAush6M4XIAhJ88hUO0hGg&oe=6742FD0D"}, {"file_name": "2 - Icon 3.png", "id": "1037645074405423", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036671_1037645081072089_7472962019283868741_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_GnRabGuHD0Q7kNvgEDIf_K&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_vRg0SColHKvVRzGpSH2lp1mCmAnk9wOCGAe62WUHsA&oe=67432148"}, {"file_name": "6 - Cover Art \u2013 Mini Landscape.png", "id": "815301317342914", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036644_815301320676247_7671440973420642809_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uh3J6PqiK68Q7kNvgFbkidY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00