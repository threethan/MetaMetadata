"video_trailer_thumbnail": null, "display_name": "InTraveler VR", "keywords": ["Detective", "Intraveler", "Milo", "Mental", "Wellness"], "long_description": "InTraveler VR is a story-driven adventure game set in mind-bending worlds inside the minds of people suffering from mental weaknesses. Experiencing a new dimension of worlds from their perspectives, solving intriguing puzzles as you traverse their story.\n\nGuided by an InTraveler, detective Milo, to travel through Inner worlds saving those trapped inside their own worlds. Follow in Milo\u2019s footsteps as you discover clues and secrets of each unique character, untangle the mystery of one\u2019s mindscape.\n\n**2 Game modes**\n\nStory mode \u2013 Experience the story of Intraveler VR.\n\nArcade mode \u2013 Choose and play chapter-specific minigames of your choice.\n", "short_description": "InTraveler VR is a story-driven adventure game set in mind-bending worlds inside the minds of people suffering from mental weaknesses. Experiencing a new dimension of worlds from their perspectives, solving intriguing puzzles as you traverse their story.\nGuided by an InTraveler, detective Milo, to travel through Inner worlds saving those trapped inside their own worlds. Follow in Milo\u2019s footsteps as you discover clues and secrets of each unique character, untangle the mystery of one\u2019s mindscape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.actplusstudio.hk/intravelervrpolicy", "developer_terms_of_service_url": null, "publisher_name": "Act Plus Education Foundation Limited", "support_website_url": null, "website_url": "https://www.actplusstudio.hk/intravelervr", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", 