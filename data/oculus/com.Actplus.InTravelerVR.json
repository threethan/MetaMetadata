019904029639_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ep4X651JSE8Q7kNvgFduZAV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcT0j9rs87MpGQUrAHCGHKLSqPbn1A-2HCI2WN_O0Ybw&oe=671E1B7C"}, {"file_name": "8 - Screenshots 5.png", "id": "1167291634373274", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240103_1167291637706607_7641633198807496496_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TCh06dTatQ8Q7kNvgGo-bYJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjVjJhgqrHDqNzOG02ItrCFQga-ll81555oolITILKqg&oe=671E1FED"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u5fc3\u9748\u5075\u63a2 VR", "keywords": ["\u5fc3\u9748\u5075\u63a2", "\u5fc3\u9748", "\u5075\u63a2", "\u89e3\u8b0e", "\u7c73\u6d1b"], "long_description": "\u300a\u5fc3\u9748\u5075\u63a2VR \u300b\u662f\u4e00\u6b3e\u6545\u4e8b\u5411\u7684\u5192\u96aa\u904a\u6232\uff0c\u4ee5\u5fc3\u7406\u5275\u50b7\u8005\u7684\u5fc3\u9748\u4e16\u754c\u70ba\u80cc\u666f\uff0c\u8b93\u73a9\u5bb6\u9ad4\u9a57\u7d93\u6b77\u4e00\u6bb5\u6bb5\u7570\u60f3\u5929\u958b\u7684\u65c5\u7a0b\u3002\n\n\u5728\u5fc3\u9748\u5075\u63a2\u7c73\u6d1b\u7684\u5f15\u5c0e\u4e4b\u4e0b\uff0c\u73a9\u5bb6\u5c07\u7a7f\u68ad\u65bc\u5fc3\u9748\u4e16\u754c\u4e4b\u9593\uff0c\u4ee5\u52a9\u624b\u7684\u8eab\u4efd\uff0c\u5354\u52a9\u90a3\u4e9b\u88ab\u81ea\u8eab\u5fc3\u9748\u6240\u56f0\u7684\u89d2\u8272\u3002\u73a9\u5bb6\u6703\u4f7f\u7528\u5fc3\u9748\u5075\u63a2\u7684\u7279\u6b8a\u5de5\u5177\u5c0b\u627e\u7dda\u7d22\uff0c\u8abf\u67e5\u6bcf\u500b\u89d2\u8272\u7684\u6848\u4ef6\uff0c\u6df1\u5165\u6316\u6398\u4ed6\u5011\u904e\u53bb\u7684\u56de\u61b6\uff0c\u7834\u89e3\u4ed6\u5011\u5167\u5fc3\u6df1\u8655\u7684\u91cd\u91cd\u8b0e\u984c\u3002\n\n\u8ddf\u96a8\u7c73\u6d1b\u4e00\u540c\u7d93\u6b77\u4e0d\u540c\u7684\u6545\u4e8b\uff0c\u4e00\u908a\u8abf\u67e5\u89d2\u8272\u88ab\u56f0\u7684\u771f\u76f8\uff0c\u4e00\u908a\u63a2\u7a76\u4eba\u985e\u5fc3\u9748\u7684\u5967\u79d8\u3002\n\n\u904a\u6232\u8a2d\u6709\u5169\u7a2e\u6a21\u5f0f\uff1a\n\n- \u6545\u4e8b\u6a21\u5f0f\uff1a\u9ad4\u9a57\u300a\u5fc3\u9748\u5075\u63a2VR\u300b\u7684\u6545\u4e8b\u3002\n\n- \u8857\u6a5f\u6a21\u5f0f\uff1a\u9078\u64c7\u4e26\u904a\u73a9\u60a8\u559c\u6b61\u7684\u7279\u5b9a\u7ae0\u7bc0\u5c0f\u904a\u6232\u3002\n", "short_description": "\u300a\u5fc3\u9748\u5075\u63a2VR \u300b\u662f\u4e00\u6b3e\u6545\u4e8b\u5411\u7684\u5192\u96aa\u904a\u6232\uff0c\u4ee5\u5fc3\u7406\u5275\u50b7\u8005\u7684\u5fc3\u9748\u4e16\u754c\u70ba\u80cc\u666f\uff0c\u8b93\u73a9\u5bb6\u9ad4\u9a57\u7d93\u6b77\u4e00\u6bb5\u6bb5\u7570\u60f3\u5929\u958b\u7684\u65c5\u7a0b\u3002\n\u5728\u5fc3\u9748\u5075\u63a2\u7c73\u6d1b\u7684\u5f15\u5c0e\u4e4b\u4e0b\uff0c\u73a9\u5bb6\u5c07\u7a7f\u68ad\u65bc\u5fc3\u9748\u4e16\u754c\u4e4b\u9593\uff0c\u4ee5\u52a9\u624b\u7684\u8eab\u4efd\uff0c\u5354\u52a9\u90a3\u4e9b\u88ab\u81ea\u8eab\u5fc3\u9748\u6240\u56f0\u7684\u89d2\u8272\u3002\u73a9\u5bb6\u6703\u4f7f\u7528\u5fc3\u9748\u5075\u63a2\u7684\u7279\u6b8a\u5de5\u5177\u5c0b\u627e\u7dda\u7d22\uff0c\u8abf\u67e5\u6bcf\u500b\u89d2\u8272\u7684\u6848\u4ef6\uff0c\u6df1\u5165\u6316\u6398\u4ed6\u5011\u904e\u53bb\u7684\u56de\u61b6\uff0c\u7834\u89e3\u4ed6\u5011\u5167\u5fc3\u6df1\u8655\u7684\u91cd\u91cd\u8b0e\u984c\u3002\n\u8ddf\u96a8\u7c73\u6d1b\u4e00\u540c\u7d93\u6b77\u4e0d\u540c\u7684\u6545\u4e8b\uff0c\u4e00\u908a\u8abf\u67e5\u89d2\u8272\u88ab\u56f0\u7684\u771f\u76f8\uff0c\u4e00\u908a\u63a2\u7a76\u4eba\u985e\u5fc3\u9748\u7684\u5967\u79d8\u3002\n"}, {"images": {"nodes": [{"file_name": "5 - Cover Art \u2013 Portrait.png", "id": "2298313853843803", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196228_2298313857177136_9092487723564688740_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H-09KW8GVUIQ7kNvgEBlaDG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9NBaQ820x4j_WDjaeEnc7J3s1SRa2QH8dBV5VlPbSaA&oe=671E0EC1"}, {"file_name": "2 - Icon 3.png", "id": "1556631668394593", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-