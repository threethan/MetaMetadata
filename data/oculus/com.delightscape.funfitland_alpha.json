-7&_nc_sid=6e7a0a&_nc_ohc=9p2Xq26YD9cQ7kNvgHybUCs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5jtp3G3TBiYodaq4drF5XdBOl7qqCsgzW4iabm-H5CQ&oe=674AE660"}, {"file_name": "3.png", "id": "6636089333126992", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031360_6636089336460325_3054016984900627763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bZ0AYFHFRs0Q7kNvgFTbSV_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCoPJZNyUkfOpUVAIL2Wvma71JF1rulLwlmlHUnpooEFw&oe=674AF151"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "funfitland after preview.png", "id": "772384328174930", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75326675_772384331508263_9104009070075037217_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c-TqEN2GYPcQ7kNvgEov47U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCfyCRKVzZQBWU9Cth3JOwhU9-o-Z7Ra5eOnRjWJ-doiA&oe=674B0C61"}, "display_name": "FunFitLand", "keywords": ["boxing", "fitness", "dance", "workout", "fit"], "long_description": "**Experience a whole new way to work out--so fun, you'll fortet you're working out!** Start your free 14-day trial today, cancel anytime, and discover your own unique journey to fitness.\n\n**\u2b50\ufe0f A Choice You Won\u2019t Regret**\n\nThe highest-rated fitness app on Quest and award-winning, including the SideQuest Indie Spotlight 2023, Qualcomm XR Innovation Award for \"Best Fitness App,\" UploadVR\u2019s Top 4 Watchlist 2024...\n\n**\ud83c\udf89 Enjoy the Most Delightful Fitness Experience**\n\nStep into spectacular 360\u00b0 environments and train with expert coaches. Every session is crafted by world-class combat and dance specialists, making each workout engaging, fresh, and designed to keep you coming back for more.\n\n**\ud83d\udd25 Never Get Bored! Unlimited New Experiences Await**\n\nWith new workouts added every week, enjoy a constant flow of exciting routines, stunning environments, and unique activities that make your fitness journey anything but routine.\n\n**\ud83d\udcaa A Whole New Way to Train with Real Equipment**\n\nElevate your workout with real equipment like dumbbells and cable machines, taking your fitness experience to the next level\u2014all made possible with hand tracking and Mixed Reality support.\n\n**\ud83e\udd1d Supported Everywhere, Every Step of the Way**\n\nCelebrate every milestone and tackle each challenge with a supportive community across Facebook, Reddit, and Discord, where fitness is more than just a goal; it's a nurtured journey.\n\nStart your free trial today and redefine what fitness can be! Available on Meta Quest 2, Meta Quest 3, Meta Quest 3s, and Meta Quest Pro.", "short_description": "Dive into a journey so enjoyable that you'll forget you're working out. Engage with premium workouts that feel intuitive, delightful, and refreshingly new."}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.termly.io/document/privacy-policy/0163988b-469b-4e76-947f-625a686149bd", "developer_terms_of_service_url": "https://app.termly.io/document/terms-of-service/a47ec382-a72e-4903-bffd-f846c153ff8d", "publisher_name": "DelightScape Interactives", "support_website_url": null, "website_url": "https://www.funfitland.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}, {"id": "1228796255027646"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9089214281109216"}, "revi