t64.5771-25/57575360_2930713907070629_5092048639601029686_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lLxV8C5Eb_QQ7kNvgH6o1QW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpUL4TycIjU5rTF-cjpVVioGVQSrzgseKPir8-KG7KAQ&oe=66E2CED7"}, {"file_name": "1.png", "id": "893783675697466", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_893783679030799_382586088077897792_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k-Or_Bor-yIQ7kNvgEwpbmH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmrRVuSdIx9sTvvQhQX037D-Z2OCfRepU3t-fI02aEAw&oe=66E2BA33"}, {"file_name": "ss5.png", "id": "2412276982310625", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75532179_2412276985643958_8923718928593194234_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-kPalEEHh48Q7kNvgE7Saq5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBozYT5T5psHO5av7eKLy4jOWU6Llb9gjuenB79Mqd03Q&oe=66E2C2F6"}, {"file_name": "ui.png", "id": "717983739664130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031482_717983742997463_5533430577157724947_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1nSIS-4Uk6AQ7kNvgEi-pPr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCeQXQ86EwKunfMsUWDqYiqj_pmh0c4a6zx1vsH5kXyQ&oe=66E2B9F7"}, {"file_name": "3.png", "id": "6636089333126992", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031360_6636089336460325_3054016984900627763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7e7ZM6uynIAQ7kNvgEMKd0v&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHM5krVyMBwgarZ6sW2NwL63-zgWBrvcDuinGEhoQD_A&oe=66E2CAD1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "292313986974027", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75326675_292313996974026_2821468147987449922_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qtay5-yiv3sQ7kNvgHYxQjz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJaPWHuP0Lfmoz0dLeQMKXCR13zpOaoi0N8zKTLi1UNA&oe=66E2D997"}, "display_name": "FunFitLand", "keywords": [], "long_description": "Discover FunFitLand: Dive into a world of truly innovative fitness adventures. Encounter workouts that feel instinctive, utterly delightful, and unmistakably new. JOIN ALPHA NOW and co-create a fitness journey that resonates with your vibe. \n\n\ud83d\udc83 DanceFit: More Than Just Dance\nExperience dance in a new light with DanceFit, where every beat turns into a spontaneous step, making each workout feel like a lively dance party. Whether with a controller or just your hands, the experience is immersive, allowing you to explore the essence of movement in a fitness-oriented manner.\n\n\ud83e\uddb8 CombatFit: Embrace the Fighter Within\nUnleash your energy with CombatFit. Engage in sequences that feel organic. Each strike and combo brings a rush, making workouts thrilling.\n\n\u270b Hand-Tracking **Experimental**\nGo controller-free! Natural hand movements lead you through a new world of possibilities \u2014 chop, slash, even finger snaps!\n\n\ud83c\udfcb\ufe0f Real Coaches, Always On:\nWith our dedicated coaches by your side, you're never alone. They guide, motivate, and help you harness the full potential of every session.\n\n\ud83c\udf08 A Visual Feast\nEnjoy workouts within stunning landscapes that enhance your fitness journey with beauty and engagement.\n\n\ud83e\udd1d Become a Part of FunFitLand\nJoin a community where your feedback and success are celebrated. Here, workouts are more than just exercise; they're a fun journey we take together. Your thoughts help us improve, making fitness both enjoyable and rewarding for everyone.", "short_description": "Step into FunFitLand, where dance grooves and combat moves blend in a fresh and innovative fitness experience! Try DanceFit, where every beat turns into a spontaneous step, making each workout feel like a lively party. Want something more intense? CombatFit provides a new, thrilling rush. With our passionate and friendly coaches leading the way, each session is bursting with energy and enjoyment. JOIN ALPHA NOW and immerse yourself in the FunFitLand community \u2013 where fun and fitness converge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.termly.io/document/privacy-policy/0163988b-469b-4e76-947f-625a686149bd", "developer_terms_of_service_url": "https://app.termly.io/document/terms-of-service/a47ec382-a72e-4903-bffd-f846c153ff8d", "publisher_name": "DelightScape Interactives", "support_website_url": null, "website_url": "https://www.funfitland.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "950473746010167"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "567548612173298"}]}, "baseline_offer": {"id": "567548612173298"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1698699054, "status": "PUBLISHED", "id": "567548612173298"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8620083044689011", "version": "QB.2.01.09"}, "id": "853446335716234", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6909643465732986", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8620083044689011"}, "release_status": "RELEASED"}, "binary_