-7&_nc_sid=6e7a0a&_nc_ohc=On1TDLGJD1oQ7kNvgFhP720&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDa-1Mn8tduhy4onC9iKyiU0cPDYvmxgUs5Mo_TMC5htg&oe=672C93E0"}, {"file_name": "3.png", "id": "6636089333126992", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031360_6636089336460325_3054016984900627763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LL0EGzIjoCQQ7kNvgFmA0nh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChjzvLS87tBS0TlIMJ5hjK0UdFybpMNRE0obrFFRgpbA&oe=672C9ED1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "funfitland after preview.png", "id": "772384328174930", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75326675_772384331508263_9104009070075037217_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aMf8xGHW3KAQ7kNvgGsogmk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFokmfZSJtdjDLSdQZBD_fdAtTFMv5B_5Mra1GC6rxFw&oe=672CB9E1"}, "display_name": "FunFitLand", "keywords": ["boxing", "fitness", "dance", "workout", "fit"], "long_description": "# \ud83c\udf89 Start Your Free Trial and Secure the Best Deal! \ud83c\udf89\n\nUnlock full access to **premium workouts updated weekly**, immersive features, and personalized plans crafted just for you. Don't miss out\u2014join now and **save up to 42%** with our exclusive, limited-time offer! \ud83d\udd25\n\n{751803970472768}\n\n# \ud83c\udf1f The Most Delightful Journey Awaits \ud83c\udf1f\n\nDive into a journey so enjoyable that you'll forget you're working out. Engage with premium workouts that feel intuitive, delightful, and refreshingly new.\n\n# \ud83c\udfc6 Unmatched Quality in Every Workout \ud83c\udfc6\n\nWe believe in craftsmanship, dedicating nearly 300 hours to perfect every detail in every workout. Every scene, every movement, every word of guidance is crafted for your enjoyment.\n\n{1216459219695204}\n\n**\ud83d\udc83 Experience the most intuitive and liberating dance workouts**\n\n{1657631788346812}\n\n**\ud83e\udd4a Unleash your inner fighter with CombatFit**\n\n{2250756945323103}\n\n**\ud83c\udf08 Immerse yourself in spectacular environments**\n\n{981484383329779}\n\n**\ud83c\udfcb\ufe0f Real coaches, always cheering you on**\n\n# \ud83d\ude80 Unlimited New Experiences Await \ud83d\ude80\n\nEmbark on a life-changing journey, made possible through continuous innovations like hand tracking, MR modes, social integrations, new workout types, and so much more magic to come!\n\n{2117290371982006}\n\n**\u270b Go controller-free with hand tracking (experimental)! Experience the next generation of intuitive workouts.**\n\n{494248173522346}\n\n**\ud83d\udc40 Try mixed-reality mode for an entirely fresh experience.**\n\n# \ud83e\udd1d Supported at Every Turn \ud83e\udd1d\n\nEvery achievement is celebrated, every challenge met with support\u2014thanks to our vibrant, encouraging community, where fitness is more than a goal; it's a nurtured journey.\n\n# Are you ready to work out your FUN way?\n\n\n\n\n", "short_description": "Dive into a journey so enjoyable that you'll forget you're working out. Engage with premium workouts that feel intuitive, delightful, and refreshingly new."}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.termly.io/document/privacy-policy/0163988b-469b-4e76-947f-625a686149bd", "developer_terms_of_service_url": "https://app.termly.io/document/terms-of-service/a47ec382-a72e-4903-bffd-f846c153ff8d", "publisher_name": "DelightScape Interactives", "support_website_url": null, "website_url": "https://www.funfitland.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}, {"id": "1228796255027646"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb