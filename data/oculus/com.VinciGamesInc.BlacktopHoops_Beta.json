ding indie brands and shoe designers. Become the G.O.A.T.\n", "short_description": "Chain together flashy dribble tricks, shots, and high-flying dunks to finish off opponents in epic games of 1-on-1 streetball in Blacktop Hoops.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.blacktophoopsvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.blacktophoopsvr.com/terms-of-use", "publisher_name": "Vinci Games", "support_website_url": "https://www.blacktophoopsvr.com/support", "website_url": "https://www.blacktophoopsvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "693641628617687"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "2874484812741860"}, {"status": "PUBLISHED", "id": "1313658550017831"}, {"status": "PUBLISHED", "id": "798649302039932"}, {"status": "PUBLISHED", "id": "962428858998038"}, {"status": "PUBLISHED", "id": "25938762025737419"}, {"status": "PUBLISHED", "id": "1106466777136966"}, {"status": "PUBLISHED", "id": "1481768162447095"}, {"status": "PUBLISHED", "id": "2436572466550301"}, {"status": "PUBLISHED", "id": "1297313197424871"}, {"status": "PUBLISHED", "id": "735173095164738"}]}, "baseline_offer": {"id": "2436572466550301"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731006000, "status": "PUBLISHED", "id": "2874484812741860"}]}, "live