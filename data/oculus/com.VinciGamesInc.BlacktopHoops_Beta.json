=676FCD3A"}, {"file_name": "BH-SC4.png", "id": "717165745955283", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974583_717165749288616_5630488830920959774_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EhU6UTC08fYQ7kNvgHJM1aj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkL9Lx6zenktoEV69GWXvQcWb-KTyxpU66BOGo4kdjtg&oe=676FDEBB"}, {"file_name": "BH-SC3.png", "id": "3124894027758518", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86631743_3124894031091851_2941008453356497014_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LJ2DeAVpmEYQ7kNvgEJ3Tx_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApDN1-be3gvUrqSHIIApjzME8d2TX6YDgHvl76Ocg_4w&oe=676FD681"}, {"file_name": "BH-SC9.png", "id": "1501767363611550", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240099_1501767366944883_5916997000706158803_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0pmBM7C_Cp8Q7kNvgG1UeRU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMLpDLJXe3ZoB_zo7-30CMGLDHyThqot4B5MQG2Mqv1A&oe=676FDC3D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BH-Demo-CoverLandscape-2560x1440@3x.png", "id": "1166103434215700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036670_1166103437549033_1399066160305085332_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YMgrwd503a8Q7kNvgEx0vr6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDuGPAdnFSBePWR07wKNn5mon7eKiyncsybJMuK5tDGNQ&oe=676FE5E5"}, "display_name": "Blacktop Hoops - Alpha", "keywords": [], "long_description": "Blacktop Hoops is the world\u2019s first competitive VR streetball game. Players can chain together flashy dribble tricks, shots, and high-flying dunks to finish off opponents the globe in epic games of 1-on-1 streetball. The game was designed with the most realistic basketball mechanics ever built for virtual reality. Play against dynamic AI with mocap animations from pro streetball players and dunkers. Ball out to an original 90s-inspired soundtrack with narration from legendary emcees Bobbito Garcia and WNBA legend Renee Montgomery. Unlock 30+ kicks from leading indie brands and shoe designers. Become the G.O.A.T.\n", "short_description": "Chain together flashy dribble tricks, shots, and high-flying dunks to finish off opponents in epic games of 1-on-1 streetball in Blacktop Hoops.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.blacktophoopsvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.blacktophoopsvr.com/terms-of-use", "publisher_name": "Vinci Games", "support_website_url": "https://www.blacktophoopsvr.com/support", "website_url": "https://www.blacktophoopsvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SPORTS", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "693641628617687"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "2874484812741860"}, {"status": "PUBLISHED", "id": "1313658550017831"}, {"status": "PUBLISHED", "id": "798649302039932"}, {"status": "PUBLISHED", "id": "962428858998038"}, {"status": "PUBLISHED", "id": "25938762025737419"}, {"status": "PUBLISHED", "id": "1106466777136966"}, {"status": "PUBLISHED", "id": "1481768162447095"}, {"status": "PUBLISHED", "id": "2436572466550301"}, {"status": "PUBLISHED", "id": "1297313197424871"}, {"status": "PUBLISHED", 