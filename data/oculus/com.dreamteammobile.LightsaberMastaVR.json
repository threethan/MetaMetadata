FA&oe=67090014"}, {"file_name": "Screen1.png", "id": "236452534703777", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974809_236452538037110_2979880150285965719_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=60cOWc55CfoQ7kNvgEJOAJq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALF0sWDVMds3XRt8_kssRtRTcG9fe7KGANQwAM52PLVg&oe=67091514"}, {"file_name": "ESMVR-NewRelease-1-17-Demo-Cover-2560.png", "id": "201314355139295", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75282168_201314358472628_5534199337026705058_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKJv6pIf4MsQ7kNvgHg5tBi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVHq3_KqFyZgxz0ibuBml21qA1ZG-PwXotjiy2NE8flA&oe=67091B56"}, {"file_name": "Screen3.png", "id": "102966335057834", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974827_102966338391167_5016676235978288126_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G6NRTKQCQ-sQ7kNvgFGm1L8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEaxlwzx__zSPVV7ebnN-uoh465uNTqnPFx_kUZRR5Mw&oe=67090869"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screen1.png", "id": "218608259977806", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031495_218608263311139_6027119395023712781_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gJk4asz2ejUQ7kNvgFK-mEP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCqkJI2MXdBPo5dSe3NunRT3SEd1ksJNjzw7YYuNOvvAw&oe=6709176F"}, "display_name": "Energysaber Masta VR", "keywords": [], "long_description": "A long time ago in a galaxy far, far away...\n\nJust kidding\n\nBut imagine yourself standing in magnet boots on top of the spaceship, overlooking a galaxy, equipped with 2 energysabers with built-in rail-guns, hearing this alien synth sound alarming you about the drones coming up in different shapes and styles. Be the masta of your sabers and your people. Protect yourself and protect them.\n\nPhysical and mind activities:\n- 360 arm swings\n- 180 body rotation\n- Squats\n- Dodging lasers\n- Precision training\n- Attention exercising\n- Spaceship walking if you have enough room\n\nIt's a VR deep-space experience.\nIt's a survival game.\nGood luck!\n\nPlease, join our Discord server: \nhttps://discord.gg/Q4yEbzw", "short_description": "Defense style game. Energysabers with built-in rail-guns. On the spaceship in the deep universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://drmtm.blob.core.windows.net/policies/energysabervr/privacypolicy.pdf", "developer_terms_of_service_url": "https://drmtm.blob.core.windows.net/policies/energysabervr/EnergysaberMastaVR-TermsOfService-TOS.pdf", "publisher_name": "DreamTeam Mobile", "support_website_url": "https://energysabermastavr.carrd.co/", "website_url": "https://energysabermastavr.carrd.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5805124576260804"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003273_1407492846288546_3926540595902703484_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r4oE_XhGBzwQ7kNvgEfO5eP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlwM7LITTRz2zDXMtMJf7R07nL1ThZF7g76m4zFxYAxg&oe=67091614"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Energysaber Mas