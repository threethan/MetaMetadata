 synth sound alarming you about the drones coming up in different shapes and styles. Be the masta of your sabers and your people. Protect yourself and protect them.\n\nPhysical and mind activities:\n- 360 arm swings\n- 180 body rotation\n- Squats\n- Dodging lasers\n- Precision training\n- Attention exercising\n- Spaceship walking if you have enough room\n\nIt's a VR deep-space experience.\nIt's a survival game.\nGood luck!", "short_description": "Defense style game. Energysabers with built-in rail-guns. On the spaceship in the deep universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://drmtm.blob.core.windows.net/policies/energysabervr/privacypolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "DreamTeam Mobile", "support_website_url": "https://energysabermastavr.carrd.co/", "website_url": "https://energysabermastavr.carrd.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5015507175182918"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "2887139881607608"}, {"status": "PUBLISHED", "id": "463782574888599"}, {"status": "PUBLISHED", "id": "804100900927157"}]}, "baseline_offer": {"id": "804100900927157"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1615316040, "status": "PUBLISHED", "id": "2887139881607608"}]}, "liveCh