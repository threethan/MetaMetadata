Protect yourself and protect them.\n\nPhysical and mind activities:\n- 360 arm swings\n- 180 body rotation\n- Squats\n- Dodging lasers\n- Precision training\n- Attention exercising\n- Spaceship walking if you have enough room\n\nIt's a VR deep-space experience.\nIt's a survival game.\nGood luck!\n\nPlease, join our Discord server: \nhttps://discord.gg/Q4yEbzw", "short_description": "Defense style game. Energysabers with built-in rail-guns. On the spaceship in the deep universe."}]}, "developer_name": null, "developer_privacy_policy_url": "https://drmtm.blob.core.windows.net/policies/energysabervr/privacypolicy.pdf", "developer_terms_of_service_url": "https://drmtm.blob.core.windows.net/policies/energysabervr/EnergysaberMastaVR-TermsOfService-TOS.pdf", "publisher_name": "DreamTeam Mobile", "support_website_url": "https://energysabermastavr.carrd.co/", "website_url": "https://energysabermastavr.carrd.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5805124576260804"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003273_1407492846288546_3926540595902703484_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lrkeTZbhQhkQ7kNvgG49yQ3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA1mUg-wa8br-t4-LUfx4nFv2JNL7VfMYto4raf