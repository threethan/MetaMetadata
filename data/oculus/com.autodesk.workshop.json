46"}, {"file_name": "3-Inspect Properties Image.png", "id": "324343430142954", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974871_324343433476287_8918942951199295624_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IJRkr6xlR0wQ7kNvgF83916&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgBNcxT2QSxsU71htfZO1gwa6a3ywfDJqdcUMXXaRsVA&oe=6713ABDD"}, {"file_name": "4-Workshop Image.png", "id": "999692381122745", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984460_999692384456078_4612545688317797888_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BxvhFUz1z9sQ7kNvgFpYDZs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBOKwWCWXR30wfPmkjCX1DyfQWvKx1aZVPW4qbOPLE3hw&oe=6713A4FC"}, {"file_name": "5-Issue Management Image.png", "id": "965478264755779", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974639_965478268089112_4308866345139591421_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KH3qeoIjSgEQ7kNvgG9vTfj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBm5mU-hLMN4cnFePc7ABJzwnp9m1NT9sA05tyrd-xbig&oe=67138DDB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Workshop XR", "keywords": [], "long_description": "ONLY AVAILABLE FOR LICENSED USERS. Sign up for the waitlist to stay updated when Workshop XR is available for you. Visit workshopxr.autodesk.com to learn more and request a free trial.\n__ \nAutodesk Workshop XR is an immersive workspace for Autodesk Construction Cloud where AEC teams can review and collaborate in their 3D models to track issues, catch errors, and enable better spatial understanding.\n\nWith automatically connected data, no-prep model streaming, and synced issue tracking, Workshop XR makes design reviews frictionless and efficient.\n\n**v1.0**\n\n- Load Revit or Navisworks Models from ACC into VR\n- Meet in a collaborative workshop with team members\n- Access supported ACC data like Files, Issues, and Model Browser Settings\n- Track and create issues\n\nAutodesk Workshop XR is compatible with Meta Quest 2, Meta Quest Pro, and Meta Quest 3.\n__ \nFOR LICENSED USERS ONLY \n(Visit workshopxr.autodesk.com to learn more and request a free trial.)", "short_description": "Immersive workspace for Autodesk Construction Cloud | Review and collaborate in your 3D models."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.autodesk.com/company/legal-notices-trademarks/privacy-statement", "developer_terms_of_service_url": null, "publisher_name": "Autodesk, Inc.", "support_website_url": null, "website_url": "https://workshopxr.autodesk.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1309326339782559"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1986824868356221"}]}, "baseline_offer": {"id": "1986824868356221"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709830800, "status": "PUBLISHED", "id": "1986824868356221"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8223077707801017", "version": "2.1.12"}, "id": "1103341383989130", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6311