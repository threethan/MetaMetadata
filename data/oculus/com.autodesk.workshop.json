00_AYB4TJ_YDX1WuIabpGOM9eKDAb820csPGkaffnc9anjz3A&oe=66EAD2C6"}, {"file_name": "3-Inspect Properties Image.png", "id": "324343430142954", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_324343433476287_8918942951199295624_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jlSFm9rSx2wQ7kNvgEvsVkB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgFnKm8i-EgRTVr7i0oNca9&oh=00_AYBoItCbiNxfOeWWelr8m_D0s-EQTifGDsYUfVV-K7D9SA&oe=66EACD5D"}, {"file_name": "4-Workshop Image.png", "id": "999692381122745", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_999692384456078_4612545688317797888_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Gd3-C6p5rAQ7kNvgFQVbC-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgFnKm8i-EgRTVr7i0oNca9&oh=00_AYDZWwQ_4Zx6cFiYsx28Y2t7USEeyBBZGWcyJMMAA3-xYg&oe=66EAC67C"}, {"file_name": "5-Issue Management Image.png", "id": "965478264755779", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974639_965478268089112_4308866345139591421_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bgUfezSVlTYQ7kNvgFEB83f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgFnKm8i-EgRTVr7i0oNca9&oh=00_AYASvSM7oN-HrHMjJAsGLm2QhfgxcYx9VQCy8I0Y2AcHdA&oe=66EAAF5B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Workshop XR", "keywords": [], "long_description": "ONLY AVAILABLE FOR LICENSED USERS. Sign up for the waitlist to stay updated when Workshop XR is available for you. Visit workshopxr.autodesk.com to learn more and request a free trial.\n__ \nAutodesk Workshop XR is an immersive workspace for Autodesk Construction Cloud where AEC teams can review and collaborate in their 3D models to track issues, catch errors, and enable better spatial understanding.\n\nWith automatically connected data, no-prep model streaming, and synced issue tracking, Workshop XR makes design reviews frictionless and efficient.\n\n**v1.0**\n\n- Load Revit or Navisworks Models from ACC into VR\n- Meet in a collaborative workshop with team members\n- Access supported ACC data like Files, Issues, and Model Browser Settings\n- Track and create issues\n\nAutodesk Workshop XR is compatible with Meta Quest 2, Meta Quest Pro, and Meta Quest 3.\n__ \nFOR LICENSED USERS ONLY \n(Visit workshopxr.autodesk.com to learn more and request a free trial.)", "short_description": "Immersive workspace for Autodesk Construction Cloud | Review and collaborate in your 3D models."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.autodesk.com/company/legal-notices-trademarks/privacy-statement", "developer_terms_of_service_url": null, "publisher_name": "Autodesk, Inc.", "support_website_url": null, "website_url": "https://workshopxr.autodesk.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1309326339782559"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1986824868356221"}]}, "baseline_offer": {"id": "1986824868356221"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709830800, "status": "PUBLISHED", "id": "1986824868356221"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7956810907761033", "version": "1.9.11"}, "id": "1103341383989130", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6311586865616787", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7956810907761033"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1103341383989130"}]}, "change_log": "Updates:\n- (NEW) Persistent Measurements: You can now identify the spatial distance between endpoints. Measurements are automatically visible to other users.\n- Easier Issue Creation: Create issues more intuitively and with fewer clicks.\n- Improved model load times and switching between 1:1 and workshop.\n\nWhat\u2019s Fixed:\n- Fixed an issue that could cause some users to lose the ability to control visibility via the Model Tab.\n- Fixed several bugs that resulted in app crashes.\n\nKnown Issues and Workarounds:\n- Users may intermittently lose the ability to go to or gather specific users due to a known issue with certain permission roles.\n- Button to open/close and reposition the console may lose functionality if the user goes to the Home space and then returns to a Workshop. To resolve this, exit the app and re-enter it.\n- Some users with lower permissions may not see measurements created by those with higher permission levels.\n- Users may hang in blank space for an extended time when exiting the workshop after working with large data sets.", "created_date": 1726007151, "id": "7956810907761033", "version": "1.9.11", "version_code": 358, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6311586865616787", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7956810907761033"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1103341383989130"}]}, "change_log": "New:\n- Added a blue overlay tint to indicate geometry that is still loading\nFixes\n- Resolved a crash when user leaves workshop\n- Bug fixes and improvements", "created_date": 1721945366, "id": "7675208725921254", "version": "1.6.10", "version_code": 357, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6311586865616787", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7956810907761033"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1103341383989130"}]}, "change_log": "Bug Fixes:\n- Resolved an issue causing the application to crash when the headset is put to sleep while the voice-to-text feature is still active", "created_date": 1719962327, "id": "7548199455288849", "version": "1.4.28+1-g8b1e", "version_code": 356, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6311586865616787", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7956810907761033"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1719954504, "id": "7547581125350682", "version": "1.4.28", "version_code": 355, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "