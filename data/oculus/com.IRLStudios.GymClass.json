hc=cjbePrUuyR8Q7kNvgH4bI89&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYB7g2y5JvyfZOjIyditQwj7Rn0gBjW_PQz_m8K7Y3fWkQ&oe=67289AD2"}]}, "id": "1062120598444007", "locale": "en_US", "screenshots": [{"file_name": "2024 Product Page Screenshots - 4.png", "id": "1509356679853452", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974853_1509356683186785_245496980552221799_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ROhAuulGg58Q7kNvgFE857S&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAdsUr7mm-uP3l27vEUrV9rcpVnJ7XqBseohXJqZhYnaw&oe=6728CCBD"}, {"file_name": "2024 Product Page Screenshots - 6 (1).png", "id": "3629811947307678", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974778_3629811950641011_1325301661716721494_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WSuhnadRSesQ7kNvgEVZgSV&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYDMnjseQIJ6MvWXO0ksMgJ5XQaDbYhclu94YJgwpkm3Zg&oe=6728B596"}, {"file_name": "sandbox.png", "id": "1065945105160628", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974567_1065945108493961_2792661541731211064_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V-d5OjNtSTwQ7kNvgGAbnfV&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBP9qMcjbylN2GPODVWhI9zi35MpzQwPvlcoD0UJW9YLQ&oe=6728C486"}, {"file_name": "2024 Product Page Screenshots - 8.png", "id": "937941248048494", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982608_937941251381827_4208153383432172814_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bVU0LanVhskQ7kNvgHki1Bf&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDYivpqOiusmPmzqZQYlRqlV8Ts9ZtMo82puBKVr9R5wA&oe=6728A7B2"}, {"file_name": "2024 Product Page Screenshots - 1 (1).png", "id": "1510867419692907", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38982603_1510867423026240_4268777374503305816_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ii-6hRLgCBEQ7kNvgGCUbZD&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAeprLoH3VTG0yed96lNrxXmjVMGX8zcTZnbeAsT36jnA&oe=6728CA03"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gymclass_trailer_cover_image_v05.png", "id": "794105814977946", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/38982516_794105818311279_4409523219033140330_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zCXTNPKLD2EQ7kNvgH2sRQT&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYCQ4WbUoi1v6CybuNuMNYgULhbjU2Yl5PpJ_pEZOyIPdw&oe=6728A24B"}, "display_name": "GYM CLASS - BASKETBALL VR", "keywords": ["basketball", "nba", "sports", "social", "football"], "long_description": "**GYM CLASS is the top VR basketball & sports game \ud83c\udfc0\ud83c\udfc8\u26be** \n\nExperience NBA licensed team courts, full-court multiplayer games, massive worlds, simulation physics, and football & baseball stadiums. Rated best on Quest - make friends or level-up to be the best among millions in the top VR sports community.\n\n{8704248146300574}\n\n**Download GC FREE to experience:** \n- \u2795 Unparalleled Simulation Physics: The most realistic physics in gaming. Control your shots, passes, dribble moves, and dunks like never before.\n- \ud83c\udfae Multiplayer Games: Play half, fullcourt, and minigames with friends or AI.\n- \ud83c\udf0d Social Worlds: Connect with friends in massive environments.\n- \ud83c\udfc8\u26be Multi-Sport: Basketball, football, baseball, arcade, & more.\n- \ud83c\udfa8 Endless Styles: Complete Quests to unlock cosmetics - hoodies, shirts, jerseys, suits, glasses, hats, mascot costumes, green sounds, & more.\n- \ud83c\udfc6 Level-up & Stats: Track deep stats (shots, assists, rebounds)\n\n{2315442282123322}\n\n**Buy the NBA Bundle to get:**\n- \ud83d\ude2e NBA team courts: Hoop on virtual replicas of all 30 NBA team courts with friends or AI.\n- \ud83c\udfc6 NBA team branded apparel & challenges: Two different sets of team-branded apparel, a team-branded basketball, and team-branded hat. Play games to unlock further items.\n- \ud83d\udc55 NBA Bundle premium items: Additional NBA & team-branded shirts, hoodies, basketballs & accessories is available to purchase separately.\n\n{969686844967912}\n\n**GC PRO unlocks:**\n- \ud83c\udfe0 Private Courts: Customize your world, set your rules. Play with friends privately on a wide set of GC environments.\n- \ud83d\udc55 Full-body Avatars: Design your player w/ max control. Hairstyles, face details, facial hair, body shapes, height, tattoos, and more.\n- \ud83c\udfa8 Cosmetics: Unlock a wide variety of cosmetics from hoodies, glasses, headphones, & gorilla around w/ banana hats.\n- \ud83e\udd16 Design Your Bot: Name, design, and level-up your bot. \n\n{557813239965509}", "short_description": "\ud83c\udfc0\ud83c\udfc8\u26be GYM CLASS is the top VR basketball & sports game. Experience NBA licensed team courts, full-court multiplayer games, massive worlds, simulation physics, and football & baseball stadiums. Rated best on Quest - make friends or level-up to be the best among millions in the top VR sports community."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gymclassvr.com/privacy", "developer_terms_of_service_url": "https://gymclassvr.com/tos", "publisher_name": "IRL Studios Inc.", "support_website_url": "https://gymclassvr.com/support", "website_url": "https://gymclassvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking