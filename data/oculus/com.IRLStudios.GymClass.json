": "937941248048494", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982608_937941251381827_4208153383432172814_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W7WHKk-mmnsQ7kNvgFsoElb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbMO4-4mQFegDDW7Mx9EgmNSQFXl0Yd94SDFYUZCDcig&oe=66D2F632"}, {"file_name": "2024 Product Page Screenshots - 6 (1).png", "id": "3629811947307678", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974778_3629811950641011_1325301661716721494_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C6SCuFNRLkIQ7kNvgE6-vx3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwb4u4MvnMmVwiNGZy-q1zp9Z-7F97m-IvikU0veyMWw&oe=66D30416"}, {"file_name": "R2 2024 Product Page Screenshots - 11.png", "id": "340419552265294", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974691_340419555598627_3827652328806099938_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AXVIAqDq9KQQ7kNvgG16J1A&_nc_ht=scontent.oculuscdn.com&oh=00_AYDAK708AutXpJ4u1dR836z1aM2FxVltyBbPYUnCIycbaA&oe=66D312ED"}, {"file_name": "2024 Product Page Screenshots - 4.png", "id": "1509356679853452", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974853_1509356683186785_245496980552221799_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xiTE-Z0sM7oQ7kNvgEHtWjX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcy4wAMhclcSnDmrizgRQT4U5stR-sHB4TcGI8On0L4w&oe=66D2E2FD"}, {"file_name": "2024 Product Page Screenshots - 1 (1).png", "id": "1510867419692907", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982603_1510867423026240_4268777374503305816_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RJ_rv3cKdIQ7kNvgGEliXb&_nc_ht=scontent.oculuscdn.com&oh=00_AYBo-TQvFDs8qecHkXpshFA04y5DVC98BfGSrbSfS2kKlw&oe=66D31883"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gymclass_trailer_cover_image_v05.png", "id": "794105814977946", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982516_794105818311279_4409523219033140330_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aG7_rbo77EsQ7kNvgEKYDbe&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQeXQ9Hs-oB00Cgr_7YWNo2DcHOhejq5YbWMrzlp0D0A&oe=66D2F0CB"}, "display_name": "GYM CLASS - BASKETBALL VR", "keywords": ["basketball", "nba", "sports", "social", "baseball"], "long_description": "\ud83c\udfc0\ud83c\udfc8\u26be GYM CLASS is the top VR basketball & sports game. Experience NBA licensed team courts with full-court games, social worlds for pickup games with friends, and football & baseball stadiums. Rated best on Quest, GC delivers top-notch simulation physics, environments, gameplay, avatars, and cosmetics. Tag your opponents in a fast-paced match, or play rec games - GC is where ballers unite.\n\nDownload free to enjoy:\n\ud83c\udfc8\u26be Sandbox: Football baseball, & more activities.\n\ud83c\udf0d Social Worlds: Connect to the best community in epic environments.\n\u2795 Physics Engine: Use real-life shooting, passing, dribbling in realtime, multiplayer games. Get superpowers w/ insane dunks too.\n\ud83e\udd16 Game Modes: Multiplayer 2v2, 3v3, & 4v4 game modes & AI.\n\ud83c\udfa8 Design Your Look: Complete challenges to unlock cosmetics.\n\ud83c\udfc6 Stats & Matchmaking: Track your wins and improve your skills.\n\nNBA Bundle unlocks:\n\ud83d\ude2e NBA team courts: Virtual replicas of all 30 NBA team courts.\n\ud83d\udc55 NBA team branded apparel: Two different sets of team-branded apparel, a team-branded basketball, and team-branded hat. Additional NBA & team-branded basketballs & accessories is available for purchase separately.\n\ud83c\udfc6 NBA Bundle Challenges: Play games to unlock NBA team features.\n\nGC PRO unlocks: \n\ud83c\udfe0 Private Courts: Customize your world, set your rules.\n\ud83d\udc55 Nextgen Avatars: Design your player w/ max control. Hairstyles, facial hair, body shapes, & height.\n\ud83c\udfa8 Cosmetics: Unlock a wide variety of cosmetics from hoodies, glasses, headphones, & gorilla around w/ banana hats.", "short_description": "\ud83c\udfc0\ud83c\udfc8\u26be GYM CLASS is the top VR basketball & sports game. Experience NBA licensed team courts with full-court games, social worlds for pickup games with friends, and football & baseball stadiums. Rated best on Quest, GC delivers top-notch simulation physics, environments, gameplay, avatars, and cosmetics. Tag your opponents in a fast-paced match, or play rec games - GC is where ballers unite."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gymclassvr.com/privacy", "developer_terms_of_service_url": "https://gymclassvr.com/tos", "publisher_name": "IRL Studios Inc.", "support_website_url": "https://gymclassvr.com/support", "website_url": "https://gymclassvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7829698153780681"}, "review_messages": ["Approved for release"]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75617320_901289084322532_7352245107606873760_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ACQbHbzCLNAQ7kNvgFqeRoV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfSlbdARdWC_u_m7F9IhwN4V8xc39UXGNax2DAioCVvA&oe=66D3072C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "GYM CLASS - BASKETBALL VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "27433260359255