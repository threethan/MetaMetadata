&oe=675FF9D2"}]}, "id": "1595835714662383", "locale": "en_US", "screenshots": [{"file_name": "2024 Product Page Screenshots - 4.png", "id": "1509356679853452", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974853_1509356683186785_245496980552221799_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p-w_HTU3eloQ7kNvgE_49ue&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYArtBnrARQnaI6w2o9e4xWmzyouFvwlX-HfKcFSJuJWZw&oe=67602BBD"}, {"file_name": "2024 Product Page Screenshots - 6 (1).png", "id": "3629811947307678", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974778_3629811950641011_1325301661716721494_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QHiJl43gOGgQ7kNvgHfhpP-&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYArQfHK663trES-ir845Wpq8XV1NhSZALFq5y2jKG7xrQ&oe=67601496"}, {"file_name": "sandbox.png", "id": "1065945105160628", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974567_1065945108493961_2792661541731211064_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0hUdaNHkp98Q7kNvgFepIp9&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAcDiCSQUkqto7j8ZW_WlXFq_WBlGSLGxyNM41ByP5tfQ&oe=67602386"}, {"file_name": "2024 Product Page Screenshots - 8.png", "id": "937941248048494", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982608_937941251381827_4208153383432172814_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v3EOKhl5avYQ7kNvgHsCuYp&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBiJjYc8x-JHGbpWpr1LOtKjV0o8icbz5aN1kFRG_7sNQ&oe=676006B2"}, {"file_name": "2024 Product Page Screenshots - 1 (1).png", "id": "1510867419692907", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982603_1510867423026240_4268777374503305816_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X3dW1S1ctkgQ7kNvgFZGFXv&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCqGv51sdQXW_nf543twv2VOAvd5MQCfF0LjGyrsf9kAw&oe=67602903"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gymclass_trailer_cover_image_v05.png", "id": "794105814977946", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982516_794105818311279_4409523219033140330_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X4GfD98X9-QQ7kNvgHr-MYq&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAE7CdGPryhQdua3rwcRUe3CFuyWTK5RO8Bnx2nWPC_KQ&oe=6760014B"}, "display_name": "GYM CLASS - BASKETBALL VR", "keywords": ["basketball", "nba", "sports", "social", "football"], "long_description": "**GYM CLASS is the top VR basketball & sports game \ud83c\udfc0\ud83c\udfc8\u26be** \n\nExperience NBA licensed team courts, full-court multiplayer games, massive worlds, simulation physics, & football & baseball stadiums. Rated best on Quest - make friends or level-up to be the best among millions in the top VR sports community.\n\n{8704248146300574}\n\n**Download GC FREE to experience:** \n- \u2795 Simulation Physics: The most realistic basketball game physics. Control shots, passes, dribble moves, & dunks like never before.\n- \ud83c\udfae Multiplayer Games: Play half, fullcourt, & minigames with friends or AI.\n- \ud83c\udf0d Social Worlds: Connect with friends in massive environments.\n- \ud83c\udfc8\u26be Multi-Sport: Basketball, football, baseball, & arcade.\n- \ud83c\udfa8 Endless Styles: Unlock cosmetics - hoodies, shirts, jerseys, suits, glasses, hats, mascot costumes, green sounds, & more.\n\n{2315442282123322}\n\n**Buy the NBA Bundle for:**\n- \ud83d\ude2e NBA team courts: Hoop on virtual replicas of all 30 NBA team courts.\n- \ud83c\udfc6 Apparel & challenges: Two different sets of team-branded apparel, a team-branded basketball, & team-branded hat. Play games to unlock additional items.\n- \ud83d\udc55 Premium items: Premium NBA & team-branded shirts, hoodies, basketballs & accessories available for purchase separately.\n\n{969686844967912}\n\n**GC PRO unlocks:**\n- \ud83c\udfe0 Private Lobbies: Custom space & rules. Play with friends privately.\n- \ud83d\udc55 Full-body Avatars: Design hairstyles, face details, facial hair, body shapes, height, tattoos.\n- \ud83c\udfa8 Cosmetics: Hoodies, glasses, headphones, mascot outfits, banana hats, etc.\n- \ud83e\udd16 Custom Bot: Name, design, & level-up your bot. \n\n{557813239965509}", "short_description": "\ud83c\udfc0\ud83c\udfc8\u26be GYM CLASS is the top VR basketball & sports game. Experience NBA licensed team courts, full-court multiplayer games, massive worlds, simulation physics, and football & baseball stadiums. Rated best on Quest - make friends or level-up to be the best among millions in the top VR sports community."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gymclassvr.com/privacy", "developer_terms_of_service_url": "https://gymclassvr.com/tos", "publisher_name": "IRL Studios Inc.", "support_website_url": "https://gymclassvr.com/support", "website_url": "https://gymclassvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SOCIAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8714441785306309"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39035420_8591159597596182_7937907681005140433_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ZNUVKSv2YEQ7kNvgFyagZJ&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDbPC7NonSjVaYLnKOD_Ir2MUvT7D_3lREJyFtX-WSiOQ&oe=6760