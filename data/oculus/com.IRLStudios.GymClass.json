721263538_851375230247779122_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SvlsP0fiM0wQ7kNvgHpMozt&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYAvM5R-0FO36W1GfEgAdBuZpTHEhKFl0iCNMVH49Zjenw&oe=66DD7552"}]}, "id": "993284755840165", "locale": "en_US", "screenshots": [{"file_name": "2024 Product Page Screenshots - 8.png", "id": "937941248048494", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982608_937941251381827_4208153383432172814_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_K2gwRCje4Q7kNvgHPzT2a&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYDmAtJpaOJOJ-J1xGxyCMwjhm42jVzyIKR-MxHEf_q43Q&oe=66DD8232"}, {"file_name": "2024 Product Page Screenshots - 6 (1).png", "id": "3629811947307678", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974778_3629811950641011_1325301661716721494_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wbp1MLy4RYAQ7kNvgHnRe6H&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYCmfh-54ZUnExx7k-aIH1mZarBRIbKHOMRsL0kyO8ngYA&oe=66DD9016"}, {"file_name": "R2 2024 Product Page Screenshots - 11.png", "id": "340419552265294", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974691_340419555598627_3827652328806099938_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pb9jRukn4FYQ7kNvgGZ4COm&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYCcqdxWdb0fJsATbezgezz9K0I-YYGZ4ojZgHi70qcZ0g&oe=66DD9EED"}, {"file_name": "2024 Product Page Screenshots - 4.png", "id": "1509356679853452", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974853_1509356683186785_245496980552221799_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z-DQkfp1evIQ7kNvgHKaHa_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYCz03svg64V_ep2etKoCrcYFoehoBLl-jIDAIJv6eq9OA&oe=66DD6EFD"}, {"file_name": "2024 Product Page Screenshots - 1 (1).png", "id": "1510867419692907", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982603_1510867423026240_4268777374503305816_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PRVzujMs_AMQ7kNvgHE2OFs&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYBMNLs-4UZTB1BmjVxq1cW2iVkPhPJ7w2oK2IbpUkC3fA&oe=66DDA483"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gymclass_trailer_cover_image_v05.png", "id": "794105814977946", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982516_794105818311279_4409523219033140330_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l5kqpEiYxdAQ7kNvgGt6bQZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aze-KCLHiOWk-tFfp4QAMi7&oh=00_AYBzsafkGw0AsWbXmAC9YXIXU4SneCu_Ez4MYQmvd2W-_w&oe=66DD7CCB"}, "display_name": "GYM CLASS - BASKETBALL VR", "keywords": ["basketball", "nba", "sports", "social", "baseball"], "long_description": "\ud83c\udfc0\ud83c\udfc8\u26be GYM CLASS is the top VR basketball & sports game. Experience NBA licensed team courts with full-court games, social worlds for pickup games with friends, and football & baseball stadiums. Rated best on Quest, GC delivers top-notch simulation physics, environments, gameplay, avatars, and cosmetics. Tag your opponents in a fast-paced match, or play rec games - GC is where ballers unite.\n\nDownload free to enjoy:\n\ud83c\udfc8\u26be Sandbox: Football baseball, & more activities.\n\ud83c\udf0d Social Worlds: Connect to the best community in epic environments.\n\u2795 Physics Engine: Use real-life shooting, passing, dribbling in realtime, multiplayer games. Get superpowers w/ insane dunks too.\n\ud83e\udd16 Game Modes: Multiplayer 2v2, 3v3, & 4v4 game modes & AI.\n\ud83c\udfa8 Design Your Look: Complete challenges to unlock cosmetics.\n\ud83c\udfc6 Stats & Matchmaking: Track your wins and improve your skills.\n\nNBA Bundle unlocks:\n\ud83d\ude2e NBA team courts: Virtual replicas of all 30 NBA team courts.\n\ud83d\udc55 NBA team branded apparel: Two different sets of team-branded apparel, a team-branded basketball, and team-branded hat. Additional NBA & team-branded basketballs & accessories is available for purchase separately.\n\ud83c\udfc6 NBA Bundle Challenges: Play games to unlock NBA team features.\n\nGC PRO unlocks: \n\ud83c\udfe0 Private Courts: Customize your world, set your rules.\n\ud83d\udc55 Nextgen Avatars: Design your player w/ max control. Hairstyles, facial hair, body shapes, & height.\n\ud83c\udfa8 Cosmetics: Unlock a wide variety of cosmetics from hoodies, glasses, headphones, & gorilla around w/ banana hats.", "short_description": "\ud83c\udfc0\ud83c\udfc8\u26be GYM CLASS is the top VR basketball & sports game. Experience NBA licensed team courts with full-court games, social worlds for pickup games with friends, and football & baseball stadiums. Rated best on Quest, GC delivers top-notch simulation physics, environments, gameplay, avatars, and cosmetics. Tag your opponents in a fast-paced match, or play rec games - GC is where ballers unite."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gymclassvr.com/privacy", "developer_terms_of_service_url": "https://gymclassvr.com/tos", "publisher_name": "IRL Studios Inc.", "support_website_url": "https://gymclassvr.com/support", "website_url": "https://gymclassvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7829698153780681"}, "review_messages": ["Approved