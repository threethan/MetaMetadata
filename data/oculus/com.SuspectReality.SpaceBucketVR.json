52312442679_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HfUaZT_YahYQ7kNvgEFIZZZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdX7ABXhGxBK3YQ7_VGMv9j&oh=00_AYD507vgk82RqW9-lAjBuZW9iPUR1UaLShRcl8EGqfJFmw&oe=66F6AEE4"}, {"file_name": "Screenshot09.png", "id": "337369811125070", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_337369814458403_3194979340277084116_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=icFT93cmsR4Q7kNvgGdsgz0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdX7ABXhGxBK3YQ7_VGMv9j&oh=00_AYBClOtCQKbEltZrkQfqxlLP-TqLydXc6-Di1dfMStJHDA&oe=66F6A1C7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1383443358677671", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974454_1383443362011004_7988140006223216847_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuZamMZWhq4Q7kNvgG6dX5R&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdX7ABXhGxBK3YQ7_VGMv9j&oh=00_AYAwGm0UqlXCC-SDgTk1t-cH-ziZ1EFOB97a3P1X9wQhRA&oe=66F69F52"}, "display_name": "Space Bucket VR", "keywords": [], "long_description": "The epic tale of a hero, a bucket, and the vicious alien that tries to tear them apart.  A receptacle-based love story for the ages in the grandest traditions of classic space opera and the tales of antiquity.  You will laugh.  You will cry.  You will travel through vast stretches of space and time with a box on your head, a bucket in your hand, and a song in your heart.  Embrace the future.  Embrace your destiny.  Embrace the bucket.  Space Bucket.\n\nBut in all seriousness, Space Bucket is a fun little arcade-style game where you run around catching stuff in a bucket while trying to avoid falling to your death.  There's some grabby and throwy bits too, and we hope you enjoy it!", "short_description": "Space Bucket is a fun little arcade-style game where you run around catching stuff in a bucket while trying to avoid falling to your death.  There's some grabby and throwy bits too, and we hope you enjoy it!"}]}, "developer_nam