700075017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974897_1437704703408350_96200541353181347_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kaFYwkBm0eIQ7kNvgEAi_7I&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_NmtqoPPSg94ENFzD92joj8Xy-ZGYXhlqp-yzHXfZyw&oe=66DC36D0"}, {"file_name": "ss5.png", "id": "3344706469148469", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_3344706472481802_779807546605739355_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2KkygYB_RhUQ7kNvgEBsi2X&_nc_ht=scontent.oculuscdn.com&oh=00_AYCu5KihQX5GiNrRTwJEApK_Da8ljhzuJbcucuzQ7y3WtQ&oe=66DC1E88"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover.png", "id": "1305377666896083", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974873_1305377670229416_6224510581138482787_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8vE9QVvRruAQ7kNvgFrZYSo&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuLZii1K5Q4fXrnQzvJtYAVK12u6ZSlOstiHIRXiGfFg&oe=66DC2AE4"}, "display_name": "Flare Frenzy", "keywords": [], "long_description": "Flare Frenzy could be the most colorful way for showing off your shooting skills. \n\nYou hold two guns each placed in your hands.  These guns has two color options for each. Change the color and shoot the targets within a time limit. Collect as much points as you can.\n\nOur goal is to make you improve your hand-eye coordination while changing the colors of both guns and having fun.", "short_description": "Enhance your shooting skills with colored guns."}]}, "developer_name": null, "developer_privacy_policy_url": "https://flarefrenzy.widegamestudio.com/privacy.html", "developer_terms_of_service_url": "https://flarefrenzy.widegamestudio.com/terms.html", "publisher_name": "Wide Game Studio", "support_website_url": null, "website_url": "https://flarefrenzy.widegamestudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "470214545162582"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "2852142224937685"}, {"status": "PUBLISHED", "id": "215262984606082"}, {"status": "PUBLISHED", "id": "527093115934171"}]}, "baseline_offer": {"id": "2852142224937685"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723567393, "status": "PUBLISHED", "id": "2852142224937685"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6494898070601097", "version": "2.1.3"}, "id": "574528334454374", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5489531501137764", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6494898070601097"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "574528334454374"}]}, "change_log": null, "created_date": 1692398263, "id": "6494898070601097", "version": "2.1.3", "version_code": 36, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5489531501137764", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6494898070601097"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "574528334454374"}]}, "change_log": "\u201cFlare Frenzy 2.1.0\n\nHello again!\n\nWe\u2019re back with Flare Frenzy with some ingame adjustments and refurbished display. Following patch note includes what\u2019s adjusted and new;\n\n-For making gunplay more fluent, Guns are attached to the hand. Target and gun colors decreased to two from four. The colors are red and blue for increasing accessibility for color blindness. More accessibility options going to be added in the future updates.\n\n-Gun model changed to more realistic one, which also includes haptic feedbacks.\n\n-Target model is changed to ball-like target which is more noticeable.\n\n-New global leaderboard integration.\n\n-Score system improved. \n\n-Added combo multiplier. At every multiplier music becomes more complex and exciting.\n\n-Default scene changed with futuristic styled space battlefield.\n\n-Ingame UI is improved. Some UI elements adjusted to be less distractive and a UI bug that breaks game entirely is fixed.\n\n-Minor bug fixes.\u201d", "created_date": 1688074693, "id": "6331663600257879", "version": "2.1.0", "version_code": 30, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5489531501137764", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6494898070601097"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "574528334454374"}]}, "change_log": null, "created_date": 168