luscdn.com/v/t64.5771-25/38974595_3082116258734330_4305673658046121902_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I886pGsozv0Q7kNvgHDisTU&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azcc8gXuXDpYRnPcwGQwOY9&oh=00_AYBagJOkj9ODZESwftKpGtfcuhQAlYHx7Hr3I5VQnRaKfw&oe=66E2C82B"}, {"file_name": "HandPaintSS4.png", "id": "3580895252014851", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982542_3580895255348184_5116071747278364834_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AOuAvxH_ZBcQ7kNvgHybt8H&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azcc8gXuXDpYRnPcwGQwOY9&oh=00_AYB_vzK3XHYtzAAN06ohNozXzLsTE1jNeqoDt9VGCi4SLQ&oe=66E2C82D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "handbrush_2560_1440.png", "id": "503517510670985", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_503517514004318_4954347346057839852_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L8KiTIwvrjgQ7kNvgF_7J1R&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azcc8gXuXDpYRnPcwGQwOY9&oh=00_AYAwqrX81SOhx8JDrRJtdqWYU5lFHNbqMfX_QHxblYi2aQ&oe=66E2C79D"}, "display_name": "Hand Brush \u201cwith your friend\u201d", "keywords": [], "long_description": "This app supplies great VR experience for you ! You can draw 3D paint by hands in VR space.\nAdditionally, you can connect to player that exists same LAN.\nIn other words, you can play with your friends.\n\nAll of actions in this app are able to doing with hands.\nIf you would like to draw something in VR space, you dip your hand a color bucket.\nYou can also erase something that was drawn by somebody.\nJust you dip your hand a transparent bucket and grip something that you would like to erase.\n\nLet's play!\n\nUp-frontier, Inc.\nHP\uff1ahttps://www.up-frontier.jp/\nTwitter\uff1ahttps://twitter.com/Up_frontier\nFacebook\uff1ahttps://www.facebook.com/upfrontier/", "short_description": "This app supplies great VR experience for you ! You can draw 3D paint by hands in VR space with your friends."}]}, "developer_name": null, "developer_priva