nce for you ! You can draw 3D paint by hands in VR space with your friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://up-frontier.jp/company/privacy", "developer_terms_of_service_url": null, "publisher_name": "Up-frontier, Inc.", "support_website_url": null, "website_url": "https://up-frontier.jp/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "684986512878722"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3844546302324717", "version": "0.1"}, "id": "145767007453629", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3641689015943781", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3844546302324717"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "145767007453629"}]}, "change_log": null, "created_date": 1622793269, "id": "3844546302324717", "version": "0.1", "version_code": 6, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"