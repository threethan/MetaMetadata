.com/v/t64.5771-25/38974595_3082116258734330_4305673658046121902_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTo-XivH5ZEQ7kNvgETxc2Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiaG9tYP1yorcRVqaqDIesk&oh=00_AYCYveIRQL-Z1Wbh3F9JKNFht0JJ169kxr3lER_YGD84GQ&oe=66EFF72B"}, {"file_name": "HandPaintSS4.png", "id": "3580895252014851", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982542_3580895255348184_5116071747278364834_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EUtK2paW3agQ7kNvgFntT7d&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiaG9tYP1yorcRVqaqDIesk&oh=00_AYAr5CD_tRUIXmzfBuTQwjdU2h_gmFdrw5WjpDdqSI44Uw&oe=66EFF72D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "handbrush_2560_1440.png", "id": "503517510670985", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_503517514004318_4954347346057839852_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S5GOg3XH6SIQ7kNvgGdnzlx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiaG9tYP1yorcRVqaqDIesk&oh=00_AYDLKQf7Vjo-XCtd5vJNe64iAE70miNlwXXtWcq4RvoC7w&oe=66EFF69D"}, "display_name": "Hand Brush \u201cwith your friend\u201d", "keywords": [], "long_description": "This app supplies great VR experience for you ! You can draw 3D paint by hands in VR space.\nAdditionally, you can connect to player that exists same LAN.\nIn other words, you can play with your friends.\n\nAll of actions in this app are able to doing with hands.\nIf you would like to draw something in VR space, you dip your hand a color bucket.\nYou can also erase something that was drawn by somebody.\nJust you dip your hand a transparent bucket and grip something that you would like to erase.\n\nLet's play!\n\nUp-frontier, Inc.\nHP\uff1ahttps://www.up-frontier.jp/\nTwitter\uff1ahttps://twitter.com/Up_frontier\nFacebook\uff1ahttps://www.facebook.com/upfrontier/", "short_description": "This app supplies great VR experience for you ! You can draw 3D paint by hands in VR space with your friends."}]}, "developer_name": null, "developer_privacy_pol