e\u307e\u306b\u6563\u7b56\u3067\u304d\u308b\u3001\u63a2\u7d22\u30d1\u30fc\u30c8\n{831995881780508}\n\n**\u3053\u3093\u306a\u4eba\u306b\u30aa\u30b9\u30b9\u30e1**\n- \u738b\u9053RPG\u3092VR\u3067\u5f85\u3061\u671b\u3093\u3067\u3044\u305f\u4eba\n- \u9b54\u6cd5\u4f7f\u3044\u306b\u306a\u3063\u3066\u30d5\u30a1\u30f3\u30bf\u30b8\u30fc\u4e16\u754c\u3092\u5192\u967a\u3057\u305f\u3044\u4eba\n- \u3084\u308a\u3054\u305f\u3048\u306e\u3042\u308bVR\u30a2\u30af\u30b7\u30e7\u30f3\u4f53\u9a13\u3092\u6c42\u3081\u3066\u3044\u305f\u4eba\n- \u30a2\u30cb\u30e1\u3084\u30c9\u30e9\u30de\u306e\u4e2d\u306b\u5165\u3063\u3066\u307f\u305f\u3044\u3068\u4e00\u5ea6\u3067\u3082\u601d\u3063\u305f\u3053\u3068\u306e\u3042\u308b\u4eba\n\n\n**\u30b9\u30c8\u30fc\u30ea\u30fc**\n\n30\u4eba\u4ee5\u4e0a\u306e\u500b\u6027\u7684\u306a\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u305f\u3061\u304c\u7e54\u308a\u306a\u3059\u3001\u516826\u7ae0\u306b\u3082\u53ca\u3076\u58ee\u5927\u306a\u30b9\u30c8\u30fc\u30ea\u30fc\u3092VR\u3067\u4f53\u9a13\u3067\u304d\u307e\u3059\u3002\n\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u3067\u7e70\u308a\u5e83\u3052\u3089\u308c\u308b\u30c9\u30e9\u30de\u3092\u7d4c\u3066\u3001\u3042\u306a\u305f\u304c\u76ee\u306b\u3059\u308b\u666f\u8272\u306f...\u3002\n{488743613602652}\n\n**\u30a2\u30af\u30b7\u30e7\u30f3**\n\n\u907a\u8de1\u5185\u3067\u306f\u3001\u3042\u306a\u305f\u306b\u8972\u3044\u639b\u304b\u308b\u300e\u30ac\u30fc\u30c7\u30a3\u30a2\u30f3\u300f\u3068\u306e\u6226\u95d8\u306f\u907f\u3051\u3089\u308c\u307e\u305b\u3093\u3002\n\u69d8\u3005\u306a\u7279\u5fb4\u3092\u6301\u3064\u9b54\u6cd5\u3092\u5f37\u5316\u3057\u4f7f\u3044\u5206\u3051\u3001\u30ac\u30fc\u30c7\u30a3\u30a2\u30f3\u3092\u5012\u3057\u3001\u907a\u8de1\u306e\u6700\u5965\u3092\u76ee\u6307\u3057\u307e\u3059\u3002\n\u9b54\u6cd5\u3060\u3051\u3067\u306a\u304f\u3001\u76fe\u30a2\u30af\u30b7\u30e7\u30f3\uff08\u9632\u5fa1\u30fb\u30d1\u30ea\u30a3\uff09\u3084\u56de\u907f\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u4e0a\u624b\u304f\u4f7f\u3044\u3001\u5f37\u529b\u306