1268_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7imVmMx-O0Q7kNvgHwHEaA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-Vdg99UeXEgOfVaJl3N9VKLPYHx40dhEreAIVhBpvxA&oe=677A5859"}, {"file_name": "MetaStore-SS5-Temp.png", "id": "828911845059867", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974732_828911848393200_3074068480724448144_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tWCAsQyUelkQ7kNvgGxlHYh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUHMafBeZpeLFcbfpgDx5_cunPwvfCn8Zkk6ryyRoitg&oe=677A65D4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoHeaderMeta.png", "id": "1175310229824307", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86811598_1175310233157640_6086778125962899174_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VntW-H1li-wQ7kNvgEBG9-P&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBONKxq_UG2PVXBS2bzq2WH4gZ7UNCRAWvyNRakiYCtmw&oe=677A71CD"}, "display_name": "RUINSMAGUS", "keywords": ["JRPG", "Magic", "Action", "Anime", "Japan"], "long_description": "# \u201cLet\u2019s start a Journey! To our tomorrow!\u201d\n\nAs a member of the renowned RUINSMAGUS Guild, your goal is to help strengthen it with magic, resources \u2013 and wisdom! \u2013 as you embark on more than 25 unique, story-driven quests. \n{351937041257287}\n\n\nFace off against guardians tasked with protecting the ruins from intruders \u2013 and solve the deadly puzzles hidden within. When you've succeeded, head to the surface to acquire new items and upgrade your equipment in town \u2013 if you want to live another day, that is!\n{1298633201098030}\n\n# Features\n- Immersive VR mechanics bring the world to life.\n\n- More than 25 story-driven quests to challenge your skills.\n\n- Unleash 16 unique spells from the palm of your hand.\n\n- Raise your shield with to block enemy attacks.\n\n- Cast and blink your way through a stunning VR fantasy world.\n\n- Equip new armor, gauntlets, and shields to stack the odds in your favor!\n{3782892395315941}", "short_description": "RUINSMAGUS is a VR action RPG developed for Oculus Quest 2. Explore and cast your way in first-person through an immersive fantasy world. As a novice member of the RUINSMAGUS guild, work with the Enigma Research Institute to uncover the mysteries hidden beneath the gilded streets of Grand Amnis."}]}, "developer_name": null, "developer_privacy_policy_url": "https://characterbank.atlassian.net/wiki/external/302743560/MWMwYzFkMjQyODc4NDk3M2I2MWRhYWFmY2NkNTRmMDc?atlOrigin=eyJpIjoiMDEzYzgyZmIxM2YzNGNhNTgzNTUzMTkxY2IzYzA1ZmYiLCJwIjoiYyJ9", "developer_terms_of_service_url": null, "publisher_name": "Mastiff", "support_website_url": "https://character-bank.com/", "website_url": "https://ruinsmagus.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27294391073541695"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974471_1106111670580194_3078947988605199266_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r_gBgjb7NEEQ7kNvgEXhT-y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBaa6OOjdpLV8D17d5j2cbnzbERo89zdTGmdkQsJONHbQ&oe=677A7BBA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RUINSMAGUS"