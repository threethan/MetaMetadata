WrI0OfB-bfLsBIIxh3GX3lE6NGKZ60NovWigL_E9w&oe=6703B159"}, {"file_name": "MetaStore-SS5-Temp.png", "id": "828911845059867", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974732_828911848393200_3074068480724448144_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qB2pYnKveswQ7kNvgEcrAUx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-9RLZlrW8x17XmOoZUQ9cdAjLA3KEl9N3AylBnjimeA&oe=6703BED4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoHeaderMeta.png", "id": "1175310229824307", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86811598_1175310233157640_6086778125962899174_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4NpdZoZYnpEQ7kNvgFaOy1h&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDWJtXX_eW7gpt-wnJ0R6otVWYRv8C-j7P3gviGYogFDw&oe=6703CACD"}, "display_name": "RUINSMAGUS", "keywords": ["JRPG", "Magic", "Action", "Anime", "Japan"], "long_description": "# \u201cLet\u2019s start a Journey! To our tomorrow!\u201d\n\nAs a member of the renowned RUINSMAGUS Guild, your goal is to help strengthen it with magic, resources \u2013 and wisdom! \u2013 as you embark on more than 25 unique, story-driven quests. \n{351937041257287}\n\n\nFace off against guardians tasked with protecting the ruins from intruders \u2013 and solve the deadly puzzles hidden within. When you've succeeded, head to the surface to acquire new items and upgrade your equipment in town \u2013 if you want to live another day, that is!\n{1298633201098030}\n\n# Features\n- Immersive VR mechanics bring the world to life.\n\n- More than 25 story-driven quests to challenge your skills.\n\n- Unleash 16 unique spells from the palm of your hand.\n\n- Raise your shield with to block enemy attacks.\n\n- Cast and blink your way through a stunning VR fantasy world.\n\n- Equip new armor, gauntlets, and shields to stack the odds in your favor!\n{3782892395315941}", "short_description": "RUINSMAGUS is a VR action RPG developed for Oculus Quest 2. Explore and cast your way in first-person through an immersive fantasy world. As a novice member of the RUINSMAGUS guild, work with the Enigma Research Institute to uncover the mysteries hidden beneath the gilded streets of Grand Amnis."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "3557392304496017", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476597_3557392307829350_2156474618434251073_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PO-O5ynhYL4Q7kNvgHJ5_qA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFTu__cTzjlrooqjTj-UJIZb6Qpbb3MIMWyFDe2yLyxQ&oe=6703C51C"}, {"file_name": "Left.png", "id": "3315126055411013", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035433_3315126058744346_1611526926850836736_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=klaQM2jgVT8Q7kNvgEIWnZE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAP27j4AjaugujLE__5kYNcCVC1ECrNCfKQbFqakX-oOQ&oe=6703D9C6"}, {"file_name": "Right_2.png", "id": "1319400565483943", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036671_1319400568817276_691908682853268363_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K2xf8jYT4xIQ7kNvgFqWSMe&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBo1mOKa76ZpEMkW0tSGh2y4SsbWUL9R6EVoPEgtQoa5Q&oe=6703B4CA"}, {"file_name": "cover_1080x360_unbo_1.2.png", "id": "945008479880986", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974756_945008483214319_8669948048078115246_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=olGP8yrP5pIQ7kNvgF87Ty1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiWHlswoIxMjgFdlHcH44sUDZflDGfuR2qhUH0_eHpqw&oe=6703D8E1"}, {"file_name": "cover_1008x1440_unbo_1.2.png", "id": "769996238053996", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75294239_769996241387329_4055116176231517273_n.png?_nc_ca