Q&oe=66D6DF29"}, {"file_name": "cover_horizontal.png", "id": "452885806634128", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75658018_452885809967461_7677553697199946937_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PY1_SqnGI6EQ7kNvgHd8497&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRhfw6qfYuOc5tKoyiB48IlO68wCP5bcQQO2LwyxISDQ&oe=66D70100"}]}, "id": "1111235902969685", "locale": "en_US", "screenshots": [{"file_name": "\u30d7\u30ec\u30a4\u30e4\u30fc\u8996\u70b9_3.png", "id": "503882534610403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75557065_503882537943736_5552064400038643493_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tunec8bRkcEQ7kNvgGYlIxs&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtRRG1tI9UkK2K-DCw6hzTil2xsiB8YQ_aBHiO1qPtyA&oe=66D6EDF9"}, {"file_name": "\u30b9\u30c8\u30fc\u30ea\u30fc_3.png", "id": "307515631492646", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031476_307515634825979_568235038275447894_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvDhrvPCCI4Q7kNvgGN6f6i&_nc_ht=scontent.oculuscdn.com&oh=00_AYDeWvyiJQBX5I64JevNbvOM2b29MPK7e5SIkvjOm3h8sg&oe=66D6E509"}, {"file_name": "\u30d7\u30ec\u30a4\u30e4\u30fc\u8996\u70b9_1.png", "id": "1037374443540901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_1037374446874234_79307409232744145_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=baK9YUgSg1sQ7kNvgGYc804&_nc_ht=scontent.oculuscdn.com&oh=00_AYABYBUvosi_i1n8iIs-2Mbmu8a2O9OplSnSaCiCiL707w&oe=66D6FFA3"}, {"file_name": "\u30ca\u30f3\u30c7\u30e2\u5802_2.png", "id": "1021720058742128", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031600_1021720062075461_5267452909577450820_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-OqG7r2kC3MQ7kNvgFHrSBc&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCg-_0S6k61d3B9oJYzJCuPo9LoX5oVwPsciaM8IfQrw&oe=66D70ABF"}, {"file_name": "\u8def\u5730_\u591c.png", "id": "379689330833085", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982719_379689337499751_3307261581081345135_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fBbRJDG7hA8Q7kNvgERQvuk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnoQ2QQ5-W1EgePe1a3uQkQ_yBQFMbF8BBafig86af9g&oe=66D6E482"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RUINSMAGUS", "keywords": ["JRPG", "Magic", "Action"], "long_description": "\u201cLet\u2019s start a Journey! To our tomorrow!\u201d\n\nAs a member of the renowned RUINSMAGUS Guild, your goal is to help strengthen it with magic, resources \u2013 and wisdom! \u2013 as you embark on more than 25 unique, story-driven quests. Face off against guardians tasked with protecting the ruins from intruders \u2013 and solve the deadly puzzles hidden within. When you've succeeded, head to the surface to acquire new items and upgrade your equipment in town \u2013 if you want to live another day, that is!\n\nFeatures\nJack In: Immersive VR mechanics bring your character to life.\n\nMake your Mark: More than 25 story-driven quests to challenge your skills.\n\nFeel the Power: Unleash 16 unique spells from the palm of your hand.\n\nDefend Yourself: Raise your shield with your non-casting hand to block enemy attacks.\n\nExplore and Fight: Cast and blink your way through a stunning VR fantasy world.\n\nLoad Up: Equip armor, gauntlets, and shields to stack the odds in your favor!", "short_description": "RUINSMAGUS is a VR action RPG developed for Oculus Quest 2. Explore and cast your way in first-person through an immersive fantasy world. As a novice member of the RUINSMAGUS guild, work with the Enigma Research Institute to uncover the mysteries hidden beneath the gilded streets of Grand Amnis."}, {"images": {"nodes": []}, "id": "683586732959946", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RUINSMAGUS \uff5e\u30eb\u30a4\u30f3\u30ba\u30e1\u30a4\u30ac\u30b9\uff5e", "keywords": ["\u9b54\u6cd5", "\u30a2\u30af\u30b7\u30e7\u30f3", "RPG", "JRPG"], "long_description": "\u300c\u884c\u3053\u3046\u3002\u50d5\u305f\u3061\u306e\u660e\u65e5\u3078\u3002\u300d\n\u821e\u53f0\u306f\u8857\u306e\u4e2d\u592e\u306b\u5927\u304d\u306a\u907a\u8de1\u304c\u69cb\u3048\u308b\u300e\u907a\u8de1\u90fd\u5e02\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3002\n\u3042\u306a\u305f\u306f\u65b0\u4eba\u9b54\u6cd5\u4f7f\u3044\u3068\u3057\u3066\u3001\u7814\u7a76\u6a5f\u95a2\u30a8\u30cb\u30b0\u30de\u306e\u65b0\u4eba\u7814\u7a76\u54e1\u30a2\u30a4\u30ea\u30b9\u3068\u5171\u306b\u3001\u907a\u8de1\u306b\u79d8\u3081\u3089\u308c\u305f\u8b0e\u306e\u89e3\u660e\u3092\u76ee\u6307\u3057\u307e\u3059\u3002\n\n\u25a0\u30dd\u30a4\u30f3\u30c8\n\u30fb\u500b\u6027\u8c4a\u304b\u306a\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u304c\u7e54\u308a\u306a\u3059\u30c9\u30e9\u30de\u3092\u30d5\u30eb\u30dc\u30a4\u30b9\u3067\u697d\u3057\u3081\u308b\u30b7\u30ca\u30ea\u30aa\u30d1\u30fc\u30c8\n\u30fb\u69d8\u3005\u306a\u7279\u5fb4\u3092\u6301\u3064\u9b54\u6cd5\u3068\u76fe\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u99c6\u4f7f\u3057\u3001\u8feb\u308a\u304f\u308b\u6575\u3092\u5012\u3057\u3066\u3044\u304f\u30a2\u30af\u30b7\u30e7\u30f3\u30d1\u30fc\u30c8\n\u30fb\u30b2\u30fc\u30e0\u5185\u306e\u4e16\u754c\u3001\u300e\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3092\u6c17\u307e\u307e\u306b\u6563\u7b56\u3067\u304d\u308b\u3001\u63a2\u7d22\u30d1\u30fc\u30c8\n\n\u25a0\u3053\u3093\u306a\u4eba\u306b\u30aa\u30b9\u30b9\u30e1\n\u30fb\u738b\u9053RPG\u3092VR\u3067\u5f85\u3061\u671b\u3093\u3067\u3044\u305f\u4eba\n\u30fb\u9b54\u6cd5\u4f7f\u3044\u306b\u306a\u3063\u3066\u30d5\u30a1\u30f3\u30bf\u30b8\u30fc\u4e16\u754c\u3092\u5192\u967a\u3057\u305f\u3044\u4eba\n\u30fb\u3084\u308a\u3054\u305f\u3048\u306e\u3042\u308bVR\u30a2\u30af\u30b7\u30e7\u30f3\u4f53\u9a13\u3092\u6c42\u3081\u3066\u3044\u305f\u4eba\n\u30fb\u30a2\u30cb\u30e1\u3084\u30c9\u30e9\u30de\u306e\u4e2d\u306b\u5165\u3063\u3066\u307f\u305f\u3044\u3068\u4e00\u5ea6\u3067\u3082\u601d\u3063\u305f\u3053\u3068\u306e\u3042\u308b\u4eba\n\n\n\u25bc\u30b9\u30c8\u30fc\u30ea\u30fc\n30\u4eba\u4ee5\u4e0a\u306e\u500b\u6027\u7684\u306a\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u305f\u3061\u304c\u7e54\u308a\u306a\u3059\u3001\u516826\u7ae0\u306b\u3082\u53ca\u3076\u58ee\u5927\u306a\u30b9\u30c8\u30fc\u30ea\u30fc\u3092VR\u3067\u4f53\u9a13\u3067\u304d\u307e\u3059\u3002\n\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u3067\u7e70\u308a\u5e83\u3052\u3089\u308c\u308b\u30c9\u30e9\u30de\u3092\u7d4c\u3066\u3001\u3042\u306a\u305f\u304c\u76ee\u306b\u3059\u308b\u666f\u8272\u306f...\u3002\n\n\u25bc\u30a2\u30af\u30b7\u30e7\u30f3\n\u907a\u8de1\u5185\u3067\u306f\u3001\u3042\u306a\u305f\u306b\u8972\u3044\u639b\u304b\u308b\u300e\u30ac\u30fc\u30c7\u30a3\u30a2\u30f3\u300f\u3068\u306e\u6226\u95d8\u306f\u907f\u3051\u3089\u308c\u307e\u305b\u3093\u3002\n\u69d8\u3005\u306a\u7279\u5fb4\u3092\u6301\u3064\u9b54\u6cd5\u3092\u5f37\u5316\u3057\u4f7f\u3044\u5206\u3051\u3001\u30ac\u30fc\u30c7\u30a3\u30a2\u30f3\u3092\u5012\u3057\u3001\u907a\u8de1\u306e\u6700\u5965\u3092\u76ee\u6307\u3057\u307e\u3059\u3002\n\u9b54\u6cd5\u3060\u3051\u3067\u306a\u304f\u3001\u76fe\u30a2\u30af\u30b7\u30e7\u30f3\uff08\u9632\u5fa1\u30fb\u30d1\u30ea\u30a3\uff09\u3084\u56de\u907f\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u4e0a\u624b\u304f\u4f7f\u3044\u3001\u5f37\u529b\u306a\u30ac\u30fc\u30c7\u30a3\u30a2\u30f3\u3084\u6575\u5bfe\u3059\u308b\u9b54\u6cd5\u4f7f\u3044\u3068\u306e\u624b\u306b\u6c57\u63e1\u308b\u6226\u95d8\u3092\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\n\u25bc\u63a2\u7d22\n\u672c\u4f5c\u306e\u821e\u53f0\u3067\u3042\u308b\u3001\u907a\u8de1\u90fd\u5e02\u300e\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3092\u81ea\u7531\u306b\u63a2\u7d22\u3067\u304d\u308b\u30d1\u30fc\u30c8\u3067\u3059\u3002\n\u30b2\u30fc\u30e0\u5185\u3067\u306f\u3001\u3053\u306e\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u306b\u70b9\u5728\u3059\u308b\u69d8\u3005\u306a\u30b9\u30dd\u30c3\u30c8\u3092\u884c\u304d\u6765\u3057\u305f\u308a\u3001\u307e\u305f\u3001\u8857\u884c\u304f\u4eba\u3005\u3068\u306e\u4f1a\u8a71\u3092\u697d\u3057\u3080\u3053\u3068\u304c\u51fa\u6765\u307e\u3059\u3002\n\u7d30\u90e8\u307e\u3067\u4f5c\u308a\u3053\u307e\u308c\u305f\u3053\u306e\u300e\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3092\u5fc3\u3086\u304f\u307e\u3067\u697d\u3057\u3093\u3067\u304f\u3060\u3055\u3044\u3002", "short_description": "VR\u00d7\u9b54\u6cd5\u00d7\u30a2\u30af\u30b7\u30e7\u30f3\uff01\u300eRUINSMAGUS\u300f\u306f\u69d8\u3005\u306a\u9b54\u6cd5\u3068\u76fe\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u99c6\u4f7f\u3057\u3001\u907a\u8de1\u306b\u79d8\u3081\u3089\u308c\u305f\u8b0e\u306e\u89e3\u660e\u3092\u76ee\u6307\u3059VR\u9b54\u6cd5\u30a2\u30af\u30b7\u30e7\u30f3RPG\u3067\u3059\u3002\n\u821e\u53f0\u306f\u8857\u306e\u4e2d\u592e\u306b\u5927\u304d\u306a\u907a\u8de1\u304c\u69cb\u3048\u308b\u300e\u907a\u8de1\u90fd\u5e02\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3002\u3042\u306a\u305f\u306f\u65b0\u4eba\u9b54\u6cd5\u4f7f\u3044\u3068\u3057\u3066\u3001\u7814\u7a76\u6a5f\u95a2\u30a8\u30cb\u30b0\u30de\u306e\u65b0\u4eba\u7814\u7a76\u54e1\u30a2\u30a4\u30ea\u30b9\u3068\u5171\u306b\u69d8\u3005\u306a\u56f0\u96e3\u306b\u7acb\u3061\u5411\u304b\u3044\u307e\u3059\u3002"}]}, "developer_name": null, "developer_privacy_policy_url": "https://characterbank.atlassian.net/wiki/external/302743560/MWMwYzFkMjQyODc4NDk3M2I2MWRhYWFmY2NkNTRmMDc?atlOrigin=eyJpIjoiMDEzYzgyZmIxM2YzNGNhNTgzNTUzMTkxY2IzYzA1ZmYiLCJwIjoiYyJ9", "developer_terms_of_service_url": null, "publisher_name": "Mastiff", "support_website_url": null, "website_url": "https://ruinsmagus.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recomme