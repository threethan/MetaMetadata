3_511725457214000_7700733551806835120_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LpaVcfPRq3EQ7kNvgEuZNvV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4bnlKXVltg5hITIzIAubbq4V-tOkR2iinvg_TPjjDeA&oe=6703E3FC"}, {"file_name": "cover_vertical.png", "id": "484899843311124", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974629_484899846644457_844554344779573953_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mByvDNl2-McQ7kNvgF7CZnP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuHu11AoWA2SvDt36vJS-ElKmDZjYvuhFcYo9AzPqEtA&oe=6703B229"}, {"file_name": "cover_horizontal.png", "id": "452885806634128", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75658018_452885809967461_7677553697199946937_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0RhwDFZMSAQQ7kNvgGOjz8l&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqE2dngvmu496Ogn5Bv9LCWFJgB9krTZzLAtDwlqD-8w&oe=6703D400"}]}, "id": "1111235902969685", "locale": "en_US", "screenshots": [{"file_name": "\u30d7\u30ec\u30a4\u30e4\u30fc\u8996\u70b9_3.png", "id": "503882534610403", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75557065_503882537943736_5552064400038643493_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HNeXQnI_KS4Q7kNvgF0S7Xo&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpCJbbP_3LqjjkWt0JVzSDoyAGroNT10JaRt96B2psCQ&oe=6703C0F9"}, {"file_name": "\u30b9\u30c8\u30fc\u30ea\u30fc_3.png", "id": "307515631492646", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031476_307515634825979_568235038275447894_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4rx94f7qlIIQ7kNvgGqrCBz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCGoGGQgSixfOo-b6ElOKi1uM9fE-S1175GzPA0u76cQ&oe=6703B809"}, {"file_name": "\u30d7\u30ec\u30a4\u30e4\u30fc\u8996\u70b9_1.png", "id": "1037374443540901", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982441_1037374446874234_79307409232744145_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ko-D0YKffmkQ7kNvgEHLSkh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC41yeHnV2cLRHq27mJLB2Eel4UHK3cf8XhQa9AZZBV5Q&oe=6703D2A3"}, {"file_name": "\u30ca\u30f3\u30c7\u30e2\u5802_2.png", "id": "1021720058742128", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031600_1021720062075461_5267452909577450820_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZIQCbASxngQ7kNvgGfOq39&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBg3Rt_BIDelmWzm6P8Xb1tVepi1yoPtKrsiElPg_mN-w&oe=6703DDBF"}, {"file_name": "\u8def\u5730_\u591c.png", "id": "379689330833085", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982719_379689337499751_3307261581081345135_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F6D0KrQ0EKAQ7kNvgFaX0Vu&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANo1KWbCweYhqdQwiFPceFN4MtavQTRwXHogEF8UK4Hw&oe=6703B782"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RUINSMAGUS", "keywords": ["JRPG", "Magic", "Action"], "long_description": "\u201cLet\u2019s start a Journey! To our tomorrow!\u201d\n\nAs a member of the renowned RUINSMAGUS Guild, your goal is to help strengthen it with magic, resources \u2013 and wisdom! \u2013 as you embark on more than 25 unique, story-driven quests. Face off against guardians tasked with protecting the ruins from intruders \u2013 and solve the deadly puzzles hidden within. When you've succeeded, head to the surface to acquire new items and upgrade your equipment in town \u2013 if you want to live another day, that is!\n\nFeatures\nJack In: Immersive VR mechanics bring your character to life.\n\nMake your Mark: More than 25 story-driven quests to challenge your skills.\n\nFeel the Power: Unleash 16 unique spells from the palm of your hand.\n\nDefend Yourself: Raise your shield with your non-casting hand to block enemy attacks.\n\nExplore and Fight: Cast and blink your way through a stunning VR fantasy world.\n\nLoad Up: Equip armor, gauntlets, and shields to stack the odds in your favor!", "short_description": "RUINSMAGUS is a VR action RPG developed for Oculus Quest 2. Explore and cast your way in first-person through an immersive fantasy world. As a novice member of the RUINSMAGUS guild, work with the Enigma Research Institute to uncover the mysteries hidden beneath the gilded streets of Grand Amnis."}, {"images": {"nodes": []}, "id": "683586732959946", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RUINSMAGUS \uff5e\u30eb\u30a4\u30f3\u30ba\u30e1\u30a4\u30ac\u30b9\uff5e", "keywords": ["\u9b54\u6cd5", "\u30a2\u30af\u30b7\u30e7\u30f3", "RPG", "JRPG"], "long_description": "\u300c\u884c\u3053\u3046\u3002\u50d5\u305f\u3061\u306e\u660e\u65e5\u3078\u3002\u300d\n\u821e\u53f0\u306f\u8857\u306e\u4e2d\u592e\u306b\u5927\u304d\u306a\u907a\u8de1\u304c\u69cb\u3048\u308b\u300e\u907a\u8de1\u90fd\u5e02\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3002\n\u3042\u306a\u305f\u306f\u65b0\u4eba\u9b54\u6cd5\u4f7f\u3044\u3068\u3057\u3066\u3001\u7814\u7a76\u6a5f\u95a2\u30a8\u30cb\u30b0\u30de\u306e\u65b0\u4eba\u7814\u7a76\u54e1\u30a2\u30a4\u30ea\u30b9\u3068\u5171\u306b\u3001\u907a\u8de1\u306b\u79d8\u3081\u3089\u308c\u305f\u8b0e\u306e\u89e3\u660e\u3092\u76ee\u6307\u3057\u307e\u3059\u3002\n\n\u25a0\u30dd\u30a4\u30f3\u30c8\n\u30fb\u500b\u6027\u8c4a\u304b\u306a\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u304c\u7e54\u308a\u306a\u3059\u30c9\u30e9\u30de\u3092\u30d5\u30eb\u30dc\u30a4\u30b9\u3067\u697d\u3057\u3081\u308b\u30b7\u30ca\u30ea\u30aa\u30d1\u30fc\u30c8\n\u30fb\u69d8\u3005\u306a\u7279\u5fb4\u3092\u6301\u3064\u9b54\u6cd5\u3068\u76fe\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u99c6\u4f7f\u3057\u3001\u8feb\u308a\u304f\u308b\u6575\u3092\u5012\u3057\u3066\u3044\u304f\u30a2\u30af\u30b7\u30e7\u30f3\u30d1\u30fc\u30c8\n\u30fb\u30b2\u30fc\u30e0\u5185\u306e\u4e16\u754c\u3001\u300e\u30b0\u30e9\u30f3\u30a2\u30e0\u30cb\u30b9\u300f\u3092\u6c17\u307e\u307e\u306b\u6563\u7b56\u3067\u304d\u308b\u3001\u63a2\u7d22\u30d1\u30