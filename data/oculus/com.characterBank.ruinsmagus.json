272345_3633608651486291268_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CK-FUqIOYBoQ7kNvgHoiWLD&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDUSyWZPKWYWfg_7zTjkQbo87KRxoLqBIlAndAACTYNLw&oe=67289B59"}, {"file_name": "MetaStore-SS5-Temp.png", "id": "828911845059867", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974732_828911848393200_3074068480724448144_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=grTbtp9xjjMQ7kNvgHItqqJ&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDnDStcHq4NyTKnUumzpWcgT-DyaPgGsoB6X_DB5tK79A&oe=6728A8D4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoHeaderMeta.png", "id": "1175310229824307", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/86811598_1175310233157640_6086778125962899174_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-YweQIw9Q8EQ7kNvgEb1nvc&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCd78CksOWBDOMiPpnIiLHUSXsoSJqZD7qkkUc1gq6_DQ&oe=6728B4CD"}, "display_name": "RUINSMAGUS", "keywords": ["JRPG", "Magic", "Action", "Anime", "Japan"], "long_description": "# \u201cLet\u2019s start a Journey! To our tomorrow!\u201d\n\nAs a member of the renowned RUINSMAGUS Guild, your goal is to help strengthen it with magic, resources \u2013 and wisdom! \u2013 as you embark on more than 25 unique, story-driven quests. \n{351937041257287}\n\n\nFace off against guardians tasked with protecting the ruins from intruders \u2013 and solve the deadly puzzles hidden within. When you've succeeded, head to the surface to acquire new items and upgrade your equipment in town \u2013 if you want to live another day, that is!\n{1298633201098030}\n\n# Features\n- Immersive VR mechanics bring the world to life.\n\n- More than 25 story-driven quests to challenge your skills.\n\n- Unleash 16 unique spells from the palm of your hand.\n\n- Raise your shield with to block enemy attacks.\n\n- Cast and blink your way through a stunning VR fantasy world.\n\n- Equip new armor, gauntlets, and shields to stack the odds in your favor!\n{3782892395315941}", "short_description": "RUINSMAGUS is a VR action RPG developed for Oculus Quest 2. Explore and cast your way in first-person through an immersive fantasy world. As a novice member of the RUINSMAGUS guild, work with the Enigma Research Institute to uncover the mysteries hidden beneath the gilded streets of Grand Amnis."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "3557392304496017", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/75476597_3557392307829350_2156474618434251073_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VyKzbDn-yDUQ7kNvgEvzn0A&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYB6BiVyfp_hfYKI2OlKb0CGY3eboKgBx8bauL9cBauRPw&oe=6728AF1C"}, {"file_name": "Left.png", "id": "3315126055411013", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39035433_3315126058744346_1611526926850836736_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uUrT96ei7tAQ7kNvgGDRaAG&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYDLnCHgqNW9J-9c-rjJqAawg2T8BlI5xiEN3sPonToyTw&oe=6728C3C6"}, {"file_name": "Right_2.png", "id": "1319400565483943", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/39036671_1319400568817276_691908682853268363_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JyP9yos-LdwQ7kNvgEggL_a&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYAFNcVgJk77AX9SVuRtAl_EH_vShcG-8slhBtcAJ5Q8nw&oe=67289ECA"}, {"file_name": "cover_1080x360_unbo_1.2.png", "id": "945008479880986", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974756_945008483214319_8669948048078115246_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6V60OMleG0sQ7kNvgGbvUAw&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCfCOj20jM-5mpJrXw9y11w28pUV_xbkdkDgWoKKBtPQQ&oe=6728C2E1"}, {"file_name": 