mes - mystery, strategy, puzzles and action.\n\u25cf\tMindful stories with amazing music - binaural beats that relax and rejuvenate\n\u25cf\tCreative Playhouse \u2013 decorate your own playhouse with 2D and 3D painting.\n\u25cf\tRewards \u2013 for every three stars, you\u2019ll receive another reward.\n\nStay in contact for updates and new levels!", "short_description": "Tjuhej is a magical playground for kids and big kids, where you can play fun mini games, meet storytellers from all over the universe, and get your own amazing playhouse. With Tjuhej, a world of excitement is at your fingertips!"}]}, "developer_name": "Minditorium", "developer_privacy_policy_url": "http://www.tjuhej.com/sample-page/", "developer_terms_of_service_url": "http://www.tjuhej.com/sample-page/", "publisher_name": "Minditorium", "support_website_url": null, "website_url": "http://www.tjuhej.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION", "PUZZLE", "NARRATIVE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3277689685792858"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "266472373887684"}]}, "baseline_offer": {"id": "266472373887684"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1518026400, "status": "PUBLISHED", "id": "266472373887684"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1879254208775116", "version": "1.1.0"}, "id": "538440436489274", "channel_name"