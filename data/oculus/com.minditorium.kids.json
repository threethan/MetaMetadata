4873006524_1840643809914912768_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_r35XNZ4bowQ7kNvgE2FWZu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApkJxbkkgVXe9lD8MQSR5iZ&oh=00_AYAVgctvj7Ul0LWzLQYxuBM8-tkpdM0lzwIXMy8xUozzjw&oe=66DEF0D9"}, {"file_name": "migrated_image.png", "id": "141509870580218", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162753_105474883577168_2760768629560573952_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qtpEh9PZ7X8Q7kNvgEQbehH&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApkJxbkkgVXe9lD8MQSR5iZ&oh=00_AYDPHe57iJkhQcE5hAVFQKqVujxhfvh28yVxrcHsFarCDA&oe=66DEF08A"}, {"file_name": "migrated_image.png", "id": "231039388021951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162763_1642951579127800_3642216555741184000_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRhqbu4fT4oQ7kNvgGMUR6G&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApkJxbkkgVXe9lD8MQSR5iZ&oh=00_AYCe_m5m4Qa7iHQTnL_1_4WeMgajp-MGz8v3IkwlVjRTjg&oe=66DED65C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Cover Art Landscape.png", "id": "198798457528467", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162769_198798460861800_90065447017250816_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_8O-Xxh5ZUQ7kNvgF-FpDv&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApkJxbkkgVXe9lD8MQSR5iZ&oh=00_AYBMYRTlh_dwrjQ3H3Akct9wCmV9oc_4y7KDvxZ_8G00zg&oe=66DEE1E9"}, "display_name": "Tjuhej", "keywords": ["adventure", "storytelling", "playhouse", "paint", "puzzle"], "long_description": "Tjuhej is a story universe where mindful storytelling and thrilling music provides a positive input and time to reflect. Each level starts with a minigame where you must solve a task and figure out how to get to your story. At the end of a level you will get a star and when the door to Playhouse got 3 stars you can unlock this amazing room. When entering Playhouse, you get a whole new world, where you can redecorate, collect rewards and let your imagination fly!\nLevel 1-3 can be played without controller then double tap to move forward and swipe to turn.\nYou should definitely use headphones!\nTjuhej features:\n\u25cf\tMini games - mystery, strategy, puzzles and action.\n\u25cf\tMindful stories with amazing music - binaural beats that relax and rejuvenate\n\u25cf\tCreative Playhouse \u2013 decorate your own playhouse with 2D and 3D painting, listen to music.\n\u25cf\tRewards \u2013 for every three stars, you\u2019ll receive another reward.\nThis update has new levels, a few bug fixes and a tutorial.", "short_description": "Tjuhej is a magical playground for kids and big kids, where you can play fun mini games, meet storytellers from all over the universe, and get your own amazing playhouse. With Tjuhej, a world of excitement is at your fingertips!\nNow new levels 4-9 with new surprises!"}]}, "developer_name": "Minditorium", "developer_privacy_policy_url": "http://www.tjuhej.com/wp-content/uploads/2018/01/Private-Policy-Tjuhej.pdf", "developer_terms_of_service_url": "http://www.tjuhej.com/sample-page/", "publisher_name": "Minditorium", "support_website_url": null, "website_url": "http://www.tjuhej.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION", "NARRATIVE", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "468801428115103"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410407_2026531734289567_8454582236719611904_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tsvGQAzGi