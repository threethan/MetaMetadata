&_nc_ohc=Pm9KZgpFp2AQ7kNvgFyWSiR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHaKx2m3D-au9MTNZbiZYmeYuIPAWWindWg1E_g4nImw&oe=672C9E8A"}, {"file_name": "migrated_image.png", "id": "166606897669987", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162716_1603944873006524_1840643809914912768_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u8QoXG5FJqkQ7kNvgFIs2Jm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTQ2XemENhTbHXbJuOk4n-vfWaePdLUhYeLMenGSoXhQ&oe=672CB959"}, {"file_name": "migrated_image.png", "id": "302851597343327", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162753_105474883577168_2760768629560573952_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CQJinvo_7H4Q7kNvgFQFPoW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkLXUQYx-ipQAujdDouHCBhvmTvQcTbuEDi_OF3eXB7A&oe=672CB90A"}, {"file_name": "migrated_image.png", "id": "532527934109174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162763_1642951579127800_3642216555741184000_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pygFHujwR5sQ7kNvgFUSzm8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA8W_CfXCIvFNeiHQuHJa1xucRyAN-w8J0CqJ1enI_wKg&oe=672C9EDC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Tjuhej", "keywords": ["adventure", "storytelling", "playhouse", "minigames", "kids"], "long_description": "Tjuhej is a great adventure game with strategy, puzzles, action and mystery. Each mini game features a wonderful story with thrilling music. Keep playing to unlock the Playhouse, where you can redecorate, collect rewards and let your imagination fly! \nLevel 1-3 can be played without controller. \nYou should definitely use headphones!\nTjuhej features:\n\u25cf\tMini games - mystery, strategy, puzzles and action.\n\u25cf\tMindful stories with amazing music - binaural beats that relax and rejuvenate\n\u25cf\tCreative Playhouse \u2013 decorate your own playhouse with 2D and 3D painting.\n\u25cf\tRewards \u2013 for every three stars, you\u2019ll receive another reward.\n\nStay in contact for updates and new levels!", "short_description": "Tjuhej is a magical playground for kids and big kids, where you can play fun mini games, meet storytellers from all over the universe, and get your own amazing playhouse. With Tjuhej, a world of excitement is at your fingertips!"}]}, "developer_name": "Minditorium", "developer_privacy_policy_url": "http://www.tjuhej.com/sample-page/", "developer_terms_of_service_url": "http://www.tjuhej.com/sample-page/", "publisher_name": "Minditorium", "support_website_url": null, "website_url": "http://www.tjuhej.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION", "PUZZLE", "NARRATIVE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3277689685792858"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "266472373887684"}]}, "baseline_offer": {"id": "266472373887684"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1518026400, "status": "PUBLISHED", "id": "266472373887684"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1879254208775116", "version": "1.1.0"}, "id": "538440436489274", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1780456281988243", "is_concept": fals