/38974905_502086258504907_6349727471447871497_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e5W2pZMxuTcQ7kNvgGTBK6G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALF5mJqVSpRdcJtTa5Gkxl4kmtQ6Ftv9qSPnQNe5wauQ&oe=67222E8F"}, {"file_name": "Meta-Icon.png", "id": "399337356373932", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031632_399337366373931_5548211413848613555_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=spPNqIwQd90Q7kNvgEKF5na&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyURIK3O89cYsqDL7DvaXeTm-Jh4Xo0hVfmCivqJKZwg&oe=6721FEBD"}]}, "id": "1650884102502588", "locale": "en_US", "screenshots": [{"file_name": "PDP FRONT ROW NBA.png", "id": "8352170468241896", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031650_8352170478241895_6929693567970576290_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Hjpjwd_AGYQ7kNvgF4IiHE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtkNeAZLo_UHuNjxZfi_OEtATvthQjJ4e8gvqx5yNFiA&oe=67220535"}, {"file_name": "PDP FRONT ROW UFC (1).png", "id": "1620972335429582", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003244_1620972338762915_7285546774381073060_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OAJuSJTEhsUQ7kNvgFIx51W&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnKmsTGSSC1k_dg51_pL2LB5ZF4pg3OcoSxUgWFbhrMA&oe=672226CB"}, {"file_name": "PDP NBA MR.png", "id": "559065233308259", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572956_559065239974925_3091373088159794473_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a2e2tiC0gx8Q7kNvgFw5jEU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtcUlC8YtvA-8DD30iDJ9BphYlHNoGjP_SkN7fBdPlgw&oe=67220125"}, {"file_name": "PDP FRONT ROW NBA 2.png", "id": "919921313340522", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031358_919921316673855_2920661372702259426_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5n2W9Tm-m34Q7kNvgFZl3wc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrlnERwtf6AJouCPg6WR-GfnoCpwONevsvp7D0d2zg-w&oe=672226BB"}, {"file_name": "PDP stats MR.png", "id": "3857124301243607", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974757_3857124307910273_4372563573110349011_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B9-pmiEtDTkQ7kNvgHvlfyz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkKxvBSSfLBcEJ85SMnIU0ooZTMN5WmzpVihc2K_1bGg&oe=672223D8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta-TrailerCoverImage.png", "id": "1459641995425426", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566697_1459641998758759_4792333071599506237_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YhdOWDs_JKcQ7kNvgGWRSw9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUD71O6L-sK57EPgndbhkB0LTvT0DA7wSCC5BdC7NArQ&oe=67220998"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events from NBA, NASCAR, TNT Sports, FOX Sports, ESPN, and more!\n\n- Experience NBA games courtside, with free live immersive games from the '24-'25 NBA season.\n\n- NBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality.\n\n- Front Row from Home - Immerse yourself in a revolutionary VR sports experience by sitting in the front row from home.\n\n- Mixed Reality - Content available in Virtual and Mixed Reality. Choose your favorite!\n\n- Multicam Experience - Fans can view different camera angles simultaneously.\n\n- Multigame experience - Exclusive Multi-Game experience and in live!\n\n- Create Your Private Party -  Watch with your friends from anywhere.\n\n- Check your social media while watching - Don\u2019t miss anything from your social feeds.\n\n- Hand tracking - Navigate the app with your hands, no need for controllers.\n\n- Real-Time Statistics - Up-to-date stats and scores at your fingertips.\n\nFollow us on Instagram, TikTok and Twitter/X @XtadiumVR or visit us at https://xtadiumvr.com/", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ybvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Yerba Buena VR, Inc.", "support_website_url": null, "website_url": "https://www.xtadiumvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27371161639165889"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035460_895726795361118_5650496741243383103_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wZBM4S2U3v0Q7kNvgHwLxn6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.