5973630156079782999_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iS2n_QsVf2IQ7kNvgFjEsvd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWJM1etvdN7u7xQHLWOFHQZ&oh=00_AYCt9xdwXd-1ETPhWZXINj72cESWp34G5WHz62ppMCBY8g&oe=66F6B3AE"}, {"file_name": "Handtracking.png", "id": "1270834920558447", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031403_1270834923891780_2433575160526974408_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nq0XwjhYjm0Q7kNvgEVZjh9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWJM1etvdN7u7xQHLWOFHQZ&oh=00_AYBYXMgYseOvAxhq71Jq75obXPv4ypQCOYZM7FKTCAUHEA&oe=66F69B47"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-landscape (2).png", "id": "587216216524579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441573_587216219857912_5521150868777665769_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Q-h3dGVno0Q7kNvgESA0Q5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWJM1etvdN7u7xQHLWOFHQZ&oh=00_AYD5Z8DwRKXKZblSPQS8x4l6EwGwnff_s0ObwRWLM5-Afw&oe=66F6ACE9"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events:\n- Experience NBA games courtside, with free live games from the '23-'24 NBA season\n- NBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality \n- Sit octagon-side for UFC LFA and Cage Warriors events.\n- Check out more sports content from NASCAR, X Games, BeIn (La Liga) and more!\nImmerse yourself in a revolutionary VR sports experience by sitting in the front row from home. Or stay connected with reality by surrounding yourself with multiple screens in Mixed Reality that you can drag and drop around your room. With the addition of hand tracking, you can interact with the content like never before, making your sports viewing experience even more dynamic and immersive.", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ybvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Yerba Buena VR, Inc.", "support_website_url": null, "website_url": "https://www.xtadiumvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "384928226018505"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "26734119139536812"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404383_787797799238273_7640123976525113975_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BkjKgKRrHA0Q7kNvgEJbb3O&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWJM1etvdN7u7xQHLWOFHQZ&oh=00_AYAC8LnQ04sALQ9EnSZrswbiAyCA9vfLGbv2Em2GfXuxLA&oe=66F6984C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name