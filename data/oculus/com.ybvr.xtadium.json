076_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EwmcE8eQ8loQ7kNvgEWeIAs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAx3tcmpj8_Ps-amAeA6CKs27jFj_y7rlFrHI90TwLgzg&oe=676BE557"}, {"file_name": "ImmersiveLogo-Store-556x164.png", "id": "502086255171574", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974905_502086258504907_6349727471447871497_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7pCLNdVpgIQ7kNvgEsrzJn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLN0pesiMSdKQkH4qFtjh26VCcX3vXhH23lJAy-S706w&oe=676C028F"}]}, "id": "615085184292473", "locale": "en_US", "screenshots": [{"file_name": "PDP FRONT ROW NBA.png", "id": "8352170468241896", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031650_8352170478241895_6929693567970576290_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gcY4kannCJAQ7kNvgF2tR2N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9hiGbLqqrOWuSxaEGTXO3tALEPWWQtMo8WVNT0bN0Bw&oe=676BD935"}, {"file_name": "PDP FRONT ROW UFC (1).png", "id": "1620972335429582", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003244_1620972338762915_7285546774381073060_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DliKQHTES6AQ7kNvgECQdjb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDyTWtfIlLnQNuOjKl9mUhqFLnUPSxjI3__ov97255NUA&oe=676BFACB"}, {"file_name": "PDP NBA MR.png", "id": "559065233308259", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572956_559065239974925_3091373088159794473_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RVSDNzFSLYwQ7kNvgELwfOx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAXXgd8BmRi4tZ3ANfsAw5qih1kYD1GW4ZqApbrbs2cuw&oe=676BD525"}, {"file_name": "PDP FRONT ROW NBA 2.png", "id": "919921313340522", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031358_919921316673855_2920661372702259426_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bFU4v4h1EM0Q7kNvgGBdc4W&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkxs_a_e42QfeVxJ7hwTL7CEB_Yg9cBwZXwLXELwBztQ&oe=676BFABB"}, {"file_name": "PDP stats MR.png", "id": "3857124301243607", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974757_3857124307910273_4372563573110349011_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kSEPBiO76q8Q7kNvgGKfvJf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDvqFrgDb3a_41yUHPMKstrVv7eS6RUi79Pu3QUZlDMw&oe=676BF7D8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_2560x1440.png", "id": "8862851040489719", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_8862851057156384_7166767818846791855_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Br_zAPHTEIQ7kNvgFHQNEx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJEpvdyaw0v5ndtV4HQSaSyZxRoC4wTx4eL11gUG18xQ&oe=676BEDF4"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events from NBA, NASCAR, TNT Sports, FOX Sports, ESPN, and more!\n\n- Experience NBA games courtside, with free live immersive games from the '24-'25 NBA season.\n\n- NBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality.\n\n- Front Row from Home - Immerse yourself in a revolutionary VR sports experience by sitting in the front row from home.\n\n- Mixed Reality - Content available in Virtual and Mixed Reality. Choose your favorite!\n\n- Multicam Experience - Fans can view different camera angles simultaneously.\n\n- Multigame experience - Exclusive Multi-Game experience and in live!\n\n- Create Your Private Party -  Watch with your friends from anywhere.\n\n- Check your social media while watching - Don\u2019t miss anything from your social feeds.\n\n- Hand tracking - Navigate the app with your hands, no need for controllers.\n\n- Real-Time Statistics - Up-to-date stats and scores at your fingertips.\n\nFollow us on Instagram, TikTok and Twitter/X @XtadiumVR or visit us at https://xtadiumvr.com/", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ybvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Yerba Buena VR, Inc.", "support_website_url": null, "website_url": "https://www.xtadiumvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27972518945696819"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031608_612268841326861_500349215946308371_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a11dnZ9xHwYQ7kNvgFfErlf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD