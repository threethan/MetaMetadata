574", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974905_502086258504907_6349727471447871497_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aMjCFLFQdSMQ7kNvgGqUTj-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBP-8H2ZMY5S29Xfr4HBK5ZpZw7d7oSDNpclkYmvnTaQQ&oe=66F9500F"}]}, "id": "529444346241448", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2023-10-27 at 2.39.38 PM (1).png", "id": "362628282889618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250459_362628286222951_7636067528765532586_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5mIvREk3n00Q7kNvgFgIa3l&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlXWw_ty_9T7kZ93mrSqcd8G2r7IPTgKcQQCAZE2rKMw&oe=66F951B4"}, {"file_name": "ControlRoom-MR.png", "id": "1488369451735206", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429290_1488369455068539_7272563674127579903_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xi5Q1P_C9cwQ7kNvgEK8ZyO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDw5P4rXsSF-eS3a8I1WNxACxVsepZEg4hZ-QsfFi2xyA&oe=66F94956"}, {"file_name": "AppLab_9_Videoplayer.png", "id": "356374203948882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641342_356374207282215_1643079420207477187_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7c0AUwjaxw0Q7kNvgHjhcFs&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdGjz5xsEzrLt3Lb0gDmYe1G4IY9Q_f8CQd_E45IqqEg&oe=66F9223D"}, {"file_name": "AppLab_6_WatchParty.png", "id": "1692440887837888", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974716_1692440891171221_5973630156079782999_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iS2n_QsVf2IQ7kNvgFSX99K&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnd9YnF7YZHNiOnu2M_rlRRPEUoVeoPRzmHAQ9E0Lxjw&oe=66F956AE"}, {"file_name": "Handtracking.png", "id": "1270834920558447", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031403_1270834923891780_2433575160526974408_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nq0XwjhYjm0Q7kNvgH_89Jx&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3nmv07RV9xIdFjzt6exBSSrwsfwPnFciS3OP422Gt_w&oe=66F93E47"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-landscape (2).png", "id": "587216216524579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441573_587216219857912_5521150868777665769_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Q-h3dGVno0Q7kNvgEwnSJn&_nc_ht=scontent.oculuscdn.com&oh=00_AYCeqxNE6hwcn-kJOauIlwNxHLm8AF9ZcfGwUY2PrCo0uw&oe=66F94FE9"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events:\n- Experience NBA games courtside, with free live games from the '23-'24 NBA season\n- NBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality \n- Sit octagon-side for UFC LFA and Cage Warriors events.\n- Check out more sports content from NASCAR, X Games, BeIn (La Liga) and more!\nImmerse yourself in a revolutionary VR sports experience by sitting in the front row from home. Or stay connected with reality by surrounding yourself with multiple screens in Mixed Reality that you can drag and drop around your room. With the addition of hand tracking, you can interact with the content like never before, making your sports viewing experience even more dynamic and immersive.", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_