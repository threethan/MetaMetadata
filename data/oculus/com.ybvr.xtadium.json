t=scontent-xsp1-1.oculuscdn.com&oh=00_AYBdH2DAWqNjGdC7QgVS2zCcT6Ayu2DfoCh1WouobCy08A&oe=671A3DBB"}, {"file_name": "PDP stats MR.png", "id": "3857124301243607", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974757_3857124307910273_4372563573110349011_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MOdQfbUe3soQ7kNvgE8xI1_&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAhiK54tm05eysLgeDIsPPEApGhE8FmZMpXvN85rGN86w&oe=671A3AD8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta-TrailerCoverImage.png", "id": "1459641995425426", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/57566697_1459641998758759_4792333071599506237_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-yyc33s4nQQQ7kNvgHYwn0b&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAKgLvqVkeR1phNYRTGcXw1xUHIXzPBOH9833hGrgWvtQ&oe=671A2098"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events from NBA, NASCAR, TNT Sports, FOX Sports, ESPN, and more!\nExperience NBA games courtside, with free live immersive games from the '24-'25 NBA season\nNBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality\nFront Row from Home - Immerse yourself in a revolutionary VR sports experience by sitting in the front row from home.\nMixed Reality - Content available in Virtual and Mixed Reality. Choose your favorite!\nMulticam Experience - Fans can view different camera angles simultaneously.\nMultigame experience - Exclusive Multi-Game experience and in live!\nCreate Your Private Party -  Watch with your friends from anywhere.\nCheck your social media while watching - Don\u2019t miss anything from your social feeds.\nHand tracking - Navigate the app with your hands, no need for controllers.\nReal-Time Statistics - Up-to-date stats and scores at your fingertips.\nFollow us on Twitter/X @XtadiumVR or visit us at https://xtadiumvr.com/", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ybvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Yerba Buena VR, Inc.", "support_website_url": null, "website_url": "https://www.xtadiumvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "384928226018505"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27265111693104218"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39035460_895726795361118_5650496741243383103_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=om4kSZoymLkQ7kNvgGKRUo-&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAMNfEcFtpGGdLIMd8XvkfXrKU7y