me": "Handtracking.png", "id": "1270834920558447", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031403_1270834923891780_2433575160526974408_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1kbdP7u4PMAQ7kNvgG1H2f0&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZsW38nRPdlG5SakS4tsxEt4ROTdlvISBxCSw-lCfvgQ&oe=670E5647"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta-TrailerCoverImage.png", "id": "1459641995425426", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566697_1459641998758759_4792333071599506237_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-9Pa8rAIfYQ7kNvgEVr0Gx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCc-4yRsS-kaVFPbenwztnEKCpybpXnZdGDOUeMjtEJBw&oe=670E4318"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events:\n- Experience NBA games courtside, with free live games from the '23-'24 NBA season\n- NBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality \n- Sit octagon-side for UFC LFA and Cage Warriors events.\n- Check out more sports content from NASCAR, X Games, BeIn (La Liga) and more!\nImmerse yourself in a revolutionary VR sports experience by sitting in the front row from home. Or stay connected with reality by surrounding yourself with multiple screens in Mixed Reality that you can drag and drop around your room. With the addition of hand tracking, you can interact with the content like never before, making your sports viewing experience even more dynamic and immersive.", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ybvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Yerba Buena VR, Inc.", "support_website_url": null, "website_url": "https://www.xtadiumvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "384928226018505"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27115980354684020"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035460_895726795361118_5650496741243383103_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OSTfP97un0AQ7kNvgHFZRRi&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAET6YS2iuAs9PDu_4G8MhUVU0k3ZUZxwZu1PL0KLn-FQ&oe=670E4D60"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Xtadium", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Media & Streaming", "id": "384928226018505"}], "release_date": 1668088800, "l