64.5771-25/75641342_356374207282215_1643079420207477187_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NIiAxyBIABgQ7kNvgG_ZCFK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbB-ZUPACf4s2iVmGxJcuHj&oh=00_AYD-Yn_9NDhIw3xylmw9w12EOPpHAriH_Ndf6LM9Pb08jg&oe=66D043BD"}, {"file_name": "AppLab_6_WatchParty.png", "id": "1692440887837888", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974716_1692440891171221_5973630156079782999_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J9IHhirAQiMQ7kNvgE4BIPm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbB-ZUPACf4s2iVmGxJcuHj&oh=00_AYCpXemgzzwAPqKpandRFV5dmO4WCCW6V9lrz5ESp95IGw&oe=66D0782E"}, {"file_name": "Handtracking.png", "id": "1270834920558447", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031403_1270834923891780_2433575160526974408_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8nXGpZx-fW4Q7kNvgGReLdX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbB-ZUPACf4s2iVmGxJcuHj&oh=00_AYBs7ZLmYUv6om_LP2jdcTqa3dfXPXUL-EuRWnZPiM8YxA&oe=66D05FC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-landscape (2).png", "id": "587216216524579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441573_587216219857912_5521150868777665769_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4erdVWKuv7sQ7kNvgGFG5V2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbB-ZUPACf4s2iVmGxJcuHj&oh=00_AYDhguW5gQxJPE6cPXT1fYbmLUnk0TVXHBuNIxLw2TKR0g&oe=66D07169"}, "display_name": "Xtadium", "keywords": ["sport", "stadium", "ufc", "nascar", "nba"], "long_description": "Xtadium is the ultimate social VR and MR sports experience that combines the excitement of live, on-demand, and pay-per-view access to sporting events:\n- Experience NBA games courtside, with free live games from the '23-'24 NBA season\n- NBA League Pass holders can access an exclusive Multi-Game NBA experience in Mixed Reality \n- Sit octagon-side for UFC LFA and Cage Warriors events.\n- Check out more sports content from NASCAR, X Games, BeIn (La Liga) and more!\nImmerse yourself in a revolutionary VR sports experience by sitting in the front row from home. Or stay connected with reality by surrounding yourself with multiple screens in Mixed Reality that you can drag and drop around your room. With the addition of hand tracking, you can interact with the content like never before, making your sports viewing experience even more dynamic and immersive.", "short_description": "Xtadium takes your favorite sports to a whole new level with its cutting-edge Virtual Reality and Mixed Reality features. Put on your headset to watch UFC, NBA, NASCAR, XGAMES, and more, like never before. Whether you're a die-hard fan or a casual viewer, Xtadium revolutionizes the way you experience sports. Watch alone, or invite your friends to a watch party to enjoy the experience together. Plus, with the new hand tracking feature, you can interact with the action like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xtadiumvr.com/legal", "developer_terms_of_service_url": null, "publisher_name": "Yerba Buena VR, Inc.", "support_website_url": null, "website_url": "https://www.xtadiumvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "384928226018505"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "25759255037023232"}, "review_messages": ["Approved for release."]}]}, "cover_