ent-iad3-1.oculuscdn.com/v/t64.5771-25/75307249_289926853864314_2736004098850791689_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3j35klRVwjYQ7kNvgHVf1vq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsPhEdbD5EGKxZ7yQt36ng8Ad_mRZ8N2gtbbnMLTYiKw&oe=6766A811"}, {"file_name": "s4.png", "id": "711533717071132", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001654_711533720404465_7785444266462284687_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5RHLOQaABVkQ7kNvgHFrBai&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxoO-ixgTKeV0x0QWh74uSq5LvjVitHEwlSpp3yADShg&oe=676694D4"}, {"file_name": "s8.png", "id": "1736209486803681", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269597_1736209490137014_7496905580706190806_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xtKZ9iN2LnoQ7kNvgEXZrIW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAS0zvuqQJ0um8D7F7Z4Nedw0eyiYPv68TF9V_dszVOsQ&oe=6766A87C"}, {"file_name": "s5.png", "id": "868089051382606", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031462_868089054715939_4935544365236901930_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EFf89wWLo1YQ7kNvgHaz8Zv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAx1nx0mtElmmHhKXAYKKm4WadkXKQ5QJExjymGkxKvQw&oe=6766AAF2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "banner.png", "id": "852145366410491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031486_852145369743824_4693346598210692709_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3YxZ8bRZkuUQ7kNvgGQMwvC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMivfT4NRczf7pqhKwk1sjlfHzqznFk6tiX7H_4G1gQQ&oe=6766B7A1"}, "display_name": "VR Rage Room", "keywords": [], "long_description": "Introducing our cutting-edge VR Rage Room Experience, a revolutionary way to let off steam and conquer stress in a completely immersive and controlled environment. Picture yourself stepping into a virtual world, equipped with a state-of-the-art headset that transports you to a realm where you have the power to unleash your frustrations like never before.\n\nOnce you're suited up, you'll have a virtual arsenal of tools at your disposal, from baseball bats to sledgehammers, allowing you to demolish a wide array of objects in your path. The satisfaction of each impact reverberates through the virtual world, creating an unparalleled sense of release.\n\nWhat sets our VR Rage Room apart is its ability to provide this cathartic experience without any of the real-world mess or safety concerns. You can let loose without worrying about cleanup or potential harm, allowing you to focus solely on the liberating sensation of release.\n\nWhether you're dealing with the pressures of a demanding job, the strains of daily life, or simply seeking an adrenaline-pumping adventure, our VR Rage Room is the ultimate solution. It offers a controlled, yet exhilarating outlet for pent-up energy and frustrations. You'll find yourself fully immersed in an environment designed to facilitate the therapeutic act of venting, leaving you refreshed, rejuvenated, and ready to face the world anew.", "short_description": "Experience a virtual Rage Room: don a headset, grab tools, and let off steam in a mess-free environment. Smash and shatter stress away!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/61b6455b-0d88-4260-993d-4766d5c0c188", "developer_terms_of_service_url": null, "publisher_name": "Render Island", "support_website_url": "https://www.render-island.com/contact-us", "website_url": "https://www.render-island.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommende