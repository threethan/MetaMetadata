b9\u30af\u30b7\u30e7\uff16.png", "id": "227959255938021", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031483_227959259271354_9132655420635688492_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=npJl86i5JZgQ7kNvgGACPK_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZ_A27IebD_9IUi04cSnppY&oh=00_AYDUDwH2dCj6oq6UwTBsq0E4DELsm-4oxzTz8yXHlVx-Tw&oe=66EAC7BB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30cf\u3099\u30fc\u5199\u771f.png", "id": "922745501653731", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572925_922745504987064_1064929762484899199_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J9ndj-n9wTUQ7kNvgFq1_Ia&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZ_A27IebD_9IUi04cSnppY&oh=00_AYDZOeWXdg-MnBWOgcOP9r6CG04qaiv285TJ4_7BExl9PQ&oe=66EAB49E"}, "display_name": "Digital Campfire ", "keywords": [], "long_description": "\ud83c\udfd5Easy for VR beginners!\nThe functions are focused on a few, making it simple to operate. Even those who are not familiar with VR can immediately focus on communication.\n\n\ud83c\udfd5Small space for your acquaintances\nThis place can hold up to 10 people at the same time. This version is open-space as a demo version, but the regular version can be used closed. So, you can relax and enjoy conversation with your friends, families, or team mates.\n\n\ud83c\udfd5Bonding in a warm & cozy space\nMost of the time, it takes active engagements to create a bond. But maybe, sharing a starry sky and the crackling sound of firewoods could be enough for us to feel connection to the people next to you. Digital Campfire provides warm and comfortable space for every people!\n\n\u25a0 Spec List\n- 10 users at the same time (If there are more than 10 people in the room, the mode will switch to world browsing only. )\n- Voice chat with spacial audio\n- Full body avatar (2 types)\n- Cave & campfire world", "short_description": "Looking for VR communication app? Digital Campfire is where you can enjoy VR communication and campfire experiences! (*This app is a demo version.)"}, {"images": {"nodes": [{"file_name": "TemplatePortrait.png", "id": "1899961576849564", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001704_1899961580182897_2064927627623761242_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BEjLm3CS8GIQ7kNvgETUMpq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZ_A27IebD_9IUi04cSnppY&oh=00_AYBLyZ46I1qiKjzHVDktNfCDTs-YkILr0XOY4Bjqj6nPBA&oe=66EAB90D"}, {"file_name": "TemplateLandscape\u306e\u30b3\u30d2\u309a\u30fc.png", "id": "1552058528459711", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_1552058531793044_2218360000003611892_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jf0ubmW9qLoQ7kNvgHO8T_Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZ_A27IebD_9IUi04cSnppY&oh=00_AYBq0C3h40SCNNHqKRiffWWdkfiugK1xBhGAnWYInxfhFA&oe=66EACE6F"}, {"file_name": "TemplateLandscape.png", "id": "1172877306521699", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974857_1172877309855032_3159780346436681194_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MRJwf7844H8Q7kNvgFg9-oU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZ_A27IebD_9IUi04cSnppY&oh=00_AYDozLZ0RSAWjbnlyl0pznC454cgsRGuyDtoqTmRlRAkKQ&oe=66EAD088"}, {"file_name": "TemplateHero2.png", "id": "806282513378100", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003231_806282516711433_4319103865356558536_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ofmfe5ggJBwQ7kNvgEZzjs8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZ_A27IebD_9IUi04cSnppY&oh=00_AYDm2RltFSgh1iT32O6GW6NLmZ4xMJU8BnGNtalhTKdcnA&oe=66EAA242"}, {"file_name": "DC_logo.png", "id": "617639125913799", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031433_617639129247132_7728386429254823638_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wQCvDJyfbOkQ7kNvgEW2csY&_nc_ht=scontent.oculuscdn