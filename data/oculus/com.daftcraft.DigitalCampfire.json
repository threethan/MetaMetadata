=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X3fBkwUknNAQ7kNvgFHZVp_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDxgf2zBG2jmR2xtCNBExaueagvgnR5p5FxpOA46rd_ug&oe=675C292E"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff12.png", "id": "3072721432948235", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031411_3072721436281568_5445115366953999188_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8nuswX-0_TsQ7kNvgEtefuA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATmWD-kgiafeHxT9W4jn8UhRs1Q1OZyAIBeCptU6EkkA&oe=675C1B84"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff13.png", "id": "694628618161382", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031365_694628624828048_7207905928164471739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1H3Z7tJil_oQ7kNvgHK3Dj9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOw44wovrmSBVxmVJOcP80ktmmNQh0tEnkBV7HD797Vw&oe=675C3343"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff15.png", "id": "624834208483289", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031506_624834211816622_2109387924173311950_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xXUPxZ5lnEwQ7kNvgFQfuxT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCqaQuQz6YoFd3msaCtbU15wWspGv1Ie07bdNxxPETLOg&oe=675C1444"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff16.png", "id": "1237353566690056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031351_1237353570023389_6271386357945776354_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Cva2YWmi08Q7kNvgGwwQ5n&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5EOfcjWu2Mj4eQrfbuyuQOCVSn2D_EfdfjXuoOqnoBQ&oe=675C16C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30cf\u3099\u30fc\u5199\u771f.png", "id": "922745501653731", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572925_922745504987064_1064929762484899199_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OVb-Rz2Pf-MQ7kNvgF-Lgv4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBY2D9_3AeMr992tqZL3d4tbmPlp4-gMngdRo2LdBCK4A&oe=675C159E"}, "display_name": "Digital Campfire ", "keywords": [], "long_description": "\ud83c\udfd5Easy for VR beginners!\nThe functions are focused on a few, making it simple to operate. Even those who are not familiar with VR can immediately focus on communication.\n\n\ud83c\udfd5Small space for your acquaintances\nThis place can hold up to 10 people at the same time. This version is open-space as a demo version, but the regular version can be used closed. So, you can relax and enjoy conversation with your friends, families, or team mates.\n\n\ud83c\udfd5Bonding in a warm & cozy space\nMost of the time, it takes active engagements to create a bond. But maybe, sharing a starry sky and the crackling sound of firewoods could be enough for us to feel connection to the people next to you. Digital Campfire provides warm and comfortable space for every people!\n\n\u25a0 Spec List\n- 10 users at the same time (If there are more than 10 people in the room, the mode will switch to world browsing only. )\n- Voice chat with spacial audio\n- Full body avatar (2 types)\n- Cave & campfire world", "short_description": "Looking for VR communication app? Digital Campfire is where you can enjoy VR communication and campfire experiences! (*This app is a demo version.)"}, {"images": {"nodes": [{"file_name": "TemplatePortrait.png", "id": "1899961576849564", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001704_1899961580182897_2064927627623761242_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xS8mOYa9r3EQ7kNvgGSEP87&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCp2QXiMRwAoFS_TWuHMVxkiWm9fZHOVWzjvw_Sg7dtXw&oe=675C1A0D"}, {"file_name": "TemplateLandscape\u306e\u30b3\u30d2\u309a\u30fc.png", "id": "1552058528459711", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031398_1552058531793044_221836000000361189