cdn.com&oh=00_AYD4X5By1UHn85ycOKJvfJXdaQ0zcYhWSup3vh3MZbpjbg&oe=66F7F5D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30b7\u30e7\uff10.png", "id": "1530830513948710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195911_1530830517282043_7944463305062052797_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQNDm5K5mb4Q7kNvgF8YYTI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBk7Wpu17Pxl__U7aMKPl8DgRwf5uZFxQEsYRAnaIwmw&oe=66F7FB79"}, "display_name": "\u30c7\u30b8\u30bf\u30eb\u30ad\u30e3\u30f3\u30d7\u30d5\u30a1\u30a4\u30e4\u30fc", "keywords": [], "long_description": "VR\u30b3\u30df\u30e5\u30cb\u30b1\u30fc\u30b7\u30e7\u30f3\u30a2\u30d7\u30ea\u3092\u304a\u63a2\u3057\u3067\u3059\u304b\uff1f\u30c7\u30b8\u30bf\u30eb\u30ad\u30e3\u30f3\u30d7\u30d5\u30a1\u30a4\u30e4\u30fc\u306fVR\u30b3\u30df\u30e5\u30cb\u30b1\u30fc\u30b7\u30e7\u30f3\u3068\u711a\u304d\u706b\u7a7a\u9593\u3092\u4f53\u9a13\u3067\u304d\u308b\u30a2\u30d7\u30ea\u3067\u3059\uff01(\u203b\u3053\u306e\u30a2\u30d7\u30ea\u306f\u4f53\u9a13\u7248\u3067\u3059)\n\n\ud83c\udfd5VR\u521d\u5fc3\u8005\u306b\u3084\u3055\u3057\u3044\uff01\n\u3059\u3050\u306b\u64cd\u4f5c\u3092\u30de\u30b9\u30bf\u30fc\u3067\u304d\u308b\u3088\u3046\u3001\u6a5f\u80fd\u3092\u5c11\u6570\u306b\u7d5e\u308a\u307e\u3057\u305f\u3002VR\u521d\u5fc3\u8005\u306e\u65b9\u3067\u3082\u3059\u3050\u306b\u6163\u308c\u3066\u3001\u30b3\u30df\u30e5\u30cb\u30b1\u30fc\u30b7\u30e7\u30f3\u306b\u96c6\u4e2d\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u308b\u74b0\u5883\u3067\u3059\u3002\n\n\ud83c\udfd5\u6c17\u306e\u77e5\u308c\u305f\u4ef2\u9593\u306e\u305f\u3081\u306e\u5c0f\u3055\u306a\u30b9\u30da\u30fc\u30b9\n\u3053\u3053\u3067\u306f10\u4eba\u306e\u540c\u6642\u63a5\u7d9a\u304c\u53ef\u80fd\u3002\u30c7\u30e2\u30d0\u30fc\u30b8\u30e7\u30f3\u306f\u30aa\u30fc\u30d7\u30f3\u30ef\u30fc\u30eb\u30c9\u3067\u3059\u304c\u6b63\u898f\u7248\u3067\u306f\u30af\u30ed\u30fc\u30ba\u3067\u4f7f\u3046\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u53cb\u9054\u30fb\u5b