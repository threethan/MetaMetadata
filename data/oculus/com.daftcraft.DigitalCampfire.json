594194338244898", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982665_594194341578231_840515192763299177_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lOOhm3_fMTAQ7kNvgHZ39lz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYB0MxadMrxCQyJ40me-LZd3KWb5CrZaFq80A-gjTJ6DyQ&oe=66E6D3AE"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff12.png", "id": "3072721432948235", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031411_3072721436281568_5445115366953999188_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RuqvX2uyDgAQ7kNvgHhbRua&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYDDsgfJIh-Eym8guDpoy_nMMONLm415hiQKEm2Dub5foQ&oe=66E6C604"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff13.png", "id": "694628618161382", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031365_694628624828048_7207905928164471739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nlmBGFV4hhsQ7kNvgEF9t2f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYD8bttQXw4XB8JfYZh27Jp82tENzZi6YwGucmndNDci6w&oe=66E6DDC3"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff15.png", "id": "624834208483289", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031506_624834211816622_2109387924173311950_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XIumkJ5ZjuEQ7kNvgFcCrMk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYC-RnwsJXgM9Vm3r-2Ojv7--rpDdglRY_RAQN8VFota2Q&oe=66E6BEC4"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff16.png", "id": "1237353566690056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031351_1237353570023389_6271386357945776354_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aAf2d_UGzjgQ7kNvgFSsc1g&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYDnkA_D9acvHguwZCOZiYlRp_hER81BmrVRKPc3uTBb9Q&oe=66E6C148"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30cf\u3099\u30fc\u5199\u771f.png", "id": "922745501653731", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572925_922745504987064_1064929762484899199_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ogfYPm60rDgQ7kNvgHg-ALj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYAomaF5bX_H8dEAjci8QfvjfZjUZpG99CYXWHYBz8QFPg&oe=66E6C01E"}, "display_name": "Digital Campfire ", "keywords": [], "long_description": "\ud83c\udfd5Easy for VR beginners!\nThe functions are focused on a few, making it simple to operate. Even those who are not familiar with VR can immediately focus on communication.\n\n\ud83c\udfd5Small space for your acquaintances\nThis place can hold up to 10 people at the same time. This version is open-space as a demo version, but the regular version can be used closed. So, you can relax and enjoy conversation with your friends, families, or team mates.\n\n\ud83c\udfd5Bonding in a warm & cozy space\nMost of the time, it takes active engagements to create a bond. But maybe, sharing a starry sky and the crackling sound of firewoods could be enough for us to feel connection to the people next to you. Digital Campfire provides warm and comfortable space for every people!\n\n\u25a0 Spec List\n- 10 users at the same time (If there are more than 10 people in the room, the mode will switch to world browsing only. )\n- Voice chat with spacial audio\n- Full body avatar (2 types)\n- Cave & campfire world", "short_description": "Looking for VR communication app? Digital Campfire is where you can enjoy VR communication and campfire experiences! (*This app is a demo version.)"}, {"images": {"nodes": [{"file_name": "TemplatePortrait.png", "id": "1899961576849564", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001704_1899961580182897_2064927627623761242_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zlQpRiLdFVAQ7kNvgGPzVXr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvAMpjld0H_lq_MjXpej8vA&oh=00_AYAjUDDlZ-VaoECgzPeIoaQFa8pYDsbpWkheRDYw6OYBiQ&oe=66E6C48D"}, {"file_name": "TemplateLandscape\u306e\u30