=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X3fBkwUknNAQ7kNvgEGizN1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtc1dFAMyHsKO_EM-0X1eXd3XTJLmSYPpQTmNAl_sRBg&oe=675AD7AE"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff12.png", "id": "3072721432948235", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031411_3072721436281568_5445115366953999188_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8nuswX-0_TsQ7kNvgFA71OM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRlVm3qcnXShXgJJkw1th0CtAwwbZsD9RCw3Fv-zYD-g&oe=675ACA04"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff13.png", "id": "694628618161382", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031365_694628624828048_7207905928164471739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1H3Z7tJil_oQ7kNvgHik1xX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSsFQlm5H_ziAUlMrL4bYuFbdIEtOpWhPox66o_nA3VQ&oe=675AE1C3"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff15.png", "id": "624834208483289", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031506_624834211816622_2109387924173311950_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xXUPxZ5lnEwQ7kNvgEXd8tT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSZ00YYG2tLFZSAkuFewsQTKzYECb180MiE0J1oZSIGA&oe=675AC2C4"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff16.png", "id": "1237353566690056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031351_1237353570023389_6271386357945776354_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Cva2YWmi08Q7kNvgHPXW7n&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtWAiqmdEUwdr9zs1oxUcAL5nMfK4R9KBe3-HfP9AtyA&oe=675AC548"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30cf\u3099\u30fc\u5199\u771f.png", "id": "922745501653731", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572925_922745504987064_1064929762484899199_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OVb-Rz2Pf-MQ7kNvgGQzyd3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkZzAyDA5RVvJzQciPC4Feduw_3-8qSfNyCwXOtvjBQQ&oe=675AC41E"}, "display_name": "Digital Campfire ", "keywords": [], "long_description": "\ud83c\udfd5Easy for VR beginners!\nThe functions are focused on a few, making it simple to operate. Even those who are not familiar with VR can immediately focus on communication.\n\n\ud83c\udfd5Small space for your acquaintances\nThis place can hold up to 10 people at the same time. This version is open-space as a demo version, but the regular version can be used closed. So, you can relax and enjoy conversation with your friends, families, or team mates.\n\n\ud83c\udfd5Bonding in a warm & cozy space\nMost of the time, it takes active engagements to create a bond. But maybe, sharing a starry sky and the crackling sound of firewoods could be enough for us to feel connection to the people next to you. Digital Campfire provides warm and comfortable space for every people!\n\n\u25a0 Spec List\n- 10 users at the same time (If there are more than 10 people in the room, the mode will switch to world browsing only. )\n- Voice chat with spacial audio\n- Full body avatar (2 types)\n- Cave & campfire world", "short_description": "Looking for VR communication app? Digital Campfire is where you can enjoy VR communication and campfire experiences! (*This app is a demo version.)"}, {"images": {"nodes": [{"file_name": "TemplatePortrait.png", "id": "1899961576849564", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001704_1899961580182897_2064927627623761242_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X_tS4g1Af9wQ7kNvgHd5X-P&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBBn-mVhyhDuRb-8qzp5-D9ZbDsR31o6ayEgYOX1lZ5dw&oe=675AC88D"}, {"file_name": "TemplateLandscape\u306e\u30b3\u30d2\u309a\u30fc.png", "id": "1552058528459711", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031398_1552058531793044_221836000000361189