108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YWRZLhb8w8oQ7kNvgGuv3W7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwuriP-fmU-bxAIeqaWoWDzmkKr10xS5bY1iTcXjb9Xg&oe=676563AE"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff12.png", "id": "3072721432948235", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031411_3072721436281568_5445115366953999188_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yxRQ5ag92OEQ7kNvgGMFU1r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDk8gmrYerczDADviVsYvr8shqMkJ6ttj02LUHtOaGGSw&oe=67655604"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff13.png", "id": "694628618161382", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031365_694628624828048_7207905928164471739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4jMKTf1GiNoQ7kNvgFCAnQL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDftJm8gg8a1aDOfHu18J8ozoUS9y9tfS_Pob63n6_vpA&oe=67656DC3"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff15.png", "id": "624834208483289", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031506_624834211816622_2109387924173311950_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DmsWf-FRgrQQ7kNvgE6Tcgh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANOInSk7G6_13CcbNzfKXZs4bj4bRvvNOfvaHeN61yeg&oe=67654EC4"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff16.png", "id": "1237353566690056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031351_1237353570023389_6271386357945776354_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iWJH4VgMCPsQ7kNvgGn3yp4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmdTi4vYsgjvvFm7v66Yi5zS_uOROM76lEWeYYViczAA&oe=67655148"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30cf\u3099\u30fc\u5199\u771f.png", "id": "922745501653731", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572925_922745504987064_1064929762484899199_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kj4vx1YCHO4Q7kNvgHLkZyr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAxPOM8xSDmHN73OEG9qg1mO83Unv6QZdfD9MvgBSSzQ&oe=6765501E"}, "display_name": "Digital Campfire ", "keywords": [], "long_description": "\ud83c\udfd5Easy for VR beginners!\nThe functions are focused on a few, making it simple to operate. Even those who are not familiar with VR can immediately focus on communication.\n\n\ud83c\udfd5Small space for your acquaintances\nThis place can hold up to 10 people at the same time. This version is open-space as a demo version, but the regular version can be used closed. So, you can relax and enjoy conversation with your friends, families, or team mates.\n\n\ud83c\udfd5Bonding in a warm & cozy space\nMost of the time, it takes active engagements to create a bond. But maybe, sharing a starry sky and the crackling sound of firewoods could be enough for us to feel connection to the people next to you. Digital Campfire provides warm and comfortable space for every people!\n\n\u25a0 Spec List\n- 10 users at the same time (If there are more than 10 people in the room, the mode will switch to world browsing only. )\n- Voice chat with spacial audio\n- Full body avatar (2 types)\n- Cave & campfire world", "short_description": "Looking for VR communication app? Digital Campfire is where you can enjoy VR communication and campfire experiences! (*This app is a demo version.)"}, {"images": {"nodes": [{"file_name": "TemplatePortrait.png", "id": "1899961576849564", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001704_1899961580182897_2064927627623761242_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vjma8rr6rZIQ7kNvgH7kmZy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArdc3UungWBcClBXFWvdPmWQZNRgs9tbL7BIlhy_RQEQ&oe=6765548D"}, {"file_name": "TemplateLandscape\u306e\u30b3\u30d2\u309a\u30fc.png", "id": "1552058528459711", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031398_1552058531793044_2218360000003611892