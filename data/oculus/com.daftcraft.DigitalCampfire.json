108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cTDpy00HeWgQ7kNvgEfAEu0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmy9ZkX2ZMB75SrV995ZJk5h9yd3cUOanZm18Jhz7jsg&oe=677A7BAE"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff12.png", "id": "3072721432948235", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031411_3072721436281568_5445115366953999188_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=URs8-H1ZWVwQ7kNvgHHhKdV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlqAob7cpIEmB0MuQXdfvM90YJbfpgThcvUQmWeZNAKw&oe=677A6E04"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff13.png", "id": "694628618161382", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031365_694628624828048_7207905928164471739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K4lP-HFo4PcQ7kNvgGGHwTW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABU3bnSrVDyT9SrbRsevM0wClDEBxXclvee1Zph-kPyQ&oe=677A85C3"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff15.png", "id": "624834208483289", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031506_624834211816622_2109387924173311950_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z_6xZ478fHwQ7kNvgG55bPE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjCwjdwu-CPeX7EjEIurlTtVX40ctNBCfXfBfyMlmW5Q&oe=677A66C4"}, {"file_name": "\u30b9\u30af\u30b7\u30e7\uff16.png", "id": "1237353566690056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031351_1237353570023389_6271386357945776354_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ergosxMUyjsQ7kNvgHL1b3R&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5MfkNPANxOKFu--d4SKTbKKHVtXbB2mP3Yi7bOa4aww&oe=677A6948"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30cf\u3099\u30fc\u5199\u771f.png", "id": "922745501653731", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572925_922745504987064_1064929762484899199_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x0ggHY5QaukQ7kNvgHsmxgU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOhrFarRy_8cZWAwy7tA8myTPlqjMnauefk0T5ORvnKw&oe=677A681E"}, "display_name": "Digital Campfire ", "keywords": [], "long_description": "\ud83c\udfd5Easy for VR beginners!\nThe functions are focused on a few, making it simple to operate. Even those who are not familiar with VR can immediately focus on communication.\n\n\ud83c\udfd5Small space for your acquaintances\nThis place can hold up to 10 people at the same time. This version is open-space as a demo version, but the regular version can be used closed. So, you can relax and enjoy conversation with your friends, families, or team mates.\n\n\ud83c\udfd5Bonding in a warm & cozy space\nMost of the time, it takes active engagements to create a bond. But maybe, sharing a starry sky and the crackling sound of firewoods could be enough for us to feel connection to the people next to you. Digital Campfire provides warm and comfortable space for every people!\n\n\u25a0 Spec List\n- 10 users at the same time (If there are more than 10 people in the room, the mode will switch to world browsing only. )\n- Voice chat with spacial audio\n- Full body avatar (2 types)\n- Cave & campfire world", "short_description": "Looking for VR communication app? Digital Campfire is where you can enjoy VR communication and campfire experiences! (*This app is a demo version.)"}, {"images": {"nodes": [{"file_name": "TemplatePortrait.png", "id": "1899961576849564", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001704_1899961580182897_2064927627623761242_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=56835chSicEQ7kNvgF61HjF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCr7exdXp7dFjVHut1z3XJVm0M9XbZlVZ3Fc1wca05o1w&oe=677A6C8D"}, {"file_name": "TemplateLandscape\u306e\u30b3\u30d2\u309a\u30fc.png", "id": "1552058528459711", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031398_1552058531793044_2218360000003611892