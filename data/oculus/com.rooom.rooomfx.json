OhAQ7kNvgG-lSIQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArf_0Uu2lYzr5KyFf7zCmXn8hSv9yMSGcorMquIuTfag&oe=67388BC5"}, {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "588585132499239", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982531_588585139165905_4033963128012507547_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tQWCMgXYJ7MQ7kNvgGjCbFY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEdUD_pIF5QGSF7UAcKcderX0MsTx06pCNKQxKdKy9Rg&oe=67387844"}, {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "547331603262115", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974723_547331606595448_8423993385300020981_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5XLNxIof6SQQ7kNvgEztWYF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUuLu41HcbfSJRtJwaXbknVshWz7Drvg3goApNJ4LG2g&oe=67388BF7"}, {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "170735808405685", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982695_170735811739018_4414633431748974438_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ibOA2mrFIQQ7kNvgEMz4GU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZy4z4tQjDAzkVR7wJoAdMtNv6Bc3PbvRTmgNC9H9IHg&oe=67386929"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "869347497020732", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974448_869347503687398_7666091570050688722_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xLzjFbRe7e8Q7kNvgH4CGNP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqiMhBCK-XdYjstZ5AFJKnRxkcfO-UVvICc6DoWtzHCA&oe=673884BA"}, "display_name": "rooom", "keywords": [], "long_description": "The award-winning VR platform lets you create engaging environments for virtual showcases. \nUsing rooom, the experience of discovering VR spaces will become even more engaging! Create unique virtual venues for digital live performances, interactive exhibitions, smart learning projects and vivid product presentations. Use our best practice templates or design your own digital experience world \u2013 there are no limits!\nWith rooom you are not restricted by a web browser anymore. Supported by the rooom database and API, you can enjoy your virtual spaces in high-resolution VR quality.\nImmerse yourself into virtual brand worlds, walk through vibrant exhibition halls and marvel at high-resolution artworks and 3D models. Interact with the environment, discover integrated content, and meet other guests using your avatar.\nrooom makes it even possible to present your virtual showcases offline \u2013 an internet connection is not necessary for the virtual experience.", "short_description": "Build and explore digital experience worlds in Virtual Reality with rooom!\nrooom releases you from the limitations of a browser and lets you enjoy high-performing VR spaces. Discover virtual learning environments, interactive showrooms, digital events, real estate showcases and much more. \nFeatures:\n\u2022\tWalk-through environments\n\u2022\tLive reflections\n\u2022\tHigh-quality graphics\n\u2022\tInteractions\n\u2022\tAvatars"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/69710204", "developer_terms_of_service_url": "https://www.rooom.com/sites/termsOfUse", "publisher_name": "rooom AG", "support_website_url": "https://rooom.com/contact", "website_url": "https://rooom.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2687655338230691"}, {"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "su