.oculuscdn.com/v/t64.5771-25/38974907_898591967407445_3257976757424588253_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gx-QtHu4U-wQ7kNvgFdTES4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVaxKQ0L7gsRKUpsiz2o3I&oh=00_AYDrQkS8uzxKpM4xH08-iF6XDXXtoLfvSfZdsGN3J8vU1Q&oe=66F00945"}, {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "588585132499239", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982531_588585139165905_4033963128012507547_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MCsdmNvY8k0Q7kNvgGVH9P3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVaxKQ0L7gsRKUpsiz2o3I&oh=00_AYCvVt5AEEg83uY4SnlZfwc_xb-GVWpKF4HIbHxN5yayAg&oe=66EFF5C4"}, {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "547331603262115", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974723_547331606595448_8423993385300020981_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqgWoWR-BwwQ7kNvgEuZUto&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVaxKQ0L7gsRKUpsiz2o3I&oh=00_AYDBe1RrFVVjZqGxsJ_ApU0fJsbMiiWoZMf0rf1ydEgvKw&oe=66F00977"}, {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "170735808405685", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_170735811739018_4414633431748974438_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nknJRxK2kbEQ7kNvgEHVEbH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVaxKQ0L7gsRKUpsiz2o3I&oh=00_AYCoLqGDShuZaF5fSnAJ4XNKJ5kNpNVwUcCEFWwWpajReA&oe=66EFE6A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "rooomFX_Banner_Screenshots_2560x1440.png", "id": "869347497020732", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974448_869347503687398_7666091570050688722_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=26oYasLgV84Q7kNvgHNjMQw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVaxKQ0L7gsRKUpsiz2o3I&oh=00_AYDQhoQOeLx21maPHiUv_kbmBD-Fdz8wESLk2IurRHSubg&oe=66F0023A"}, "display_name": "rooom", "keywords": [], "long_description": "The award-winning VR platform lets you create engaging environments for virtual showcases. \nUsing rooom, the experience of discovering VR spaces will become even more engaging! Create unique virtual venues for digital live performances, interactive exhibitions, smart learning projects and vivid product presentations. Use our best practice templates or design your own digital experience world \u2013 there are no limits!\nWith rooom you are not restricted by a web browser anymore. Supported by the rooom database and API, you can enjoy your virtual spaces in high-resolution VR quality.\nImmerse yourself into virtual brand worlds, walk through vibrant exhibition halls and marvel at high-resolution artworks and 3D models. Interact with the environment, discover integrated content, and meet other guests using your avatar.\nrooom makes it even possible to present your virtual showcases offline \u2013 an internet connection is not necessary for the virtual experience.", "short_description": "Build and explore digital experience worlds in Virtual Reality with rooom!\nrooom releases you from the limitations of a browser and lets you enjoy high-performing VR spaces. Discover virtual learning environments, interactive showrooms, digital events, real estate showcases and much more. \nFeatures:\n\u2022\tWalk-through environments\n\u2022\tLive reflections\n\u2022\tHigh-quality graphics\n\u2022\tInteractions\n\u2022\tAvatars"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/69710204", "developer_terms_of_service_url": "https://www.rooom.com/sites/termsOfUse", "publisher_name": "rooom AG", "support_website_url": "https://rooom.com/contact", "website_url": "https://rooom.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNL