scontent.oculuscdn.com&oh=00_AYBAKx_MiRo_b-w8apRwHpvIIyOJ3zBQOlUBsdHCHb8veg&oe=66CF16B2"}, {"file_name": "Screen3.png", "id": "946994853447418", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001669_946994856780751_1223935063235236959_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y-V0KcldRZwQ7kNvgHM569-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAK4HIHFbWGhnNyWsGBnfROxWngcLyGkB7pn1wPypQq_w&oe=66CF03F3"}, {"file_name": "Screen4.png", "id": "3556688497878419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003251_3556688504545085_937334966672341151_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VimYnqN-dF8Q7kNvgH7KVb2&_nc_ht=scontent.oculuscdn.com&oh=00_AYC91AgqklzaduQQMzLz6OTp6hdL6BuWcJipO5rRieZfAQ&oe=66CF021D"}, {"file_name": "Screen5.png", "id": "391894503462293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_391894510128959_2781007855999020995_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ETTz9dltSsQQ7kNvgFiNo39&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjA0ElzxtOx7pDtPHUbLhys9scyYh-Kk4bwRHofBVqNw&oe=66CEF5A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "456594630143086", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031314_456594633476419_4881022021396404714_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OYlcNOQE4NoQ7kNvgFAWjiN&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQbgksJXuL6U2OFjsrGj8Tw2JVHnwBnsd_m3-Z8NS3PQ&oe=66CEFA25"}, "display_name": "Breathedge: Cosmic Cluck", "keywords": ["survival", "space", "astronaut", "spaceship", "universe"], "long_description": "An Adventure Spin-Off in the Breathedge Universe! In Breathedge: Cosmic Cluck you\u2019ll be able to:\n\n- Come back home.\n\n- Listen to an in-depth commentary on anything from a crazy Chicken.\n\n- Craft a versatile multitool that makes it so convenient to throw garbage at enemies and pull yourself to asteroids and shipwrecks... you've always dreamed of a grappling hook, haven\u2019t you?\n\n- Explore outer space and collect all the garbage that has been dumped into it by humankind... and an evil, very EVIL corporation.\n\n- Visit the space farms of an athlete, a hippie, and a criminal mastermind.\n\n- Fight a boss whose appearance you couldn't possibly have a clue about... well okay, you could, you just refused to believe it.\n\n- Save the UNIVERSE... okay, just the farm, but oh man, what a salvation it'll be!\n\nJoin the Man in his space adventure and your virtual reality will become much more real than ever before.", "short_description": "An Adventure Spin-Off in the Breathedge Universe! Breathedge: Cosmic Cluck is a Retro-Futuristic Adventure with a talking Chicken your main companion.\n\nFill your pockets with junk, build the Universal Survival Tool, blast the monitors off enemy robots, explore abandoned farms, and help Grandfather fight the Evil Corporation. You don't want to be cut out of the will, do you?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypetraindigital.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "HypeTrain Digital", "support_website_url": null, "website_url": "https://www.hypetraindigital.com/games/breathedge", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7258748120891179"}, "review_messages": [""]