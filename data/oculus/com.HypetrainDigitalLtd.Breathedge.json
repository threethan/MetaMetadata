ent.oculuscdn.com&_nc_gid=A9RcmWAQQANErPgYSF4dqOw&oh=00_AYBoq6dMsvMCvYGVYbx85LMog8OuwEWUa-FXo19oJDHgVg&oe=66E6C0C2"}, {"file_name": "Screen2.png", "id": "1483694128847202", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_1483694132180535_4793446981319234993_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6DC0HHjYQkQ7kNvgE1T_0O&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9RcmWAQQANErPgYSF4dqOw&oh=00_AYCmiLitK8MsO_Ac34JcxCxjk4RVcR4k5dqPFp8N7E84TA&oe=66E6D1B2"}, {"file_name": "Screen3.png", "id": "946994853447418", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001669_946994856780751_1223935063235236959_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vXf8pxz4-okQ7kNvgHE94O4&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9RcmWAQQANErPgYSF4dqOw&oh=00_AYAuYxzEE24DszP0pacA_HFEj7gs7JiJDimM5AQ3Zz28fw&oe=66E6BEF3"}, {"file_name": "Screen4.png", "id": "3556688497878419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003251_3556688504545085_937334966672341151_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=baJf3HczlKIQ7kNvgGQ2AuM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9RcmWAQQANErPgYSF4dqOw&oh=00_AYAMUIxixEQQQK-OgZi4m_uzY59k_hMLPYNCn-0aGWvnEg&oe=66E6BD1D"}, {"file_name": "Screen5.png", "id": "391894503462293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_391894510128959_2781007855999020995_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03nyjDSUVLsQ7kNvgEuUl-7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9RcmWAQQANErPgYSF4dqOw&oh=00_AYBw-rExr0HoHEYcGKL3NNKJ9OXltr39U62BvLAv6KjPng&oe=66E6B0A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "456594630143086", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031314_456594633476419_4881022021396404714_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9d2EfZI2Ed4Q7kNvgED6cHE&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9RcmWAQQANErPgYSF4dqOw&oh=00_AYAhToIayxuT-bBrbTgymECvZEnsKQPtWEW93CjdXkrC4g&oe=66E6B525"}, "display_name": "Breathedge: Cosmic Cluck", "keywords": ["survival", "space", "astronaut", "spaceship", "universe"], "long_description": "An Adventure Spin-Off in the Breathedge Universe! In Breathedge: Cosmic Cluck you\u2019ll be able to:\n\n- Come back home.\n\n- Listen to an in-depth commentary on anything from a crazy Chicken.\n\n- Craft a versatile multitool that makes it so convenient to throw garbage at enemies and pull yourself to asteroids and shipwrecks... you've always dreamed of a grappling hook, haven\u2019t you?\n\n- Explore outer space and collect all the garbage that has been dumped into it by humankind... and an evil, very EVIL corporation.\n\n- Visit the space farms of an athlete, a hippie, and a criminal mastermind.\n\n- Fight a boss whose appearance you couldn't possibly have a clue about... well okay, you could, you just refused to believe it.\n\n- Save the UNIVERSE... okay, just the farm, but oh man, what a salvation it'll be!\n\nJoin the Man in his space adventure and your virtual reality will become much more real than ever before.", "short_description": "An Adventure Spin-Off in the Breathedge Universe! Breathedge: Cosmic Cluck is a Retro-Futuristic Adventure with a talking Chicken your main companion.\n\nFill your pockets with junk, build the Universal Survival Tool, blast the monitors off enemy robots, explore abandoned farms, and help Grandfather fight the Evil Corporation. You don't want to be cut out of the will, do you?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypetraindigital.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "HypeTrain Digital", "support_website_url": null, "website_url": "https://www.hypetraindigital.com/games/breathedge", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_typ