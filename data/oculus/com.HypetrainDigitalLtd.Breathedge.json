ent.oculuscdn.com&_nc_gid=ANz78Nk24nGED9uxn6rAZ9h&oh=00_AYDYfBwF0WXUfT2U5nwlatOJQGuKcglaC4rHX_QrmXGCSw&oe=66E81242"}, {"file_name": "Screen2.png", "id": "1483694128847202", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_1483694132180535_4793446981319234993_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6DC0HHjYQkQ7kNvgGOdUfR&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANz78Nk24nGED9uxn6rAZ9h&oh=00_AYBErFU6NU0VCQXKyGn-dgNzdvi-no4kXZjFg7egp4_QDA&oe=66E82332"}, {"file_name": "Screen3.png", "id": "946994853447418", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001669_946994856780751_1223935063235236959_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17ZzcIv8ZyAQ7kNvgHpkWvs&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANz78Nk24nGED9uxn6rAZ9h&oh=00_AYD3RtdnpAKyxgaHLi7feaPt314DDWvd5Jf3dDBkshPl4w&oe=66E81073"}, {"file_name": "Screen4.png", "id": "3556688497878419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003251_3556688504545085_937334966672341151_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cPUIGvskTtYQ7kNvgH34nZi&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANz78Nk24nGED9uxn6rAZ9h&oh=00_AYCHAyYceaJn0-4QKxckWoDGTpWeY5AuLRot4QtEFVgpVQ&oe=66E80E9D"}, {"file_name": "Screen5.png", "id": "391894503462293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_391894510128959_2781007855999020995_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fgd1DfAUqTMQ7kNvgFFsZbw&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANz78Nk24nGED9uxn6rAZ9h&oh=00_AYCcCi1g_YVdcKKZhNDAg1WzMMZN9QRdCmfhv0qC_WDp1A&oe=66E80224"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "456594630143086", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031314_456594633476419_4881022021396404714_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9d2EfZI2Ed4Q7kNvgHzB9LM&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANz78Nk24nGED9uxn6rAZ9h&oh=00_AYARxMXFx-Ztq4FHh90iY4B14DSA5Xr9cusS7Ma6Uf8eVQ&oe=66E806A5"}, "display_name": "Breathedge: Cosmic Cluck", "keywords": ["survival", "space", "astronaut", "spaceship", "universe"], "long_description": "An Adventure Spin-Off in the Breathedge Universe! In Breathedge: Cosmic Cluck you\u2019ll be able to:\n\n- Come back home.\n\n- Listen to an in-depth commentary on anything from a crazy Chicken.\n\n- Craft a versatile multitool that makes it so convenient to throw garbage at enemies and pull yourself to asteroids and shipwrecks... you've always dreamed of a grappling hook, haven\u2019t you?\n\n- Explore outer space and collect all the garbage that has been dumped into it by humankind... and an evil, very EVIL corporation.\n\n- Visit the space farms of an athlete, a hippie, and a criminal mastermind.\n\n- Fight a boss whose appearance you couldn't possibly have a clue about... well okay, you could, you just refused to believe it.\n\n- Save the UNIVERSE... okay, just the farm, but oh man, what a salvation it'll be!\n\nJoin the Man in his space adventure and your virtual reality will become much more real than ever before.", "short_description": "An Adventure Spin-Off in the Breathedge Universe! Breathedge: Cosmic Cluck is a Retro-Futuristic Adventure with a talking Chicken your main companion.\n\nFill your pockets with junk, build the Universal Survival Tool, blast the monitors off enemy robots, explore abandoned farms, and help Grandfather fight the Evil Corporation. You don't want to be cut out of the will, do you?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypetraindigital.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "HypeTrain Digital", "support_website_url": null, "website_url": "https://www.hypetraindigital.com/games/breathedge", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_typ