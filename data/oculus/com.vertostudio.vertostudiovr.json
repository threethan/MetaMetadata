n.com/v/t64.5771-25/38974684_123993829622586_3071525568216661453_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GR5c9qwPHS8Q7kNvgEshxt8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC94LOxOztCICCDxrBgHL2MbtVnnYbVFtQ2nAlTqrMKvQ&oe=671F65B7"}, {"file_name": "quest_store_ss5.png", "id": "451607189360258", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974738_451607192693591_5264901383228771667_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RQ4Qf7eja9gQ7kNvgFhjLrP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtmpgfzE402H9LF9r_CFnMjT9HieKKJfGnIRwBmYLj_w&oe=671F6AD6"}, {"file_name": "quest_store_ss1.png", "id": "1061720087646878", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974908_1061720090980211_61566680048714381_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qGq684F5r-kQ7kNvgHHp0nR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUOIPfPgV4IK3bFhH96poTiG_086P2Cw1-phHm4_RWzQ&oe=671F945E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "quest_store_promo_cover.png", "id": "417340956009330", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031495_417340959342663_8025418479443864112_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FKO9eBBArdsQ7kNvgFUFSWI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCieedaon7Jnr7yo8d_WLzXCsj5Muur6IGzlXl-WNoWCQ&oe=671F81E5"}, "display_name": "Verto Studio VR", "keywords": [], "long_description": "VertoStudio VR is a fully-capable 3D modeling studio designed to run entirely in VR!  You can use it to import FBX, OBJ, DAE (and more) directly in front of you, then configure every aspect of the visual display of these scenes directly down to the individual polygons. \n\nWhether you are mocking up a quick VR workflow, or designing production VR environments, this tool eliminates all of the pipeline complexity involved with getting 3D assets and content into VR quickly. Using Verto Studio, there is no more guesswork in designing for VR. ", "short_d