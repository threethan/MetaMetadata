0428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dnHTBYMXzEoQ7kNvgHmHACo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvvHNY2-Zw7_6hjKRh9KXySLHnYZ7sISgjdp1LsiwIwQ&oe=671390C6"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pY8yo_W3GmQQ7kNvgGgt9RA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCL0nOQcUSDc9QEaXl5XpVMrGF5nh5aRFPtxnBMLaIdIg&oe=67138CB0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T-AMaSAXVM8Q7kNvgHVCAGj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBz4bJEyfJZ3SyaROImnZ5WBF9yFd-941e-i9kNpBZfwA&oe=6713B844"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-polic