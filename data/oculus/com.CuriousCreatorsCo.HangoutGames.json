567095083", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568674_1370521570428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zExT5Of7OW8Q7kNvgEfbCLx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJ0MQQYume2Q3bHkBTuqtrVv_ApcWANYUYxptexxvnWg&oe=67499E46"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7R5_Nr2gI1AQ7kNvgFB2l1q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBAgoxrysMBBctesfsiOYh1ONOg1G1ikF1FTwIjtrbUkw&oe=67499A30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1by0rtfZwSwQ7kNvgHF1ZSW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9DA9waVgSTILNAA7x1N3aSgxArUHtfpcRqDuwh4lzIQ&oe=6749C5C4"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusia