567095083", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57568674_1370521570428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yVHzgYQe7rMQ7kNvgH-OAJs&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDEBmfsLQvUa5TRuQh3UPu0rqc2QIzaACWRqpjDyYDHUg&oe=6756CD46"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_rtfqjrLLxMQ7kNvgFstV36&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCdEVJl0tMz6q-FNUesFZgXecSvpjh1d-lV6viZq2K95w&oe=6756C930"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ohMdLLfpY2AQ7kNvgGrzXEp&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAAhcQbP3B3LpZ5oCDegTNVDmxqdq437UDLNOhtVi6pdw&oe=6756F4C4"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusia