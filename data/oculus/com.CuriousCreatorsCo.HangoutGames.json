0428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S_R94r723c0Q7kNvgESEXGL&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDQTDHgLjniidaBYt46du0Unt-csxuQQhfctr7Z-PT5Uw&oe=670BA7C6"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FO32iiRN-V8Q7kNvgFBrGHj&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBJMbo-SnW7Ay5TVMHSmHti3gqAPGG_DBzvdp1TsIAT9Q&oe=670BA3B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=89bFtvZk-NwQ7kNvgEJ4Vtm&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAZlTC4eNJN1v5I_esjIQjQLW8bi9CEoONRY9jbAIoWTw&oe=670B9704"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-polic