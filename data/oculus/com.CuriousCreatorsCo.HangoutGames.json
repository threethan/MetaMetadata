0428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NN0SfGM_KwsQ7kNvgFyWXpq&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA20_OGrj53ObEtm1VG0FJEsP9AR1cfvlskkeT5xqhwng&oe=670F9C46"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ejZ4fB56o08Q7kNvgFtLHXA&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBklb0BOfQ4K-dNhUkGcgQDTUearK1GbTBkiE-T4qg4Tw&oe=670F9830"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gboekBPyd50Q7kNvgHCxSxj&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC9UIRcQHH9KDc36Rv__VXWwmZWyxuVg9aT6fYMCqYjsg&oe=670F8B84"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-polic