0428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HjbnIh3lWRsQ7kNvgGoepN0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfJuIzjEf1f7M2iyi_sSarVaY6xPcXnqozbdCYjUf_XA&oe=6720BFC6"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4I9iuT8-KuMQ7kNvgFU1Gmx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArSn3xkIVN4FQyQZ-TVF63EEkfpcBqJCTynuuuuVGXkw&oe=6720BBB0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1c3esOhLy-cQ7kNvgEdP9OF&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApLt3FO2xs26pIWMFamMjUEqeu4M6F8Tu-QYI10BlJaQ&oe=6720AF04"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-polic