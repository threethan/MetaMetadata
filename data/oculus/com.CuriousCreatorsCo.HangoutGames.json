0428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6QgX2RhapS4Q7kNvgHMg9eO&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAD7z3Mo5Hfe5rn1QcAsJZJWu0ovgvQlgo8bc6fYksHkA&oe=67011BC6"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B-o4M0lNDvAQ7kNvgG4GdVp&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCKFfExXwNcOpz0tSv2DnOC8cybVTzkqTSJrrVwePnFmQ&oe=670117B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Xw7AmZs9xEQ7kNvgFCW2Wj&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAJ30cZqv4HWIPIYm1f7ToO3-GY1Reh40otS5QCFt7jdQ&oe=67014344"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-polic