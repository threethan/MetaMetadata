567095083", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/57568674_1370521570428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A2L60Ohj1z8Q7kNvgEj_jqJ&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBNQRPrpEs3WK1-R5gPiVl-4DuoTdLQIpf4awf9ALrJaA&oe=67518746"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v2wzRrTNWQMQ7kNvgG-K08k&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCW7qCx17V1xjUjq6c1smMjpJkRTWZ_UmmhCjcynwlY6Q&oe=67518330"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hw4-Nmv_g2UQ7kNvgF7dnHO&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDG4SBQuE39hBxrtKVTh6cAtuoI9CvUmihV1NnZTqPvJg&oe=6751AEC4"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusia