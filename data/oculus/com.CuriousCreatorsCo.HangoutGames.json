567095083", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568674_1370521570428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R8TbxFmlaX4Q7kNvgEGGDHJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBibb_mQdAnZCM3ko7TBWdAtCgR41rwPDdx1RFrMluB7A&oe=6773CE46"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jMlVIqXMBT0Q7kNvgG7llFZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQOg2Uopf5jKACq-MVqW8tm-XMVRzB7-e8U20N3p7d6g&oe=6773CA30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dn4xOs3EOrQQ7kNvgEBpKU4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATTXwTUOl9USZPT1YCe710rx5D-jXoYbRrONXUOpL94w&oe=6773BD84"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Curious Creators Co.", "support_website_url": null, "website_url": "https://www.curiouscreatorsgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "ART_CREATIVITY", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "780498299664847"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57574716_494356249374080_139159223172307728_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AhzKp0ueCP8Q7kNvgGxswmM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDpYg1530SrM1VbuGjqjTCaXWhccNaCPtSVYjRbjHWT-w&oe=6773EA32"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Spark", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Party Game", "id": "1700921480735423"}], "release_date": 1661965158, "lastRevision": {"nodes": [{"id": "8518098951540891", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8518098914874228", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": 