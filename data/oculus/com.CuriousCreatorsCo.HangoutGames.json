567095083", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/57568674_1370521570428416_6683341558105669118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ACb9lbwb72IQ7kNvgEE9uAZ&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCr7QSwC5X5zJeR2SSaf8pbwvS7GJV0MoniMGhUEg-b_w&oe=671A2846"}, {"file_name": "Screenshots_hangoutGames_05.png", "id": "5593006924095285", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39035433_5593006927428618_5014745775662241398_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KlaIJj4h1uUQ7kNvgFogLwW&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAmPhAVgFPCayQ8z0AmBaQXQmFaOEfwvLVhpgAWAyurMA&oe=671A2430"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Spark_VRUNOUpdate_CoverLandscape.png", "id": "180227841416099", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38982627_180227844749432_7870967784300522440_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L7TSkkryHD0Q7kNvgGifKA2&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAnnPomMNgpXDr05GTijZORzEVHv7vADRPV4CEqwdIDww&oe=671A1784"}, "display_name": "Spark", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copy Cat, take turns drawing and guessing each other's creations. \n\nVRUNO is your favorite family card game, with a disco dance twist. Try it out, and try to out dance your competition!\n\nIn High Roller, test your trivia knowledge and bet your way to success against the competition.\n\nClue Cove is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nAlso, listen to music with your friends together with our shared room radio.\n", "short_description": "Formerly Hangout Games, free and fun social party games for multiplayer. A chill, fun place to socialize with friends and like-minded game enthusia