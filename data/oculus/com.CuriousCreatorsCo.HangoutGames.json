1618_1362407947617031_2202114620352043181_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZC2VeV5RoBQQ7kNvgFzpYrH&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBonl5C5Zr3bGexdyxrichJbo_DWfWNFYWVdGoMO7Huog&oe=67162461"}, {"file_name": "39031433_5170499593043967_5647460791535147534_n.png", "id": "573769781100075", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75630185_573769784433408_4874436914141267503_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VzeDX3LuKRAQ7kNvgGZk6ba&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBOwQ0S-Rk6l_TGHfHmFYbwXWeuDndktEgBzggabWlg-g&oe=67163215"}, {"file_name": "com.CuriousCreatorsCo.Formation-20220712-110717.png", "id": "3325514594359241", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974738_3325514597692574_7713797041680217542_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8pmVSzoIqUYQ7kNvgFKot84&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBcOklyi90Inzy3ZNLWmCSMhHTPp34rgTFPfeg9IGVDkQ&oe=67163CAF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hangout Games", "keywords": [], "long_description": "Supports up to 8 players in each lobby. \n\nIn Copycat, take turns drawing and guessing each other's creations. \n\nCodewords is a fantastically fun word clue guessing game on a beautiful beach! Two teams attempt to guess words given by their spy masters. Be the first to guess all of your teams words without selecting the other team's words, or even worse, the bomb!\n\nFormation is a game of luck and strategy. Make a sequence of 5 cards in either direction or diagonally. First team to two sequences wins!\n\n", "short_description": "A chill, fun place to socialize with friends and like-minded game enthusiasts!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.curiouscreatorsgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Curious Creators Co.", "support_website_url": null, "website_url": "https://ww