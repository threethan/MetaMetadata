9RAJnHgEIVOiCxAR3hnghWh_TPWb8pz7zNw7g&oe=67388F45"}, {"file_name": "migrated_image.png", "id": "1047326192301200", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12602069_1924544877781818_7846082699130306560_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B-FPRMjWencQ7kNvgGGVoc8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdbm7Ga6tUsIHLnM9ZVAWM_ElYgx0khqDOpx_jvE7fZQ&oe=67386E2C"}, {"file_name": "migrated_image.png", "id": "2614702835464427", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12727931_1885549548355508_7510415208058191872_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5pkuN8bu380Q7kNvgF_NYSm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8KpCQeJl96tlgUnON86lEiX3dv4SJOoUaSsBRIX8JkA&oe=67389415"}, {"file_name": "migrated_image.png", "id": "544421042881208", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12602284_190388158127198_8037412647374684160_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rf4kjkkPrlcQ7kNvgGjsX5x&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeCrA8cK1haIWQz3oy2bboLJruajDfHcuvfM3Xvxs7qQ&oe=673899FB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Vlisco", "keywords": ["Fashion", "Clothes", "Design"], "long_description": "Entrez dans le monde color\u00e9 de Vlisco et d\u00e9couvrez comment nos tissus de cire sont fabriqu\u00e9s.\n\nVlisco fabrique des textiles aux Pays-Bas principalement pour les femmes africaines, qui portent ces tissus pour exprimer leur style individuel et communautaire. Fonde en 1846, Vlisco a maintenant une collection riche de 350 000 textiles uniques. Les designs audacieux, color\u00e9s et surprenants viennent \u00e0 la vie en raison de la beaut\u00e9 naturelle du processus d'impression de cire, faisant chaque yard imprim\u00e9 unique.\n\nD\u00e9couvrez cette vid\u00e9o unique de r\u00e9alit\u00e9 virtuelle qui vous emm\u00e8ne dans notre usine d' Helmond. Entrez dans notre environnement de design o\u00f9 vous verrez des designers en plein travail et faite un tour parmi nos machines sp\u00e9ciales et d\u00e9couvrez nos proc\u00e9d\u00e9s magiques. D\u00e9couvrez pourquoi les tissus Wax Hollandais ne peuvent \u00eatre que Vlisco.", "short_description": "D\u00c9COUVREZ L\u2019USINE VLISCO"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.scopic.nl/", "developer_terms_of_service_url": "http://www.scopic.nl/", "publisher_name": "Scopic", "support_website_url": null, "website_url": "https://www.vlisco.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPLORATION", "MOVIE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["fr"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "902748427054646"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12386450_193288624493989_8233982898101813248_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GXvpP3tgIWMQ7kNvgGcZf3N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAWRPGzKYdT7Inj88YUy0uLFq2zDdLu81QSUX2M08sXWw&oe=67388CAC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Vlisco", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1491980400, "lastRevision": {"nodes": [{"id": "1820132848238584", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1233634056684177", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"