ng", "multimusic"], "long_description": "This is an educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. You have to move your head and select the correct answer with Gear Vr Controller or touchpad in the shortest possible time. And make no mistake or you will get an electric shock!. It's highly recommended for teachers to motivate their students with Maths and Music. It's a lot of fun to play it with kids in class and try to get the shortest time and learn Maths and Music while playing.", "short_description": "An educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. \n     You have to move your head and select the correct answer with Gear Vr Controller or touchpad in the shortest possible time. And make no mistake or you will get an electric shock!. It's highly recommended for teachers to encourage their students with Maths and Music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://termsfeed.com/privacy-policy/97bbd061665a34feeb770c2e5a014223", "developer_terms_of_service_url": "https://termsfeed.com/privacy-policy/97bbd061665a34feeb770c2e5a014223", "publisher_name": "Rafael Gimeno", "support_website_url": null, "website_url": "https://www.youtube.com/channel/UCqdPBw7LqObII7qDh6pUwpg", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_mode