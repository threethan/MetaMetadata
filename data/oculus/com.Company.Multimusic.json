6525_2231656846563737600_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-e8pgDfCCXwQ7kNvgE3vbyw&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBqcm0ObPU9hoJV5SJlvi39FKa8UlWm9fMlNCWn0yDkVQ&oe=6702695D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Multimusic", "keywords": ["multiplication", "tables", "music", "eartraining", "multimusic"], "long_description": "This is an educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. You have to move your head and select the correct answer with Gear Vr Controller or touchpad in the shortest possible time. And make no mistake or you will get an electric shock!. It's highly recommended for teachers to motivate their students with Maths and Music. It's a lot of fun to play it with kids in class and try to get the shortest time and learn Maths and Music while playing.", "short_description": "An educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. \n     You have to move your head and select the correct answer with Gear Vr Controller or touchpad in the shortest possible time. And make no mistake or you will get an electric shock!. It's highly recommended for teachers to encourage their students with Maths and Music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://termsfeed.com/privacy-policy/97bbd061665a34feeb770c2e5a014223", "developer_terms_of_service_url": "https://termsfeed.com/privacy-policy/97bbd061665a34feeb770c2e5a014223", "publisher_name": "Rafael Gimeno", "support_website_url": null, "website_url": "https://www.youtube.com/channel/UCqdPBw7LqObII7qDh6pUwpg", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "MUSIC"], "has_i