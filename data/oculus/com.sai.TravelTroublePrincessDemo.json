//scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031495_358035183001351_7373169728344257660_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mvq2-_roGtYQ7kNvgGlXeSO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmm8PBuweNvUhb_I3yVP0YzFpcx5lT-KS_aM0c-j_PmQ&oe=677FB8E0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "samune.png", "id": "1236812453730460", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974600_1236812457063793_7215892702917018058_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m6JACetbBVcQ7kNvgG-rT6g&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNY4Gc5NMfJComhRfT9Io1wxe_y4rdHHSqxF0sf7JYkA&oe=677FD007"}, "display_name": "Travel Trouble Princess Demo", "keywords": ["Journey", "RUN", "Free", "Cute", "Adventure"], "long_description": "-------------------------------------------------\nOperation Description\n\nA Button :\nAsk your princess to jump.\n\nSword in the right hand :\nSwinging a sword against a monster to reduce the monster's HP.\n\n\nLeft-hand umbrella :\n\nBy covering the princess with the shadow of the umbrella\nthe princess's health will not be depleted.\n\n-----------------------------------------------------------------------\nStory\n\nOnce upon a time,\nthere was a kind-hearted princess.\nShe was heartbroken by the world's ongoing war with monsters.\n\nOne day, she decides to go to the temple of the God of Creation\nat the end of the world to pray for peace.\n\nYou are the knight who protects her.\nUse your sword to drive away monsters along the way, and\nUse your umbrella to provide her with shade.", "short_description": "This app is a demo version of \"Travel Trouble Princess\"\nYou can play up to Stage 2.\n\nWield your sword.\nand guide the princess on her journey!\n\nWith the sword in her right hand, she drives away her enemies, and\nThe left-hand umbrella provides shade and keeps the princess from losing energy.\nA new type of VR run game is now available!\n\nWhether or not the princess can make it safely through her journey is\ndepends on your two hands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2022/07/travel-trouble-princess.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2022/07/about-travel-trouble-princess.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8950184051686305"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035308_1048099973362927_3742823903326026503_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mr7Th2aXhKsQ7kNvgGiRdPA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBbRb0M2zZinJ4N0xS7L6gED-jkeEnMlz-V-UhDJxefMw&oe=677FBDEF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Travel Trouble Princess Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1658854800, "lastRevision": {"nodes": [{"id": "5406076632