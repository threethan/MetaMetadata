dQ&oe=676D4E95"}, {"file_name": "4.png", "id": "1046342166063489", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974760_1046342169396822_2464903453867216222_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N8qlhhtP92oQ7kNvgENxJ4u&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAWNnF0urTqOj_F2Lbp5VHFloTO0wZDLNNlf9Cxm8Iisw&oe=676D2AD4"}, {"file_name": "2.png", "id": "1758009217870081", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575358_1758009224536747_6093307699415438475_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WA0vRLcXep4Q7kNvgFlQHxo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRiPH2oncIVsFAxYmt9vkqUU_70lq4wx_njPQ4tBC-lA&oe=676D3C8B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1089995215277965", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982532_1089995218611298_2733378075075386054_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IvPVP8MhM6IQ7kNvgG8lMZi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9nZKntJ6PzuXE9o1OllMQVqSYhY7sEmYjsLSw3RzJtA&oe=676D4BCC"}, "display_name": "Towerport Demo", "keywords": [], "long_description": "STRATEGY AND ACTION\nAs the sole defender of the realm, you will need to be an effective archer as well as a fast-thinking strategist. The enemy is persistent and strong, and will often attack more than one front. Your ability to keep calm, build the right towers on the right spots, freezing a group of enemies with your battle orbs while nailing head-shots with your bow, will be crucial to your success\n\nADAPT AND PREVAIL\nThroughout your missions, you will confront gradually tougher enemies with various skill sets and stats. No single strategy works for them all. You will have to adapt and experiment with alternative tactics to succeed.\n\nLOOKING FOR THE FULL VERSION?\n- https://www.oculus.com/experiences/quest/7805743412834399/", "short_description": "Demo version of Towerport (3 levels available)\n\n