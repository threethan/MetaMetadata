2169396822_2464903453867216222_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z4Tbffy343oQ7kNvgG4Mxo7&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAOrT-RpJ5sckTL0pPITjoSMKBehVKcPWrXyT330OeiGA&oe=678788D4"}, {"file_name": "2.png", "id": "1758009217870081", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/57575358_1758009224536747_6093307699415438475_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j3ynv315T3oQ7kNvgGf56AA&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAaqsRfL0y7cfpZznOBGJ1LSwN4oe1NHYU4bDv9SL41kA&oe=67879A8B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1089995215277965", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982532_1089995218611298_2733378075075386054_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oo8FGmczabMQ7kNvgEY3BqE&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA8xwNfbp_-9BXl7r3Z-eLmup-4fhgTZfWdPceCnDBO_w&oe=6787A9CC"}, "display_name": "Towerport Demo", "keywords": [], "long_description": "STRATEGY AND ACTION\nAs the sole defender of the realm, you will need to be an effective archer as well as a fast-thinking strategist. The enemy is persistent and strong, and will often attack more than one front. Your ability to keep calm, build the right towers on the right spots, freezing a group of enemies with your battle orbs while nailing head-shots with your bow, will be crucial to your success\n\nADAPT AND PREVAIL\nThroughout your missions, you will confront gradually tougher enemies with various skill sets and stats. No single strategy works for them all. You will have to adapt and experiment with alternative tactics to succeed.\n\nLOOKING FOR THE FULL VERSION?\n- https://www.oculus.com/experiences/quest/7805743412834399/", "short_description": "Demo version of Towerport (3 levels available)\n\nA VR tower defense experience where you function as both general and soldier. As the newly appointed Sky Marshall you oversee the defense effort and take on the enemy with bow, zeppelin, and battle orbs! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://barrelcry.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Barrelcry", "support_website_url": null, "website_url": "https://barrelcry.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1094210291218429"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974658_1123216291934131_7829909346370512248_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OY6TFxuUzUgQ7kNvgFu-Lpy&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCIuJnTAOC1inlMXuwStDi_gY4y9qDEQObU6hmCWvqsoQ&oe=6787AE53"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Towerport Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1662933600, "lastRevision": {"nodes": [{"id": "5811635492201864", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5811635368868543", "is_first_party": false, "