342166063489", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974760_1046342169396822_2464903453867216222_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yf5VGhFtxxQQ7kNvgHJ1O9-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AknD-w9QUdZLgxrC0IIHVQ5&oh=00_AYAAfdhon6-ajqpYpDRccEKeLL-jJRpFcrjONXJgCBpjbQ&oe=66EFEC54"}, {"file_name": "2.png", "id": "1758009217870081", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575358_1758009224536747_6093307699415438475_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6G0noPXlc_gQ7kNvgG9RyaZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AknD-w9QUdZLgxrC0IIHVQ5&oh=00_AYCYhbdGO_sNnNaK9bTmdpMNMwOgr3_Ztdy0SRsPCpAngw&oe=66EFFE0B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1089995215277965", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982532_1089995218611298_2733378075075386054_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nP_BQokvHQMQ7kNvgEzhnJB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AknD-w9QUdZLgxrC0IIHVQ5&oh=00_AYBB6-gPyxKYxHGyg0hJxrpYYzpDvm7VuF2gPdCi_pN43g&oe=66F00D4C"}, "display_name": "Towerport Demo", "keywords": [], "long_description": "STRATEGY AND ACTION\nAs the sole defender of the realm, you will need to be an effective archer as well as a fast-thinking strategist. The enemy is persistent and strong, and will often attack more than one front. Your ability to keep calm, build the right towers on the right spots, freezing a group of enemies with your battle orbs while nailing head-shots with your bow, will be crucial to your success\n\nADAPT AND PREVAIL\nThroughout your missions, you will confront gradually tougher enemies with various skill sets and stats. No single strategy works for them all. You will have to adapt and experiment with alternative tactics to succeed.\n\nLOOKING FOR THE FULL VERSION?\n- https://www.oculus.com/experiences/quest/7805743412834399/", "short_description": "Demo version of Towerport (3 levels available)\n\nA VR tower defense experience where you function as both general and soldier. As the newly appointed Sky Marshall you oversee the defense effort and take on the enemy with bow, zeppelin, and battle orbs! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://barrelcry.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Barrelcry", "support_website_url": null, "website_url": "https://barrelcry.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1094210291218429"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974658_1123216291934131_7829909346370512248_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lm2J8DBFeoQQ7kNvgHXY06b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AknD-w9QUdZLgxrC0IIHVQ5&oh=00_AYADTezbO69VmeroABxzeJ2ggUZ0jcQNQxHMDz77XtO3mQ&oe=66F011D3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Towerport Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1662933600, "lastRevision": {"nodes": [{"id": "5811635492201864", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5811635368868543", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "ia