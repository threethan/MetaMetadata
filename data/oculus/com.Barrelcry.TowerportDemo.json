gQ7kNvgE7GaX1&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCZuJ2VPM03aVUnkia6WcN-yWs6WvaGhC0yPiqPgsKoVA&oe=67010FD4"}, {"file_name": "2.png", "id": "1758009217870081", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57575358_1758009224536747_6093307699415438475_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ee77U-Uic7sQ7kNvgEtk4oM&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBEWPSraN5ub40LYs3XgxJrFTSNUYlxrjPGGjAE-4S69g&oe=6701218B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1089995215277965", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982532_1089995218611298_2733378075075386054_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEDrsnPKR-QQ7kNvgF1fyQC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDSGH1PkYhp0a6CGCeXWy-_yM_YBa1If-Ap9dGqRsL4qw&oe=670130CC"}, "display_name": "Towerport Demo", "keywords": [], "long_description": "STRATEGY AND ACTION\nAs the sole defender of the realm, you will need to be an effective archer as well as a fast-thinking strategist. The enemy is persistent and strong, and will often attack more than one front. Your ability to keep calm, build the right towers on the right spots, freezing a group of enemies with your battle orbs while nailing head-shots with your bow, will be crucial to your success\n\nADAPT AND PREVAIL\nThroughout your missions, you will confront gradually tougher enemies with various skill sets and stats. No single strategy works for them all. You will have to adapt and experiment with alternative tactics to succeed.\n\nLOOKING FOR THE FULL VERSION?\n- https://www.oculus.com/experiences/quest/7805743412834399/", "short_description": "Demo version of Towerport (3 levels available)\n\nA VR tower defense experience where you function as both general and soldier. As the newly appointed Sky Marshall you oversee the defense effort and take on the enemy with bow, zeppelin, and battle orbs! "}]}, "developer_name": null, "developer_privacy_policy