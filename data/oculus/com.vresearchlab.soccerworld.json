6_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QhafXYiIKhYQ7kNvgHkQJMv&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_r5hHpvoEdph0R0PDOKxeL&oh=00_AYDWk0v_96X4ls9XkjkIAiNRGiiloAMG2un8Vbh8shVMTA&oe=66F3FD3F"}, {"file_name": "cyt 41.png", "id": "1042648490328752", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223486_1042648493662085_7229067347458647589_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQhrZyezk5EQ7kNvgE3H_q-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_r5hHpvoEdph0R0PDOKxeL&oh=00_AYAjzNstutGKgw5fWbl1t1ocZGSuH4GtcfQyQ9KBG5SYKQ&oe=66F3E511"}, {"file_name": "image_038_0000.png", "id": "1212043653445829", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395591_1212043656779162_4025685345986081004_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Q4kWSGN18QQ7kNvgG7dgIP&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_r5hHpvoEdph0R0PDOKxeL&oh=00_AYC93obYlqPxzTGSIaWLiLcrmgJbrfDc9WFdHVN1qVAbgw&oe=66F40C1F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Soccer-World-Trailer-March-2023-V2_Moment.png", "id": "1633240867123590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_1633240870456923_3299241486666879826_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xo-bTH1sNiUQ7kNvgHsua2A&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_r5hHpvoEdph0R0PDOKxeL&oh=00_AYDlgZkVKkheEayMW-ofykq_NKif5jGRPoqnK7WluzmdPQ&oe=66F3EE73"}, "display_name": "Soccer World", "keywords": [], "long_description": "Master your goalkeeping skills with Soccer World\u2014your ultimate training tool! Whether you're aiming to improve or complement your outdoor practice, our immersive VR game brings pro-level training right to your headset.\n\n# TRAIN LIKE A PRO WITH OUR EXCLUSIVE TRAINING PLANS\nStep up your game with personalized Training Plans that mirror real-life scenarios like curved shots, low drives, and high-powered shots. Each plan is tailored to your needs, with customizable difficulty and daily training duration, so you can fit practice into your schedule.\n\n# PRECISION METRICS TO TRACK YOUR PROGRESS\nSoccer World provides high-precision tracking of your reaction speed, shots blocked, and movement speed\u2014metrics you won\u2019t get anywhere else. Watch your progress through detailed graphs and numbers that show your daily improvements and help you identify areas to strengthen.\n\n# PRO SCORE COMPARISON\nWant to know how you compare to the best? Your Pro Score shows how your skills stack up against real professional goalkeepers. Track your global score and compete with other players to push yourself even further!\n\n# QUICK DRILLS & ARCADE FUN\nJump into Individual Drills to focus on specific skills like blocking fast low shots or handling tricky curve balls. Or, switch to Arcade Mode for fun challenges like Goal Attack and Memory Game, perfect for keeping your reflexes sharp.\n\nReady to defend your goal? Download Soccer World now and start your journey!", "short_description": "Master your goalkeeping skills in Soccer World! Train like a pro with personalized Training Plans that cover real match scenarios, from powerful high shots to fast shots. Track your performance with precision metrics, including reaction speed and Pro Score comparisons to professional goalkeepers. Jump into Arcade Mode for fun challenges like Goal Attack and Memory Match. Free to play, fully customizable, and packed with immersive soccer action!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://www.vresearchlab.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connectio