at=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iv6gWlJyxkwQ7kNvgHdlCb4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQ_xLaac9uUdSWozcLVxLCy&oh=00_AYB2-pEmu-hP40JkoSt-hFkQrynD1ioYjUFfvrH3_2SkMQ&oe=66E57667"}, {"file_name": "Avatar.png", "id": "878778053423628", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001657_878778056756961_1921195467113134731_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KvmK3tWFo4sQ7kNvgFz8puq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQ_xLaac9uUdSWozcLVxLCy&oh=00_AYByPdT-rWGtT4fI9eqRYLXcuuy0CaOhWV-BDqo3UklPdg&oe=66E57D04"}, {"file_name": "Foosball-SS-1.png", "id": "6056201804461989", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974580_6056201807795322_7803567847767323694_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8p6sshpqfiUQ7kNvgEmpkWQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQ_xLaac9uUdSWozcLVxLCy&oh=00_AYCyMKkJT9nw1IEj__j8MLyPxrKXmFFF6rdEyjGfZMwp9w&oe=66E575B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Soccer-World-Trailer-March-2023-V2_Moment.png", "id": "1633240867123590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_1633240870456923_3299241486666879826_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nE69x9mfnWoQ7kNvgHFKqI8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQ_xLaac9uUdSWozcLVxLCy&oh=00_AYDGoeZZ_8FdnnOcuQyoAPbosaDWPu_9GcNMzc0cDxhAIg&oe=66E56DF3"}, "display_name": "Soccer World", "keywords": [], "long_description": "Welcome to the Soccer World VR Game experience! With two thrilling game modes, Sports Mode and Playground, our game promises an immersive journey that challenges your skills. \n\nSPORTS MODE:\n\nGOALKEEPER PRACTICE: Step into the goalie's shoes, defending the net from all angles. Dive and block shots to keep your opponent at bay!\n\nINFINITE MODE: Take on increasingly difficult shots, testing your reflexes and predicting skills. How high can you score before missing a shot?\n\nPLAYGROUND:\n\nGOAL ATTACK: Showcase your precision and quick reflexes as you shoot past obstacles, racking up points in this challenging game.\n\nFOOSBALL: Experience the classic tabletop game in virtual reality. Compete against the computer in a fast-paced match, using hand-eye coordination and strategic thinking to score.\n\nMEMORY: Engage your brainpower to remember and match various objects. With each level, the difficulty rises, demanding focus for a high score.\nWith different scenarios available and immersive gameplay, the Soccer World VR Game is the ultimate test of your skills. Brace yourself for the thrills of Compete Mode and the engaging challenges of Arcade Mode!\n\nYou\u2019ll have access for free to all experiences and if you like it, you can purchase the full version with all challenges. ", "short_description": "Welcome to the Soccer World VR Game experience! With two thrilling game modes, Sports Mode and Playground, our game promises an immersive journey that challenges your skills. Play as a goalie defending against increasingly difficult shots or play one of our many soccer-themed minigames!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://www.vresearchlab.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "82711892428