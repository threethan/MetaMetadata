nc_ohc=aCz4f7CHM_MQ7kNvgE8-kjI&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAA3mkZ7k8d2u_cmtjtl1tO_FTymunjdl4YfujOBqZoDw&oe=674083B3"}, {"file_name": "75443251_1698434823657563_580012992956978883_n.png", "id": "762115074431769", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75371506_762115077765102_4739356723719856490_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g1zOwWPC-q4Q7kNvgHZUtPH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAqqo5lvhX7jQxQaoJeLnFfmA3YQuqLTj1aqe1dx9uR2w&oe=67407A99"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape (2560x1440).png", "id": "492689858427362", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974648_492689861760695_1651259702864724545_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9J2ve-Z7Q3AQ7kNvgFCSd1w&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAPcIeEqyrxtLXdp_1NYfoxKT6_V8ZOtBkufPQtxyKFxQ&oe=67406EF2"}, "display_name": "Synth Riders Demo", "keywords": [], "long_description": "Synth Riders Demo will no longer be supported on Meta Quest devices and new users will no longer be able to search & install this app. If you already \"own\" this entitlement, you will continue to have access.\n\n---------\n\nA FREESTYLE-DANCE RHYTHM ALTERNATIVE\n\nCUSTOM SONGS officially supported - never breaks with an update\nGOOD FITNESS - activates whole body without repetitive movements\nGREAT MUSIC \u2013 74 free and 67 DLC songs from Gorillaz, Muse & more\n\nIn the demo, you can play 7 songs on all difficulty levels and experiment with all the modifiers - unlimited!\n\nThe full version of Synth Riders is available on the Meta Quest Store featuring:\n\n\u2022 135 Songs - 74 free and 67 DLC, including Gorillaz, Muse, Caravan Palace, The Offspring and more!\n\u2022 Official Custom Song Support\n\u2022 Cross-Platform Multiplayer\n\u2022 360\u00b0 Spin Mode in Every Song\n\u2022 Party mode - local multiplayer\n\nWe hope you will enjoy the demo and join the Synth Riders community soon!", "short_description": "Synth Riders Demo will no longer be supported on Meta Quest devices and new users will no longer be able to search & install this app. If you already \"own\" this entitlement, you will continue to have access.\n\n---------\n\nWelcome to the demo of Synth Riders - a freestyle dancing VR rhythm alternative. The demo comes with 5 songs on all difficulty levels with all the modifiers!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://synthridersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Kluge Interactive", "support_website_url": "https://synthridersvr.com/contact-us/", "website_url": "https://www.synthridersvr.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7672301819505121"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031356_1688611468007565_1333122296219517372_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QTUjc2msEfkQ7kNvgFSXAM_&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAxqZ5p6oMCmXDyIvtVz-H7ub4d54Fshj_rIXlXjIZBrg&oe=674081B5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Synth Riders Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1616199529, "lastRevision": {"nodes": [{"id": "1204279086635396", "release_type": "SCHEDULED"