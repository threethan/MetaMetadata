/v/t64.5771-25/75324645_1007348640480509_5200006446549011088_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=52buKimlLI0Q7kNvgEnyjdv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD86CNFW4zDdXgl7p-xPM0BYoB2wpc4CEUraeAhykltJQ&oe=677A89BD"}, {"file_name": "1008x1440 Cover.png", "id": "314057404744113", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207243_314057408077446_4304738864558194891_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y57uNZ0jnDYQ7kNvgEuK1Jb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbu8WdPk92t3Fcf7MDQX9ZukeAd8oopPFZZNbSPkugbA&oe=677A5C42"}, {"file_name": "Cricket X Icon 512x512.png", "id": "301425529484261", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031373_301425532817594_3650731344652652407_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qu_5x7TSfT0Q7kNvgEFQDjg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCfmlicbs3aYw3dhsO6VwYzSg5ewvoNRiI7_LG3fs_hhA&oe=677A6B7C"}, {"file_name": "1080x360 Cover.png", "id": "258684686788766", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974691_258684690122099_2633354679438812701_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vkPb6IvTAAQQ7kNvgGLAx7c&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHZDZawDhlIajg0RP3ia021pe5AWDN8xXz5ZY1M9btFQ&oe=677A6685"}]}, "id": "395203239690683", "locale": "en_US", "screenshots": [{"file_name": "Cricket X Screenshot 1.png", "id": "450819861214131", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568725_450819864547464_2038582010610644382_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Twl9iYGP7FkQ7kNvgHNEk69&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAXepZ-jC600Fxvokbx6hrIL35Fb3o9I65uHLuai7PtZA&oe=677A87F4"}, {"file_name": "Cricket X Screenshot 4.png", "id": "314068445006679", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001676_314068448340012_6227481545496341750_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bqkmXVBhoIkQ7kNvgH1yzZw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzu1ZK-CXeCzxUNxBr31zriSe0lrschm0upcwpMp-rXA&oe=677A7F1B"}, {"file_name": "Cricket X Screenshot 2.png", "id": "1523194464928537", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86616644_1523194468261870_8606475524555149201_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aPc2cqxu8_4Q7kNvgGnEzX1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9GJkK7S4bfBj1S409C3ST38Ss3Lh15Rh10WnCLjcQNA&oe=677A7867"}, {"file_name": "Cricket X Screenshot 3.png", "id": "813031630542509", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476598_813031633875842_8138021581861231288_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wTWncNdv9a8Q7kNvgHSdesa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRHh-cRh6e2ri-cLCgq-GKdnTf6QTvUJ_SweIuMh1aSQ&oe=677A5559"}, {"file_name": "Cricket X Screenshot 5.png", "id": "445873261671966", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476754_445873265005299_3973631504296513136_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w2B9jKT6aZQQ7kNvgFX9LSk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOiix6LmuMnePdQtCkO1_0wpSOJKLPp5kwf_F5airniQ&oe=677A6D2B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cricket X", "keywords": [], "long_description": "Cricket X: The Ultimate VR Cricket Simulator\n\nStep into the immersive world of cricket like never before with Cricket X, the premier VR cricket simulator that brings the excitement of the pitch to your fingertips. Experience the thrill of chasing down targets in a hyper-realistic environment, designed to make you feel like you're right in the heart of the action.\n\nKey Features:\n\nRealistic Physics: Enjoy true-to-life ball dynamics and player movements, capturing the essence of real cricket.\nChase Mode: Face the ultimate challenge of chasing down thrilling targets, with the ability to set your preferred score, number of overs, and wickets.\nInteractive Gameplay: Play with a controller or attach it to a real bat for an unparalleled immersive experience.\nDetailed Analytics: Gain insights into your performance with comprehensive analytics, helping you refine your skills and strategy.\nIconic Venues: Take to the field in meticulously recreated stadiums, starting with the legendary Qaddafi Stadium.\n\nCricket X is more than a game\u2014it's your gateway to the ultimate cricket experience. Whether you're a seasoned pro or a budding enthusiast, Cricket X will have you hooked from the first ball to the last run.", "short_description": "A Virtual Reality Cricket Simulator game with realistic physics where you can chase thrilling targets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xrevstudiopk.blogspot.com/2023/08/xrev-studio.html", "developer_terms_of_service_url": null, "publisher_name": "Xrev Studio", "support_website_url": null, "website_url": "https://xrevstudio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8027302137349656"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "498386349624923"}, {"status": "PUBLISHED", "id": "1179304823327784"}, {"status": "PUBLISHED", "id": "1170911294051909"}]}, "baseline_offer": {"id": "498386349624923"}, "is_approved": true, "firstOffer"