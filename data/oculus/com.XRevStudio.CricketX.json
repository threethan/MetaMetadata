gFZZ6n8&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAUmP10j2_4xGFXjhCPolSncKZxabil1NdobqkT-SdbVw&oe=6724D674"}, {"file_name": "Cricket X Screenshot 4.png", "id": "314068445006679", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001676_314068448340012_6227481545496341750_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6iteSz19ZsUQ7kNvgFnH930&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAn3pdCkE0DI2Am4jMtNRkBLBNqcRKtPlOnAAQiLoHuqw&oe=6724CD9B"}, {"file_name": "Cricket X Screenshot 2.png", "id": "1523194464928537", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86616644_1523194468261870_8606475524555149201_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hSed915-WdgQ7kNvgGO7rp7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBoCkaqzz4KVAPZQreh-5K59XJjOjbPMr4zkZxRcmbWug&oe=6724C6E7"}, {"file_name": "Cricket X Screenshot 3.png", "id": "813031630542509", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75476598_813031633875842_8138021581861231288_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l-c3dWRcmY0Q7kNvgErxqu2&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAuiKmgCi2WQXAEl3-Pkp5K3iqqNrCVpFInGPD-FL8dLg&oe=6724A3D9"}, {"file_name": "Cricket X Screenshot 5.png", "id": "445873261671966", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75476754_445873265005299_3973631504296513136_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nNBEr3iqdZsQ7kNvgFDFXKv&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBW45akBhJDy7n7KHadeyQRE7_-y-8ZFGKqirxd5QTqUw&oe=6724BBAB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cricket X", "keywords": [], "long_description": "Cricket X: The Ultimate VR Cricket Simulator\n\nStep into the immersive world of cricket like never before with Cricket X, the premier VR cricket simulator that brings the excitement of the pitch to your fingertips. Experience the thrill of chasing down targets in a hyper-realistic environment, designed to make you feel like you're right in the heart of the action.\n\nKey Features:\n\nRealistic Physics: Enjoy true-to-life ball dynamics and player movements, capturing the essence of real cricket.\nChase Mode: Face the ultimate challenge of chasing down thrilling targets, with the ability to set your preferred score, number of overs, and wickets.\nInteractive Gameplay: Play with a controller or attach it to a real bat for an unparalleled immersive experience.\nDetailed Analytics: Gain insights into your performance with comprehensive analytics, helping you refine your skills and strategy.\nIconic Venues: Take to the field in meticulously recreated stadiums, starting with the legendary Qaddafi Stadium.\n\nCricket X is more than a game\u2014it's your gateway to the ultimate cricket experience. Whether you're a seasoned pro or a budding enthusiast, Cricket X will have you hooked from the first ball to the last run.", "short_description": "A Virtual Reality Cricket Simulator game with realistic physics where you can chase thrilling targets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xrevstudiopk.blogspot.com/2023/08/xrev-studio.html", "developer_terms_of_service_url": null, "publisher_name": "Xrev Studio", "support_website_url": null, "website_url": "https://xrevstudio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8027302137349656"}}]}, "s