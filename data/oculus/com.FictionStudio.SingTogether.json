218 \uc788\uc73c\uba70, \uacc4\uc18d\ud574\uc11c \uc0c8\ub85c\uc6b4 \uace1\ub4e4\uc774 \ucd94\uac00\ub429\ub2c8\ub2e4.\n\n[\uc74c\uc545\uc744 \ud1b5\ud55c \uc5f0\uacb0]\n\ud63c\uc790 \uc990\uae30\ub294 \uac83\ubfd0\ub9cc \uc544\ub2c8\ub77c \uba40\ud2f0\ud50c\ub808\uc774\uc640 \uc18c\uc15c \uc0c1\ud638\uc791\uc6a9\uc744 \ud1b5\ud574 \uc0c8\ub85c\uc6b4 \uce5c\uad6c\ub4e4\uacfc \uc5f0\uacb0\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc9c0\uad6c\uc5d0\uc11c \uac00\uc7a5 \ud070 \ub178\ub798\ubc29\uc5d0\uc11c \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694!", "short_description": "\uc2f1\ub8f8(SingRoom)\uc740 VR \uc18c\uc15c \ub178\ub798\ubc29\uc785\ub2c8\ub2e4.\n\ud63c\uc790 \ub610\ub294 \ud568\uaed8 \uba4b\uc9c4 \uacf5\uac04\uc5d0\uc11c \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \uc990\uae38 \uc218 \uc788\uc5b4\uc694!\n\uc9c0\uad6c\uc5d0\uc11c \uac00\uc7a5 \ud070 \ub178\ub798\ubc29\uc5d0\uc11c \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694!"}, {"images": {"nodes": [{"file_name": "Logo_W.png", "id": "2037009236758399", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_2037009240091732_6274024698972295157_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tY6CjheAYu8Q7kNvgGw06lu&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6iMQhKbFtr1sGAV9vlR8ky&oh=00_AYDmd4W7wX3vBlOxxXm781LXJ7V2GA671dq1pSlpn4gxyg&oe=66DC3FEF"}, {"file_name": "Mobile Icon_512x512.png", "id": "1662144754347109", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570306_1662144757680442_3047029859871833100_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k2lQrQT5uO8Q7kNvgH-VsM5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6iMQhKbFtr1sGAV9vlR8ky&oh=00_AYD7ibMIM0UwzIhDkzszQNijR86Syhv45Ppx6zGdlVTc3g&oe=66DC3DCF"}, {"file_name": "Landscape_2560x1440.png", "id": "1455643215096373", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_1455643218429706_4847338792641025967_