dn.com/v/t64.5771-25/38974700_1164856628125617_7258642273874214950_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K4KQkLi_Re0Q7kNvgE4NEV_&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBGFxoMzR4qvCuK7RFNC-7HbEOQBCaNzTd4gABoSHJ0EA&oe=67027BA0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image (12).png", "id": "526812856511693", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57568673_526812859845026_2971041064871438978_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U4Yb4FLpexgQ7kNvgH1zrD8&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAk-5qOIa1KdQ_1SYsMT4nBCmvp9p24xxfFonAja62rRg&oe=6702630E"}, "display_name": "SingRoom - \uc18c\uc15c \ub178\ub798\ubc29", "keywords": [], "long_description": "\uc2f1\ub8f8(SingRoom)\uc740 VR \uc18c\uc15c \ub178\ub798\ubc29\uc785\ub2c8\ub2e4.\n\ud63c\uc790 \ub610\ub294 \ud568\uaed8 \uba4b\uc9c4 \uacf5\uac04\uc5d0\uc11c \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \uc990\uae38 \uc218 \uc788\uc5b4\uc694!\n\n[\ub178\ub798 \ubd80\ub974\uae30 \uc88b\uc740 \uba4b\uc9c4 \uacf5\uac04]\n\ud604\uc2e4 \uacf5\uac04 \uc7ac\ud604\ubd80\ud130 \uac00\uc0c1\uc758 \uacf5\uac04\uae4c\uc9c0, \ub178\ub798 \ubd80\ub974\uae30 \uc88b\uc740 \uacf5\uac04\uc744 \uacbd\ud5d8\ud560 \uc218 \uc788\uc5b4\uc694\n\n[\ub9c8\uc774\ud06c \ud6a8\uacfc \ub4f1 \ub178\ub798\ubc29 \uae30\ub2a5]\n\uc5d0\ucf54 \ub4f1 \ub9c8\uc774\ud06c \ud6a8\uacfc\ub4e4\uacfc \ub178\ub798\ubc29 \uae30\ub2a5\uc73c\ub85c \ub2e4\uc591\ud558\uac8c \uc990\uae38 \uc218 \uc788\uc5b4\uc694\n\n[\ub2e4\uc591\ud55c \ub178\ub798]\n\uce5c\uc219\ud55c \uace1\ubd80\ud130 \uc0c8\ub85c\uc6b4 \uace1\uae4c\uc9c0 \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \ubd80\ub97c \uc218 \uc788\uc73c\uba70, \uacc4\uc18d\ud574\uc11c \uc0c8\ub85c\uc6b4 \uace1\ub4e4\uc774 \ucd94\uac00\ub429\ub2c8\ub2e4.\n\n[\uc74c\uc545\uc744 \ud1b5\ud55c \uc5f0\uacb0]\n\ud63c\uc790 \uc990\uae30\ub294 \uac83\ubfd0\ub9cc \uc544\ub2c8\ub77c \uba40\ud2f0\ud50c\ub808\uc774\uc640 \uc18c\uc15c \uc0c1\ud638\uc791\uc6a9\uc744 \ud1b5\ud574 \uc0c8\ub85c\uc6b4 \uce5c\uad6c\ub4e4\uacfc \uc5f0\uacb0\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc74c\uc545\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c XR \uc5d4\ud130\ud14c\uc778\uba3c\ud2b8\uc5d0\uc11c \uacf5\uc5f0\uc744 \uc2dc\uc791\ud558\uace0 \ucd94\uc5b5\uc744 \ub9cc\ub4dc\uc138\uc694!", "short_description": "\uc2f1\ub8f8(SingRoom)\uc740 VR \uc18c\uc15c \ub178\ub798\ubc29\uc785\ub2c8\ub2e4.\n\ud63c\uc790 \ub610\ub294 \ud568\uaed8 \uba4b\uc9c4 \uacf5\uac04\uc5d0\uc11c \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \uc990\uae38 \uc218 \uc788\uc5b4\uc694!\n\uc74c\uc545\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c XR \uc5d4\ud130\ud14c\uc778\uba3c\ud2b8\uc5d0\uc11c \uacf5\uc5f0\uc744 \uc2dc\uc791\ud558\uace0 \ucd94\uc5b5\uc744 \ub9cc\ub4dc\uc138\uc694!"}, {"images": {"nodes": [{"file_name": "Square_1440x1440.png", "id": "3699045017020782", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031434_3699045020354115_910938296252219971_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1LobJqueYikQ7kNvgE0W58X&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYA5mArKVfoxZ9eS5-KaKRag2_mXEIl3WTOqQAKIwWtUsg&oe=6702879E"}, {"file_name": "Hero_3000x900.png", "id": "3322640134707100", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035456_3322640138040433_8133699819728704442_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gQq3CYNpk9EQ7kNvgFoVpFY&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD80xUU-k-c_dBGhHjwEyPWWfyiM4ThmN5d5wW9Gg4bVw&oe=670290C0"}, {"file_name": "Mobile Icon_512x512.png", "id": "2207549399630250", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974561_2207549402963583_8485899512184601559_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7PhNTbcUgg4Q7kNvgGjvjjl&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDAqWDde0rJpDXCfvJdbfzkZhyYhHnN101UUJSPjdmkwg&oe=67028B96"}, {"file_name": "Mini_1080x360.png", "id": "473238462085070", "i