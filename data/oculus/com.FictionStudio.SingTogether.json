-7&_nc_sid=6e7a0a&_nc_ohc=RFiq6hiIJtAQ7kNvgHEGTvR&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8xQ2Ro38FLPRAer2ACcKHQlgF9Xtm-VITOxjsvwHXBA&oe=66E2E00D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tailer-cover.png", "id": "3401014840198368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388619_3401014843531701_901436449177248655_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ibqbP_X6YUQ7kNvgEAoy01&_nc_ht=scontent.oculuscdn.com&oh=00_AYDml4PeXOuzuwY1mMBOY6VOvtDpL7hfhTb4gmnjeZgSow&oe=66E2CC6D"}, "display_name": "SingRoom - Social Karaoke", "keywords": [], "long_description": "SingRoom is a VR social karaoke experience.\nEnjoy your favorite songs in an amazing space, alone or together!\n\n[Great Spaces for Singing]\nFrom realistic recreations to fantastical virtual environments, experience spaces that are perfect for singing.\n\n[Karaoke Features like Microphone Effects]\nEnjoy a variety of fun with echo and other microphone effects and karaoke functions.\n\n[A Wide Selection of Songs]\nFrom familiar tunes to new tracks, sing your favorite songs, with new songs added continuously.\n\n[Connecting Through Music]\nEnjoy music solo or engage in multiplayer and social interactions, connecting with new friends through music.\n\nStart your performance and create memories with XR entertainment centered around music", "short_description": "SingRoom is a VR social karaoke.\nEnjoy your favorite songs alone or together in stunning spaces!\nStart your performance and create memories with XR entertainment centered around music"}]}, "developer_name": "StasisField", "developer_privacy_policy_url": "https://www.singroom.com/privacypolicy", "developer_terms_of_service_url": "https://www.singroom.com/termsofservice", "publisher_name": "StasisField", "support_website_url": null, "website_url": "https://www.singroom.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "co