cdn.com&oh=00_AYAzGgOfHW7XbzbOM4P_IakQea66lJlvoNhJayE2qCkLrg&oe=66F006A0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tailer-cover.png", "id": "1081942659946269", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75280981_1081942663279602_731022313695504107_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QW91ngPxE10Q7kNvgG-MaBt&_nc_ht=scontent.oculuscdn.com&oh=00_AYA52r9ZrlG5Qb1G0BLzdAYIo2GE8YcYxonXEKcGxNU9cg&oe=66F019AA"}, "display_name": "SingRoom - \uc18c\uc15c \ub178\ub798\ubc29", "keywords": [], "long_description": "\uc2f1\ub8f8(SingRoom)\uc740 VR \uc18c\uc15c \ub178\ub798\ubc29\uc785\ub2c8\ub2e4.\n\ud63c\uc790 \ub610\ub294 \ud568\uaed8 \uba4b\uc9c4 \uacf5\uac04\uc5d0\uc11c \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \uc990\uae38 \uc218 \uc788\uc5b4\uc694!\n\n[\ub178\ub798 \ubd80\ub974\uae30 \uc88b\uc740 \uba4b\uc9c4 \uacf5\uac04]\n\ud604\uc2e4 \uacf5\uac04 \uc7ac\ud604\ubd80\ud130 \uac00\uc0c1\uc758 \uacf5\uac04\uae4c\uc9c0, \ub178\ub798 \ubd80\ub974\uae30 \uc88b\uc740 \uacf5\uac04\uc744 \uacbd\ud5d8\ud560 \uc218 \uc788\uc5b4\uc694\n\n[\ub9c8\uc774\ud06c \ud6a8\uacfc \ub4f1 \ub178\ub798\ubc29 \uae30\ub2a5]\n\uc5d0\ucf54 \ub4f1 \ub9c8\uc774\ud06c \ud6a8\uacfc\ub4e4\uacfc \ub178\ub798\ubc29 \uae30\ub2a5\uc73c\ub85c \ub2e4\uc591\ud558\uac8c \uc990\uae38 \uc218 \uc788\uc5b4\uc694\n\n[\ub2e4\uc591\ud55c \ub178\ub798]\n\uce5c\uc219\ud55c \uace1\ubd80\ud130 \uc0c8\ub85c\uc6b4 \uace1\uae4c\uc9c0 \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \ubd80\ub97c \uc218 \uc788\uc73c\uba70, \uacc4\uc18d\ud574\uc11c \uc0c8\ub85c\uc6b4 \uace1\ub4e4\uc774 \ucd94\uac00\ub429\ub2c8\ub2e4.\n\n[\uc74c\uc545\uc744 \ud1b5\ud55c \uc5f0\uacb0]\n\ud63c\uc790 \uc990\uae30\ub294 \uac83\ubfd0\ub9cc \uc544\ub2c8\ub77c \uba40\ud2f0\ud50c\ub808\uc774\uc640 \uc18c\uc15c \uc0c1\ud638\uc791\uc6a9\uc744 \ud1b5\ud574 \uc0c8\ub85c\uc6b4 \uce5c\uad6c\ub4e4\uacfc \uc5f0\uacb0\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc74c\uc545\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c XR \uc5d4\ud130\ud14c\uc778\uba3c\ud2b8\uc5d0\uc11c \uacf5\uc5f0\uc744 \uc2dc\uc791\ud558\uace0 \ucd94\uc5b5\uc744 \ub9cc\ub4dc\uc138\uc694!", "short_description": "\uc2f1\ub8f8(SingRoom)\uc740 VR \uc18c\uc15c \ub178\ub798\ubc29\uc785\ub2c8\ub2e4.\n\ud63c\uc790 \ub610\ub294 \ud568\uaed8 \uba4b\uc9c4 \uacf5\uac04\uc5d0\uc11c \uc88b\uc544\ud558\ub294 \ub178\ub798\ub97c \uc990\uae38 \uc218 \uc788\uc5b4\uc694!\n\uc74c\uc545\uc744 \uc911\uc2ec\uc73c\ub85c \ud55c XR \uc5d4\ud130\ud14c\uc778\uba3c\ud2b8\uc5d0\uc11c \uacf5\uc5f0\uc744 \uc2dc\uc791\ud558\uace0 \ucd94\uc5b5\uc744 \ub9cc\ub4dc\uc138\uc694!"}, {"images": {"nodes": [{"file_name": "Logo_W.png", "id": "2037009236758399", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_2037009240091732_6274024698972295157_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=avvUhaVZbjMQ7kNvgHHukD_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiqDqsMBNEOrzr1fz69cRG2A52DoQbHnsZQbuoroWUfw&oe=66F0066F"}, {"file_name": "Mobile Icon_512x512.png", "id": "1662144754347109", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570306_1662144757680442_3047029859871833100_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ePNoUeJEvygQ7kNvgEz7Gvs&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKE7po2Wa1F7VS-7VUjQtunc1grVZ9hHDNqkmfqywf4Q&oe=66F0044F"}, {"file_name": "Landscape_2560x1440.png", "id": "1455643215096373", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_1455643218429706_4847338792641025967_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wHZG8dJQpwoQ7kNvgG9bJIf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIqBIhinQHkehdDNTj1t9bscsWPWoz_A6tvHfqfQOwaA&oe=66EFFE74"}, {"file_name": "Portrait_1008x1440.png", "id": "526393913280535", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031624_526393916613868_106861051659656797_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s3SaC5bD5ZgQ7kNvgGKSB