scdn.com&oh=00_AYAjdwm1-HvV9vsC6vC3j8dJSdHQk_cwahg8GIn-ZNBE1w&oe=66D5B10D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tailer-cover.png", "id": "3401014840198368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388619_3401014843531701_901436449177248655_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aM7pds5mYYoQ7kNvgEavEOe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBrUnXmQBplsXP_ColSVk8T1yzjITbeB1dTic3z9dUQvQ&oe=66D59D6D"}, "display_name": "SingRoom (Global Beta)", "keywords": [], "long_description": "SingRoom is a VR social karaoke experience.\nEnjoy your favorite songs in an amazing space, alone or together!\n\n[Great Spaces for Singing]\nFrom realistic recreations to fantastical virtual environments, experience spaces that are perfect for singing.\n\n[Karaoke Features like Microphone Effects]\nEnjoy a variety of fun with echo and other microphone effects and karaoke functions.\n\n[A Wide Selection of Songs]\nFrom familiar tunes to new tracks, sing your favorite songs, with new songs added continuously.\n\n[Connecting Through Music]\nEnjoy music solo or engage in multiplayer and social interactions, connecting with new friends through music.\n\nStart your performance and create memories in Earth's Biggest Karaoke!", "short_description": "SingRoom is a VR social karaoke.\nEnjoy your favorite songs alone or together in stunning spaces!\nCreate memories in Earth's Biggest Karaoke!"}, {"images": {"nodes": [{"file_name": "Mobile Icon_512x512.png", "id": "1532567051000297", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031454_1532567054333630_1075922125802443888_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vnOIood5X00Q7kNvgEBSYcx&_nc_ht=scontent.oculuscdn.com&oh=00_AYDy8MFj-qjYssBDQS_MjtlVSzhnZLLTfvvjO_XQfxqrug&oe=66D5B96D"}, {"file_name": "Landscape_2560x1440.png", "id": "1500385397254399", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974802_150038