luscdn.com/v/t64.5771-25/39003285_2878827818939368_2498813927561401326_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=22IImJa3_7wQ7kNvgGYUfah&_nc_ht=scontent.oculuscdn.com&oh=00_AYABjHm1YWgiT6oKv5qy-YS1zvmmFqAkPOL2OJO4Z8tddg&oe=66FE94F4"}, {"file_name": "image (10).png", "id": "1062448355495236", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974577_1062448358828569_2693241330333797358_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRrdcyEVJl8Q7kNvgHJFf2H&_nc_ht=scontent.oculuscdn.com&oh=00_AYByI7jz9yYKylvQHfbcqYah1NAf1oVCKIvczs82rRIvrw&oe=66FE8FFA"}, {"file_name": "image (2).png", "id": "460310300297940", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031634_460310303631273_6153160145890889644_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GIMAbVnhqlQQ7kNvgGpGaUV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVgiSQL_St_Ks_udbGPJtd8kAZ9zy7XkpQhOVmj3G_eA&oe=66FE8F8D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image (12).png", "id": "523026330378213", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974859_523026333711546_8017864695105220869_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4IQk8104D-wQ7kNvgGKToh5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZgc72YqFwAObD-T55gUgDPivu1NIHHv71RW1OvIVAxQ&oe=66FE7D73"}, "display_name": "SingRoom - Social Karaoke", "keywords": [], "long_description": "SingRoom is a VR social karaoke experience.\nEnjoy your favorite songs in an amazing space, alone or together!\n\n[Great Spaces for Singing]\nFrom realistic recreations to fantastical virtual environments, experience spaces that are perfect for singing.\n\n[Karaoke Features like Microphone Effects]\nEnjoy a variety of fun with echo and other microphone effects and karaoke functions.\n\n[A Wide Selection of Songs]\nFrom familiar tunes to new tracks, sing your favorite songs, with new songs added continuously.\n\n[Connecting Through Music]\nEnjoy music solo or engage in multiplayer and social interactions, connecting with new friends throug