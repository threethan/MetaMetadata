scdn.com&oh=00_AYA83zKkixg89nqxk4wdm-XHyip1DBo-YUsqrSRHDwtdxA&oe=66CF198D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tailer-cover.png", "id": "3401014840198368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388619_3401014843531701_901436449177248655_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7t6Ajd31oigQ7kNvgGoNEfa&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7MeoS8QkohYg2fAMVdBOoLujnUIaVLr1KMqZ7ZDWmsQ&oe=66CF05ED"}, "display_name": "SingRoom (Global Beta)", "keywords": [], "long_description": "SingRoom is a VR social karaoke experience.\nEnjoy your favorite songs in an amazing space, alone or together!\n\n[Great Spaces for Singing]\nFrom realistic recreations to fantastical virtual environments, experience spaces that are perfect for singing.\n\n[Karaoke Features like Microphone Effects]\nEnjoy a variety of fun with echo and other microphone effects and karaoke functions.\n\n[A Wide Selection of Songs]\nFrom familiar tunes to new tracks, sing your favorite songs, with new songs added continuously.\n\n[Connecting Through Music]\nEnjoy music solo or engage in multiplayer and social interactions, connecting with new friends through music.\n\nStart your performance and create memories in Earth's Biggest Karaoke!", "short_description": "SingRoom is a VR social karaoke.\nEnjoy your favorite songs alone or together in stunning spaces!\nCreate memories in Earth's Biggest Karaoke!"}, {"images": {"nodes": [{"file_name": "Mobile Icon_512x512.png", "id": "1532567051000297", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031454_1532567054333630_1075922125802443888_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KqrvTr86QZ8Q7kNvgGYumaN&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnKzKJ08lFsSRwTipdPWWYPznv0uwpgYFRzf_1g_2_sg&oe=66CF21ED"}, {"file_name": "Landscape_2560x1440.png", "id": "1500385397254399", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974802_150038