=676FE548"}, {"file_name": "migrated_image.png", "id": "510190883204066", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982617_446618022617189_8062851992071962624_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Mu7RvJDc2kQ7kNvgEAGAvz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_E7VZul1ZJUiooAnD5kL6IbPPLuYawyKj5hLjzjBn2g&oe=676FEE6F"}, {"file_name": "migrated_image.png", "id": "149798582941257", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_1595889477209275_4997468884421312512_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MhUR8MaSCfsQ7kNvgFrp7E8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDiy8jROpNVdaeHWN_u-R9zsF3snNILxo9pUZCXYMMSDg&oe=676FFE14"}, {"file_name": "migrated_image.png", "id": "1559492570865052", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974861_2481287701938145_3363924480509345792_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHLVA2aW07kQ7kNvgHbCd9J&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMeZ2OYNGB_ippaM8e3rC1hxmv6VbAKvJtGNFPszL2cg&oe=676FDC11"}, {"file_name": "migrated_image.png", "id": "2648037355431063", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031377_447246322540721_3617549622257385472_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6rGTMHWj8ToQ7kNvgGrAR68&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBBabv1Mjl_kDfZprfr57YHE-znLCC8y3DAbDfOb56npQ&oe=676FFAC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/hlUVc9", "id": "954000998283676", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974680_954001001617009_1289459064702500864_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rFx0yNWEVp4Q7kNvgF-UFNX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_OP_c_w7NZq-sXSsqyllxRTNEHRrdG3kx6xV2s5rcXg&oe=676FD89B"}, "display_name": "Pistol Whip", "keywords": ["pistol", "whip", "beat", "superhot", "audica"], "long_description": "CROSSBUY ENABLED.\n\nInspired by God-mode action movies like John Wick and Equilibrium, Pistol Whip puts you gun-first through an explosive batch of hand-crafted action sequences each set to their own pulse-pounding soundtrack. But unlike traditional music games, Pistol Whip has no line in the sand; you have complete freedom to shoot, melee, and dodge targets to the rhythm YOU see fit.\n\n\u2022 Pair the pulse-pounding pace of an FPS with the flow-state energy of a music game in a cinematic symphony of violence.\n\n\u2022 Form your rhythm and find your playstyle, from tactical to musical, then challenge your skill with friends and world leaderboards.\n\n\u2022 Infiltrate a fever dream of hand-crafted sequences, from bank heists to android uprisings, each uniquely designed to music.\n\n\u2022 Featuring EDM artists from Kannibalen Records, including Apashe, HVDES, and Black Tiger Sex Machine; with more to come...", "short_description": "Pistol Whip is an unstoppable action-rhythm FPS. Journey through a cinematic bullet hell powered by a breakneck soundtrack to become the ultimate action hero legend."}]}, "developer_name": "Cloudhead Games, Ltd.", "developer_privacy_policy_url": "http://cloudheadgames.com/privacy-policy/", "developer_terms_of_service_url": "http://cloudheadgames.com/eula/", "publisher_name": "Cloudhead Games, Ltd.", "support_website_url": null, "website_url": "http://cloudheadgames.com/pistolwhip/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1672577396871977"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supporte