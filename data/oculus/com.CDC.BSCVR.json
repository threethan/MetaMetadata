yt47zw&oe=66FA890A"}, {"file_name": "Screenshot6.png", "id": "382177290175526", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_382177293508859_4158422507920947771_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RPVTISuIZnAQ7kNvgGggALz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUF66Z0xOLQXyQ0EDd659iysyxaNmuPNSSTQR8kkDgRg&oe=66FA7CF5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "640897637257915", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_640897640591248_3726570399134143249_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EguHpiFEIRwQ7kNvgG8ZSKE&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKUfTfK9bLbmT6dlSN7TcjwOOTuknFjQazgnt8ZarpyQ&oe=66FA819A"}, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "keywords": [], "long_description": "Step into a virtual laboratory and learn how to work safely in the first-ever Centers for Disease Control and Prevention\u2019s (CDC) virtual reality (VR) laboratory training course. This course enables learners to apply knowledge and practice setting up a biosafety cabinet (also known as a biological safety cabinet, or BSC) in a virtual laboratory in order to identify the major parts, demonstrate how to maintain positive airflow, demonstrate how to prepare for work, apply safe-work practices, demonstrate how to decontaminate and shutdown, and conduct emergency shutdown procedures of a Class II Biosafety Cabinet. This course is developed for laboratory professionals and supplements the existing CDC eLearning course on the same topic found on the CDC LabTraining page.", "short_description": "LabTrainingVR: Biosafety Cabinet Edition course enables learners to apply knowledge and practice setting up and working in a biological safety cabinet (BSC) in a virtual laboratory."}]}, "developer_name": "Centers for Disease Control and Prevention", "developer_privacy_policy_url": "https://www.cdc.gov/labtraining/training-courses/VR_Training_Privacy_Policy_Page.html",