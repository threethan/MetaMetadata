&oe=66EFE3C7"}, {"file_name": "Screenshot5.png", "id": "898116627571706", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035393_898116630905039_506864153412416018_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6XS6Z08d-2QQ7kNvgF71Nn7&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADJIAlKZa_7q5tSqaaJ6aGv&oh=00_AYCy877e6dtwPNgpeNJqVe7NFkRXQUu-MmKEpYakXUp3xw&oe=66EFFD0A"}, {"file_name": "Screenshot6.png", "id": "382177290175526", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_382177293508859_4158422507920947771_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQLngVJmJjMQ7kNvgH7r1Mk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADJIAlKZa_7q5tSqaaJ6aGv&oh=00_AYDO_yU1m4itPTlhVLpnedm5Djo9jAxCRrpMqETsfuAJJQ&oe=66EFF0F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "640897637257915", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_640897640591248_3726570399134143249_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6gVIuF2PpsQ7kNvgGAry7d&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADJIAlKZa_7q5tSqaaJ6aGv&oh=00_AYBabVRJHf28WFhHUnw71qcWeymS539dNk1LcxDTVbek4A&oe=66EFF59A"}, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "keywords": [], "long_description": "Step into a virtual laboratory and learn how to work safely in the first-ever Centers for Disease Control and Prevention\u2019s (CDC) virtual reality (VR) laboratory training course. This course enables learners to apply knowledge and practice setting up a biosafety cabinet (also known as a biological safety cabinet, or BSC) in a virtual laboratory in order to identify the major parts, demonstrate how to maintain positive airflow, demonstrate how to prepare for work, apply safe-work practices, demonstrate how to decontaminate and shutdown, and conduct emergency shutdown procedures of a Class II Biosafety Cabinet. This course is developed for laboratory professionals and supplements the existing CDC eLearning course on the same topic found on the CDC LabTraining page.", "short_description": "LabTrainingVR: Biosafety Cabinet Edition course enables learners to apply knowledge and practice setting up and working in a biological safety cabinet (BSC) in a virtual laboratory."}]}, "developer_name": "Centers for Disease Control and Prevention", "developer_privacy_policy_url": "https://www.cdc.gov/labtraining/training-courses/VR_Training_Privacy_Policy_Page.html", "developer_terms_of_service_url": null, "publisher_name": "Centers for Disease Control and Prevention", "support_website_url": null, "website_url": "https://www.cdc.gov/labtraining", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "554692686266707"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982532_315552120449196_7761963953066735625_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bP5a-z2XCKAQ7kNvgHc7pqh&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADJIAlKZa_7q5tSqaaJ6aGv&oh=00_AYD0hnYmZ6lAnZQtQbPEXIXj9B6yXqtPz4fKrfM6mAka7g&oe=66F01890"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1649960458, "lastRevision": {"nodes": [{"id": "468455888031932", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_m