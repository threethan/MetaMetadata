87"}, {"file_name": "Screenshot5.png", "id": "898116627571706", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035393_898116630905039_506864153412416018_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=el4VyrRu7ukQ7kNvgFeGdpk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgyS7tbnBhm_rM-o1g3FwT2e7G2XaL9U8fzS_xcGCSPw&oe=6735DC8A"}, {"file_name": "Screenshot6.png", "id": "382177290175526", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982584_382177293508859_4158422507920947771_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zon3zptflKMQ7kNvgHzhlMw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoCHWRtFggSkzXrrCkwirlVAzXwLIJKZDu4nTzapXoCA&oe=6735D075"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "640897637257915", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982698_640897640591248_3726570399134143249_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XHuNKC9MdNkQ7kNvgGRyaCK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDHN6IYEwCqmZUBZ35fGSq_sTBScBwfZzBJmSVoKAScw&oe=6735D51A"}, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "keywords": [], "long_description": "Step into a virtual laboratory and learn how to work safely in the first-ever Centers for Disease Control and Prevention\u2019s (CDC) virtual reality (VR) laboratory training course. This course enables learners to apply knowledge and practice setting up a biosafety cabinet (also known as a biological safety cabinet, or BSC) in a virtual laboratory in order to identify the major parts, demonstrate how to maintain positive airflow, demonstrate how to prepare for work, apply safe-work practices, demonstrate how to decontaminate and shutdown, and conduct emergency shutdown procedures of a Class II Biosafety Cabinet. This course is developed for laboratory professionals and supplements the existing CDC eLearning course on the same topic found on the CDC LabTraining page.", "short_description": "LabTrainingVR: Biosafety Cabinet Edition course enables learners to apply knowledge and practice setting up and working in a biological safety cabinet (BSC) in a virtual laboratory."}]}, "developer_name": "Centers for Disease Control and Prevention", "developer_privacy_policy_url": "https://www.cdc.gov/lab-training/php/virtual-reality/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Centers for Disease Control and Prevention", "support_website_url": null, "website_url": "https://www.cdc.gov/lab-training/php/onelab/index.html", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "1043107547362485"}, {"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8862629297128834"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221326_1247738169688723_3516847363062144735_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9U4hoNbDoVAQ7kNvgHglSN3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHEKK-E9ExC5MiXnNIAeqjU8Y8Zr4TbA9VT-7QhZru1g&oe=6735FA23"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"