 order to identify the major parts, demonstrate how to maintain positive airflow, demonstrate how to prepare for work, apply safe-work practices, demonstrate how to decontaminate and shutdown, and conduct emergency shutdown procedures of a Class II Biosafety Cabinet. This course is developed for laboratory professionals and supplements the existing CDC eLearning course on the same topic found on the CDC LabTraining page.", "short_description": "LabTrainingVR: Biosafety Cabinet Edition course enables learners to apply knowledge and practice setting up and working in a biological safety cabinet (BSC) in a virtual laboratory."}]}, "developer_name": "Centers for Disease Control and Prevention", "developer_privacy_policy_url": "https://www.cdc.gov/labtraining/training-courses/VR_Training_Privacy_Policy_Page.html", "developer_terms_of_service_url": null, "publisher_name": "Centers for Disease Control and Prevention", "support_website_url": null, "website_url": "https://www.cdc.gov/labtraining", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "1043107547362485"}, {"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "554692686266707"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "724207765689105"}]}, "baseline_offer": {"id": "724207765689105"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1649960400, "status": "PUBLISHED", "id": "7242077656