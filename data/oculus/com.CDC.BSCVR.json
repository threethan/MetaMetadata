6aJ2JQ&oe=66E16347"}, {"file_name": "Screenshot5.png", "id": "898116627571706", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035393_898116630905039_506864153412416018_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Q_Cb09P-qQQ7kNvgFHKkQ6&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad6x6nUHzkNzixZE18ZuUca&oh=00_AYCQHO5iQkeCu1frLwIuxTyu0xdItysum_q2ijDmCsVsHQ&oe=66E17C8A"}, {"file_name": "Screenshot6.png", "id": "382177290175526", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_382177293508859_4158422507920947771_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h2_KUSgYrNkQ7kNvgEkzks-&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad6x6nUHzkNzixZE18ZuUca&oh=00_AYDAuBQNrCYphc0G2FzvpX4NLxC1M-nPXaOfQzEPK5JY1A&oe=66E17075"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "640897637257915", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_640897640591248_3726570399134143249_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C7Bu4wHEKK8Q7kNvgEKtBC4&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad6x6nUHzkNzixZE18ZuUca&oh=00_AYDzzFVnSmuIuYDfmmm_H_S_Ikm3f5_OvXI1Wek9_EcNSw&oe=66E1751A"}, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "keywords": [], "long_description": "Step into a virtual laboratory and learn how to work safely in the first-ever Centers for Disease Control and Prevention\u2019s (CDC) virtual reality (VR) laboratory training course. This course enables learners to apply knowledge and practice setting up a biosafety cabinet (also known as a biological safety cabinet, or BSC) in a virtual laboratory in order to identify the major parts, demonstrate how to maintain positive airflow, demonstrate how to prepare for work, apply safe-work practices, demonstrate how to decontaminate and shutdown, and conduct emergency shutdown procedures of a Class II Biosafety Cabinet. This course is developed for laboratory professionals and supplements the existing CDC eLearning course on the same topic found on the CDC LabTraining page.", "short_description": "LabTrainingVR: Biosafety Cabinet Edition course enables learners to apply knowledge and practice setting up and working in a biological safety cabinet (BSC) in a virtual laboratory."}]}, "developer_name": "Centers for Disease Control and Prevention", "developer_privacy_policy_url": "https://www.cdc.gov/labtraining/training-courses/VR_Training_Privacy_Policy_Page.html", "developer_terms_of_service_url": null, "publisher_name": "Centers for Disease Control and Prevention", "support_website_url": null, "website_url": "https://www.cdc.gov/labtraining", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "554692686266707"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982532_315552120449196_7761963953066735625_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ImTesuiPu4cQ7kNvgF_rjlK&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad6x6nUHzkNzixZE18ZuUca&oh=00_AYDYiKXeG3bgBgaxn7XYlm7gn9RxsWY9-wynBjv5Ms-uxA&oe=66E19810"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1649960458, "lastRevision": {"nodes": [{"id": "468455888031932", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale"