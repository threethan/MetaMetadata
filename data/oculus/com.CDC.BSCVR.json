07"}, {"file_name": "Screenshot5.png", "id": "898116627571706", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035393_898116630905039_506864153412416018_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x2Wc_qlfWFMQ7kNvgEAaEO0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAX2oWxnLL8oW0QUPMOErP-ja5k8igh_qRjXyLWtBohlA&oe=67542F0A"}, {"file_name": "Screenshot6.png", "id": "382177290175526", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982584_382177293508859_4158422507920947771_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ja2s1XG1JusQ7kNvgENW-KZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKWZGXOOwqcHGs7p6rEhHPvIMDRHzar2RaDqVigU9e0g&oe=675422F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "640897637257915", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982698_640897640591248_3726570399134143249_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3NDbHscvdmsQ7kNvgH3xYPH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDb2gF141-nxm_iRhxneoY8U0i84y2zkpaaJoCDa5u57g&oe=6754279A"}, "display_name": "LabTrainingVR: Biosafety Cabinet Edition", "keywords": [], "long_description": "Step into a virtual laboratory and learn how to work safely in the first-ever Centers for Disease Control and Prevention\u2019s (CDC) virtual reality (VR) laboratory training course. This course enables learners to apply knowledge and practice setting up a biosafety cabinet (also known as a biological safety cabinet, or BSC) in a virtual laboratory in order to identify the major parts, demonstrate how to maintain positive airflow, demonstrate how to prepare for work, apply safe-work practices, demonstrate how to decontaminate and shutdown, and conduct emergency shutdown procedures of a Class II Biosafety Cabinet. This course is developed for laboratory professionals and supplements the existing CDC eLearning course on the same topic found on the CDC LabTraining page.", "short_descrip