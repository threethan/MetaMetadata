scdn.com/v/t64.5771-25/38974445_964566337717676_1169298822759567376_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TJGslvxZYFAQ7kNvgEQirQq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A406kIN9MZOA-G5ThWWy8Bb&oh=00_AYDpyno_NUtYJZMbpWdYaqfGVRAtP-Qm8SRDUDQvzS0hPA&oe=66DECE7A"}, {"file_name": "3.png", "id": "4486719454727031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_4486719458060364_1113984044610949546_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WKoANYseSfYQ7kNvgFGxdUi&_nc_ht=scontent.oculuscdn.com&_nc_gid=A406kIN9MZOA-G5ThWWy8Bb&oh=00_AYCj8GdZa9vLHVyh3c-i41K6_fpj_lYylrA8wuExgyQUOw&oe=66DEC000"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5.png", "id": "508612663541185", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_508612666874518_8175450015938176745_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iD7kh_PoZi4Q7kNvgERurCU&_nc_ht=scontent.oculuscdn.com&_nc_gid=A406kIN9MZOA-G5ThWWy8Bb&oh=00_AYB2Rpc70snSdSxN2Lh2Rn9YE08kPgSjoM3X-8QP6YRydg&oe=66DECAF9"}, "display_name": "BoomXR", "keywords": [], "long_description": "A boxing pad trainer where you hit coloured targets in sync with the beats of your mp3.\n\nYou'll also have to dodge and parry strikes as you top the ranks of the ninja shrine.\n\nStriking angles are strict and the game promotes hip movement for intense workouts.\n\nThe dark setting combines elements of rave and martial arts in a colourful experience.\n\nAll the beats are mapped in real-time by our algorithm, including the default music.\n\nThe game difficulty adapts to your live score so the better you play the harder it gets.\n\nTIP: Create a folder \"/sdcard/Music/Yolopia\" to limit the mp3 search in that folder only.", "short_description": "Ninja rhythmic boxing workout"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.yolopia.com/privacy.txt", "developer_terms_of_service_url": "http://www.yolopia.com/boomxr/EULA.txt", "publisher_name": "Yolopia", "support_website_url": null,