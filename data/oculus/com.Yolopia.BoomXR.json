=1-7&_nc_sid=6e7a0a&_nc_ohc=M7o8cy5age8Q7kNvgH96i4O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_98jXoKDa68p-eOwTPKaU5yF6oZUdSK2fdgo3cqcIfQ&oe=6738747A"}, {"file_name": "3.png", "id": "4486719454727031", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035320_4486719458060364_1113984044610949546_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fZHzcjXTSv0Q7kNvgF1REI8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC3MBGmVoizDpTvUYPoQ0DNNbmT6uZEweh8VET15DL8oA&oe=67389E40"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5.png", "id": "508612663541185", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974510_508612666874518_8175450015938176745_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dg-NvToLddsQ7kNvgGCvFvY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQTv8PE4ZE_h6bzBOuD1vaF1SckCczj4YeKr0mnLO0vA&oe=673870F9"}, "display_name": "BoomXR", "keywords": [], "long_description": "A boxing pad trainer where you hit coloured targets in sync with the beats of your mp3.\n\nYou'll also have to dodge and parry strikes as you top the ranks of the ninja shrine.\n\nStriking angles are strict and the game promotes hip movement for intense workouts.\n\nThe dark setting combines elements of rave and martial arts in a colourful experience.\n\nAll the beats are mapped in real-time by our algorithm, including the default music.\n\nThe game difficulty adapts to your live score so the better you play the harder it gets.\n\nTIP: Create a folder \"/sdcard/Music/Yolopia\" to limit the mp3 search in that folder only.", "short_description": "Ninja rhythmic boxing workout"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.yolopia.com/privacy.txt", "developer_terms_of_service_url": "http://www.yolopia.com/boomxr/EULA.txt", "publisher_name": "Yolopia", "support_website_url": null, "website_url": "http://www.yolopia.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context