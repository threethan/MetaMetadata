scdn.com/v/t64.5771-25/38974445_964566337717676_1169298822759567376_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8fEFJuzPhIgQ7kNvgEy9dmj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AER896tINMTMgJQAfa8yt9t&oh=00_AYAeaFw8nM-KBaGyKbObwhUhRUNlYs1yWiLSLcU1yhuN4A&oe=66E01FFA"}, {"file_name": "3.png", "id": "4486719454727031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_4486719458060364_1113984044610949546_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x6tHK9mtJrYQ7kNvgEyvOuG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AER896tINMTMgJQAfa8yt9t&oh=00_AYAa1JgRRNC54y_HbDkCtayHcAqo8-sWOgL2Rmqmh7DxPg&oe=66E01180"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5.png", "id": "508612663541185", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_508612666874518_8175450015938176745_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iD7kh_PoZi4Q7kNvgFDRvN9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AER896tINMTMgJQAfa8yt9t&oh=00_AYAA6WgQwKvfBcU2VFomRGgK4HsUkpnCq78ldWJA1ppoVQ&oe=66E01C79"}, "display_name": "BoomXR", "keywords": [], "long_description": "A boxing pad trainer where you hit coloured targets in sync with the beats of your mp3.\n\nYou'll also have to dodge and parry strikes as you top the ranks of the ninja shrine.\n\nStriking angles are strict and the game promotes hip movement for intense workouts.\n\nThe dark setting combines elements of rave and martial arts in a colourful experience.\n\nAll the beats are mapped in real-time by our algorithm, including the default music.\n\nThe game difficulty adapts to your live score so the better you play the harder it gets.\n\nTIP: Create a folder \"/sdcard/Music/Yolopia\" to limit the mp3 search in that folder only.", "short_description": "Ninja rhythmic boxing workout"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.yolopia.com/privacy.txt", "developer_terms_of_service_url": "http://www.yolopia.com/boomxr/EULA.txt", "publisher_name": "Yolopia", "support_website_url": null,