 skills.\n\nAspiring electricians can gain invaluable experience without exposure to real-world risks, leading to improved on-the-job performance and heightened safety awareness."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bitspacedevelopment.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bit Space Development Ltd.", "support_website_url": null, "website_url": "https://www.bitspacedevelopment.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7420947388015379"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3713676185575167"}]}, "baseline_offer": {"id": "3713676185575167"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715189460, "status": "PUBLISHED", "id": "3713676185575167"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8715227591920679", "version": "1"}, "id": "3236672019958159", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6288695571240572", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8715227591920679"}, "release_status": "RELEASED"}, "binary_release_channels": 