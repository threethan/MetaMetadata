.com/v/t64.5771-25/75210398_336466345549248_1090091723398161830_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uPmlkwQYcr0Q7kNvgGz6bFe&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACQ-BnJQ7QViM6pjBviI11s&oh=00_AYDh2a77WoD-gUH65PZur_AD62UCdMhpsBaGbWIKmlBAhQ&oe=66F2A8EB"}, "display_name": "Residential Electrician", "keywords": [], "long_description": "This safety simulator is designed to teach you various skills about electrical work such as:\n-Electrical Equipment Operation\n-Safe Wiring and Circuit Installation\n-Electrical Circuit Testing\n-Safety Precautions and Protocols in Electrical Work\n-Electrical Grounding\n-Electrical Component Identification and Usage\n-Electrical Safety Gear and Personal Protective Equipment (PPE)", "short_description": "Residential Electrician VR is an immersive and cutting-edge training simulator designed to enhance electrical safety and expertise within the electrical industry. Utilizing virtual reality technology, this simulator creates a realistic environment for electricians to hone their skills.\n\nAspiring electricians can gain invaluable experience without exposure to real-world risks, leading to improved on-the-job performance and heightened safety awareness."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bitspacedevelopment.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bit Space Development Ltd.", "support_website_url": null, "website_url": "https://www.bitspacedevelopment.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "sup