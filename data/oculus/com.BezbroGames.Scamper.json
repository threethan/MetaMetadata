4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover.png", "id": "658656272975553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_658656276308886_947163137306463690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A2hw0CYwLfoQ7kNvgEUVmut&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOgA6Gq-PC1cktgVnqjbogy&oh=00_AYC1fxKeT7B0x07hVS0X2Fnu1JAWBnuIGZ_ixjRRSrn4lQ&oe=66F697EF"}, "display_name": "Scamper", "keywords": [], "long_description": "You Are A Rat.\nEnter into a dark and complex sewer system where another rat is lost. Your mission is to find this lost rat and help it escape.\n\nYou Are Not Alone.\nSomething lurks in the shadows of the sewer system, and it is always on the hunt for rats.\n\nYou can scamper, climb, and leap through the environment with just the movement of your hands and arms. You will need to move fast and figure out how to get around the vast sewer system.\n\nYou\u2019ll need to use clever tactics to guide the lost rat, as it will react to your movements and actions. Will it follow your lead, or will it run away out of fear? It\u2019s all up to you.\n\nIt is time to enter the sewer.", "short_description": "You are a rat. Enter the sewer system and help a fellow rat escape what lurks within it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/1b7bff2b-076c-44a2-b462-db150a651fff", "developer_terms_of_service_url": null, "publisher_name": "Bezbro Games", "support_website_url": null, "website_url": "https://bezbrogames.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_g