601_3454308911501947_8768951964143475862_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gZaUsChN2M4Q7kNvgFuxnm9&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHHoJA4FCENneOsCpuwMIEOeIt1ILqSxI0xHVsEKDVPQ&oe=66EC1E49"}, {"file_name": "ss4.png", "id": "1205888560076765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_1205888563410098_6233883395171935723_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IFc64Lk6CJwQ7kNvgGFAJFr&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAgOXlPyPSgvUTVmF-jknOSJyvwco9SwAfiidrvjUBlw&oe=66EC02EB"}, {"file_name": "ss2.png", "id": "259494686722641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982545_259494690055974_4607054332296823703_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wrzlQbr0XSgQ7kNvgFpfWm-&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7aE5lH4u8ouSeQjG6OYlPtqPBUEgAvgYh6S8pLOdDuw&oe=66EC0D27"}, {"file_name": "ss5.png", "id": "2597365140419734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035349_2597365143753067_8978226914280681512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qLu_to954DUQ7kNvgEbuWfP&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7EL5soh9R-2bEyoCofSCWbeUpmwqbAgu4uXlJ4J55gg&oe=66EBF574"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover.png", "id": "658656272975553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_658656276308886_947163137306463690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qcZB0GvzuRsQ7kNvgHlsJe1&_nc_ht=scontent.oculuscdn.com&oh=00_AYAD-4-PsM_dArPWosZplPYDfuB_DogkjdM6t7PtAznw_Q&oe=66EC0BEF"}, "display_name": "Scamper", "keywords": [], "long_description": "You Are A Rat.\nEnter into a dark and complex sewer system where another rat is lost. Your mission is to find this lost rat and help it escape.\n\nYou Are Not Alone.\nSomething lurks in the shadows of the sewer system, and it is always on the hunt for rats.\n\nYou can scamper, climb, and leap through the environment with just the movement of your hands and arms. You will need to mov