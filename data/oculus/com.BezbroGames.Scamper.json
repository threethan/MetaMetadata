Z2xOUvYKiMRlTYhhRKntMbKo2aPRvQBsA&oe=67179FC9"}, {"file_name": "ss4.png", "id": "1205888560076765", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974788_1205888563410098_6233883395171935723_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oxVr67crL6UQ7kNvgEwyo0K&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBPplnaV01DJylBRCiE_hSZMVgGp6T-k22STX2IlEEgYA&oe=6717846B"}, {"file_name": "ss2.png", "id": "259494686722641", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982545_259494690055974_4607054332296823703_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KVyUJYYA5mUQ7kNvgElVOzd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOJUHDdWK6mbMaX9LhD4XOHu4Pzd414UeyM-ofRMyQkw&oe=67178EA7"}, {"file_name": "ss5.png", "id": "2597365140419734", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035349_2597365143753067_8978226914280681512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8VYBzDO9TR0Q7kNvgEKAO8U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA97OlZytw0n1E1oGxLzg-ZjrUU1SHApItntOrSlJhg1w&oe=671776F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover.png", "id": "658656272975553", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974871_658656276308886_947163137306463690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TqCk6AU_dlIQ7kNvgF_Lu9R&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-BWUwxySK4cAZ6vqW9MtIkYF9cYgQrPPqgD7Hy1SfBw&oe=67178D6F"}, "display_name": "Scamper", "keywords": [], "long_description": "You Are A Rat.\nEnter into a dark and complex sewer system where another rat is lost. Your mission is to find this lost rat and help it escape.\n\nYou Are Not Alone.\nSomething lurks in the shadows of the sewer system, and it is always on the hunt for rats.\n\nYou can scamper, climb, and leap through the environment with just the movement of your hands and arms. You will need to move fast and figure out how to get around the vast sewer system.\n\nYou\u2019ll need to use clever tactics to guide the lost rat, as it will react to your movements and actions. Will it follow your lead, or will it run away out of fear? It\u2019s all up to you.\n\nIt is time to enter the sewer.", "short_description": "You are a rat. Enter the sewer system and help a fellow rat escape what lurks within it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/1b7bff2b-076c-44a2-b462-db150a651fff", "developer_terms_of_service_url": null, "publisher_name": "Bezbro Games", "support_website_url": null, "website_url": "https://bezbrogames.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1394543634671740"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "226679486946564"}]}, "baseline_offer": {"id": "226679486946564"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1690579800, "status": "PUBLISHED", "id": "226679486946564"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6973435412757189", "version": "19.93"}, "id": "744776554061767", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename