/39031601_3454308911501947_8768951964143475862_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dyb2SmQVvDkQ7kNvgEbNMB_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtMKO2quxr3s_KQafmqqm444gAPdMBTnga3RcGuNSTHQ&oe=66CF1D49"}, {"file_name": "ss4.png", "id": "1205888560076765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_1205888563410098_6233883395171935723_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vLS7pH7BvKwQ7kNvgGRv4mh&_nc_ht=scontent.oculuscdn.com&oh=00_AYBFAhfwPMH-lB6z-uAT1r_iPOxpcKKQ28mN1jmdlhERnA&oe=66CF01EB"}, {"file_name": "ss2.png", "id": "259494686722641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982545_259494690055974_4607054332296823703_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PTh0ue0_hlIQ7kNvgEc7Dsl&_nc_ht=scontent.oculuscdn.com&oh=00_AYD152HBivxIjy8uMRhKKfxHBGIpBMTIcg4jQvV-VuEibw&oe=66CF0C27"}, {"file_name": "ss5.png", "id": "2597365140419734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035349_2597365143753067_8978226914280681512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=09zeCv-u1vsQ7kNvgE16Txo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoJYahmhGdQcfKll3R-cc7A4ZlReBc5M3nRbcw4Jnmog&oe=66CEF474"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover.png", "id": "658656272975553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974871_658656276308886_947163137306463690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gYIgQ3UUWQEQ7kNvgH9f8YH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCG2u5mfPMlg2RFqPTGLnHQdBeKxCcfKosagDIXpQ_kzg&oe=66CF0AEF"}, "display_name": "Scamper", "keywords": [], "long_description": "You Are A Rat.\nEnter into a dark and complex sewer system where another rat is lost. Your mission is to find this lost rat and help it escape.\n\nYou Are Not Alone.\nSomething lurks in the shadows of the sewer system, and it is always on the hunt for rats.\n\nYou can scamper, climb, and leap through the environment with just the movement of your hands and arms. You will need 