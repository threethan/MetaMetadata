0076765", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974788_1205888563410098_6233883395171935723_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1xJcqYF-PGwQ7kNvgFy1o0c&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAxWl0Fp2aaHGwjYDi20vUjjHkfVcLNWiKj75MCxwniJA&oe=670BA6EB"}, {"file_name": "ss2.png", "id": "259494686722641", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982545_259494690055974_4607054332296823703_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Qz8gqrOvmEQ7kNvgHI7xuu&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBntXNDI9mhLJMHYAUt8fecmLSqR5nYKtdYh5RvNZG0gQ&oe=670BB127"}, {"file_name": "ss5.png", "id": "2597365140419734", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035349_2597365143753067_8978226914280681512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lLEWtHvD6EQ7kNvgEX0pUh&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC1E5_QLkJoj-ZM47hzcqiZmosxSQ7XzhKDJhvgdC7avg&oe=670B9974"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover.png", "id": "658656272975553", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974871_658656276308886_947163137306463690_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxkLVMZt0eEQ7kNvgEW65wv&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYANOZ36nua0OZShucoyLAgAhTLskGh5VLjqUrqc0Jsg3g&oe=670BAFEF"}, "display_name": "Scamper", "keywords": [], "long_description": "You Are A Rat.\nEnter into a dark and complex sewer system where another rat is lost. Your mission is to find this lost rat and help it escape.\n\nYou Are Not Alone.\nSomething lurks in the shadows of the sewer system, and it is always on the hunt for rats.\n\nYou can scamper, climb, and leap through the environment with just the movement of your hands and arms. You will need to move fast and figure out how to get around the vast sewer system.\n\nYou\u2019ll need to use clever tactics to guide the lost rat, as it will react to your movements and actions. Will it follow your lead, or will it run away out of fear? It\u2019s all up to you.\n\nIt is time to enter the sewer.", "short_description": "You are a rat. Enter the sewer system and help a fellow rat escape what lurks within it."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/1b7bff2b-076c-44a2-b462-db150a651fff", "developer_terms_of_service_url": null, "publisher_name": "Bezbro Games", "support_website_url": null, "website_url": "https://bezbrogames.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1394543634671740"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "226679486946564"}]}, "baseline_offer": {"id": "226679486946564"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1690579800, "status": "PUBLISHED", "id": "226679486946564"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6973435412757189", "version": "19.93"}, "id": "744776554061767", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5664867976947279", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id