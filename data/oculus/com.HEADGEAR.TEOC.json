tent-iad3-1.oculuscdn.com/v/t64.5771-25/75297579_361423314974094_4468664441597916853_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jK40PhjaCjgQ7kNvgGBHcZB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdkI6usdB3G4Evsa5UVRSEl8tWfoi2VK4zgSAh-uXH_w&oe=671CCA60"}, {"file_name": "consume.png", "id": "356221875528110", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001669_356221878861443_261896368707707264_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=myF950NFmcoQ7kNvgFtHofn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB47qRtbhnaKROl_tvQzTRrsHi1s3EJXooygws3dtoN6w&oe=671CEF03"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982553_2716489995261681_7852865887418274915_n[1].png", "id": "1017968672039348", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974845_1017968675372681_3537640423345626257_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zRMUQ93EtlIQ7kNvgEWG4U2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDD7kMlU4dhcn-7HEzWaOwF4MpKU9v3lOOafbvhFA-7BA&oe=671CD006"}, "display_name": "TEOC", "keywords": ["arcade", "puzzle", "casual", "atmospheric", "puzzler"], "long_description": "Evolve from an atomic state to marine-life in this spatial arcade puzzler with just one goal: Consume or be Consumed! \n\nPowered by elemental forces and mythical artifacts navigate your way through 3 environments with 30+ rounds each to get through. Will you be able to top the leaderboard for each of these? \n\nTEOC provides\u2026\n\u2022 more than 5 hours of mesmerizing gameplay,\n\u2022 a beautiful minimalist style with ambient adaptive soundtracks,\n\u2022 10+ game mechanics to master,\n\u2022 additional powerups to collect and use across all 90+ rounds\n\u2022 with daily powerup rewards for coming back\n\u2022 to compete on the 3 leaderboards,\n\u2022 increasingly challenging level design all procedurally generated\n\u2022 and seated or standing play options!\n\n\n", "short_description": "Evolve from an atomic state to marine-life in this spatial arcade puzzler with just one goal: Consume or be Consumed! \n\nPowered by elemental forces and mythical artifacts navigate your way through 3 environments with 30+ rounds each to get through. Will you be able to top the leaderboard for each of these? With >5 hours of mesmerizing gameplay, 10+ game mechanics to master and all set in a beautiful minimalist style with ambient adaptive soundtracks, you can enjoy it seated or standing up!\n"}]}, "developer_name": "HEADGEAR GbR", "developer_privacy_policy_url": "https://headgear.io/legal.html", "developer_terms_of_service_url": "https://headgear.io/legal.html#terms", "publisher_name": "HEADGEAR GbR", "support_website_url": null, "website_url": "https://headgear.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "495334582022458"}, "review_messages": ["", "Hello, and thank you for your submission!\n\nYour trailer displays the Oculus logo in a way that may imply partnership. Please remove the logo, or precede it with the text \"available on\"."]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031515_382689612886422_8593492969456066625_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0KSQ6x8OqXIQ7kNvgE8kMX6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDavbnWmvmMIr0-u2iIB90WbuWAxG6reEwK1W8PUspPIw&oe=671CD6E6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, 