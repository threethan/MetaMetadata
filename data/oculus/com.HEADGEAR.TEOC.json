 state to marine-life in this spatial arcade puzzler with just one goal: Consume or be Consumed! \n\nPowered by elemental forces and mythical artifacts navigate your way through 3 environments with 30+ rounds each to get through. Will you be able to top the leaderboard for each of these? With >5 hours of mesmerizing gameplay, 10+ game mechanics to master and all set in a beautiful minimalist style with ambient adaptive soundtracks, you can enjoy it seated or standing up!\n"}]}, "developer_name": "HEADGEAR GbR", "developer_privacy_policy_url": "https://headgear.io/legal.html", "developer_terms_of_service_url": "https://headgear.io/legal.html#terms", "publisher_name": "HEADGEAR GbR", "support_website_url": null, "website_url": "https://headgear.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "ARCADE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "495334582022458"}, "review_messages": ["", "Hello, and thank you for your submission!\n\nYour trailer displays the Oculus logo in a way that may imply partnership. Please remove the logo, or precede it with the text \"available on\"."]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031515_382689612886422_8593492969456066625_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ubmVBX4CIw0Q7kNvgEREfB0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA9Vi1CwGlDq8LOXeSikLT8gVlkTUULnC4dk4FkxUh3WA&oe=6767FC66"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "