-sjc3-1.oculuscdn.com/v/t64.5771-25/39031347_639895660509372_7705356960869435234_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1xwRNh9oo6sQ7kNvgHT4Neb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBlCDQo2VSVP_Cm2liQ7eSlFJWtmyo8RCP7rAryYgxuIA&oe=6724C228"}, {"file_name": "tall building cc.png", "id": "1498752603838723", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003239_1498752607172056_151360250922560175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VrPhbsTVjsAQ7kNvgE4eL62&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBVJDLi-YDAG93VlMDxCYGCZrvSplo0z-U0I2uMTrJXAQ&oe=6724AF5B"}, {"file_name": "lightning cc.png", "id": "395324105376435", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001654_395324108709768_5459926047627792842_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fm-5eBkl-VUQ7kNvgELkLCC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAk0vz4jws473k7O2d7rGNS8P8GDJG1QiZxMkVKo-vXvw&oe=6724B088"}, {"file_name": "hole cc.png", "id": "2075857779239822", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003281_2075857782573155_9122727236454616172_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b2nXm4Roq_4Q7kNvgEXqB0g&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCwkX-_OoIR8jzIH2d0hh9-g2R4KTvi-TJd36sR8BqPWQ&oe=6724C5AA"}, {"file_name": "dungeon sword cc.png", "id": "282029897081919", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001692_282029900415252_4974564925784914357_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=REP304CkFYYQ7kNvgH6Me8w&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDxfw6GnNiWR3vtwbWmo0RMiCBxHRqXP1A6PGdsaIKdfA&oe=6724BEF9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape_logo.png", "id": "1050042049126333", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569485_1050042052459666_4399707948180398893_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YE9mhrRG9dgQ7kNvgEitXVt&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAtFQYvQ26Y2Sywee7sp1OO19v7al2gpQ7f7C-dn6P5gw&oe=6724D48C"}, "display_name": "Blade & Sorcery: Nomad", "keywords": ["Sword", "Melee", "Medieval", "Physic", "Magic"], "long_description": "The era of the VR weightless, wiggle-sword combat is over. Blade & Sorcery: Nomad is a medieval fantasy sandbox like no other, focusing on melee, ranged and magic combat that fully utilizes a unique and realistic physics driven interaction and combat system. Built exclusively for VR, collisions are dictated by fine hitboxes, objects have weight and follow the laws of physics, creatures have full body physics and presence, and blades can be used to penetrate soft materials or deflect magic. In Blade & Sorcery: Nomad, the combat is limited only by your own creativity. Choose your weapon, choose your stance, choose your fighting style; Be the powerful warrior, ranger or sorcerer you always dreamed of becoming!", "short_description": "Blade & Sorcery: Nomad is a built-for-VR medieval fantasy sandbox with full physics driven melee, ranged and magic combat. Become a powerful warrior, ranger or sorcerer and devastate your enemies."}]}, "developer_name": "Warpfrog", "developer_privacy_policy_url": "https://warpfrog.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Warpfrog", "support_website_url": "https://discordapp.com/invite/bladeandsorcery", "website_url": "https://warpfrog.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2710427532541308"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, 