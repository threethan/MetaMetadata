 your fighting style; Be the powerful warrior, ranger or sorcerer you always dreamed of becoming!", "short_description": "Blade & Sorcery: Nomad is a built-for-VR medieval fantasy sandbox with full physics driven melee, ranged and magic combat. Become a powerful warrior, ranger or sorcerer and devastate your enemies."}]}, "developer_name": "Warpfrog", "developer_privacy_policy_url": "https://warpfrog.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Warpfrog", "support_website_url": "https://discordapp.com/invite/bladeandsorcery", "website_url": "https://warpfrog.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3138085263116987"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_245635767597981_1478285280090246989_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2fG0YwZArxcQ7kNvgFcaHbL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCs-CgTm2TZq59mBtzROzHtnK773CR_Yv87-e6qeNUf6A&oe=66E169EB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Blade & Sorcery: Nomad", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "27104275