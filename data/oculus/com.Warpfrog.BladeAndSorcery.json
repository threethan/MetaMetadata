25/39001692_282029900415252_4974564925784914357_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OXtt3WmGxwAQ7kNvgF1Ifup&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0j17TjZCGtvtpHq_baGpBE&oh=00_AYCyaMIxtGuFdIfCBBTvJx4QxpTWeW_YbJbVbqidOOS1Ug&oe=66EC0E79"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape_logo.png", "id": "1050042049126333", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569485_1050042052459666_4399707948180398893_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bHCtNT2oh2UQ7kNvgFDgA_c&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0j17TjZCGtvtpHq_baGpBE&oh=00_AYASeAE465IpkoMTSOAPvDO7zcibPFxdDOsZXhFL4631UQ&oe=66EC240C"}, "display_name": "Blade & Sorcery: Nomad", "keywords": ["Sword", "Melee", "Medieval", "Physic", "Magic"], "long_description": "The era of the VR weightless, wiggle-sword combat is over. Blade & Sorcery: Nomad is a medieval fantasy sandbox like no other, focusing on melee, ranged and magic combat that fully utilizes a unique and realistic physics driven interaction and combat system. Built exclusively for VR, collisions are dictated by fine hitboxes, objects have weight and follow the laws of physics, creatures have full body physics and presence, and blades can be used to penetrate soft materials or deflect magic. In Blade & Sorcery: Nomad, the combat is limited only by your own creativity. Choose your weapon, choose your stance, choose your fighting style; Be the powerful warrior, ranger or sorcerer you always dreamed of becoming!", "short_description": "Blade & Sorcery: Nomad is a built-for-VR medieval fantasy sandbox with full physics driven melee, ranged and magic combat. Become a powerful warrior, ranger or sorcerer and devastate your enemies."}]}, "developer_name": "Warpfrog", "developer_privacy_policy_url": "https://warpfrog.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Warpfrog", "support_website_url": "https://discordapp.com/invite/bladeandsorcer