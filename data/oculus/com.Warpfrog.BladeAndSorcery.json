ile_name": "lightning cc.png", "id": "395324105376435", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001654_395324108709768_5459926047627792842_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0p_5falg8_YQ7kNvgEDK8Tz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC47W8iYtS4wpJG7HzeATo67CGttaJN2vLwPnPeRfpyww&oe=670CF588"}, {"file_name": "hole cc.png", "id": "2075857779239822", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_2075857782573155_9122727236454616172_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CpeO_jrnK-AQ7kNvgEYFLeo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDFHtGzd6pgTQsa-irRss8rlx3ae2xgOhzulzXjKZTcLA&oe=670D0AAA"}, {"file_name": "dungeon sword cc.png", "id": "282029897081919", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001692_282029900415252_4974564925784914357_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SKgKHukq27sQ7kNvgGanLW3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbt2psWNUsxK3ytpq8fqfNl-pbiJqEoflloFYeXeTQIA&oe=670D03F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape_logo.png", "id": "1050042049126333", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569485_1050042052459666_4399707948180398893_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vAnEo5GGyScQ7kNvgGNcN_s&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA70cpIbFQpiKHlZgsbrggnNKVCZOlYb4KVgHmktTj5XQ&oe=670D198C"}, "display_name": "Blade & Sorcery: Nomad", "keywords": ["Sword", "Melee", "Medieval", "Physic", "Magic"], "long_description": "The era of the VR weightless, wiggle-sword combat is over. Blade & Sorcery: Nomad is a medieval fantasy sandbox like no other, focusing on melee, ranged and magic combat that fully utilizes a unique and realistic physics driven interaction and combat system. Built exclusively for VR, collisions are dictated by fine hitboxes, objects have weight and follow the laws of physics, creatures have full body physics and presence, and blades can be used to penetrate soft materials or deflect magic. In Blade & Sorcery: Nomad, the combat is limited only by your own creativity. Choose your weapon, choose your stance, choose your fighting style; Be the powerful warrior, ranger or sorcerer you always dreamed of becoming!", "short_description": "Blade & Sorcery: Nomad is a built-for-VR medieval fantasy sandbox with full physics driven melee, ranged and magic combat. Become a powerful warrior, ranger or sorcerer and devastate your enemies."}]}, "developer_name": "Warpfrog", "developer_privacy_policy_url": "https://warpfrog.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Warpfrog", "support_website_url": "https://discordapp.com/invite/bladeandsorcery", "website_url": "https://warpfrog.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3138085263116987"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982618_245635767597981_1478285280090246989_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QDYL3MRXMdAQ7kNvgGFyf7v&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRsL6UAVsAVoPJ1qRhJhhqaBDUCsO6vXSfiji6OEitvA&oe=670CEB6B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "d