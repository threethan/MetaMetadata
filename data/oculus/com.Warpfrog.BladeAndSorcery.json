ile_name": "lightning cc.png", "id": "395324105376435", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39001654_395324108709768_5459926047627792842_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3k3604SCW8EQ7kNvgESKQFc&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDvMhtqBWGB_aK88ky4F6Q8VYBOR7cIrRUhcG6fOMu5kw&oe=67163008"}, {"file_name": "hole cc.png", "id": "2075857779239822", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39003281_2075857782573155_9122727236454616172_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KQtulllgNK4Q7kNvgFP2TEG&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYD0qEX3EiCWqFByWdxAqp78hJpTRQOpvmlOUEfgMR3Wuw&oe=6716452A"}, {"file_name": "dungeon sword cc.png", "id": "282029897081919", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39001692_282029900415252_4974564925784914357_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LihjNpS7lpgQ7kNvgE3DHji&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAGqzyhJaThZ9_24rVp3V5prFqimHV6ma-2_gj5EgmstA&oe=67163E79"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape_logo.png", "id": "1050042049126333", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/57569485_1050042052459666_4399707948180398893_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UvczvD9F2LUQ7kNvgELk2AW&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYD1CzRcjLDO-EZr-4RpgA_Omwa4RpusVC7VtCaNp2ccvA&oe=6716540C"}, "display_name": "Blade & Sorcery: Nomad", "keywords": ["Sword", "Melee", "Medieval", "Physic", "Magic"], "long_description": "The era of the VR weightless, wiggle-sword combat is over. Blade & Sorcery: Nomad is a medieval fantasy sandbox like no other, focusing on melee, ranged and magic combat that fully utilizes a unique and realistic physics driven interaction and combat system. Built exclusively for VR, collisions are dictated by fine hitboxes, objects have weight and follow the laws of physics, creatures have full body physics and presence, and blades can be used to penetrate soft materials or deflect magic. In Blade & Sorcery: Nomad, the combat is limited only by your own creativity. Choose your weapon, choose your stance, choose your fighting style; Be the powerful warrior, ranger or sorcerer you always dreamed of becoming!", "short_description": "Blade & Sorcery: Nomad is a built-for-VR medieval fantasy sandbox with full physics driven melee, ranged and magic combat. Become a powerful warrior, ranger or sorcerer and devastate your enemies."}]}, "developer_name": "Warpfrog", "developer_privacy_policy_url": "https://warpfrog.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Warpfrog", "support_website_url": "https://discordapp.com/invite/bladeandsorcery", "website_url": "https://warpfrog.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3138085263116987"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982618_245635767597981_1478285280090246989_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wxn56k7cn9sQ7kNvgHqJw73&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBf6NcQSkYgE7eDJBaFHQE4lyYgChB5S5V8joMIvuICQA&oe=671625EB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, 