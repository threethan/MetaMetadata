c=4v-Wq8X8DugQ7kNvgGudl-r&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA10jCDSmUMhlDmlQKqjO33tcO5MZmPSB_Oz6w7TmkcPQ&oe=6756E906"}, {"file_name": "migrated_image.png", "id": "227630628591101", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031351_756032921501850_5719982825713696768_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NPq1AZqs0c8Q7kNvgGTk6n1&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCh9Ho_MgLRN3UJDIJuPO8ndXeSmyP4XYxYQcOgl478ow&oe=6756D070"}, {"file_name": "migrated_image.png", "id": "225755278789245", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001728_1653383734791707_4392752019018874880_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s5nTiFZho4oQ7kNvgE6TXJM&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAKT5cnHbFYLD7eJp8ZlRLncmpexhyFIrdlUAS2pOfivA&oe=6756E863"}, {"file_name": "migrated_image.png", "id": "327933284831942", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031647_417935015578012_2400822427098546176_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G6T9eXUzS2IQ7kNvgET3pIa&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAAVSM26HCGWysmMfbb6xWD_7ZyQ4W4DopJ8AdXHN-N6w&oe=6756E3BE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/szSSdM", "id": "2395015640772174", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982637_2395015644105507_1151433955568779264_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hyrdr-PDKEEQ7kNvgHvgVax&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBkHWHwDacZJRG_AiezNjKx_ThdT8HQgc2rAYCjZoErfQ&oe=6756CC34"}, "display_name": "Synth Riders", "keywords": ["music", "rhythm", "beat", "audio", "fitness"], "long_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game. \n\nSynth Riders absolutely loads your senses for an experience that\u2019s truly unique, unforgettable and simply a blast to play.\n\n- 21 top songs and new top artists added regularly\n- World leaderboards taking advantage of Quest\u2019s brand new social features and includes cross-platform support\n- Different modes that keep the game fresh, including force mode for harder workouts and challenges\n- An active community supporting and creating infinite forms of gameplay\n- Multiplayer coming soon", "short_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.synthridersvr.com/", "publisher_name": "Kluge Interactive", "support_website_url": "https://www.synthridersvr.com/contact", "website_url": "https://www.synthridersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_device