SHED", "id": "2860321390771780"}, {"status": "PENDING", "id": "359505019971889"}, {"status": "CANCELLED", "id": "1124785787886174"}, {"status": "PENDING", "id": "562085185756540"}, {"status": "CANCELLED", "id": "7915764198438456"}, {"status": "PUBLISHED", "id": "441729468146179"}, {"status": "PENDING", "id": "3295663150686098"}, {"status": "PUBLISHED", "id": "520539602972524"}, {"status": "PUBLISHED", "id": "336910824544138"}, {"status": "PENDING", "id": "354657410292796"}, {"status": "PENDING", "id": "680007016391928"}, {"status": "CANCELLED", "id": "540831357281709"}, {"status": "PENDING", "id": "2554455594716973"}, {"status": "PENDING", "id": "316817754063011"}, {"status": "PUBLISHED", "id": "2407859796131301"}, {"status": "PUBLISHED", "id": "1070169843488755"}, {"status": "PUBLISHED", "id": "235015356196959"}, {"status": "PUBLISHED", "id": "3242628742442573"}, {"status": "PUBLISHED", "id": "289576429827715"}, {"status": "PUBLISHED", "id": "1004761406584240"}, {"status": "PUBLISHED", "id": "445726740746370"}, {"status": "PUBLISHED", "id": "997467334849315"}, {"status": "CANCELLED", "id": "392345402603969"}, {"status": "PUBLISHED", "id": "572808110455564"}, {"status": "PUBLISHED", "id": "722881871699987"}, {"status": "PUBLISHED", "id": "911481683085250"}, {"status": "PENDING", "id": "1504630723382324"}, {"status": "PUBLISHED", "id": "840469430163137"}, {"status": "PENDING", "id": "3541416689433774"}, {"status": "PENDING", "id": "672439661422497"}, {"status": "PENDING", "id": "1760927994374844"}, {"status": "PUBLISHED", "id": "267959407837991"}, {"status": "PUBLISHED", "id": "929795368158087"}, {"status": "PUBLISHED", "id": "482492747327580"}, {"status": "PUBLISHED", "id": "593491622404051"}, {"status": "CANCELLED", "id": "605667957379017"}, {"status": "PENDING", "id": "3505046773107907"}, {"status": "PUBLISHED", "id": "1310054713278021"}]}, "baseline_offer": {"id": "267959407837991"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1369444894460822"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8757757377665440", "version": "3.5.1a1"}, "id": "1294977310680058", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2436558143118760", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8757757377665440"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1294977310680058"}]}, "change_log": "# Version 3.5.1a1 - UI Update\n\n** Important Note: Please make sure all your friends update their game, as this version is incompatible with previous versions for Multiplayer! **\n\n# What's New?\n\nWelcome to the new Synth Riders look and feel!  We hope you'll enjoy this update as we improve the way you navigate the game, bringing a host of new features with it.\n\n## Updated Main Menu\n\u2022 Find Challenges and Experiences more easily with their own options.\n\u2022 Addition of the News Carousel, thumbstick scroll left and right for quick news flashes.\n\n## Improved First Time User Experience\n\u2022 Updated onboarding, with tutorials script and stage changed.\n\u2022 Addition of written \"How To Play\" guide.\n\n## Challenges\n\u2022 Brand new Challenges panel where you can easily see what's on offer, what you've completed - jump in and check it out!\n\u2022 Challenges now count down the minutes until they expire, no excuses for missing the Daily Challenges!\n\n## Experiences\n\u2022 Find all your Experiences in one place with the new Experiences panel.\n\u2022 \"Try Before You Buy\" is still available for the Muse - \"Algorithm\" Experience here if you haven't tried it before.\n\u2022 In your song lists, songs with Experiences are highlighted and you can now make the selection to PLAY the song or take the EXPERIENCE without another prompt. \n\n## Song Selection Screen\n\u2022 Song lists are much faster to get around now!  Jump top and bottom of long song lists by clicking in the scrollbar.\n\u2022 Scroll and drag song lists and pack lists.  Use up/down thumbstick for songs, left/right for packs or select and hold trigger to drag.\n\u2022 New options in the Sort and Filter menu to help you filter down your lists.\n\n## Modifiers Panel\n\u2022 Panel restructured with new left to right flow makes it easier to set anmd reset your play choices.\n\u2022 Look for the Stages button above the Modifiers panel to check and change the space you play in.\n\u2022 One-Handed mode is now part of the Modifiers panel for easy access.\n\u2022 With the removal of Basics / Extras separation, we've also retired Play Profiles.\n\n## Leaderboards\n\u2022 Boards default to showing your score, with a slider to turn on modifiers view when desired.\n\u2022 Use the page controls at the bottom of the list to scroll through pages of scores, so you can see how many players have played along with you.\n\n## Multiplayer\n\u2022 With larger panels, it's improved readability for everyone, everywhere in the lobby.\n\u2022 New look and feel throughout the room.\n\u2022 Leave Room now asks for confirmation.\n\u2022 Score summary now has multiple tabs for an uncluttered view.\n\n## Settings\n\u2022 Use Up-Down thumbstick scroll and drag everywhere here too!\n\n## Other\n\u2022 Gameplay HUD, score counters and flyoffs all updated to match the futuristic new style.\n\u2022 Completely new localization for all languages.\n\u2022 Improved sharpness in UI, gameplay.\n\nAs always we welcome your feedback and bug reports on Reddit in /r/SynthRiders, on our Official Discord server or in the Synth Riders Official Community on Facebook.\nIf you want to support the development of Synth Riders, we really appreciate reviews left in the store!\n\nHappy Riding! \n", "created_date": 1732083680, "id": "8757757377665440", "version": "3.5.1a1", "version_code": 847, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8757755474332297"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2436558143118760", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8757757377665440"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731986976, "id": "8751510004956844", "version": "3.5.0.a1", "version_code": 846, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8751508704956974"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2436558143118760", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8757757377665440"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731835536, "id": "8741968982577613", "version": "3.5.0b75", "version_code": 845, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8741967525911092"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2436558143118760", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8757757377665440"}, "release_status": "RELEASED"}, "binary_release_ch