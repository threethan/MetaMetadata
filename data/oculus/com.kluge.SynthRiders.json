.com&oh=00_AYASLdXz8Zgl9hoHtpjzq4BOL35P12CxYI3bm2sB-bQv5w&oe=673738D6"}, {"file_name": "migrated_image.png", "id": "819867331831040", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974625_1661964410601854_2519039722588733440_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zDNdwYes7LYQ7kNvgEvHUdY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAeBB3b6Gp_iLPDyYcpotbwbeGKygkLSl4gv97rgX5TJQ&oe=67374506"}, {"file_name": "migrated_image.png", "id": "227630628591101", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031351_756032921501850_5719982825713696768_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZC2-rExG2WUQ7kNvgEKo0qX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOxoOQFtPSU-fhRs-ToIAuIQ1oobQkH5XYfsaDuTF3XQ&oe=67372C70"}, {"file_name": "migrated_image.png", "id": "225755278789245", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001728_1653383734791707_4392752019018874880_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8n46AdVoyhkQ7kNvgH-i4jW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBeT_rnUQBTcor3Tr1Puqu57Q6FFldT1iE2PGaXfko_cQ&oe=67374463"}, {"file_name": "migrated_image.png", "id": "327933284831942", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031647_417935015578012_2400822427098546176_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QMd3R9I_EesQ7kNvgEc01tw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZGomaaLt8x7DwiLs_mFcPLn5Ts0UXluqD_gzpuvbAtw&oe=67373FBE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/szSSdM", "id": "2395015640772174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982637_2395015644105507_1151433955568779264_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YvLClLE8czgQ7kNvgGOBofZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFeGJaxZepF0k5ETRfzxOBr1nQ4DZfcVyXdMTN4b23yQ&oe=67372834"}, "display_name": "Synth Riders", "keywords": ["music", "rhythm", "beat", "audio", "fitness"], "long_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game. \n\nSynth Riders absolutely loads your senses for an experience that\u2019s truly unique, unforgettable and simply a blast to play.\n\n- 21 top songs and new top artists added regularly\n- World leaderboards taking advantage of Quest\u2019s brand new social features and includes cross-platform support\n- Different modes that keep the game fresh, including force mode for harder workouts and challenges\n- An active community supporting and creating infinite forms of gameplay\n- Multiplayer coming soon", "short_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.synthridersvr.com/", "publisher_name": "Kluge Interactive", "support_website_url": "https://www.synthridersvr.com/contact", "website_url": "https://www.synthridersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRE