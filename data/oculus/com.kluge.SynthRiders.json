biTZwcHIrewQ7kNvgHmAZyO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDlLk2SYvLNQ7prGyhKoLdvfwIB-A_Uy3x7u1lv28K9Eg&oe=674F0006"}, {"file_name": "migrated_image.png", "id": "227630628591101", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031351_756032921501850_5719982825713696768_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fc4vSCaxXbAQ7kNvgHuOUDM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUtm2RpbvfMPfYJDwGkGREWACrXgcNYrzIh19txgSDQg&oe=674EE770"}, {"file_name": "migrated_image.png", "id": "225755278789245", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001728_1653383734791707_4392752019018874880_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SdVcfz9IWcMQ7kNvgF3OB5V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFCiMQsyj-j-_oyG0JoVSNcwnso0BG-SAKQ8k3m-focw&oe=674EFF63"}, {"file_name": "migrated_image.png", "id": "327933284831942", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031647_417935015578012_2400822427098546176_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nL5x9y9y7ewQ7kNvgESLFPu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByAZo-fU-bSRG5Wmtq_1z0xRdFone2WzQ-DjANHgs2cg&oe=674EFABE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/szSSdM", "id": "2395015640772174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982637_2395015644105507_1151433955568779264_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HQLrdcW1gj0Q7kNvgFX7yln&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwt3bES3QDSEZN9pT7j9KH9dh4Q2kAMN6lTi5GIMW1HA&oe=674EE334"}, "display_name": "Synth Riders", "keywords": ["music", "rhythm", "beat", "audio", "fitness"], "long_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game. \n\nSynth Riders absolutely loads your senses for an experience that\u2019s truly unique, unforgettable and simply a blast to play.\n\n- 21 top songs and new top artists added regularly\n- World leaderboards taking advantage of Quest\u2019s brand new social features and includes cross-platform support\n- Different modes that keep the game fresh, including force mode for harder workouts and challenges\n- An active community supporting and creating infinite forms of gameplay\n- Multiplayer coming soon", "short_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.synthridersvr.com/", "publisher_name": "Kluge Interactive", "support_website_url": "https://www.synthridersvr.com/contact", "website_url": "https://www.synthridersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices"