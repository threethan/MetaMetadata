://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001728_1653383734791707_4392752019018874880_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MODZmL2Js_0Q7kNvgEZX88J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJaNmih1C1Y2sRmHXl4klnE1wWzEswx6qaXfJEsRDbXA&oe=675C2E63"}, {"file_name": "migrated_image.png", "id": "327933284831942", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031647_417935015578012_2400822427098546176_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=au-jEDx43B0Q7kNvgGSbH06&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBmUSBY6LuoHHJdLN6MSNzx03AIWP5798GJVryg4FG4Cg&oe=675C29BE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/szSSdM", "id": "2395015640772174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982637_2395015644105507_1151433955568779264_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F30RYot8o5sQ7kNvgFUy2hI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQDguc0gEVS1XAkEifnO0jjDehIeyM4bm4q8urmlzYtQ&oe=675C1234"}, "display_name": "Synth Riders", "keywords": ["music", "rhythm", "beat", "audio", "fitness"], "long_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game. \n\nSynth Riders absolutely loads your senses for an experience that\u2019s truly unique, unforgettable and simply a blast to play.\n\n- 21 top songs and new top artists added regularly\n- World leaderboards taking advantage of Quest\u2019s brand new social features and includes cross-platform support\n- Different modes that keep the game fresh, including force mode for harder workouts and challenges\n- An active community supporting and creating infinite forms of gameplay\n- Multiplayer coming soon", "short_description": "Synth Riders is a game about experiencing incredible music in a whole new way. You\u2019ll feel it as your arms soar when riding our unique rail system and instantly know you\u2019re in the music.\n\nFrom the diverse environments, lighting, the carefully crafted beat maps, the catchy rhythms and melodies, the way the notes flow, how notes and obstacles make your body move, the way the haptics feel, and so many other tiny details from the love put into this game."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.synthridersvr.com/", "publisher_name": "Kluge Interactive", "support_website_url": "https://www.synthridersvr.com/contact", "website_url": "https://www.synthridersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2138383172983119"}}]}, "scheduled_offers": {"count": 65, "nodes": [{"status": "PUBLISHED", "id": "1369444894460822"}, {"status": "PUBLISHED", "id": "526745549716920"}, {"status": "PUBLISHED", "id": "818991513654706"}, {"status": "PUBLISHED", "id": "1128449555095908"}, {"status": "PUBLISHED", "id": "3283304098614662"}, {"status": "PUBLISHED", "id": "592062792328426"}, {"status": "PENDING", "id": 