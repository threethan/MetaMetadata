_nc_sid=6e7a0a&_nc_ohc=jev5mbVTY1YQ7kNvgE6l1MD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6hiyyKDgax8QsR1_ERiZ5fI5YoM3nbvm5u20boc194g&oe=675C081E"}]}, "id": "1734662614000813", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 5 (2560x1440).png", "id": "548421174496831", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974796_548421181163497_2936921495505607029_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ID6Op8ez4GAQ7kNvgHROwiv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHWDuD_ex9Hd1S9cEsZXcap7A-S58ot4aKHM8yUk2Tzg&oe=675C0412"}, {"file_name": "Screenshot 2 (2560x1440) Copy.png", "id": "465647376093272", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035339_465647379426605_3807672220051445626_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fkTyxi46aVwQ7kNvgHYhGXP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTlTVXOhoAlxVZmIdnArUPD4I_2mKhfbhfqRP1tfSiEw&oe=675C0D6B"}, {"file_name": "Screenshot 3 (2560x1440).png", "id": "1121410219495630", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974652_1121410222828963_6544871318944044434_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jl9gwL9o9-sQ7kNvgEFCmu0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5IqHYq60P3B2DsZ7yTN_NgvzFAGUg0YV2JGRDFvicqQ&oe=675C13FF"}, {"file_name": "Screenshot 2 (2560x1440) Copy (1).png", "id": "792590946325838", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984462_792590949659171_3507267126315424421_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QrPvXHwWdWIQ7kNvgF_y_cu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAW9hY5UKGTBZKRbXvtfGuFUAITH0CMpkCL7YAm4DzceQ&oe=675C1435"}, {"file_name": "Screenshot 2 (2560x1440).png", "id": "1688759028360682", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035448_1688759031694015_5457448987176639351_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ucshLvK16LkQ7kNvgEzTrfZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_2DYAIGOZChIOh4Sh73bJri2iAbbzf86Ak8H48scouQ&oe=675C0E94"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "bbdnd_srx_storewip_meta_landscape.png", "id": "458100140217277", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982456_458100143550610_711186060220961288_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pHW4oATvSoYQ7kNvgEwYqQ-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBKul9-whEl9ZvUWM7OE5kKQGJ3sg9Bt2SmhRQk2ZB9FQ&oe=675C284E"}, "display_name": "Synth Riders", "keywords": ["music", "rhythm", "beat", "fitness", "mixed"], "long_description": "# New DLC Available for Purchase today!\n\nFor the first time in a VR rhythm game, enter the world of **Barbie\u2122** through an immersive musical **Synth Riders Experience\u2122**! \n\nA world inspired by Barbie flows all around you while you play and dance to the rhythm. Soak in rays at the beach and groove at the roller disco while bopping along to K-pop hit, **\u201cBarbie Dreams (feat. Kaliii)\u201d by FIFTY FIFTY from Barbie\u2122 the Album**.\n\n# About Synth Riders\n\nLet the music move you in a unique combination of freestyle dancing & fitness workout that\u2019ll make you to burn calories while having tons of fun, in full VR or Mixed Reality!\n\n\"Accessible, fun, and an absolute must-have for anyone with a VR headset.\"\n9.5/10 - GamingTrend\n\n\u201cAn amazing physical experience that involves the entire body.\u201d\n8.8/10 - VR Fitness Insider\n\n\u201cBrilliant gameplay and exceptional soundtrack.\u201d\n9/10 - Push Square\n\n- Play, dance & exercise to 75 included tracks\n- Have fun in 10 player cross-platform multiplayer\n- Customize your experience with a range of features, including custom song support and Mixed Reality mode.\n- Play your way with a tremendous variety of gameplay modifiers & styles, such as Spin & Spiral modes\n- Discover 13 optional DLCs adding 7 visually stunning experiences & 68 songs from artists such as Gorillaz, Muse, Bruno Mars, Lindsey Stirling, Caravan Palace & more!\n\n\nBARBIE\u2122 and any associated trademarks  and trade dress are owned by, and under license from, Mattel. \u00a92024 Mattel.", "short_description": "New Synth Riders Experience\u2122 Available for Purchase today!\n\nFor the first time in a VR rhythm game, enter the world of Barbie\u2122 through an immersive musical Synth Riders Experience\u2122! \n\nLet the music move you in Synth Riders, a dance-action rhythm game packed with 75 included & 68 DLC songs that will make you party all night! \n\n\"Accessible, fun, and an absolute must-have for anyone with a VR headset.\" 9.5/10 - GamingTrend"}, {"images": {"nodes": [{"file_name": "Landscape Korean (2560x1440).png", "id": "4380771405382668", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75324645_4380771418716000_1466639104384545928_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SM3RWeGW09cQ7kNvgGxBPe0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ8c9070kqkclC59YzBOGSbR2oHuphaJJ2ppmj3xNZsA&oe=675C15F7"}, {"file_name": "VR Landscape Korean (1080x360).png", "id": "3178479692381808", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375772_3178479695715141_3240691111789696281_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QmD-XZEVjtwQ7kNvgENds17&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJGXofcK4GfgO1gweMwA385H5FRkAu5bJb7zjNHYAVgA&oe=675C1C1D"}, {"file_name": "Hero Korean(3000x900).png", "id": "1310510096052385", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580066_1310510099385718_4209684345890756287_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ik2fbFswBpQQ7kNvgGSqvq3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBp1qNJIOs_6MquEUVYFV-7DImgHtEMdQYRuFO8RnGk1g&oe=675C26A2"}, {"file_name": "Portrait Korean(1008x1440).png", "id": "651628275992847", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://sco