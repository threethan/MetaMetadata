d the waters of ancient seas. But Earth shifted once again and another metamorphosis began. It left in its wake oceans of salt layers, one lone river and a dying sea\u201d"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vTB9QkEglEoGWqRiiejtmGluAKDptYFAgijYU1fjypF3J8n1QQQVWJ1R5-_1hUzRkqSCDwaxKOhSJew/pub", "developer_terms_of_service_url": null, "publisher_name": "Blimey", "support_website_url": null, "website_url": "http://blimey.tv/blog/welcome-to-our-blog-but-what-is-it", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "649803076263759"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1322921591469398"}]}, "baseline_offer": {"id": "1322921591469398"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1644619620, "status": "PUBLISHED", "id": "1322921591469398"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5286936104734282", "version": "3"}, "id": "940769666836430", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4673576826070216", "is_concept": false, "latest_released_binary": {"__typename": "A