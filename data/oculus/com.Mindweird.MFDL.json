g life. You can either help him out or fork things up as you choose who he dates in this interactive VR romantic-comedy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mindweird.com/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Mindweird", "support_website_url": null, "website_url": "http://www.mindweird.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3281341681961503"}, {"id": "447840929525167"}, {"id": "337573230800174"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24877836225193556"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "300139389251009"}]}, "baseline_offer": {"id": "300139389251009"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1710192600, "status": "PUBLISHED", "id": "300139389251009"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24898901369753708", "version": "2.1.5"}, "id": "1682496322167578", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8728935483843554", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "24898901369753708"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "L