860492387_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G5pdBaBKXl8Q7kNvgFHL8EK&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAr4tjE836obxy-1qT4Z80VljKHkZHL3VwNjiy3r109ew&oe=6707B1E0"}, {"file_name": "bestMFDL_2560x1440_121.png", "id": "253432307398516", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974756_253432310731849_567586541239218082_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aq23AfaPxnMQ7kNvgESfv5r&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhSF7CUaghhLLjuM38vBUtPXk28WvIcI4M5GAoWoD3Fw&oe=6707D1A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 x 1440 MFDL Wyatt Billboard rev.png", "id": "842574890974146", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566682_842574894307479_7527762273476649291_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sYmWCBVkWyAQ7kNvgFLczH-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7j9noX5TUqNQoB1zjYbFedT37USlGAjsZTG6eWKzwqQ&oe=6707ADD9"}, "display_name": "My Forked Dating Life", "keywords": [], "long_description": "In this interactive romantic comedy, Wyatt, a biker with a disability, wheels through the dating scene with style and confidence, only he\u2019s not in control of who he dates next\u2026 you are!  Help Wyatt navigate the awkwardness of dating and online profiles on the dating site \"Sausage and Muffins.\" With hilarious dating profile videos from Madyson, a hippie who runs a pet shop, and Olivia, a blunt but charming writer, Wyatt finds himself on a wild adventure to find love and share the moments with someone special. Will he find the one or will he be stuck riding solo forever? You help decide his fate in \"My Forked Dating Life.\"", "short_description": "Ready to hang up his lone-wolf status, a biker with a disability finds himself at a crossroads in his dating life. You can either help him out or fork things up as you choose who he dates in this interactive VR romantic-comedy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://m