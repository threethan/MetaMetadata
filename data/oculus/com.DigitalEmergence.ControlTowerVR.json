b=1-7&_nc_sid=6e7a0a&_nc_ohc=Jdz4OUFnqIQQ7kNvgEPaUok&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpXNKhGIi_L1ZONlkxNgFLNMV0UKu9XStrGYVG7pkBew&oe=675300FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ControlTowerVR_Oculus_Banner_Large.png", "id": "1462741121195775", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75303840_1462741124529108_7229600463246882697_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fIClJEbF3xIQ7kNvgHW1R92&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnKL398HKrxY2ZxoKZciPxzoUN0XJKAOaD5LXonf-ktQ&oe=6752D850"}, "display_name": "Control Tower VR", "keywords": ["airplane", "plane", "atc", "flight", "controller"], "long_description": "Control Tower VR puts the player in the role of an air traffic controller that draws lines in 3-dimensional space to guide each aircraft to its runway while avoiding other aircraft and obstacles in the environment. There are 5 types of aircraft to land: commercial airliner, private plane, glider, helicopter, and zeppelin. Each aircraft present a different set of characteristics, for example, a glider cannot climb unless it is in an updraft.\n\nThere are 2 game modes: Play Now and Career.\n\u201cPlay Now\u201d is an open-ended gameplay; the player must safely land as many aircraft as possible while the difficulty increases over time. \u201cCareer\u201d is also open-ended gameplay but requires a minimum target score to a medal which unlocks the next map. Career mode offers a variety of challenges such as UFO attacking your planes or having airplanes go next to a point of interest before landing. \nBoth Play Now and Career has 5 different maps, each presenting a different set of challenges. ", "short_description": "Control Tower VR puts the player in the role of an air traffic controller that draws lines in 3 dimensional space to guide each aircraft to its runway while avoiding other aircrafts and obstacles in the environment. There are 5 types of aircraft to land: commercial airliner, private plane, glider, helicopter and zeppelin on 5 different maps. Each aircraft present a different set of characteristics, for example a glider cannot climb unless it is in an updraft."}]}, "developer_name": "Digital Emergence Ltd", "developer_privacy_policy_url": "https://controltowervr.weebly.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Digital Emergence Ltd", "support_website_url": null, "website_url": "https://controltowervr.weebly.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8510279742383820"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003240_1608195706340658_8885868801352132357_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-pzHeG6-X10Q7kNvgF2hVNG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDLgNImg1JwA89d3fAA8A8Kmtf5Xb2FohVaIc8DnymL_w&oe=6752CD4E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Control Tower VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1692908977, "lastRevision": {"nodes": [{"id": "122777120274140", "release_type": "SCHEDULED",