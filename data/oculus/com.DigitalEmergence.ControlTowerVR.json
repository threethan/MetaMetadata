384379_1389812290659930738_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HsXw65CzU0cQ7kNvgHAAhaj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCb7SCMsgq8eYS-x6EFxDe60HWU3V2feH-9PvFc8SQJ5w&oe=66D85263"}]}, "id": "26543414231939653", "locale": "en_US", "screenshots": [{"file_name": "InsideTower.png", "id": "647491923763308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_647491927096641_3218717068688940304_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pnUfM_JW-MYQ7kNvgHfYxVT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXRYgZLKEnj5saDaR8n97u1fykiV5MxwdmiezEZwcXCg&oe=66D847F2"}, {"file_name": "IslandMap2.png", "id": "274244795296839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974593_274244798630172_8831061919729667753_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CHlPUvVV7EgQ7kNvgFgNlXL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwxje-oIBqnXej4RweFUX-OZ9g7ECAFV-gVVU-hC9BMQ&oe=66D8386C"}, {"file_name": "Explosion.png", "id": "1582473022283921", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429292_1582473025617254_8880973784013326554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-_u9jHeaBYwQ7kNvgEHZUiD&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjiKfxD8Qu_KWROgYjRLer0sAxp6VlkoMlW2Jmd7jWgA&oe=66D8299F"}, {"file_name": "MountainMap.png", "id": "236155306004996", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86629766_236155309338329_5652908726960707139_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=48iTTq5lu9EQ7kNvgEB_Ivh&_nc_ht=scontent.oculuscdn.com&oh=00_AYBC1a6EGAI2l_SA0FX9jvIni2IEyYKyizBPLiWFbMRP0w&oe=66D83C88"}, {"file_name": "CityNightMap.png", "id": "814210383701157", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392879_814210387034490_2905782898928723536_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AfuifTb9iNYQ7kNvgF71e8C&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRAx0UVDaSON2vwBav6A50nfgmVzly2yOXtW3LitB8lA&oe=66D82D3B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ControlTowerVR_Oculus_Banner_Large.png", "id": "1462741121195775", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75303840_1462741124529108_7229600463246882697_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mUysVZ0Ya24Q7kNvgF6FQQf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDGQxHRhHiMgxfyD5mZECZF36fgaa5DndqL7Ij4dnT7Aw&oe=66D83CD0"}, "display_name": "Control Tower VR", "keywords": ["airplane", "plane", "atc", "flight", "controller"], "long_description": "Control Tower VR puts the player in the role of an air traffic controller that draws lines in 3-dimensional space to guide each aircraft to its runway while avoiding other aircraft and obstacles in the environment. There are 5 types of aircraft to land: commercial airliner, private plane, glider, helicopter, and zeppelin. Each aircraft present a different set of characteristics, for example, a glider cannot climb unless it is in an updraft.\n\nThere are 2 game modes: Play Now and Career.\n\u201cPlay Now\u201d is an open-ended gameplay; the player must safely land as many aircraft as possible while the difficulty increases over time. \u201cCareer\u201d is also open-ended gameplay but requires a minimum target score to a medal which unlocks the next map. Career mode offers a variety of challenges such as UFO attacking your planes or having airplanes go next to a point of interest before landing. \nBoth Play Now and Career has 5 different maps, each presenting a different set of challenges. ", "short_description": "Control Tower VR puts the player in the role of an air traffic controller that draws lines in 3 dimensional space to guide each aircraft to its runway while avoiding other aircrafts and obstacles in the environment. There are 5 types of aircraft to land: commercial airliner, private plane, glider, helicopter and zeppelin on 5 different maps. Each aircraft present a different set of characteristics, for example a glider cannot climb unless it is in an updraft."}]}, "developer_name": "Digital Emergence Ltd", "developer_privacy_policy_url": "http