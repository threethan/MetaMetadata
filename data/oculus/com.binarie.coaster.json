yw0-KyekEKMweTxl3b6BxG8A&oe=66DD7FBC"}, {"file_name": "migrated_image.png", "id": "215708209541219", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162717_1997668163581743_5050670128920788992_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NADcRHlESYEQ7kNvgGN7E5d&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqADAILhjBp-fkbymaZMPliSnY5bnrY2kTD4WLGG__dQ&oe=66DDA05F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store_2560x1440.png", "id": "457864648002529", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12602063_457864651335862_3663465004495011840_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bntp9jDdXHwQ7kNvgHNkjhY&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8qvRdl2EOG_VIaIy77jRtWKjsdPbaSlUaXKvx9fgb0Q&oe=66DD888B"}, "display_name": "Coaster", "keywords": ["Rollercoaster", "Roller", "Coaster", "Ride", "Fun"], "long_description": "Experience the thrill and sensation of 4 unique roller coaster experiences. Feel the wind rush through your virtual hair as you ride some of the most enjoyable and immersive VR coasters on the market.\n\nJourney into each exceptional environment and enjoy extended coasters from a range of different perspectives. Get ready to swoop around asteroids in Space Coaster, fly with a bee\u2019s eye view in Picnic Coaster, dive and loop around like never before in Room Coaster and explore a dystopian mining colony in Moon Coaster.\n\nSometimes intense, always exhilarating, 4 awesome attractions at a great value price.  \n\nCheck out Coaster today\n\nDon\u2019t forget to rate and leave a review!\n\nThanks and enjoy :)", "short_description": "Experience the thrill and sensation of 4 unique roller coaster experiences. Feel the wind rush through your virtual hair as you ride some of the most enjoyable and immersive VR coasters on the market."}]}, "developer_name": "Monster Paw Games", "developer_privacy_policy_url": "http://monsterpawgames.com/", "developer_terms_of_service_url": "http://monsterpawgames.com/", "publisher_name":