rough your virtual hair as you ride some of the most enjoyable and immersive VR coasters on the market."}]}, "developer_name": "Monster Paw Games", "developer_privacy_policy_url": "http://monsterpawgames.com/", "developer_terms_of_service_url": "http://monsterpawgames.com/", "publisher_name": "Monster Paw Games", "support_website_url": null, "website_url": "http://monsterpawgames.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "CASUAL", "EXPLORATION", "ROLLER_COASTER", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "653141579069182"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12449084_117917599073255_5180859684403281920_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w9t4rrfQg2sQ7kNvgH0G25O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBA2dgizcvsmYfK2EHewc-rjirEov5eUb8iQYawuOp7Rw&oe=676A9213"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Coaster", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1482170400, "lastRevision": {"nodes": [{"id": "1215162588523470", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1135654449807002", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translations": 