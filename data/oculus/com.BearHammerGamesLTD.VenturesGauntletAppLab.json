c_ohc=YmbTpQDIyi4Q7kNvgHQb-JR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUqZHKrWZJEjioVxTObw6SwPJnOkZupBKXyeN_G12UaA&oe=66F7D4ED"}]}, "id": "444070985128007", "locale": "en_US", "screenshots": [{"file_name": "SC26.png", "id": "964420118677466", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031510_964420125344132_7279037948266946186_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=abBtaulbiJIQ7kNvgGx_qX0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWjS4LrYInMhhblTAyMiZmHJvlDQTotGlfuApQykJ_aQ&oe=66F80445"}, {"file_name": "SC19.png", "id": "1028550412168366", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031459_1028550415501699_7667063941983084531_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JP02VkJiAewQ7kNvgHfRVi8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmrmR_-yg2eaOalTd9ijShWJVwmgz0qsPG1ukoMnrT6g&oe=66F801EC"}, {"file_name": "SC6.png", "id": "1213008986735069", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982453_1213008990068402_721949442093583782_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xX--ZacLR5YQ7kNvgERTeCw&_nc_ht=scontent.oculuscdn.com&oh=00_AYALhntj2kJiZdew2wlGBbGhf-Khw9fRCUeimxVxFkvnnQ&oe=66F7DD60"}, {"file_name": "SC25.png", "id": "2182709462063835", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_2182709465397168_1136481695964559917_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LlijmaYwJCUQ7kNvgGWskIQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKyWFwtoH6rjw-qxMxzNc2VAQqbw0KczGARvkUFqbpYQ&oe=66F7D276"}, {"file_name": "SC11.png", "id": "1020526033014243", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250452_1020526036347576_3573329723363051043_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aT-k1Uip7h0Q7kNvgGxd2QH&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3TLGu3S6sm40FjcD_sTigcZ8Q7jQ8DoM1O2sQqCWVIQ&oe=66F8002F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1670277503511368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974650_1670277506844701_2413630122857125207_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ekHZ_2c_sXMQ7kNvgHUAx3g&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8d-UJdKc_ZFnSnIzksh0GjfS6En1aFP06Po1Inc1xBg&oe=66F7D895"}, "display_name": "Venture's Gauntlet", "keywords": [], "long_description": "# VR's Ultimate Action-Platformer\n\nObsessed with his family's legacy, aging billionaire Adam Venture is looking for a capable heir to the Venture name and fortune. His only requirement? The skill and tenacity to overcome a series of deadly obstacle courses known as: **Venture\u2019s Gauntlet**\n\n{960204795511693}\n\n# Comfortable Locomotion \n\nRun, climb, swing and zipline your way through the gauntlet in comfort and style with **TrueMotionVR** arm swing controls.\n\n\n# Overcome Dangerous Challenges\n\nKiller-drones, deadly lasers, fatal drops and more all stand along the path to glory. Only the most capable will survive.\n\n{472666925095689}\n\n# Embark On An Epic Journey\n\nTraverse giant cliffs, delve into the depths of the earth and climb crumbling castles across 9 intense stages inspired by the Highlands of Scotland.\n\n{2173852816328585}\n\n# Breathtaking Visuals\n\nExperience beautiful graphics powered by Unreal Engine. A dynamic time of day and weather system makes the world feel alive as you progress through the Gauntlet.\n\n{408266168650091}\n\n# Uncover the secrets of the Ventures\n\nThe ever-present Adam Venture watches your every move. Do you have the skill to impress him, or will you be a disappointment like all the others?\n\n{1446632349279537}\n\n# Tailor Made Courses\n\nCalibration adjusts the Gauntlet\u2019s obstacles to your height & arm length measurements to ensure the best experience for all users.\n\n# Claim the ultimate glory\n\nCompete against other players for the best times on each stage on the online leaderboards.\n\nSo ask yourself this -  do **YOU** have what it takes to run the Gauntlet?\n\nWe think you can do it!!\n\n\n\n\n\n\n", "short_description": "Venture\u2019s Gauntlet is an intense parkour & obstacle course game that features arm swing movement, climbing, archery, moving lasers, shooter drones, shields, and more.  \n\nPlaying the game is an immersive physical experience, a test of both fitness and skill because you are the one running, climbing, and dodging through challenging courses!  \n\nKiller-drones, deadly lasers, fatal drops and more all stand along the path to glory. Only the most capable will survive and claim Adam Venture's fortune.\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bearhammergames.com/privacypolicy/", "developer_terms_of_service_url": "https://bearhammergames.com/eula/", "publisher_name": "BearHammer Games Ltd", "support_website_url": null, "website_url": "https://bearhammergames.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8208390875867425"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974887_1128237098292392_9105714002800348117_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TpAsA0A7VLoQ7kNvgF7kb3f&_nc_ht=scontent.oculuscdn.com&oh=00_AYCf0SMeT7ehkLnS-iZqHgjWOpHrhfJzt7jzlPODMsfZ6Q&oe=66F80113"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Venture's Gauntlet", "platform": "ANDROID_6DOF", "context_category": {"context_categor