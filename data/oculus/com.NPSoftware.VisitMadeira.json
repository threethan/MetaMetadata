: "481299008081167", "locale": "en_US", "screenshots": [{"file_name": "Madeira_v0_23_.png", "id": "2664915457017769", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974614_2664915463684435_7025851192426820138_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qLFcMHCXc_cQ7kNvgEfHJSp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfkWjKjPRh-nwHEihgXkpqhCoVA5-XbrGUWTYkaDODfQ&oe=67066FC6"}, {"file_name": "MadeiraStart_screenshot_2.png", "id": "103030302822281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569428_103030306155614_1542125922620018982_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=00PrQu5ggz0Q7kNvgERHFfC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjLyJaZsf2beKuDEVQ3EmpJhBExyqrvkZy5rHhXhAsbw&oe=6706807D"}, {"file_name": "MadeiraStart_screenshot_3.png", "id": "282511007558120", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974716_282511010891453_2716856767606707530_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iu9VQRDB-XgQ7kNvgEcY_by&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAkEMXshD3qeUsKbXjG4ZilaLj8lGhXC4_uxzJOz1lRA&oe=67068265"}, {"file_name": "Sao_Jorge_Gate_scaled.png", "id": "1213929343133606", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974547_1213929349800272_5700380456411247427_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ntnuJacLrMkQ7kNvgGMpyAt&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxAQG5_me4ArTFDBLoC6jwjAjIEy6Ge46xvuorpsMGRg&oe=6706793F"}, {"file_name": "MadeiraStart_screenshot_5.png", "id": "1296598017609030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_1296598020942363_2385486776623640381_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8WzkW1fDSEQ7kNvgHGoE4d&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRWdq4Q64YnAw10YbOOXPfqhkCFrAJjB0b45oKuMXDHg&oe=67067AAD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "731707592244519", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_731707598911185_6842667435744127897_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KEkZ66TpNFMQ7kNvgHOqeYe&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDpVY6qamU4-g1Vk9m5H-Lzqrh5IP9m_0_bLdgpT93Waw&oe=670686DF"}, "display_name": "Visit Madeira", "keywords": ["Travel", "Explore", "Nature"], "long_description": "Have you ever been in ***Madeira***? Did you ever saw the beauty that this island can offer? Now you got an opportunity to fast travel there, just by putting your headset on. \n\nImmerse yourself into ***360 3D videos*** of the nicest locations on the island. Let your headset take you there in ***full 360 3D with spatial audio in max allowed quality***. \n{927982805825055}\n\nFeel the heights of the cliffs, the beauty of the hills and forests. Relax on a beach, walk along levadas or visit Funchal . \n\nListen to a ***narrative voice over description of each location in English, Chinese, German and Portuguese!*** \n\n{523360923574946}\nCurrently there are ***73 viewpoints from 21 scenes***, where you can travel.\nIn each scene (touristic hot spot) you have usually around ***3-7 viewpoints***, where you can immerse yourself into the beauty of Madeira. \n{1050616439835900}\n\nList of the included locations:\n- ***Pico Areeiro***\n- Porto Moniz\n- ***Fanal Forest***\n- Arco de Sao Jorge\n- Ruins of Sao Jorge\n- Santana\n- Miradouro do Guindaste\n- ***Levada do Cadeir\u00e3o Verde***\n- Achada Cruz\n- Casas Madeirenses\n- Igreja de Nossa Senhora do Monte\n- Levada Faja do Rodrigues\n- Miradouro Arco de Sao Jorge Pequeno\n- Miradouro Farol da Ponta do Pargo\n- Miradouro do Pico do Fortim\n- ***Monte Palace Tropical Garden***\n- ***PR1 trail***\n- Praia de Ponta do Sol\n- ***Praia do Porto do Seixal***\n- ***Ribiera de Janela***\n- Capelinha de Nossa Senhora de F\u00e1tima\n- Cais da Esperan\u00e7a\n\nIt might be one of the biggest apps in your headset, but I hope the experience is really worth it. (After in app downloads ***13GB***)\n\nYour next holiday is just a point and click away! \n\nEnjoy it now!\n\n{1702291367231528}\n\n", "short_description": "Have you ever been in Madeira? Did you ever saw the beauty that this island can offer? Now you got an opportunity to fast travel there, just by putting your headset on. \n\nImmerse yourself into 360 3D videos of the nicest locations on the island. Let your headset take you there in full 360 3D with spatial audio. Feel the heights of the cliffs, the beauty of the hills and forests. Relax on a beach or visit Funchal . \n\nYour next holiday is just a point and click away! \n\nEnjoy it now!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://npsoftware.at/visit_madeira/PrivacyPolicyVisitMadeira.html", "developer_terms_of_service_url": "https://npsoftware.at/visit_madeira/TermsAndConditionsVisitMadeira.html", "publisher_name": "NP Software", "support_website_url": "https://npsoftware.at/index.php/contact-us/", "website_url": "https://npsoftware.at/index.php/portfolio/visit-madeira/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "687057922013375"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "zh_CN", "pt"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8102210519875421"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/428982225_493778733352373_7221967431641820537_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc