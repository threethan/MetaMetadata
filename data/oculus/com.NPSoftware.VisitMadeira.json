1-7&_nc_sid=6e7a0a&_nc_ohc=TvsFpd0WnkIQ7kNvgGQ7CAm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlsPwkDcqcHavH8Ub9rI74V-I_Mp9Jl5o0ZVZnnqfeGA&oe=67065B99"}, {"file_name": "MadeiraStart_screenshot_2.png", "id": "103030302822281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569428_103030306155614_1542125922620018982_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=00PrQu5ggz0Q7kNvgERHFfC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjLyJaZsf2beKuDEVQ3EmpJhBExyqrvkZy5rHhXhAsbw&oe=6706807D"}, {"file_name": "MadeiraStart_screenshot_3.png", "id": "282511007558120", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974716_282511010891453_2716856767606707530_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iu9VQRDB-XgQ7kNvgEcY_by&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAkEMXshD3qeUsKbXjG4ZilaLj8lGhXC4_uxzJOz1lRA&oe=67068265"}, {"file_name": "MadeiraStart_screenshot_4.png", "id": "1275744626369177", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974862_1275744629702510_7868136726062868530_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r3Cp8KP1rAIQ7kNvgGltNcO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnUF94Tbe3knR1nIw_PVDhDbgUw2lMMbjse5kY1r0CXQ&oe=670673A7"}, {"file_name": "MadeiraStart_screenshot_5.png", "id": "1296598017609030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_1296598020942363_2385486776623640381_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8WzkW1fDSEQ7kNvgHGoE4d&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRWdq4Q64YnAw10YbOOXPfqhkCFrAJjB0b45oKuMXDHg&oe=67067AAD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Visit Madeira", "keywords": [], "long_description": "Have you ever been in Madeira? Did you ever saw the beauty that this island can offer? Now you got an opportunity to fast travel there, just by putting your headset on. \n\nImmerse yourself into 360 3D videos of the nicest locations on the island. Let your headset take you there in full 360 3D with spatial audio. Let yourself feel the heights of the cliffs, the beauty of the hills and forests. Relax on a beach, walk along levadas or visit Funchal . \n\nListen to a narrative voice over description of each location in English, Chinese, German and Portuguese! \n\nCurrently there are about 14 scenes, where you can travel.\nIn each scene you have usually around 3-7 locations, where you\ncan immerse yourself into the beauty of Madeira. \nBut be careful, sometimes the locations are on an edge of a cliff, or on a glass platform. If you look at them in the immersive 360 3D view, you might get a bit dizzy.\n\nI still have some locations to add and process to the app. Currently there are 51 locations, which you can visit. (A scene can have multiple locations, for example a Touristic hotspot is a scene, but you can move to 3-7 locations withing this hotspot)\n\nThe final app will contain around 25 Scenes, each having 3-7 locations within.\n\nIt might be one of the biggest apps in your headset, but I hope the experience is really worth it. (Currently around 10GB)\n\nYour next holiday is just a point and click away! \n\nEnjoy it now!", "short_description": "Have you ever been in Madeira? Did you ever saw the beauty that this island can offer? Now you got an opportunity to fast travel there, just by putting your headset on. \n\nImmerse yourself into 360 3D videos of the nicest locations on the island. Let your headset take you there in full 360 3D with spatial audio. Let yourself feel the heights of the cliffs, the beauty of the hills and forests. Relax on a beach or visit Funchal . \n\nYour next holiday is just a point and click away! \n\nEnjoy it now!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://npsoftware.at/visit_madeira/PrivacyPolicyVisitMadeira.html", "developer_terms_of_service_url": "https://npsoftware.at/visit_madeira/TermsAndConditionsVisitMadeira.html", "publisher_name": "NP Software", "support_website_url": null, "website_url": "ht