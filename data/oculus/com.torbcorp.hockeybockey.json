tent.oculuscdn.com&_nc_gid=Ax-5IXzVi34II5_AZmteJFt&oh=00_AYCBQ2fTOQ7fARSQRfSLYLGGXIJgPZkAG8L2J_meJQdDWQ&oe=66E18A1B"}, {"file_name": "curved_walls.png", "id": "573951296971980", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984440_573951300305313_7063127277047755046_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ndAs50sFcmAQ7kNvgFg1wE3&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ax-5IXzVi34II5_AZmteJFt&oh=00_AYCm378H-yiDLroCt8USB9Sc7HRRjUkpQEy42FPXU--7Tg&oe=66E162F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "hockeybockeyCOVER.png", "id": "1194531554292049", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_1194531557625382_2309043283139476511_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=86BKLmSMS44Q7kNvgFtwxhY&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ax-5IXzVi34II5_AZmteJFt&oh=00_AYCPyAnms0CTp6bd9xTzfaV46TYfEUWJz7hob5omkRH_Sw&oe=66E166C0"}, "display_name": "Hockey Bockey", "keywords": [], "long_description": "Hockey Bockey is a fluid and fun VR Sport played on a seamless rink with curved boards. Every aspect of the arena is designed to keep the play moving and to allow the players to make spectacular moves and plays with their friends. AI bots are there to insure you never have an empty game, even when you are playing alone!\n\nFeatures:\n- Features 3v3, 2v2, and 1v1 full multiplayer game modes\n- Dynamic AI Bots that can pass, shoot and check will make sure you always have a full game \n- AI goalies that keep the ball moving and out of your net \n- Curved arena walls allow for astounding trick passes and moves\n- Matches are easy to start and join \n- Practice your moves on a goalie in your private practice rink\n- Customize your player, helmet, pads and stick", "short_description": "Welcome to Hockey Bockey...where hockey is MAGIC!  \n\nSkate, pass, shoot, deflect, block, steal, and deke like a pro! Full online multiplayer with 3 game modes! Never have an empty game with full bot support. Your own skill is your only limit!"}]}, "developer_name": "Jason Rosenstock", "developer_privacy_policy_url": "https://sites.google.com/view/hockeybockey-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Jason Rosenstock", "support_website_url": null, "website_url": "https://sites.google.com/view/hockeybockey", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1095032438016867"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "153236747023740"}, {"status": "PUBLISHED", "id": "1114467619424710"}]}, "baseline_offer": {"id": "1114467619424710"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1633970340, "status": "PUBLISHED", "id": "153236747023740"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7822503374534072", "version": "1.3.6"}, "id": "610091653313288", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4140827699368343", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7822503374534072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "610091653313288"}]}, "change_log": null, "created_date": 1721356680, "id": "7822