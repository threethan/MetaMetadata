ri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_1194531557625382_2309043283139476511_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oVPrsaJs-XIQ7kNvgFQJOgi&_nc_ht=scontent.oculuscdn.com&oh=00_AYC42OpgCgW8QWW61reqOiDmSlHfPnHdW_k-nEOkJLjimA&oe=66FD1640"}, "display_name": "Hockey Bockey", "keywords": [], "long_description": "Hockey Bockey is a fluid and fun VR Sport played on a seamless rink with curved boards. Every aspect of the arena is designed to keep the play moving and to allow the players to make spectacular moves and plays with their friends. AI bots are there to insure you never have an empty game, even when you are playing alone!\n\nFeatures:\n- Features 3v3, 2v2, and 1v1 full multiplayer game modes\n- Dynamic AI Bots that can pass, shoot and check will make sure you always have a full game \n- AI goalies that keep the ball moving and out of your net \n- Curved arena walls allow for astounding trick passes and moves\n- Matches are easy to start and join \n- Practice your moves on a goalie in your private practice rink\n- Customize your player, helmet, pads and stick", "short_description": "Welcome to Hockey Bockey...where hockey is MAGIC!  \n\nSkate, pass, shoot, deflect, block, steal, and deke like a pro! Full online multiplayer with 3 game modes! Never have an empty game with full bot support. Your own skill is your only limit!"}]}, "developer_name": "Jason Rosenstock", "developer_privacy_policy_url": "https://sites.google.com/view/hockeybockey-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Jason Rosenstock", "support_website_url": null, "website_url": "https://torbcorp.bigcartel.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_