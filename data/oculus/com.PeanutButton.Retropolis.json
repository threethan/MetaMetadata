68997017244506", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974515_968997020577839_6270397460277949170_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=arHWAm_u6c8Q7kNvgHunEuR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPcXtsZUXEjLPBTHWrXFO9YQVD9akAYREcPSYk6l2x_w&oe=671E2C26"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "57572948_497516054931027_4931697810068219177_n.png", "id": "535757434404002", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_535757437737335_5271675859752528110_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bu9_v6wTvEQQ7kNvgEcdUAP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDH_PbA4okj5IkX8tvEzCdDUHMZqZRU4Y4E8kNhWxJGQ&oe=671E3CE2"}, "display_name": "The Secret of Retropolis", "keywords": [], "long_description": "The Secret of Retropolis is a VR narrative game of a new kind, a blend of classic point-and-click adventure with immersive cinematography. Embody the witty protagonist of a film noir plot. Meet unforgettable characters. Solve puzzles. Lose yourself in the retro-futuristic atmosphere.\n\nEXPERIENCE IN COMFORT.\nAs a seated experience with intuitive controls, first time VR users will find this game engaging and easy to play. Experienced VR users will find this game casual and relaxing.\n\nSTORY. ART. MUSIC.\nEnter a sprawling retro-futuristic cityscape with an original score, ensemble of voice actors and detailed hand drawn (in VR!) environments.\n\nGOOD \u2018OL ADVENTURE GAME\nBoot up that nostalgia for your favorite 90's point-and-click adventure games. Look around. Find items. Solve puzzles. Keep the past alive.\n\n\n* No robots were harmed in the making of this game.", "short_description": "The Secret of Retropolis is a VR narrative game of a new kind, a blend of classic point-and-click adventure with immersive cinematography. Embody the witty protagonist of a film noir plot. Meet unforgettable characters. Solve puzzles. Lose yourself in the retro-futuristic atmosphere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://peanutbutton.net/privacy", "developer_terms_of_service_url": null, "publisher_name": "Peanut Button", "support_website_url": "http://peanutbutton.net/", "website_url": "http://peanutbutton.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "480630163590463"}}]}, "scheduled_offers": {"count": 19, "nodes": [{"status": "PUBLISHED", "id": "1523544714949834"}, {"status": "PUBLISHED", "id": "3753350611596603"}, {"status": "PUBLISHED", "id": "7917731701603575"}, {"status": "PUBLISHED", "id": "415174141420058"}, {"status": "CANCELLED", "id": "1017356930021582"}, {"status": "PUBLISHED", "id": "1918347958608838"}, {"status": "PUBLISHED", "id": "609635484578890"}, {"status": "CANCELLED", "id": "549788310316533"}, {"status": "PUBLISHED", "id": "252606794506925"}, {"status": "PUBLISHED", "id": "127259620363651"}, {"status": "PUBLISHED", "id": "1777593695914656"}, {"status": "PUBLISHED", "id": "1577672412764997"}, {"status": "PUBLISHED", "id": "188658530097787"}, {"status": "PUBLISHED", "id": "359028722715705"}, {"status": "PUBLISHED", "id": "1420311331908296"}, {"status": "PUBLISHED", "id": "922264732106040"}, {"status": "PUBLISHED", "id": "1017794389409263"}, {"status": "PENDING", "id": "653107300253024"}, {"status": "CANCELLED", "id": "393135528765300"}]}, "baseline_offer": {"id": "922264732106040"}, 