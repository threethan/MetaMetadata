dn.com&oh=00_AYBOpNVmV85nsiXO8IFgPEq5abaNAmdy3lHhOgbZqRcG0w&oe=6764180D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_ASP_CoverImage.png", "id": "865693635411839", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031309_865693638745172_2747540183598569721_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SmXNykqHtwQQ7kNvgG031zi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbhhR4YlJ21-dxG3i5fr-DM0jVlBh2IChl-DRPsSxWCw&oe=6764028D"}, "display_name": "A Space Pawdyssey", "keywords": [], "long_description": "# Embark on A Space Pawdyssey!\n\nYou play **Astra**, a smart, sweet and ambitious husky, sent on a space exploration mission by the human-led organization called PAWSA.\n\nAstra is joined by a quirky team of companions **SBURD**, a deranged goose that only communicates through honks and unsettling stares; **Albert the XV**, a cynical and well-educated monkey, that is also the team\u2019s weapon expert; and **Luna**, an adorable, but slightly neurotic mouse suffering from space allergies and a massive crush on the goose.\n{949438840336802}\n\n\n The team is tasked with traveling to two mysterious planets to collect three vital ingredients for analysis, providing insights into newly discovered celestial bodies. \n{606909931764369}\n\n\nAlong the way, they face a series of **wild adventures** and **chaotic disasters**: \n{413392028505368}\n\nLuna gets launched across the first planet by an uncontrollable sneezing fit, a **meteor shower** pummels the second planet, and a **space battle** erupts with French cat astronauts. \n\nFrom **reactor reboots** to electrical malfunctions and the unclogging of the ship\u2019s engines after a vicious **chicken \"bowel movement\" attack**, this crew has to master it all.\n\n{549656377922356}\nThese adrenaline-packed challenges are paired with fun **puzzle** and **rhythm-based** mini-games, which serve as the key to experimenting with the collected ingredients.\n\n\n\n", "short_description": "Join the space pack and embark on a high-stakes cosmic adventure: Battle meteor storms, rival feline-astronauts, and chaotic mishaps like sneezing fits and questionable chicken sabotage. Solve puzzles, play rhythm mini-games, and explore newly discovered planets!!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://anotherworldvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "anotherworld GmbH", "support_website_url": null, "website_url": "http://anotherworldvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7106365296111539"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "553604374155924"}]}, "baseline_offer": {"id": "553604374155924"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733421601, "status": "PUBLISHED", "id": "553604374155924"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8764891723592213", "version": "1.0"}, "id": "732523395523574", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7106365289444873", "is_concept": false