253_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMBhfi8dxgIQ7kNvgHBjdZr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpSULj_FmC1hgZ82P8wmkaInABg-HuBWXZiEDSv4BfZQ&oe=66CDCB2D"}, {"file_name": "sc3.png", "id": "6270730466313440", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031612_6270730472980106_8190040581208549115_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E_7u0lIBvfoQ7kNvgFdo_q3&_nc_ht=scontent.oculuscdn.com&oh=00_AYD-qGE8gl_BPAYG6uIW-bdQWCzs615VTwBovF2SAH1f5g&oe=66CDD074"}, {"file_name": "sc4.png", "id": "801009518208489", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974503_801009521541822_5221848288115427578_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMuQdC4VWjkQ7kNvgGEZL6a&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwO7azq02PIFVSYoVWB_LA8MtlK0x-Yn8w8AgbjBQY5g&oe=66CDA78A"}, {"file_name": "sc5.png", "id": "1899108710489742", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982617_1899108713823075_2453402927026108180_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYBCTx4zo1IQ7kNvgFjS9tS&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8bL3_raaTt_4QgCyYl9I4smiR1OwsBRIP-b_n11D25g&oe=66CDA1B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape.png", "id": "1208463843149612", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974909_1208463846482945_6765298824796059065_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PLoaw4RTfOUQ7kNvgHR0SjZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgdOi8na0hcjyP7G4DeY3XcPHOXUtcGg207u6oQbqOgg&oe=66CDAD93"}, "display_name": "Crack the code", "keywords": [], "long_description": "50+ levels with increasing difficulty. Everything starts with the easy ones, so you can get familiar with the mechanics.\nIt's a game for the whole family or for solo play. \nGiven the available blocks and available space on the tablet, you need to move the fox on the map so it can grab all the coins.\n\nListen what hero says, there might be some hints.\nYou can also unlock some other small games, that will help you relax a bit.\nAnd most important - look around and find hidden options - can you make Foxy happy? \n\nThere are possible blocks:\n- Move\n- Turn left\n- Turn right\n- Grab\n- Procedure\n- Loop\n\nGame has support for hero voice and you can enable subtitles.", "short_description": "50+ levels with increasing difficulty. Everything starts with the easy ones, so you can get familiar with the mechanics.\nIt's a game for the whole family or for solo play. \nGiven the available blocks and available space on the tablet, you need to move the fox on the map so it can grab all the coins.\n\nListen what hero says.\nYou can also unlock some other small games, that will help you relax a bit.\nAnd most important - look around and find hidden options - can you make Foxy happy? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://artisoft.pl/policies/ctc_v1.html", "developer_terms_of_service_url": null, "publisher_name": "Artisoft", "support_website_url": null, "website_url": "https://ctc.artisoft.pl/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "577643944555881"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "441133488758249"}, {"status": "PUBLISHED", "id": "638824711756170"}, {"status": "PUBLISHED", "id": "275854278536837"}, {"status": "PUBLISHED", "id": "289590936805836"}, {"status": "PUBLISHED", "id": "415984377560455"}]}, "baseline_