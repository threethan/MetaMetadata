/scontent.oculuscdn.com/v/t64.5771-25/39031505_919835612275010_5579081734693718338_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lrKzLS8Ps8MQ7kNvgE-2Yle&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah7OeAXhloqWYF3T7y5VCI9&oh=00_AYDNgmQDvahCmOrZLUcKeEtPTlGfe6e_5nToP7IH-tlSoA&oe=66E96DFB"}, {"file_name": "Updated_Screenshot_4_Oculus.png", "id": "456272123384556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001726_456272126717889_6151231868675041051_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qYwKgmg8kOgQ7kNvgEPaugq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah7OeAXhloqWYF3T7y5VCI9&oh=00_AYDpDfuxBfZ11x40uVvaUfS_AV6DFp6x3bB5NU6RKNhFbg&oe=66E963A2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape.png", "id": "999779757647287", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_999779760980620_7423226441179076258_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Yxwpz9HcAEQ7kNvgE9o2GX&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah7OeAXhloqWYF3T7y5VCI9&oh=00_AYC05etlqbiY4BPcdJFIeBHQUmEx1CdC1XvwJ_JNQ7cCiA&oe=66E96693"}, "display_name": "Give The People What They Want", "keywords": [], "long_description": "In Give the People What They Want, you play as a lowly mining robot who has been promoted to the service industry. It's a tough job, customers can be very demanding, and you'll need to adapt to whatever people need based on the jobs you're given. You will need to learn how to optimize to get people what they want in the shortest amount of time and deal with their increasingly complex requests to show that you can be a good quality service bot.\n\nKey Features:\n3 different stages with unique environments and items\nBonus challenges that will let you earn extra points\nCustomizable robot body system to be the best bot you can be\n\n\nIt's a tough job, but someone's gotta do it, and apparently, there's nobody else who wants to. So it's up to you to Give the People What They Want. Will you succeed as the best service bot ever? Or are you destined for the scrap heap? ", "short_description": "A VR Game where you take on odd jobs, become your ideal self, and throw things at customers' faces."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starlightvintagestudios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Starlight Vintage Studios", "support_website_url": null, "website_url": "https://starlightvintagestudios.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5889862721059601"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9329297837141481", "version": "1.3.2"}, "id": "2452581891560977", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8461886807215926", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9329297837141481"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2452581891560977"}]}, "change_log": null, "created_date": 1685472998, "id": "932