oh=00_AYC-B3kJsuwMAwG1j_48zrlW1nQ3JRhokaHCt86TAgrFbw&oe=676D43FB"}, {"file_name": "Updated_Screenshot_4_Oculus.png", "id": "456272123384556", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001726_456272126717889_6151231868675041051_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1PW1pNkzJXoQ7kNvgGniGVG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBaCYDKzvDA-zcSmRhrLOX0N41GuW-sJ6ah_YwcsLzYeg&oe=676D39A2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape.png", "id": "999779757647287", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036641_999779760980620_7423226441179076258_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WDAKAJSZfg4Q7kNvgEYmzIr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPgVLVT86lvJev1o1hTBUhY3_AGcGT8GAKs5SxreFmeA&oe=676D3C93"}, "display_name": "Give The People What They Want", "keywords": [], "long_description": "In Give the People What They Want, you play as a lowly mining robot who has been promoted to the service industry. It's a tough job, customers can be very demanding, and you'll need to adapt to whatever people need based on the jobs you're given. You will need to learn how to optimize to get people what they want in the shortest amount of time and deal with their increasingly complex requests to show that you can be a good quality service bot.\n\nKey Features:\n3 different stages with unique environments and items\nBonus challenges that will let you earn extra points\nCustomizable robot body system to be the best bot you can be\n\n\nIt's a tough job, but someone's gotta do it, and apparently, there's nobody else who wants to. So it's up to you to Give the People What They Want. Will you succeed as the best service bot ever? Or are you destined for the scrap heap? ", "short_description": "A VR Game where you take on odd jobs, become your ideal self, and throw things at customers' faces."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www