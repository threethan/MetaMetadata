_Kf46gQ7kNvgGit8uY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaj2-5jYi0eEg8Z7dCUY3QhpYG2JXvZy7sb1z9SSAD6w&oe=66EC0B1C"}]}, "id": "686810412977510", "locale": "en_US", "screenshots": [{"file_name": "GTP-MetaScreenshot06.png", "id": "1545645619271169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227942960_1545645622604502_636989479919588043_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eslG7COpU0cQ7kNvgGyOJSH&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzfgbKYMF8Ep7rqrQZ2t-c0fy_NYWEjglWZr4tlDquhA&oe=66EC1B79"}, {"file_name": "GTP-MetaScreenshot02.png", "id": "859553921910487", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227942845_859553925243820_3839294002224521913_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l0MimuKRkTEQ7kNvgGAih3y&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPFmW-E_Nk_BuSO8iWjJp43iYi4opBClTESqoCN6Nczg&oe=66EBFFB0"}, {"file_name": "GTP-MetaScreenshot03.png", "id": "857097335678212", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569472_857097339011545_4931694670950153394_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UfH6iuzMk3QQ7kNvgFRQ1-Z&_nc_ht=scontent.oculuscdn.com&oh=00_AYAPgvhO-qQ_G-ZEZVutkKsdGAP88m5nn8fvgd2NJGgIIQ&oe=66EC28EC"}, {"file_name": "GTP-MetaScreenshot04.png", "id": "1268488450404035", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974924_1268488453737368_7408781568125309811_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rROALVyrK3cQ7kNvgHxG2eg&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSdsB-PXTZBfO7TD-i1_n9n8IIKEg1hen_sOy42qm0Og&oe=66EBFDAE"}, {"file_name": "GTP-MetaScreenshot01.png", "id": "1132538277408339", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982613_1132538280741672_3561373941679093613_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fepi7bcqezcQ7kNvgHsWSGL&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXMtK2-XOOuyXrIYISwykC72Ct4UxQ8ocemmlKdHOtkQ&oe=66EC138B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape.png", "id": "999779757647287", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_999779760980620_7423226441179076258_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1zsay2JHQe0Q7kNvgFOmqYI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJl8hu2sY9iUCgOjPGOQAzn3gCxe8_UPio-gJg4t_W8g&oe=66EC0993"}, "display_name": "Give The People What They Want", "keywords": [], "long_description": "In Give the People What They Want, you play as a lowly mining robot who has been promoted to the service industry. It's a tough job, customers can be very demanding, and you'll need to adapt to whatever people need based on the jobs you're given. You will need to learn how to optimize to get people what they want in the shortest amount of time and deal with their increasingly complex requests to show that you can be a good quality service bot.\n\nKey Features:\n3 different stages with unique environments and items\nBonus challenges that will let you earn extra points\nCustomizable robot body system to be the best bot you can be\n\n\nIt's a tough job, but someone's gotta do it, and apparently, there's nobody else who wants to. So it's up to you to Give the People What They Want. Will you succeed as the best service bot ever? Or are you destined for the scrap heap? ", "short_description": "A VR Game where you take on odd jobs, become your ideal self, and throw things at customers' faces."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starlightvintagestudios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Starlight Vintage Studios", "support_website_url": null, "website_url": "https://starlightvintagestudios.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "r