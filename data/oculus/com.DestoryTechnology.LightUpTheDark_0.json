.com&_nc_gid=AayKC6BrpVQK4YybpgaQ_8C&oh=00_AYBUhbDNAH2Upz5Qxa34wurm5YM467mfzvezfctnEEchng&oe=66E55C73"}, {"file_name": "Final5.png", "id": "1109469673205956", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1109469676539289_4268533616333460252_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R0H0js-ynmoQ7kNvgFlQ7he&_nc_ht=scontent.oculuscdn.com&_nc_gid=AayKC6BrpVQK4YybpgaQ_8C&oh=00_AYCCsPRN8JaAqVoe4LdRNAVIowv0_dH7vorvijHnPkA17g&oe=66E55AF7"}, {"file_name": "Final2.png", "id": "916532898880837", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_916532902214170_6367672695544734699_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0LaafwZQm0EQ7kNvgEy9HXN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AayKC6BrpVQK4YybpgaQ_8C&oh=00_AYAaSQLzaYsMNukZF4pputigNr7vYqPCy_3Sggqq8IwA4Q&oe=66E5833A"}, {"file_name": "Final3.png", "id": "1165340330878993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_1165340334212326_9147485654240656059_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2t8NduO92YYQ7kNvgFNmup-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AayKC6BrpVQK4YybpgaQ_8C&oh=00_AYBu25FkzPTUg1fXaeu6SvAAFdFGYUS1tQstqc2mNW4cIg&oe=66E55E07"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Light Up The Dark", "keywords": [], "long_description": "*  Finger Controls.  \"Play\" the fireworks with your right-hand fingers using individual fingers and \"chords\" of fingers to fire different types of fire works.\n*  The Color Ball.  Your left hand is the color ball, moving side-to-side changes the color of the firework, and up/down adjusts the size of the fireworks blasts.\n*  Seamlessly switch between hands and controllers (with a hardware delay).\n*  Play reclined or laying down!  Or upside down.  Any position, any space.\n*  Environmental features such as snow, falling leaves, fireflies, and bubbles.  Seriously, try the bubbles.\n*  Listen to various audio tracks including a gentle Mozart piece, a Sousa March, and Wagner's Ride of the Valkyries, adjustable volumes for music and fireworks.\n*  Set the weather and the Speed of Time.  Note, the weather has a mind of its own.  \n*  Show and hide individual UI components or enter the VOID, with no user interface other than the finger streaks.\n\nShow and hide individual UI components or enter the ", "short_description": "Light Up The Dark is an exciting firework experience featuring a highly customizable atmosphere and snowman modes for casual or gaming fun.  Advanced controls using fingers and hands provide a unique experience.\n\nEnjoy a zen world with a light snow and the sounds of the forest at night, with fireworks.  \n\n\u200bOr bend time so a day lasts a few seconds, with a Sousa march fillings your ears while snowmen crash any sense of tranquility, with fireworks.\n\nYour fireworks.  Your way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lightupthedarkgame.com/credits-legal", "developer_terms_of_service_url": null, "publisher_name": "Destroy Technology", "support_website_url": null, "website_url": "https://www.LightUpTheDarkGame.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1675672486097598"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {