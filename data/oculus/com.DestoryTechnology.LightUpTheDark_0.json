ng", "id": "448260017041820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974497_448260027041819_4812746175687748913_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lznGYXz8Pf0Q7kNvgEzguEC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYAq8UOvKrBpmdaT-yRR8dIBY13k5ih2jOIah0oBCTHUMQ&oe=66DC476F"}, {"file_name": "CoverArtSquare1440x1440.png", "id": "274204374718713", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974873_274204378052046_3943290152368089985_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_GbjU9mODMQ7kNvgGHle4f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYA1rrjbi1ScWx4ImNS_eiz5dwtlrtM4Xql0A6A2sWGSXw&oe=66DC4800"}]}, "id": "707470977011826", "locale": "en_US", "screenshots": [{"file_name": "com.DestoryTechnology.LightUpTheDark_0-20220624-001602.mp4.Still002.png", "id": "798525171529606", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974523_798525174862939_4626036896631940665_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aAU-cvgJDJYQ7kNvgGCSies&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYCPFQU8JWamwgRtUV7dsByyOKTaCYH3ARkz0wKBEtDZQQ&oe=66DC2D57"}, {"file_name": "com.oculus.shellenv-20220623-002405.mp4.Still008.png", "id": "5363798030329732", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_5363798033663065_4663252338829439864_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zXryBiEW7UcQ7kNvgGspEhs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYCLbLGJuJMtd-So745S6MYXOIPa476M_TtqzLS0WfvHCw&oe=66DC35A7"}, {"file_name": "com.oculus.shellenv-20220623-002405.mp4.Still003.png", "id": "5319208218169963", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974530_5319208231503295_3232326796993336551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I22e8SA8z0EQ7kNvgFFpce2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYBpQLTpCmh17DXc1glzTryaCqcEsFRTs4SfRVX2FryIMg&oe=66DC37B0"}, {"file_name": "com.oculus.shellenv-20220623-002405.mp4.Still006.png", "id": "1430097507417067", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974454_1430097514083733_5445658030471255393_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qmnLKpDQHT8Q7kNvgHABqOS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYDuz8ekn7mWnC9MlLj1uCNPvDZi4tjhTob1h1Hbt9tvRw&oe=66DC406B"}, {"file_name": "com.oculus.shellenv-20220624-042522.mp4.Still001.png", "id": "3113937215589309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974530_3113937218922642_5085609095707691860_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ti3ifl1TKg4Q7kNvgHcU8BG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYAyVcszFJO7sBdCbq46np9XMS8pfAXZa58QQoc_UKrozw&oe=66DC424D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArtLandScape2560x1440.png", "id": "508996884020276", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974844_508996887353609_5509969863082992813_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gROxGiNrD6IQ7kNvgGi4AhB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYDjsYBZ2lRNZeXeRPbBQDdvwQHB0xKMlxPrDDuMwUuZ-g&oe=66DC37C9"}, "display_name": "Light Up The Dark", "keywords": [], "long_description": "*  Dual Controller or Dual Hand/Finger control operation.\n*  Seamlessly switch between hands and controllers (with a hardware delay).\n*  Play reclined or laying down!  Or upside down.  Any position, any space.\n*  Environmental features such as snow, falling leaves, fireflies, and bubbles.  Seriously, try the bubbles.\n*  Listen to various audio tracks including a gentle Mozart piece, a Sousa March, and Wagner's Ride of the Valkyries, adjustable volumes for music and fireworks.\n*  Set the weather and the Speed of Time.  Note, the weather has a mind of its own.  \n*  Show and hide individual UI components or enter the VOID, with all aim assistance turned off.", "short_description": "Light Up The Dark is an exciting firework experience featuring a highly customizable atmosphere and fun casual modes and a snowman shooting game.  Advanced controls using fingers and hands provide a unique experience.\n\nEnjoy a zen world with a light snow and the sounds of the forest at night, with fireworks.  \n\n\u200bOr bend time so a day lasts a few seconds, with a Sousa march fillings your ears while snowmen crash any sense of tranquility, with fireworks.\n\nYour fireworks.  Your way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lightupthedarkgame.com/credits-legal", "developer_terms_of_service_url": null, "publisher_name": "Destroy Technology", "support_website_url": null, "website_url": "https://www.LightUpTheDarkGame.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "580949743395507"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974873_274204378052046_3943290152368089985_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_GbjU9mODMQ7kNvgGHle4f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF7jHrU2W1IKuw22EqLNPYv&oh=00_AYCmc-rgrQf8mpUUu2GvpT3PEg0SYqjl5QEEcfqvVQcUfg&oe=66DC4800"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Light Up The Dark", "platform": "ANDROID_6DOF", "context_category