IWDS-fYmbF1u4LIxmcJmnKzoyoOitGeg&oe=66F3F2B0"}, {"file_name": "com.oculus.shellenv-20220623-002405.mp4.Still006.png", "id": "1430097507417067", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974454_1430097514083733_5445658030471255393_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kvux2QI1TMcQ7kNvgFonEGm&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw0HCjOSHwh11dpgHYreYIV&oh=00_AYD0jeu63oPdXTwm3tyI9Aw-Be_uV-615pY4osr3rQaOrg&oe=66F3FB6B"}, {"file_name": "com.oculus.shellenv-20220624-042522.mp4.Still001.png", "id": "3113937215589309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974530_3113937218922642_5085609095707691860_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JXrjUdjf2IwQ7kNvgFdWDAq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw0HCjOSHwh11dpgHYreYIV&oh=00_AYCx7VznxCwjVVmze6vAYsmxdlC3KRBff7DBJRW3y25_0w&oe=66F3FD4D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArtLandScape2560x1440.png", "id": "508996884020276", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974844_508996887353609_5509969863082992813_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y0Mz9EimttoQ7kNvgHMccEl&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw0HCjOSHwh11dpgHYreYIV&oh=00_AYClV-D7VyAUjxNTKTzYaaCx9dSM6yfDIZ-LNlKy5hxSmA&oe=66F3F2C9"}, "display_name": "Light Up The Dark", "keywords": [], "long_description": "*  Dual Controller or Dual Hand/Finger control operation.\n*  Seamlessly switch between hands and controllers (with a hardware delay).\n*  Play reclined or laying down!  Or upside down.  Any position, any space.\n*  Environmental features such as snow, falling leaves, fireflies, and bubbles.  Seriously, try the bubbles.\n*  Listen to various audio tracks including a gentle Mozart piece, a Sousa March, and Wagner's Ride of the Valkyries, adjustable volumes for music and fireworks.\n*  Set the weather and the Speed of Time.  Note, the weather has a mind of its own.  \n*  Show and hide individual UI components or enter the VOID, with all aim assistance turned off.", "short_description": "Light Up The Dark is an exciting firework experience featuring a highly customizable atmosphere and fun casual modes and a snowman shooting game.  Advanced controls using fingers and hands provide a unique experience.\n\nEnjoy a zen world with a light snow and the sounds of the forest at night, with fireworks.  \n\n\u200bOr bend time so a day lasts a few seconds, with a Sousa march fillings your ears while snowmen crash any sense of tranquility, with fireworks.\n\nYour fireworks.  Your way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lightupthedarkgame.com/credits-legal", "developer_terms_of_service_url": null, "publisher_name": "Destroy Technology", "support_website_url": null, "website_url": "https://www.LightUpTheDarkGame.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "580949743395507"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974873_274204378052046_3943290152368089985_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5jOn29gnas0Q7kNvgG6809m&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw0HCjOSHwh11dpgHYreYIV&oh=00_AYDM5UTISceLBuFPZTD3qqumG0AopTC4AGMNcCBarq4BVA&oe=66F40300"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Light Up The Dark", 