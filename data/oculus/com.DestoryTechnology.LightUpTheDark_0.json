om/v/t64.5771-25/38982710_476929613965364_5245029297215347228_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mfoihoNRLpwQ7kNvgGiifRU&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpxZrvCGLyr9dujjfErbt5gLMbz7mv7t0zTqq_Z_JOQg&oe=67068109"}, {"file_name": "Logo9000x1440.png", "id": "7368380116536136", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031574_7368380123202802_7558905963144694006_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hryx9MGDRqUQ7kNvgH9P2Ws&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdV5ZXufmbwXAw4ke0jD9emAAJqfFXjGeZgNFSWHgv8Q&oe=670676AF"}, {"file_name": "Icon512x512.png", "id": "1670336176664074", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982460_1670336179997407_7260350772183686599_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJ-wWSo36TgQ7kNvgF10E4M&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdvRp6nsH71AJKE8ZOLkkOzJ67b7MEo3qgLE2BwY0KLA&oe=670683C7"}]}, "id": "718554092403278", "locale": "en_US", "screenshots": [{"file_name": "Final4.png", "id": "1064564687657120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031458_1064564694323786_2934528766626345290_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nY5ZKu4NYOcQ7kNvgGt6cW_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgGTM9t4PIKfweERsPgf2nps3O4NXRsSOvclsy1Io3lw&oe=67065E1E"}, {"file_name": "Final1.png", "id": "934483367267393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984460_934483370600726_2342269543366152476_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=um09VDoa_aoQ7kNvgG7e3Mz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrnG_95gFPcyXpFfWnac1RFk5Dr8uJ5msrmvHXdSkDPg&oe=670651F3"}, {"file_name": "Final5.png", "id": "1109469673205956", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031326_1109469676539289_4268533616333460252_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_zP7LcWe8wAQ7kNvgFBTQQy&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaYktkiC6Jim2P-xwkP-IDdgKEzPoKSbCO3ZggYQBzXQ&oe=67065077"}, {"file_name": "Final2.png", "id": "916532898880837", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003274_916532902214170_6367672695544734699_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uN1_uix4jngQ7kNvgGNuZR2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgtSNcH3Idit-ZuSyTsRjCOvkKY1ZP3iSZKYlmVVR3OA&oe=670678BA"}, {"file_name": "Final3.png", "id": "1165340330878993", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974677_1165340334212326_9147485654240656059_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8qCA5ZiahyoQ7kNvgEeMHeY&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYtbTIdkIwtG2nxvrrZfU9FPX1tC0kFFiUVRbzkoQh0A&oe=67065387"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Light Up The Dark", "keywords": [], "long_description": "*  Finger Controls.  \"Play\" the fireworks with your right-hand fingers using individual fingers and \"chords\" of fingers to fire different types of fire works.\n*  The Color Ball.  Your left hand is the color ball, moving side-to-side changes the color of the firework, and up/down adjusts the size of the fireworks blasts.\n*  Seamlessly switch between hands and controllers (with a hardware delay).\n*  Play reclined or laying down!  Or upside down.  Any position, any space.\n*  Environmental features such as snow, falling leaves, fireflies, and bubbles.  Seriously, try the bubbles.\n*  Listen to various audio tracks including a gentle Mozart piece, a Sousa March, and Wagner's Ride of the Valkyries, adjustable volumes for music and fireworks.\n*  Set the weather and the Speed of Time.  Note, the weather has a mind of its own.  \n*  Show and hide individual UI components or enter the VOID, with no user interface other than the finger streaks.\n\nShow and hide individual UI components or enter the ", "short_description": "Light Up The Dark is an exciting firework experience featuring a highly customizable atmosphere and snowman modes for casual or gaming fun.  Advanced controls using fingers and hands provide a unique experience.\n\nEnjoy a zen world with a light snow and the sounds of the forest at night, with fireworks.  \n\n\u200bOr bend time so a day lasts a few seconds, with a Sousa march fillings your ears while snowmen crash any sense of tranquility, with fireworks.\n\nYour fireworks.  Your way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lightupthedarkgame.com/credits-legal", "developer_terms_of_service_url": null, "publisher_name": "Destroy Technology", "support_website_url": null, "website_url": "https://www.LightUpTheDarkGame.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1675672486097598"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4946590738784527", "version": "1.7"}, "id": "458184729301815", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4495091483934457", "is_concept": false, "latest_released_binary": {"__t