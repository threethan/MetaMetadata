vm7pbrPSfKvRf-KUgf4YHLshRrZtlZHRw&oe=6766B233"}, {"file_name": "screenshot4 (1).png", "id": "250054969903506", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75195907_250054973236839_3351405699426217824_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6mUbKpz9HBcQ7kNvgFxAd5v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXQxdDgcYACNbfxj2QFAVTXx0B40Jl_VFVG0r6B11hWw&oe=6766C4CA"}, {"file_name": "screenshot5 (1).png", "id": "772795033666731", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001689_772795037000064_3763266580022143986_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=Wi66g_naNskQ7kNvgF8pE7e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3B6NoctBNd4zm6g04VFhyktyyRDeFf07ZztEQFRoBgg&oe=6766C522"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "75221327_1539695449710517_4524333578914128917_n.png", "id": "148488417144003", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036607_148488420477336_5459426973821019091_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YJicV93QeBoQ7kNvgG6jqR-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCHfd2ndhKRF_xOBkT_djYaVgAO-VTeLx4YLDvyNlvtXA&oe=6766B3F0"}, "display_name": "RSI", "keywords": [], "long_description": "An online, on-demand learning experience platform delivering a growing catalog of courses for the skilled trades industry. Get the training you need to reach that next level in HVAC, Solar, Plumbing, Electrical, and Facility Maintenance. Plus, our catalog keeps growing. You\u2019ll find hundreds of hours of training including video and scenario-based exercises across different equipment types. Hone your skills and be ready for whatever the real world throws at you.\n\nWhether you\u2019re new on the job or a more seasoned pro looking to advance, the course catalog can help you be the kind of tech you want to be \u2013 a great one.\n\nA growing catalog of field-like training courses focused on helping tradesmen upskill through:\nInteractive, 3D based simulations to deliver field-like training\nExpert-led video courses drive understanding\nKnowledge checks throughout engage users and reinforce lessons\n\nTrailer music: https://www.bensound.com", "short_description": "VR training simulations develop on-the-job skills quickly and efficiently, building better careers and better lives for the essential skilled trades."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.interplaylearning.com/privacy", "developer_terms_of_service_url": "https://www.interplaylearning.com/terms-of-use", "publisher_name": "Interplay Learning Inc", "support_website_url": "https://www.interplaylearning.com/contact", "website_url": "https://www.interplaylearning.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "337040224979551"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575347_280142810117962_6878396599048805806_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zccyD5AaF3AQ7kNvgFNhaww&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8VFvJNH4GqfMQLYj-_CQXiOUer8ug9wmOcx7EIO__OQ&oe=676691E1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RSI", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "3