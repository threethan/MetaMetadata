nInteractive, 3D based simulations to deliver field-like training\nExpert-led video courses drive understanding\nKnowledge checks throughout engage users and reinforce lessons\n\nTrailer music: https://www.bensound.com", "short_description": "VR training simulations develop on-the-job skills quickly and efficiently, building better careers and better lives for the essential skilled trades."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.interplaylearning.com/privacy", "developer_terms_of_service_url": "https://www.interplaylearning.com/terms-of-use", "publisher_name": "Interplay Learning Inc", "support_website_url": "https://www.interplaylearning.com/contact", "website_url": "https://www.interplaylearning.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "337040224979551"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/57575347_280142810117962_6878396599048805806_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AjNyYXZ9bQMQ7kNvgHNaYV0&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDWUujM4hLadxv0dXeuKHCHtxjMWB4POAMp8gJbtAaMJQ&oe=67878761"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RSI", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "3