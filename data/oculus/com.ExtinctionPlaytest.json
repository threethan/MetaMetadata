t=scontent-iad3-1.oculuscdn.com&oh=00_AYBMRvsZ4JGDbNFWHyt_2tbYwZX7wa1EV7MRNP5PzDovpw&oe=6773D017"}, {"file_name": "fess2.png", "id": "1706249676864177", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203614_1706249680197510_3161793931806612472_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YV7L0d1IfLEQ7kNvgGBegqO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAneRBCXL7uY4gE8frhjvisHbXdd_Md2Q71U-r6Is3bhQ&oe=6773D305"}, {"file_name": "fess3.png", "id": "2047403575675769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75416836_2047403579009102_7653909196600754875_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eKMZGSPcfRkQ7kNvgHV_mBM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDsVOGdOd08Hc3MaINxPszhAwVfie80UglTxov4eW9zOw&oe=6773E8CD"}, {"file_name": "fess5.png", "id": "1151394316312163", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_1151394319645496_5289106993288423625_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jepEo2mSrjcQ7kNvgHC68u3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxLWvBxBY-LER-HZz8t6eGoByKXPPlF89W4EKdF_kW7A&oe=6773C062"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Frenzy Extinction LITE", "keywords": [], "long_description": "# Join our Discord for the Secret Code required to play! frenzyextinction.com/discord\n\nThis is a LITE / DEMO build of Frenzy Extinction. Expect incomplete features, bugs, and missing content. \n# Buy the full game here: https://www.meta.com/experiences/frenzy-extinction/25176949381952074/\n==========\n{913272780634577}\nThe Frenzy Virus has mutated, unleashing a new wave of chaos. You and your team must now confront hordes of \"The Ridden\" in Frenzy Extinction. The fast-paced, action-packed gameplay tests you and your team's ability to adapt, upgrade, and overpower relentless enemies.\n\n# Key Features:\n**Intense Horde Survival Gameplay**\n\nPhysics-based combat against waves of mutated monsters. Each enemy is designed with unique abilities and behaviors, keeping you on your toes as you fight for survival.\n\n**Upgrade and Customize**\n\nCollect Necronium from defeated enemies to upgrade your gear, unlock new areas, and enhance your abilities with powerful perks. All weapons feature unique customizable looks and abilities that you can tailor your loadout with.\n\n**Epic Boss Battles**\n\nFace off against formidable bosses at the end of each map. Test your skills and teamwork as you battle to escape the map and advance the story.\n\n**Multiplayer Mayhem**\n\nTeam up with up to 3 friends in seamless co-op multiplayer. Strategize and cooperate to defeat the hordes, share loot, and defeat the boss to extract. \n", "short_description": "This is the LITE / DEMO version of Frenzy Extinction\n\nThe Frenzy Virus has mutated. Now, you and your team must defeat hordes of \"The Ridden\" in Frenzy Extinction! Survive waves of mutated monsters as your team upgrades their gear, powers up with custom abilities, and races to extract after defeating the boss. Use physics-based combat and dismemberment to decimate The Ridden and save the world! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://clique.games/privacy", "developer_terms_of_service_url": "https://clique.games/terms", "publisher_name": "Clique Games", "support_website_url": null, "website_url": "http://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "HORROR"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_inpu