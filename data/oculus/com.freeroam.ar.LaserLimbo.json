, "id": "915343413639038", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982647_915343416972371_6498249555483074989_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uj4jsn9sHKgQ7kNvgGkC3a-&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDPnYs5FJYvvnQ9c9W9jN3Ch8YM_T7_ZoZjZnP9mK5EOA&oe=6780F8E7"}, {"file_name": "Logo A 1440.png", "id": "903141788031546", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974845_903141791364879_7349642253493641173_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJpq_UjcsT0Q7kNvgHYUqxO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBK2D-rhyAEEvWHN8zT5so1BPLgbBc3D0KUoMPoRllsig&oe=6781234C"}, {"file_name": "Icon.png", "id": "880914280709310", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57568679_880914287375976_5513610484792159753_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sEfxuvLERHkQ7kNvgF6L1j3&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBJR8-G9HENYmF6MT85WVuv3_EzCEi3kfOaVas8mP5MAQ&oe=67810915"}]}, "id": "432808279113268", "locale": "en_US", "screenshots": [{"file_name": "Compilation 2023 oculus wide (0-00-09-01).png", "id": "799333922024084", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974835_799333925357417_6838248202620419814_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y6gGmxUIjr4Q7kNvgGa6Psy&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDIpfiLYKM5uaGfUrbczicM__FBRB5InHMAbQg6SbBWxQ&oe=6781065C"}, {"file_name": "Compilation 2023 oculus wide (0-00-30-08).png", "id": "416339817629205", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031553_416339820962538_6454065026989816328_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FEO4oRuAyWcQ7kNvgEznGOv&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCF66YDXqtb8ytmYARljOQCAK--RzF-noGj9tG7kE59gg&oe=6780FB7E"}, {"file_name": "Compilation 2023 oculus wide (0-00-04-29).png", "id": "1544565856112534", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75210394_1544565859445867_4542355005518720892_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vTJzsCKuedMQ7kNvgG-ulKP&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBrIHQkHDbi8KVIf2j5NC2t-9KXB3yt7DuKZXJDQb8qFg&oe=678113AB"}, {"file_name": "Compilation 2023 oculus wide (0-00-12-07).png", "id": "827909709350946", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031553_827909712684279_1375813226688130100_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b_D_VJw4WT8Q7kNvgGKNJI5&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDQEONM6nj2ghdhIWsUfU5612Rflp4b0wlvImXky1CtdA&oe=67810161"}, {"file_name": "Compilation 2023 oculus wide (0-00-00-00).png", "id": "438205571894106", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974521_438205575227439_1776630697263311931_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TyWfR8ZneJAQ7kNvgFcMf3j&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD8qCNvpO4cyUgPGp2K0oFrelO32297SksnOX61YO2h0A&oe=67810DED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Compilation 2023 oculus wide (0-00-04-29).png", "id": "1458145795082435", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982520_1458145798415768_6343355900190619901_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uXZLBPqPPzEQ7kNvgHpcUYs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAblcLy0R-SAYN_CUEK52qCmjUiXjDAA5raBcpLx0LPIQ&oe=678100D2"}, "display_name": "Laser Limbo", "keywords": [], "long_description": "Laser Limbo is an augmented reality focused multiplayer game. It transforms every room into a game world through the associated level editor. The players see the real environment via video through the VR glasses, but this is enhanced by virtual game elements (Passthrough AR).\nThe art style of the game is based on 90s 3D pixel graphics and gives a rather playful impression. Martial and realistic depictions are deliberately avoided. \nThe game element that connects the different game modes are laser beam traps (as known from agent films). The players have to move carefully and skilfully through the room so as not to trigger the traps. They wear waistcoats in game colours that explode when they leave the game.\n", "short_description": "Laser Limbo is an augmented reality multiplayer game that turns any room into a gaming world with a level editor. Using VR glasses, players see their real environment enhanced with virtual elements in a 90s 3D pixel art style. The game avoids martial and realistic depictions and features laser beam traps from various game modes. Players navigate skillfully to avoid triggering traps and wear game-colored waistcoats that explode upon leaving the game.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeroam.ar/data-privacy-quest-app", "developer_terms_of_service_url": null, "publisher_name": "freeroam.ar", "support_website_url": null, "website_url": "https://www.freeroam.ar/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7852382358106757"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "964231852406488"}, {"status": "PUBLISHED", "id": "1295526204459364"}]}, "baseline_offer": {"id": "964231852406488"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733238360, "status": "PUBLISHED", "id": 