mbat.\nFind powerful weapons and wield mighty artifacts to defend yourself against poisonous scorpions, hungry spiders and the\nundead remains of the warriors who have come here before you."}]}, "developer_name": null, "developer_privacy_policy_url": "http://download.headupgames.com/cdn/Headup_Games_Privacy_Policy.txt", "developer_terms_of_service_url": "http://download.headupgames.com/cdn/TermsAndConditions.txt", "publisher_name": "Headup Games", "support_website_url": null, "website_url": "http://www.headupgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "662046558328420"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162716_120912718493101_3275442231451844608_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6_jPdtR5PoIQ7kNvgG4MDrT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAapvuXKJEO9V7hxMlVhi6pQcPHrTUCfQ-tj4RguT-j4A&oe=6741A62C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "KryptCrawler Sneak Peek", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1498004313, "lastRevision": {"nodes": [{"id": "1457906160928304", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1301430849952300", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platfo