_6770350059004362752_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KeV1yl8_EuIQ7kNvgHAD6ZR&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYD_lbb2M09ofYHFhflfRYhyUD7kcehZsasrRnHH2fV6Kw&oe=6728C45E"}, {"file_name": "migrated_image.png", "id": "195359681898712", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/11162717_1912279389033061_3284699848774778880_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wjc0_h-CsZ0Q7kNvgH8R23z&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDZMcZ2VuM-5Glch6MNOa3o9TMtheImEtDLW3E5ZBt5-w&oe=6728A083"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "kryptcrawler_boxart_2560x1440_Logo.png", "id": "1736571129969647", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/11162748_1736571136636313_1925396064559431680_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huW-9gi8kdMQ7kNvgG1bnkA&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCDlGO2rfhYR9-6C7tk61wxQQN9YpaM1iiFxis9mRq9Vw&oe=6728A6B8"}, "display_name": "KryptCrawler Sneak Peek", "keywords": ["dungeon", "action", "adventure", "gridbased", "archery"], "long_description": "This summer, KryptCrawler wil bring classic first person, grid based Dungeon Crawler gameplay to Virtual Reality!\n\nA combination of turn based old school gameplay, real time combat and trap evasion unprecedented in its genre, combined with the immersion of modern VR technology. Experience dungeons like never before! Let\u2019s just hope you make it back to sunlight and the world of the living \u2013 there are many rumors of simple-hearted adventurers who have set foot into the abyss of the crypt and have never been heard of again!", "short_description": "This is a Sneak Peek for KryptCrawler, a classic first person, grid based Dungeon Crawler  forVirtual Reality.\n\nKryptCrawler delivers a combination of turn based old school gameplay and real time combat.\nFind powerful weapons and wield mighty artifacts to defend yourself against poisonous scorpions, hungry spiders and the\nundead remains of the warriors who have come here before you."}]}, "developer_name": null, "developer_privacy_policy_url": "http://download.headupgames.com/cdn/Headup_Games_Privacy_Policy.txt", "developer_terms_of_service_url": "http://download.headupgames.com/cdn/TermsAndConditions.txt", "publisher_name": "Headup Games", "support_website_url": null, "website_url": "http://www.headupgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "662046558328420"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/11162716_120912718493101_3275442231451844608_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UyVSdKM8UWMQ7kNvgGkwbJ7&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAPaAKodLUReWswsPsd1Z5LOIXlmpqHuxCMvclwGPcMtQ&oe=672899AC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "KryptCrawler Sneak Peek", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1498004313, "lastRevision": {"nodes": [{"id": "1457906160928304", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1301430849952300", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1463891040329856"}, "iarc_email": null, "msrp": null, "translations": {"