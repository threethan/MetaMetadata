390415259928801_3385305250069917517_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ehmh4ItQGmoQ7kNvgF2-VPb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQ34mcixG_TZUa9wBUNhJ_GMdY1UGVF3KV2n--kP5qzg&oe=6752DC66"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landsacpe.png", "id": "3660204447525406", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222939_3660204450858739_5601392693514547207_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xL9Rw5Dg_rsQ7kNvgHyo_i6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0qjbR85OWks90LE2yOx5LfdAwpFm4eYyViVLCrelgTQ&oe=6752D2C5"}, "display_name": "Gorilla Soccer - Play Soccer Sport Game as Monkey", "keywords": ["SOCCER", "GORILLA", "BASEBALL", "FOOTBALL", "MONKEY"], "long_description": "This is an interesting VR sports competitive game. You play as a gorilla.\n\nThe locomotion is inspired by Gorilla Tag. You can run, jump, and hit the ball using only your hands. The rules are the same as soccer.\n\nBesides soccer, there are also many other modes, such as American football, baseball and crossbow.\n\nThis game is free, and you can play with other players.", "short_description": "A new type of sports competitive game. You can play soccer as a gorilla!\n"}, {"images": {"nodes": []}, "id": "1770867833662375", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gorilla Soccer", "keywords": ["\u8db3\u7403", "\u6a44\u6984\u7403", "\u68d2\u7403"], "long_description": "\u8fd9\u662f\u4e00\u6b3e\u6709\u8da3\u7684VR\u8fd0\u52a8\u7ade\u6280\u6e38\u620f\uff0c\u4f60\u5c06\u626e\u6f14\u4e00\u53ea\u7329\u7329\u3002\n\n\u79fb\u52a8\u65b9\u5f0f\u501f\u9274\u4e86Gorilla Tag\uff0c\u4f60\u53ef\u4ee5\u4ec5\u4ec5\u53ea\u7528\u53cc\u624b\u6765\u8dd1\u3001\u8df3\u548c\u51fb\u7403\u3002\u6e38\u620f\u89c4\u5219\u548c\u8db3\u7403\u76f8\u540c\u3002", "short_description": "\u4e00\u79cd\u65b0\u7684\u8fd0\u52a8\u7ade\u6280\u6e38\u620f\uff0c\u4f60\u5c06\u626e\u6f14\u4e00\u53ea\u7329\u7329\u6765\u8e22\u8db3\u7403\uff01"}, {"images": {"nodes": []}, "id": "1300754620947691", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gorilla Soccer", "keywords": ["FOOTBALL"], "long_description": "This is an interesting VR sports competitive game. You play as a gorilla.\n\nThe locomotion is inspired by Gorilla Tag. You can run, jump, and hit the ball using only your hands. The rules are the same as football.\n\nBesides football, there are also many other modes, such as American football, baseball and crossbow.\n\nThis game is free, and you can play with other players.", "short_description": "A new type of sports competitive game. You can play football as a gorilla!\n"}]}, "developer_name": "Fengu Studio", "developer_privacy_policy_url": "http://web.manyatang.com/gorilla_soccer/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Fengu Studio", "support_website_url": null, "website_url": "http://web.manyatang.com/gorilla_soccer", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8152484748185990"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86774302_1665046250923671_19799670877099