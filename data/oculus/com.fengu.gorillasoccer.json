403\u76f8\u540c\u3002", "short_description": "\u4e00\u79cd\u65b0\u7684\u8fd0\u52a8\u7ade\u6280\u6e38\u620f\uff0c\u4f60\u5c06\u626e\u6f14\u4e00\u53ea\u7329\u7329\u6765\u8e22\u8db3\u7403\uff01"}, {"images": {"nodes": []}, "id": "1300754620947691", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gorilla Soccer", "keywords": ["FOOTBALL"], "long_description": "This is an interesting VR sports competitive game. You play as a gorilla.\n\nThe locomotion is inspired by Gorilla Tag. You can run, jump, and hit the ball using only your hands. The rules are the same as football.\n\nBesides football, there are also many other modes, such as American football, baseball and crossbow.\n\nThis game is free, and you can play with other players.", "short_description": "A new type of sports competitive game. You can play football as a gorilla!\n"}]}, "developer_name": "Fengu Studio", "developer_privacy_policy_url": "http://web.manyatang.com/gorilla_soccer/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Fengu Studio", "support_website_url": null, "website_url": "http://web.manyatang.com/gorilla_soccer", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8152484748185990"}, "review_messages": [""]}