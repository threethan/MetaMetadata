.oculuscdn.com/v/t64.5771-25/39031369_361638593515997_85557821188059079_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rvEjJngNDoMQ7kNvgHe05dN&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC0fTGCrMUqeHxoRhw44QlORIl5zVevqhKOKqeruGQp4Q&oe=672B5825"}]}, "id": "543759978375393", "locale": "en_US", "screenshots": [{"file_name": "Screen1.png", "id": "718350113718142", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86615891_718350117051475_3761648993260399099_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v7vg74F1pI4Q7kNvgGtK1Mn&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD5CSWG3rUsbzE62dSCdh-qdnco2bpnlSxImEMIKi7Y3A&oe=672B4EE0"}, {"file_name": "Screen2.png", "id": "848344957051608", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982488_848344960384941_5562188843677354763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KHnTej-Vf0AQ7kNvgG_-645&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAenGtO8Fb5RevaHAqH-vy23xWA1brUtmKRXp86Pm2yTw&oe=672B59C1"}, {"file_name": "Screen3.png", "id": "284399771207326", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003262_284399774540659_583941828548167615_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TRys4falKI4Q7kNvgH_jY2d&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDkdQdN5IR9F962hniVmcjwp4VGU4VYCE2k0mp0Im_Hew&oe=672B54DC"}, {"file_name": "Screen4.png", "id": "673323821473265", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86627652_673323824806598_2759875515778636570_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Ubpu5bwfAQQ7kNvgFHnrtH&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDLAxGV6OcXu83eRfZSlhvnOuwRW62rRrRYTlGOn8w_wg&oe=672B613A"}, {"file_name": "Screen5.png", "id": "415663131144126", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036626_415663134477459_183982206886202827_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iYV6E-V6yTcQ7kNvgF15dii&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD-OXToljmDPTsjlQSAOcrampwAADBJpfreOfnPAjG3Mw&oe=672B449B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Vignette Trailer.png", "id": "1767662870409827", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75394636_1767662877076493_8257219521689657681_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ccZYbUrhC2AQ7kNvgGtQm_0&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA7WLHr1fWPknDM5jLVUsvlFO3rDxGoSoG4S3KUGI0tpQ&oe=672B5694"}, "display_name": "In-dividus", "keywords": [], "long_description": "Stress concerns us all, sometimes having a very strong impact. Our tool offers physiological reinforcement and a way for self-awareness. Reinforcement consists of the implementation of a scientific protocol ; a inventive proposal pass through expression. We are accompanied by a neuro-cognition Researcher and working locally inter alia with the aim of lending equipment to people who do not have enough means.\n\nIn the reinforcement workspace is an interactive avatar as a guide. First of all, be aware of our body. In-dividus will then provide access to information on stress and our approach. We then discover the training workshop. Finally a synthesis takes place, with self-knowledge.\n...\nLe stress nous concerne tous et toutes, impactant parfois tr\u00e8s fortement. Notre outil propose du renforcement physiologique ainsi qu'une voie de connaissance de soi. Le renforcement consiste en la mise en oeuvre d'un protocole scientifique ; la proposition inventive concerne l'expression. Nous sommes accompagn\u00e9s par un Chercheur en neuro-cognition et oeuvrons localement avec notamment la vis\u00e9e de pr\u00eater des \u00e9quipements \u00e0 des personnes n'ayant pas assez de moyens.\n\nDans l'espace de travail pour le renforcement se trouve un avatar interactif - notre guide. D'abord bien conscientiser notre corps. In-dividus donne ensuite acc\u00e8s \u00e0 de l'information sur le stress et sur notre approche. On d\u00e9couvre alors l'atelier d'entra\u00eenement. Enfin une synth\u00e8se a lieu et vient la proposition de travail sur soi.", "short_description": "In-dividus is a tool about stress effects. It offers physiological reinforcement as well as a way to progress in self-knowledge.\n...\nIn-dividus est un outil en rapport avec les effets du stress. Il propose du renforcement physiologique ainsi qu'une voie pour progresser en connaissance de soi."}]}, "developer_name": null, "developer_privacy_policy_url": "https://technosethumain.sitew.fr/", "developer_terms_of_service_url": null, "publisher_name": "Technos et humain (sergemeunier73)", "support_website_url": null, "website_url": "https://technosethumain.sitew.fr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["fr"], "supported_input_devices": ["HAND_TRACKING", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8744235732265533"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982685_733269178946271_7984753534575837229_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=43M156mCKRIQ7kNvgHCbio3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAoiMpVV9gWm7rwENR3_YeTSIEcLPWT7XRnKmKHOUgnjA&oe=672B4942"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "In-dividus", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357