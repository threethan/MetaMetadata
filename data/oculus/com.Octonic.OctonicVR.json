7Ln3IYZuQRl-Q6gXGiO5Xg&oe=673355FD"}, {"file_name": "AppLab Arena.png", "id": "381962590733004", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974694_381962594066337_4605626946194605937_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ufSF1s4Lt0IQ7kNvgFoiUyQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMHRMM8YtN0n13ifWURpIGrVfz8PURCo7k1hV4i-lRJw&oe=673350AC"}, {"file_name": "AppLab 1st Person Arena.png", "id": "352366207096505", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031456_352366210429838_565353767722813819_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xBSe7etnQ0IQ7kNvgFrHKQZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZ8GQ_AIMCl0bVC6-2283MqjmEU1M_gtP-XJGgd8-eag&oe=67333FF8"}, {"file_name": "AppLab Arena Shot.png", "id": "747148913242465", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036671_747148916575798_2643521397375277232_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H94bs59VLksQ7kNvgEq2kgb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD510tP_5iz94nsuME5I4mJwSBSHJw94Zbsix-oQFYSCA&oe=67333289"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover art square  2560 x 1440.png", "id": "482031050588688", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974751_482031057255354_1914744784459287969_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LtczeKkmIoQQ7kNvgE-ZBTI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDl8yrFKAtLjzIlCdk_JSRK30IPuwaQIMEqzndQSPWKvA&oe=67333DF8"}, "display_name": "OctonicVR", "keywords": [], "long_description": "FITNESS TREADMILL REQUIRED. QUEST 2 ONLY. \n\nGIVE YOUR TREADMILL JOURNEY A DESTINATION. Transform boring treadmill workouts into VR fitness adventures with Octonic\u2019s virtual worlds, and inspire your personal best without leaving your home or gym!\n\nOur product allows you to combine immersive VR with the natural movements of walking, jogging or running on a treadmill. Just step on a treadmill, put on the VR headset, perform a quick VR/MR calibration, and start exercising naturally in VR. \n\nIn our Caves and Canyons environment, you\u2019ll run through natural landscapes, swerve in and out of caverns, and trot by towering mountains and arches. \n\nIn Arena, you\u2019ll transport yourself to an interplanetary competition. You can add up to seven AI competitors to join you on their marks, pushing you to your limit as you race to the finish line.\n\nThis app is designed for hand tracking (controllers are not needed). Use a non-fabric head strap (Oculus Elite, Kiwi, etc.) for jogging or running.\n", "short_description": "GIVE YOUR TREADMILL JOURNEY A DESTINATION. Transform boring treadmill workouts into VR fitness adventures with Octonic\u2019s virtual worlds, without leaving your home or gym!\n\nOur product allows you to combine immersive VR with the natural movements of walking, jogging or running on a treadmill. Just step on a treadmill, put on the VR headset, perform a quick VR/MR calibration, and start exercising naturally in VR. Your treadmill exercise will never be the same.\n\nFITNESS TREADMILL REQUIRED."}]}, "developer_name": "Octonic", "developer_privacy_policy_url": "https://octonicvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Octonic", "support_website_url": null, "website_url": "https://octonicvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "RELAXATION_MEDITATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes"