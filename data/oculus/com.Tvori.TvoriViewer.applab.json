/v/t64.5771-25/86615256_455288775502667_5947491372458712945_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5PfOh87axzEQ7kNvgEdsVWP&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCkeUfrL8C-shLCjZHV0Kj80g0zugRkZ6fx-uLxI-vfCg&oe=6777D359"}, {"file_name": "05.png", "id": "324094699020262", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982671_324094705686928_7023416651586249447_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=09eLc1hbPHgQ7kNvgGYnM_O&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBn2JMNRUC3M5gc4B_scaj8uHIJY5gEbD1s_qjD0Yzo4Q&oe=6777D862"}, {"file_name": "04.png", "id": "230881942091749", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/86615896_230881945425082_3303861453012130059_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_3JGl5dbxMoQ7kNvgFC1Gk2&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCbpWHWx2pfjwcx2MPNUms3qOgy3F0Mo9t3yd9Pk5dCSQ&oe=6777E781"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Viewer2550WHITETTT23.png", "id": "3159930287440672", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982535_3159930290774005_8911193312761706255_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PGnm1hNFQf8Q7kNvgE4bngc&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDL2ZvH1grf7NtmuzvW57mtWqCD0cdALl9myYfMazqmJw&oe=6777B5F5"}, "display_name": "The Viewer", "keywords": [], "long_description": "With the Tvori Viewer, you can gather as a team in VR to review and discuss your creations, made in Tvori. As a host you can control the presentation: play animations, switch between different scenes, jump from one viewpoint to another, mute guests, transit host rights.\n\nThe aim is to quickly share, present, and discuss 3D ideas in 3D with as little friction as possible.\nThe Viewer works on Oculus Quest, PC VR headsets and in a 2D desktop mode.", "short_description": "Tvori Viewer allows to host collaborative design reviews in VR and make impressive 3D pitches of your 3D designs and animated prototypes to colleagues and clients.\n\nYou create in Tvori editor and then export your creation to the Viewer. You can invites team members or clients to join the review session. \n\nThe aim of the Viewer is to quickly share, present, discuss  and get feedback for your 3D ideas in 3D with as little friction as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "https://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["UTILITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "276206754613489"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982701_227028775812875_8454787463991877417_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K9IQL4mIYN0Q7kNvgGNvFI5&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC9yw4rmlYMqLtvKhugajl_T-dY3h429iXqIMOoFjcL2g&oe=6777E716"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Viewer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Creativity", "id": "1819021644882647"}, {"topic_name": "Productivity", "id": "1063584910766706"}