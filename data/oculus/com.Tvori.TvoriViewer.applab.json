=1-7&_nc_sid=6e7a0a&_nc_ohc=uANtNUoTvbwQ7kNvgHwGEVL&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTyNCfHLeA8auaSXmsJXYRlhCOJBkpPlSk9lV6umT8qQ&oe=670D09D9"}, {"file_name": "05.png", "id": "324094699020262", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982671_324094705686928_7023416651586249447_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wRGms3W-WEEQ7kNvgHZPQfJ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCSkN0yMn177WD0hNy2SOnAi1rLG9dYAqhjSgT3x3FjYg&oe=670D0EE2"}, {"file_name": "04.png", "id": "230881942091749", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86615896_230881945425082_3303861453012130059_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N6sXJG6p5lMQ7kNvgGndgQg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwtG0-myzj4N5KRktkRAq4C2OImOYeznExj8G-pG9A7Q&oe=670D1E01"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Viewer2550WHITETTT23.png", "id": "3159930287440672", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982535_3159930290774005_8911193312761706255_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3VzS49bsLIYQ7kNvgGCqP6x&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQT4Qlb-0vr9C651qxFxWS16r8B3dP40JvKH2bReGQcg&oe=670CEC75"}, "display_name": "The Viewer", "keywords": [], "long_description": "With the Tvori Viewer, you can gather as a team in VR to review and discuss your creations, made in Tvori. As a host you can control the presentation: play animations, switch between different scenes, jump from one viewpoint to another, mute guests, transit host rights.\n\nThe aim is to quickly share, present, and discuss 3D ideas in 3D with as little friction as possible.\nThe Viewer works on Oculus Quest, PC VR headsets and in a 2D desktop mode.", "short_description": "Tvori Viewer allows to host collaborative design reviews in VR and make impressive 3D pitches of your 3D designs and animated prototypes to colleagues and clients.\n\nYou create in Tvori editor and then export your creation to the Viewer. You can invites team members or clients to join the review session. \n\nThe aim of the Viewer is to quickly share, present, discuss  and get feedback for your 3D ideas in 3D with as little friction as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tvori.co/privacy", "developer_terms_of_service_url": null, "publisher_name": "Tvori", "support_website_url": null, "website_url": "https://tvori.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "276206754613489"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982701_227028775812875_8454787463991877417_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qZq6EQll3fIQ7kNvgGvDmPJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOg28N2OxKNip9v9wwjJjrq69IuWnLuwYcceRcvHnD5Q&oe=670D1D96"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Viewer", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1618202214, "lastRevision": {"nodes": [{"id": "3594350997328841", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4061130713920469", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"},