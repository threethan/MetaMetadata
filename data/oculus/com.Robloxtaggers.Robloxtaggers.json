kNvgET-803&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAUQcw9SCLm0tn5OkUEBwANE6Rcl0zCh7dTG-6mrDZHw&oe=66E2B925"}, {"file_name": "DFRF (2) (1).png", "id": "1176875830402568", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86796482_1176875833735901_6466333344444458420_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KZf7QwbdrN4Q7kNvgGDqen9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnYrujumV4pBQWP7aDLIYEMkhsosEKOE2uHL4I0Ysbgw&oe=66E2EBAD"}, {"file_name": "DFRF (2) (1).png", "id": "834399874779444", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974733_834399878112777_3696016832261689858_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VVKi_QeSfEQQ7kNvgEOGCcL&_nc_ht=scontent.oculuscdn.com&oh=00_AYDAIO7C77LVmHg1heMW558bXzkmCSt2X_AwcND-IQh_8g&oe=66E2EA84"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DFRF (2) (1).png", "id": "7937188119653093", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75326678_7937188136319758_3777017794538859455_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GZp8t5DpPA8Q7kNvgEhEIaV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmtBbWfMNGzs8PrATAXYtUznzQP7CSvfeTGrwIx8u1Ig&oe=66E2E005"}, "display_name": "Roblox taggers", "keywords": [], "long_description": "Game Description: Roblox Taggers\nTitle: Roblox Taggers\n\nGenre: Action, Casual, Multiplayer\n\nPlatform: vr\n\nDeveloper: hellovr1\n\n\n\nOverview\nRoblox Taggers is an exhilarating, fast-paced multiplayer game where players engage in the classic playground game of tag within a vibrant, interactive Roblox world. Inspired by the timeless fun of \"Goeill a Tag,\" this game takes the simple concept of tag and elevates it with dynamic environments, diverse characters, and unique abilities.\n\nGameplay\nObjective:\nPlayers are divided into two teams: Taggers and Runners. The Taggers' goal is to chase and tag all the Runners before the timer runs out. Runners must avoid being tagged and use the environment and power-ups to outmaneuver the Taggers.\n\nGame Modes:\n\nClassic Tag: Traditional tag mode where Taggers must tag all Runners to win.\nInfected Tag: Tagged players become Taggers, spreading the infection until only one Runner remains.\nFreeze Tag: Tagged players are frozen in place until a teammate unfreezes them. Taggers win by freezing all players.\nMaps:\n\nUrban Playground: Navigate through a bustling cityscape with rooftops, alleys, and parks.\nEnchanted Forest: A magical forest filled with hiding spots and mystical creatures.\nSpace Station: A futuristic environment with zero-gravity zones and space-themed obstacles.\nPower-Ups:\n\n\n\n", "short_description": "Roblox Taggers is a dynamic and exciting game on the Roblox platform, inspired by the classic playground game of tag. In this game, players are divided into two groups: Taggers and Runners. The Taggers' objective is to chase and tag as many Runners as possible within a set time limit, while the Runners aim to avoid getting tagged. The game features various maps with obstacles and hiding spots, adding strategic depth and fun to the chase. Power-ups and special abilities can be collected to gain a"}]}, "developer_name": null, "developer_privacy_policy_url": "https://robloxtaggers.pages.dev/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "H3LLOVR1", "support_website_url": null, "website_url": "https://sites.google.com/view/robloxrunners/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_