0a&_nc_ohc=meH1sNBi3M8Q7kNvgFgoFJk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAjnHC99jGswxfZ_2t3xCsuoI8FSsANSWPrfri10oK-KQ&oe=6718D746"}, {"file_name": "DFRF (2) (1).png", "id": "1194849921708461", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982662_1194849925041794_862157149029389239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=APOkv2qUiQYQ7kNvgFGRk9m&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB2k-mt7pn2_EKCyMdxDdRL125wWuvX3Ndyib5Exn60mQ&oe=6718D676"}, {"file_name": "DFRF (2) (1).png", "id": "1645641829561341", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65397209_1645641832894674_7853497919645059059_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJBHCcaCkywQ7kNvgFoOtbx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxUJG0u3Lu-3PICFsrR_40NsmDNmA1yG117yY80093dg&oe=6718C6A5"}, {"file_name": "DFRF (2) (1).png", "id": "1176875830402568", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86796482_1176875833735901_6466333344444458420_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A-IIVHPyE1UQ7kNvgGiUmGf&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDCdzVqwhUVJrD_CbZMkb99NS9F6nWUM5jzPl-_B6wng&oe=6718F92D"}, {"file_name": "DFRF (2) (1).png", "id": "834399874779444", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974733_834399878112777_3696016832261689858_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SP7JaCMu-cIQ7kNvgECQ5Ws&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIzSgGSnxv-lxBimYZn-ri0OsLerSjjCA3I8uMr-t76w&oe=6718F804"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DFRF (2) (1).png", "id": "7937188119653093", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75326678_7937188136319758_3777017794538859455_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8EkkkXFi98EQ7kNvgGTHGjj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB33xKG-7e_hVIfFVxdAh_na4SROKDNRXO8pcvqKBSUig&oe=6718ED85"}, "display_name": "Roblox taggers", "keywords": [], "long_description": "Game Description: Roblox Taggers\nTitle: Roblox Taggers\n\nGenre: Action, Casual, Multiplayer\n\nPlatform: vr\n\nDeveloper: hellovr1\n\n\n\nOverview\nRoblox Taggers is an exhilarating, fast-paced multiplayer game where players engage in the classic playground game of tag within a vibrant, interactive Roblox world. Inspired by the timeless fun of \"Goeill a Tag,\" this game takes the simple concept of tag and elevates it with dynamic environments, diverse characters, and unique abilities.\n\nGameplay\nObjective:\nPlayers are divided into two teams: Taggers and Runners. The Taggers' goal is to chase and tag all the Runners before the timer runs out. Runners must avoid being tagged and use the environment and power-ups to outmaneuver the Taggers.\n\nGame Modes:\n\nClassic Tag: Traditional tag mode where Taggers must tag all Runners to win.\nInfected Tag: Tagged players become Taggers, spreading the infection until only one Runner remains.\nFreeze Tag: Tagged players are frozen in place until a teammate unfreezes them. Taggers win by freezing all players.\nMaps:\n\nUrban Playground: Navigate through a bustling cityscape with rooftops, alleys, and parks.\nEnchanted Forest: A magical forest filled with hiding spots and mystical creatures.\nSpace Station: A futuristic environment with zero-gravity zones and space-themed obstacles.\nPower-Ups:\n\n\n\n", "short_description": "Roblox Taggers is a dynamic and exciting game on the Roblox platform, inspired by the classic playground game of tag. In this game, players are divided into two groups: Taggers and Runners. The Taggers' objective is to chase and tag as many Runners as possible within a set time limit, while the Runners aim to avoid getting tagged. The game features various maps with obstacles and hiding spots, adding strategic depth and fun to the chase. Power-ups and special abilities can be collected to gain a"}]}, "developer_name": null, "developer_privacy_policy_url": "https://robloxtaggers.pages.dev/privacypolicy", "developer_terms_of_