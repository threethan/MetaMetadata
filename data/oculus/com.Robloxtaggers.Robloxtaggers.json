n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TfQeWcto7KgQ7kNvgHddT9o&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb8syCcJfnvhnli83xoH28KmJa899jmUGBCdvgjpczbA&oe=67139076"}, {"file_name": "DFRF (2) (1).png", "id": "1645641829561341", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65397209_1645641832894674_7853497919645059059_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uRyLKr_LXkgQ7kNvgGeWoR0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDTt1g7_P4DBkeEgqDU2Y-xGVU3yXgCw_tSzg43kxQGg&oe=671380A5"}, {"file_name": "DFRF (2) (1).png", "id": "1176875830402568", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86796482_1176875833735901_6466333344444458420_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OlDzz8is0xUQ7kNvgFkzhCd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD17WZXTJccJLAgsl8JZrI6MYyLXb1TN1KzK44-FoIHjQ&oe=6713B32D"}, {"file_name": "DFRF (2) (1).png", "id": "834399874779444", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974733_834399878112777_3696016832261689858_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kkLTX79gXccQ7kNvgHBNa08&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCioLAwuOIQk0ZMKYFzVLrZ0hWcIDIX_wRmsxs4j8TikA&oe=6713B204"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DFRF (2) (1).png", "id": "7937188119653093", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75326678_7937188136319758_3777017794538859455_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=484ig-n90VoQ7kNvgG6ZPPP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDbD-ztSjoOPOomQ-dfCB1daUpj9KFrKfuSL3l5p8Pt_A&oe=6713A785"}, "display_name": "Roblox taggers", "keywords": [], "long_description": "Game Description: Roblox Taggers\nTitle: Roblox Taggers\n\nGenre: Action, Casual, Multiplayer\n\nPlatform: vr\n\nDeveloper: hellovr1\n\n\n\nOverview\nRoblox Taggers is an exhilarating, fast-paced multiplayer game where players engage in the classic playground game of tag within a vibrant, interactive Roblox world. Inspired by the timeless fun of \"Goeill a Tag,\" this game takes the simple concept of tag and elevates it with dynamic environments, diverse characters, and unique abilities.\n\nGameplay\nObjective:\nPlayers are divided into two teams: Taggers and Runners. The Taggers' goal is to chase and tag all the Runners before the timer runs out. Runners must avoid being tagged and use the environment and power-ups to outmaneuver the Taggers.\n\nGame Modes:\n\nClassic Tag: Traditional tag mode where Taggers must tag all Runners to win.\nInfected Tag: Tagged players become Taggers, spreading the infection until only one Runner remains.\nFreeze Tag: Tagged players are frozen in place until a teammate unfreezes them. Taggers win by freezing all players.\nMaps:\n\nUrban Playground: Navigate through a bustling cityscape with rooftops, alleys, and parks.\nEnchanted Forest: A magical forest filled with hiding spots and mystical creatures.\nSpace Station: A futuristic environment with zero-gravity zones and space-themed obstacles.\nPower-Ups:\n\n\n\n", "short_description": "Roblox Taggers is a dynamic and exciting game on the Roblox platform, inspired by the classic playground game of tag. In this game, players are divided into two groups: Taggers and Runners. The Taggers' objective is to chase and tag as many Runners as possible within a set time limit, while the Runners aim to avoid getting tagged. The game features various maps with obstacles and hiding spots, adding strategic depth and fun to the chase. Power-ups and special abilities can be collected to gain a"}]}, "developer_name": null, "developer_privacy_policy_url": "https://robloxtaggers.pages.dev/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "H3LLOVR1", "support_website_url": null, "website_url": "https://sites.google.com/view/robloxrunners/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "cont