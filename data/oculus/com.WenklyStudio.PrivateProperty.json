e town from the hordes of zombies.\nBecome a deadly gunslinger and test your skill.\nWatch out for special zombies who can treat you with a pipe or exploding dynamite!\nPlay alone or with other players in online mode."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacypolicy", "developer_terms_of_service_url": "https://www.wenklystudio.com/pp-tos", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/private-property", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "345643904158212"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "419347717900715"}, {"status": "PUBLISHED", "id": "1423118921693228"}, {"status": "PUBLISHED", "id": "2223437521192035"}]}, "baseline_offer": {"id": "2223437521192035"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "419347717900715"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7491461937634836", "version": "1.0.2_OculusQuest"}, "id": "739177423754599", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_applic