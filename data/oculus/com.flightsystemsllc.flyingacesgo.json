d3-1.oculuscdn.com/v/t64.5771-25/38984460_308829680008016_6090779653163712512_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Q-zkYXULyIQ7kNvgHSE_3F&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv5oNHydRD7V78sspbzO777k511x9YbEPs_MgMyUwLaw&oe=6746FAB9"}, {"file_name": "migrated_image.png", "id": "493171268041581", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974641_902061403519016_4600076081876172800_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=whqtX62KkD0Q7kNvgEK0PV-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASg_p9sI3i9bu9nMO9l5Nq4ruxEhHNWZsHvyEWAbYYRw&oe=6746F468"}, {"file_name": "migrated_image.png", "id": "201299934426546", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982705_2240486472870773_1224532761348407296_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1GV7ylWnkRMQ7kNvgGbPCDI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBrNSmuETBvYuGnW_GdF12Nz5dn6vL7ipFp9f4pOw1Mxg&oe=67470CA2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/1u2hg1", "id": "306922216927954", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974479_306922220261287_3494691593129033728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NLbBFBxJJuwQ7kNvgG9R4Ma&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCAuLHxgcuJv2UHzbbi8YAFTktZlh1PPzHeTv3MAmB5aQ&oe=6746F8DF"}, "display_name": "Flying Aces: Navy Pilot Simulator", "keywords": ["Flight", "Simulator", "Simulation", "Aircraft", "Plane"], "long_description": "Flying Aces is a story based virtual reality experience unlike any other. You will experience what it\u2019s like to train to become a navy pilot. As gamers, we search for experiences that aren\u2019t possible in our daily lives. With Navy Pilot Simulator, we\u2019re able to bring the armchair pilot into the cockpit of a fighter jet. \n\nThe Oculus Go allows us to create an experience that previous generations of hardware aren\u2019t capable of. Conquering the game will require a skillset of hand eye coordination, decision making, and a tough stomach. You start out as a low ranked Ensign (below a junior lieutenant) tasked with learning the functionality of the F-18 Super Hornet. As you progress through the ranks, the missions become more challenging.\n\nFeatures:\n- Campaign with choice based missions\n- Combat Theater Mode\n- Landing Competition Mode\n- Free Flight Mode\n- Optimized Specifically for the Oculus Go\n- And more!", "short_description": "Flying Aces is a story based virtual reality experience unlike any other. You will experience what it\u2019s like to train to become a navy pilot. As gamers, we search for experiences that aren\u2019t possible in our daily lives. With Navy Pilot Simulator, we\u2019re able to bring the armchair pilot into the cockpit of a fighter jet."}]}, "developer_name": "TAS Systems Corp", "developer_privacy_policy_url": "https://tasappsystems.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TAS Systems Corp", "support_website_url": null, "website_url": "http://www.flightsystemsllc.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SIMULATION", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "472797544571205"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982467_2395243027204915_2735773453201178624_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2pjXPHUZ6KcQ7kNvgH-yeE1&_nc_zt=3&_nc_ht=scontent-iad3-2.o