78576771742890_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lu4fZrxzQFAQ7kNvgE8fe2K&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAFKqy5g87j8BNNObgTIdVky4V1uMvPkH4asRXJwMg8eA&oe=6756C16D"}, {"file_name": "\u30b9\u30af\u30b7\u30e7004en.png", "id": "975700746216926", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57570291_975700752883592_1980124384639185229_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AbjFFnI9m4kQ7kNvgHtkW2X&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBkpn-O4z4Tg4ByaCvtX9aliovDx9gEU60e46k0B6pwyQ&oe=6756DB09"}, {"file_name": "\u30b9\u30af\u30b7\u30e7005en.png", "id": "1572542546252650", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001689_1572542549585983_2593094984406766483_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vToyOuVVNSYQ7kNvgGt2VoJ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDIR2MIRiM1nhwIhQJTpmgXDK6zv6QAa_gsatkBoXHnAg&oe=6756E4EC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Homestar VR: Special Edition", "keywords": ["relax", "planetarium", "stars", "constellation", "astronomy"], "long_description": "1.This title is 'HomestarVR' SPECIAL EDTION (special specification).\n2.The narration of the planetarium uses very famous voice actors in Japan (Jun Fukuyama, Sayaka Ohara, Donna Burke)\n3.A new appreciation program has been added to the planetarium mode.\n4.A famous starry sky spot has been added to 'Starry Sky Selection'.\n5.Others\n\u00b7 Full Celestial Planetarium -starry sky extends right down to your feet\n\u00b7 Experience a sense of depth and feeling of immersion only possible with VR\n\u00b7 Reproduces an accurate sky based on NASA data\n\u00b7 Recreate what the starry sky was like on your birthday or special anniversary\n\u00b7 See selected locales famous for their starry skies with VR\n\u00b7 Scenery of the wonderful Milky Way that spreads out before you\n\u00b7 Somewhere in the 'Starry Sky Selection' where aurora appears\n\u00b7 'HomestarVR' brings you a world of 2,500,000 crystal-clear stars.", "short_description": "1.This title is 'HomestarVR' SPECIAL EDTION (special specification).\n2.The narration of the planetarium uses very famous voice actors in Japan (Jun Fukuyama, Sayaka Ohara, Donna Burke)\n3.A new appreciation program has been added to the planetarium mode.\n4.A famous starry sky spot has been added to 'Starry Sky Selection'."}, {"images": {"nodes": []}, "id": "1041777496218798", "locale": "ja_JP", "screenshots": [{"file_name": "\u30b9\u30af\u30b7\u30e7001jp.png", "id": "1190017244694699", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001702_1190017248028032_7230416444519635743_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H9_fLWdtFQkQ7kNvgEqpgRE&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCjXFYRcT633LdiI6ucQe2eKrJm5SlqggXMxSHwWGsPTA&oe=6756C19C"}, {"file_name": "\u30b9\u30af\u30b7\u30e7002jp.png", "id": "738729200255439", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982657_738729203588772_5361291790342939379_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QulZwviQJ4UQ7kNvgFulWec&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCAj0MdvzCCU5rrXnoR1wEczZh490-ghvzjiN8VfYzsEA&oe=6756C251"}, {"file_name": "\u30b9\u30af\u30b7\u30e7003jp.png", "id": "607420490204619", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001688_607420493537952_7294677861149719886_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AIE3njiRoSQQ7kNvgF6Xhd2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC8RTAlMwLpFsNPSlWJH_ikFJSrh3GqPJ3VxrMD8W-Uwg&oe=6756CA93"}, {"file_name": "\u30b9\u30af\u30b7\u30e7004jp.png", "id": "340297353630873", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003259_340297356964206_3442125940725843545_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FB8ZvdVqm4kQ7kNvgHv3Rfd&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAmuVEDUggBlFLWX09ikVlSHt4UpPOtZBdCYbq6h4Vfug&oe=6756D730"}, {"file_name": "\u30b9\u3