8576771742890_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SYXYzUPGu6wQ7kNvgGJ8DDA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBx1Fozs06A8cuNimq5sPGKDWNIR5WxTSVIe5FQNA94Hg&oe=677270ED"}, {"file_name": "\u30b9\u30af\u30b7\u30e7004en.png", "id": "975700746216926", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57570291_975700752883592_1980124384639185229_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-yDLtBFNUgQ7kNvgGX3452&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCwhrkr3axC0AjPU0SMXiSZCrNVI_BQO26rsaPt0n_Weg&oe=67728A89"}, {"file_name": "\u30b9\u30af\u30b7\u30e7005en.png", "id": "1572542546252650", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001689_1572542549585983_2593094984406766483_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M_hrsuNrNcwQ7kNvgGYlGeA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD0sWYhJkm7OTGjsMO7zM90DNOFJra00XDfvZf-VKYY0g&oe=6772946C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Homestar VR: Special Edition", "keywords": ["relax", "planetarium", "stars", "constellation", "astronomy"], "long_description": "1.This title is 'HomestarVR' SPECIAL EDTION (special specification).\n2.The narration of the planetarium uses very famous voice actors in Japan (Jun Fukuyama, Sayaka Ohara, Donna Burke)\n3.A new appreciation program has been added to the planetarium mode.\n4.A famous starry sky spot has been added to 'Starry Sky Selection'.\n5.Others\n\u00b7 Full Celestial Planetarium -starry sky extends right down to your feet\n\u00b7 Experience a sense of depth and feeling of immersion only possible with VR\n\u00b7 Reproduces an accurate sky based on NASA data\n\u00b7 Recreate what the starry sky was like on your birthday or special anniversary\n\u00b7 See selected locales famous for their starry skies with VR\n\u00b7 Scenery of the wonderful Milky Way that spreads out before you\n\u00b7 Somewhere in the 'Starry Sky Selection' where aurora appears\n\u00b7 'HomestarVR' brings you a world of 2,500,000 crystal-clear stars.", "short_description": "1.This title is 'HomestarVR' SPECIAL EDTION (special specification).\n2.The narration of the planetarium uses very famous voice actors in Japan (Jun Fukuyama, Sayaka Ohara, Donna Burke)\n3.A new appreciation program has been added to the planetarium mode.\n4.A famous starry sky spot has been added to 'Starry Sky Selection'."}, {"images": {"nodes": []}, "id": "1041777496218798", "locale": "ja_JP", "screenshots": [{"file_name": "\u30b9\u30af\u30b7\u30e7001jp.png", "id": "1190017244694699", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001702_1190017248028032_7230416444519635743_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R1zsu8QJedEQ7kNvgEVyw_8&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBLOjp9z--u-cYA8uF6cjiAIYDO4TbIVdFomyhG-bJrGw&oe=6772711C"}, {"file_name": "\u30b9\u30af\u30b7\u30e7002jp.png", "id": "738729200255439", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982657_738729203588772_5361291790342939379_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EA4wXt77-4kQ7kNvgFQSY2r&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCBskCY6qgKYj_p9-mWpWtgCKKG2QrAfW4_WVR3ZZkm_w&oe=677271D1"}, {"file_name": "\u30b9\u30af\u30b7\u30e7003jp.png", "id": "607420490204619", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001688_607420493537952_7294677861149719886_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pFCgwzLdr4AQ7kNvgHStvFE&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBVX_N6jga0bAD7FZZH-8he0g_VV-F4y4CF87nge4nN5A&oe=67727A13"}, {"file_name": "\u30b9\u30af\u30b7\u30e7004jp.png", "id": "340297353630873", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003259_340297356964206_3442125940725843545_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=761DpwRCvRcQ7kNvgGJ0emA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC3D8AcZTLTjJ_vCi3gOfVQcduBrb15HgM4e5uRFFBZzQ&oe=677286B0"}, {"file_name": "\u30b9\u30