56399", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974897_907338776889732_2705424282686344400_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VAKRGM872_EQ7kNvgHSRVNi&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDY7UQbn6JSVa4mLb2j4VrOGhA2T_vQo5obQoSL5FJLbw&oe=678783BB"}, {"file_name": "Screenshot_GymScene_03_2560x144.png", "id": "771013554086692", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974721_771013557420025_854679852112542484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oWQ238fMy-sQ7kNvgFtqbEL&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAgDH-np3ltcikoNZgeS4uHWZjIypij_rLCkqxSwQU2eg&oe=6787A449"}, {"file_name": "Screenshot_GymScene_2560x1440.png", "id": "740489623947052", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974497_740489627280385_4764678504717223132_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rc1tEOMtB18Q7kNvgEW_SKY&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBaLF5q3bQdsdrPygocMRNixi79uiQD21NUWA3ZfteqKQ&oe=6787A1FF"}, {"file_name": "Screenshot_GymScene_02_2560x144.png", "id": "449773693401688", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982563_449773696735021_610680784429811519_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mBhLTJkh2PUQ7kNvgGfip4x&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCJzYctegda1c61U40StZxtLXeENPc0Wk74oJwGSvH2lg&oe=67879DED"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Golden Gloves VR", "keywords": [], "long_description": "Play, train and compete with Golden Gloves VR.  Building on 100 years of history, we\u2019re proud to bring the most recognizable brand in boxing into the digital world. Train like a fighter in our virtual gym, as you immerse yourself in the most realistic boxing experience you\u2019ll find outside of a brick and mortar facility. Starting as a novice boxer, you\u2019ll follow a career path, working your way through the ranks to become a Golden Gloves Champion. Developed by Engine Room VR, a gaming company owned and operated by a licensed and certified boxing coach, promoter, and gym owner, Golden Gloves VR is designed to create a realistic boxing experience. Learn the fight styles and personalities of each of your opponents as you advance through the ranks, perfecting your own boxing skills. Train for competition, using our state-of-the art boxing equipment, with physics that perfectly mimic the real world experience. Enhance your virtual training with our online support.", "short_description": "Play, train and compete with Golden Gloves VR.  Building on 100 years of history, we\u2019re proud to bring the most recognizable brand in boxing into the digital world. Train like a fighter in our virtual gym, as you immerse yourself in the most realistic boxing experience you\u2019ll find outside of a brick and mortar facility. Starting as a novice boxer, you\u2019ll follow a career path, working your way through the ranks to become a Golden Gloves Champion."}]}, "developer_name": null, "developer_privacy_policy_url": "https://goldenglovesvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Engine Room VR LLC", "support_website_url": "https://goldenglovesvr.com/contact/", "website_url": "https://goldenglovesvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "SPORTS", "ACTION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "u