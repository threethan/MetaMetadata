RjM9o6Vw&oh=00_AYCB7up_CZOA22DG3E2PyLH31a7LpSroael7rrWuNUKORg&oe=66E97C28"}, {"file_name": "05_1440.png", "id": "6278120392269968", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984466_6278120405603300_6768471527037336311_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oSqkLeRryPIQ7kNvgGlApW6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5HCY4GL_bib6SoRjM9o6Vw&oh=00_AYCr3FnW3K0FEzZccd3iJGJLqYwgYagCY8tmmweflm1nWA&oe=66E94E35"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Masternoid_CoverArt_3840x2160_Resized.png", "id": "696935008935394", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036615_696935015602060_6147907796215355231_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UXMmVx3Y0R0Q7kNvgEm2Zlw&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5HCY4GL_bib6SoRjM9o6Vw&oh=00_AYA4WMweQjXAHE9qY6xpgTjzxEP5-5jLem8h5Uku0Fp_ZQ&oe=66E9779F"}, "display_name": "Masternoid", "keywords": [], "long_description": "Masternoid is a pure arcade brick breaker, reimagined for the age of VR.\n\nImmerse yourself in a bright and colourful world and embrace the meditative power of coordinated voxel explosions. Followed by the sounds of an original soundtrack that adapts to gameplay and will keep you in your flow zone.\n\nMaster the art of destruction, in a place where your trusted energy wave blaster from the future is your only friend. Use it to telekinetically juggle multiple ultrasonic balls with great finesse and precision.\n\nBlast your way through 50 handcrafted levels of voxel goodness, and ascend to the top of the leaderboards like a true arcade legend. \n\nPlay seated or standing, as minimal physical effort and space is expected. Just a single controller is required to play, right or left is up to you.", "short_description": "Masternoid is a pure arcade brick breaker, reimagined for the age of VR.\n\nImmerse yourself in a bright and colourful world and embrace the meditative power of coordinated voxel explosions. Followed by the sounds of an original soundtrack that adapts to gameplay and will keep you in your flow zone.\n\nBlast your way through 50 handcrafted levels of voxel goodness, and ascend to the top of the leaderboards like a true arcade legend. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.masternoid.com/privacy-policy-meta", "developer_terms_of_service_url": null, "publisher_name": "Pixel Magnet", "support_website_url": null, "website_url": "https://masternoid.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1290268938281106"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031384_957167355544112_6462924691106208595_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FXdgQetJ9gsQ7kNvgGeJMJs&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5HCY4GL_bib6SoRjM9o6Vw&oh=00_AYCSKcK-CLHplRJuAbvotWu5GUSujffOL_I6vRfZkiAraA&oe=66E95B3D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Masternoid", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1650473866, "lastRevision": {"nodes": [{"id": "6818689551490641", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5975