description": "Car Parking Simulator is a fully interactive, realistic and immersive car parking experience. Introducing one of the most advanced and dynamic car physics in VR.\n\nGiving players more wings of freedom by introducing a Free Roam mode in a town with a realistic traffic system, bustling with various fun activities and challenges to compete in, or just drive around and chill with any of your unlocked vehicles.\n\nFeatures:\n- All cars have realistic controls and interactive interiors with customizable right or left steering orientations.- Three main vehicle challenges, ranging from Sedan, SUV and Hatchback.\n- Formula One (F1) vehicle available as a bonus car for fun!\n- Different exhilarating environments in different parts of the day and night cycles.\n- Total 65 levels, giving you ratings based on your driving and challenge completion skills.\n- A free roam mode for players to explore using any of the unlocked vehicles or to try its own activities and challenges.", "short_description": "Car Parking Simulator is a fully interactive, realistic and immersive car parking experience. The game has one of the best vehicle physics simulations in VR."}]}, "developer_name": "Sloppy Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1D6BNfGb6atkqQcC0nfnctZJA78mcOWpeP5nuttz7Wlw/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1CXW3P6emNNMZfK3T2PD8m-kpTUXwP29LklLVhr6prX8/edit?usp=sharing", "publisher_name": "Sloppy Studios", "support_website_url": null, "website_url": "https://sloppystudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "SIMULATION", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null