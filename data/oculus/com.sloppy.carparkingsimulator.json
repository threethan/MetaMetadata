h=00_AYAdOgp75sn2kts-Nzaz8o_66xZF-CS6BQdcMDsYwWbYgA&oe=66E80BCB"}, {"file_name": "oculusAsset 12.png", "id": "1319764898422698", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572929_1319764901756031_7982105661700720073_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aBi1CoIZXJMQ7kNvgGGmuzT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al35td3Y8L8UqQ2mg2FEdXa&oh=00_AYCkW2rj3vebp2eZLIIYf8f1JNgdZeCTFNADeHA6vsbYHw&oe=66E82997"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Asset 5.png", "id": "895648881253348", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_895648884586681_4943548350184216825_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-HHSMQ3YEp8Q7kNvgEqjRGU&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al35td3Y8L8UqQ2mg2FEdXa&oh=00_AYDCs37SeNHYQ3IHmveI_0cT5Zc5YNpqT6OwEyeNk43KMg&oe=66E81CC9"}, "display_name": "Car Parking Simulator - Driving and Racing", "keywords": ["Driving", "racing", "drive", "parking", "car"], "long_description": " # \ud83d\udd30  Learn To Drive In VR   \ud83d\udd30\n\n- Used by thousands of people to learn driving and parking.\n- The game has also helped reduce **driving anxiety**. \n- A **Free Roam City** featuring various challenges like racing, taxi, etc.\n- Left and Right steering options.\n\n# \ud83d\udd79\ufe0f Controls designed for VR\nAll cars have realistic controls and interactive interiors with customizable right or left steering orientations.\n{1532401434021514}\n\n\n# \ud83d\udccc Realistic Mirrors and Interiors\nAll cars have realistic mirrors and left and right-hand driving options.\n\n{865634415412163}\n\n# \ud83c\udfc1 Multiple Challenges\nComplete various racing challenges, including taxi missions, rooftop missions, checkpoint races, and much more.\n\n{461614410055878}\n\n# \ud83d\udefb Varitey of cars\nHatchback, sedan, SUV, or sports car \u2013 we have it all for you to hone your driving and challenge completion skills.\n\n{1027966278361492}\n\n\ud83d\udccc**Download now** to learn to drive or hone your parking skills. Complete racing challenges, undertake taxi missions, or drive and race on the tops of buildings.\n ", "short_description": "Learn to drive in VR with Car Parking Simulator, offering both left and right-hand driving. Experience over 65 different parking levels and a Free Roam City featuring various challenges like racing, taxi missions, and much more."}]}, "developer_name": "Sloppy Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1D6BNfGb6atkqQcC0nfnctZJA78mcOWpeP5nuttz7Wlw/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1CXW3P6emNNMZfK3T2PD8m-kpTUXwP29LklLVhr6prX8/edit?usp=sharing", "publisher_name": "Sloppy Studios", "support_website_url": null, "website_url": "https://sloppystudio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "SIMULATION", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8342002585852111"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75241704_802491125202664_2274165713220876819_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CxoSHJwT3q4Q7kNvgHXsFZk&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al35td3Y8L8UqQ2mg2FEdXa&oh=00_AYA-kqImw5GgM9gnTolrAGtfiGNNKCz1PXQC65ifmL3QPA&oe=66E7FE8B"}, "is_concept": false, "is_test": false, "is