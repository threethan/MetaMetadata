2.oculuscdn.com&oh=00_AYDjzaO5oUwjGjfZYHyAP9m9sxWyN-ZAkY6yahVScN_4mA&oe=675579E8"}, {"file_name": "Asset 9.png", "id": "189367996273042", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302223_189367999606375_1811081238421952140_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=48k0V4lUuukQ7kNvgFI6tvC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAuRFe3z7nWpsSDf4D28Sh5ritR6u0E9d_w5o0O6o0GUA&oe=67559DB8"}, {"file_name": "oculusAsset 14.png", "id": "815349909193915", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75361346_815349912527248_5492795874282751772_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EmE-NK8YkRUQ7kNvgG_Taaw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMZddfPt_83TlVlrRflwbpJTXABmSCrq2knAcYqhm1TQ&oe=6755784B"}, {"file_name": "oculusAsset 12.png", "id": "1319764898422698", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572929_1319764901756031_7982105661700720073_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BC5QoZiw0zkQ7kNvgHVMhdX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAH1NxkaK-0LtUzFIVHwgLoXQwKI_ebqmtnhFqRImUjA&oe=67559617"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Asset 5.png", "id": "895648881253348", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984445_895648884586681_4943548350184216825_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WkSR4K2_XN8Q7kNvgFi4nwU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJFBrAj6xGhdVBLNGfNzQLRi5trzr7-cKlRhX8THM8IQ&oe=67558949"}, "display_name": "Car Parking Simulator", "keywords": [], "long_description": "Car Parking Simulator is a fully interactive, realistic and immersive car parking experience. Introducing one of the most advanced and dynamic car physics in VR.\n\nGiving players more wings of freedom by introducing a Free Roam mode in a town with a realistic traffic system, bustling with various fun activities and challenges to compete in, or just drive around and chill with any of your unlocked vehicles.\n\nFeatures:\n- All cars have realistic controls and interactive interiors with customizable right or left steering orientations.- Three main vehicle challenges, ranging from Sedan, SUV and Hatchback.\n- Formula One (F1) vehicle available as a bonus car for fun!\n- Different exhilarating environments in different parts of the day and night cycles.\n- Total 65 levels, giving you ratings based on your driving and challenge completion skills.\n- A free roam mode for players to explore using any of the unlocked vehicles or to try its own activities and challenges.", "short_description": "Car Parking Simulator is a fully interactive, realistic and immersive car parking experience. The game has one of the best vehicle physics simulations in VR."}]}, "developer_name": "Sloppy Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1D6BNfGb6atkqQcC0nfnctZJA78mcOWpeP5nuttz7Wlw/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1CXW3P6emNNMZfK3T2PD8m-kpTUXwP29LklLVhr6prX8/edit?usp=sharing", "publisher_name": "Sloppy Studios", "support_website_url": null, "website_url": "https://sloppystudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "SIMULATION", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3245153735708266"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "10633860685