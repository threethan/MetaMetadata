, "id": "228931572223712", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568668_228931575557045_7580447718787206327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PoGjyyMUB4IQ7kNvgEWVgWb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCIoALE7iPdAn9XXKYcdRnt7aA_g8syAQBE63y12uPd2Q&oe=66E029E9"}]}, "id": "7707694522662645", "locale": "en_US", "screenshots": [{"file_name": "Asset 5.png", "id": "2808144376122398", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982583_2808144379455731_3843130385319848552_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4NghOU7tweAQ7kNvgEU0W62&_nc_ht=scontent.oculuscdn.com&oh=00_AYCaC_Iq1WrGrjXwGBM4k5f3MlrxbXfm6O89pBXP1Nk-NQ&oe=66E01BFA"}, {"file_name": "oculusAsset 13.png", "id": "901639690610540", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443237_901639693943873_1485624828755765223_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HCYreXiR5UEQ7kNvgGJMdVa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCO0XyZLF8unLiyrNOwX2DZZ0VPDz4EpawSTltab_J6Bw&oe=66E02468"}, {"file_name": "Asset 9.png", "id": "189367996273042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302223_189367999606375_1811081238421952140_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W9VijmSNvOEQ7kNvgHcqN9G&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRIaVAs9XIEooonG3lQfZkshUedVgJQZqoZ1763Uk09A&oe=66E04838"}, {"file_name": "oculusAsset 14.png", "id": "815349909193915", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75361346_815349912527248_5492795874282751772_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f7oVuRuRbjEQ7kNvgE0yVuu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgK3pksCK4VFc8JQnf_GNdoHTY_reIUGm2CwJvJFwXOg&oe=66E022CB"}, {"file_name": "oculusAsset 12.png", "id": "1319764898422698", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572929_1319764901756031_7982105661700720073_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2vO8sRY6YPQQ7kNvgG70wyZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkrF6IvNszt1ejxAu6j9V2f6lNZX4PgE5KHqHQxRzD_Q&oe=66E04097"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Asset 5.png", "id": "895648881253348", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_895648884586681_4943548350184216825_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=toayUf6OpyEQ7kNvgFKIWR1&_nc_ht=scontent.oculuscdn.com&oh=00_AYA4LRQHeZNq6uwGnumOLqYqEAX3t4t4otuy1hcbGsVzfQ&oe=66E033C9"}, "display_name": "Car Parking Simulator - Driving and Racing", "keywords": ["Driving", "racing", "drive", "parking", "car"], "long_description": " # \ud83d\udd30  Learn To Drive In VR   \ud83d\udd30\n\n- Used by thousands of people to learn driving and parking.\n- The game has also helped reduce **driving anxiety**. \n- A **Free Roam City** featuring various challenges like racing, taxi, etc.\n- Left and Right steering options.\n\n# \ud83d\udd79\ufe0f Controls designed for VR\nAll cars have realistic controls and interactive interiors with customizable right or left steering orientations.\n{1532401434021514}\n\n\n# \ud83d\udccc Realistic Mirrors and Interiors\nAll cars have realistic mirrors and left and right-hand driving options.\n\n{865634415412163}\n\n# \ud83c\udfc1 Multiple Challenges\nComplete various racing challenges, including taxi missions, rooftop missions, checkpoint races, and much more.\n\n{461614410055878}\n\n# \ud83d\udefb Varitey of cars\nHatchback, sedan, SUV, or sports car \u2013 we have it all for you to hone your driving and challenge completion skills.\n\n{1027966278361492}\n\n\ud83d\udccc**Download now** to learn to drive or hone your parking skills. Complete racing challenges, undertake taxi missions, or drive and race on the tops of buildings.\n ", "short_description": "Learn to drive in VR with Car Parking Simulator, offering both left and right-hand driving. Experience over 65 different parking levels and a Free Roam City featuring various challenges like racing, taxi missions, and much more."}]}, "developer_name": "Sloppy Studios", "