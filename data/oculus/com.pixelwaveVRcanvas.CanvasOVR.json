e=67614AC8"}, {"file_name": "migrated_image.png", "id": "520448518667584", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162754_606268173052132_4783216425135243264_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cFHWUu3AMWEQ7kNvgEsGkLd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQ7JQrAvkDJ3VjTrwmkVowIglbbbbp8rUTFny62Tunog&oe=67617F8E"}, {"file_name": "migrated_image.png", "id": "202221927782313", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162711_1939252456341455_6270244071353090048_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BYwRVs3znvMQ7kNvgFtQ0UW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYk2cR1vyN2gxIwJuCRZh2ctkyN48zqtwdUQDaOxPPdw&oe=676175C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3 vr canvas 2560 x 1440.png", "id": "151209828942432", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162703_151209832275765_5614153616064512000_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oiA6tVIQrdQQ7kNvgFpzjFi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClzb7SoZHKExrkx1xt7xvK6mgP-ZsajwycQHEhbRh40w&oe=67616461"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before in Gear VR or Real world!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.