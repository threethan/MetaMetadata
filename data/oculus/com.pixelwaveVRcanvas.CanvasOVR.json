264_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g2BEstThrsQQ7kNvgEwRmRn&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCRUB7m-Ik0R8VGfvR3FBlFnMXR1IhVQOhPRQvXPy1c9A&oe=6728CF0E"}, {"file_name": "migrated_image.png", "id": "206266577352150", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/11162788_1695949920436921_31988851996098560_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oL92GiDV1PoQ7kNvgEhVUp1&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDQqk8cKrFi_f63XJ8owuzNXT7VUx_vfp0l7fuIA8gR-A&oe=6728BAA3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4 vr canvas 2560 x 1440.png", "id": "2691314447788155", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974789_2691314451121488_8474531208594795837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RHHH_Bnyid0Q7kNvgE_RdPC&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCu1cHVE301FyTdrDcstl8sJd3y9Eol04YcKH-FTUA-5g&oe=6728A312"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": 