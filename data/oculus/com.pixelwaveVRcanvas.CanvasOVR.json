: "https://scontent.oculuscdn.com/v/t64.5771-25/11162788_1695949920436921_31988851996098560_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jgkoOnSaLeMQ7kNvgHXa3hg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCanyD259_YsU-UaySW38g45jpzBRZOVG9hfIYo63cWYQ&oe=66F7F323"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4 vr canvas 2560 x 1440.png", "id": "2691314447788155", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974789_2691314451121488_8474531208594795837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ekPT36K0qZ4Q7kNvgHUfrK4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCn-nielyWwU9-aex5VASMSaQP43p6wpNqw7PDu0mQDSg&oe=66F7DB92"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": "Pixelwave", "developer_privacy_policy_url": "http://deepbrain.xyz/canvas/privacy-policy.html", "developer_terms_of_service_url": "http://deepbrain.xyz/canvas/terms-of-use.html", "publisher_name": "DeepBrain", "support_website_url": "https://m.youtube.com/channel/UCTO1_2onnlwtul08nxxFeaQ", "website_url":