ad3-2.oculuscdn.com&oh=00_AYAr-iMPWlerRLjUXe2LtWEcAdBAggMqnKc_stXrzV2taQ&oe=67064FCE"}, {"file_name": "migrated_image.png", "id": "206266577352150", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162788_1695949920436921_31988851996098560_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=50fBEpUE2AwQ7kNvgGfNX1G&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_52b4q4pxtd2fftMr3iA2qu-SUMT6bh99rSc8p3D6IQ&oe=670673A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4 vr canvas 2560 x 1440.png", "id": "2691314447788155", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974789_2691314451121488_8474531208594795837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9_KezznfLqEQ7kNvgGLxDjZ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA87hJdLdLiT7WVEVAHbSWNmlYMeV8ombtuV0jMc67nwg&oe=67065C12"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": "Pixelwave", "developer_privacy_policy_url": "http://deepbrain.xyz/canvas/privacy-policy.html", "developer_terms_of_service