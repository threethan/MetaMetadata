4121725985510_1960196479456903168_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IhT_aae2XlgQ7kNvgF-rEXd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaULta97gzet23iqzcP0iL7&oh=00_AYB0BTlT47YRn9UfE_MqvqVbswmtbpzfE20_SnVMFjQUsg&oe=66DEC648"}, {"file_name": "migrated_image.png", "id": "520448518667584", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162754_606268173052132_4783216425135243264_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cLV17E9oBvAQ7kNvgG8LmoK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaULta97gzet23iqzcP0iL7&oh=00_AYAbsXCT-e-j3RmKwjLNUy50T5BfOd3X8w5NTSG4jIakBA&oe=66DEC2CE"}, {"file_name": "migrated_image.png", "id": "202221927782313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162711_1939252456341455_6270244071353090048_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AdcXWtwlKIYQ7kNvgH112v4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaULta97gzet23iqzcP0iL7&oh=00_AYCnuV0leUj9YXLXqELJ6T2PoXKtezvpoyAo5YPH7sK1yQ&oe=66DEF149"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3 vr canvas 2560 x 1440.png", "id": "151209828942432", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162703_151209832275765_5614153616064512000_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lR8Yjrp0EzoQ7kNvgFNUZfy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaULta97gzet23iqzcP0iL7&oh=00_AYDXKegAVPKWc8Wxfbqpv-mmF-vevzTlSreMFPmQA62caw&oe=66DEDFE1"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before in Gear VR or Real world!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": "Pixelwave", "developer_privacy_policy_url": "http://www.deepbrain.xyz/canvas", "developer_terms_of_service_url": "http://www.deepbrain.xyz/canvas", "publisher_name": "DeepBrain", "support_website_url": null, "website_url": "http://www.deepbrain.xyz/canvas", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["SIMULATION", "UTILITY", "EXPLORATION", "PRODUCTIVITY", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_CA"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1517165121986660"}}]}, "scheduled_offers": {"count": 8, "nodes": [{"status": "PUBLISHED", "id": "469503713469743"}, {"status": "PUBLISHED", "id": "211198502776543"}, {"status": "PUBLISHED", "id": "2120192071329750"}, {"status": "PENDING", "id": "200647097173980"}, {"status": "PUBLISHED", "id": "212502389441951"}, {"status": "PUBLISHED", "id": "1970675426591695"}, {"status": "PUBLISHED", "id": "2004536146472334"}, {"status": "PENDING", "id": "370514356705750"}]}, "baseline_offer": {"id": "1970675426591695"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1528995600, "status": "PUBLISHED", "id": "469503713469743"}]}, "liveChannel