e7a0a&_nc_ohc=JXVN75QdV9EQ7kNvgG8SbR7&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAeuBad8RnCqmP_s33G7ew0ZbBYXqiK0kmS_65K5kXjOw&oe=6718C4CE"}, {"file_name": "migrated_image.png", "id": "202221927782313", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162711_1939252456341455_6270244071353090048_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GCDOTqEeu4kQ7kNvgFlP4LJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJGsPPAvSl0No2W0VfRrPEJqLnYWg4KrY8zc7UM6s3CQ&oe=6718F349"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3 vr canvas 2560 x 1440.png", "id": "151209828942432", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162703_151209832275765_5614153616064512000_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cNFSlsTY1W0Q7kNvgF14vwX&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATGXRmVuPIOk9EShr_Vh2foYBzIY6BL4XJs_4rZpuLWA&oe=6718E1E1"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before in Gear VR or Real world!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": "Pixelwave", "developer_privacy_policy_url"