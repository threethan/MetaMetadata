n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uJBJ9GaAdtUQ7kNvgEM1DVB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0uscxBwoCdAhqEXI5eXwW3ZyH5GhD4E5xYZbCd9wL1Q&oe=6723890E"}, {"file_name": "migrated_image.png", "id": "206266577352150", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162788_1695949920436921_31988851996098560_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mE8Jlc3Xnl8Q7kNvgEBEyV0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbLKh-hKyP9ktC38o2Uv7RuoYrH2HRjTSW0OFIDQCRzQ&oe=672374A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4 vr canvas 2560 x 1440.png", "id": "2691314447788155", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974789_2691314451121488_8474531208594795837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fV7ZMluitvQQ7kNvgGmKHP5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmyPZnbO61gHgRutnhTVFfGnC07WSmqssJU5SAOGSK1Q&oe=67235D12"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": "Pixelwave", "developer_privacy_policy_url": "http://deepbrain.xyz/canvas/privacy-policy.html", "developer_terms_of_service_url": "http://deepbrain.xyz/canvas/terms-of-use.html", "publisher_name": "DeepBrain", "support_website_url": "https://m.youtube.com/channel/UCTO1_2onnlwtul08nxxFeaQ", "website_url": "http://www.deepbrain.xyz/canvas", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_CA"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1141016476438942"}, "review_messages": ["", "Both your Privacy Policy URL and your Terms of Service URL point to the same address. If a Terms of Service URL is provided, it must link to a different document on your website.", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974808_752752358610607_1290946574223743558_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hoLeiGTD0tsQ7kNvgHdd7Ym&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVER3sJxZmQHWaDheYd19T7hsGW5wtOKO1zDq7_W40Ig&oe=672369B7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Canvas", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1513020449, "lastRevision": {"nodes": [{"id": "1594572060598890", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1242229392548045", "is_first_party": false, "enables_in_app_ads": false, "is_concept"