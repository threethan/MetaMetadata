ad3-2.oculuscdn.com&oh=00_AYC5KFPLHvz35MXWAcmKa_1wGiTXYY7WmP9mjTvvZiANEg&oe=6703ACCE"}, {"file_name": "migrated_image.png", "id": "206266577352150", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162788_1695949920436921_31988851996098560_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EAV8wQBw60kQ7kNvgHbkume&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoEAEql4fHV3EKRQyYlC4Ior_1fOacAdvOuo4X6XSiMQ&oe=6703D0A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4 vr canvas 2560 x 1440.png", "id": "2691314447788155", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974789_2691314451121488_8474531208594795837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9_KezznfLqEQ7kNvgHQISZq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDef1kKR-HoipWUuqESkRULza-38UAKow7_j9lf2m4-4A&oe=6703B912"}, "display_name": "VR Canvas", "keywords": ["Paint", "Colors", "Canvas", "Brushes", "Palette"], "long_description": "Experience immersive painting, feel psychedelic colors as you have never before!\nArtists and creators get ready to lost in Dreams.\n\nVR CANVAS lets you paint in 3D world space with full control over all 3 axis. Unleash your creativity with 3D intuitive brush strokes, experience vibrant colors, use animated brushes for fire, smoke, leafs and even tiny little stars. \n\nYour headset is your canvas and the controller your brushes. Your palette is your imagination.\n \nThe possibilities are endless.\n\n\u25cf Art faster with intuitive brushes.\n\u25cf Walk and draw.\n\u25cf Draw animated fire, smoke and more 14 effects.\n\u25cf Change brush sizes.\n\u25cf Change brush distance.\n\u25cf Draw lifting yourself up or down.\n\u25cf Use animated rain, snow, spooky fog.\n\u25cf Choose from 7 different backgrounds. With music.", "short_description": "Unleash your imagination, Experience your dream."}]}, "developer_name": "Pixelwave", "developer_privacy_policy_url": "http://deepbrain.xyz/canvas/privacy-policy.html", "developer_terms_of_service