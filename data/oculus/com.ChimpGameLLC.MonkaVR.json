: "Screenshot 2024-09-12 144227.png", "id": "429259540172022", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974613_429259543505355_3388875102320643121_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_JoKPrp_t9sQ7kNvgFyA4Og&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHlzDmeU1yFo6b4OqDE5sUCGYKENMqT8U7XznoKb7KHA&oe=67236DD8"}, {"file_name": "Screenshot 2024-09-12 144527.png", "id": "1858092104681999", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984470_1858092108015332_4416070985556907193_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wcRRvoBWxQoQ7kNvgHz3_qb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSUQl1lnuFLFlc81Mo3kXYlyTa6UuQUdw2zirPPCL-kQ&oe=672372A9"}, {"file_name": "Screenshot 2024-09-12 144328.png", "id": "1052047419657821", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001679_1052047426324487_2129466214041454670_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_NATogkIPPcQ7kNvgEHfRwR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfC762YO6nnMFlaIf4UrAeBrtilVApNTY9EYH-pzcokQ&oe=67237ADE"}, {"file_name": "Screenshot 2024-09-12 155817 (1).png", "id": "1106964280867783", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974735_1106964284201116_8834897816866465643_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x7qiP8mNoqMQ7kNvgGs8-Rt&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4QueeebA6bCELBYwEuk9PiV3gOV79SR-BGs1CdErK_w&oe=672384F1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monka VR", "keywords": [], "long_description": "Dive into the ultimate Gorilla Tag experience with our fan-made game that takes the excitement to new heights! Swing into action in a dynamic, vibrant world where you'll leap, climb, and tag your friends in exhilarating gameplay. Our game offers the classic tag mechanics you love, with fresh, innovative twists and new game modes that will keep you on your toes.\n\nExplore diverse and engaging environments, each with its own unique challenges and secrets. Whether you're a seasoned tag player or new to the scene, you'll find something to enjoy. And we're just getting started\u2014stay tuned for regular updates and additional features designed to expand and enhance your gameplay experience. Gather your friends, put your agility to the test, and get ready for endless fun in our Gorilla Tag fan game!", "short_description": "Get ready for an immersive adventure in our Gorilla Tag fan game! Swing through vibrant worlds, tag your friends, and explore exciting new game modes. Stay tuned for even more thrilling updates and features!"}]}, "developer_name": "ChimpGameLLC", "developer_privacy_policy_url": "https://free-5506949.webadorsite.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "ChimpGameLLC", "support_website_url": null, "website_url": "https://free-5506949.webadorsite.com/?_gl=1%2A1dcwy2z%2A_gcl_au%2AMTY3ODk3NDg2MS4xNzI2MTcxNDYy%2A_ga%2AMTU5NjExODEwLjE3MjYxNzE0NjE.%2A_ga_E6PZPGE4QM%2AMTcyNjM2MjIxNy42LjEuMTcyNjM2MzE4Ny41Ny4wLjA.", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "26661692463479198"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1647807852742479"}]}, "baseline_offer": {"id": "1647807852742479"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727220600, "status": "PUBLISHED", "id": "164