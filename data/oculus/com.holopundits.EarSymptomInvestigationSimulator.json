enshot_02.png", "id": "1649777109152455", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982688_1649777112485788_968200243907841236_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E9_M37gfk_AQ7kNvgGQOIZn&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBZnZnC4pmUGH-gaMrs9rPuvcGzO_DvAnRu5srLorR8Aw&oe=675D7B1E"}, {"file_name": "Ear Symptom Investigation Simulator_screenshot_03.png", "id": "1211220906718963", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036696_1211220910052296_5320679418438448369_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yH41pMFRmuEQ7kNvgEPT0Xd&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDuekkh8rdkcPAxO2kvPctn8bnm1wmKhWQnLlw1f7SN-A&oe=675D7FC1"}, {"file_name": "Ear Symptom Investigation Simulator_screenshot_04.png", "id": "1967111670411057", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974795_1967111673744390_1560963435726443511_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oUT513EzW9IQ7kNvgHKZDjw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDDRmaWPEoUKbG0kZMAlhiqH6g9mA6Lce3MfXS3H0EBZw&oe=675D88A2"}, {"file_name": "Ear Symptom Investigation Simulator_screenshot_05.png", "id": "419249807665712", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031583_419249820999044_835207457413829966_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GkkrB-TVsSsQ7kNvgFzqXRg&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCh9dIZXIouCqpzBV3_kikZmYuKQX3nsrZAdA2AsBsTxA&oe=675D5A5D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "1494725554463067", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974903_1494725557796400_7550125774767171861_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rVF_byTkNXkQ7kNvgH2zj1K&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCNDFMmU8KR2u1SK1xUHo0vtVoDoH1nAjFiBpKbh1KS8g&oe=675D762E"}, "display_name": "Ear Symptom Investigation Simulator", "keywords": [], "long_description": "The Ear Symptom Investigation Simulator app immerses participants in a realistic and interactive environment to practice examining patients' ears using an otoscope. This application guides users through the selection and proper use of an otoscope, identifying common ear symptoms such as infections, blockages, and abnormalities.\n# Learning Objectives:\n- Remembering the anatomy of the ear and common symptoms\n- Understanding the implications of different ear conditions\n- Applying the correct technique for using an otoscope in a virtual scenario\n- Analyzing the visual cues presented in the ear canal\n- Evaluating the findings against standard medical criteria\n- Creating a report or action plan based on the examination results.  \n\nThis comprehensive simulation ensures that certified nursing assistant's or anyone interested in the healthcare field are well-prepared to perform ear examinations accurately and diagnose potential issues in clinical settings.", "short_description": "Designed to train CNAs in conducting ear examinations using an otoscope to identify and interpret common ear symptoms."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_i