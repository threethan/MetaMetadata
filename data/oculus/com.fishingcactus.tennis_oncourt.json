_name": "Screen3.png", "id": "749687596639291", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031616_749687599972624_8966126731538132281_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vRYUUQU4QCgQ7kNvgHyjGL3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCXdm2v9zFHUXQtd4fAn1eHNMqGAQ9E2niP__MUNCP0cA&oe=67751196"}, {"file_name": "Screen4.png", "id": "1244144979810089", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974798_1244144983143422_1681704455242691437_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PblZeX6TbckQ7kNvgEbCl1p&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCjLKYZvn9UDmUx-xjEQ-iIFfJC5jIiRxZtugQkkaC4WQ&oe=67753F41"}, {"file_name": "Screen5.png", "id": "746407370603414", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031560_746407377270080_7049822999817787277_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5tI1l3mi6hkQ7kNvgFhrLp8&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCeiuwHk-sdphur0EOJh_-8k5kG17P_KoMq0AQfhKxwxg&oe=67753F34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage.png", "id": "167636232574363", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984448_167636235907696_6696061602154100125_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YLDBKL39iPcQ7kNvgF1MQ8p&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDmbNsiIkS5QQyIb9bVXHgDAF7wBhfYA0KQaS4ktgiSmw&oe=67753A89"}, "display_name": "Tennis On-Court", "keywords": [], "long_description": "Tennis On-Court is the ultimate tennis simulator to discover!\n\nIt's not only a video game, it's real tennis thanks to the experience of Decathlon & Artengo engineers, working every day on the design of tennis equipment : rackets, balls, accessories, ... used by top players on the ATP & WTA tours.\n\nLift, slice, dropshot, retro, perform all those effects and feel like a real tennis player..\n\n~Foundations~\n\n- Gameplay : Arcade or Realistic, choose your side!\n- 3 different types of moving: Teleport, Automatic, Manual\n- Fully customizable 3D male & female avatars\n- 13 rackets with different characteristics to match with your style.\n- 6 incredible stadiums with different evolutive surfaces : clay, grass, hard...\n- 5 assists to help you to perform: service hit assist, position assist, ball trajectory correction, ...\n- Spectator mode\n\n~Realism~\n\n- Play with your ball before serving\n- 1 handed or 2 handed backhand ? That works!\n- Umpire and linesmen are present on the court to follow your matchs\n- Playing in a crowed out stadium is perfect for immersion!\n- AI is almost human thanks to all motion-captured animations in match.\n\n~Game modes~\n\n- Play against AI in 1vs1 with 4 difficulty levels\n- Bonus : choose if your opponent is left or right-handed\n- Play with your friend in singles (1vs1) or doubles (2vs2) online match\n- Find perfect opponents thanks to matchmaking feature\n- Prove your are the best thanks to the online championship\n- Improve your skills with 5 training modes.\n", "short_description": "The ultimate VR Tennis simulator. Play with your friends or worldwide competitors in 1vs1 and 2vs2 online mode. Or practice in match against AI and various exercices. Physics has been worked with top players to transpose real tennis in VR."}]}, "developer_name": "Fishing Cactus", "developer_privacy_policy_url": "https://www.tennisoncourtvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Decathlon", "support_website_url": null, "website_url": "https://www.tennisoncourtvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "reco