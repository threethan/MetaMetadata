213703186540421", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035358_2383687081666667_994196147755024384_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bwsCWv8ylP4Q7kNvgGVDxtH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDXp80IYS_SAUUmjjMW7Xhrynm5PYSUeAbvqIcz0CB3dg&oe=6730B2FD"}, {"file_name": "migrated_image.png", "id": "1620229981476641", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031555_488501271934136_1354123014274285568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Um1iuCizcE4Q7kNvgGPU7FK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDtr_yZ41tlQyx1i_ObDGDG9LnzCb7SnS3JWWPcdwZsfg&oe=6730B3A0"}, {"file_name": "migrated_image.png", "id": "2778828985504138", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974710_369274084006757_4844399866354335744_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z74BrTKiwToQ7kNvgHVU4Gs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCRP5jIcy7ZfVEtu06WHzBGwTLw1fUhLpD6tkp8Q4QrPQ&oe=6730A5FC"}, {"file_name": "migrated_image.png", "id": "205414920805768", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031580_518243338950436_4337549547392729088_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BN-MWg1u_h8Q7kNvgGm3gal&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCW_iCgxKGORnVC0OVF2TDAlVwvqQk6hU-D1ra23u0HYQ&oe=67308805"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/8OqhYX", "id": "886213865076064", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974459_886213868409397_7277970959523381248_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3dpAjZ6L-tcQ7kNvgHMwT0W&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDCqMeOrBfWP5rKG122NgJwm4b2DIEiuTHJm99tczhlFA&oe=6730B22F"}, "display_name": "Poker VR", "keywords": ["poker", "casino", "casual", "social", "free"], "long_description": "The most popular social app on Oculus Go, now reimagined for Oculus Quest! Play poker like a pro, Poker VR is the only app to feature both multi table tournaments and cash games.  \n\nMain features: \n- Most expressive avatars built for reading tells with growing customisations  \n- Built for the quest, environments and avatars look sharp and clear \n- Play poker just like in real life, knock to check, throw your cards over the line to fold etc. \n- Feel like you are in a casino and not just at one table\n- Lose hours making chip stacks and doing chip tricks. Poker VR features physics-based gameplay at the table.  \n- Multi table tournaments with automated table balancing and live leaderboard. Tournaments support 100s of players at the same time. \n- Scope all casinos before joining a table. View where your friends are playing, their chip stack, and more.\n- Smart friends\u2019 system to invite your friends or join them directly at the table. \n- \u2026 and much much more!", "short_description": "The most popular social app on Oculus Go, now reimagined for Oculus Quest! Play poker like a pro, Poker VR is the only app to feature multi table tournaments and cash games. \n\nPlaying poker with friends was never more fun and social. Stimulated gaze tracking, facial expressions and full hand presence makes reading tells even more fun. Want to enjoy poker as a sport? Join 100s of other players in daily tournaments to hone your skill and prove to your friends that you are the best!"}]}, "developer_name": "Mega Particle, Inc.", "developer_privacy_policy_url": "https://www.pokervr.co/privacy-policy", "developer_terms_of_service_url": "https://www.pokervr.co/termsofservice", "publisher_name": "Mega Particle, Inc.", "support_website_url": "https://www.pokervr.co/", "website_url": "https://www.pokervr.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CA