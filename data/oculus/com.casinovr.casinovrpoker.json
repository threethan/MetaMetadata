oe=67642337"}, {"file_name": "migrated_image.png", "id": "213703186540421", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035358_2383687081666667_994196147755024384_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W3tcn6mO1GIQ7kNvgGO9pLm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBo6Gn_FWsFb9XQkVWKvHR8F6LlFPmUOrooWEKEyrOz-g&oe=67641D7D"}, {"file_name": "migrated_image.png", "id": "1620229981476641", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031555_488501271934136_1354123014274285568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LqTSMhsoCBYQ7kNvgHRSGJy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDUO0ca25UcNt8E3OOB9SMg2kJ4yq_g5XlOmaqXLUfCA&oe=67641E20"}, {"file_name": "migrated_image.png", "id": "2778828985504138", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974710_369274084006757_4844399866354335744_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K02ELuj0_AwQ7kNvgG2itSP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXEK361Hu2EvdMZTJvHHpcTa0TUauKRkQHyuQI4hoVPQ&oe=6764107C"}, {"file_name": "migrated_image.png", "id": "205414920805768", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031580_518243338950436_4337549547392729088_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vZiWzDdDD3EQ7kNvgG9QThS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDPuK64tG-sMJ__Qgz-x8VRwwzpE_abnEJ6onnos6gSIQ&oe=6763F285"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/8OqhYX", "id": "886213865076064", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974459_886213868409397_7277970959523381248_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3_SFt17wMUsQ7kNvgFLtXh_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAp302j30V2Ki2fzQ3wcaHmns8YybBGyK7VM794kItvnw&oe=67641CAF"}, "display_name": "Poker VR", "keywords": ["poker", "casino", "casual", "social", "free"], "long_description": "The most popular social app on Oculus Go, now reimagined for Oculus Quest! Play poker like a pro, Poker VR is the only app to feature both multi table tournaments and cash games.  \n\nMain features: \n- Most expressive avatars built for reading tells with growing customisations  \n- Built for the quest, environments and avatars look sharp and clear \n- Play poker just like in real life, knock to check, throw your cards over the line to fold etc. \n- Feel like you are in a casino and not just at one table\n- Lose hours making chip stacks and doing chip tricks. Poker VR features physics-based gameplay at the table.  \n- Multi table tournaments with automated table balancing and live leaderboard. Tournaments support 100s of players at the same time. \n- Scope all casinos before joining a table. View where your friends are playing, their chip stack, and more.\n- Smart friends\u2019 system to invite your friends or join them directly at the table. \n- \u2026 and much much more!", "short_description": "The most popular social app on Oculus Go, now reimagined for Oculus Quest! Play poker like a pro, Poker VR is the only app to feature multi table tournaments and cash games. \n\nPlaying poker with friends was never more fun and social. Stimulated gaze tracking, facial expressions and full hand presence makes reading tells even more fun. Want to enjoy poker as a sport? Join 100s of other players in daily tournaments to hone your skill and prove to your friends that you are the best!"}]}, "developer_name": "Mega Particle, Inc.", "developer_privacy_policy_url": "https://www.pokervr.co/privacy-policy", "developer_terms_of_service_url": "https://www.pokervr.co/termsofservice", "publisher_name": "Mega Particle, Inc.", "support_website_url": "https://www.pokervr.co/", "website_url": "https://www.pokervr.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "1023770785722696"}], "e