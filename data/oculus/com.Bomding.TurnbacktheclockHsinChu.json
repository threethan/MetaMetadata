content.oculuscdn.com/v/t64.5771-25/39031491_535765945261194_2588613643764798383_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=32BE-tMOrfAQ7kNvgF-Fftz&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_Fj93kcNhbR70JStazaPwM&oh=00_AYAH3RCZdqViIh_83IQJcEXkzprKzH3mvDohrGgikJKWjQ&oe=66F5397C"}, {"file_name": "\u904a\u6232\u622a\u5716 (13).png", "id": "951758269126412", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_951758272459745_8809545645993813883_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FHtKUYasTCwQ7kNvgFrNonE&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_Fj93kcNhbR70JStazaPwM&oh=00_AYBREC4p4OYxibY5g3oYd9vJFGPv_6DT30vRmTmJA-jYXQ&oe=66F5615E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "702973728224332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569466_702973731557665_1738109767858809757_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4vS23HjhHjMQ7kNvgFDO5SE&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_Fj93kcNhbR70JStazaPwM&oh=00_AYCUDko0AW6cY5XrHEIIphHH9fW2mxxhbRcXIsdqRbidPA&oe=66F534C3"}, "display_name": "Turn back the clock\uff1a Hsinchu", "keywords": [], "long_description": "\"Turn back the clock\uff1a Hsinchu\" takes Hsinchu City, Taiwan as the main stage. Players can experience the historical time and space changes of Hsinchu while playing. The story will revolve around a historian and an agent of the Time and Space Security Agency. Players can alternately play the roles to be played according to the progress of the plot, and experience the same script from different perspectives as a starting point, through different perspectives. Encounter, correct, and repair historical events, experience conflict, cooperation, choice, and other plots, and finally work together to catch the mastermind and explore his motives.\n\nThe game is not limited to static observation and puzzle solving, but also has dynamic action elements for players to complete when encountering emergencies. The puzzle-solving theme is easy to use, but also in line with the historical era, fully demonstrating the humanistic history of Hsinchu, creating a very high sense of immersion in the era, and sometimes the player's choice will also affect the direction of the plot. In addition, the option of 360 view appreciation is also provided, and five scenic spots with on-site 4K high-resolution stereo shooting with VR 180/360 are waiting for players to have a glimpse of the actual appearance of Hsinchu City.\n", "short_description": "\"Turn back the clock\uff1aHsinchu\" takes the historical time and space of Hsinchu City, Taiwan as the background of the game. The story revolves around the common adventure between a contemporary historian and an agent of the Time and Space Security Bureau from the future. In the plot, the player needs to alternately play the two protagonists, using a dual-perspective method, to gradually explore the truth of the event in the process of rectifying and repairing historical events.\n"}, {"images": {"nodes": [{"file_name": "Logo.png", "id": "1520834925092245", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_1520834928425578_4347327135975978259_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S9UV-0NvnCwQ7kNvgEc3NDS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_Fj93kcNhbR70JStazaPwM&oh=00_AYC3GLu9LoS-zsWtJAVCMeBH4vlSBqMEBhRFJBDT6j9hvQ&oe=66F53520"}, {"file_name": "CoverPortrait.png", "id": "1280033692541072", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974740_1280033695874405_4170986497490021167_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QPPndV27XysQ7kNvgGW0ZLI&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_Fj93kcNhbR70JStazaPwM&oh=00_AYAdoTsl83a2SBrpKd9fDJMrs5agb7-Z6ReYiSaT5eX9wg&oe=66F53116"}, {"file_name": "HeroCover.png", "id": "861312668396379", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982528_861312671729712_108660272202463