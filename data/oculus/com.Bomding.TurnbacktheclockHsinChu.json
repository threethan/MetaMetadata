5/39031491_535765945261194_2588613643764798383_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y8bpbe5-wZMQ7kNvgE2Heic&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgLkMFivupVdt9tExcGWASHyeXlH1mmokYMl3FI2sqdA&oe=66FA7F7C"}, {"file_name": "\u904a\u6232\u622a\u5716 (13).png", "id": "951758269126412", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_951758272459745_8809545645993813883_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xcnz8dyrZDwQ7kNvgHxrqA2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBK22LWqanxh915OszKDCu6MTcvndUVuup1zjR51_0fdQ&oe=66FAA75E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "702973728224332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569466_702973731557665_1738109767858809757_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8RbS1SVrzbYQ7kNvgHCvXTb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo9kug8mp9DyLiLs_GjeDMaoaw1j47MWo3hz-xv5q7TA&oe=66FA7AC3"}, "display_name": "Turn back the clock\uff1a Hsinchu", "keywords": [], "long_description": "\"Turn back the clock\uff1a Hsinchu\" takes Hsinchu City, Taiwan as the main stage. Players can experience the historical time and space changes of Hsinchu while playing. The story will revolve around a historian and an agent of the Time and Space Security Agency. Players can alternately play the roles to be played according to the progress of the plot, and experience the same script from different perspectives as a starting point, through different perspectives. Encounter, correct, and repair historical events, experience conflict, cooperation, choice, and other plots, and finally work together to catch the mastermind and explore his motives.\n\nThe game is not limited to static observation and puzzle solving, but also has dynamic action elements for players to complete when encountering emergencies. The puzzle-solving theme is easy to use, but also in line with the historical era, fully demonstrating the humanistic history of Hsinchu, creating a very high sense of immersion in the era, and sometimes the player's choice will also affect the direction of the plot. In addition, the option of 360 view appreciation is also provided, and five scenic spots with on-site 4K high-resolution stereo shooting with VR 180/360 are waiting for players to have a glimpse of the actual appearance of Hsinchu City.\n", "short_description": "\"Turn back the clock\uff1aHsinchu\" takes the historical time and space of Hsinchu City, Taiwan as the background of the game. The story revolves around the common adventure between a contemporary historian and an agent of the Time and Space Security Bureau from the future. In the plot, the player needs to alternately play the two protagonists, using a dual-perspective method, to gradually explore the truth of the event in the process of rectifying and repairing historical events.\n"}, {"images": {"nodes": [{"file_name": "Logo.png", "id": "1520834925092245", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_1520834928425578_4347327135975978259_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dMBfOhMDGToQ7kNvgELEZeC&_nc_ht=scontent.oculuscdn.com&oh=00_AYANsqpJCKrM5bI38MyPKSbr6gTa6d8mlI9K2TiD7d112w&oe=66FA7B20"}, {"file_name": "CoverPortrait.png", "id": "1280033692541072", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974740_1280033695874405_4170986497490021167_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z7z1A8iigbEQ7kNvgFnfTKA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBy7IRIc16yvtoziJ1VrNCYl0J7nFoNgp8LxEZAxbcvjg&oe=66FA7716"}, {"file_name": "HeroCover.png", "id": "861312668396379", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982528_861312671729712_1086602722024638930_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w1VHKPd_bR4Q7kNvgGX9DY7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqKohzQkCq6-P_HE_ptQSSetKboJ-tHue9zXh4AEtQVw&oe=66FAA03D"}, {"file_name": "Min