zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDclgih2yD_YMoWwB5XyzOFoY8J8gDN4GU6NcKLe_gb6A&oe=67542BB3"}, {"file_name": "Screenshot 2023-01-30 at 02.29 2.png", "id": "565789808551133", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974892_565789811884466_6526345203447617269_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oj2Q8xyvR-IQ7kNvgGfgWKo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDk7qYGzWss_I5C5xhDSNAT5Epwbjn9KPcJ_Jmo2Vqy5A&oe=67542F70"}, {"file_name": "bn1.png", "id": "703831071324154", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2yQzQAByYxEQ7kNvgF6Te0J&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBO6Ir6Fs2DgRuXeezwTvelZ0mwcGx8LbS1N1hHPyhzqw&oe=67541F92"}, {"file_name": "Screenshot 2023-01-30 at 02.33 2.png", "id": "5437349666365786", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75371511_5437349673032452_5749519266546188894_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XV_K1SLWJeEQ7kNvgFdd7HP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCOYITObhYwwUOWAEa-qor4c_zVyZK9EQkAO1KKJ-Ap6A&oe=6754416C"}, {"file_name": "Screenshot 2023-01-30 at 02.32.png", "id": "972095697532669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031515_972095700866002_1006233267072909900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-MCjKxaSZ-sQ7kNvgE132HP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBE3jwy2KGCyT5gC5r2CHnFXTQ7fIXgJhG5mdbSjipo2Q&oe=67542D2E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-prod-2560-1440.png", "id": "1765829837121763", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566679_1765829840455096_3553248497618459432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M79Joepy9ioQ7kNvgGERQ70&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2eJQmWrn8sTzMVNAmH7vE13FRnz8pfezUxUAjLJoOOQ&oe=67541E41"}, "display_name": "VRFS - Football (soccer) simulator", "keywords": [], "long_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n\nFOOTBALL PHYSICS SIMULATION: A player can perform almost any trick from balancing the ball on the tip of the foot to executing curved power shots and long passes. The ball's trajectory is solely determined by physics engine. \n\nCOMPETITIVE ONLINE MODE: The multiplayer architecture allows for an immediate response when a player touches the ball. For example, it is possible to finish a powerful cross at the same speed as in real football, even if the connection is not perfect.\n\nCOMFORT: Players move around using thumbsticks and can play in a seated or standing position. No intense hand movement is required.\n\nNO PAY-TO-WIN in VRFS: only skills matter. No one can buy \"stronger kicks\" or \"faster boots.\" Keep practicing, and you'll feel how you improve.\n\nFREE FOR ALL: Players have full access to the game with no need to purchase anything. However, if you wish, you will be able to buy cool equipment in the store, thus supporting the further development of this project (paid equipment coming soon)\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements.", "short_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n- Realistic football physics\n- Competitive online mode\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1378871059538951"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "524845919632663"}]}, "baseline_offer": {"id": "524845919632663"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1675454400, "status": "PUBLISHED", "id": "524845919632663"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27719052547709285", "version": "0.1"}, "id": "4132387000218482", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27719052547709285"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733158115, "id": "27762758130005393", "version": "0.1", "version_code": 255, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27719052547709285"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733157739, "id": "27762715213343018", "version": "0.1", "version_code": 254, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27719052547709285"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "# UPDATE 0.4.6\n\n## Christmas Maps\nWe\u2019ve added Christmas versions of some of the popular maps. Enjoy the festive mood and Christmas atmosphere. Also added some decorations in the arena building.\n\n## 2025 Mega Bundle\nNew bundle featuring 25 items and a \u2018Snowman\u2019 ball with unique tumbler doll physics.\n\n## Voice Chat Settings\nAdded feature to switch voice chat to team-only or friends-only modes (see in the Settings).\n\n## In-field Bots in Multiplayer Practice\nYou can now add in-field bots on your custom arenas. They will try tackling the ball all the time. Note that this is in beta and will get improved in the future.\n\n## Portals (Experimental)\nAdded experimental portals on the starting arena.\n\n## New Bots Training Mode\nUpdated training bots and introduced bot matches in the 4v4 arena. Access it through the portal in the starting scene.\n\n## Optimized Botkeepers\nAs you may have noticed, botkeepers on custom arenas were a bit heavy on performance, so we\u2019ve revamped them. \n\n## New Reporting Interface and Moderation\nYour assistance in reporting disruptive players is highly valued. The reporting interface has been upgraded for better usability.\n\n## Tutorial Testing \nWe\u2019ve created a tutorial mode for new players. If you\u2019d like to test it and share some suggestions on enhancing it, we\u2019d appreciate that a lot. Enter via the portal on the starting arena.\n\n## New Arrivals\nApart from the Christmas bundle, check out the new arrivals, including the latest winter soccer boots and a few other things. \n\n## Graphics Settings\nYou can now switch to higher or lower resolution if you\u2019d like to. \n\n## Some Bug Fixes\nFixed glitched items in some lockers\nEnhanced performance on the VFA arena\nOptimized palm trees\n", "created_date": 1732765685, "id": "27719069101040963", "version": "0.1", "version_code": 253, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27719052547709285"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "# UPDATE 0.4.6\n\n## Christmas Maps\nWe\u2019ve added Christmas versions of some of the popular maps. Enjoy the festive mood and Christmas atmosphere. Also added some decorations in the arena building.\n\n## 2025 Mega Bundle\nNew bundle featuring 25 items and a \u2018Snowman\u2019 ball with unique tumbler doll physics.\n\n## Voice Chat Settings\nAdded feature to switch voice chat to team-only or friends-only modes (see in the Settings).\n\n## In-field Bots in Multiplayer Practice\nYou can now add in-field bots on your custom arenas. They will try tackling the ball all the time. Note that this is in beta and will get improved in the future.\n\n## Portals (Experimental)\nAdded experimental portals on the starting arena.\n\n## New Bots Training Mode\nUpdated training bots and introduced bot matches in the 4v4 arena. Access it through the portal in the starting scene.\n\n## Optimized Botkeepers\nAs you may have noticed, botkeepers on custom arenas were a bit heavy on performance, so we\u2019ve revamped them. \n\n## New Reporting Interface and Moderation\nYour assistance in reporting disruptive players is highly valued. The reporting interface has been upgraded for better usability.\n\n## Tutorial Testing \nWe\u2019ve created a tutorial mode for new players. If you\u2019d like to test it and share some suggestions on enhancing it, we\u2019d appreciate that a lot. Enter via the portal on the starting arena.\n\n## New Arrivals\nApart from the Christmas bundle, check out the new arrivals, including the latest winter soccer boots and a few other things. \n\n## Graphics Settings\nYou can now switch to higher or lower resolution if you\u2019d like to. \n\n## Some Bug Fixes\nFixed glitched items in some lockers\nEnhanced performance on the VFA arena\nOptimized palm trees\n", "created_date": 1732765524, "id": "27719052547709285", "version": "0.1", "version_code": 252, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27719052547709285"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732765144, "id": "27719014041046469", "version": "0.1", "version_code": 251, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}