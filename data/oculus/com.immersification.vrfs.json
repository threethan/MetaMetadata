us": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "UPDATE 0.4.3.1 Patch\n\n- Fixed random rotations of player avatars\n- Fixed player body collider ", "created_date": 1728659791, "id": "27194871606794051", "version": "0.1", "version_code": 224, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27194913526789859"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "UPDATE 0.4.3 \n\n[ Introducing the Camera Device ]\nRecord videos inside VRFS! Open the menu and tap the new icon at the top. Move around holding the device, fix it in the air, or even throw it around. We've optimized it to use minimal resources, but be aware that using the device on heavy custom arenas may cause FPS drops.\n\n[ U19 Halloween Bundle ]\nThe Halloween bundle is available in the store until Halloween. It will be removed from the store afterward, but all purchased items are yours forever.\n\n[ Dark Arena Template ]\nA new dark scene is available in the arena builder\u2014perfect for creating scary places. We've also added a pumpkin object to the objects list.\n\n[ New GK in Public Lobbies ]\nThe new goalie mechanics, which allow catching and throwing the ball, are now enabled in all public match lobbies. We also need your feedback on whether the gloves-dash feature should be removed.\n\n[ Verification Badges ]\nBased on initial feedback, we\u2019ve moved the badge to the username instead of the player model. The verified blue check mark will be visible in the player list in the lobby.\n\n[ Bug Fixes and Enhancements ]\nWe've fixed many issues, including lag when switching jerseys and glove collision problems. Custom arenas have been significantly optimized, especially those with many blocks.\n", "created_date": 1728509909, "id": "27167848029496409", "version": "0.1", "version_code": 223, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27194913526789859"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "UPDATE 0.4.3 \n\n[ Introducing the Camera Device ]\nRecord videos inside VRFS! Open the menu and tap the new icon at the top. Move around holding the device, fix it in the air, or even throw it around. We've optimized it to use minimal resources, but be aware that using the device on heavy custom arenas may cause FPS drops.\n\n[ U19 Halloween Bundle ]\nThe Halloween bundle is available in the store until Halloween. It will be removed from the store afterward, but all purchased items are yours forever.\n\n[ Dark Arena Template ]\nA new dark scene is available in the arena builder\u2014perfect for creating scary places. We've also added a pumpkin object to the objects list.\n\n[ New GK in Public Lobbies ]\nThe new goalie mechanics, which allow catching and throwing the ball, are now enabled in all public match lobbies. We also need your feedback on whether the gloves-dash feature should be removed.\n\n[ Verification Badges ]\nBased on initial feedback, we\u2019ve moved the badge to the username instead of the player model. The verified blue check mark will be visible in the player list in the lobby.\n\n[ Bug Fixes and Enhancements ]\nWe've fixed many issues, including lag when switching jerseys and glove collision problems. Custom arenas have been significantly optimized, especially those with many blocks.\n", "created_date": 1728509779, "id": "27167815872832958", "version": "0.1", "version_code": 222, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27194913526789859"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1728485107, "id": "27163587969922415", "version": "0.1", "version_code": 221, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}