g", "id": "602735458325235", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031634_602735461658568_4828349097392926470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jkmzcz-ZRvwQ7kNvgF-lrFh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANuVPXT-MQLupyFGoXdLuOgnwZMDcotZYWslfHaiK74g&oe=67220828"}]}, "id": "779459420996169", "locale": "en_US", "screenshots": [{"file_name": "bn2.png", "id": "723206489317459", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367591_723206492650792_7836788807916181930_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C8N1rJvvumsQ7kNvgHI6jyd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBdmuSw1VMR4i6NmNRWQuaawB-d1lFQJoWGTrP8T2VinQ&oe=672212B3"}, {"file_name": "ctky.png", "id": "563457245767154", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_563457249100487_6418008387233526367_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZ5Om2Tmm38Q7kNvgG_Nbuw&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbDkvDij3c1ekmK5fOlgG1FoHiY6FrDx3uioCxkD8JYw&oe=672201CC"}, {"file_name": "Screenshot 2023-01-30 at 02.29 2.png", "id": "565789808551133", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974892_565789811884466_6526345203447617269_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffR75EqvlvQQ7kNvgG7YjMu&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuMlSm-GEk0ICHLLVMyneGpZnMElwpAGK6VcEm4zms_Q&oe=67221670"}, {"file_name": "bn1.png", "id": "703831071324154", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jdpns8tVltUQ7kNvgFLfBen&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyhBM217ksiQzViv3l6yDrmcWX6l2z4vZNbkOElwvKLw&oe=67220692"}, {"file_name": "image 86.png", "id": "1352566882309213", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974482_1352566885642546_8597886574679645531_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SURr0aHJoWQQ7kNvgHQijJz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMIrNdy24pq1AInjkdNJDYEjk6kOW0IJgSSskoPyRO0Q&oe=672214B3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape.png", "id": "3722371651381650", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035326_3722371654714983_6861457912443840052_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hucmsZl_ic4Q7kNvgFAfd2L&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhZHYBUMIJdu1W4enSJQxCCLz59j_mi9TybO6qS6LdyQ&oe=6722047E"}, "display_name": "VRFS - Football (Soccer) Simulator", "keywords": [], "long_description": "VRFS is a community-driven soccer (football) simulator with focus on realistic physics and competitive multiplayer.\n\nHere are the main features of VRFS:\n\nPHYSICS SIMULATION: Players can perform almost any trick, from balancing the ball on the tip of their foot to executing curved power shots and long passes. The ball's trajectory is solely determined by the physics engine.\n\nCOMPETITIVE MULTIPLAYER: The multiplayer architecture allows for instantaneous ball-touch response. For example, players can finish powerful crosses at the same speed as in real soccer. \n\nCOMFORT: Players can move around using thumbsticks and play in either a seated or standing position. No intense hand movements are required.\n\nNO PAY-TO-WIN in VRFS: Only skills matter. No one can buy 'stronger kicks' or 'faster boots.' Keep practicing, and you'll see improvement.\n\nFREE FOR ALL: Players have full access to the game without needing to purchase anything. However, if you wish, you can buy cool equipment in the store to support the further development of this project.\n\nPlease keep in mind that VRFS is still in development, with upcoming upgrades to the physics and scenery. We'd appreciate your suggestions for any enhancements.\n", "short_description": "VRFS is a community-driven soccer (football) simulator with focus on realistic physics and competitive multiplayer.\n\nHere are the main features of VRFS:\n- Realistic physics\n- Competitive multiplayer\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease keep in mind that VRFS is still in development, with upcoming upgrades to the physics and scenery. We'd appreciate your suggestions for any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "es", "de", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "25623527567261804"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031634_602735461658568_4828349097392926470_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jkmzcz-ZRvwQ7kNvgF-lrFh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAr2wBhQ60iFM8HntaktfKUFtBTf4ynzATg3Uqxg6jqHg&oe=67220828"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRFS - Football (Soccer) Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286