zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrr4eyH8S8mVK8nr9HrvtEzrAmnbM_xa9zlQpxjtX72Q&oe=673F13B3"}, {"file_name": "Screenshot 2023-01-30 at 02.29 2.png", "id": "565789808551133", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974892_565789811884466_6526345203447617269_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t84T4Tzxb4UQ7kNvgH6opVL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA8iYv5JVkCY3L7_pquDWZh5GQ6LMCAZTZQUZuBhPygtA&oe=673F1770"}, {"file_name": "bn1.png", "id": "703831071324154", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_nwc5KspFFoQ7kNvgFl4TXs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB0u_E4R30BwxeakCOqvL3crg-_7rITDLShpFjZLsJcBQ&oe=673F0792"}, {"file_name": "Screenshot 2023-01-30 at 02.33 2.png", "id": "5437349666365786", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75371511_5437349673032452_5749519266546188894_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_-M2VWfV3e0Q7kNvgEVVNvd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDMxv_UeICA1zSoGpBcgWr4MaRR7Ub_DF0M-1ttCbePsA&oe=673F296C"}, {"file_name": "Screenshot 2023-01-30 at 02.32.png", "id": "972095697532669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031515_972095700866002_1006233267072909900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FeQwl0iab2sQ7kNvgH7SQWH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQdpFlltRYDeVjQiEZIy0zjWv1F5QFt18CPf-O6aW3Xg&oe=673F152E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-prod-2560-1440.png", "id": "1765829837121763", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566679_1765829840455096_3553248497618459432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a-aZMujskuwQ7kNvgHnuY52&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIMdIK9V99wdbYOdGDVPZlvgfvFkQnbbBSXKb6ufMJBw&oe=673F0641"}, "display_name": "VRFS - Football (soccer) simulator", "keywords": [], "long_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n\nFOOTBALL PHYSICS SIMULATION: A player can perform almost any trick from balancing the ball on the tip of the foot to executing curved power shots and long passes. The ball's trajectory is solely determined by physics engine. \n\nCOMPETITIVE ONLINE MODE: The multiplayer architecture allows for an immediate response when a player touches the ball. For example, it is possible to finish a powerful cross at the same speed as in real football, even if the connection is not perfect.\n\nCOMFORT: Players move around using thumbsticks and can play in a seated or standing position. No intense hand movement is required.\n\nNO PAY-TO-WIN in VRFS: only skills matter. No one can buy \"stronger kicks\" or \"faster boots.\" Keep practicing, and you'll feel how you improve.\n\nFREE FOR ALL: Players have full access to the game with no need to purchase anything. However, if you wish, you will be able to buy cool equipment in the store, thus supporting the further development of this project (paid equipment coming soon)\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements.", "short_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n- Realistic football physics\n- Competitive online mode\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1378871059538951"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "524845919632663"}]}, "baseline_offer": {"id": "524845919632663"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1675454400, "status": "PUBLISHED", "id": "524845919632663"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27544649725149569", "version": "0.1"}, "id": "4132387000218482", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27544649725149569"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "# UPDATE 0.4.5\n\n## New Mega Pitch\nAdded an even larger pitch (way beyond FIFA standards) as it was highly requested by the community. This arena is available for public and private games and in the arena editor.\n\n## Curl Physics Enhanced\nThe curl physics simulation has been updated to enhance realism, smoothness, and predictability. Let us know what you think about this change. Note that balls with extra curling effects remain unchanged.\n\n## Corner Flags with Physics\nRecreated the original corner flags with fully-featured physics for your celebrations.\n\n## Renegade and Razor Bundles\nEach bundle includes six items you can mix and match to create unique sci-fi looks.\n\n## New Boots Collection\nThe new brand with a strange unreadable name \u201c/////\u201d features 16 sports casual boots designs.\n\n## Gloves Dash Disabled\nAfter long consideration, taking into account the new GK mechanics and community feedback, we've disabled the gloves dash. We can switch it back on if the majority wants this.\n\n## Performance Improved\nA lot of performance optimizations have been made in the online practice mode and some official maps. We keep on working on more optimizations for the custom arenas to move the limits as far away as possible.\n\n## Other\nFixed some known bugs, potentially improved stick-drift issues, head physics, custom arena thumbnails, and overall performance enhancements.", "created_date": 1731268699, "id": "27544667531814455", "version": "0.1", "version_code": 240, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27544649725149569"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "# UPDATE 0.4.5\n\n## New Mega Pitch\nAdded an even larger pitch (way beyond FIFA standards) as it was highly requested by the community. This arena is available for public and private games and in the arena editor.\n\n## Curl Physics Enhanced\nThe curl physics simulation has been updated to enhance realism, smoothness, and predictability. Let us know what you think about this change. Note that balls with extra curling effects remain unchanged.\n\n## Corner Flags with Physics\nRecreated the original corner flags with fully-featured physics for your celebrations.\n\n## Renegade and Razor Bundles\nEach bundle includes six items you can mix and match to create unique sci-fi looks.\n\n## New Boots Collection\nThe new brand with a strange unreadable name \u201c/////\u201d features 16 sports casual boots designs.\n\n## Gloves Dash Disabled\nAfter long consideration, taking into account the new GK mechanics and community feedback, we've disabled the gloves dash. We can switch it back on if the majority wants this.\n\n## Performance Improved\nA lot of performance optimizations have been made in the online practice mode and some official maps. We keep on working on more optimizations for the custom arenas to move the limits as far away as possible.\n\n## Other\nFixed some known bugs, potentially improved stick-drift issues, head physics, custom arena thumbnails, and overall performance enhancements.", "created_date": 1731268567, "id": "27544649725149569", "version": "0.1", "version_code": 239, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27544649725149569"}, "release_status": "RELEASED"}, "bi