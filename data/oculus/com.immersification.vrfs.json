, {"file_name": "bn1.png", "id": "703831071324154", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VgbOXmIgJicQ7kNvgEI8e0L&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAy5-a3KZjMgZyQP9oPq3fPDaboDSL9nngpNa4AP0UCKw&oe=67863892"}, {"file_name": "Screenshot 2023-01-30 at 02.33 2.png", "id": "5437349666365786", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75371511_5437349673032452_5749519266546188894_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FHPIg8eJ2w8Q7kNvgGSPCTB&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDEYS6KMQl5Eb6bOOMfmfnxteaBD0P7SGjwSdOFUuBUMg&oe=67865A6C"}, {"file_name": "Screenshot 2023-01-30 at 02.32.png", "id": "972095697532669", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031515_972095700866002_1006233267072909900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=isnv_kwoLT4Q7kNvgFQj_YJ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAEVVykBCVbByv6txWXbr3d-l9cOocexPdO0lqC8QEcqg&oe=6786462E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-prod-2560-1440.png", "id": "1765829837121763", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57566679_1765829840455096_3553248497618459432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7fYxTVXl5a0Q7kNvgF5AQxt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAJFNPxTmQWqg3i4WTnmnSfLCodconihmV2ctmiNM1TtQ&oe=67863741"}, "display_name": "VRFS - Football (soccer) simulator", "keywords": [], "long_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n\nFOOTBALL PHYSICS SIMULATION: A player can perform almost any trick from balancing the ball on the tip of the foot to executing curved power shots and long passes. The ball's trajectory is solely determined by physics engine. \n\nCOMPETITIVE ONLINE MODE: The multiplayer architecture allows for an immediate response when a player touches the ball. For example, it is possible to finish a powerful cross at the same speed as in real football, even if the connection is not perfect.\n\nCOMFORT: Players move around using thumbsticks and can play in a seated or standing position. No intense hand movement is required.\n\nNO PAY-TO-WIN in VRFS: only skills matter. No one can buy \"stronger kicks\" or \"faster boots.\" Keep practicing, and you'll feel how you improve.\n\nFREE FOR ALL: Players have full access to the game with no need to purchase anything. However, if you wish, you will be able to buy cool equipment in the store, thus supporting the further development of this project (paid equipment coming soon)\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements.", "short_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n- Realistic football physics\n- Competitive online mode\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has