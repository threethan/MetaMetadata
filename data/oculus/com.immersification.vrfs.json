=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YO7pN0fc_hEQ7kNvgEIRxYo&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDjMD7y4IpcXI1N0lizzvczkhNHUTrpqLyaRIQ6gvCe0Q&oe=678646B3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560-1440.png", "id": "1148388549976714", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982610_1148388553310047_1806456483740005848_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BzlO8CX4xswQ7kNvgEYGCDw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBa8kmIqQW90COZSclLZLYl1QeenD8puE43x9Y8fhObdg&oe=678636CE"}, "display_name": "VRFS - Football (Soccer) Simulator", "keywords": ["football", "soccer", "player", "sports", "ball"], "long_description": "VRFS is a community-driven soccer (football) simulator focused on realistic physics and competitive multiplayer.\n\nMain features of VRFS:\n\nPHYSICS SIMULATION: Perform almost any trick\u2014from balancing the ball on your foot to executing curved power shots or long passes. The ball\u2019s trajectory is fully determined by the physics engine.\n\nCOMPETITIVE MULTIPLAYER: Experience instantaneous ball-touch response. For example, you can finish powerful crosses as fast as in real soccer.\n\nCOMFORT: Move with thumbsticks and play seated or standing. No intense hand motions are required.\n\nNO PAY-TO-WIN: Skill determines success. No one can buy \u201cstronger kicks\u201d or \u201cfaster boots.\u201d Practice leads to improvement.\n\nFREE FOR ALL: Full access without any mandatory purchases. Optional cool gear is available to support further development.\n\nPlease note, VRFS is still in development, with upcoming physics and scenery enhancements. We welcome your suggestions for improvements.", "short_description": "VRFS is a community-driven soccer (football) simulator focused on realistic physics and competitive multiplayer.\n\nMain features of VRFS:\n- Realistic physics\n- Competitive multiplayer\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease note, VRFS is still in development, with upcoming physics and scenery enhancements. We welcome your suggestions for improvements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "es", "de", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "27903934155887789"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001676_1824224198313981_7092790403687487897_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fm_nDJB01dMQ7kNvgEPpkcI&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD0hmXIbrYktKOaBvTXy8qn6T2jn2tua7Sw5wUZwDPLwg&oe=67863C20"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRFS - Football (Soccer) Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Hangout", "id": "1023770785722696"}, {"topic_name": "Simulation", "id": "331529