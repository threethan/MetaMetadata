9564797_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zWnC16dOnTQQ7kNvgGlCi3q&_nc_ht=scontent.oculuscdn.com&oh=00_AYC0xc3jBHY7DKJAb_uJLfoqtH5xSQOjrYOMxkBUMEmZvA&oe=66F3E60D"}, {"file_name": "710.png", "id": "721841896188940", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43997714_721841899522273_3843659623067343370_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0JgvOn3Z6w4Q7kNvgElugRO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoQxx82n85svUsi2jpgQP9JhfxOuMPFwAAG0Nj4G4nCQ&oe=66F3FE36"}, {"file_name": "square-avatar-1440-1440.png", "id": "602735458325235", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031634_602735461658568_4828349097392926470_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FQLEKxvensUQ7kNvgGaQQUZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXdJaq0QoeOriJ-8T68GerSItp2ps8colCam_Vwr1HHQ&oe=66F3E3A8"}]}, "id": "565148722321142", "locale": "en_US", "screenshots": [{"file_name": "bn2.png", "id": "723206489317459", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367591_723206492650792_7836788807916181930_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IEkcyeAl66AQ7kNvgEUWV6x&_nc_ht=scontent.oculuscdn.com&oh=00_AYAyFB_P8zFxnbJ36ZGZjiGDbhlCuDleubZ_ghAZJgSU2Q&oe=66F3EE33"}, {"file_name": "Screenshot 2023-01-30 at 02.29 2.png", "id": "565789808551133", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974892_565789811884466_6526345203447617269_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I1DHps0tbKIQ7kNvgEVoqYI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPygSlUun60UCKaeYiklpx-GDKVqFFbOwo3aFPwmsQFA&oe=66F3F1F0"}, {"file_name": "bn1.png", "id": "703831071324154", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cobMuyKPaIYQ7kNvgG94uJn&_nc_ht=scontent.oculuscdn.com&oh=00_AYDffG0V34PmabdmXvOua0YmSADf1xW-tx1YiD4R3jxODw&oe=66F3E212"}, {"file_name": "Screenshot 2023-01-30 at 02.33 2.png", "id": "5437349666365786", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371511_5437349673032452_5749519266546188894_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=THCBu7NfsbQQ7kNvgEJwrql&_nc_ht=scontent.oculuscdn.com&oh=00_AYDf27DhgCleQKqhGUyOaK_qjUT_4hFwRnG5zT-RzrmDSQ&oe=66F403EC"}, {"file_name": "Screenshot 2023-01-30 at 02.32.png", "id": "972095697532669", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031515_972095700866002_1006233267072909900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3GQacn68n5oQ7kNvgHHejHZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjW4w-YiH6IdyXcBkEqBjgXN3gkkgE1wtLvPvdSGUMsQ&oe=66F3EFAE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-prod-2560-1440.png", "id": "1765829837121763", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566679_1765829840455096_3553248497618459432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2S-MdkEiQd4Q7kNvgHmwO2S&_nc_ht=scontent.oculuscdn.com&oh=00_AYComDM813CyfGLwixEuIrM2TKPVEKul24mnxwgYBUJrZA&oe=66F3E0C1"}, "display_name": "VRFS - Football (soccer) simulator", "keywords": [], "long_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n\nFOOTBALL PHYSICS SIMULATION: A player can perform almost any trick from balancing the ball on the tip of the foot to executing curved power shots and long passes. The ball's trajectory is solely determined by physics engine. \n\nCOMPETITIVE ONLINE MODE: The multiplayer architecture allows for an immediate response when a player touches the ball. For example, it is possible to finish a powerful cross at the same speed as in real football, even if the connection is not perfect.\n\nCOMFORT: Players move around using thumbsticks and can play in a seated or standing position. No intense hand movement is required.\n\nNO PAY-TO-WIN in VRFS: only skills matter. No one can buy \"stronger kicks\" or \"faster boots.\" Keep practicing, and you'll feel how you improve.\n\nFREE FOR ALL: Players have full access to the game with no need to purchase anything. However, if you wish, you will be able to buy cool equipment in the store, thus supporting the further development of this project (paid equipment coming soon)\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements.", "short_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n- Realistic football physics\n- Competitive online mode\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1378871059538951"}}]}, "