"703831071324154", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jdpns8tVltUQ7kNvgFLfBen&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyhBM217ksiQzViv3l6yDrmcWX6l2z4vZNbkOElwvKLw&oe=67220692"}, {"file_name": "Screenshot 2023-01-30 at 02.33 2.png", "id": "5437349666365786", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75371511_5437349673032452_5749519266546188894_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4XSYleI-Cj8Q7kNvgHEcM6_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBNMZ3Ax24NEbGyd-ZMA6YYQTcydS95jvAJLGnzUqceg&oe=6722286C"}, {"file_name": "Screenshot 2023-01-30 at 02.32.png", "id": "972095697532669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031515_972095700866002_1006233267072909900_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vm5M4sHvm-kQ7kNvgHgdhOR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDl-9pzKqawuUFSPnMLAaMm3HNR7AFzG3x0Vq0feD97gw&oe=6722142E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-prod-2560-1440.png", "id": "1765829837121763", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566679_1765829840455096_3553248497618459432_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AbsW7qRZcRoQ7kNvgF0Uiea&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnDEv7gv1YiD4dMvdeqWEWWx1WmRKMW9PgA9RIsWd69A&oe=67220541"}, "display_name": "VRFS - Football (soccer) simulator", "keywords": [], "long_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n\nFOOTBALL PHYSICS SIMULATION: A player can perform almost any trick from balancing the ball on the tip of the foot to executing curved power shots and long passes. The ball's trajectory is solely determined by physics engine. \n\nCOMPETITIVE ONLINE MODE: The multiplayer architecture allows for an immediate response when a player touches the ball. For example, it is possible to finish a powerful cross at the same speed as in real football, even if the connection is not perfect.\n\nCOMFORT: Players move around using thumbsticks and can play in a seated or standing position. No intense hand movement is required.\n\nNO PAY-TO-WIN in VRFS: only skills matter. No one can buy \"stronger kicks\" or \"faster boots.\" Keep practicing, and you'll feel how you improve.\n\nFREE FOR ALL: Players have full access to the game with no need to purchase anything. However, if you wish, you will be able to buy cool equipment in the store, thus supporting the further development of this project (paid equipment coming soon)\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements.", "short_description": "VRFS is a community-driven football simulator with focus on realistic physics and competitive online multiplayer.\n\nHere are the main features of VRFS:\n- Realistic football physics\n- Competitive online mode\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease, bear in mind that VRFS is still in development, including upcoming upgrades to the physics and scenery. We'd appreciate your suggestions regarding any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1378871059538951"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "524845919632663"}]}, "baseline_offer": {"id": "524845919632663"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1675454400, "status": "PUBLISHED", "id": "524845919632663"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27351971817750695", "version": "0.1"}, "id": "4132387000218482", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27351971817750695"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "# UPDATE 0.4.4\n\n## New 4v4 Arena\nMeet the new arena featuring a new pitch format available for 3v3 and 4v4 public lobbies and having full-scale goals. There are also outs and throw-ins activated on this arena by default, and it\u2019s heavily optimized.\n\n## Physics Enhanced\nBetter physics related to when you kick the ball straight up in the air. Note that all other aspects are retained unchanged and untouched. We\u2019d be gathering your feedback on this.\n\n## 50+ New Cool Cosmetics\nCheck out \u2018New arrivals\u2019 in the store.\n\n## Arena Editor Thumbnails\nArena creators now have a special item\u2014a thumbnail camera. Just position it as an object on the arena and it will make arena covers from the point of your choice.\n\n## Other\n- Beginner lobbies are now marked with a special badge.\n- Color setting for some of the stands in the arena editor.\n- \u2018Glitch dribbling\u2019 won\u2019t get a free kick anymore.\n- Optimized almost all official arenas.\n- Stuttering when jumping in locomotion fixed.\n- Other minor fixes.\n", "created_date": 1729785692, "id": "27351971817750695", "version": "0.1", "version_code": 235, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27351971817750695"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4132387000218482"}]}, "change_log": "# UPDATE 0.4.4\n\n## New 4v4 Arena\nMeet the new arena featuring a new pitch format available for 3v3 and 4v4 public lobbies and having full-scale goals. There are also outs and throw-ins activated on this arena by default, and it\u2019s heavily optimized.\n\n## Physics Enhanced\nBetter physics related to when you kick the ball straight up in the air. Note that all other aspects are retained unchanged and untouched. We\u2019d be gathering your feedback on this.\n\n## 50+ New Cool Cosmetics\nCheck out \u2018New arrivals\u2019 in the store.\n\n## Arena Editor Thumbnails\nArena creators now have a special item\u2014a thumbnail camera. Just position it as an object on the arena and it will make arena covers from the point of your choice.\n\n## Other\n- Beginner lobbies are now marked with a special badge.\n- Color setting for some of the stands in the arena editor.\n- \u2018Glitch dribbling\u2019 won\u2019t get a free kick anymore.\n- Optimized almost all official arenas.\n- Stuttering when jumping in locomotion fixed.\n- Other minor fixes.\n", "created_date": 1729785555, "id": "27351954727752404", "version": "0.1", "version_code": 234, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27351971817750695"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1729781810, "id": "27351441781137032", "version": "0.1", "version_code": 233, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27351971817750695"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1729781696, "id": "27351426884471855", "version": "0.1", "version_code": 232, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8464137310294097", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "273519718177506