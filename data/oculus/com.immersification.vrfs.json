g", "id": "602735458325235", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031634_602735461658568_4828349097392926470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w29iMuCwkWQQ7kNvgHiyeUb&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCd_FmgI8TQfkmiJcYBLJYSm1a03ockYZBYocIRL8lRfg&oe=670F9328"}]}, "id": "779459420996169", "locale": "en_US", "screenshots": [{"file_name": "bn2.png", "id": "723206489317459", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75367591_723206492650792_7836788807916181930_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qa49lknb1PMQ7kNvgFo96gV&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDMT5mLahFhP13pYGKO7dDEYzxdowykUnR2U-wHu5JD2Q&oe=670F9DB3"}, {"file_name": "ctky.png", "id": "563457245767154", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031350_563457249100487_6418008387233526367_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oEr4ZeD-H1oQ7kNvgEfSLMO&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD1TMmJ5-nEm1yoqlLO4KCFtF_x3nUa6Bf9y4HToWEn_A&oe=670F8CCC"}, {"file_name": "Screenshot 2023-01-30 at 02.29 2.png", "id": "565789808551133", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974892_565789811884466_6526345203447617269_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZYztBqlEuIgQ7kNvgGk6ci3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBqajlL7FXHKcf4QlhwsOHDpYWAgMh16IhxsaGItb4Ycg&oe=670FA170"}, {"file_name": "bn1.png", "id": "703831071324154", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75392880_703831077990820_4260937339645075700_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_6HAJlNC02gQ7kNvgHE8daz&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA9ji4px6fgHaoh4BJmV9gY9JIQUfha-vjnPJbFq1HsdQ&oe=670F9192"}, {"file_name": "image 86.png", "id": "1352566882309213", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974482_1352566885642546_8597886574679645531_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_RGMhb3R5VsQ7kNvgGxJJjj&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCNFQxl2kup2s4ztrv22wRtp40co0sCa4_xMyjax5dWsQ&oe=670F9FB3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape.png", "id": "3722371651381650", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035326_3722371654714983_6861457912443840052_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jAj2Y1kNVIEQ7kNvgGCbctJ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYATQ4VHS9L7Es_HIQ6GIeOVtruTcubsM1rPORJ5RpjKhA&oe=670F8F7E"}, "display_name": "VRFS - Football (Soccer) Simulator", "keywords": [], "long_description": "VRFS is a community-driven soccer (football) simulator with focus on realistic physics and competitive multiplayer.\n\nHere are the main features of VRFS:\n\nPHYSICS SIMULATION: Players can perform almost any trick, from balancing the ball on the tip of their foot to executing curved power shots and long passes. The ball's trajectory is solely determined by the physics engine.\n\nCOMPETITIVE MULTIPLAYER: The multiplayer architecture allows for instantaneous ball-touch response. For example, players can finish powerful crosses at the same speed as in real soccer. \n\nCOMFORT: Players can move around using thumbsticks and play in either a seated or standing position. No intense hand movements are required.\n\nNO PAY-TO-WIN in VRFS: Only skills matter. No one can buy 'stronger kicks' or 'faster boots.' Keep practicing, and you'll see improvement.\n\nFREE FOR ALL: Players have full access to the game without needing to purchase anything. However, if you wish, you can buy cool equipment in the store to support the further development of this project.\n\nPlease keep in mind that VRFS is still in development, with upcoming upgrades to the physics and scenery. We'd appreciate your suggestions for any enhancements.\n", "short_description": "VRFS is a community-driven soccer (football) simulator with focus on realistic physics and competitive multiplayer.\n\nHere are the main features of VRFS:\n- Realistic physics\n- Competitive multiplayer\n- Comfortable controls\n- No pay-to-win mechanics\n- Free for all\n\nPlease keep in mind that VRFS is still in development, with upcoming upgrades to the physics and scenery. We'd appreciate your suggestions for any enhancements."}]}, "developer_name": "0BS3SS10N Co.", "developer_privacy_policy_url": "https://vrfs.gg/en/docs/privacy/", "developer_terms_of_service_url": "https://vrfs.gg/en/docs/terms/", "publisher_name": "Immersification", "support_website_url": "https://vrfs.gg/contacts/", "website_url": "https://vrfs.gg/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "es", "de", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "25623527567261804"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031634_602735461658568_4828349097392926470_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w29iMuCwkWQQ7kNvgHiyeUb&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCkwfLjqExpmyx7yV8nBDLJqzI7JhRyYvcozL2vcfDxvw&oe=670F9328"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRFS - Football (Soccer) Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "27765422860