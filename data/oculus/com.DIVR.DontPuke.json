kNvgELt3G9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0St5-DQdVJtLnQZu45p_yVzmy11f_hvZmWr0p-T6jGA&oe=6752ECB0"}, {"file_name": "art_3(2560x1440)4.png", "id": "1129112464888620", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982600_1129112468221953_4843682270007910152_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mm3A7h2hScEQ7kNvgHn6bBI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBp69xFCEnG_1HUG1_1twvSq1vzYq4SGSeYCuTFAW_rXw&oe=6752D27A"}, {"file_name": "art_5(2560x1440)2.png", "id": "386613044000784", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031356_386613047334117_4276970737731009030_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JvkHf3doqJEQ7kNvgH9b_ZA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUyfqYtGkdKNalwouXOHazvnWvTJIenzzpzslNrZuvFg&oe=6752E6DA"}, {"file_name": "art_6(2560x1440)1.png", "id": "365858286069392", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75361346_365858289402725_4836685336958732003_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dFqjbScT0QoQ7kNvgG2Kl7W&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBMW7-LdwQIi5bW1TXJ1d5wnHLGkD0L4Kh3oq-3ZgbqbQ&oe=6752F8D8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage2560 x 1440px (24-Bit PNG).png", "id": "762706069056253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569431_762706072389586_7921072148263435219_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_gvnUxl69_QQ7kNvgGeXtnS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAZETS2-Vty38DBQuqokCZuN2YcoYpE3pzLpw_Re9cqeg&oe=6752F7BD"}, "display_name": "Don't Puke!", "keywords": [], "long_description": "Only a few will make it to the top! Embark on a wild ride in a new online, physics-based VR game with unique control mechanics. Discover and enjoy the world around you!\n\nExplore the expansive open-sky island playground, designed to challenge your skills to the utmost. The island is segmented into various areas, each offering distinct PvP or Co-Op mechanics. Scale and fly across the island's highest peaks. Tackle mini-puzzles solo or alongside friends. To reach the summit, mastering your cart control skills is crucial.\n\nThe sky is the limit!\n\nCURRENT FEATURES:\nPlayers navigate using a special cart that moves based on realistic physics, capable of boosting, jumping, and gliding. Control is achieved by grabbing and turning the wheels. Use the boost to accelerate or ascend steep inclines. Jump to reach higher levels or leap across platforms. Alternatively, spread your wings and glide through the air.\n\nEnjoy the game solo or join public servers for an enhanced experience with other players.\n\nThe game is set on a sky island, divided into several sections, each embodying a unique PvP gameplay mechanic. The island's vertical terrain offers a challenging obstacle course, ideal for solo play and even more engaging in multiplayer cooperation. Through adept cart control, players strive to reach the island's summit.", "short_description": "Only a few will make it to the top! Ride, jump, and fly either solo or with friends, in this virtual reality game. Mastering your cart control skills is essential to reach the island's highest peaks."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/18j-rc2KTGxvH9NQeiRki5tzALUWSkeZJQtH9f75zw1U/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "DIVR Labs", "support_website_url": null, "website_url": "http://www.dontpuke.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_pro