"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75549081_1044834287018548_64805007839376468_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DH-iHlODc_AQ7kNvgGsYwAe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDs6ql4gtovICvPWnR-El1dpYUW_pC_mG_zXqcqj87wWQ&oe=672DDE8F"}, {"file_name": "Image7.png", "id": "1763201200886253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035412_1763201204219586_8820887229598491536_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z58hl6MZeskQ7kNvgETDb78&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5nitYxBgeccfX8dzLxdOj36jcQfwESAAoAfZrgrpdmQ&oe=672DE45B"}, {"file_name": "Image1.png", "id": "557571833262622", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75549081_557571836595955_7752800878290085319_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4r__bvG0Jr4Q7kNvgGtF3Mu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDkLlwKIGyaBjAFlFr3uNudrwEuk4jHTP7RUKxrSLP9Gw&oe=672DFA11"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HB_Landscape.png", "id": "866328791671111", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982511_866328795004444_367377865113191215_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tD2txvV2RWYQ7kNvgGxSZw7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7WpkoHJhzxHkzMlLp-l1_eBRQS2eQGof-Dxn_BQCWaQ&oe=672E132A"}, "display_name": "HoverBlade", "keywords": [], "long_description": "In Megacity 13, racing is more than just a sport\u2014it's a high-stakes challenge where only the best emerge victorious. In **HoverBlade**, you are an elite racer, poised to dominate the competition as new tracks are laid out across the city\u2019s towering skyline. With nothing but the void below, you must navigate your hoverbike through intense, fast-paced races against other skilled pilots.\n\nMaster the art of racing as you push your limits to be the first across the finish line. **HoverBlade** offers both competitive tournaments where you can challenge your friends and a more relaxed training environment where you can perfect your skills. What sets **HoverBlade** apart is its unique gameplay, requiring you to use your entire body to maneuver through the intricate twists and turns of each track.\n\nFor those seeking a thrilling and immersive racing experience, **HoverBlade** offers something truly unique. So when the call for the next race goes out, will you be ready to rise to the challenge?\n{3625421424454523}", "short_description": "Race through the daring tracks of Megacity 13 on your hoverbike, outpacing your rivals to claim victory!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.imitera.com/privacy-policy-hoverblade/", "developer_terms_of_service_url": null, "publisher_name": "Imitera", "support_website_url": null, "website_url": "https://www.imitera.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "676916699976767"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974447_1196931098241762_6251665912076372406_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g_kQh473a44Q7kNvgFrsUkb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBC096DYjecZpcaipMJW2XU5j1Dh-fw4F26p7IAZ0SGA&oe=672DE4C5"}, "is_concept": false, "is_test": f