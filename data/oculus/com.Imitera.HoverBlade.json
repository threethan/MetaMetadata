5007839376468_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sqY0E_Jue_oQ7kNvgGHPcqp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5IDslCaURk-lGndra53fzHgv_LkntKQAp5WAj1lYPAw&oe=6708F48F"}, {"file_name": "Image7.png", "id": "1763201200886253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035412_1763201204219586_8820887229598491536_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VoyL-ZAIeHIQ7kNvgHOJmQF&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_zRBk7xeQ-FcqCDJ7gC1K6AXEwx1u4kCxeyIHt1s2Dg&oe=6708FA5B"}, {"file_name": "Image1.png", "id": "557571833262622", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75549081_557571836595955_7752800878290085319_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_JUOzIffEhUQ7kNvgHbFVdz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuySor9nqqWb18x-5bhAvnkgx-jTSqc1tZ8tQ4Khm2TA&oe=67091011"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HB_Landscape.png", "id": "866328791671111", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982511_866328795004444_367377865113191215_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pLb12f5fYSMQ7kNvgH6gi-e&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBnqqwoPWq58jENeCdXMwPy8nT_GwVzej5mXjWR5fSXfQ&oe=6709292A"}, "display_name": "HoverBlade", "keywords": [], "long_description": "In Megacity 13, racing is more than just a sport\u2014it's a high-stakes challenge where only the best emerge victorious. In **HoverBlade**, you are an elite racer, poised to dominate the competition as new tracks are laid out across the city\u2019s towering skyline. With nothing but the void below, you must navigate your hoverbike through intense, fast-paced races against other skilled pilots.\n\nMaster the art of racing as you push your limits to be the first across the finish line. **HoverBlade** offers both competitive tournaments where you can challenge your friends and a more relaxed training environment where you can perfect your skills. What sets **HoverBlade** apart is its unique gameplay, requiring you to use your entire body to maneuver through the intricate twists and turns of each track.\n\nFor those seeking a thrilling and immersive racing experience, **HoverBlade** offers something truly unique. So when the call for the next race goes out, will you be ready to rise to the challenge?\n{3625421424454523}", "short_description": "Race through the daring tracks of Megacity 13 on your hoverbike, outpacing your rivals to claim victory!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.imitera.com/privacy-policy-hoverblade/", "developer_terms_of_service_url": null, "publisher_name": "Imitera", "support_website_url": null, "website_url": "https://www.imitera.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "673385183287495"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "676916699976767"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974447_1196931098241762_6251665912076372406_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e5qcTU_aG-4Q7kNvgGaCKWL&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPUGUZ5o3c125s7G3lX3tromlYSRZ-5k6zGksB7MqC5Q&oe=6708FAC5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "HoverBlade", "platform": "ANDROID_6DOF", "context_category": {"context_category":