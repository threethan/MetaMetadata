vgG-_98r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZsiu1E4eG8dexAu-L5Zu2IxDUr5e66uviL5dj2MJBhg&oe=6741AB94"}, {"file_name": "Image9.png", "id": "3775357589402833", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982706_3775357592736166_5788432583573586860_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YKG34hApAu4Q7kNvgH7ZTsL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCASJeHDdnpJyUYBof10O6U5SjU9fpb7jIBlsi86skLQ&oe=6741AFE8"}, {"file_name": "Image10.png", "id": "1044834283685215", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75549081_1044834287018548_64805007839376468_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XQoMhZxbOwcQ7kNvgHqchui&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASvdTEML4CCtbXWRU32hH7SnWlS34Xtya4NHA6_r1DRQ&oe=6741A50F"}, {"file_name": "Image7.png", "id": "1763201200886253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035412_1763201204219586_8820887229598491536_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=12wCpmFwSYcQ7kNvgFcdZ6F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmLUcTQkIzNgTnAW07U34dFXaPIO2TdKO5OGv5igkw1Q&oe=6741AADB"}, {"file_name": "Image1.png", "id": "557571833262622", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75549081_557571836595955_7752800878290085319_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O3fkR_rwzjwQ7kNvgEw2DYW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUxuYA-5KGmATO5avDM6M_J_UqMfsjtopoAisztBI16g&oe=6741C091"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HB_Landscape.png", "id": "866328791671111", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982511_866328795004444_367377865113191215_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XadCPAoPc54Q7kNvgGqibap&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvZujQd_0X9_XeW5Xu_3K25-5-KI-vc4oKN0B79chHCA&oe=6741D9AA"}, "display_name": "HoverBlade", "keywords": [], "long_description": "In Megacity 13, racing is more than just a sport\u2014it's a high-stakes challenge where only the best emerge victorious. In **HoverBlade**, you are an elite racer, poised to dominate the competition as new tracks are laid out across the city\u2019s towering skyline. With nothing but the void below, you must navigate your hoverbike through intense, fast-paced races against other skilled pilots.\n\nMaster the art of racing as you push your limits to be the first across the finish line. **HoverBlade** offers both competitive tournaments where you can challenge your friends and a more relaxed training environment where you can perfect your skills. What sets **HoverBlade** apart is its unique gameplay, requiring you to use your entire body to maneuver through the intricate twists and turns of each track.\n\nFor those seeking a thrilling and immersive racing experience, **HoverBlade** offers something truly unique. So when the call for the next race goes out, will you be ready to rise to the challenge?\n{3625421424454523}", "short_description": "Race through the daring tracks of Megacity 13 on your hoverbike, outpacing your rivals to claim victory!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.imitera.com/privacy-policy-hoverblade/", "developer_terms_of_service_url": null, "publisher_name": "Imitera", "support_website_url": null, "website_url": "https://www.imitera.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["