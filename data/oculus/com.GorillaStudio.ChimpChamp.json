rilla Tag Fan Game that you can do , well, technically ANYTHING in! We have maps such as: Forest, Horror, Zero Gravity, City, Pool, you name it! In Chimp Champ we try to make a game that is amusing, exciting, and for the most part, FUN! This is the owner out."}]}, "developer_name": "goRILLA", "developer_privacy_policy_url": "https://sleezgtag.wixsite.com/my-site-3", "developer_terms_of_service_url": null, "publisher_name": "goRILLA", "support_website_url": null, "website_url": "https://sleezgtag.wixsite.com/my-site-3", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8020624198020325"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "802727875176671"}]}, "baseline_offer": {"id": "802727875176671"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722810763, "status": "PUBLISHED", "id": "802727875176671"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8161915050557905", "version": "30"}, "id": "755919623197604", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8020624188020326", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8161915050557905"}, "release_