ase\n\nFull version includes 10 scenes plus the ability to add your own photos and a choice of between 8 and 162 piece jigsaws.", "short_description": "Relax while completing beautifully detailed spherical jigsaws. The new way to experience a traditional puzzle. Demo includes two scenes with both spherical and flat jigsaws to try."}]}, "developer_name": "Head Start Design", "developer_privacy_policy_url": "http://www.jumblivr.com/privacy/", "developer_terms_of_service_url": "http://www.jumblivr.com/terms/", "publisher_name": "Head Start Design", "support_website_url": "http://www.jumblivr.com/", "website_url": "http://www.jumblivr.com/519_jigsaw_360/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "650106892904225"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974621_617351212427875_122842507116544000_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VPJRdr3fYxMQ7kNvgFVPd2z&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABZFajlvonDseHSCk9CTN3H&oh=00_AYCAjRgoKkDn7vgS_MjczhJH-xLmD1b1p0jOaKblId9-MA&oe=66CC75C7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Jigsaw 360 Demo", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1582221569, "lastRevision": {"nodes": [{"id": "3497052933699836", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata"