autifully detailed spherical jigsaws. The new way to experience a traditional puzzle. Demo includes two scenes with both spherical and flat jigsaws to try."}]}, "developer_name": "Head Start Design", "developer_privacy_policy_url": "http://www.jumblivr.com/privacy", "developer_terms_of_service_url": "http://www.jumblivr.com/terms/", "publisher_name": "Head Start Design", "support_website_url": null, "website_url": "http://www.jumblivr.com/519_jigsaw_360/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "315761010489745"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4360110187347964", "version": "2.1.8"}, "id": "1257771857754535", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3965164823509171", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4360110187347964"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1257771857754535"}]}, "change_log": "Alcove integration v1.0", "created_date": 1588587859, "id": "4360110187347964", "version": "2.1.8", "version_