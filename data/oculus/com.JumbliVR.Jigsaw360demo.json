928_2983841678326576_5985576198774718464_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QyWLSIAgKh0Q7kNvgE9NXvm&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABZFajlvonDseHSCk9CTN3H&oh=00_AYASosczBbizzwpnlqdMQ0zg_nneBeE13V9u79X6xSPLtQ&oe=66CC69AF"}, {"file_name": "migrated_image.png", "id": "263831054616898", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556795_722573121602268_2439440449446871040_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C9lVQNwzYmIQ7kNvgEzCHFn&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABZFajlvonDseHSCk9CTN3H&oh=00_AYAyxqbLeYpSZV3u0qtSm7jDjU3X3Omh4qvVPRwokVuY1w&oe=66CC58BF"}, {"file_name": "migrated_image.png", "id": "251541162532306", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982556_1480853892091762_2567871409095180288_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RqfrCTsIsgMQ7kNvgGt68-4&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABZFajlvonDseHSCk9CTN3H&oh=00_AYBBB6vnmtVQ7tpAmydfxvuquQQgjbrt541ow-d0H7514w&oe=66CC7E48"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/P1b8ml", "id": "642346203237026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974467_642346206570359_2225010560766836736_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tsjk9JFH8GMQ7kNvgE4evvd&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABZFajlvonDseHSCk9CTN3H&oh=00_AYBUSZokNnGBFoyypnY5R65k1-vAuQRE58OtVOaZpoAP4w&oe=66CC4D2D"}, "display_name": "Jigsaw 360 Demo", "keywords": ["free", "demo"], "long_description": "Relax while completing beautifully detailed spherical jigsaws. The new way to experience a traditional puzzle. \n\nDemo includes two scenes with both spherical and flat jigsaws to try.\n\nFind yourself stood inside the jigsaw. Use your controllers to precisely place your pieces as you build the spherical puzzle. Rotate the jigsaw and scene to see it from different angles. Traditional flat jigsaws are also included.\n\n***What to expect***\nBe relaxed by the music\nCalmed by the sounds of nature, rain or waves (headphones recommended)\nGrab and manipulate pieces with ease\n\nFull version includes 10 scenes plus the ability to add your own spherical (equirectangular) photos and a choice of between 8 and 162 piece jigsaws.", "short_description": "Relax while completing beautifully detailed spherical jigsaws. The new way to experience a traditional puzzle. Demo includes two scenes with both spherical and flat jigsaws to try."}]}, "developer_name": "Head Start Design", "developer_privacy_policy_url": "http://www.jumblivr.com/privacy", "developer_terms_of_service_url": "http://www.jumblivr.com/terms/", "publisher_name": "Head Start Design", "support_website_url": null, "website_url": "http://www.jumblivr.com/519_jigsaw_360/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "315761010489745"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "146852446410605"}, {"status": "CANCELLED", "id": "916752025406535"}]}, "baseline_offer": {"id": "146852446410605"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1582221699, "status": "PUBLISHED", "id": "146852446410605"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4360110187347964", "version": "2.1.8"}, "id": "1257771857754535", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary"