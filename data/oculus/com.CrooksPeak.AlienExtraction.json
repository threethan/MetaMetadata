g you...\n\nFull game releasing March 2022!", "short_description": "Control an alien infested space station in this lighthearted VR strategy puzzle game. Guide Lenny the janitor through deadly and dangerous levels: sneak, burn, distract, pilot, blast and clean his way to safety. Control drones, check cameras and complete puzzles to solve the station's mysteries. Full game releasing March 2022!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://alienextraction.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Crooks Peak", "support_website_url": "https://alienextraction.com/bug", "website_url": "https://alienextraction.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "STRATEGY", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "234465122195418"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_705607217497178_2399535277660242594_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UPOdRBTwW_EQ7kNvgFllfrj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6uFrWTIaab--6hS-ptT5pC&oh=00_AYBjg8B92tSjfgi9WnuyyYZe-c8xW9neWlJgAKsw9vbqiA&oe=66E967EC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Alien Extraction Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1645052867, "lastRevision": {"nodes": [{"id": "4691660124249764", "release_type": "SCHEDULED", "admi