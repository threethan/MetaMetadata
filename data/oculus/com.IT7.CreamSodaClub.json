scdn.com&oh=00_AYCg-LaRQs9GjAtJPMpkOO6aVFLWSQiweM3CJECxR4Jg1A&oe=671F8BA4"}, {"file_name": "Meta-1080 x360.png", "id": "963910525053488", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982564_963910528386821_4638279911598050766_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xgd9rHpT3vgQ7kNvgFAuE5E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDkiEIoRZps5Xs-38l6DmDPpoj2Mu_prfKVwaybWQVhFA&oe=671F7A96"}, {"file_name": "Meta-3000x900.png", "id": "915584226370013", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404382_915584229703346_8448700366979786440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ga0wWrpcFTwQ7kNvgH97RSF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDtIpeeH2gkYeiezTHM5F_Tzf2TN8EibP-H90Q_VhJqZA&oe=671F63A5"}, {"file_name": "Meta-2560 x1440.png", "id": "791319009326399", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001660_791319012659732_2310774473768321787_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KMM8GS49tbUQ7kNvgEcBNnV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFhdYPgu5Lf7KPtkTcyOxAWw4RlIFohuGjjBsUxXM7dw&oe=671F6CED"}, {"file_name": "Meta-1440 x1440.png", "id": "714806980445424", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035411_714806983778757_2700937402279450083_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_GdVuOdF2aIQ7kNvgGHkSP7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC2QTqZKFFXD8ZHSDHyGvBpqFhe7tjmfHRmNK7ZdgBylg&oe=671F6B2B"}]}, "id": "5971617616293962", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cream Soda Club", "keywords": [], "long_description": "\u0421\u0442\u0430\u043d\u044c \u0447\u043b\u0435\u043d\u043e\u043c \u043a\u043e\u043c\u0430\u043d\u0434\u044b Cream Soda\n\n\u0412 \u0438\u0433\u0440\u0435 Cream Soda Club \u0442\u044b \u043f\u043e\u043f\u0430\u0434\u0430\u0435\u0448\u044c \u0432 \u043c\u0438\u0440 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u043e\u0439 \u043c\u0443\u0437\u044b\u043a\u0438 \u0438 \u0432\u0435\u0447\u0435\u0440\u0438\u043d\u043e\u043a. \u0422\u044b - \u0438\u0432\u0435\u043d\u0442-\u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440, \u0443\u043a\u0440\u0430\u0448\u0430\u0439 \u043c\u0443\u0437\u044b\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043b\u0443\u0431, \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0439 \u0448\u043e\u0443 \u0432\u043c\u0435\u0441\u0442\u0435 \u0441 \u0433\u0440\u0443\u043f\u043f\u043e\u0439 Cream Soda.\n\n\u0413\u0435\u0439\u043c\u043f\u043b\u0435\u0439\n\n\u041f\u043e\u0441\u0435\u0442\u0438\u0442\u0435\u043b\u0438 \u0434\u043e\u043b\u0436\u043d\u044b \u0431\u044b\u0442\u044c \u0432 \u0432\u043e\u0441\u0442\u043e\u0440\u0433\u0435 \u043e\u0442 \u0448\u043e\u0443, \u0442\u043e\u0433\u0434\u0430 \u043e\u043d\u0438 \u0431\u0443\u0434\u0443\u0442 \u0434\u0430\u0440\u0438\u0442\u044c \u043a\u043b\u0443\u0431\u0443 \u201c\u043b\u0430\u0439\u043a\u0438\u201d. \u0422\u0440\u0430\u0442\u044c \u043b\u0430\u0439\u043a\u0438 \u043d\u0430 \u0443\u043a\u0440\u0430\u0448\u0435\u043d\u0438\u0435 \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043a\u043b\u0443\u0431\u0430, \u043f\u0443\u0441\u0442\u044c \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0430 \u0432\u0435\u0447\u0435\u0440\u0438\u043d\u043a\u0438 \u0431\u0443\u0434\u0435\u0442 \u043d\u0435\u043f\u043e\u0432\u0442\u043e\u0440\u0438\u043c\u043e\u0439. \u0417\u0430\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0439 \u0431\u043e\u043b\u044c\u0448\u0435 \u043b\u0430\u0439\u043a\u043e\u0432, \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0439 \u043d\u043e\u0432\u044b\u0435 \u0442\u0440\u0435\u043a\u0438 \u0438 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u044b \u043a\u0430\u0441\u0442\u043e\u043c\u0438\u0437\u0430\u0446\u0438\u0438 \u043a\u043b\u0443\u0431\u0430.\n\n\u041a\u043b\u044e\u0447\u0435\u0432\u044b\u0435 \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u0438:\n- \u0422\u0440\u0435\u043a\u0438 \u043e\u0442 Cream Soda \u0432 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0443\u0440\u043e\u0432\u043d\u0435\u0439 \u0438\u0433\u0440\u044b. \u0412\u0441\u0435 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u044b \u043a\u043b\u0443\u0431\u0430 \u0432 \u0443\u043d\u0438\u0441\u043e\u043d \u0440\u0435\u0430\u0433\u0438\u0440\u0443\u044e\u0442 \u043d\u0430 \u0440\u0438\u0442\u043c, \u043f\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044f \u0438\u0433\u0440\u0443 \u0432 \u043c\u0443\u0437\u044b\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043b\u0438\u043f.\n- \u041c\u0443\u0437\u044b\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043b\u0443\u0431 \u043a\u0430\u043a \u0438\u0433\u0440\u043e\u0432\u043e\u0439 \u043c\u0438\u0440. \u041f\u043e\u043a\u0443\u043f\u0430\u0439 \u0438 \u0440\u0430\u0437\u043c\u0435\u0449\u0430\u0439 \u0434\u0438\u0441\u043a\u043e-\u0448\u0430\u0440\u044b, \u043a\u043e\u043b\u043e\u043d\u043a\u0438, \u043f\u0440\u043e\u0436\u0435\u043a\u0442\u043e\u0440\u044b, \u043f\u0443\u0444\u0438\u043a\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u0435 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u044b.\n- \u0416\u0435\u043b\u0430\u043d\u0438\u0435 \u043f\u043e\u0441\u0435\u0442\u0438\u0442\u0435\u043b\u044f - \u0437\u0430\u043a\u043e\u043d. \u041a\u0442\u043e-\u0442\u043e \u0445\u043e\u0447\u0435\u0442 \u0442\u0430\u043d\u0446\u0435\u0432\u0430\u0442\u044c, \u043a\u0442\u043e-\u0442\u043e \u0435\u0441\u0442\u044c, \u0430 \u043a\u0442\u043e-\u0442\u043e \u043e\u0431\u0449\u0430\u0442\u044c\u0441\u044f. \u0417\u0430\u0434\u0430\u0447\u0430 \u0438\u0433\u0440\u043e\u043a\u0430 \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u0438\u0442\u044c \u043f\u043e\u0442\u0440\u0435\u0431\u043d\u043e\u0441\u0442\u0438 \u0432\u0441\u0435\u0445.\n- \u0412\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0439 \u0441 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u0433\u0440\u0443\u043f\u043f\u044b Cream Soda \u0432 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0435\u0439 \u043a\u043b\u0443\u0431\u0430 \u0438 \u0443\u043b\u0443\u0447\u0448\u0430\u0439 \u0438\u0445 dj-\u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u0435.\n- \u041f\u0443\u0441\u0442\u044c \u0432\u0430\u0448 \u0433\u0435\u0439\u043c\u043f\u043b\u0435\u0439 \u0438 Cream Soda \u0437\u0432\u0443\u0447\u0430\u0442 \u0432 \u0443\u043d\u0438\u0441\u043e\u043d!\n", "short_description": "\u0412 \u0438\u0433\u0440\u0435 Cream Soda Club \u0442\u044b \u043f\u043e\u043f\u0430\u0434\u0430\u0435\u0448\u044c \u0432 \u043c\u0438\u0440 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u043e\u0439 \u043c\u0443\u0437\u044b\u043a\u0438 \u0438 \u0432\u0435\u0447\u0435\u0440\u0438\u043d\u043e\u043a. \u0422\u044b - \u0438\u0432\u0435\u043d\u0442-\u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440, \u0443\u043a\u0440\u0430\u0448\u0430\u0439 \u043c\u0443\u0437\u044b\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043b\u0443\u0431, \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0439 \u0448\u043e\u0443 \u0432\u043c\u0435\u0441\u0442\u0435 \u0441 \u0433\u0440\u0443\u043f\u043f\u043e\u0439 Cream Soda.\n"}, {"images": {"nodes": [{"file_name": "meta-360x360.png", "id": "1286677865611957", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036655_1286677868945290_1988679933159081839_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FyMq5j12olgQ7kNvgGrHoIy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAkrbjUJhzi6Na0yv9NGKewrUxkF6JwflgFUMstKJKZfA&oe=671F8BF3"}, {"file_name": "Meta-1080 x360.png", "id": "1226479238239233", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https: