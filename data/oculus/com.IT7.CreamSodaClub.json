://scontent.oculuscdn.com/v/t64.5771-25/75572750_1411891502931175_408961297352812201_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=haopnVk4sGMQ7kNvgHR2rsW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdg6ZYWam4jKFWo3i9otHrQc5ywFpf3I7yKoK846RWxQ&oe=66D4555D"}, {"file_name": "9.png", "id": "1440910643317404", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982564_1440910646650737_8196635112941224990_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=scf4MWhWT4wQ7kNvgG2EfEG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAd1y2aSLaaNPBq9mvsU_SucpapkX3F29uyxtV8OIVZBg&oe=66D44482"}, {"file_name": "7.png", "id": "941507890234535", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422385_941507893567868_4576673717763229281_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=452zTi4LFB8Q7kNvgH6iTv1&_nc_ht=scontent.oculuscdn.com&oh=00_AYCpe3M0J8oD7a5fnhh48_5VVj8vn1jkwzjR-Q-afXEOpA&oe=66D46012"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta-2560-x1440.png", "id": "200037129611859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974813_200037132945192_2121428774428329616_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IEFPFd_L0SEQ7kNvgGgUnYK&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8i2jj5XYYlJ1fqDDNLI4PPSBc-VMGKLx7ekgY5ATbJg&oe=66D4349F"}, "display_name": "CREAM SODA CLUB", "keywords": [], "long_description": "Jazz up the VR party in all possible ways. Make the dance floor burst with satisfied patrons and pay attention to their desires. The more happy faces there are, the more music and development opportunities you will discover!\n\nKey features\n- Start an epic rave in a huge VR club\n- Observe the mood of your patrons and fulfill their wishes\n- The audience gives you likes for the atmosphere. You spend them on sound, light, and decor\n- Develop the club space right in the middle of the headliner performance\n- Discover a new track from the latest album of the popular band CREAM SODA on each new level of the game\n", "short_description": "Welcome to the world of fantastic parties with CREAM SODA! In this universe, suggested by the ideas of the band, you are the promoter of the club where their new album is premiering. The success of the party is in your hands \u2014 arrange a complete soldout!"}]}, "developer_name": "CREAM SODA CLUB Team", "developer_privacy_policy_url": "https://itseven-studio.com/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "CREAM SODA CLUB Team", "support_website_url": null, "website_url": "https://itseven-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "267744875621062"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_1026530508323631_7272139152816204882_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KWNlyEQY9iIQ7kNvgE-DtdC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfeU0W8GHcZoHl7dSFuJu7MD8XMj-XcDwIfQCuwK5Y5Q&oe=66D44D5D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CREAM SODA CLUB", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Simulation", "id": "331529188132278"}], "rel