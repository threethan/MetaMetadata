mood of your patrons and fulfill their wishes\n- The audience gives you likes for the atmosphere. You spend them on sound, light, and decor\n- Develop the club space right in the middle of the headliner performance\n- Discover a new track from the latest album of the popular band CREAM SODA on each new level of the game\n", "short_description": "Welcome to the world of fantastic parties with CREAM SODA! In this universe, suggested by the ideas of the band, you are the promoter of the club where their new album is premiering. The success of the party is in your hands \u2014 arrange a complete soldout!"}]}, "developer_name": "CREAM SODA CLUB Team", "developer_privacy_policy_url": "https://itseven-studio.com/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "CREAM SODA CLUB Team", "support_website_url": null, "website_url": "https://itseven-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "267744875621062"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035320_1026530508323631_7272139152816204882_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9EWvoEzTDugQ7kNvgG4q-id&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBKOfj7LGrFoEzi5fJFNqyivzHprWpl-3wjcY7HGCmXow&oe=670FA0DD"}, "is_concept": false, "is_te