_sid=6e7a0a&_nc_ohc=Lz17wNA3ClQQ7kNvgFDBwJv&_nc_ht=scontent.oculuscdn.com&oh=00_AYCt4ua7nNc0QcXWQxhx_Iuwh2zr6YDIH7-cniBhVFptmw&oe=66D7088E"}, {"file_name": "291.png", "id": "545917907478709", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568684_545917914145375_6760022836583993199_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VubbYp27LGkQ7kNvgGX-lW-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCzw7mwKzqe6Vxh3YZo3OJi9UQO6Fw0xtBAtVurf9Yyg&oe=66D6EA3C"}, {"file_name": "135.png", "id": "620218949704284", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_620218953037617_4533280750713458941_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OFjiEgYsVzIQ7kNvgGWdXed&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgPvAaewQfDxUJKS2LJc3U2xBT9F-Xr5V8AFNvuWqhkA&oe=66D6FDC7"}, {"file_name": "305.png", "id": "1253018791979472", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031631_1253018795312805_7116269350022562735_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nllULMvnP6YQ7kNvgFPCNgR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyzJVyeI7AKryAQW7PGEdcF82XM_65--TZuC5iy9xLEA&oe=66D709CE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cream Soda Club", "keywords": [], "long_description": "Gameplay\nWhenever your patrons have enjoyed the show, they \u2018like\u2019 your club. Spend likes as a resource to furnish and develop the venue, and make sure to create a unique atmosphere. Earn more likes to unlock more music tracks and customize your nightspot.\n\nKey features\n- Cream Soda tracks as game levels. Objects in the club react to the beat, turning the game into a music video. \n- Nightclub as the game world. Purchase and place disco balls, speakers, projectors, poufs, and other furnishings.\n- Patron is the law. Some want to dance, some want to eat, and others come to socialize. Your task is to cater to everyone\u2019s needs.\n- Interact with Cream Soda band members as game characters and upgrade their DJ equipment.\n- Sync up with Cream Soda\u2019s music!\n", "short_description": "Cream Soda Club transports you into the world of EDM and parties. Play as an event manager: furnish the club and throw parties with Cream Soda."}]}, "developer_name": "Cream Soda Club Team", "developer_privacy_policy_url": "https://itseven-studio.com/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "Cream Soda Club Team", "support_website_url": null, "website_url": "https://itseven-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "208993575286907"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "920892019121891"}, {"status": "PUBLISHED", "id": "926779498439900"}]}, "baseline_offer": {"id": "920892019121891"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1685048400, "status": "PUBLISHED", "id": "920892019121891"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6155238044571353", "version": "1.41"}, "id": "957714551918248", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6002623299832829", "is_concept": false, "latest_released_binary": {"__typename