_nc_gid=AwVznjXLw96CCNuq-wHNfSw&oh=00_AYA269U7RDgcryTmyQl4JddHTGPBzUmY6t9VA6HR8Kkrqw&oe=66EA9E1F"}, "display_name": "CREAM SODA CLUB", "keywords": [], "long_description": "Jazz up the VR party in all possible ways. Make the dance floor burst with satisfied patrons and pay attention to their desires. The more happy faces there are, the more music and development opportunities you will discover!\n\nKey features\n- Start an epic rave in a huge VR club\n- Observe the mood of your patrons and fulfill their wishes\n- The audience gives you likes for the atmosphere. You spend them on sound, light, and decor\n- Develop the club space right in the middle of the headliner performance\n- Discover a new track from the latest album of the popular band CREAM SODA on each new level of the game\n", "short_description": "Welcome to the world of fantastic parties with CREAM SODA! In this universe, suggested by the ideas of the band, you are the promoter of the club where their new album is premiering. The success of the party is in your hands \u2014 arrange a complete soldout!"}]}, "developer_name": "CREAM SODA CLUB Team", "developer_privacy_policy_url": "https://itseven-studio.com/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "CREAM SODA CLUB Team", "support_website_url": null, "website_url": "https://itseven-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_track