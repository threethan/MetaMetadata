6988_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W7cToEt7oJoQ7kNvgG14zjz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaWIgkZwcWXQMj6Q8h-gAbHDn0P0CBldxAxkAMPsbYJA&oe=66D30583"}, "display_name": "CREAM SODA CLUB", "keywords": [], "long_description": "\u041f\u0440\u043e\u043a\u0430\u0447\u0430\u0439\u0442\u0435 VR-\u0432\u0435\u0447\u0435\u0440\u0438\u043d\u043a\u0443 \u0432\u0441\u0435\u043c\u0438 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u044b\u043c\u0438 \u0441\u043f\u043e\u0441\u043e\u0431\u0430\u043c\u0438. \u0422\u0430\u043d\u0446\u043f\u043e\u043b \u0434\u043e\u043b\u0436\u0435\u043d \u043b\u043e\u043c\u0438\u0442\u044c\u0441\u044f \u043e\u0442 \u0434\u043e\u0432\u043e\u043b\u044c\u043d\u043e\u0439 \u043f\u0443\u0431\u043b\u0438\u043a\u0438, \u0430 \u0434\u043b\u044f \u044d\u0442\u043e\u0433\u043e \u043d\u0443\u0436\u043d\u043e \u0443\u0433\u0430\u0434\u044b\u0432\u0430\u0442\u044c \u0435\u0435 \u0436\u0435\u043b\u0430\u043d\u0438\u044f. \u0427\u0435\u043c \u0431\u043e\u043b\u044c\u0448\u0435 \u0441\u0447\u0430\u0441\u0442\u043b\u0438\u0432\u044b\u0445 \u043b\u0438\u0446 \u0432 \u043a\u043b\u0443\u0431\u0435 \u2014 \u0442\u0435\u043c \u0431\u043e\u043b\u044c\u0448\u0435 \u043d\u043e\u0432\u043e\u0439 \u043c\u0443\u0437\u044b\u043a\u0438 \u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0435\u0439 \u0434\u043b\u044f \u0435\u0433\u043e \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044f \u0432\u044b \u043e\u0442\u043a\u0440\u043e\u0435\u0442\u0435!\n\n\u041a\u043b\u044e\u0447\u0435\u0432\u044b\u0435 \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u0438: \n- \u0423\u0441\u0442\u0440\u043e\u0439\u0442\u0435 \u044d\u043f\u0438\u0447\u043d\u044b\u0439 \u0440\u044d\u0439\u0432 \u0432 \u043e\u0433\u0440\u043e\u043c\u043d\u043e\u043c VR-\u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0435 \u043a\u043b\u0443\u0431\u0430\n- \u0421\u043b\u0435\u0434\u0438\u0442\u0435 \u0437\u0430 \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u0435\u043c \u0433\u043e\u0441\u0442\u0435\u0439 \u0438 \u0438\u0441\u043f\u043e\u043b\u043d\u044f\u0439\u0442\u0435 \u0438\u0445 \u0436\u0435\u043b\u0430\u043d\u0438\u044f\n- \u041f\u0443\u0431\u043b\u0438\u043a\u0430 \u0434\u0430\u0440\u0438\u0442 \u043b\u0430\u0439\u043a\u0438 \u0437\u0430 \u0430\u0442\u043c\u043e\u0441\u0444\u0435\u0440\u0443, \u0430 \u0432\u044b \u2013 \u0442\u0440\u0430\u0442\u0438\u0442\u0435 \u0438\u0445 \u043d\u0430 \u0437\u0432\u0443\u043a, \u0441\u0432\u0435\u0442 \u0438 \u0434\u0435\u043a\u043e\u0440\n- \u0420\u0430\u0437\u0432\u0438\u0432\u0430\u0439\u0442\u0435 \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u043a\u043b\u0443\u0431\u0430 \u043f\u0440\u044f\u043c\u043e \u0432 \u0440\u0430\u0437\u0433\u0430\u0440 \u0432\u044b\u0441\u0442\u0443\u043f\u043b\u0435\u043d\u0438\u044f \u0445\u0435\u0434\u043b\u0430\u0439\u043d\u0435\u0440\u043e\u0432\n- \u041e\u0442\u043a\u0440\u044b\u0432\u0430\u0439\u0442\u0435 \u043d\u043e\u0432\u044b\u0439 \u0442\u0440\u0435\u043a \u0438\u0437 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0435\u0433\u043e \u0430\u043b\u044c\u0431\u043e\u043c\u0430 \u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u043e\u0439 \u043c\u0443\u0437\u044b\u043a\u0430\u043b\u044c\u043d\u043e\u0439 \u0433\u0440\u0443\u043f\u043f\u044b \u00abCREAM SODA\u00bb \u0441 \u043a\u0430\u0436\u0434\u044b\u043c \u043d\u043e\u0432\u044b\u043c \u0443\u0440\u043e\u0432\u043d\u0435\u043c \u0438\u0433\u0440\u044b\n", "short_description": "\u0414\u043e\u0431\u0440\u043e \u043f\u043e\u0436\u0430\u043b\u043e\u0432\u0430\u0442\u044c \u0432 \u043c\u0438\u0440 \u0444\u0430\u043d\u0442\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0432\u0435\u0447\u0435\u0440\u0438\u043d\u043e\u043a \u0433\u0440\u0443\u043f\u043f\u044b CREAM SODA! \u0412 \u044d\u0442\u043e\u0439 \u0432\u0441\u0435\u043b\u0435\u043d\u043d\u043e\u0439, \u0441\u043e\u0431\u0440\u0430\u043d\u043d\u043e\u0439 \u0438\u0437 \u0438\u0434\u0435\u0439 \u0433\u0440\u0443\u043f\u043f\u044b, \u0432\u044b - \u043f\u0440\u043e\u043c\u043e\u0443\u0442\u0435\u0440 \u043a\u043b\u0443\u0431\u0430, \u0432 \u043a\u043e\u0442\u043e\u0440\u043e\u043c \u0438\u0434\u0435\u0442 \u043f\u0440\u0435\u043c\u044c\u0435\u0440\u0430 \u043d\u043e\u0432\u043e\u0433\u043e \u0430\u043b\u044c\u0431\u043e\u043c\u0430. \u0423\u0441\u043f\u0435\u0445 \u0432\u0435\u0447\u0435\u0440\u0438\u043d\u043a\u0438 \u0432 \u0432\u0430\u0448\u0438\u0445 \u0440\u0443\u043a\u0430\u0445 \u2014 \u0443\u0441\u0442\u0440\u043e\u0439\u0442\u0435 \u043f\u043e\u043b\u043d\u044b\u0439 \u0441\u043e\u043b\u0434 \u0430\u0443\u0442!\n"}, {"images": {"nodes": [{"file_name": "Meta-1440-x1440.png", "id": "1026530504990298", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_1026530508323631_7272139152816204882_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KWNlyEQY9iIQ7kNvgGu1EpH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQA44Te29GLE07j3qhz2ppP8tBflhl7SZJDEASQt5s5A&oe=66D2FBDD"}, {"file_name": "Meta-1008-x1440.png", "id": "1011903000159955", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974497_1011903003493288_5059094685793525234_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xsX83m5DNV8Q7kNvgHn0jBl&_nc_ht=scontent.oculuscdn.com&oh=00_AYDuDvlZZ36EDOgIv32KXv4bGv_Qf5l5w3XrEkT0qTSsuQ&oe=66D2F3C5"}, {"file_name": "meta-360x360.png", "id": "987276072640897", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75322597_987276079307563_5802004394285286209_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_d06xBKLVScQ7kNvgHs4qUX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDNRbXaJaE9AVLG1hlzQwAbEDKiXV_XIKSJbfKxnCpi7w&oe=66D3002E"}, {"file_name": "Meta-2560-x1440.png", "id": "801066068027454", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54823267_801066071360787_690247716076167113_n.png?_nc_cat=104&