://scontent.oculuscdn.com/v/t64.5771-25/75572750_1411891502931175_408961297352812201_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SSLVifyUKLIQ7kNvgGZ4hzX&_nc_ht=scontent.oculuscdn.com&oh=00_AYBDRPt9Vz5V35MnIZZReqJPsimVPo3Tx7nZCNuFl8AmBA&oe=66E032DD"}, {"file_name": "9.png", "id": "1440910643317404", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982564_1440910646650737_8196635112941224990_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qb6YbbdF0DUQ7kNvgFHitE0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXvqBJ1NQ0QFVgZMyO9wfsis82nb9lmj3kEtmgfuVSHg&oe=66E02202"}, {"file_name": "7.png", "id": "941507890234535", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422385_941507893567868_4576673717763229281_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dN3o4qxjw6kQ7kNvgFz4Es1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbWJ7fyMSuVl5VjkGJUNXENyYTHOkua3-_icI9oTAydw&oe=66E03D92"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta-2560-x1440.png", "id": "200037129611859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974813_200037132945192_2121428774428329616_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u4jr1Dc76HsQ7kNvgHyOIdY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDfarZEcQf0q_2iUpx7pZJuAzOUiCu7-U_bs_vAXsSgNQ&oe=66E0121F"}, "display_name": "CREAM SODA CLUB", "keywords": [], "long_description": "Jazz up the VR party in all possible ways. Make the dance floor burst with satisfied patrons and pay attention to their desires. The more happy faces there are, the more music and development opportunities you will discover!\n\nKey features\n- Start an epic rave in a huge VR club\n- Observe the mood of your patrons and fulfill their wishes\n- The audience gives you likes for the atmosphere. You spend them on sound, light, and decor\n- Develop the club space right in the middle of the headliner performance\n- Discover a new track from the latest album of the popular band CREAM SODA on each new level of the game\n", "short_description": "Welcome to the world of fantastic parties with CREAM SODA! In this universe, suggested by the ideas of the band, you are the promoter of the club where their new album is premiering. The success of the party is in your hands \u2014 arrange a complete soldout!"}]}, "developer_name": "CREAM SODA CLUB Team", "developer_privacy_policy_url": "https://itseven-studio.com/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "CREAM SODA CLUB Team", "support_website_url": null, "website_url": "https://itseven-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "267744875621062"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_1026530508323631_7272139152816204882_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zmUXgbYPwMsQ7kNvgF7DuqJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZSlX9g9sBUat3R3Ksf5GV0QPL4b4kFB1EqNfFs-8HDA&oe=66E02ADD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CREAM SODA CLUB", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Simulation", "id": "331529188132278"}], "rel