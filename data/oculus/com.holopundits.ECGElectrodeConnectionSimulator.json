818529495388_2006685117776233217_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SC5mv4jUWKQQ7kNvgEtOjkR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvLkQS7NYg0wB_zDAV_abZNbEYtVyRyTEGnMsYvrXvuQ&oe=66D43B31"}, {"file_name": "ECG Electrode Connection Simulator_Screenshot_06.png", "id": "1486087411975972", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_1486087415309305_7213549594852165332_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-V2_B4ZxFBQQ7kNvgGyS5GW&_nc_ht=scontent.oculuscdn.com&oh=00_AYAkYf5IOdEFfNx9qsdPQDTtfQuabeCaOt3WhbyRwz_30w&oe=66D46809"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "7320587681372580", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422379_7320587688039246_9004529337689774178_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=teVKTtx8S2gQ7kNvgHI0Tw-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgwYI_HBXF7u_yGi2a4p_jIrr5929f6yPM_YCPXVT2TA&oe=66D445D4"}, "display_name": "ECG Electrode Connection Simulator", "keywords": [], "long_description": "The ECG Electrode Connection Simulator app immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master placing and using a 5-electrode ECG to monitor cardiac activity. This application guides users through the correct placement of electrodes, operation of the ECG machine, and interpretation of the resulting electrocardiogram. \n# Learning Objectives:  \n- Remembering the anatomical landmarks for electrode placement \n- Understanding the principles of ECG and its importance in cardiac monitoring \n- Applying the correct technique for attaching electrodes and operating the ECG machine \n- Analyzing the resulting ECG tracings to identify normal and abnormal patterns \n- Evaluating the quality of the ECG signal and making necessary adjustments \n- Creating a detailed report or care plan based on the ECG findings.  \n\nThis comprehensive simulation ensures that certified nursing assistant's or anyone interested in the healthcare field are proficient in the necessary skills required to perform ECG monitoring accurately and effectively in clinical settings. ", "short_description": "Designed to train CNAs in correctly placing and using a 5-electrode ECG to monitor and interpret patients' cardiac activity. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7644457645644102"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1153401749309562"}]}, "baseline_offer": {"id": "1153401749309562"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1717576070, "status": "PUBLISHED", "id": "1153401749309562"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7695585890531277", "version": "1.1"}, "id": "442974695041189", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7644457628977437", "is_concept": false, "latest_released_binary": {"__typename": "