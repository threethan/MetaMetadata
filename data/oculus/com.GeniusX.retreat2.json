90591922775185940_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nR-lWT201MMQ7kNvgEUCIeT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlRRRZCMlii08OzB4hnTlp9g2RqqeGu6AeZznKCsC4dg&oe=676154AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031642_1107542336615473_6053581035555005591_n.png", "id": "813181176440829", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203623_813181179774162_76645970692002799_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NLKCzAMZN0UQ7kNvgG-q4F5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIGgJ4VCiD7O7wybff2IBWL_R7AdNZ7oGnogeFINvkLw&oe=67615F38"}, "display_name": "Retreat", "keywords": ["education", "learning", "mindfulness", "friends", "community"], "long_description": "Ready to level up your skills, have fun, and meet new people? Don't miss this amazing opportunity!\n\nEDUCATION & PRODUCTIVITY\n\nThink of it like an adult summer camp - with courses from top experts in Art & Creativity, Career & Entrepreneurship, Financial Well-Being to Holistic Wellness.\n\nINTERACT WITH EXPERTS & LIVE EVENTS Get exclusive access and ask questions directly from world renowned instructors who are sharing decades worth of their expertise through immersive experiences. Don\u2019t just upgrade the virtual you \u2013 use this chance to grow into a better real life version of yourself!\n\nSOCIAL CLASSROOMS\n\nLearning together is the way to go! Get your friends and family involved in mastering new skills by studying collaboratively in social classrooms. Studies prove it \u2013 group learning helps you remember what you learn better too!", "short_description": "Ready to level up your skills, have fun, and meet new people? You don't want to miss this amazing opportunity! Think of it like an adult summer camp - with courses from top experts in Art & Creativity, Career & Entrepreneurship, Financial Well-Being to Holistic Wellness. Get exclusive access and ask questions directly from world renowned instructors who are sharing decades worth of their expertise through immersive experiences. Upgrade your real world Avatar, that is you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retreatvr.io/privacy-policy/", "developer_terms_of_service_url": "https://retreatvr.io/terms-of-service/", "publisher_name": "GeniusX Inc", "support_website_url": null, "website_url": "https://www.RetreatVR.io/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "933990497937085"}, "review_messages": ["", "VRC.Quest.Asset.5 - Screenshots must be representative of the app and showcase in-game content only. Please replace edited images.", "VRC.Quest.Asset.5 - Screenshots must be representative of the app and showcase in-game content only."]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036702_1263619724516017_1827925776562210043_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BSUEG2n15FEQ7kNvgEiYt55&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdtzmka2acvL7novnQxkcNWkpOoHBv_I_OirBuvZVGzw&oe=6761767A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Retreat", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}],