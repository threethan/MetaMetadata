le_name": "menu_screen.png", "id": "207037745267399", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974886_207037748600732_3890591922775185940_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ipk0D6T4QokQ7kNvgFyJZlI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AERKx9pFFFLcVJT_15N9R4E&oh=00_AYDc9KawrYjmnOpjejFNodhZ5Ko--Rrj0yAiQg99Hxo5jQ&oe=66E2C4AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031642_1107542336615473_6053581035555005591_n.png", "id": "813181176440829", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203623_813181179774162_76645970692002799_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tvZK1gLh3cUQ7kNvgHHZiBn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AERKx9pFFFLcVJT_15N9R4E&oh=00_AYDnVLqH-FqT-NiQa3nJ5WylWIv6gFcx5_RVoiZwnIm12g&oe=66E2CF38"}, "display_name": "Retreat", "keywords": ["education", "learning", "mindfulness", "friends", "community"], "long_description": "Ready to level up your skills, have fun, and meet new people? Don't miss this amazing opportunity!\n\nEDUCATION & PRODUCTIVITY\n\nThink of it like an adult summer camp - with courses from top experts in Art & Creativity, Career & Entrepreneurship, Financial Well-Being to Holistic Wellness.\n\nINTERACT WITH EXPERTS & LIVE EVENTS Get exclusive access and ask questions directly from world renowned instructors who are sharing decades worth of their expertise through immersive experiences. Don\u2019t just upgrade the virtual you \u2013 use this chance to grow into a better real life version of yourself!\n\nSOCIAL CLASSROOMS\n\nLearning together is the way to go! Get your friends and family involved in mastering new skills by studying collaboratively in social classrooms. Studies prove it \u2013 group learning helps you remember what you learn better too!", "short_description": "Ready to level up your skills, have fun, and meet new people? You don't want to miss this amazing opportunity! Think of it like an adult summer camp - with courses from top experts in Art & Creativity, Career & Entrepreneurship, Financial Well-Being to Holistic Wellness. Get exclusive access and ask questions directly from world renowned instructors who are sharing decades worth of their expertise through immersive experiences. Upgrade your real world Avatar, that is you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retreatvr.io/privacy-policy/", "developer_terms_of_service_url": "https://retreatvr.io/terms-of-service/", "publisher_name": "GeniusX Inc", "support_website_url": null, "website_url": "https://www.RetreatVR.io/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "933990497937085"}, "review_messages": ["", "VRC.Quest.Asset.5 - Screenshots must be representative of the app and showcase in-game content only. Please replace edited images.", "VRC.Quest.Asset.5 - Screenshots must be representative of the app and showcase in-game content only."]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036702_1263619724516017_1827925776562210043_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y7UkGkLNtJAQ7kNvgFwPTiO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AERKx9pFFFLcVJT_15N9R4E&oh=00_AYBacNBkqAtGyLghiPauF_2XWdKdktJEMDIuB59qkitGow&oe=66E2E67A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Retreat", "platfo