01722_2920586988056070_8473383748115628032_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_J66W4FL4_MQ7kNvgGwA9VW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL-0Vvx3TpzkLyKnuWtVUS3&oh=00_AYAEX-vcOoOQyyjz6YZ8gurmejYrSSraGJPY8yInJLbq9w&oe=66EC0C7F"}, {"file_name": "migrated_image.png", "id": "1389141664599467", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974814_1686980521432583_1760242842472546304_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YX-uVHE0Nm8Q7kNvgEqwhru&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL-0Vvx3TpzkLyKnuWtVUS3&oh=00_AYB36688LipmpYPPpnQ3GrNFFaWnASFpW30KOUBJuhWdGg&oe=66EC1705"}, {"file_name": "U9fq65.png", "id": "264496061263208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974454_264496064596541_1144932929860796416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WEzrw5n3mYIQ7kNvgHlSAPb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL-0Vvx3TpzkLyKnuWtVUS3&oh=00_AYDrEuzYEf4hrhKR9Eol2TeVLisM8ONzhK0T2yLcmrxhxg&oe=66EC0A5B"}, {"file_name": "hzpAiw.png", "id": "645984319585548", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86625136_645984322918881_7380021478420381696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HKT5k9FI1BwQ7kNvgFYimAN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL-0Vvx3TpzkLyKnuWtVUS3&oh=00_AYAYi8xr1GPTKUvta3afLV7-60Vnn070I9PKF0WeiDIF9w&oe=66EC1689"}, {"file_name": "GHYni9.png", "id": "1333858383670102", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86624300_1333858387003435_7792963003174879232_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ntv4j5V14QEQ7kNvgEUL6mj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL-0Vvx3TpzkLyKnuWtVUS3&oh=00_AYCAJN7vOtyAohdaGBtu4t9dYuo3RQReHhdcPvSsKlrJ5A&oe=66EC0842"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/oL1aLO", "id": "628657391198278", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974442_628657394531611_8488709084780953600_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vBYtbeGAjmIQ7kNvgEtugJi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL-0Vvx3TpzkLyKnuWtVUS3&oh=00_AYCy6JZC1y_tD23qKsspxP5SeyEOh068KtvrzgdBij18CQ&oe=66EC0D96"}, "display_name": "Audio Trip", "keywords": ["dance", "rhythm", "music", "beat", "fitness"], "long_description": "Audio Trip is a VR dance game that takes players through surreal environments specially crafted for each song. Catch gems, ride ribbons, smash drums, and dodge barriers -- which together form exhilarating dance choreographed by a professional dancer.\nShow off your flair and make this YOUR audio trip!\nFeatures\n\u2022 Licensed music by top artists:\n - Skrillex, Zedd, deadmau5, Lady Gaga, and more.\n - 11 unique tracks available so far, with many more coming soon.\n\u2022 Three levels of difficulty for each track.\n\u2022 \u2018Full\u2019 or \u2018Short Trip\u2019 options for each song.\n\u2022 In-VR level editor (\u201cChoreographer\u201d tool) included.\n\u2022 Fully immersive dynamic environments for each song.\n\u2022 Intuitive UI - pick up and play.\n\u2022 Simple tutorial included for each first-time player.\n\u2022 Optional \u2018Comfort\u2019 mode for visually sensitive players.\n\u2022 Optional \u2018Dancer\u2019 mode to follow along with \u201cGoldie\u201d the dancer.\n\u2022 Optional \u2018No Fail\u2019 mode.\n\u2022 Optional \u2018Color swap\u2019 mode.\n\u2022 Much more content being continuously developed and added.", "short_description": "Audio Trip is a VR dance game. Players move their bodies to catch colored gems, ride ribbons, smash drums, and dodge barriers -- which together form exhilarating dance choreographed by a professional dancer."}]}, "developer_name": "Kinemotik Studios", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.enterandromeda.com/legal/audio_trip.html", "publisher_name": "Andromeda Entertainment", "support_website_url": "http://audio.chat/", "website_url": "http://audiotripvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topic