1.oculuscdn.com&oh=00_AYAZiLM6fAWx6fMvKLPvT7XA5hfi91dlLHgv5Ir-lSVrJQ&oe=67178DFF"}, {"file_name": "migrated_image.png", "id": "1389141664599467", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974814_1686980521432583_1760242842472546304_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mO16rG6nhecQ7kNvgGOsYei&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBtutLiFBXcMaYwFoeEZeZImWiscRfz2wI0F7Zubofk0w&oe=67179885"}, {"file_name": "U9fq65.png", "id": "264496061263208", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974454_264496064596541_1144932929860796416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RCfi7DO-17UQ7kNvgGjL5cN&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCv4JSITDXYEiKc2OmW8ubw318zMkYvlYQ8oIKGL7tyNw&oe=67178BDB"}, {"file_name": "hzpAiw.png", "id": "645984319585548", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86625136_645984322918881_7380021478420381696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iGOHgNx3jNAQ7kNvgGwgx2N&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANa3nFRu6vMXpk5_5xORvmYLbF-glR2_7U1RRpbUlyNQ&oe=67179809"}, {"file_name": "GHYni9.png", "id": "1333858383670102", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86624300_1333858387003435_7792963003174879232_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dgMuhtvKsT8Q7kNvgHu0U69&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJ-0_mHKjpfGW0GJ8BUAeLIcA9VdLSRqkwC76rZJbOEw&oe=671789C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/oL1aLO", "id": "628657391198278", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974442_628657394531611_8488709084780953600_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cYZgy9tJZAsQ7kNvgHUxrUl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCHTduGC-9fB1cTdJXrKPNMh4nN-bRTh18uw-vWx5UAug&oe=67178F16"}, "display_name": "Audio Trip", "keywords": ["dance", "rhythm", "music", "beat", "fitness"], "long_description": "Audio Trip is a VR dance game that takes players through surreal environments specially crafted for each song. Catch gems, ride ribbons, smash drums, and dodge barriers -- which together form exhilarating dance choreographed by a professional dancer.\nShow off your flair and make this YOUR audio trip!\nFeatures\n\u2022 Licensed music by top artists:\n - Skrillex, Zedd, deadmau5, Lady Gaga, and more.\n - 11 unique tracks available so far, with many more coming soon.\n\u2022 Three levels of difficulty for each track.\n\u2022 \u2018Full\u2019 or \u2018Short Trip\u2019 options for each song.\n\u2022 In-VR level editor (\u201cChoreographer\u201d tool) included.\n\u2022 Fully immersive dynamic environments for each song.\n\u2022 Intuitive UI - pick up and play.\n\u2022 Simple tutorial included for each first-time player.\n\u2022 Optional \u2018Comfort\u2019 mode for visually sensitive players.\n\u2022 Optional \u2018Dancer\u2019 mode to follow along with \u201cGoldie\u201d the dancer.\n\u2022 Optional \u2018No Fail\u2019 mode.\n\u2022 Optional \u2018Color swap\u2019 mode.\n\u2022 Much more content being continuously developed and added.", "short_description": "Audio Trip is a VR dance game. Players move their bodies to catch colored gems, ride ribbons, smash drums, and dodge barriers -- which together form exhilarating dance choreographed by a professional dancer."}]}, "developer_name": "Kinemotik Studios", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.enterandromeda.com/legal/audio_trip.html", "publisher_name": "Andromeda Entertainment", "support_website_url": "http://audio.chat/", "website_url": "http://audiotripvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", 