311303855068168212_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYCT3fJe2ioQ7kNvgHVflB-&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad9EWhXEuqis0UsKobHY5cM&oh=00_AYA3Xy0Zwn_qK8ennH-pTUNLIsEoMr8pNvuNc1AB7KjMKA&oe=66ED55C7"}, {"file_name": "Screenshot04.png", "id": "7086809438075179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035458_7086809441408512_8159876966003429488_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-jIQB3n4LOMQ7kNvgEA8A_9&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad9EWhXEuqis0UsKobHY5cM&oh=00_AYCqOQm3c9wGKHBCyPpFKoKbgI3qv-5aqKl1v5ZNRL_dDA&oe=66ED7028"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7365976890103381", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031511_7365976896770047_3665999971173599018_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SVk0DgW94wQQ7kNvgErnygV&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad9EWhXEuqis0UsKobHY5cM&oh=00_AYCrTBZGXTTb0p_kmOToOJCwPlAe9qG80k929e7XpHZ7Gg&oe=66ED52D7"}, "display_name": "Artefacto", "keywords": [], "long_description": "Can you protect humanity\u2019s greatest treasures from an overexcited alien?\nAn alien has studied our planet \u2013 and its human occupants \u2013 and is not entirely convinced that we appreciate the richness and importance of our cultural heritage. For reasons best known to themselves, they decide to quiz us, testing our knowledge of a variety of cultural collections relating to topics such as Stonehenge, Ancient Egypt and the planet Mars.\nAnswer correctly, and we are rewarded with a copy of a cultural artefact, to keep in our own collection. Get them wrong and\u2026 well, just try to get them right, ok?\n\nCulture Quest Demo Features:\n- Play in Mixed Reality on Quest 3 or Quest Pro\n- Use grab & throw physics to reveal hidden Mixed Reality views through your walls and ceiling\n- Explore three example levels, each with their own trivia questions and Mixed Reality view back through time\n- Collect artefacts from ancient cultures around the world and even from space\n- Requires a play area of 3m x 3m", "short_description": "Can you protect humanity\u2019s greatest treasures from an overexcited alien?\nAn alien has studied our planet \u2013 and its human occupants \u2013 and is not entirely convinced that we appreciate the richness and importance of our cultural heritage. So they have decided to test our knowledge of a variety of cultural collections around the world.\nAnswer correctly, and we are rewarded with a copy of a cultural artefact, to keep in our own collection. Get them wrong and\u2026 well, just try to get them right, ok?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.arcade-xr.com/app-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "ARCADE", "support_website_url": null, "website_url": "https://arcade-xr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24527662743514780"}, "review_messages": ["", "", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575360_1765509100581897_4495388328767162677_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RzSdJzCOrkgQ7kNvgG5ToEx&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad9EWhXEuqis0UsKobHY5cM&oh=00_AYBHfED5gH7mSn3I-t2BuF9PDDjRqcuwQZ99PImiERW9eQ&oe=66ED7819"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Artef