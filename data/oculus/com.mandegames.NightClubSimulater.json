uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_1090532505187559_139531054362447348_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GOtnbrDezUMQ7kNvgF68nFD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvFpWtCWSpRtR9DUa7m9n2J&oh=00_AYAqxhfegVKX2h_CPm5-ptjxxDUntJEI5ub0aUcbFgGQ_w&oe=66E96C74"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fotor_2023-2-23_23_41_53.png", "id": "1095254868210222", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375759_1095254871543555_2151072909448793447_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MfXAAKc2D0gQ7kNvgGP1-27&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvFpWtCWSpRtR9DUa7m9n2J&oh=00_AYDldZWmDOGO8PSjG8414I82qSgSAruZStj_44sy7AiG2g&oe=66E96DC3"}, "display_name": "NightClub Simulator VR", "keywords": [], "long_description": "Night Club Simulator is a highly immersive VR game with a great degree of freedom. It uses a fully physics-based animation system to simulate NPC behaviors and reactions, allowing you to interact with them as if you were in the real world. NPCs have realistic AI, displaying emotions such as happiness, anger, fear, or affection. Their emotions will change depending on your actions. You can do whatever you want here, cause chaos, but you have to watch out for the police. Experience a lifelike and interactive night club adventure with Night Club Simulator.", "short_description": "Experience a virtual nightclub with a high degree of freedom."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mandegames.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "mandegames", "support_website_url": null, "website_url": "https://mandegames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQU