ent-iad3-1.oculuscdn.com&oh=00_AYCIBpm0fUNkLcmKnACn7RQ5FmoMElvwGbWHtRd10pY_yg&oe=67091D86"}, {"file_name": "2022-08-07 130919.png", "id": "1090532501854226", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982447_1090532505187559_139531054362447348_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tQnjpppTLF8Q7kNvgEd8RQA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfYbPVJn68SZp4oum38cHvFBX5Qw9SNqRcNm2b9nkohg&oe=67091074"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2022-08-07 1309191.png", "id": "448389313929129", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984471_448389317262462_4742164588630018022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UZJ19BxZhvUQ7kNvgEgQeNC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnjzFUdxTnSW8T7POeMYxAJFtNjm6dxj8f6MLQ5rpvAA&oe=6708F652"}, "display_name": "Night Club Simulator -- DEMO", "keywords": [], "long_description": "Night Club Simulator is a high degree of freedom VR game. use fully physics based animation system to simulate NPC's behaviours and reactions, so you can interact with them like real world. the NPC have realistic AI, they will happy, anger, scare or love. their emotion will change depend on what you do. The goal of this game is open, you can provoke and fight with any people, dance and kiss with girls, but you need be careful her boy friend when you accost a girl.\n\nGuide:\nMove--left Joystick\nTurn--right Joystick\nGrab Objects--left or right Grip button\nOpen/Close Menu--left menu button or X button\n\nthere are several ways you can interact with a girl:\n1, wave your hand\n2, clap hands when a girl is dancing, the palm relative and clap\n3, shake hand, reach out one hand to a girl\n4, dancing, the palm up, reach out one hand to a girl\n5, hug and kiss, open arms, reach out double hands to a girl\n\nThis game still in development, Join Discard: https://discord.gg/rSUKqXcg3u for any suggestion.", "short_description": "seduce girls or get into fights, you ca