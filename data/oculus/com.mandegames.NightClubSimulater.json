ds": [], "long_description": "Night Club Simulator is a high degree of freedom VR game. use fully physics based animation system to simulate NPC's behaviours and reactions, so you can interact with them like real world. the NPC have realistic AI, they will happy, anger, scare or love. their emotion will change depend on what you do. The goal of this game is open, you can provoke and fight with any people, dance and kiss with girls, but you need be careful her boy friend when you accost a girl.\n\nGuide:\nMove--left Joystick\nTurn--right Joystick\nGrab Objects--left or right Grip button\nOpen/Close Menu--left menu button or X button\n\nthere are several ways you can interact with a girl:\n1, wave your hand\n2, clap hands when a girl is dancing, the palm relative and clap\n3, shake hand, reach out one hand to a girl\n4, dancing, the palm up, reach out one hand to a girl\n5, hug and kiss, open arms, reach out double hands to a girl\n\nThis game still in development, Join Discard: https://discord.gg/rSUKqXcg3u for any suggestion.", "short_description": "seduce girls or get into fights, you can do anythings in virtual night club that you can't do in real life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mandegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "mandegames", "support_website_url": null, "website_url": "https://mandegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interactio