t64.5771-25/38982678_1276325853195274_8041552784406399158_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_AsPGIaHQ9EQ7kNvgHtpV9r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZqVrWOkep1reis2xZ1HD03eGdVvyxs-H0KjEwwl96Cg&oe=6720D886"}, {"file_name": "2022-08-07 130919.png", "id": "1090532501854226", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982447_1090532505187559_139531054362447348_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BEJfV2JyR_sQ7kNvgEMBuHb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKOvQFbAhD93C0HCu640WC2PsNL2wHNEvnGOJU6iWa0w&oe=6720CB74"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2022-08-07 1309191.png", "id": "448389313929129", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984471_448389317262462_4742164588630018022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=esmm5d5q-T0Q7kNvgHasGs_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBGJ7YlMNVvIT1g3-bsyvqPzd-uRX95_KPR1Awz1pO5jQ&oe=6720B152"}, "display_name": "Night Club Simulator -- DEMO", "keywords": [], "long_description": "Night Club Simulator is a high degree of freedom VR game. use fully physics based animation system to simulate NPC's behaviours and reactions, so you can interact with them like real world. the NPC have realistic AI, they will happy, anger, scare or love. their emotion will change depend on what you do. The goal of this game is open, you can provoke and fight with any people, dance and kiss with girls, but you need be careful her boy friend when you accost a girl.\n\nGuide:\nMove--left Joystick\nTurn--right Joystick\nGrab Objects--left or right Grip button\nOpen/Close Menu--left menu button or X button\n\nthere are several ways you can interact with a girl:\n1, wave your hand\n2, clap hands when a girl is dancing, the palm relative and clap\n3, shake hand, reach out one hand to a girl\n4, dancing, the palm up, reach out one hand to a girl\n5, hug and kiss, open arms, reach out double hands to a girl\n\nThis game still in development, Join Discard: https://discord.gg/rSUKqXcg3u for any suggestion.", "short_description": "seduce girls or get into fights, you can do anythings in virtual night club that you can't do in real life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mandegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "mandegames", "support_website_url": null, "website_url": "https://mandegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "483926886944664"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "877906477134028"}, {"status": "CANCELLED", "id": "513947667884839"}, {"status": "PUBLISHED", "id": "1185672425816294"}, {"status": "PUBLISHED", "id": "285623280609123"}, {"status": "PUBLISHED", "id": "645497327207564"}, {"status": "PUBLISHED", "id": "145371615079796"}]}, "baseline_offer": {"id": "1185672425816294"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726768800, "status": "PUBLISHED", "id": "877906477134028"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8215799671836010", "version": "0.56"}, "id": "579913957109512", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "pri