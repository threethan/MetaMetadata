8.png", "id": "1276325849861941", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982678_1276325853195274_8041552784406399158_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMepLkioKD4Q7kNvgFhABBh&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBJNCGV5QT5zlobVeZr4EQ0tJaUMMYelnMAgaOCjBZEFQ&oe=671A4106"}, {"file_name": "2022-08-07 130919.png", "id": "1090532501854226", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982447_1090532505187559_139531054362447348_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dVRuwiMlOtEQ7kNvgF9W9oq&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAlYGefLO_0qCgKGXSp-bNFSHTynSBasYTfld86vhjgKQ&oe=671A33F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2022-08-07 1309191.png", "id": "448389313929129", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38984471_448389317262462_4742164588630018022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hX_xufnPfSoQ7kNvgGMsJ4T&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYDCP7ZDLZple7eQHmTfu5x9PtrxAx1KmKx8qqqKdxrwBA&oe=671A19D2"}, "display_name": "Night Club Simulator -- DEMO", "keywords": [], "long_description": "Night Club Simulator is a high degree of freedom VR game. use fully physics based animation system to simulate NPC's behaviours and reactions, so you can interact with them like real world. the NPC have realistic AI, they will happy, anger, scare or love. their emotion will change depend on what you do. The goal of this game is open, you can provoke and fight with any people, dance and kiss with girls, but you need be careful her boy friend when you accost a girl.\n\nGuide:\nMove--left Joystick\nTurn--right Joystick\nGrab Objects--left or right Grip button\nOpen/Close Menu--left menu button or X button\n\nthere are several ways you can interact with a girl:\n1, wave your hand\n2, clap hands when a girl is dancing, the palm relative and clap\n3, shake hand, reach out one hand to a girl\n4, dancing, the palm up, r