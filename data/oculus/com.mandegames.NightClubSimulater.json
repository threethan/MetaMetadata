i": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75639802_388553410075356_7160599931928332812_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TcjMc0bKjLwQ7kNvgHdNpvB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCc1f-HtC7RS-eOoa6CzIMfyRrYB3KvrxyvwrCirYQ5LA&oe=673484C4"}, {"file_name": "2022-08-07 131728.png", "id": "1276325849861941", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982678_1276325853195274_8041552784406399158_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AyCqLOvty2cQ7kNvgHQssNk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYARjlgEBCCrnCnfKLulE_g58ixXZqoI8-tkgsHL86CbDw&oe=67349F06"}, {"file_name": "2022-08-07 130919.png", "id": "1090532501854226", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982447_1090532505187559_139531054362447348_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IKo-bP37a9kQ7kNvgFLD_vD&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB-e-xVZNvppNzzD9rRswlx4qGeSDrOBD7NN3tUGBGM8Q&oe=673491F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2022-08-07 1309191.png", "id": "448389313929129", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38984471_448389317262462_4742164588630018022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zgFifxzrY1UQ7kNvgHj-qTi&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA1pNGJtJ1u2fjlZAmb_PTGeoF9E0oYg_xEvWey8hgE8g&oe=673477D2"}, "display_name": "Night Club Simulator -- DEMO", "keywords": [], "long_description": "Night Club Simulator is a high degree of freedom VR game. use fully physics based animation system to simulate NPC's behaviours and reactions, so you can interact with them like real world. the NPC have realistic AI, they will happy, anger, scare or love. their emotion will change depend on what you do. The goal of this game is open, you can provoke and fight with any people, dance and kiss with girls, but you need be careful her boy friend when you accost a girl.\n\nGuide:\nMove--left Joystick\nTurn--right Joystick\nGrab Objects--left or right Grip button\nOpen/Close Menu--left menu button or X button\n\nthere are several ways you can interact with a girl:\n1, wave your hand\n2, clap hands when a girl is dancing, the palm relative and clap\n3, shake hand, reach out one hand to a girl\n4, dancing, the palm up, reach out one hand to a girl\n5, hug and kiss, open arms, reach out double hands to a girl\n\nThis game still in development, Join Discard: https://discord.gg/rSUKqXcg3u for any suggestion.", "short_description": "seduce girls or get into fights, you can do anythings in virtual night club that you can't do in real life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mandegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "mandegames", "support_website_url": null, "website_url": "https://mandegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "483926886944664"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "877906477134028"}, {"status": "CANCELLED", "id": "513947667884839"}, {"status": "PUBLISHED", "id": "1185672425816294"}, {"status": "PUBLISHED", "id": "285623280609123"}, {"status": "PUBLISHED", "id": "645497327207564"}, {"status": "PUBLISHED", "id": "145371615079796"}]}, "baseline_offer": {"id": "11