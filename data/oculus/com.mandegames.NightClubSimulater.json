ekMLy6aDew&oe=66D1BE86"}, {"file_name": "2022-08-07 130919.png", "id": "1090532501854226", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_1090532505187559_139531054362447348_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=34wNu2Fyt28Q7kNvgHq7y0x&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmKAjA3AbAFQjaTiKoaunUF&oh=00_AYCm37yJFJcbvq2cx1hjeDUR3sBVchr73AnjnP0F9y9Eiw&oe=66D1B174"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2022-08-07 1309191.png", "id": "448389313929129", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_448389317262462_4742164588630018022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bXG9lLpVw34Q7kNvgF-OvWl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmKAjA3AbAFQjaTiKoaunUF&oh=00_AYC0Jj8jyf7FPcCeg_6goG-T67H3DH6dlU4kH9lWA0llHg&oe=66D19752"}, "display_name": "Night Club Simulator -- DEMO", "keywords": [], "long_description": "Night Club Simulator is a high degree of freedom VR game. use fully physics based animation system to simulate NPC's behaviours and reactions, so you can interact with them like real world. the NPC have realistic AI, they will happy, anger, scare or love. their emotion will change depend on what you do. The goal of this game is open, you can provoke and fight with any people, dance and kiss with girls, but you need be careful her boy friend when you accost a girl.\n\nGuide:\nMove--left Joystick\nTurn--right Joystick\nGrab Objects--left or right Grip button\nOpen/Close Menu--left menu button or X button\n\nthere are several ways you can interact with a girl:\n1, wave your hand\n2, clap hands when a girl is dancing, the palm relative and clap\n3, shake hand, reach out one hand to a girl\n4, dancing, the palm up, reach out one hand to a girl\n5, hug and kiss, open arms, reach out double hands to a girl\n\nThis game still in development, Join Discard: https://discord.gg/rSUKqXcg3u for any suggestion.", "short_description": "seduce girls or get into fights, you can do anythings in virtual night club that you can't do in real life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mandegames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "mandegames", "support_website_url": null, "website_url": "https://mandegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "483926886944664"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "285623280609123"}, {"status": "PUBLISHED", "id": "645497327207564"}, {"status": "PUBLISHED", "id": "145371615079796"}]}, "baseline_offer": {"id": "285623280609123"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1688399704, "status": "PUBLISHED", "id": "285623280609123"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7859481970801117", "version": "0.54"}, "id": "579913957109512", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5332536576829015", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7859481970801117"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "579913957109512"}]}, "change_log": null, "created_date": 1721055585, "id": "78