2621_1054895899098400_3576986833825981806_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PWvu0wIC73oQ7kNvgEnCu2o&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCTPLH07o-PREbuGWyZug0TbJsb1MPYrRyFStSPUfVgIw&oe=67124FB7"}, {"file_name": "2024-10-01 220932-fotor-20241001221821.png", "id": "496949326573832", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39031597_496949329907165_8371581491091993146_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5hrmSMb6pzgQ7kNvgHD2KCe&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCSk0bekVKNe3PwCWy8O2K780nhIzM2dP40fUNF7ZntGw&oe=67124A35"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Night-club-simulator-2560-X1440_3x.png", "id": "1751393498962286", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982539_1751393502295619_1126416376167818254_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qu10RTsRlpwQ7kNvgHdkhfk&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD3zB8fmCtoMtQM3PzShi8_waW5uzoqXDZjG1VEaTu4DA&oe=671251E5"}, "display_name": "NightClub Simulator VR", "keywords": [], "long_description": "Night Club Simulator is a highly immersive VR game with a great degree of freedom. It uses a fully physics-based animation system to simulate NPC behaviors and reactions, allowing you to interact with them as if you were in the real world. NPCs have realistic AI, displaying emotions such as happiness, anger, fear, or affection. Their emotions will change depending on your actions. You can do whatever you want here, cause chaos, but you have to watch out for the police. Experience a lifelike and interactive night club adventure with Night Club Simulator.", "short_description": "Experience a virtual nightclub with a high degree of freedom."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mandegames.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "mandegames", "support_website_url": null, "website_url": "https://mandegames.com/", "category": "GAMES",