s high fidelity graphics and effects, utilizing Application Spacewarp to get the most out of your device.", "short_description": "Haunted by an unmoving creature whilst suffering from very dry eyes."}]}, "developer_name": "Krakentanz", "developer_privacy_policy_url": "http://www.mitgutemerfolg.org/krakentanz/ug/legal/legal.html", "developer_terms_of_service_url": null, "publisher_name": "Krakentanz", "support_website_url": null, "website_url": "http://www.krakentanz.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "EXPLORATION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1343909206073434"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "2551221971748143"}, {"status": "PUBLISHED", "id": "691402005299650"}, {"status": "PUBLISHED", "id": "676019157926305"}, {"status": "PUBLISHED", "id": "3020791834799235"}]}, "baseline_offer": {"id": "2551221971748143"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729772041, "status": "PUBLISHED", "id": "2551221971748143"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7372920129434117", "version": "1.6"}, "id": "1070885147069217", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppB