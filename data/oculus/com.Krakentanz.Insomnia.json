=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wKneySAgpD8Q7kNvgExBxAf&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDC6ppzYOIF9sdpyJIU2S3wWiGKXHazj5fCLw9Zq-fAwQ&oe=6777C018"}, {"file_name": "Screenshot_Rose_A_01.png", "id": "338937091152635", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982512_338937097819301_7495403605620351691_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=851H-0GYZnIQ7kNvgHGWmq0&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBopN5kzL6SGQmNBDwazEZ5Uk9j5z-X9D-B8KGIwwRKoQ&oe=6777E028"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WalkEat-Teaser_v2_04_normalized_thumbnail.png", "id": "473000464364992", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031383_473000467698325_3576075146764866845_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DKF_Jz-1KQ8Q7kNvgEOKgJR&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDfOeD44f1nn22h2D8p1Dymb66KzKp2Tel6nIwcixvdVg&oe=6777D54A"}, "display_name": "Insomnia", "keywords": ["horror", "backrooms", "jumpscare", "blink", "creature"], "long_description": "An ***eerie*** VR experience about a ***hauting creature that never seems to move***, yet follows you through the unsettling corridors of an abandoned hotel. Worse still, your vision blurs as your eyes grow heavy, forcing you to blink more often than you'd prefer ... \n\nInsomnia is perfect for ***solo thrills*** or as a ***party experience***. Hand over the headset and watch as your friends confront the creature and attempt their escape, knowing that every blink could be their last.\n\nWith ***high-fidelity graphics*** and effects, immersive soundscapes, and ***Application Spacewarp optimization*** this short VR experience pushes your device\u2019s performance.", "short_description": "Haunted by an unmoving creature. Blink, and it inches closer. Hold your gaze to survive \u2014 will you find the way out before it closes in?"}]}, "developer_name": "Krakentanz", "developer_privacy_policy_url": "http://ww