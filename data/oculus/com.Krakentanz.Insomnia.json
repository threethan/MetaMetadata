16962664529_3297886005740334078_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8bD3MylTiYQQ7kNvgHTlQaw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5MAXw2PIDN1MhnEvH2BoMT1ar0qoFJM6yBSOiIVbbyw&oe=67851209"}, {"file_name": "Screenshot_StichgangBelle_A_02.png", "id": "608858426841573", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982699_608858430174906_2600919328073995788_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M8UwfRYjgH0Q7kNvgEi9KT5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBAXQ77DlUn8XamooHGk7-G0IYyKcDYkONvcre5hPzk9g&oe=6784EF18"}, {"file_name": "Screenshot_Rose_A_01.png", "id": "338937091152635", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982512_338937097819301_7495403605620351691_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ghlC51UMhrcQ7kNvgHKs70P&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUDpLjrrK14s0y8LqDkSDooT3FNOERBrj7Shd8mSzxSQ&oe=67850F28"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WalkEat-Teaser_v2_04_normalized_thumbnail.png", "id": "473000464364992", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031383_473000467698325_3576075146764866845_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TmEN48yxvXIQ7kNvgG91nRf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCx2U6sbY_Q7vz_2kAu4EhpPqpTqLbdrOLRF06peDUWxQ&oe=6785044A"}, "display_name": "Insomnia", "keywords": [], "long_description": "-------------------------------------------------------\nALL PROCEEDS GO TO UKRAINE \n\n100% of our earnings go to support humanitarian aid for Ukraine. The money will be donated to the tireless Doctors Without Borders (MSF).\n-------------------------------------------------------\n\nAn eerie VR experience about a hauting creature that never seems to move, yet follows you through the corridors of an abandoned hotel. Worse still, your increasingly dry eyes and blurry vision force you to blink more often than you'd prefer ...\n\nThis short game features high fidelity graphics and effects, utilizing Application Spacewarp to get the most out of your device.", "short_description": "Haunted by an unmoving creature whilst suffering from very dry eyes."}]}, "developer_name": "Krakentanz", "developer_privacy_policy_url": "http://www.mitgutemerfolg.org/krakentanz/ug/legal/legal.html", "developer_terms_of_service_url": null, "publisher_name": "Krakentanz", "support_website_url": null, "website_url": "http://www.krakentanz.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "EXPLORATION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1343909206073434"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "2551221971748143"}, {"status": "PUBLISHED", "id": "691402005299650"}, {"status": "PUBLISHED", "id": "676019157926305"}, {"status": "PUBLISHED", "id": "3020791834799235"}]}, "baseline_offer": {"id": "2551221971748143"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729772041, "status": "PUBLISHED", "id": "2551221971748143"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7372920129434117", "version": "1.6"}, "id": "1070885147069217", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppB