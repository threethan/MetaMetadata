ng?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rOYy-xIsGKsQ7kNvgH4iYYh&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCCX47WYNWBROsYFrLTISbqho8sYvLrTxKk3ravbiONdw&oe=677E5798"}, {"file_name": "Screenshot_Rose_A_01.png", "id": "338937091152635", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982512_338937097819301_7495403605620351691_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iDdb7nbht9oQ7kNvgH2aeex&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYC8dQJbqgOTvgN1rCMhyGCuhtEIbOu4oVjnacQ2oRh8hQ&oe=677E77A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WalkEat-Teaser_v2_04_normalized_thumbnail.png", "id": "473000464364992", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031383_473000467698325_3576075146764866845_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j6JfC7GhCv8Q7kNvgH-Im8d&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYAJQJ2YkFaBvQSVpEdXLq_vpPD0Y_GFI7m0dmfk0NkJRw&oe=677E6CCA"}, "display_name": "Insomnia", "keywords": ["horror", "backrooms", "jumpscare", "blink", "creature"], "long_description": "An ***eerie*** VR experience about a ***hauting creature that never seems to move***, yet follows you through the unsettling corridors of an abandoned hotel. Worse still, your vision blurs as your eyes grow heavy, forcing you to blink more often than you'd prefer ... \n\nInsomnia is perfect for ***solo thrills*** or as a ***party experience***. Hand over the headset and watch as your friends confront the creature and attempt their escape, knowing that every blink could be their last.\n\nWith ***high-fidelity graphics*** and effects, immersive soundscapes, and ***Application Spacewarp optimization*** this short VR experience pushes your device\u2019s performance.", "short_description": "Haunted by an unmoving creature. Blink, and it inches closer. Hold your gaze to survive \u2014 will you find the way out before it closes in?"}]}, "developer_name": "Krakentanz", "developer_privacy_policy_url"