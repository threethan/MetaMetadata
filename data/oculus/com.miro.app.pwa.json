c_ohc=IaRsuKB_3s0Q7kNvgEA6MZX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_WIJQVbOz-ex0ixb5AaY0GPbZXTKVS4qP0vZ_NdbvAQ&oe=677A69E1"}, {"file_name": "com.oculus.shellenv-20211130-114336 (1).png", "id": "615008293152701", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_615008299819367_4109496001641683634_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7QX9nYBiNPgQ7kNvgEnDZsg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCedwzM2g-Po3gGaguWnZeFbvsxUaWFbBgaM4d3E4lnsg&oe=677A7F46"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot 2021-12-05 at 17.41.26.png", "id": "1288205531608958", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_1288205534942291_6447482674783543975_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=teLWg1qG_pEQ7kNvgEj2WAd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCT4LUjmHWgqLkb8G3BWdH0MyPZoCDuXvSp63ik5S9JmQ&oe=677A5845"}, "display_name": "Miro", "keywords": [], "long_description": "Miro unlocks creativity with:\n\n- An infinite canvas to help you ideate, strategize, get organized, and work with your team without constraints\n- Whiteboarding tools like sticky notes, a pen, shapes, arrows, and smart drawing that let you easily co-create\n- 200+ best-practice templates to help you easily facilitate brainstorming, Agile rituals, design-thinking activities, and strategic planning\n- Integrations with your favorite tools including Dropbox, Box, Google Suite, JIRA, Slack, and Sketch to streamline your workflows and see the big picture of your projects", "short_description": "Miro is the online whiteboard for team collaboration. With the magic of Miro, visualizing concepts, ideas, and solutions as a team can happen anywhere, any time. Miro helps teams sync, flow, and feel the connection of working side by side \u2014 even in remote, distributed, and hybrid work environments."}]}, "developer_name": "Miro", "developer_privacy_policy_url": "https://miro.com/legal/pr