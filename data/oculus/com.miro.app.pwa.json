/38974762_642766500078331_7578208648623068373_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O6ufHYheOnQQ7kNvgFi6iUa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmIY5Hn9aGBbV4ZNxrKXomw&oh=00_AYA_CD8s4t_7CqGz487xk3B0A5oNAX7InJgIIuS-HCSLGw&oe=66E81361"}, {"file_name": "com.oculus.shellenv-20211130-114336 (1).png", "id": "615008293152701", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_615008299819367_4109496001641683634_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aDGD6F18Lu8Q7kNvgG91S-q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmIY5Hn9aGBbV4ZNxrKXomw&oh=00_AYCc7x5Pbex14XBK_LSO_h1wZYcGKnTdah_VdDMUzfMZbw&oe=66E828C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot 2021-12-05 at 17.41.26.png", "id": "1288205531608958", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003281_1288205534942291_6447482674783543975_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VAhs3NADHg0Q7kNvgHCO7yZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmIY5Hn9aGBbV4ZNxrKXomw&oh=00_AYDioCqnn1JMxHGWdP6lfRlvyh8HyKzZSo79BDUFbYOw_w&oe=66E801C5"}, "display_name": "Miro", "keywords": [], "long_description": "Miro unlocks creativity with:\n\n- An infinite canvas to help you ideate, strategize, get organized, and work with your team without constraints\n- Whiteboarding tools like sticky notes, a pen, shapes, arrows, and smart drawing that let you easily co-create\n- 200+ best-practice templates to help you easily facilitate brainstorming, Agile rituals, design-thinking activities, and strategic planning\n- Integrations with your favorite tools including Dropbox, Box, Google Suite, JIRA, Slack, and Sketch to streamline your workflows and see the big picture of your projects", "short_description": "Miro is the online whiteboard for team collaboration. With the magic of Miro, visualizing concepts, ideas, and solutions as a team can happen anywhere, any time. Miro helps teams sync, flow, and feel the connection of working side by side \u2014 even in remote, distributed, and hybrid work environments."}]}, "developer_name": "Miro", "developer_privacy_policy_url": "https://miro.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://miro.com/legal/terms-of-service/", "publisher_name": "Miro", "support_website_url": "https://help.miro.com/hc/en-us", "website_url": "https://www.miro.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "5108963129124071"}, {"id": "1063584910766706"}, {"id": "393222478507326"}, {"id": "323450648956687"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY", "UTILITY", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "472216757677394"}, "review_messages": ["", "- All image assets must include App Name & Logo as the largest element. See Asset Design Guidelines:   https://developer.oculus.com/resources/asset-guidelines/\n"]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031527_488301792876795_5055339541598633920_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9vg9WRIFj-0Q7kNvgGZKY6_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmIY5Hn9aGBbV4ZNxrKXomw&oh=00_AYB-N7sgLEP6wu48LSBzJicKCLiyZmy7cRCmt22DYMEaig&oe=66E7FB31"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Miro", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "2D", "id": "5108963129124071"}, {"topic_name": "Productivi