c_ohc=GHrTFlGey4sQ7kNvgEWHPj7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC41LREm7bzf3YIM0LZm3i5YIJqQRRgFWmDhdYFumYkSw&oe=674850E1"}, {"file_name": "com.oculus.shellenv-20211130-114336 (1).png", "id": "615008293152701", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_615008299819367_4109496001641683634_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hqfQM96e6PUQ7kNvgH7EbTI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMHjAlbWDdV_2dLL0VfnL2M_yPA_SeED8evKrmJn48yQ&oe=67486646"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot 2021-12-05 at 17.41.26.png", "id": "1288205531608958", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_1288205534942291_6447482674783543975_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u9iknaV-__wQ7kNvgE2H9um&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZpF58U57Y84vdg7rsBY-im9aauinezkDP0MKbybtqHA&oe=67483F45"}, "display_name": "Miro", "keywords": [], "long_description": "Miro unlocks creativity with:\n\n- An infinite canvas to help you ideate, strategize, get organized, and work with your team without constraints\n- Whiteboarding tools like sticky notes, a pen, shapes, arrows, and smart drawing that let you easily co-create\n- 200+ best-practice templates to help you easily facilitate brainstorming, Agile rituals, design-thinking activities, and strategic planning\n- Integrations with your favorite tools including Dropbox, Box, Google Suite, JIRA, Slack, and Sketch to streamline your workflows and see the big picture of your projects", "short_description": "Miro is the online whiteboard for team collaboration. With the magic of Miro, visualizing concepts, ideas, and solutions as a team can happen anywhere, any time. Miro helps teams sync, flow, and feel the connection of working side by side \u2014 even in remote, distributed, and hybrid work environments."}]}, "developer_name": "Miro", "developer_privacy_policy_url": "https://miro.com/legal/pr